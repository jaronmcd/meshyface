    }}

    async function applyDeviceBroadcastSettings() {{
      if (settingsApplyInFlight) return;
      const nodeBroadcastSecs = readNumberValue("settings-device-node-broadcast-secs");
      if (!Number.isFinite(nodeBroadcastSecs) || Number(nodeBroadcastSecs) < 60) {{
        setText("settings-apply-status", "Node broadcast interval must be at least 60 seconds.");
        return;
      }}
      if (
        Number(nodeBroadcastSecs) < recommendedNodeBroadcastSecs
        && !window.confirm("Node broadcast interval below 6 hours increases mesh chatter. Apply anyway?")
      ) {{
        return;
      }}

      const ok = await postRadioSettingsPayload(
        {{ local: {{ device: {{ node_info_broadcast_secs: Math.trunc(Number(nodeBroadcastSecs)) }} }} }},
        "Applying node broadcast interval…",
        "device node broadcast interval saved"
      );
      if (ok) {{
        setTimeout(() => {{
          void fetchSettingsFromRadio();
        }}, 600);
      }}
    }}

