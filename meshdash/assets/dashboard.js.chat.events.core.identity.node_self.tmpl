      const outlineDarkLightBand = outlineDarkLightBands[Math.min(outlineDarkLightBands.length - 1, Math.floor(outlineDarkLightFrac * outlineDarkLightBands.length))];
      const outlineDarkLightShift = outlineDarkLightBand + ((outlineDarkLightJitterFrac - 0.5) * 1.6);

