    function chatUnicodeStyleById(styleId) {{
      const cleanId = String(styleId || "").trim();
      if (!cleanId) return null;
      return chatUnicodeStyles.find((style) => style.id === cleanId) || null;
    }}

    function normalizeChatUnicodeGroup(groupId) {{
      const cleanId = String(groupId || "").trim();
      if (chatUnicodeGroups.some((group) => group.id === cleanId)) return cleanId;
      return chatUnicodeGroups[0] ? chatUnicodeGroups[0].id : "math";
    }}

    function transformChatUnicodeText(rawText, styleId) {{
      const style = chatUnicodeStyleById(styleId);
      const text = String(rawText == null ? "" : rawText);
      if (!style) return text;
      if (typeof style.transformText === "function") {{
        return String(style.transformText(text));
      }}
      const map = style.map && typeof style.map === "object" ? style.map : {{}};
      let chars = Array.from(text);
      if (style.reverse) {{
        chars = chars.reverse();
      }}
      const transformed = chars.map((ch) => (
        Object.prototype.hasOwnProperty.call(map, ch) ? map[ch] : ch
      ));
      const combiningMark = Number(style.combiningMark);
      if (Number.isInteger(combiningMark) && combiningMark > 0) {{
        const mark = String.fromCodePoint(combiningMark);
        return transformed
          .map((ch) => (/^\s$/u.test(ch) ? ch : `${{ch}}${{mark}}`))
          .join("");
      }}
      return transformed.join("");
    }}

    function chatUnicodePanelElement() {{
      const panel = document.getElementById("chat-unicode-panel");
      return panel instanceof HTMLElement ? panel : null;
