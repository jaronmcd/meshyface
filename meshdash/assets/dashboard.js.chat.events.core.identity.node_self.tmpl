      const outlineSatJitterFrac = radicalInverse32(mixHash32(baseHash ^ 0xbb67ae85));
      const outlineLightFrac = radicalInverse32(mixHash32(baseHash ^ 0x3a6ef9c1));
      const outlineLightJitterFrac = radicalInverse32(mixHash32(baseHash ^ 0xc6ef372f));
      const outlineDarkSatFrac = radicalInverse32(mixHash32(baseHash ^ 0x510e527f));
      const outlineDarkSatJitterFrac = radicalInverse32(mixHash32(baseHash ^ 0x9b05688c));
      const outlineDarkLightFrac = radicalInverse32(mixHash32(baseHash ^ 0x1f83d9ab));
