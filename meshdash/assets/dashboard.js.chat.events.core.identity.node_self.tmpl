          tintStartHue,
          tintEndHue,
          satMult,
          lightShift,
          darkSatMult,
          darkLightShift,
          outlineHue,
          outlineSatMult,
          outlineLightShift,
          outlineDarkSatMult,
          outlineDarkLightShift,
          vibrance,
