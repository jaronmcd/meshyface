    }}

    function resolveNodeTintStyleState(nodeIdOrProfile, options = null) {{
      const opts = options && typeof options === "object" ? options : {{}};
      const scope = String(opts.scope || "feed").trim().toLowerCase() === "member"
        ? "member"
        : "feed";
      const fallbackHue = Number.isFinite(Number(opts.fallbackHue))
        ? Number(opts.fallbackHue)
