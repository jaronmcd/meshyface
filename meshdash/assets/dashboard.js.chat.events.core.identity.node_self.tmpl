        btn.setAttribute("role", "option");
        btn.setAttribute("aria-label", `${{style.label}} Unicode text`);
        const label = document.createElement("span");
        label.className = "chat-unicode-label";
        label.textContent = style.label;
        const preview = document.createElement("span");
        preview.className = "chat-unicode-preview";
        preview.textContent = transformChatUnicodeText(sourceText, style.id);
        btn.append(label, preview);
        options.appendChild(btn);
      }}
      panel.replaceChildren(menu, options);
    }}

    function setChatUnicodeExpanded(expanded) {{
      const btn = chatUnicodeButtonElement();
      if (btn instanceof HTMLButtonElement) {{
        btn.setAttribute("aria-expanded", expanded ? "true" : "false");
      }}
    }}

    function closeChatUnicodePanel() {{
      const panel = chatUnicodePanelElement();
      if (panel instanceof HTMLElement) {{
        panel.hidden = true;
      }}
      setChatUnicodeExpanded(false);
    }}

    function openChatUnicodePanel() {{
      const panel = chatUnicodePanelElement();
      if (!(panel instanceof HTMLElement)) return;
      if (typeof closeChatEmojiPanel === "function") {{
        closeChatEmojiPanel();
      }}
      renderChatUnicodePanel();
      panel.hidden = false;
      setChatUnicodeExpanded(true);
    }}

    function applyChatUnicodeStyle(styleId) {{
      const style = chatUnicodeStyleById(styleId);
      const input = document.getElementById("chat-input");
      if (!style || !(input instanceof HTMLInputElement) || input.disabled) return;
      const value = String(input.value || "");
      const range = chatUnicodeSelectionRange(input);
      const hasSelection = range.start !== range.end;
      const source = hasSelection ? value.slice(range.start, range.end) : value;
      if (!source) {{
        if (typeof setChatSendStatus === "function") {{
          setChatSendStatus("Type text before styling.", false);
        }}
        input.focus({{ preventScroll: true }});
        return;
      }}
      const transformed = transformChatUnicodeText(source, style.id);
      input.value = hasSelection
        ? `${{value.slice(0, range.start)}}${{transformed}}${{value.slice(range.end)}}`
        : transformed;
      const cursor = hasSelection ? range.start + transformed.length : input.value.length;
      input.focus({{ preventScroll: true }});
      input.setSelectionRange(cursor, cursor);
      input.dispatchEvent(new Event("input", {{ bubbles: true }}));
      if (typeof setChatSendStatus === "function") {{
        setChatSendStatus(`${{style.label}} text applied.`, false);
      }}
      closeChatUnicodePanel();
    }}

    function bindChatUnicodeGenerator() {{
      const btn = chatUnicodeButtonElement();
      const panel = chatUnicodePanelElement();
      const input = document.getElementById("chat-input");
      if (!(btn instanceof HTMLButtonElement) || !(panel instanceof HTMLElement)) return;

      if (btn.dataset.unicodeBound !== "1") {{
        btn.dataset.unicodeBound = "1";
        btn.addEventListener("click", (ev) => {{
          ev.preventDefault();
          if (panel.hidden) {{
            openChatUnicodePanel();
          }} else {{
            closeChatUnicodePanel();
          }}
        }});
      }}

      if (input instanceof HTMLInputElement && input.dataset.unicodeBound !== "1") {{
        input.dataset.unicodeBound = "1";
        const refreshOpenPanel = () => {{
          const activePanel = chatUnicodePanelElement();
          if (activePanel instanceof HTMLElement && !activePanel.hidden) {{
            renderChatUnicodePanel();
          }}
        }};
        input.addEventListener("input", refreshOpenPanel);
        input.addEventListener("select", refreshOpenPanel);
        input.addEventListener("keyup", refreshOpenPanel);
        input.addEventListener("mouseup", refreshOpenPanel);
      }}

      if (panel.dataset.bound !== "1") {{
        panel.dataset.bound = "1";
        panel.addEventListener("pointerdown", (ev) => {{
          ev.preventDefault();
        }});
        panel.addEventListener("click", (ev) => {{
          const target = ev.target;
          if (!(target instanceof Element)) return;
          const groupBtn = target.closest(".chat-unicode-menu-btn");
          if (groupBtn instanceof HTMLButtonElement) {{
            chatUnicodeActiveGroup = normalizeChatUnicodeGroup(groupBtn.dataset.unicodeGroup || "");
            panel.dataset.activeGroup = chatUnicodeActiveGroup;
            renderChatUnicodePanel();
            return;
          }}
          const option = target.closest(".chat-unicode-option");
          if (!(option instanceof HTMLButtonElement)) return;
          applyChatUnicodeStyle(option.dataset.unicodeStyle || "");
        }});
      }}

      if (document.body.dataset.chatUnicodeCloseBound !== "1") {{
        document.body.dataset.chatUnicodeCloseBound = "1";
        document.addEventListener("pointerdown", (ev) => {{
          const target = ev.target;
          if (!(target instanceof Element)) return;
          if (target.closest("#chat-unicode-panel") || target.closest("#chat-unicode-btn")) return;
          closeChatUnicodePanel();
        }});
        document.addEventListener("keydown", (ev) => {{
          if (ev.key === "Escape") {{
            closeChatUnicodePanel();
          }}
        }});
      }}
    }}

    function bindChatComposer() {{
      const btn = document.getElementById("chat-send-btn");
      if (btn instanceof HTMLButtonElement && btn.dataset.bound !== "1") {{
        btn.dataset.bound = "1";
        btn.addEventListener("click", () => {{
          sendChatMessage();
        }});
      }}

      const input = document.getElementById("chat-input");
      if (input instanceof HTMLInputElement && input.dataset.bound !== "1") {{
        input.dataset.bound = "1";
        input.maxLength = chatComposerMaxBytes;
        input.addEventListener("input", () => {{
          if (typeof syncChatHopReplyLocationAutocompleteInputState === "function") {{
            syncChatHopReplyLocationAutocompleteInputState(input.value);
          }}
          if (typeof renderChatHopReplyLocationGhost === "function") {{
            renderChatHopReplyLocationGhost(input);
          }}
        }});
        input.addEventListener("focus", () => {{
          if (typeof renderChatHopReplyLocationGhost === "function") {{
            renderChatHopReplyLocationGhost(input);
          }}
        }});
        input.addEventListener("blur", () => {{
          if (typeof renderChatHopReplyLocationGhost === "function") {{
            renderChatHopReplyLocationGhost(input);
          }}
        }});
        input.addEventListener("keydown", (ev) => {{
          if (
            ev.key === "Tab"
            && !ev.shiftKey
            && !ev.altKey
            && !ev.ctrlKey
            && !ev.metaKey
            && typeof applyChatHopReplyLocationAutocomplete === "function"
            && applyChatHopReplyLocationAutocomplete(input)
          ) {{
            ev.preventDefault();
            return;
          }}
          if (ev.key === "Enter" && !ev.shiftKey) {{
            ev.preventDefault();
            sendChatMessage({{ preserveFocus: true }});
          }}
        }});
        if (typeof renderChatHopReplyLocationGhost === "function") {{
          renderChatHopReplyLocationGhost(input);
        }}
      }}
      if (document.body.dataset.chatHopReplyGhostResizeBound !== "1") {{
        document.body.dataset.chatHopReplyGhostResizeBound = "1";
        window.addEventListener("resize", () => {{
          const chatInput = document.getElementById("chat-input");
          if (typeof renderChatHopReplyLocationGhost === "function") {{
            renderChatHopReplyLocationGhost(chatInput instanceof HTMLInputElement ? chatInput : null);
          }}
        }});
      }}
      const replyClearBtn = document.getElementById("chat-reply-clear-btn");
      if (replyClearBtn instanceof HTMLButtonElement && replyClearBtn.dataset.bound !== "1") {{
        replyClearBtn.dataset.bound = "1";
        replyClearBtn.addEventListener("click", () => {{
          clearChatReplyTarget();
        }});
      }}

      renderChatReplyContext();
      bindChatUnicodeGenerator();
      bindEmojiPicker();
    }}

    function nodeLabel(node) {{
      return node.long_name || node.short_name || node.id || "unknown";
    }}

    function preferredNodeName(node) {{
      if (!node || typeof node !== "object") return "";
      const longName = String(node.long_name || "").trim();
      if (longName) return longName;
      const shortName = String(node.short_name || "").trim();
      if (shortName) return shortName;
      return "";
    }}

    function markerStyle(isSelected) {{
      if (isSelected) {{
        return {{
          radius: 8,
          color: "#7a0f20",
          fillColor: "#ffd24a",
          fillOpacity: 0.95,
          weight: 2,
          bubblingMouseEvents: false
        }};
      }}
      return {{
        radius: 6.4,
        color: "#062f20",
        fillColor: "#34c27f",
        fillOpacity: 0.9,
        weight: 1.8,
        bubblingMouseEvents: false
      }};
    }}

    function normalizeNodeId(nodeId) {{
      const raw = String(nodeId == null ? "" : nodeId).trim();
      if (!raw) return "";
      const lower = raw.toLowerCase();
      if (
        lower === "^all"
        || lower === "all"
        || lower === "broadcast"
        || lower === "!ffffffff"
        || lower === "ffffffff"
        || lower === "0xffffffff"
        || lower === "4294967295"
      ) return "^all";
      if (lower === "unknown") return "Unknown";
      if (lower === "n/a" || lower === "na") return "n/a";
      if (lower === "local") return "local";

      const hex = raw.startsWith("!") ? raw.slice(1) : raw;
      if (/^[0-9a-f]{8}$/i.test(hex)) {{
        return `!${{hex.toLowerCase()}}`;
      }}
      return raw;
    }}

    function isCanonicalNodeId(nodeId) {{
      return /^![0-9a-f]{{8}}$/.test(normalizeNodeId(nodeId));
    }}

    function isSelectableNodeId(nodeId) {{
      const normalized = normalizeNodeId(nodeId);
      return !!normalized && normalized !== "^all" && normalized !== "Unknown" && normalized !== "n/a";
    }}

    function parseNodeNum(value) {{
      const numeric = Number(value);
      if (!Number.isFinite(numeric) || numeric < 0) return null;
      return Math.trunc(numeric);
    }}

    function findNodeIdByNum(nodeNum, state = latestState) {{
      const targetNum = parseNodeNum(nodeNum);
      if (!Number.isInteger(targetNum) || targetNum < 0) return "";
      const safeState = (state && typeof state === "object") ? state : {{}};
      const nodes = Array.isArray(safeState.nodes) ? safeState.nodes : [];
      for (const node of nodes) {{
        const candidateNum = parseNodeNum(node && node.num);
        if (candidateNum !== targetNum) continue;
        const nodeId = normalizeNodeId(node && node.id);
        if (isCanonicalNodeId(nodeId)) {{
          return nodeId;
        }}
      }}
      return "";
    }}

    function nodeNumFromMapping(value) {{
      if (!value || typeof value !== "object") return null;
      for (const key of ["my_node_num", "myNodeNum", "node_num", "nodeNum", "num"]) {{
        const parsed = parseNodeNum(value[key]);
        if (Number.isInteger(parsed) && parsed >= 0) {{
          return parsed;
        }}
      }}
      return null;
    }}

    function resolveLocalNodeId(state = latestState) {{
      const safeState = (state && typeof state === "object") ? state : {{}};
      const direct = normalizeNodeId(safeState.local_node_id || safeState.localNodeId || "");
      if (isCanonicalNodeId(direct)) {{
        return direct;
      }}

      const infoNum = nodeNumFromMapping(safeState.my_info);
      if (Number.isInteger(infoNum) && infoNum >= 0) {{
        const fromInfo = findNodeIdByNum(infoNum, safeState);
        if (isCanonicalNodeId(fromInfo)) {{
          return fromInfo;
        }}
      }}

      const localStateNum = nodeNumFromMapping(safeState.local_state);
      if (Number.isInteger(localStateNum) && localStateNum >= 0) {{
        const fromLocal = findNodeIdByNum(localStateNum, safeState);
        if (isCanonicalNodeId(fromLocal)) {{
          return fromLocal;
        }}
      }}

      return isCanonicalNodeId(resolvedLocalNodeId) ? resolvedLocalNodeId : "";
    }}

    function resolveSavedViewNodeId(state = latestState) {{
      const explicitId = normalizeNodeId(selectedNodeId || "");
      if (isSelectableNodeId(explicitId)) {{
        return explicitId;
      }}
      const localId = normalizeNodeId(resolveLocalNodeId(state) || "");
      if (isSelectableNodeId(localId)) {{
        return localId;
      }}
      return "";
    }}

    function resolveSavedViewNodeName(state = latestState, nodeId = resolveSavedViewNodeId(state)) {{
      const clean = normalizeNodeId(nodeId || "");
      if (!isSelectableNodeId(clean)) {{
        return "";
      }}
      const safeState = (state && typeof state === "object") ? state : {{}};
      const nodes = Array.isArray(safeState.nodes) ? safeState.nodes : [];
      const node = nodes.find((entry) => normalizeNodeId(entry && entry.id) === clean) || null;
      const nodeName = preferredNodeName(node);
      if (nodeName) {{
        return nodeName;
      }}
      const localId = normalizeNodeId(resolveLocalNodeId(safeState) || "");
      if (clean === localId) {{
        const owner = localNodeUserFromState(safeState);
        const longName = String((owner && owner.long_name) || "").trim();
        const shortName = String((owner && owner.short_name) || "").trim();
        if (longName && shortName && shortName !== longName) {{
          return `${{longName}} (${{shortName}})`;
        }}
        if (longName) {{
          return longName;
        }}
        if (shortName) {{
          return shortName;
        }}
      }}
      return nodeNameCache.get(clean) || clean;
    }}

    function savedViewNodeFrom(nodes, state = latestState) {{
      const nodeId = resolveSavedViewNodeId(state);
      if (!isSelectableNodeId(nodeId)) {{
        return null;
      }}
      for (const node of (nodes || [])) {{
        if (normalizeNodeId(node && node.id) === nodeId) {{
          return node;
        }}
      }}
      return null;
    }}

    function isSelfNodeId(nodeId, state = latestState) {{
      const clean = normalizeNodeId(nodeId);
      if (!isCanonicalNodeId(clean)) return false;
      const selfId = resolveLocalNodeId(state);
      return isCanonicalNodeId(selfId) && clean === selfId;
    }}

    function pruneSelfFromManualDirectPeers(state = latestState) {{
      const selfId = resolveLocalNodeId(state);
      if (!isCanonicalNodeId(selfId) || !manualDirectPeerIds.has(selfId)) {{
        return false;
      }}
      manualDirectPeerIds.delete(selfId);
      persistManualDirectPeers();
      return true;
    }}

    function selfRadioProfileShortLabel(nodeId) {{
      const cleanId = String(nodeId || "").replace(/[^A-Za-z0-9]/g, "");
      if (cleanId) return cleanId.slice(-4).toLowerCase();
      return "na";
    }}

    function renderSelfRadioPill(state = latestState) {{
      const pill = document.getElementById("self-radio-pill");
      const hasPill = pill instanceof HTMLElement;
      const profile = document.getElementById("self-radio-profile");
      const profileShort = document.getElementById("self-radio-profile-short");
      const copyBtn = document.getElementById("self-radio-copy-id-btn");
      const setProfile = (labelText, titleText) => {{
        if (profileShort instanceof HTMLElement) {{
          profileShort.textContent = String(labelText || "na");
        }}
        if (profile instanceof HTMLElement) {{
          profile.title = String(titleText || "Connected local radio: unavailable");
          profile.setAttribute("aria-label", profile.title);
        }}
      }};
      const setProfileFullId = (nodeId) => {{
        const cleanId = normalizeNodeId(nodeId || "");
        const hasFullId = isCanonicalNodeId(cleanId);
        if (profile instanceof HTMLElement) {{
          if (hasFullId) {{
            profile.dataset.fullRadioId = cleanId;
          }} else {{
            delete profile.dataset.fullRadioId;
          }}
        }}
        if (copyBtn instanceof HTMLButtonElement) {{
          copyBtn.disabled = !hasFullId;
          copyBtn.title = hasFullId
            ? `Copy ${{cleanId}} to clipboard`
            : "Full radio ID unavailable";
        }}
      }};
      const setProfileFreshness = (status, lastSeenUnix = null) => {{
        const key = normalizeFreshnessKey(status);
        if (profile instanceof HTMLElement) {{
          applyFreshnessClass(profile, key);
          const lastSeen = Number(lastSeenUnix);
          if (Number.isFinite(lastSeen) && lastSeen > 0) {{
            profile.dataset.lastSeenUnix = String(Math.trunc(lastSeen));
          }} else {{
            delete profile.dataset.lastSeenUnix;
          }}
        }}
        if (hasPill) {{
          applyFreshnessClass(pill, key);
        }}
      }};
      const freshnessLabel = (status) => {{
        const key = normalizeFreshnessKey(status);
        if (key === "online") return "Online";
        if (key === "warn") return "Aging";
        if (key === "stale") return "Stale";
        return "Unknown";
      }};

      const safeState = (state && typeof state === "object") ? state : {{}};
      const selfId = resolveLocalNodeId(safeState);
      if (!isCanonicalNodeId(selfId)) {{
        if (hasPill) {{
          pill.textContent = "n/a";
          pill.title = "Connected local radio: unavailable";
        }}
        setProfile("na", "Connected local radio: unavailable");
        setProfileFullId("");
        setProfileFreshness("unknown");
        syncConsoleCommandInputState(safeState);
        return;
      }}

      const nodes = Array.isArray(safeState.nodes) ? safeState.nodes : [];
      const selfNode = nodes.find((node) => normalizeNodeId(node && node.id) === selfId) || null;
      const historyCapsById = new Map(
        Object.entries((safeState.history_caps && typeof safeState.history_caps === "object") ? safeState.history_caps : {{}})
          .map(([rawNodeId, caps]) => [normalizeNodeId(rawNodeId), caps])
          .filter(([nodeId, caps]) => isSelectableNodeId(nodeId) && caps && typeof caps === "object")
      );
      const caps = historyCapsById.get(selfId) || null;
      const traffic = (safeState.traffic && typeof safeState.traffic === "object") ? safeState.traffic : {{}};
      const chatMessages = Array.isArray(traffic.recent_chat) ? traffic.recent_chat : [];
      const latestChatTouchByNode = mapLatestChatTouchInfo(chatMessages);
      const chatTouch = latestChatTouchByNode.get(selfId) || null;
      const nowUnix = Math.floor(Date.now() / 1000);
      const lastSeenUnix = computeNodeFreshnessUnix(selfNode, caps, chatTouch);
      const status = normalizeFreshnessKey(freshnessStatus(lastSeenUnix, nowUnix));
      setProfileFullId(selfId);
      const statusDetail = Number.isFinite(lastSeenUnix)
        ? `${{freshnessLabel(status)}} (seen ${{savedDetailAge(lastSeenUnix, nowUnix)}})`
        : freshnessLabel(status);
      const selfName = preferredNodeName(selfNode) || nodeNameCache.get(selfId) || "";
      const profileLabel = selfName || selfId;
      const profileShortLabel = selfRadioProfileShortLabel(selfId);
      const profileIdentity = selfName ? `${{selfName}} • ID: ${{selfId}}` : selfId;
      const profileTitle = `Connected local radio: ${{profileIdentity}} • Status: ${{statusDetail}}`;
      if (hasPill) {{
        pill.textContent = profileLabel;
        pill.title = profileTitle;
      }}
      setProfile(profileShortLabel, profileTitle);
      setProfileFreshness(status, lastSeenUnix);
      syncConsoleCommandInputState(safeState);
    }}
