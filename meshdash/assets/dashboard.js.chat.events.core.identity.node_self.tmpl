      const btn = document.getElementById("chat-unicode-btn");
      return btn instanceof HTMLButtonElement ? btn : null;
    }}

    function chatUnicodeSelectionRange(input) {{
      const value = input instanceof HTMLInputElement ? String(input.value || "") : "";
      const startRaw = input instanceof HTMLInputElement ? input.selectionStart : null;
      const endRaw = input instanceof HTMLInputElement ? input.selectionEnd : null;
      const start = Number.isFinite(startRaw) ? Math.max(0, Math.min(value.length, startRaw)) : value.length;
      const end = Number.isFinite(endRaw) ? Math.max(0, Math.min(value.length, endRaw)) : value.length;
      return {{
        start: Math.min(start, end),
        end: Math.max(start, end),
      }};
    }}

    function chatUnicodeSourceText(input) {{
      if (!(input instanceof HTMLInputElement)) return "mesh test";
      const value = String(input.value || "");
      const range = chatUnicodeSelectionRange(input);
      const selected = range.start !== range.end ? value.slice(range.start, range.end) : "";
      return selected || value || "mesh test";
    }}

    function renderChatUnicodePanel() {{
      const panel = chatUnicodePanelElement();
      if (!(panel instanceof HTMLElement)) return;
      const input = document.getElementById("chat-input");
      const sourceText = chatUnicodeSourceText(input);
      const activeGroup = normalizeChatUnicodeGroup(panel.dataset.activeGroup || chatUnicodeActiveGroup);
      chatUnicodeActiveGroup = activeGroup;
      panel.dataset.activeGroup = activeGroup;

      const menu = document.createElement("div");
      menu.className = "chat-unicode-menu";
      menu.setAttribute("role", "tablist");
      menu.setAttribute("aria-label", "Unicode style category");
      for (const group of chatUnicodeGroups) {{
        const menuBtn = document.createElement("button");
        menuBtn.type = "button";
        menuBtn.className = "chat-unicode-menu-btn";
        menuBtn.dataset.unicodeGroup = group.id;
        menuBtn.setAttribute("role", "tab");
        menuBtn.setAttribute("aria-selected", group.id === activeGroup ? "true" : "false");
        menuBtn.classList.toggle("active", group.id === activeGroup);
        menuBtn.textContent = group.label;
        menu.appendChild(menuBtn);
      }}

      const options = document.createElement("div");
      options.className = "chat-unicode-options";
      options.setAttribute("role", "listbox");
      options.setAttribute("aria-label", "Unicode text style");
      for (const style of chatUnicodeStyles.filter((style) => style.group === activeGroup)) {{
        const btn = document.createElement("button");
        btn.type = "button";
        btn.className = "chat-unicode-option";
        btn.dataset.unicodeStyle = style.id;
        btn.setAttribute("role", "option");
        btn.setAttribute("aria-label", `${{style.label}} Unicode text`);
        const label = document.createElement("span");
        label.className = "chat-unicode-label";
        label.textContent = style.label;
        const preview = document.createElement("span");
        preview.className = "chat-unicode-preview";
        preview.textContent = transformChatUnicodeText(sourceText, style.id);
        btn.append(label, preview);
        options.appendChild(btn);
      }}
      panel.replaceChildren(menu, options);
    }}

