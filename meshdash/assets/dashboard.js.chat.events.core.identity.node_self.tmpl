    function nodeTintStyleVars(nodeIdOrProfile, options = null) {{
      const resolved = resolveNodeTintStyleState(nodeIdOrProfile, options);
      const scopePrefix = resolved.scope === "member" ? "--chat-member-node-" : "--chat-feed-node-";
