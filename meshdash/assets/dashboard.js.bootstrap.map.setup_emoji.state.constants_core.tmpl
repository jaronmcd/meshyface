        ? nodeLastHeardLabel(node, "n/a", nowUnix)
        : (String(node && node.last_heard || "").trim() || "n/a");
      const hardwareText = String((node && (node.hardware_model || node.hardware)) || "").trim() || "n/a";
      const snrRaw = Number(node && node.snr);
      const snrNum = Number.isFinite(snrRaw) ? snrRaw : null;
      const hopsRaw = Number(
