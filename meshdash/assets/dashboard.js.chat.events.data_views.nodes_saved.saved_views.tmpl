    function normalizeNodeNoteDraftText(rawValue, maxChars = 1200) {{
      let text = String(rawValue == null ? "" : rawValue)
        .replace(/\r\n?/g, "\n")
        .replace(/\u0000/g, "");
      const cap = Math.max(80, Math.trunc(Number(maxChars) || 1200));
      if (text.length > cap) {{
        text = text.slice(0, cap);
      }}
      return text;
    }}

    function savedNodeNotesSectionHtml(nodeId, noteEntry = null, noteDraft = null) {{
      const normalizedNodeId = normalizeNodeId(nodeId || "");
      const noteText = normalizeNodeNoteText(noteEntry && noteEntry.note);
      const hasDraft = typeof noteDraft === "string";
      const draftText = hasDraft ? normalizeNodeNoteDraftText(noteDraft) : "";
      const displayNoteText = hasDraft ? draftText : noteText;
      const updatedRaw = Number(noteEntry && noteEntry.updatedUnix);
      const updatedUnix = Number.isFinite(updatedRaw) && updatedRaw > 0
        ? Math.trunc(updatedRaw)
        : 0;
      const draftCleanText = normalizeNodeNoteText(draftText);
      const hasUnsavedDraft = hasDraft && draftCleanText !== noteText;
      const statusText = hasUnsavedDraft
        ? "Unsaved draft. Save Note to persist."
        : (noteText
        ? (updatedUnix > 0 ? `Saved ${{savedDetailAge(updatedUnix)}}` : "Saved locally")
        : "No note saved for this node yet.");
      return `<section class="saved-node-section">
        <h3 class="saved-node-section-title">Notes + Tags</h3>
        <label class="saved-node-note-label" for="saved-node-note-input">Personal notes for ${{escAttr(normalizedNodeId)}} (saved only in this browser).</label>
        <textarea
          id="saved-node-note-input"
          class="saved-node-note-input"
          rows="4"
          maxlength="1200"
          placeholder="Add tags, context, or reminders for this node..."
          data-node-id="${{escAttr(normalizedNodeId)}}"
          data-saved-note="${{escAttr(noteText)}}"
          data-saved-updated-unix="${{escAttr(updatedUnix)}}"
          data-updated-unix="${{escAttr(updatedUnix)}}"
        >${{escAttr(displayNoteText)}}</textarea>
        <div class="saved-node-note-actions">
          <button id="saved-node-note-save-btn" class="btn btn-secondary" type="button">Save Note</button>
          <button id="saved-node-note-clear-btn" class="btn btn-secondary" type="button">Clear</button>
        </div>
        <div id="saved-node-note-status" class="saved-node-note">${{escAttr(statusText)}}</div>
      </section>`;
    }}

    function bindSavedNodeNotesEditor(nodeId) {{
      const cleanNodeId = normalizeNodeId(nodeId || "");
      if (!isSelectableNodeId(cleanNodeId)) return;
      const noteInput = document.getElementById("saved-node-note-input");
      const saveBtn = document.getElementById("saved-node-note-save-btn");
      const clearBtn = document.getElementById("saved-node-note-clear-btn");
      const statusEl = document.getElementById("saved-node-note-status");
      if (!(noteInput instanceof HTMLTextAreaElement)) return;
      if (!(saveBtn instanceof HTMLButtonElement)) return;
      if (!(clearBtn instanceof HTMLButtonElement)) return;
      if (!(statusEl instanceof HTMLElement)) return;
      if (normalizeNodeId(noteInput.dataset.nodeId || "") !== cleanNodeId) return;
      if (noteInput.dataset.noteEditorBound === "1") return;
      noteInput.dataset.noteEditorBound = "1";

      let baselineText = normalizeNodeNoteText(noteInput.dataset.savedNote || "");
      let baselineUpdatedUnix = Number(noteInput.dataset.savedUpdatedUnix);
      baselineUpdatedUnix = Number.isFinite(baselineUpdatedUnix) && baselineUpdatedUnix > 0
        ? Math.trunc(baselineUpdatedUnix)
        : 0;

      const applyEditorState = () => {{
        const currentText = normalizeNodeNoteText(noteInput.value);
        const dirty = currentText !== baselineText;
        saveBtn.disabled = !dirty;
        clearBtn.disabled = !currentText && !baselineText;
        if (dirty) {{
          statusEl.textContent = "Unsaved changes.";
          return;
        }}
        if (currentText) {{
          statusEl.textContent = baselineUpdatedUnix > 0
            ? `Saved ${{savedDetailAge(baselineUpdatedUnix)}}`
            : "Saved locally";
          return;
        }}
        statusEl.textContent = "No note saved for this node yet.";
      }};

      const syncDraftFromInput = () => {{
        const draftText = normalizeNodeNoteDraftText(noteInput.value);
        const draftCleanText = normalizeNodeNoteText(draftText);
        if (draftCleanText !== baselineText) {{
          nodeNoteDraftById.set(cleanNodeId, draftText);
        }} else {{
          nodeNoteDraftById.delete(cleanNodeId);
        }}
      }};

      const saveEditorNote = () => {{
        const result = saveNodeNote(cleanNodeId, noteInput.value);
        if (!result || result.ok !== true) return;
        const cleanText = normalizeNodeNoteText(result.note);
        baselineText = cleanText;
        baselineUpdatedUnix = Number(result.updatedUnix);
        baselineUpdatedUnix = Number.isFinite(baselineUpdatedUnix) && baselineUpdatedUnix > 0
          ? Math.trunc(baselineUpdatedUnix)
          : 0;
        noteInput.value = cleanText;
        noteInput.dataset.savedNote = cleanText;
        noteInput.dataset.savedUpdatedUnix = String(baselineUpdatedUnix || 0);
        nodeNoteDraftById.delete(cleanNodeId);
        applyEditorState();
      }};

      noteInput.addEventListener("input", () => {{
        syncDraftFromInput();
        applyEditorState();
      }});
      noteInput.addEventListener("keydown", (ev) => {{
        const isSaveChord = (ev.key === "Enter") && (ev.metaKey || ev.ctrlKey);
        if (!isSaveChord) return;
        ev.preventDefault();
        saveEditorNote();
      }});
      saveBtn.addEventListener("click", saveEditorNote);
      clearBtn.addEventListener("click", () => {{
        noteInput.value = "";
        saveEditorNote();
      }});
      syncDraftFromInput();
      applyEditorState();
    }}

    function bindSavedNodeDetailLinkButtons(root = null) {{
      if (!(root instanceof HTMLElement)) return;
      for (const btn of root.querySelectorAll(".saved-node-inline-link[data-node-id]")) {{
        if (!(btn instanceof HTMLButtonElement) || btn.dataset.bound === "1") continue;
        btn.dataset.bound = "1";
        btn.addEventListener("click", (ev) => {{
          ev.preventDefault();
          ev.stopPropagation();
          const nodeId = normalizeNodeId(btn.dataset.nodeId || "");
          if (!isSelectableNodeId(nodeId)) return;
          selectNode(nodeId, true, false);
        }});
      }}
    }}

    function focusSavedNodeCoordinateOnMap(nodeId, latRaw, lonRaw) {{
      const cleanNodeId = normalizeNodeId(nodeId || "");
      const lat = Number(latRaw);
      const lon = Number(lonRaw);
      if (!isSelectableNodeId(cleanNodeId) || !isValidMapCoord(lat, lon)) return false;

      const activeNetworkSubviewName = (typeof normalizeNetworkSubview === "function")
        ? normalizeNetworkSubview(activeNetworkSubview)
        : String(activeNetworkSubview || "map").trim().toLowerCase();
      const networkMapVisible = activeLayoutView === "network" && (
        typeof networkSubviewUsesMap === "function"
          ? networkSubviewUsesMap(activeNetworkSubviewName)
          : activeNetworkSubviewName === "map"
      );

      if (activeLayoutView === "network" && !networkMapVisible) {{
        if (typeof setActiveNetworkSubview === "function") {{
          setActiveNetworkSubview("map", {{ persist: true }});
        }}
      }} else if (activeLayoutView !== "network") {{
        if (typeof applyLayoutView === "function") {{
          applyLayoutView("network", true);
        }}
        if (typeof setActiveNetworkSubview === "function") {{
          setActiveNetworkSubview("map", {{ persist: true }});
        }}
      }}

      if (normalizeNodeId(selectedNodeId || "") !== cleanNodeId && typeof selectNode === "function") {{
        selectNode(cleanNodeId, true, false);
      }}

      const focusCoord = () => {{
        try {{
          if (typeof requestMapResizeNow === "function") {{
            requestMapResizeNow();
          }} else if (typeof requestMapResize === "function") {{
            requestMapResize();
          }}
        }} catch (_err) {{
        }}
        try {{
          if (typeof L !== "undefined" && map && typeof map.setView === "function") {{
            const currentZoom = typeof map.getZoom === "function" ? Number(map.getZoom()) : 12;
            const targetZoom = Math.min(16, Math.max(Number.isFinite(currentZoom) ? currentZoom : 12, 12));
            const move = () => map.setView([lat, lon], targetZoom, {{ animate: false }});
            if (typeof withProgrammaticMapMove === "function") {{
              withProgrammaticMapMove(move);
            }} else {{
              move();
            }}
          }}
        }} catch (_err) {{
        }}
        try {{
          if (typeof focusSelectedNodeOnMap === "function") {{
            focusSelectedNodeOnMap(null, {{
              nodeId: cleanNodeId,
              focusView: false,
              openPopup: true,
            }});
          }}
        }} catch (_err) {{
        }}
        const mapEl = document.getElementById("map");
        if (mapEl instanceof HTMLElement && typeof mapEl.focus === "function") {{
          if (!mapEl.hasAttribute("tabindex")) {{
            mapEl.tabIndex = -1;
          }}
          try {{
            mapEl.focus({{ preventScroll: true }});
          }} catch (_err) {{
            mapEl.focus();
          }}
        }}
        return true;
      }};

      window.requestAnimationFrame(() => {{
        focusCoord();
        window.setTimeout(focusCoord, 80);
      }});
      return true;
    }}

    function bindSavedNodeCoordinateLinks(root = null) {{
      if (!(root instanceof HTMLElement)) return;
      for (const link of root.querySelectorAll(".saved-node-coordinate-link[data-map-node-id]")) {{
        if (!(link instanceof HTMLAnchorElement) || link.dataset.bound === "1") continue;
        link.dataset.bound = "1";
        link.addEventListener("click", (ev) => {{
          const nodeId = normalizeNodeId(link.dataset.mapNodeId || "");
          const lat = Number(link.dataset.mapLat);
          const lon = Number(link.dataset.mapLon);
          if (!isSelectableNodeId(nodeId) || !isValidMapCoord(lat, lon)) return;
          ev.preventDefault();
          ev.stopPropagation();
          focusSavedNodeCoordinateOnMap(nodeId, lat, lon);
        }});
      }}
    }}

    function renderNodeDetails(state, nodeHistory = null, loadingNodeId = "") {{
      const host = document.getElementById("saved-node-details");
      if (!(host instanceof HTMLElement)) return;
      const setElementHtmlIfChanged = (element, markup, cacheKey = "default") => {{
        if (!(element instanceof HTMLElement)) return false;
        const nextMarkup = String(markup == null ? "" : markup);
        const propName = `__meshLastInnerHtml_${{cacheKey}}`;
        const previousMarkup = (typeof element[propName] === "string") ? element[propName] : null;
        if (previousMarkup === nextMarkup) return false;
        element.innerHTML = nextMarkup;
        element[propName] = nextMarkup;
        return true;
      }};
      const previousMainScroll = host.querySelector(".saved-node-main-scroll");
      const locationHost = document.getElementById("chat-node-details-location-host");
      const chatHost = document.getElementById("chat-node-details-chat-host");
      const linksHost = document.getElementById("chat-node-details-links-host");
      const notesHost = document.getElementById("chat-node-details-notes-host");
      const previousNoteInput = document.getElementById("saved-node-note-input");
      const previousNoteFocused = (
        previousNoteInput instanceof HTMLTextAreaElement
        && document.activeElement === previousNoteInput
      );
      const previousNoteSelectionStart = (
        previousNoteInput instanceof HTMLTextAreaElement
        && Number.isFinite(previousNoteInput.selectionStart)
      ) ? Math.max(0, Math.trunc(previousNoteInput.selectionStart)) : null;
      const previousNoteSelectionEnd = (
        previousNoteInput instanceof HTMLTextAreaElement
        && Number.isFinite(previousNoteInput.selectionEnd)
      ) ? Math.max(0, Math.trunc(previousNoteInput.selectionEnd)) : null;
      const previousNodeId = normalizeNodeId(host.dataset.nodeId || "");
      const previousScrollTop = (
        previousMainScroll instanceof HTMLElement
        && Number.isFinite(previousMainScroll.scrollTop)
      ) ? previousMainScroll.scrollTop : 0;
      const previousScrollHeight = (
        previousMainScroll instanceof HTMLElement
        && Number.isFinite(previousMainScroll.scrollHeight)
      ) ? previousMainScroll.scrollHeight : 0;
      const previousClientHeight = (
        previousMainScroll instanceof HTMLElement
        && Number.isFinite(previousMainScroll.clientHeight)
      ) ? previousMainScroll.clientHeight : 0;

      const safeState = (state && typeof state === "object") ? state : {{}};
      const nodeId = normalizeNodeId(selectedNodeId || "");
      const loadingId = normalizeNodeId(loadingNodeId || "");
      const drawerExpanded = (
        typeof isChatNodeDetailsDrawerExpanded === "function"
        && isChatNodeDetailsDrawerExpanded()
      );
      const activeDrawerTab = drawerExpanded
        ? normalizeChatNodeDetailsDrawerTab(chatNodeDetailsDrawerTab)
        : "details";
      const renderNotesInDrawer = (
        notesHost instanceof HTMLElement
        && drawerExpanded
      );
      const renderLocationInDrawer = (
        locationHost instanceof HTMLElement
        && drawerExpanded
      );
      const renderChatInDrawer = (
        chatHost instanceof HTMLElement
        && drawerExpanded
      );
      const renderLinksInDrawer = (
        linksHost instanceof HTMLElement
        && drawerExpanded
      );
      const needsNotesSection = !renderNotesInDrawer || activeDrawerTab === "notes";
      const needsLocationSection = !renderLocationInDrawer || activeDrawerTab === "location";
      const needsChatSection = !renderChatInDrawer || activeDrawerTab === "chat";
      const needsLinksSection = !renderLinksInDrawer || activeDrawerTab === "links";

      if (!isSelectableNodeId(nodeId)) {{
        host.dataset.nodeId = "";
        host.classList.remove("has-node-appearance", "profiled-node");
        if (typeof clearNodeAppearanceElementStyle === "function") {{
          clearNodeAppearanceElementStyle(host);
        }}
        const visibleFavoriteCount = visibleFavoriteNodeIds().length;
        const emptyDetailsHtml = visibleFavoriteCount === 0
          ? '<div class="saved-node-details-empty">Select any node to view history and summary here. Tag nodes to build your tagged subsection.</div>'
          : '<div class="saved-node-details-empty">Select any node to view history and summary, or pick one from tagged nodes.</div>';
        detachDockedHistoryPanel();
        setElementHtmlIfChanged(host, emptyDetailsHtml, "saved-node-details");
        setElementHtmlIfChanged(locationHost, "", "chat-node-details-location");
        setElementHtmlIfChanged(chatHost, "", "chat-node-details-chat");
        setElementHtmlIfChanged(linksHost, "", "chat-node-details-links");
        setElementHtmlIfChanged(notesHost, "", "chat-node-details-notes");
        syncNodeHistoryDock();
        return;
      }}

      const nodes = Array.isArray(safeState.nodes) ? safeState.nodes : [];
      const node = nodes.find((entry) => normalizeNodeId(entry.id || "") === nodeId) || null;
      const appearanceEntry = (typeof effectiveNodeAppearanceForNode === "function")
        ? effectiveNodeAppearanceForNode(nodeId, safeState)
        : null;
      const hasNodeAppearance = !!(appearanceEntry && appearanceEntry.preset);
      const profileAppearance = !!(hasNodeAppearance && appearanceEntry.profileAppearance);
      host.classList.toggle("has-node-appearance", hasNodeAppearance);
      host.classList.toggle("profiled-node", profileAppearance);
      if (hasNodeAppearance && typeof applyNodeAppearanceElementStyle === "function") {{
        applyNodeAppearanceElementStyle(host, appearanceEntry);
      }} else if (typeof clearNodeAppearanceElementStyle === "function") {{
        clearNodeAppearanceElementStyle(host);
      }}
      const historyCapsById = new Map(
        Object.entries((safeState.history_caps && typeof safeState.history_caps === "object") ? safeState.history_caps : {{}})
          .map(([rawNodeId, caps]) => [normalizeNodeId(rawNodeId), caps])
          .filter(([entryNodeId, caps]) => isSelectableNodeId(entryNodeId) && caps && typeof caps === "object")
      );
      const caps = historyCapsById.get(nodeId) || null;

      const requestedHistory = (
        nodeHistory
        && typeof nodeHistory === "object"
        && normalizeNodeId(nodeHistory.node_id || "") === nodeId
      ) ? nodeHistory : null;
      const cachedEntry = nodeHistoryCache.get(nodeId);
      const cachedHistory = (
        cachedEntry
        && cachedEntry.data
        && normalizeNodeId(cachedEntry.data.node_id || "") === nodeId
      ) ? cachedEntry.data : null;
      const history = requestedHistory || cachedHistory;
      const historySummary = (history && typeof history.summary === "object") ? history.summary : {{}};
      const historyPoints = Array.isArray(history && history.points) ? history.points : [];
      const historyPositions = Array.isArray(history && history.positions) ? history.positions : [];
      const historyNameEntries = Array.isArray(history && history.name_history) ? history.name_history : [];
      const traffic = (safeState.traffic && typeof safeState.traffic === "object") ? safeState.traffic : {{}};
      const chatMessages = Array.isArray(traffic.recent_chat) ? traffic.recent_chat : [];
      const recentPackets = needsChatSection && Array.isArray(traffic.recent_packets)
        ? traffic.recent_packets
        : [];
      const edges = needsLinksSection && Array.isArray(traffic.edges) ? traffic.edges : [];
      const latestChatTouchByNode = chatMessages.length > 0
        ? mapLatestChatTouchInfo(chatMessages)
        : new Map();
      const chatTouch = latestChatTouchByNode.get(nodeId) || null;
      const malformedTextByNode = (needsChatSection && typeof mapMalformedTextPayloadByNode === "function")
        ? mapMalformedTextPayloadByNode(recentPackets)
        : new Map();
      const malformedTextEntry = malformedTextByNode.get(nodeId) || null;
      const malformedTextCount = Math.max(0, Math.trunc(Number(malformedTextEntry && malformedTextEntry.count) || 0));
      const malformedTextLatestUnix = Number(malformedTextEntry && malformedTextEntry.latestUnix);
      const malformedTextPayloadPreview = String((malformedTextEntry && malformedTextEntry.payloadPreview) || "").trim();
      const chatStats = needsChatSection ? computeSavedChatStats(nodeId, chatMessages) : null;
      const linkStats = needsLinksSection ? computeSavedLinkStats(nodeId, edges) : null;

      const freshness = resolveNodeFreshness(node, caps, historySummary, chatTouch);
      const freshnessSource = nodeFreshnessSourceLabel(freshness.source);
      const nowUnix = Math.floor(Date.now() / 1000);

      const batteryRaw = Number(
        (node && node.battery_level != null)
          ? node.battery_level
          : NaN
      );
      const capsBatteryRaw = Number(caps && caps.battery_level);
      const batteryValue = Number.isFinite(batteryRaw)
        ? batteryRaw
        : (Number.isFinite(capsBatteryRaw) ? capsBatteryRaw : null);
      const batteryText = Number.isFinite(batteryValue)
        ? `${{Math.max(0, Math.min(100, Math.round(batteryValue)))}}%`
        : "n/a";
      const hopsRaw = Number(
        (node && node.hops_away != null)
          ? node.hops_away
          : NaN
      );
      const capsHopsRaw = Number(caps && caps.last_hops);
      const hopsValue = Number.isFinite(hopsRaw)
        ? hopsRaw
        : (Number.isFinite(capsHopsRaw) ? capsHopsRaw : null);
      const hopsText = Number.isFinite(hopsValue) && hopsValue >= 0 ? String(Math.trunc(hopsValue)) : "n/a";

      const livePosText = (
        node
        && Number.isFinite(Number(node.lat))
        && Number.isFinite(Number(node.lon))
      )
        ? savedDetailMapCoordLink(nodeId, node.lat, node.lon, "Focus live GPS position on map")
        : "n/a";
      const voltageValue = (
        node
        && node.voltage != null
        && Number.isFinite(Number(node.voltage))
      ) ? Number(node.voltage) : null;
      const channelUtilValue = (
        node
        && node.channel_utilization != null
        && Number.isFinite(Number(node.channel_utilization))
      ) ? Number(node.channel_utilization) : null;
      const airUtilTxValue = (
        node
        && node.air_util_tx != null
        && Number.isFinite(Number(node.air_util_tx))
      ) ? Number(node.air_util_tx) : null;
      const latestTrail = historyPositions.length
        ? historyPositions[historyPositions.length - 1]
        : null;
      const latestTrailAltitude = (
        latestTrail
        && latestTrail.altitude != null
        && Number.isFinite(Number(latestTrail.altitude))
      ) ? Number(latestTrail.altitude) : null;
      const latestTrailSats = (
        latestTrail
        && latestTrail.sats_in_view != null
        && Number.isFinite(Number(latestTrail.sats_in_view))
      ) ? Number(latestTrail.sats_in_view) : null;
      const latestTrailPos = latestTrail
        ? savedDetailMapCoordLink(nodeId, latestTrail.lat, latestTrail.lon, "Focus latest trail position on map")
        : "n/a";
      const livePositionAvailable = livePosText !== "n/a";
      const historyPositionAvailable = latestTrailPos !== "n/a";
      const latestPosText = livePositionAvailable ? livePosText : latestTrailPos;
      const capsPosUnixRaw = Number(caps && caps.last_position_unix);
      const capsPosUnix = Number.isFinite(capsPosUnixRaw) && capsPosUnixRaw > 0
        ? Math.trunc(capsPosUnixRaw)
        : null;
      const trailPosUnix = (
        latestTrail
        && Number.isFinite(Number(latestTrail.time_unix))
        && Number(latestTrail.time_unix) > 0
      ) ? Math.trunc(Number(latestTrail.time_unix)) : null;
      const latestPosTimeUnix = livePositionAvailable
        ? (Number.isFinite(capsPosUnix) ? capsPosUnix : trailPosUnix)
        : trailPosUnix;
      const latestPosTimeText = livePositionAvailable
        ? savedDetailText(
            Number.isFinite(capsPosUnix)
              ? formatLocalChatTime(capsPosUnix, (latestTrail && latestTrail.time) || "n/a", nowUnix)
              : ((latestTrail && latestTrail.time) || "n/a")
          )
        : savedDetailText(latestTrail && latestTrail.time);
      const latestPosAgeText = savedDetailAge(latestPosTimeUnix, nowUnix);
      const positionSource = livePositionAvailable
        ? ((Number.isFinite(capsPosUnix) && (nowUnix - capsPosUnix) <= 300)
          ? "Live (recent)"
          : (Number.isFinite(capsPosUnix) ? "Live (stale)" : "Live (time unknown)"))
        : (historyPositionAvailable ? "History trail" : "n/a");
      const positionCapable = (caps && caps.has_position === true) || latestTrailPos !== "n/a"
        ? "Yes"
        : "No";

      const linkAvgHops = linkStats && linkStats.hopsWeight > 0
        ? formatMetricValue(linkStats.hopsWeighted / linkStats.hopsWeight, 2)
        : "n/a";
      const topPeerId = normalizeNodeId((linkStats && linkStats.topPeer) || "");
      const topPeerName = topPeerId
        ? resolveNodeDisplayName(safeState, topPeerId)
        : "";
      const topPeerLabel = savedDetailText(topPeerName || topPeerId, topPeerId || "n/a");
      const topPeerValue = isSelectableNodeId(topPeerId)
        ? savedDetailHtmlValue(
            `<button type="button" class="saved-node-inline-link" data-node-id="${{escAttr(topPeerId)}}" title="${{escAttr(`Open node details for ${{topPeerLabel}} (${{topPeerId}})` )}}" aria-label="${{escAttr(`Open node details for ${{topPeerLabel}} (${{topPeerId}})` )}}">${{escAttr(topPeerLabel)}}</button>`,
            topPeerLabel,
          )
        : "n/a";
      const nodeDisplayName = node
        ? nodeLabel(node)
        : (nodeNameCache.get(nodeId) || nodeId || "n/a");
      const nodeSectionRows = [
        ["Display Name", nodeDisplayName],
        ["Node ID", nodeId],
        ["Node Num", node && node.num != null ? String(node.num) : "n/a"],
        ["Hardware", (node && node.hardware_model) || "n/a"],
        ["Role", (node && node.role) || "n/a"],
        ["Freshness Source", freshnessSource],
        ["Battery", batteryText],
        ["Hops Away", hopsText],
        ["Voltage", Number.isFinite(voltageValue) ? `${{voltageValue.toFixed(2)}}V` : "n/a"],
        ["Channel Util", Number.isFinite(channelUtilValue) ? savedDetailPercent(channelUtilValue) : "n/a"],
        ["Air Util TX", Number.isFinite(airUtilTxValue) ? savedDetailPercent(airUtilTxValue) : "n/a"],
        ["GPS Capable", positionCapable],
        ["Last Position Ping", savedDetailText(latestPosTimeText)],
      ];
      const nodeSection = savedDetailSectionHtml("Node", nodeSectionRows);
      const noteDraft = needsNotesSection && nodeNoteDraftById.has(nodeId)
        ? String(nodeNoteDraftById.get(nodeId) || "")
        : null;
      const notesSection = needsNotesSection
        ? savedNodeNotesSectionHtml(nodeId, nodeNoteEntry(nodeId), noteDraft)
        : "";

      const locationSection = needsLocationSection
        ? savedDetailSectionHtml("Location", [
            ["Last Broadcast Position", latestPosText],
            ["Position Source", positionSource],
            ["Position Age", latestPosAgeText],
            ["Latest Position Time", latestPosTimeText],
            ["Altitude", Number.isFinite(latestTrailAltitude) ? `${{formatMetricValue(latestTrailAltitude, 0)}} m` : "n/a"],
            ["Satellites", Number.isFinite(latestTrailSats) ? String(Math.round(latestTrailSats)) : "n/a"],
            ["Trail Start", savedDetailText(historySummary.trail_start)],
            ["Trail End", savedDetailText(historySummary.trail_end)],
          ], "Radio screens can show a newer local GPS fix before that fix is broadcast to this dashboard.")
        : "";

      let chatSection = "";
      if (needsChatSection && chatStats) {{
        const chatSectionRows = [
          ["Messages Touching Node", String(chatStats.touches)],
          ["Sent", String(chatStats.sent)],
          ["Received", String(chatStats.received)],
          ["Broadcast Sent", String(chatStats.broadcastSent)],
          ["Direct Sent", String(chatStats.directSent)],
          ["Reactions Sent", String(chatStats.reactionsSent)],
          ["Active Peers", String(chatStats.peers.size)],
          ["Last Chat", savedDetailText(chatStats.lastChatText)],
        ];
        if (malformedTextCount > 0) {{
          const malformedTextLatestText = (
            Number.isFinite(malformedTextLatestUnix) && malformedTextLatestUnix > 0
              ? `${{formatLocalChatTime(malformedTextLatestUnix, "n/a", nowUnix)}} (${{savedDetailAge(malformedTextLatestUnix, nowUnix)}})`
              : "n/a"
          );
          chatSectionRows.push(
            ["Malformed Text Packets", `${{malformedTextCount}} recent packet${{malformedTextCount === 1 ? "" : "s"}}`],
            ["Last Malformed Text", malformedTextLatestText],
            ["Malformed Payload Preview", malformedTextPayloadPreview || "n/a"],
          );
        }}
        const chatSectionNote = malformedTextCount > 0
          ? `Based on current in-memory packet/chat buffers. Warning: this node recently sent non-UTF-8 bytes on TEXT_MESSAGE_APP, which usually means a buggy or experimental sender rather than normal chat traffic.`
          : `Based on current in-memory chat buffer (${{chatMessages.length}} messages).`;
        chatSection = savedDetailSectionHtml("Chat (Recent Buffer)", chatSectionRows, chatSectionNote);
      }}

      const linksSection = needsLinksSection && linkStats
        ? savedDetailSectionHtml("Links", [
            ["Directed Links", String(linkStats.links)],
            ["Linked Peers", String(linkStats.peers.size)],
            ["Lifetime Packets", String(Math.round(linkStats.lifetimePackets))],
            ["Session Packets", String(Math.round(linkStats.sessionPackets))],
            ["Avg Link Hops", linkAvgHops],
            ["Last Link Activity", savedDetailText(linkStats.lastSeenText)],
            ["Top Peer", topPeerValue],
            ["Top Peer Packets", linkStats.topPeer ? String(Math.round(linkStats.topPeerPackets)) : "n/a"],
            ["Seen Ports", linkStats.ports.size > 0 ? Array.from(linkStats.ports).slice(0, 10).join(", ") : "n/a"],
          ])
        : "";

      const nextSectionsHtml = `
        ${{nodeSection}}
        ${{renderNotesInDrawer ? "" : notesSection}}
        ${{renderLocationInDrawer ? "" : locationSection}}
        ${{renderChatInDrawer ? "" : chatSection}}
        ${{renderLinksInDrawer ? "" : linksSection}}
      `;
      let sectionsHost = host.querySelector(".saved-node-sections");
      let detailsMarkupChanged = false;
      if (!(sectionsHost instanceof HTMLElement)) {{
        const nextDetailsShellHtml = `
          <div class="saved-node-stack">
            <div class="saved-node-main-scroll">
              <div class="saved-node-sections"></div>
            </div>
          </div>
        `;
        detailsMarkupChanged = setElementHtmlIfChanged(host, nextDetailsShellHtml, "saved-node-details-shell");
        sectionsHost = host.querySelector(".saved-node-sections");
      }}
      if (sectionsHost instanceof HTMLElement) {{
        detailsMarkupChanged = setElementHtmlIfChanged(sectionsHost, nextSectionsHtml, "saved-node-sections") || detailsMarkupChanged;
      }}
      host.dataset.nodeId = nodeId;
      const nextLocationHtml = renderLocationInDrawer ? locationSection : "";
      const nextChatHtml = renderChatInDrawer ? chatSection : "";
      const nextLinksHtml = renderLinksInDrawer ? linksSection : "";
      const nextNotesHtml = renderNotesInDrawer ? notesSection : "";
      setElementHtmlIfChanged(locationHost, nextLocationHtml, "chat-node-details-location");
      setElementHtmlIfChanged(chatHost, nextChatHtml, "chat-node-details-chat");
      setElementHtmlIfChanged(linksHost, nextLinksHtml, "chat-node-details-links");
      const notesMarkupChanged = setElementHtmlIfChanged(notesHost, nextNotesHtml, "chat-node-details-notes");
      bindSavedNodeDetailLinkButtons(host);
      bindSavedNodeDetailLinkButtons(linksHost);
      bindSavedNodeCoordinateLinks(host);
      bindSavedNodeCoordinateLinks(locationHost);
      if (detailsMarkupChanged || notesMarkupChanged) {{
        bindSavedNodeNotesEditor(nodeId);
      }}
      syncNodeHistoryDock();
      if ((detailsMarkupChanged || notesMarkupChanged) && previousNodeId === nodeId) {{
        const restoreNoteFocus = () => {{
          if (!previousNoteFocused) return;
          const nextNoteInput = document.getElementById("saved-node-note-input");
          if (!(nextNoteInput instanceof HTMLTextAreaElement)) return;
          if (normalizeNodeId(nextNoteInput.dataset.nodeId || "") !== nodeId) return;
          if (nextNoteInput.closest("[hidden]")) return;
          const selectionStart = Number.isFinite(previousNoteSelectionStart)
            ? Math.max(0, Math.min(nextNoteInput.value.length, Math.trunc(previousNoteSelectionStart)))
            : nextNoteInput.value.length;
          const selectionEnd = Number.isFinite(previousNoteSelectionEnd)
            ? Math.max(selectionStart, Math.min(nextNoteInput.value.length, Math.trunc(previousNoteSelectionEnd)))
            : selectionStart;
          try {{
            nextNoteInput.focus({{ preventScroll: true }});
          }} catch (_err) {{
            nextNoteInput.focus();
          }}
          try {{
            nextNoteInput.setSelectionRange(selectionStart, selectionEnd);
          }} catch (_err) {{
          }}
        }};
        const restoreMainScroll = () => {{
          const nextMainScroll = host.querySelector(".saved-node-main-scroll");
          if (!(nextMainScroll instanceof HTMLElement)) return;
          const prevMax = Math.max(0, previousScrollHeight - previousClientHeight);
          const nextMax = Math.max(0, nextMainScroll.scrollHeight - nextMainScroll.clientHeight);
          const currentTop = Math.max(0, Number(nextMainScroll.scrollTop) || 0);
          if (prevMax <= 0) {{
            if (currentTop > 1) {{
              nextMainScroll.scrollTop = 0;
            }}
            return;
          }}
          const nearBottom = (prevMax - previousScrollTop) <= 2;
          const targetTop = nearBottom
            ? nextMax
            : Math.max(0, Math.min(nextMax, Math.round((previousScrollTop / prevMax) * nextMax)));
          if (Math.abs(targetTop - currentTop) <= 1) return;
          if (nearBottom) {{
            nextMainScroll.scrollTop = targetTop;
            return;
          }}
          nextMainScroll.scrollTop = targetTop;
        }};
        // Run once immediately, then once after layout settles (history dock + flex sizing).
        if (detailsMarkupChanged) {{
          restoreMainScroll();
        }}
        restoreNoteFocus();
        window.requestAnimationFrame(() => {{
          if (normalizeNodeId(host.dataset.nodeId || "") !== nodeId) return;
          if (detailsMarkupChanged) {{
            restoreMainScroll();
          }}
          restoreNoteFocus();
        }});
      }}
    }}
