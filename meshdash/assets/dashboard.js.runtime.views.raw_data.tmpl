    function normalizeEnvMetricKey(raw) {{
      return String(raw == null ? "" : raw)
        .trim()
        .replace(/[^a-zA-Z0-9_]+/g, "_")
        .replace(/_+/g, "_")
        .replace(/^_+|_+$/g, "")
        .toLowerCase();
    }}

    function formatEnvMetricLabel(raw) {{
      const text = String(raw == null ? "" : raw)
        .replace(/[_-]+/g, " ")
        .replace(/([a-z0-9])([A-Z])/g, "$1 $2")
        .trim();
      if (!text) return "Metric";
      return text.replace(/\b([a-z])/gi, (match) => match.toUpperCase());
    }}

    function envMetricFiniteNumber(raw) {{
      if (typeof raw === "boolean" || raw == null) return null;
      if (typeof raw === "number") {{
        return Number.isFinite(raw) ? raw : null;
      }}
      const text = String(raw).trim();
      if (!text) return null;
      const normalized = text.replace(/,/g, "");
      const num = Number(normalized);
      return Number.isFinite(num) ? num : null;
    }}

    function envMetricValueText(raw, fallback = "n/a") {{
      const num = Number(raw);
      if (!Number.isFinite(num)) return fallback;
      const abs = Math.abs(num);
      const decimals = abs >= 100 ? 0 : (abs >= 10 ? 1 : 2);
      return num.toFixed(decimals);
    }}

    function environmentMetricsNowMs() {{
      return (typeof performance !== "undefined" && performance && typeof performance.now === "function")
        ? performance.now()
        : Date.now();
    }}

    function roundEnvironmentMetricsMs(value) {{
      const ms = Number(value);
      return Number.isFinite(ms) ? Math.round(Math.max(0, ms) * 100) / 100 : 0;
    }}

    function environmentMetricsPerfEnabled() {{
      return !!(typeof window !== "undefined" && window.__meshDashboardGuiBenchmarkActive === true);
    }}

    function startEnvironmentMetricsRenderPerf(forceRefresh = false) {{
      if (!environmentMetricsPerfEnabled()) return null;
      const startedAtMs = environmentMetricsNowMs();
      return {{
        status: "running",
        forceRefresh: !!forceRefresh,
        startedAtMs,
        totalMs: 0,
        points: 0,
        metrics: 0,
        nodes: 0,
        selectedMetric: "",
        selectedNodeId: "",
        windowHours: 0,
        snapshotSkipped: false,
        phases: [],
      }};
    }}

    function markEnvironmentMetricsRenderPerf(run, name, extra = null) {{
      if (!run) return;
      const nowMs = environmentMetricsNowMs();
      const phases = Array.isArray(run.phases) ? run.phases : [];
      const previous = phases.length
        ? Number(phases[phases.length - 1].atMs) || 0
        : 0;
      const atMs = roundEnvironmentMetricsMs(nowMs - (Number(run.startedAtMs) || nowMs));
      const phase = {{
        name: String(name || "phase"),
        atMs,
        deltaMs: roundEnvironmentMetricsMs(atMs - previous),
      }};
      if (extra && typeof extra === "object") {{
        Object.assign(phase, extra);
      }}
      phases.push(phase);
      run.phases = phases;
    }}

    function finishEnvironmentMetricsRenderPerf(run, status, extra = null) {{
      if (!run) return;
      run.status = String(status || "complete");
      run.totalMs = roundEnvironmentMetricsMs(environmentMetricsNowMs() - (Number(run.startedAtMs) || environmentMetricsNowMs()));
      if (extra && typeof extra === "object") {{
        Object.assign(run, extra);
      }}
      delete run.startedAtMs;
      if (typeof window !== "undefined") {{
        const store = window.__meshEnvironmentMetricsRenderStats && typeof window.__meshEnvironmentMetricsRenderStats === "object"
          ? window.__meshEnvironmentMetricsRenderStats
          : {{ runs: [] }};
        const runs = Array.isArray(store.runs) ? store.runs : [];
        runs.push(run);
        if (runs.length > 80) {{
          runs.splice(0, runs.length - 80);
        }}
        store.runs = runs;
        store.last = run;
        window.__meshEnvironmentMetricsRenderStats = store;
      }}
    }}

    function normalizeEnvHistoryHours(raw) {{
      const parsed = Number(raw);
      if (!Number.isFinite(parsed)) return 72;
      return Math.max(1, Math.min(24 * 365, Math.trunc(parsed)));
    }}

    function formatEnvHistoryTime(unix) {{
      const parsed = Number(unix);
      if (!Number.isFinite(parsed) || parsed <= 0) return "n/a";
      try {{
        return new Date(parsed * 1000).toLocaleString();
      }} catch (_err) {{
        return "n/a";
      }}
    }}

    function setEnvironmentMetricsStatus(text, kind = "info") {{
      const status = document.getElementById("env-metrics-status");
      if (!(status instanceof HTMLElement)) return;
      const nextText = String(text == null ? "" : text).trim() || "n/a";
      const nextKind = String(kind || "info");
      if (status.textContent !== nextText) {{
        status.textContent = nextText;
      }}
      if (status.dataset.kind !== nextKind) {{
        status.dataset.kind = nextKind;
      }}
    }}

    function environmentMetricsCatalogTtlMs() {{
      return Math.max(refreshMs * 2, 8000);
    }}

    function environmentMetricsSeriesTtlMs() {{
      return Math.max(refreshMs * 2, 6000);
    }}

    function environmentMetricsCacheEntryFresh(entry, ttlMs, nowMs = Date.now()) {{
      return !!(
        entry
        && entry.data
        && (nowMs - (Number(entry.fetchedAt) || 0)) < Math.max(0, Number(ttlMs) || 0)
      );
    }}

    function pruneEnvironmentMetricsCache(cache, ttlMs, maxEntriesRaw, nowMs = Date.now()) {{
      if (!(cache instanceof Map)) return;
      const maxEntries = Math.max(1, Math.trunc(Number(maxEntriesRaw) || 1));
      const safeTtlMs = Math.max(0, Number(ttlMs) || 0);
      for (const [key, entry] of cache.entries()) {{
        if (!environmentMetricsCacheEntryFresh(entry, safeTtlMs, nowMs)) {{
          cache.delete(key);
        }}
      }}
      while (cache.size > maxEntries) {{
        const oldest = cache.keys().next();
        if (!oldest || oldest.done) break;
        cache.delete(oldest.value);
      }}
    }}

    function setEnvironmentMetricsCacheEntry(cache, cacheKeyRaw, payload, maxEntriesRaw, ttlMs) {{
      if (!(cache instanceof Map)) return;
      const cacheKey = String(cacheKeyRaw || "").trim();
      if (!cacheKey) return;
      if (cache.has(cacheKey)) {{
        cache.delete(cacheKey);
      }}
      cache.set(cacheKey, {{
        fetchedAt: Date.now(),
        data: payload,
      }});
      pruneEnvironmentMetricsCache(cache, ttlMs, maxEntriesRaw);
    }}

    function environmentMetricsSeriesCacheKey(windowHours, metricKey, nodeId) {{
      return [
        String(normalizeEnvHistoryHours(windowHours)),
        normalizeEnvMetricKey(metricKey || ""),
        normalizeNodeId(nodeId || ""),
      ].join("|");
    }}

    function syncEnvironmentWindowPicker() {{
      const select = document.getElementById("env-window-select");
      const requestedHours = envMetricsViewState.selectedWindowHours || (select && select.value);
      const nextHours = normalizeEnvHistoryHours(requestedHours);
      envMetricsViewState.selectedWindowHours = nextHours;
      if (select instanceof HTMLSelectElement && String(select.value) !== String(nextHours)) {{
        select.value = String(nextHours);
      }}
      return nextHours;
    }}

    function syncEnvironmentMetricPicker(metrics) {{
      const select = document.getElementById("env-metric-select");
      if (!(select instanceof HTMLSelectElement)) return "";
      const safeMetrics = Array.isArray(metrics) ? metrics : [];
      if (!safeMetrics.length) {{
        select.innerHTML = '<option value="">No sensor metrics</option>';
        select.disabled = true;
        envMetricsViewState.selectedMetric = "";
        return "";
      }}
      const optionsHtml = safeMetrics.map((meta) => (
        `<option value="${{escAttr(meta.key)}}">${{escAttr(meta.label)}} (${{Math.max(0, Math.trunc(Number(meta.count) || 0))}})</option>`
      )).join("");
      if (select.innerHTML !== optionsHtml) {{
        select.innerHTML = optionsHtml;
      }}
      const requested = normalizeEnvMetricKey(envMetricsViewState.selectedMetric || select.value);
      const hasRequested = safeMetrics.some((meta) => meta.key === requested);
      const nextKey = hasRequested ? requested : safeMetrics[0].key;
      if (select.value !== nextKey) {{
        select.value = nextKey;
      }}
      select.disabled = false;
      envMetricsViewState.selectedMetric = nextKey;
      return nextKey;
    }}

    function deriveEnvironmentNodeMetaFromPoints(points) {{
      const safePoints = Array.isArray(points) ? points : [];
      const perNode = new Map();
      for (const point of safePoints) {{
        const nodeId = normalizeNodeId(point && point.node_id);
        if (!nodeId) continue;
        const fallbackLabel = String((point && point.node_label) || nodeId);
        const metricKey = normalizeEnvMetricKey(point && point.metric_key);
        const sampleCount = Math.max(1, Math.trunc(Number(point && point.sample_count) || 1));
        const sampleUnix = Math.max(0, Math.trunc(Number(point && point.unix) || 0));
        if (!perNode.has(nodeId)) {{
          perNode.set(nodeId, {{
            id: nodeId,
            label: resolveEnvironmentNodeDisplayName(nodeId, fallbackLabel) || fallbackLabel || nodeId,
            count: 0,
            metricKeys: new Set(),
            last_unix: sampleUnix,
          }});
        }}
        const nodeState = perNode.get(nodeId);
        nodeState.count += sampleCount;
        if (metricKey) nodeState.metricKeys.add(metricKey);
        nodeState.last_unix = Math.max(
          Math.max(0, Math.trunc(Number(nodeState.last_unix) || 0)),
          sampleUnix,
        );
        if (nodeState.label === "" || normalizeNodeId(nodeState.label) === nodeId) {{
          nodeState.label = resolveEnvironmentNodeDisplayName(nodeId, fallbackLabel) || fallbackLabel || nodeId;
        }}
      }}
      const rows = Array.from(perNode.values()).map((row) => {{
        const lastUnix = Math.max(0, Math.trunc(Number(row && row.last_unix) || 0));
        const metricKeys = (row && row.metricKeys instanceof Set) ? row.metricKeys : new Set();
        return {{
          id: String((row && row.id) || "").trim(),
          label: String((row && row.label) || (row && row.id) || "node"),
          count: Math.max(0, Math.trunc(Number(row && row.count) || 0)),
          metrics: metricKeys.size,
          last_unix: lastUnix,
          last_seen: lastUnix > 0 ? formatEnvHistoryTime(lastUnix) : "n/a",
        }};
      }}).filter((row) => normalizeNodeId(row.id));
      rows.sort((a, b) => (
        (Number(b && b.count) || 0) - (Number(a && a.count) || 0)
      ) || String((a && a.label) || "").localeCompare(String((b && b.label) || "")));
      return rows;
    }}

    function resolveEnvironmentNodeOptions(nodes, points) {{
      const safeNodes = Array.isArray(nodes)
        ? nodes.filter((meta) => normalizeNodeId(meta && meta.id))
        : [];
      if (safeNodes.length) return safeNodes;
      return deriveEnvironmentNodeMetaFromPoints(points);
    }}

    function resolveEnvironmentMetricMeta(metrics, metricKey) {{
      const safeMetrics = Array.isArray(metrics) ? metrics : [];
      const key = normalizeEnvMetricKey(metricKey);
      if (!key) return safeMetrics[0] || null;
      return safeMetrics.find((meta) => meta.key === key) || safeMetrics[0] || null;
    }}

    function resolveEnvironmentNodeMeta(nodes, nodeId) {{
      const safeNodes = Array.isArray(nodes) ? nodes : [];
      const cleanNodeId = normalizeNodeId(nodeId || "");
