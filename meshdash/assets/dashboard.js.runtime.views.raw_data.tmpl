    function renderEnvironmentNodeLegend(metricMeta, nodeMeta, nodes, filteredPoints, chartMeta, hiddenNodeIds) {{
      const host = document.getElementById("env-metrics-available");
      if (!(host instanceof HTMLElement)) return;
      host.hidden = false;
      bindEnvironmentNodeLegendToggle();
      const safeChartMeta = (chartMeta && typeof chartMeta === "object") ? chartMeta : {{}};
      const legendItems = Array.isArray(safeChartMeta.legendItems) ? safeChartMeta.legendItems : [];
      const totalSeries = Math.max(0, Math.trunc(Number(safeChartMeta.totalSeries) || 0));
      const visibleSeries = Math.max(0, Math.trunc(Number(safeChartMeta.visibleSeries) || 0));
      const hiddenSet = hiddenNodeIds instanceof Set ? hiddenNodeIds : new Set();
      if (!metricMeta || !metricMeta.key) {{
        host.textContent = "No sensor metric keys detected yet in saved telemetry history.";
        return;
      }}
      const hiddenSeries = Math.max(0, totalSeries - visibleSeries);
      host.innerHTML = [
        ...legendItems.map((item) => (
          `<button class="history-metric-inline env-node-legend-pill env-node-legend-toggle${{hiddenSet.has(normalizeNodeId(item.nodeId)) ? " is-hidden" : ""}}" type="button" data-env-node-toggle="1" data-node-id="${{escAttr(item.nodeId)}}" data-node-hidden="${{hiddenSet.has(normalizeNodeId(item.nodeId)) ? "1" : "0"}}" aria-pressed="${{hiddenSet.has(normalizeNodeId(item.nodeId)) ? "false" : "true"}}" style="--node-color:${{escAttr(item.color)}};" title="${{escAttr(`${{formatEnvironmentNodeTooltipLabel(item.nodeId, item.label)}} • click to ${{hiddenSet.has(normalizeNodeId(item.nodeId)) ? "show" : "hide"}}`)}}">
            <span class="v">${{escAttr(item.label)}}</span>
          </button>`
        )),
        hiddenSeries > 0
          ? `<span class="history-metric-inline env-node-legend-pill env-node-legend-more"><span class="v">+${{hiddenSeries}} hidden</span></span>`
          : "",
      ].filter(Boolean).join("");
    }}

    function downsampleEnvironmentSeries(points, maxPoints = 260) {{
      const safePoints = Array.isArray(points) ? points : [];
      if (safePoints.length <= maxPoints) return safePoints;
      const step = Math.max(1, Math.ceil(safePoints.length / maxPoints));
      const out = [];
      for (let idx = 0; idx < safePoints.length; idx += step) {{
        out.push(safePoints[idx]);
      }}
      const tail = safePoints[safePoints.length - 1];
      if (out[out.length - 1] !== tail) {{
        out.push(tail);
      }}
      return out;
    }}

    function buildEnvironmentSeriesPointsWithBreaks(points) {{
      const safePoints = Array.isArray(points) ? points : [];
      if (!safePoints.length) return [];
      const positiveGaps = [];
      for (let idx = 1; idx < safePoints.length; idx += 1) {{
        const prevUnix = Number(safePoints[idx - 1] && safePoints[idx - 1].unix);
        const unix = Number(safePoints[idx] && safePoints[idx].unix);
        const gap = unix - prevUnix;
        if (Number.isFinite(gap) && gap > 0) {{
          positiveGaps.push(gap);
        }}
      }}
      positiveGaps.sort((a, b) => a - b);
      const medianGap = positiveGaps.length
        ? positiveGaps[Math.floor(positiveGaps.length / 2)]
        : 0;
      const gapThreshold = medianGap > 0
        ? Math.max(3600, medianGap * 6)
        : (6 * 3600);
      return safePoints.map((point, idx) => {{
        const unix = Math.trunc(Number(point && point.unix) || 0);
        const prevUnix = idx > 0
          ? Math.trunc(Number(safePoints[idx - 1] && safePoints[idx - 1].unix) || 0)
          : 0;
        return {{
          unix,
          value: Number(point && point.value),
          breakBefore: idx > 0 && (unix - prevUnix) > gapThreshold,
        }};
      }});
    }}

    function buildEnvironmentLinearPath(points) {{
      const safePoints = Array.isArray(points) ? points : [];
      return safePoints.map((point, idx) => (
        `${{idx === 0 || point.breakBefore ? "M" : "L"}} ${{Number(point.x).toFixed(2)}} ${{Number(point.y).toFixed(2)}}`
      )).join(" ");
    }}

    function buildEnvironmentTimelineRows(points) {{
      const safePoints = Array.isArray(points) ? points : [];
      const uniqueUnix = Array.from(new Set(
        safePoints
          .map((point) => Math.trunc(Number(point && point.unix) || 0))
          .filter((unix) => Number.isFinite(unix) && unix > 0)
      )).sort((a, b) => a - b);
      return uniqueUnix.map((unix) => ({{ unix }}));
    }}

    function sortedEnvironmentMetricValues(values) {{
      return (Array.isArray(values) ? values : [])
        .map((value) => Number(value))
        .filter((value) => Number.isFinite(value))
        .sort((a, b) => a - b);
    }}

    function environmentMetricQuantile(sortedValues, ratio) {{
      const values = Array.isArray(sortedValues) ? sortedValues : [];
      if (!values.length) return NaN;
      if (values.length === 1) return Number(values[0]);
      const clampedRatio = Math.max(0, Math.min(1, Number(ratio) || 0));
      const position = clampedRatio * (values.length - 1);
      const lowerIndex = Math.floor(position);
      const upperIndex = Math.ceil(position);
      if (lowerIndex === upperIndex) {{
        return Number(values[lowerIndex]);
      }}
      const lowerValue = Number(values[lowerIndex]);
      const upperValue = Number(values[upperIndex]);
      const mix = position - lowerIndex;
      return lowerValue + ((upperValue - lowerValue) * mix);
    }}

    function resolveEnvironmentMetricValueBounds(values) {{
      const sortedValues = sortedEnvironmentMetricValues(values);
      if (!sortedValues.length) {{
        return {{
          minValue: NaN,
          maxValue: NaN,
          clippedCount: 0,
        }};
      }}
      const rawMinValue = Number(sortedValues[0]);
      const rawMaxValue = Number(sortedValues[sortedValues.length - 1]);
      if (!(Number.isFinite(rawMinValue) && Number.isFinite(rawMaxValue))) {{
        return {{
          minValue: NaN,
          maxValue: NaN,
          clippedCount: 0,
        }};
      }}
      let clippedCount = 0;
      let minValue = rawMinValue;
      let maxValue = rawMaxValue;
      if (sortedValues.length >= 6) {{
        const q1 = environmentMetricQuantile(sortedValues, 0.25);
        const q3 = environmentMetricQuantile(sortedValues, 0.75);
        const iqr = q3 - q1;
        if (Number.isFinite(iqr) && iqr > 1e-6) {{
          const lowerFence = q1 - (iqr * 1.5);
          const upperFence = q3 + (iqr * 1.5);
          const bounded = sortedValues.filter((value) => value >= lowerFence && value <= upperFence);
          if (bounded.length >= Math.max(4, Math.round(sortedValues.length * 0.55))) {{
            const boundedMin = Number(bounded[0]);
            const boundedMax = Number(bounded[bounded.length - 1]);
            if (
              Number.isFinite(boundedMin)
              && Number.isFinite(boundedMax)
              && boundedMax >= boundedMin
              && (boundedMin > rawMinValue || boundedMax < rawMaxValue)
            ) {{
              minValue = boundedMin;
              maxValue = boundedMax;
              clippedCount = sortedValues.length - bounded.length;
            }}
          }}
        }}
      }}
      return {{
        minValue,
        maxValue,
        clippedCount,
      }};
    }}

    function localNodeIdForEnvironmentMetrics() {{
      if (typeof resolveLocalNodeId !== "function") return "";
      try {{
        return normalizeNodeId(resolveLocalNodeId(latestState) || "");
      }} catch (_err) {{
        return "";
      }}
    }}

    function selectEnvironmentSeriesForAllNodes(seriesList, maxSeries = envMetricsChartMaxSeries) {{
      const safeSeries = Array.isArray(seriesList) ? seriesList.slice() : [];
      const cap = Math.max(1, Math.trunc(Number(maxSeries) || envMetricsChartMaxSeries));
      if (safeSeries.length <= cap) return safeSeries;

      const localNodeId = localNodeIdForEnvironmentMetrics();
      const selected = [];
      const seenNodeIds = new Set();

      if (isCanonicalNodeId(localNodeId)) {{
        const localSeries = safeSeries.find((series) => normalizeNodeId(series && series.nodeId) === localNodeId) || null;
        if (localSeries) {{
          selected.push(localSeries);
          seenNodeIds.add(localNodeId);
        }}
      }}

      const ranked = safeSeries
        .slice()
        .sort((a, b) => {{
          const lastA = Number(a && a.lastUnix);
          const lastB = Number(b && b.lastUnix);
          if (lastA !== lastB) return lastB - lastA;
          const pointsA = Array.isArray(a && a.points) ? a.points.length : 0;
          const pointsB = Array.isArray(b && b.points) ? b.points.length : 0;
          if (pointsA !== pointsB) return pointsB - pointsA;
          return String((a && a.label) || "").localeCompare(String((b && b.label) || ""));
        }});

      for (const series of ranked) {{
        const nodeId = normalizeNodeId(series && series.nodeId);
        if (nodeId && seenNodeIds.has(nodeId)) continue;
        selected.push(series);
        if (nodeId) seenNodeIds.add(nodeId);
        if (selected.length >= cap) break;
      }}
      return selected.slice(0, cap);
    }}

    function clampEnvironmentMetricChartUnit(value) {{
      const num = Number(value);
      if (!Number.isFinite(num)) return 0;
      if (num < 0) return 0;
      if (num > 1) return 1;
      return num;
    }}

    function environmentMetricsChartZoomMinSpan(totalPoints) {{
      const total = Math.max(0, Math.floor(Number(totalPoints) || 0));
      if (total <= 2) return 1;
      const minPoints = Math.max(2, Math.min(total, envMetricsChartZoomMinPoints));
      return Math.max(1 / Math.max(1, total - 1), (minPoints - 1) / Math.max(1, total - 1));
    }}

    function normalizeEnvironmentMetricsChartZoomWindow(totalPoints) {{
      const minSpan = environmentMetricsChartZoomMinSpan(totalPoints);
      let start = clampEnvironmentMetricChartUnit(envMetricsChartState.zoomStart);
      let end = clampEnvironmentMetricChartUnit(envMetricsChartState.zoomEnd);
      if (end <= start) {{
        end = Math.min(1, start + minSpan);
      }}
      let span = end - start;
      if (span < minSpan) {{
        const center = start + (span / 2);
        span = minSpan;
        start = center - (span / 2);
        end = center + (span / 2);
      }}
      if (start < 0) {{
        end = Math.min(1, end - start);
        start = 0;
      }}
      if (end > 1) {{
        start = Math.max(0, start - (end - 1));
        end = 1;
      }}
      span = end - start;
      if (span < minSpan) {{
        start = Math.max(0, end - minSpan);
        end = Math.min(1, start + minSpan);
      }}
      envMetricsChartState.zoomStart = clampEnvironmentMetricChartUnit(start);
      envMetricsChartState.zoomEnd = clampEnvironmentMetricChartUnit(end);
    }}

    function setEnvironmentMetricsChartZoomWindow(start, end, totalPoints) {{
      const prevStart = envMetricsChartState.zoomStart;
      const prevEnd = envMetricsChartState.zoomEnd;
      envMetricsChartState.zoomStart = start;
      envMetricsChartState.zoomEnd = end;
      normalizeEnvironmentMetricsChartZoomWindow(totalPoints);
      return Math.abs(envMetricsChartState.zoomStart - prevStart) > 1e-6
        || Math.abs(envMetricsChartState.zoomEnd - prevEnd) > 1e-6;
    }}

    function resetEnvironmentMetricsChartZoom(scopeKey = "") {{
      envMetricsChartState.zoomStart = 0;
      envMetricsChartState.zoomEnd = 1;
      envMetricsChartState.pointerDrag = null;
      envMetricsChartState.scopeKey = String(scopeKey || "").trim();
      envMetricsChartState.suppressClickUntilMs = 0;
    }}

    function getEnvironmentMetricsChartAxisBounds(svg) {{
      const rect = svg.getBoundingClientRect();
      const axisStartPx = rect.left + ((envMetricsChartLayout.padLeft / envMetricsChartLayout.width) * rect.width);
      const axisEndPx = rect.left + (((envMetricsChartLayout.width - envMetricsChartLayout.padRight) / envMetricsChartLayout.width) * rect.width);
      const axisWidthPx = Math.max(1, axisEndPx - axisStartPx);
      return {{ axisStartPx, axisEndPx, axisWidthPx }};
    }}

    function currentEnvironmentMetricSelectionMeta() {{
      const points = Array.isArray(envMetricsViewState.points) ? envMetricsViewState.points : [];
      const metrics = Array.isArray(envMetricsViewState.metrics) ? envMetricsViewState.metrics : [];
      const nodes = resolveEnvironmentNodeOptions(envMetricsViewState.nodes, points);
      const selectedMetric = normalizeEnvMetricKey(envMetricsViewState.selectedMetric || "");
      const selectedNodeId = currentEnvironmentMetricsScopedNodeId();
      const metricMeta = resolveEnvironmentMetricMeta(metrics, selectedMetric);
      const nodeMeta = resolveEnvironmentScopedNodeMeta(nodes, selectedNodeId);
      const filteredPoints = filterEnvironmentMetricPoints(points, selectedMetric, selectedNodeId);
      return {{ filteredPoints, metricMeta, nodeMeta }};
    }}

    function rerenderEnvironmentMetricsChartFromSelection() {{
      const {{ filteredPoints, metricMeta, nodeMeta }} = currentEnvironmentMetricSelectionMeta();
      const nodes = resolveEnvironmentNodeOptions(envMetricsViewState.nodes, envMetricsViewState.points);
      const selectionScopeKey = buildEnvironmentMetricsSelectionScopeKey(metricMeta, nodeMeta);
      const hiddenNodeIds = syncEnvironmentLegendScope(selectionScopeKey);
      const chartMeta = renderEnvironmentMetricsChart(filteredPoints, metricMeta, nodeMeta, hiddenNodeIds);
      renderEnvironmentNodeLegend(metricMeta, nodeMeta, nodes, filteredPoints, chartMeta, hiddenNodeIds);
    }}

    function setEnvironmentMetricsChartTitle(svg, metricLabel, zoomed) {{
      if (!(svg instanceof SVGElement)) return;
      const chartLabel = String(metricLabel || "Sensor history chart").trim() || "Sensor history chart";
      svg.classList.toggle("zoomed", !!zoomed);
      svg.setAttribute(
        "title",
        zoomed
          ? `${{chartLabel}} zoomed. Wheel to zoom, drag to pan, double-click or Esc to reset.`
          : `${{chartLabel}}. Wheel to zoom, drag to pan, double-click or Esc to reset.`
      );
    }}

    function bindEnvironmentMetricsChartZoom() {{
      const svg = document.getElementById("env-metrics-chart");
      if (!(svg instanceof SVGElement) || svg.dataset.zoomBound === "1") return;
      svg.dataset.zoomBound = "1";
      svg.setAttribute("tabindex", "0");

      svg.addEventListener("wheel", (ev) => {{
        const total = Number(svg.dataset.zoomPointCount || "0");
        if (!Number.isFinite(total) || total < 3) return;
        const {{ axisStartPx, axisEndPx, axisWidthPx }} = getEnvironmentMetricsChartAxisBounds(svg);
        if (ev.clientX < axisStartPx || ev.clientX > axisEndPx) return;
        ev.preventDefault();
        const anchorRatio = clampEnvironmentMetricChartUnit((ev.clientX - axisStartPx) / axisWidthPx);
        const currentSpan = Math.max(1e-6, envMetricsChartState.zoomEnd - envMetricsChartState.zoomStart);
        const zoomFactor = ev.deltaY < 0 ? 0.84 : 1.19;
        const minSpan = environmentMetricsChartZoomMinSpan(total);
        const nextSpan = Math.max(minSpan, Math.min(1, currentSpan * zoomFactor));
        const anchor = envMetricsChartState.zoomStart + (anchorRatio * currentSpan);
        const nextStart = anchor - (anchorRatio * nextSpan);
        const nextEnd = nextStart + nextSpan;
        if (setEnvironmentMetricsChartZoomWindow(nextStart, nextEnd, total)) {{
          rerenderEnvironmentMetricsChartFromSelection();
        }}
      }}, {{ passive: false }});

      svg.addEventListener("dblclick", (ev) => {{
        ev.preventDefault();
        const total = Number(svg.dataset.zoomPointCount || "0");
        if (setEnvironmentMetricsChartZoomWindow(0, 1, total || 2)) {{
          rerenderEnvironmentMetricsChartFromSelection();
        }}
      }});

      svg.addEventListener("pointerdown", (ev) => {{
        if (ev.button !== 0) return;
        const total = Number(svg.dataset.zoomPointCount || "0");
        if (!Number.isFinite(total) || total < 3) return;
        const {{ axisStartPx, axisEndPx }} = getEnvironmentMetricsChartAxisBounds(svg);
        if (ev.clientX < axisStartPx || ev.clientX > axisEndPx) return;
        envMetricsChartState.pointerDrag = {{
          pointerId: ev.pointerId,
          startClientX: ev.clientX,
          startZoomStart: envMetricsChartState.zoomStart,
          startZoomEnd: envMetricsChartState.zoomEnd,
          hitNodeId: resolveEnvironmentMetricsChartNodeIdFromTarget(ev.target),
          moved: false,
        }};
        svg.classList.add("chart-dragging");
        try {{
          svg.setPointerCapture(ev.pointerId);
        }} catch (_err) {{
        }}
        ev.preventDefault();
      }});

      svg.addEventListener("pointermove", (ev) => {{
        const drag = envMetricsChartState.pointerDrag;
        if (!drag || drag.pointerId !== ev.pointerId) return;
        const total = Number(svg.dataset.zoomPointCount || "0");
        if (!Number.isFinite(total) || total < 3) return;
        const {{ axisWidthPx }} = getEnvironmentMetricsChartAxisBounds(svg);
        const deltaPx = ev.clientX - drag.startClientX;
        if (Math.abs(deltaPx) > 3) {{
          drag.moved = true;
        }}
        const deltaRatio = deltaPx / axisWidthPx;
        const dragSpan = drag.startZoomEnd - drag.startZoomStart;
        const nextStart = drag.startZoomStart - (deltaRatio * dragSpan);
        const nextEnd = drag.startZoomEnd - (deltaRatio * dragSpan);
        if (setEnvironmentMetricsChartZoomWindow(nextStart, nextEnd, total)) {{
          rerenderEnvironmentMetricsChartFromSelection();
        }}
      }});

      const clearDrag = (ev) => {{
        const drag = envMetricsChartState.pointerDrag;
        if (!drag) return;
        if (ev && drag.pointerId !== ev.pointerId) return;
        const dragged = drag.moved === true;
        envMetricsChartState.pointerDrag = null;
        svg.classList.remove("chart-dragging");
        if (dragged) {{
          envMetricsChartState.suppressClickUntilMs = Date.now() + 180;
        }} else if (ev && drag.hitNodeId) {{
          envMetricsChartState.suppressClickUntilMs = Date.now() + 180;
          focusEnvironmentNodeFromChart(drag.hitNodeId);
        }}
        if (ev) {{
          try {{
            svg.releasePointerCapture(ev.pointerId);
          }} catch (_err) {{
          }}
        }}
      }};
      svg.addEventListener("pointerup", clearDrag);
      svg.addEventListener("pointercancel", clearDrag);
      svg.addEventListener("lostpointercapture", clearDrag);
      svg.addEventListener("keydown", (ev) => {{
        if (ev.key !== "Escape") return;
        const total = Number(svg.dataset.zoomPointCount || "0");
        if (setEnvironmentMetricsChartZoomWindow(0, 1, total || 2)) {{
          rerenderEnvironmentMetricsChartFromSelection();
        }}
      }});
    }}

    function renderEnvironmentMetricsChart(points, metricMeta, nodeMeta, hiddenNodeIds) {{
      const svg = document.getElementById("env-metrics-chart");
      const empty = document.getElementById("env-metrics-empty");
      const timelineId = "env-metrics-timeline";
      if (!(svg instanceof SVGElement) || !(empty instanceof HTMLElement)) {{
        return {{ legendItems: [], totalSeries: 0, visibleSeries: 0 }};
      }}
      bindEnvironmentMetricsChartZoom();

      const metricLabel = String(metricMeta && metricMeta.label ? metricMeta.label : "Sensor history chart").trim() || "Sensor history chart";
      const clearChart = (emptyText) => {{
        svg.innerHTML = "";
        svg.dataset.zoomPointCount = "0";
        svg.classList.remove("zoomed", "chart-dragging");
        envMetricsChartState.pointerDrag = null;
        setEnvironmentMetricsChartTitle(svg, metricLabel, false);
        setTimelineMessage(
          timelineId,
          emptyText || "Timeline available when history points are present."
        );
        if (emptyText) {{
          empty.textContent = String(emptyText || "").trim();
          empty.hidden = false;
        }} else {{
          empty.hidden = true;
        }}
        return {{ legendItems: [], totalSeries: 0, visibleSeries: 0 }};
      }};

      if (!metricMeta || !metricMeta.key) {{
        return clearChart("No historical sensor metrics found yet.");
      }}

      const safePoints = Array.isArray(points) ? points : [];
      if (!safePoints.length) {{
        return clearChart(`No historical points for ${{metricMeta.label}}${{nodeMeta ? ` from ${{nodeMeta.label || nodeMeta.id}}` : ""}}.`);
      }}

      const selectionScopeKey = buildEnvironmentMetricsSelectionScopeKey(metricMeta, nodeMeta);
      if (envMetricsChartState.scopeKey !== selectionScopeKey) {{
        resetEnvironmentMetricsChartZoom(selectionScopeKey);
      }}

      const seriesByNodeId = new Map();
      for (const point of safePoints) {{
        const nodeId = normalizeNodeId(point && point.node_id) || "unknown";
        const nodeLabel = String((point && point.node_label) || nodeId);
        const pointUnix = Number(point && point.unix);
        const value = envMetricFiniteNumber(point && point.value);
        if (!Number.isFinite(pointUnix) || pointUnix <= 0 || !Number.isFinite(value)) continue;
        if (!seriesByNodeId.has(nodeId)) {{
          seriesByNodeId.set(nodeId, {{
            nodeId,
            label: nodeLabel,
            points: [],
          }});
        }}
        seriesByNodeId.get(nodeId).points.push({{
          unix: Math.trunc(pointUnix),
          value,
        }});
      }}

      let seriesList = Array.from(seriesByNodeId.values())
        .map((series) => {{
          const sorted = series.points
            .slice()
            .sort((a, b) => Number(a.unix) - Number(b.unix));
          const lastPoint = sorted.length ? sorted[sorted.length - 1] : null;
          return {{
            nodeId: series.nodeId,
            label: series.label,
            points: downsampleEnvironmentSeries(sorted),
            lastUnix: Number(lastPoint && lastPoint.unix) || 0,
          }};
        }})
        .filter((series) => series.points.length > 0)
        .sort((a, b) => (b.points.length - a.points.length) || String(a.label).localeCompare(String(b.label)));

      if (!seriesList.length) {{
        return clearChart("No valid timestamped telemetry points in this selection.");
      }}
      if (!nodeMeta && seriesList.length > envMetricsChartMaxSeries) {{
        seriesList = selectEnvironmentSeriesForAllNodes(seriesList, envMetricsChartMaxSeries);
      }}
      const plottedSeries = seriesList.slice();
      const totalSeries = plottedSeries.length;
      const dockedInNetwork = !!svg.closest(".network-sensors-panel");
      const hiddenSet = hiddenNodeIds instanceof Set ? hiddenNodeIds : new Set();
      const legendItems = plottedSeries.map((series, idx) => {{
        const color = envMetricColorPalette[idx % envMetricColorPalette.length];
        const seriesNodeId = String(series.nodeId || "").trim();
        return {{
          nodeId: seriesNodeId,
          label: resolveEnvironmentNodeDisplayName(seriesNodeId, series.label),
          color,
          pointCount: Array.isArray(series.points) ? series.points.length : 0,
          hidden: hiddenSet.has(normalizeNodeId(seriesNodeId)),
        }};
      }});
      const seriesColorByNodeId = new Map(
        legendItems.map((item) => [normalizeNodeId(item.nodeId), String(item.color || "")])
      );
      seriesList = plottedSeries.filter((series) => {{
        const seriesNodeId = normalizeNodeId(series && series.nodeId);
        if (!seriesNodeId) return true;
        return !hiddenSet.has(seriesNodeId);
      }});
      const visibleSeriesCount = seriesList.length;
      if (!seriesList.length) {{
        svg.innerHTML = "";
        svg.dataset.zoomPointCount = "0";
        svg.classList.remove("zoomed", "chart-dragging");
        envMetricsChartState.pointerDrag = null;
        setEnvironmentMetricsChartTitle(svg, metricLabel, false);
        setTimelineMessage(
          timelineId,
          "Timeline available when one or more plotted nodes are visible."
        );
        empty.textContent = "All plotted nodes are hidden. Use the legend to show one or more nodes.";
        empty.hidden = false;
        return {{
          legendItems,
          totalSeries,
          visibleSeries: 0,
        }};
      }}

      const allPoints = seriesList.flatMap((series) => series.points);
      const fullMinUnix = Math.min(...allPoints.map((point) => Number(point.unix)));
      const fullMaxUnix = Math.max(...allPoints.map((point) => Number(point.unix)));
      const uniqueUnix = Array.from(
        new Set(
          allPoints
            .map((point) => Math.trunc(Number(point && point.unix)))
            .filter((unix) => Number.isFinite(unix) && unix > 0)
        )
      ).sort((a, b) => a - b);
      const zoomPointCount = uniqueUnix.length;
      svg.dataset.zoomPointCount = String(zoomPointCount);
      normalizeEnvironmentMetricsChartZoomWindow(zoomPointCount);

      const fullUnixSpan = Math.max(1, fullMaxUnix - fullMinUnix);
      let visibleMinUnix = fullMinUnix;
      let visibleMaxUnix = fullMaxUnix;
      if (zoomPointCount > 1) {{
        visibleMinUnix = fullMinUnix + (envMetricsChartState.zoomStart * fullUnixSpan);
        visibleMaxUnix = fullMinUnix + (envMetricsChartState.zoomEnd * fullUnixSpan);
      }}
      const unixWindowPad = Math.max(1, fullUnixSpan * 0.0005);
      let visibleSeriesList = seriesList
        .map((series) => ({{
          nodeId: series.nodeId,
          label: series.label,
          points: series.points.filter((point) => {{
            const unix = Number(point && point.unix);
            return Number.isFinite(unix) && unix >= (visibleMinUnix - unixWindowPad) && unix <= (visibleMaxUnix + unixWindowPad);
          }}),
        }}))
        .filter((series) => series.points.length > 0);

      if (!visibleSeriesList.length) {{
        if (setEnvironmentMetricsChartZoomWindow(0, 1, zoomPointCount || 2)) {{
          visibleMinUnix = fullMinUnix;
          visibleMaxUnix = fullMaxUnix;
        }}
        visibleSeriesList = seriesList;
      }}

      const visiblePoints = visibleSeriesList.flatMap((series) => series.points);
      const visibleValues = visiblePoints
        .map((point) => Number(point && point.value))
        .filter((value) => Number.isFinite(value));
      const bounds = resolveEnvironmentMetricValueBounds(visibleValues);
      const rawMinValue = Number(bounds && bounds.minValue);
      const rawMaxValue = Number(bounds && bounds.maxValue);

      if (!Number.isFinite(rawMinValue) || !Number.isFinite(rawMaxValue)) {{
        return clearChart("No numeric values in this selection.");
      }}

      let minValue = rawMinValue;
      let maxValue = rawMaxValue;
      if (!(Number.isFinite(minValue) && Number.isFinite(maxValue) && maxValue > minValue)) {{
        minValue = rawMinValue;
        maxValue = rawMaxValue;
      }}

      if (Math.abs(maxValue - minValue) < 1e-9) {{
        minValue -= 1;
        maxValue += 1;
      }} else {{
        const pad = (maxValue - minValue) * 0.1;
        minValue -= pad;
        maxValue += pad;
      }}
      const clippedPointCount = Math.max(0, Math.trunc(Number(bounds && bounds.clippedCount) || 0));

      const darkTheme = document.documentElement.getAttribute("data-theme") === "dark";
      const themeStyles = window.getComputedStyle
        ? window.getComputedStyle(document.documentElement)
        : null;
      const themeColor = (name, fallback) => {{
        if (!(themeStyles && typeof themeStyles.getPropertyValue === "function")) {{
          return fallback;
        }}
        const value = String(themeStyles.getPropertyValue(name) || "").trim();
        return value || fallback;
      }};
      const palette = dockedInNetwork
        ? (
          darkTheme
            ? {{
              grid: themeColor("--workspace-shell-border-muted", "#324152"),
              guide: themeColor("--workspace-shell-border-muted", "#324152"),
              guideOpacity: "0.45",
              text: themeColor("--workspace-shell-text-soft", "#9ce7b8"),
              axis: themeColor("--workspace-shell-text", "#d7e6f2"),
            }}
            : {{
              grid: "#dce8df",
              guide: "#dce8df",
              guideOpacity: "0.65",
              text: "#1f6f53",
              axis: "#1f6f53",
            }}
        )
        : (
          darkTheme
            ? {{
              grid: "#324152",
              guide: "rgba(83, 110, 135, 0.32)",
              guideOpacity: "1",
              text: "#b8cfde",
              axis: "#84a7bf",
            }}
            : {{
              grid: "rgba(76, 102, 126, 0.24)",
              guide: "rgba(106, 132, 156, 0.2)",
              guideOpacity: "1",
              text: "#557189",
              axis: "#395369",
            }}
        );

      const measuredWidth = Number(svg.clientWidth);
      const measuredHeight = Number(svg.clientHeight);
      const width = Number.isFinite(measuredWidth) && measuredWidth > 10
        ? Math.max(480, Math.round(measuredWidth))
        : envMetricsChartLayout.width;
      const height = Number.isFinite(measuredHeight) && measuredHeight > 10
        ? Math.max(240, Math.round(measuredHeight))
        : envMetricsChartLayout.height;
      const padLeft = dockedInNetwork ? 38 : envMetricsChartLayout.padLeft;
      const padRight = dockedInNetwork ? 18 : envMetricsChartLayout.padRight;
      const padTop = envMetricsChartLayout.padTop;
      const padBottom = dockedInNetwork ? 18 : envMetricsChartLayout.padBottom;
      const chartWidth = width - padLeft - padRight;
      const chartHeight = height - padTop - padBottom;
      const unixSpan = Math.max(1, visibleMaxUnix - visibleMinUnix);
      const valueSpan = Math.max(1e-9, maxValue - minValue);
      const xForUnix = (unix) => padLeft + (((Number(unix) - visibleMinUnix) / unixSpan) * chartWidth);
      const yForValue = (value) => {{
        const y = padTop + (((maxValue - Number(value)) / valueSpan) * chartHeight);
        return Math.max(padTop, Math.min(padTop + chartHeight, y));
      }};

      const yAxisTicks = buildLinearAxisTicks(minValue, maxValue, 5);
      const axisTextStyle = "font-family:'IBM Plex Sans','Segoe UI',sans-serif;font-size:10px;font-weight:600;font-variant-numeric:tabular-nums;letter-spacing:0.01em;";
      const yGrid = [];
      const yLabels = [];
      for (const tick of yAxisTicks) {{
        const value = Number(tick && tick.value);
        const y = yForValue(value);
        yGrid.push(`<line x1="${{padLeft}}" y1="${{y.toFixed(2)}}" x2="${{(padLeft + chartWidth).toFixed(2)}}" y2="${{y.toFixed(2)}}" stroke="${{palette.grid}}" stroke-width="1"></line>`);
        yLabels.push(`<text class="chart-axis-label" style="${{axisTextStyle}}" x="${{(padLeft - 4).toFixed(2)}}" y="${{(y + 4).toFixed(2)}}" text-anchor="end" fill="${{palette.axis}}">${{escAttr(envMetricValueText(value))}}</text>`);
      }}

      const xGrid = [];
      const linePaths = [];
      const timelineRows = buildEnvironmentTimelineRows(visiblePoints);
      if (dockedInNetwork) {{
        const dayBoundaries = [];
        let lastDayKey = "";
        for (const row of timelineRows) {{
          const unix = Number(row && row.unix);
          const dayKey = timelineDayKey(unix);
          if (!dayKey) continue;
          if (!lastDayKey) {{
            lastDayKey = dayKey;
            continue;
          }}
          if (dayKey !== lastDayKey) {{
            dayBoundaries.push(unix);
            lastDayKey = dayKey;
          }}
        }}
        for (const unix of dayBoundaries) {{
          const x = xForUnix(unix);
          xGrid.push(`<line x1="${{x.toFixed(2)}}" y1="${{padTop}}" x2="${{x.toFixed(2)}}" y2="${{(padTop + chartHeight).toFixed(2)}}" stroke="${{palette.guide}}" stroke-width="1" stroke-dasharray="2 3" stroke-opacity="${{palette.guideOpacity}}"></line>`);
        }}
      }} else {{
        const xTicks = 6;
        for (let idx = 0; idx < xTicks; idx += 1) {{
          const ratio = xTicks <= 1 ? 0 : (idx / (xTicks - 1));
          const unix = Math.round(visibleMinUnix + (ratio * unixSpan));
          const x = xForUnix(unix);
          xGrid.push(`<line x1="${{x.toFixed(2)}}" y1="${{padTop}}" x2="${{x.toFixed(2)}}" y2="${{(padTop + chartHeight).toFixed(2)}}" stroke="${{palette.guide}}" stroke-width="1" stroke-dasharray="3 5"></line>`);
        }}
      }}

      visibleSeriesList.forEach((series, idx) => {{
        const seriesNodeId = String(series.nodeId || "").trim();
        const color = seriesColorByNodeId.get(normalizeNodeId(seriesNodeId)) || envMetricColorPalette[idx % envMetricColorPalette.length];
        const seriesTitle = formatEnvironmentNodeTooltipLabel(seriesNodeId, series.label);
        const sourcePoints = buildEnvironmentSeriesPointsWithBreaks(series.points);
        const smoothingWindow = normalizeSmoothingWindow(
          Math.max(3, Math.min(9, Math.round(sourcePoints.length / 18))),
          sourcePoints.length
        );
        const trendPoints = smoothSeriesPointsWithBreaks(sourcePoints, smoothingWindow);
        const toScreenPoint = (point) => ({{
          x: xForUnix(point.unix),
          y: yForValue(point.value),
          breakBefore: !!point.breakBefore,
        }});
        const rawPoints = aggregatePointsByXPixels(
          sourcePoints.map((point) => toScreenPoint(point)),
          1.05
        );
        const trendScreenPoints = aggregatePointsByXPixels(
          trendPoints.map((point) => toScreenPoint(point)),
          3.4
        );
        const rawPath = buildEnvironmentLinearPath(rawPoints);
        const trendLinearPath = buildEnvironmentLinearPath(trendScreenPoints);
        const trendPath = buildSmoothSvgPath(trendScreenPoints, 0.22) || trendLinearPath;
        const hitPath = trendPath || rawPath;
        if (!hitPath) return;
        const rawStrokeWidth = dockedInNetwork ? 1.2 : 1.1;
        const rawStrokeOpacity = dockedInNetwork ? 0.26 : 0.24;
        const trendStrokeWidth = dockedInNetwork ? 2.65 : 2.35;
        const trendStrokeOpacity = dockedInNetwork ? 1 : 0.98;
        const seriesPaths = [];
        if (dockedInNetwork && trendPath) {{
          seriesPaths.push(`<path d="${{trendPath}}" fill="none" stroke="${{color}}" stroke-width="5.6" stroke-linecap="round" stroke-linejoin="round" stroke-opacity="0.14" pointer-events="none"></path>`);
        }}
        seriesPaths.push(`<path d="${{rawPath}}" fill="none" stroke="${{color}}" stroke-width="${{rawStrokeWidth.toFixed(2)}}" stroke-linecap="round" stroke-linejoin="round" stroke-opacity="${{rawStrokeOpacity.toFixed(2)}}" style="cursor:pointer;"><title>${{escAttr(`${{seriesTitle}} - click to select or deselect node`)}}</title></path>`);
        seriesPaths.push(`<path d="${{trendPath}}" fill="none" stroke="${{color}}" stroke-width="${{trendStrokeWidth.toFixed(2)}}" stroke-linecap="round" stroke-linejoin="round" stroke-opacity="${{trendStrokeOpacity.toFixed(2)}}" style="cursor:pointer;"><title>${{escAttr(`${{seriesTitle}} - click to select or deselect node`)}}</title></path>`);
        seriesPaths.push(`<path d="${{hitPath}}" fill="none" stroke="transparent" stroke-width="11" stroke-linecap="round" stroke-linejoin="round" pointer-events="stroke" style="cursor:pointer;"><title>${{escAttr(`${{seriesTitle}} - click to select or deselect node`)}}</title></path>`);
        linePaths.push(`<g data-node-id="${{escAttr(seriesNodeId)}}">${{seriesPaths.join("")}}</g>`);
      }});

      const zoomed = zoomPointCount > 1 && (
        envMetricsChartState.zoomStart > 1e-6
        || envMetricsChartState.zoomEnd < (1 - 1e-6)
      );
      svg.setAttribute("viewBox", `0 0 ${{width}} ${{height}}`);
      svg.innerHTML = `
        <g>
          <rect x="${{padLeft}}" y="${{padTop}}" width="${{chartWidth}}" height="${{chartHeight}}" fill="none" stroke="${{palette.grid}}" stroke-width="1"></rect>
          ${{yGrid.join("")}}
          ${{xGrid.join("")}}
          ${{linePaths.join("")}}
          ${{yLabels.join("")}}
        </g>
      `;
      renderTimeline(
        timelineId,
        timelineRows,
        padLeft,
        padRight,
        width,
        (row) => Number(row && row.unix)
      );
      if (svg.dataset.nodeClickBound !== "1") {{
        svg.dataset.nodeClickBound = "1";
        svg.addEventListener("click", (event) => {{
          if (Date.now() < Number(envMetricsChartState.suppressClickUntilMs || 0)) {{
            event.preventDefault();
            return;
          }}
          const target = event.target;
          if (!(target instanceof Element)) return;
          const hit = target.closest("[data-node-id]");
          if (!(hit instanceof Element)) return;
          const nodeId = normalizeNodeId(hit.getAttribute("data-node-id") || "");
          if (!nodeId) return;
          event.preventDefault();
          focusEnvironmentNodeFromChart(nodeId);
        }});
      }}
      setEnvironmentMetricsChartTitle(svg, metricMeta.label || "Sensor history chart", zoomed);
      empty.hidden = true;
      return {{
        legendItems,
        totalSeries,
        visibleSeries: visibleSeriesCount,
      }};
    }}

    function buildEnvironmentMetricsSnapshotRenderSignature(
      windowHours,
      selectedMetric,
      selectedNodeId,
      hiddenNodeIds,
      dockedInNetwork,
    ) {{
      const hiddenKey = Array.from(hiddenNodeIds instanceof Set ? hiddenNodeIds : new Set())
        .map((nodeId) => normalizeNodeId(nodeId))
        .filter(Boolean)
        .sort()
        .join(",");
      return [
        String(normalizeEnvHistoryHours(windowHours)),
        normalizeEnvMetricKey(selectedMetric || ""),
        normalizeNodeId(selectedNodeId || ""),
        String(Math.max(0, Math.trunc(Number(envMetricsViewState.catalogVersion) || 0))),
        String(Math.max(0, Math.trunc(Number(envMetricsViewState.seriesVersion) || 0))),
        String(envMetricsViewState.source || ""),
        String(Math.max(0, Math.trunc(Number(envMetricsViewState.scannedPackets) || 0))),
        String(Math.max(0, Math.trunc(Number(envMetricsViewState.cutoffUnix) || 0))),
        Number(envMetricsChartState.zoomStart).toFixed(6),
        Number(envMetricsChartState.zoomEnd).toFixed(6),
        hiddenKey,
        dockedInNetwork ? "network" : "home",
      ].join("|");
    }}

    function renderEnvironmentMetricsSnapshot(options = null) {{
      const forceRender = !!(options && options.force);
      const points = Array.isArray(envMetricsViewState.points) ? envMetricsViewState.points : [];
      const metrics = Array.isArray(envMetricsViewState.metrics) ? envMetricsViewState.metrics : [];
      const nodes = resolveEnvironmentNodeOptions(envMetricsViewState.nodes, points);
      const windowHours = syncEnvironmentWindowPicker();
      const selectedMetric = syncEnvironmentMetricPicker(metrics);
      const selectedNodeId = currentEnvironmentMetricsScopedNodeId();
      const metricMeta = resolveEnvironmentMetricMeta(metrics, selectedMetric);
      const nodeMeta = resolveEnvironmentScopedNodeMeta(nodes, selectedNodeId);
      const filteredPoints = filterEnvironmentMetricPoints(points, selectedMetric, selectedNodeId);
      const selectionScopeKey = buildEnvironmentMetricsSelectionScopeKey(metricMeta, nodeMeta);
      const hiddenNodeIds = syncEnvironmentLegendScope(selectionScopeKey);
      const chartSvg = document.getElementById("env-metrics-chart");
      const dockedInNetwork = !!(chartSvg instanceof SVGElement && chartSvg.closest(".network-sensors-panel"));
      const renderSignature = buildEnvironmentMetricsSnapshotRenderSignature(
        windowHours,
        selectedMetric,
        selectedNodeId,
        hiddenNodeIds,
        dockedInNetwork,
      );
      if (!forceRender && renderSignature && envMetricsViewState.lastSnapshotRenderSignature === renderSignature) {{
        return {{
          skipped: true,
          points: filteredPoints.length,
          metrics: metrics.length,
          nodes: nodes.length,
          selectedMetric,
          selectedNodeId,
          windowHours,
        }};
      }}
      envMetricsViewState.lastSnapshotRenderSignature = renderSignature;
      const chartMeta = renderEnvironmentMetricsChart(filteredPoints, metricMeta, nodeMeta, hiddenNodeIds);
      const activeLegendNodeIds = new Set(
        (Array.isArray(chartMeta && chartMeta.legendItems) ? chartMeta.legendItems : [])
          .map((item) => normalizeNodeId(item && item.nodeId))
          .filter(Boolean)
      );
      pruneEnvironmentLegendHiddenNodeIds(activeLegendNodeIds);
      renderEnvironmentNodeLegend(metricMeta, nodeMeta, nodes, filteredPoints, chartMeta, hiddenNodeIds);
      const renderedCount = Math.max(0, Math.trunc(Number(filteredPoints.length) || 0));

      if (!metrics.length || !nodes.length) {{
        setEnvironmentMetricsStatus("No historical sensor telemetry has been saved yet.", "warn");
        return {{
          skipped: false,
          points: filteredPoints.length,
          metrics: metrics.length,
          nodes: nodes.length,
          selectedMetric,
          selectedNodeId,
          windowHours,
        }};
      }}
      if (!metricMeta) {{
        setEnvironmentMetricsStatus("Metric list loaded, but no metric is currently selected.", "warn");
        return {{
          skipped: false,
          points: filteredPoints.length,
          metrics: metrics.length,
          nodes: nodes.length,
          selectedMetric,
          selectedNodeId,
          windowHours,
        }};
      }}
      const nodeSummary = nodeMeta
        ? `${{nodeMeta.label || nodeMeta.id}} (${{nodeMeta.id}})`
        : `${{nodes.length}} nodes`;
      const scannedLabel = (String(envMetricsViewState.source || "").toLowerCase() === "rollup_1m")
        ? "Scanned rollup rows"
        : "Scanned packets";
      setEnvironmentMetricsStatus(
        `Window ${{windowHours}}h • Metric: ${{metricMeta.label}} • Scope: ${{nodeSummary}} • Points: ${{renderedCount}} • ${{scannedLabel}}: ${{Math.max(0, Math.trunc(Number(envMetricsViewState.scannedPackets) || 0))}}`,
        filteredPoints.length ? "info" : "warn",
      );
      return {{
        skipped: false,
        points: filteredPoints.length,
        metrics: metrics.length,
        nodes: nodes.length,
        selectedMetric,
        selectedNodeId,
        windowHours,
      }};
    }}

    function applyEnvironmentMetricsCatalogPayload(payload) {{
      const data = (payload && typeof payload === "object") ? payload : {{}};
      if (envMetricsViewState.lastCatalogPayload !== data) {{
        envMetricsViewState.lastCatalogPayload = data;
        envMetricsViewState.catalogVersion = Math.max(0, Math.trunc(Number(envMetricsViewState.catalogVersion) || 0)) + 1;
      }}
      envMetricsViewState.metrics = Array.isArray(data.metrics) ? data.metrics : [];
      envMetricsViewState.nodes = Array.isArray(data.nodes) ? data.nodes : [];
      envMetricsViewState.selectedWindowHours = normalizeEnvHistoryHours(data.window_hours || envMetricsViewState.selectedWindowHours);
      const selectedMetric = normalizeEnvMetricKey(envMetricsViewState.selectedMetric || "");
      if (!selectedMetric || !envMetricsViewState.metrics.some((meta) => normalizeEnvMetricKey(meta && meta.key) === selectedMetric)) {{
        const firstMetric = envMetricsViewState.metrics[0];
        envMetricsViewState.selectedMetric = firstMetric ? normalizeEnvMetricKey(firstMetric.key) : "";
      }}
    }}

    function applyEnvironmentMetricsSeriesPayload(payload) {{
      const data = (payload && typeof payload === "object") ? payload : {{}};
      if (envMetricsViewState.lastSeriesPayload !== data) {{
        envMetricsViewState.lastSeriesPayload = data;
        envMetricsViewState.seriesVersion = Math.max(0, Math.trunc(Number(envMetricsViewState.seriesVersion) || 0)) + 1;
      }}
      envMetricsViewState.points = Array.isArray(data.points) ? data.points : [];
      envMetricsViewState.source = String(data.source || "");
      envMetricsViewState.scannedPackets = Math.max(0, Math.trunc(Number(data.scanned_packets) || 0));
      envMetricsViewState.cutoffUnix = Math.max(0, Math.trunc(Number(data.cutoff_unix) || 0));
      envMetricsViewState.selectedWindowHours = normalizeEnvHistoryHours(data.window_hours || envMetricsViewState.selectedWindowHours);
    }}

    async function fetchEnvironmentMetricsCatalog(windowHours, forceRefresh = false) {{
      const cleanHours = normalizeEnvHistoryHours(windowHours);
      const cacheKey = String(cleanHours);
      const nowMs = Date.now();
      const ttlMs = environmentMetricsCatalogTtlMs();
      pruneEnvironmentMetricsCache(envMetricsCatalogCache, ttlMs, envMetricsCatalogCacheMaxEntries, nowMs);
      const cached = envMetricsCatalogCache.get(cacheKey);
      if (!forceRefresh && environmentMetricsCacheEntryFresh(cached, ttlMs, nowMs)) {{
        return cached.data;
      }}
      const inflight = envMetricsCatalogInflight.get(cacheKey);
      if (!forceRefresh && inflight) {{
        return inflight;
      }}
      const params = new URLSearchParams();
      params.set("hours", String(cleanHours));
      params.set("limit", "25000");
      params.set("catalog", "1");
      const request = fetch(`/api/history/environment?${{params.toString()}}`, {{ cache: "no-store" }})
        .then(async (resp) => {{
          if (!resp.ok) throw new Error(`sensor history API ${{resp.status}}`);
          const payload = await resp.json();
          if (!payload || typeof payload !== "object") {{
            throw new Error("sensor history returned an invalid payload");
          }}
          if (payload.ok === false) {{
            throw new Error(String(payload.error || "sensor history unavailable"));
          }}
          setEnvironmentMetricsCacheEntry(envMetricsCatalogCache, cacheKey, payload, envMetricsCatalogCacheMaxEntries, ttlMs);
          return payload;
        }})
        .finally(() => {{
          if (envMetricsCatalogInflight.get(cacheKey) === request) {{
            envMetricsCatalogInflight.delete(cacheKey);
          }}
        }});
      if (!forceRefresh) {{
        envMetricsCatalogInflight.set(cacheKey, request);
      }}
      return request;
    }}

    async function fetchEnvironmentMetricsSeries(windowHours, metricKey, nodeId, forceRefresh = false) {{
      const cleanHours = normalizeEnvHistoryHours(windowHours);
      const cleanMetric = normalizeEnvMetricKey(metricKey || "");
      const cleanNodeId = normalizeNodeId(nodeId || "");
      const cacheKey = environmentMetricsSeriesCacheKey(cleanHours, cleanMetric, cleanNodeId);
      const nowMs = Date.now();
      const ttlMs = environmentMetricsSeriesTtlMs();
      pruneEnvironmentMetricsCache(envMetricsSeriesCache, ttlMs, envMetricsSeriesCacheMaxEntries, nowMs);
      const cached = envMetricsSeriesCache.get(cacheKey);
      if (!forceRefresh && environmentMetricsCacheEntryFresh(cached, ttlMs, nowMs)) {{
        return cached.data;
      }}
      const inflight = envMetricsSeriesInflight.get(cacheKey);
      if (!forceRefresh && inflight) {{
        return inflight;
      }}
      const params = new URLSearchParams();
      params.set("hours", String(cleanHours));
      params.set("limit", "100000");
      params.set("gap_scan", "0");
      if (cleanMetric) {{
        params.set("metric", cleanMetric);
      }}
      if (cleanNodeId) {{
        params.set("node_id", cleanNodeId);
      }}
      const request = fetch(`/api/history/environment?${{params.toString()}}`, {{ cache: "no-store" }})
        .then(async (resp) => {{
          if (!resp.ok) throw new Error(`sensor history API ${{resp.status}}`);
          const payload = await resp.json();
          if (!payload || typeof payload !== "object") {{
            throw new Error("sensor history returned an invalid payload");
          }}
          if (payload.ok === false) {{
            throw new Error(String(payload.error || "sensor history unavailable"));
          }}
          setEnvironmentMetricsCacheEntry(envMetricsSeriesCache, cacheKey, payload, envMetricsSeriesCacheMaxEntries, ttlMs);
          return payload;
        }})
        .finally(() => {{
          if (envMetricsSeriesInflight.get(cacheKey) === request) {{
            envMetricsSeriesInflight.delete(cacheKey);
          }}
        }});
      if (!forceRefresh) {{
        envMetricsSeriesInflight.set(cacheKey, request);
      }}
      return request;
    }}

    function bindEnvironmentMetricsControls() {{
      const windowSelect = document.getElementById("env-window-select");
      if (windowSelect instanceof HTMLSelectElement && windowSelect.dataset.bound !== "1") {{
        windowSelect.dataset.bound = "1";
        windowSelect.addEventListener("change", () => {{
          envMetricsViewState.selectedWindowHours = normalizeEnvHistoryHours(windowSelect.value);
          void renderEnvironmentMetricsView(false);
        }});
      }}

      const metricSelect = document.getElementById("env-metric-select");
      if (metricSelect instanceof HTMLSelectElement && metricSelect.dataset.bound !== "1") {{
        metricSelect.dataset.bound = "1";
        metricSelect.addEventListener("change", () => {{
          envMetricsViewState.selectedMetric = normalizeEnvMetricKey(metricSelect.value);
          void renderEnvironmentMetricsView(false);
        }});
      }}
    }}

    async function renderEnvironmentMetricsView(forceRefresh = false) {{
      const perfRun = startEnvironmentMetricsRenderPerf(forceRefresh);
      bindEnvironmentMetricsControls();
      const windowHours = syncEnvironmentWindowPicker();
      const selectedMetricBefore = normalizeEnvMetricKey(envMetricsViewState.selectedMetric || "");
      const selectedNodeIdBefore = currentEnvironmentMetricsScopedNodeId();
      markEnvironmentMetricsRenderPerf(perfRun, "start", {{
        windowHours,
        selectedMetric: selectedMetricBefore,
        selectedNodeId: selectedNodeIdBefore,
      }});
      if (forceRefresh || !envMetricsViewState.lastSnapshotRenderSignature) {{
        setEnvironmentMetricsStatus(`Loading saved sensor telemetry (${windowHours}h window)...`, "info");
      }}
      try {{
        const catalogCacheKey = String(windowHours);
        const catalogCacheEntry = envMetricsCatalogCache.get(catalogCacheKey);
        const catalogCacheFresh = environmentMetricsCacheEntryFresh(catalogCacheEntry, environmentMetricsCatalogTtlMs());
        markEnvironmentMetricsRenderPerf(perfRun, "catalog-start", {{
          cacheFresh: !forceRefresh && catalogCacheFresh,
          inflight: envMetricsCatalogInflight.has(catalogCacheKey),
        }});
        const catalogPayload = await fetchEnvironmentMetricsCatalog(windowHours, forceRefresh);
        markEnvironmentMetricsRenderPerf(perfRun, "catalog", {{
          metrics: Array.isArray(catalogPayload && catalogPayload.metrics) ? catalogPayload.metrics.length : 0,
          nodes: Array.isArray(catalogPayload && catalogPayload.nodes) ? catalogPayload.nodes.length : 0,
        }});
        applyEnvironmentMetricsCatalogPayload(catalogPayload);
        const selectedMetric = syncEnvironmentMetricPicker(envMetricsViewState.metrics);
        const selectedNodeId = currentEnvironmentMetricsScopedNodeId();
        if (!selectedMetric) {{
          envMetricsViewState.points = [];
          envMetricsViewState.source = "";
          envMetricsViewState.scannedPackets = 0;
          envMetricsViewState.cutoffUnix = 0;
          const snapshotResult = renderEnvironmentMetricsSnapshot({{ force: forceRefresh }});
          markEnvironmentMetricsRenderPerf(perfRun, "snapshot", {{
            skipped: !!(snapshotResult && snapshotResult.skipped),
            points: Math.max(0, Math.trunc(Number(snapshotResult && snapshotResult.points) || 0)),
          }});
          finishEnvironmentMetricsRenderPerf(perfRun, "no-metric", {{
            points: 0,
            metrics: Array.isArray(envMetricsViewState.metrics) ? envMetricsViewState.metrics.length : 0,
            nodes: Array.isArray(envMetricsViewState.nodes) ? envMetricsViewState.nodes.length : 0,
            selectedMetric: "",
            selectedNodeId,
            windowHours,
            snapshotSkipped: !!(snapshotResult && snapshotResult.skipped),
          }});
          return;
        }}
        const seriesCacheKey = environmentMetricsSeriesCacheKey(windowHours, selectedMetric, selectedNodeId);
        const seriesCacheEntry = envMetricsSeriesCache.get(seriesCacheKey);
        const seriesCacheFresh = environmentMetricsCacheEntryFresh(seriesCacheEntry, environmentMetricsSeriesTtlMs());
        markEnvironmentMetricsRenderPerf(perfRun, "series-start", {{
          cacheFresh: !forceRefresh && seriesCacheFresh,
          inflight: envMetricsSeriesInflight.has(seriesCacheKey),
          selectedMetric,
          selectedNodeId,
        }});
        const seriesPayload = await fetchEnvironmentMetricsSeries(
          windowHours,
          selectedMetric,
          selectedNodeId,
          forceRefresh,
        );
        markEnvironmentMetricsRenderPerf(perfRun, "series", {{
          points: Array.isArray(seriesPayload && seriesPayload.points) ? seriesPayload.points.length : 0,
          source: String((seriesPayload && seriesPayload.source) || ""),
        }});
        applyEnvironmentMetricsSeriesPayload(seriesPayload);
        const snapshotResult = renderEnvironmentMetricsSnapshot({{ force: forceRefresh }});
        markEnvironmentMetricsRenderPerf(perfRun, "snapshot", {{
          skipped: !!(snapshotResult && snapshotResult.skipped),
          points: Math.max(0, Math.trunc(Number(snapshotResult && snapshotResult.points) || 0)),
        }});
        finishEnvironmentMetricsRenderPerf(perfRun, "ok", {{
          points: Math.max(0, Math.trunc(Number(snapshotResult && snapshotResult.points) || 0)),
          metrics: Math.max(0, Math.trunc(Number(snapshotResult && snapshotResult.metrics) || 0)),
          nodes: Math.max(0, Math.trunc(Number(snapshotResult && snapshotResult.nodes) || 0)),
          selectedMetric: snapshotResult && snapshotResult.selectedMetric ? snapshotResult.selectedMetric : selectedMetric,
          selectedNodeId: snapshotResult && snapshotResult.selectedNodeId ? snapshotResult.selectedNodeId : selectedNodeId,
          windowHours: Math.max(0, Math.trunc(Number(snapshotResult && snapshotResult.windowHours) || windowHours)),
          snapshotSkipped: !!(snapshotResult && snapshotResult.skipped),
        }});
      }} catch (err) {{
        const msg = err instanceof Error ? err.message : String(err || "unknown error");
        envMetricsViewState.points = [];
        envMetricsViewState.metrics = [];
        envMetricsViewState.nodes = [];
        envMetricsViewState.source = "";
        envMetricsViewState.scannedPackets = 0;
        const snapshotResult = renderEnvironmentMetricsSnapshot({{ force: true }});
        setEnvironmentMetricsStatus(`Sensor history unavailable: ${{msg}}`, "error");
        markEnvironmentMetricsRenderPerf(perfRun, "error", {{
          message: msg,
          snapshotSkipped: !!(snapshotResult && snapshotResult.skipped),
        }});
        finishEnvironmentMetricsRenderPerf(perfRun, "error", {{
          error: msg,
          points: 0,
          metrics: 0,
          nodes: 0,
          selectedMetric: "",
          selectedNodeId: selectedNodeIdBefore,
          windowHours,
          snapshotSkipped: !!(snapshotResult && snapshotResult.skipped),
        }});
      }}
    }}

    async function fetchRawJson(url, cacheEntry, ttlMs = 30000) {{
      const nowMs = Date.now();
      if (cacheEntry && cacheEntry.data != null && (nowMs - (cacheEntry.fetchedAt || 0)) < ttlMs) {{
        return cacheEntry.data;
      }}
      const resp = await fetch(url, {{ cache: "no-store" }});
      if (!resp.ok) throw new Error(`raw API ${{resp.status}}`);
      const data = await resp.json();
      if (cacheEntry) {{
        cacheEntry.fetchedAt = nowMs;
        cacheEntry.data = data;
      }}
      return data;
    }}
