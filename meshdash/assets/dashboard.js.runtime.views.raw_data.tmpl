    function resolveEnvironmentNodeDisplayName(nodeId, fallbackLabel = "") {{
      const cleanNodeId = normalizeNodeId(nodeId || "");
      const safeFallback = String(fallbackLabel || "").trim();
      const safeState = (latestState && typeof latestState === "object") ? latestState : {{}};
      const nodes = Array.isArray(safeState.nodes) ? safeState.nodes : [];
      const stateNode = nodes.find((node) => normalizeNodeId(node && node.id) === cleanNodeId) || null;
      if (stateNode && typeof stateNode === "object") {{
        const preferred = String(preferredNodeName(stateNode) || "").trim();
        if (preferred) return preferred;
        const shortName = String(stateNode.short_name || "").trim();
        if (shortName) return shortName;
      }}
      if (cleanNodeId && nodeNameCache instanceof Map) {{
        const cached = String(nodeNameCache.get(cleanNodeId) || "").trim();
        if (cached) return cached;
      }}
      if (safeFallback && normalizeNodeId(safeFallback) !== cleanNodeId) {{
        return safeFallback;
      }}
      return safeFallback || cleanNodeId || "unknown";
    }}

    function formatEnvironmentNodeTooltipLabel(nodeId, fallbackLabel = "") {{
      const cleanNodeId = normalizeNodeId(nodeId || "");
      const displayName = resolveEnvironmentNodeDisplayName(cleanNodeId, fallbackLabel);
      const cleanDisplay = String(displayName || "").trim();
      if (!cleanNodeId) return cleanDisplay || "unknown";
      if (!cleanDisplay) return cleanNodeId;
      if (normalizeNodeId(cleanDisplay) === cleanNodeId) {{
        return cleanDisplay;
      }}
      return `${{cleanDisplay}} (${{cleanNodeId}})`;
    }}

    function filterEnvironmentMetricPoints(points, metricKey, nodeId) {{
      const cleanMetric = normalizeEnvMetricKey(metricKey || "");
      const cleanNodeId = normalizeNodeId(nodeId || "");
      return (Array.isArray(points) ? points : [])
        .filter((point) => {{
          const pointMetric = normalizeEnvMetricKey(point && point.metric_key);
          if (!cleanMetric || pointMetric !== cleanMetric) return false;
          if (!cleanNodeId) return true;
          return normalizeNodeId(point && point.node_id) === cleanNodeId;
        }});
    }}

