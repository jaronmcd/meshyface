    function bindEnvironmentNodeLegendToggle() {{
      const host = document.getElementById("env-metrics-available");
      if (!(host instanceof HTMLElement) || host.dataset.toggleBound === "1") return;
      host.dataset.toggleBound = "1";
      host.addEventListener("click", (event) => {{
        const target = event.target;
        if (!(target instanceof Element)) return;
        const hit = target.closest("[data-env-node-toggle='1']");
        if (!(hit instanceof HTMLElement)) return;
        const nodeId = normalizeNodeId(hit.getAttribute("data-node-id") || "");
        if (!nodeId) return;
        event.preventDefault();
        toggleEnvironmentLegendNodeVisibility(nodeId);
