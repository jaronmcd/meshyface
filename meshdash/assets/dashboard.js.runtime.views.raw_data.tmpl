    function pruneEnvironmentLegendHiddenNodeIds(activeNodeIds) {{
      const hidden = (envMetricsViewState.hiddenLegendNodeIds instanceof Set)
        ? envMetricsViewState.hiddenLegendNodeIds
        : new Set();
      const safeActive = activeNodeIds instanceof Set ? activeNodeIds : new Set();
      for (const nodeId of Array.from(hidden)) {{
        if (!safeActive.has(normalizeNodeId(nodeId))) {{
          hidden.delete(nodeId);
        }}
      }}
    }}

    function toggleEnvironmentLegendNodeVisibility(nodeId) {{
      const cleanNodeId = normalizeNodeId(nodeId || "");
      if (!cleanNodeId) return;
      const hidden = syncEnvironmentLegendScope(envMetricsViewState.legendScopeKey || "");
      if (hidden.has(cleanNodeId)) {{
        hidden.delete(cleanNodeId);
      }} else {{
        hidden.add(cleanNodeId);
      }}
