    function bindGamesSplitters() {{
      const splitters = [
        {{
          element: document.getElementById("games-sidebar-splitter"),
          storage: () => persistGamesSidebarSplitState(),
          canResize: () => !(typeof window.matchMedia === "function" && window.matchMedia("(max-width: 760px)").matches),
          resolveWidth: (paneRect) => Number.isFinite(Number(paneRect.width)) && paneRect.width > 0
            ? paneRect.width
            : gamesSidebarWidthPx,
          updateWidth: (startWidth, deltaX, shellWidth) => {{
            gamesSidebarWidthPx = clampGamesSidebarWidthPx(startWidth + deltaX, shellWidth, gamesStatusWidthPx);
          }},
        }},
        {{
          element: document.getElementById("games-status-splitter"),
          storage: () => persistGamesStatusSplitState(),
          canResize: () => !(typeof window.matchMedia === "function" && window.matchMedia("(max-width: 1180px)").matches),
          resolveWidth: (paneRect) => Number.isFinite(Number(paneRect.width)) && paneRect.width > 0
            ? paneRect.width
            : gamesStatusWidthPx,
          updateWidth: (startWidth, deltaX, shellWidth) => {{
            gamesStatusWidthPx = clampGamesStatusWidthPx(startWidth - deltaX, shellWidth, gamesSidebarWidthPx);
          }},
        }},
      ];

      for (const entry of splitters) {{
        const splitter = entry && entry.element;
        if (!(splitter instanceof HTMLElement) || splitter.dataset.bound === "1") continue;
        const shell = splitter.closest(".games-shell");
        const targetPane = splitter.dataset.target === "right"
          ? splitter.nextElementSibling
          : splitter.previousElementSibling;
        if (!(shell instanceof HTMLElement) || !(targetPane instanceof HTMLElement)) continue;
        splitter.dataset.bound = "1";

        splitter.addEventListener("pointerdown", (ev) => {{
          if (activeLayoutView !== "games") return;
          if (typeof entry.canResize === "function" && !entry.canResize()) return;
          ev.preventDefault();
          splitter.classList.add("active");
          document.body.classList.add("resizing-panels-x");
          splitter.setPointerCapture(ev.pointerId);

          const startX = ev.clientX;
          const paneRect = targetPane.getBoundingClientRect();
          const startWidth = entry.resolveWidth(paneRect);

          const updateFromClientX = (clientX) => {{
            const deltaX = clientX - startX;
            const shellRect = shell.getBoundingClientRect();
            const shellWidth = Number.isFinite(Number(shellRect.width)) && shellRect.width > 0
              ? shellRect.width
              : window.innerWidth;
            entry.updateWidth(startWidth, deltaX, shellWidth);
            applyGamesSplitState();
          }};

          updateFromClientX(ev.clientX);

          const onMove = (moveEv) => {{
            updateFromClientX(moveEv.clientX);
          }};

          const onUp = () => {{
            splitter.classList.remove("active");
            document.body.classList.remove("resizing-panels-x");
            entry.storage();
            splitter.removeEventListener("pointermove", onMove);
            splitter.removeEventListener("pointerup", onUp);
            splitter.removeEventListener("pointercancel", onUp);
          }};

          splitter.addEventListener("pointermove", onMove);
          splitter.addEventListener("pointerup", onUp);
          splitter.addEventListener("pointercancel", onUp);
        }});
      }}
    }}

    function bindChatPanelSplitter() {{
      const splitter = document.getElementById("chat-panel-splitter");
      if (!(splitter instanceof HTMLElement) || splitter.dataset.bound === "1") return;
      const shell = splitter.closest(".workspace-shell");
      const panel = document.getElementById("chat-left-panel");
      if (!(shell instanceof HTMLElement) || !(panel instanceof HTMLElement)) return;
      splitter.dataset.bound = "1";

      splitter.addEventListener("pointerdown", (ev) => {{
        if (window.matchMedia("(max-width: 1100px)").matches) return;
        if (!shell.classList.contains("chat-panel-open")) return;
        ev.preventDefault();
        splitter.classList.add("active");
        document.body.classList.add("resizing-panels-x");
        splitter.setPointerCapture(ev.pointerId);

        const startX = ev.clientX;
        const collapsedMode = !!chatPanelCollapsed;
        const panelRect = panel.getBoundingClientRect();
        const splitterRect = splitter.getBoundingClientRect();
        const panelOnLeft = panelRect.right <= splitterRect.left + 1;
        const startWidth = Number.isFinite(panelRect.width) && panelRect.width > 0
          ? panelRect.width
          : (collapsedMode ? chatPanelCollapsedWidthPx : chatPanelWidthPx);

        const updateFromClientX = (clientX) => {{
          const deltaX = clientX - startX;
          const shellRect = shell.getBoundingClientRect();
          const nextWidth = panelOnLeft
            ? (startWidth + deltaX)
            : (startWidth - deltaX);
          if (collapsedMode) {{
            chatPanelCollapsedWidthPx = clampChatPanelCollapsedWidthPx(nextWidth, shellRect.width);
          }} else {{
            chatPanelWidthPx = clampChatPanelWidthPx(nextWidth, shellRect.width);
          }}
          applyChatPanelSplitState();
          requestMapResize();
        }};

        updateFromClientX(ev.clientX);

        const onMove = (moveEv) => {{
          updateFromClientX(moveEv.clientX);
        }};

        const onUp = () => {{
          splitter.classList.remove("active");
          document.body.classList.remove("resizing-panels-x");
          if (collapsedMode) {{
            persistChatPanelCollapsedSplitState();
          }} else {{
            persistChatPanelSplitState();
          }}
          requestMapResize();
          splitter.removeEventListener("pointermove", onMove);
          splitter.removeEventListener("pointerup", onUp);
          splitter.removeEventListener("pointercancel", onUp);
        }};

        splitter.addEventListener("pointermove", onMove);
        splitter.addEventListener("pointerup", onUp);
        splitter.addEventListener("pointercancel", onUp);
      }});
    }}

    function bindChatPanelCollapseToggle() {{
      const btn = document.getElementById("chat-panel-collapse-btn");
      if (!(btn instanceof HTMLButtonElement) || btn.dataset.bound === "1") return;
      btn.dataset.bound = "1";

      btn.addEventListener("click", (ev) => {{
        ev.preventDefault();
        setChatPanelCollapsed(!chatPanelCollapsed, {{ persist: true }});
      }});
    }}

    function bindChatNodeDetailsSplitter() {{
      const splitter = document.getElementById("chat-node-details-splitter");
      if (!(splitter instanceof HTMLElement) || splitter.dataset.bound === "1") return;
      const section = splitter.closest(".chat-left-section.chat-users-section");
      if (!(section instanceof HTMLElement)) return;
      splitter.dataset.bound = "1";

      splitter.addEventListener("pointerdown", (ev) => {{
        if (window.matchMedia("(max-width: 1100px)").matches) return;
        if (!section.classList.contains("has-node-details")) return;
        ev.preventDefault();
        splitter.classList.add("active");
        document.body.classList.add("resizing-panels-y");
        splitter.setPointerCapture(ev.pointerId);
        const list = section.querySelector(".chat-member-list");
        if (!(list instanceof HTMLElement)) {{
          splitter.classList.remove("active");
          document.body.classList.remove("resizing-panels-y");
          return;
        }}
        const startY = Number(ev.clientY);
        const listRect = list.getBoundingClientRect();
        const startListPx = Number.isFinite(Number(listRect.height)) ? Number(listRect.height) : 0;

        const updateFromClientY = (clientY) => {{
          const rect = section.getBoundingClientRect();
          if (rect.height < 80) return;
          const nextListPx = startListPx + (Number(clientY) - startY);
          const pct = clampChatNodeListPct((nextListPx / rect.height) * 100);
          chatNodeListPct = pct;
          applyChatNodeListSplitState();
        }};

        const onMove = (moveEv) => {{
          updateFromClientY(moveEv.clientY);
        }};

        const onUp = (upEv) => {{
          if (upEv && Number.isFinite(Number(upEv.clientY))) {{
            updateFromClientY(Number(upEv.clientY));
          }}
          splitter.classList.remove("active");
          document.body.classList.remove("resizing-panels-y");
          persistChatNodeListSplitState();
          splitter.removeEventListener("pointermove", onMove);
          splitter.removeEventListener("pointerup", onUp);
          splitter.removeEventListener("pointercancel", onUp);
        }};

        splitter.addEventListener("pointermove", onMove);
        splitter.addEventListener("pointerup", onUp);
        splitter.addEventListener("pointercancel", onUp);
      }});
    }}

