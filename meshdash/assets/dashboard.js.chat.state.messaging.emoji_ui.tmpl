    function normalizeChatEmojiPinnedChoices(rawChoices, maxCount = chatEmojiTopUsageCount) {{
      const list = Array.isArray(rawChoices) ? rawChoices : [];
      const out = [];
      const seen = new Set();
      for (const rawEmoji of list) {{
        const emoji = String(rawEmoji || "").trim();
        if (!emoji || seen.has(emoji) || !chatEmojiChoiceSet.has(emoji)) continue;
        seen.add(emoji);
        out.push(emoji);
        if (out.length >= maxCount) {{
          break;
        }}
      }}
      return out;
    }}

    function chatEmojiPanelElement() {{
      const panel = document.getElementById("chat-emoji-panel");
      if (!(panel instanceof HTMLElement)) return null;
      if (panel.parentElement !== document.body) {{
        document.body.appendChild(panel);
      }}
      return panel;
    }}

    function chatEmojiComposeButtons() {{
      const out = [];
      const chatBtn = document.getElementById("chat-emoji-btn");
      const gamesBtn = document.getElementById("games-emoji-btn");
      if (chatBtn instanceof HTMLButtonElement) out.push(chatBtn);
      if (gamesBtn instanceof HTMLButtonElement) out.push(gamesBtn);
      return out;
    }}

    function restoreChatReactionContextTooltip() {{
      for (const node of document.querySelectorAll("[data-chat-reaction-muted-title]")) {{
        if (!(node instanceof HTMLElement)) continue;
        const mutedTitle = String(node.dataset.chatReactionMutedTitle || "");
        if (mutedTitle) {{
          node.setAttribute("title", mutedTitle);
        }} else {{
          node.removeAttribute("title");
        }}
        delete node.dataset.chatReactionMutedTitle;
      }}
    }}

    function suppressChatReactionContextTooltip(anchor = null) {{
      restoreChatReactionContextTooltip();
      if (!(anchor instanceof HTMLElement)) return;
      const owner = anchor.closest(".chat-feed-item[title], .chatlabs-message-row[title], [data-message-id][title]");
      if (!(owner instanceof HTMLElement)) return;
      owner.dataset.chatReactionMutedTitle = owner.getAttribute("title") || "";
      owner.removeAttribute("title");
    }}

    function clearChatReactionPickerHideTimer() {{
      if (chatReactionPickerHideTimer !== null) {{
        clearTimeout(chatReactionPickerHideTimer);
        chatReactionPickerHideTimer = null;
      }}
    }}

    function prefersReducedChatEmojiMotion() {{
      return !!(
        window.matchMedia
        && window.matchMedia("(prefers-reduced-motion: reduce)").matches
      );
    }}

    function cancelChatEmojiPanelAnimations(panel = null) {{
      const targetPanel = panel instanceof HTMLElement ? panel : chatEmojiPanelElement();
      if (!(targetPanel instanceof HTMLElement) || typeof targetPanel.getAnimations !== "function") {{
        return;
      }}
      for (const animation of targetPanel.getAnimations()) {{
        animation.cancel();
      }}
    }}

    function animateChatEmojiPanelTransition(previousRect = null, options = null) {{
      const panel = chatEmojiPanelElement();
      if (
        !(panel instanceof HTMLElement)
        || panel.hidden
        || prefersReducedChatEmojiMotion()
        || typeof panel.animate !== "function"
      ) {{
        return;
      }}

      cancelChatEmojiPanelAnimations(panel);
      const nextRect = panel.getBoundingClientRect();
      if (nextRect.width <= 0 || nextRect.height <= 0) return;

      const duration = Math.max(120, Number(options && options.duration) || 0) || 170;
      const easing = "cubic-bezier(0.22, 1, 0.36, 1)";
      const offsetY = Number.isFinite(Number(options && options.offsetY))
        ? Number(options && options.offsetY)
        : 6;
      let keyframes = null;

      if (
        previousRect
        && Number.isFinite(previousRect.left)
        && Number.isFinite(previousRect.top)
        && Number.isFinite(previousRect.width)
        && Number.isFinite(previousRect.height)
        && previousRect.width > 0
        && previousRect.height > 0
      ) {{
        const deltaX = previousRect.left - nextRect.left;
        const deltaY = previousRect.top - nextRect.top;
        const scaleX = previousRect.width / nextRect.width;
        const scaleY = previousRect.height / nextRect.height;
        keyframes = [
          {{
            opacity: 0.92,
            transformOrigin: "top left",
            transform: `translate(${{deltaX}}px, ${{deltaY}}px) scale(${{scaleX}}, ${{scaleY}})`,
          }},
          {{
            opacity: 1,
            transformOrigin: "top left",
            transform: "translate(0px, 0px) scale(1, 1)",
          }},
        ];
      }} else {{
        keyframes = [
          {{
            opacity: 0,
            transformOrigin: "top left",
            transform: `translateY(${{offsetY}}px) scale(0.985)`,
          }},
          {{
            opacity: 1,
            transformOrigin: "top left",
            transform: "translateY(0px) scale(1)",
          }},
        ];
      }}

      const animation = panel.animate(keyframes, {{
        duration,
        easing,
        fill: "both",
      }});
      animation.finished.catch(() => {{}}).finally(() => {{
        if (!panel.isConnected) return;
        panel.style.transformOrigin = "";
      }});
    }}

    function finalizeChatEmojiPanelClose(panel = null) {{
      const targetPanel = panel instanceof HTMLElement ? panel : chatEmojiPanelElement();
      restoreChatReactionContextTooltip();
      chatEmojiMode = "compose";
      chatReactionTargetId = null;
      chatReactionPickerExpanded = false;
      chatEmojiAnchorElement = null;
      chatEmojiTagTargetInput = null;
      chatEmojiSearchQuery = "";
      if (targetPanel instanceof HTMLElement) {{
        targetPanel.hidden = true;
        targetPanel.dataset.closing = "0";
        targetPanel.dataset.closeNonce = "";
        targetPanel.classList.remove("is-closing");
        targetPanel.classList.remove("chat-emoji-panel-react-collapsed");
        targetPanel.classList.remove("chat-emoji-panel-react-expanded");
        targetPanel.style.maxHeight = "";
        targetPanel.style.position = "";
        targetPanel.style.left = "";
        targetPanel.style.top = "";
        targetPanel.style.right = "";
        targetPanel.style.bottom = "";
        targetPanel.style.opacity = "";
        targetPanel.style.transform = "";
      }}
      const grid = document.getElementById("chat-emoji-grid");
      if (grid instanceof HTMLElement) {{
        grid.replaceChildren();
        grid.dataset.key = "";
      }}
      const searchInput = document.getElementById("chat-emoji-search");
      if (searchInput instanceof HTMLInputElement) {{
        searchInput.value = "";
      }}
      setChatEmojiButtonsExpanded(false, null);
      syncChatReactionAnchorLabels();
    }}

    function animateChatEmojiPanelClose(options = null) {{
      const panel = chatEmojiPanelElement();
      if (!(panel instanceof HTMLElement)) {{
        finalizeChatEmojiPanelClose(null);
        return;
      }}

      const offsetY = Number.isFinite(Number(options && options.offsetY))
        ? Number(options && options.offsetY)
        : 4;
      const duration = Math.max(110, Number(options && options.duration) || 0) || 135;
      const closeNonce = `${{Date.now()}}:${{Math.random().toString(36).slice(2, 8)}}`;
      panel.dataset.closing = "1";
      panel.dataset.closeNonce = closeNonce;
      panel.classList.add("is-closing");

      if (prefersReducedChatEmojiMotion() || typeof panel.animate !== "function") {{
        finalizeChatEmojiPanelClose(panel);
        return;
      }}

      cancelChatEmojiPanelAnimations(panel);
      const animation = panel.animate([
        {{
          opacity: 1,
          transformOrigin: "top left",
          transform: "translateY(0px) scale(1)",
        }},
        {{
          opacity: 0,
          transformOrigin: "top left",
          transform: `translateY(${{offsetY}}px) scale(0.985)`,
        }},
      ], {{
        duration,
        easing: "cubic-bezier(0.4, 0, 1, 1)",
        fill: "both",
      }});
      animation.finished.catch(() => {{}}).finally(() => {{
        if (
          !panel.isConnected
          || panel.dataset.closing !== "1"
          || panel.dataset.closeNonce !== closeNonce
        ) {{
          return;
        }}
        finalizeChatEmojiPanelClose(panel);
      }});
    }}

    function isChatReactionPickerOpenForAnchor(anchor) {{
      if (!(anchor instanceof HTMLButtonElement)) return false;
      const panel = chatEmojiPanelElement();
      if (!(panel instanceof HTMLElement) || panel.hidden) return false;
      if (chatEmojiMode !== "react") return false;
      const replyId = Number(anchor.dataset.replyId || "");
      return (
        Number.isInteger(replyId)
        && replyId > 0
        && Number.isInteger(chatReactionTargetId)
        && chatReactionTargetId === replyId
        && chatEmojiAnchorElement === anchor
      );
    }}

    function isChatReactionAnchorToggleSource(anchor) {{
      if (!(anchor instanceof HTMLElement)) return false;
      return !!anchor.closest(".chat-reaction-summary, .chat-react-btn");
    }}

    function normalizeChatReactionSummaryName(value) {{
      const clean = String(value == null ? "" : value).replace(/\s+/g, " ").trim();
      return clean || "Unknown node";
    }}

    function parseChatReactionSummaryGroups(anchor) {{
      if (!(anchor instanceof HTMLButtonElement)) return [];
      const raw = String(anchor.dataset.reactionSummary || "").trim();
      if (!raw) return [];
      try {{
        const parsed = JSON.parse(raw);
        if (!Array.isArray(parsed)) return [];
        return parsed
          .map((item) => {{
            if (!item || typeof item !== "object") return null;
            const emoji = String(item.emoji || "").trim();
            const count = Number(item.count || 0);
            const names = Array.isArray(item.names)
              ? item.names
                  .map((name) => normalizeChatReactionSummaryName(name))
                  .filter((name, idx, arr) => !!name && arr.indexOf(name) === idx)
              : [];
            if (!emoji || !Number.isFinite(count) || count <= 0) return null;
            return {{
              emoji,
              count: Math.trunc(count),
              names,
            }};
          }})
          .filter((item) => !!item);
      }} catch (_err) {{
        return [];
      }}
    }}

    function chatReactionSummaryGroupTooltip(group) {{
      if (!group || typeof group !== "object") return "";
      const emoji = String(group.emoji || "").trim();
      const count = Math.max(0, Number(group.count || 0));
      const names = Array.isArray(group.names) ? group.names : [];
      const shownNames = names.slice(0, 6);
      const remainder = Math.max(0, count - shownNames.length);
      if (!shownNames.length) {{
        return `${{emoji}} ${{count}} reaction${{count === 1 ? "" : "s"}}`;
      }}
      return `${{emoji}} ${{count}} • ${{shownNames.join(", ")}}${{remainder > 0 ? ` +${{remainder}} more` : ""}}`;
    }}

    function renderChatEmojiReactionSummaryRow(anchor = null) {{
      const shell = document.getElementById("chat-emoji-current-reactions-shell");
      const row = document.getElementById("chat-emoji-current-reactions");
      if (!(shell instanceof HTMLElement) || !(row instanceof HTMLElement)) return;
      const groups = (
        chatEmojiMode === "react" && anchor instanceof HTMLButtonElement
      ) ? parseChatReactionSummaryGroups(anchor) : [];
      if (!groups.length) {{
        shell.hidden = true;
        row.replaceChildren();
        return;
      }}
      const nodes = groups.map((group) => {{
        const tooltip = chatReactionSummaryGroupTooltip(group);
        const btn = document.createElement("button");
        btn.type = "button";
        btn.className = "chat-reaction-chip chat-emoji-current-reaction-chip";
        btn.setAttribute("data-emoji", group.emoji);
        btn.setAttribute("title", tooltip);
        btn.setAttribute("aria-label", tooltip);
        btn.innerHTML = `<span class="chat-reaction-emoji">${{escAttr(group.emoji)}}</span><span class="chat-reaction-count">${{escAttr(group.count)}}</span>`;
        return btn;
      }});
      row.replaceChildren(...nodes);
      shell.hidden = false;
    }}

    function syncChatReactionAnchorLabels() {{
      for (const node of document.querySelectorAll(".chat-reaction-summary.is-empty")) {{
        if (!(node instanceof HTMLButtonElement)) continue;
        const label = node.querySelector(".chat-reaction-summary-label");
        if (!node.dataset.defaultReactionAria) {{
          node.dataset.defaultReactionAria = node.getAttribute("aria-label") || "Add reaction";
        }}
        const state = isChatReactionPickerOpenForAnchor(node)
          ? (chatReactionPickerExpanded ? "expanded" : "preview")
          : "";
        const nextText = state === "expanded"
          ? "Less reactions"
          : (state === "preview" ? "More reactions" : "React");
        if (label instanceof HTMLElement && label.textContent !== nextText) {{
          label.textContent = nextText;
        }} else if (!(label instanceof HTMLElement) && node.textContent !== nextText) {{
          node.textContent = nextText;
        }}
        node.dataset.reactionAnchorState = state;
        node.classList.toggle("is-reaction-preview", state === "preview");
        node.classList.toggle("is-reaction-expanded", state === "expanded");
        if (state) {{
          node.setAttribute("aria-label", nextText);
        }} else {{
          node.setAttribute("aria-label", node.dataset.defaultReactionAria);
        }}
      }}
    }}

    function setChatReactionPickerExpanded(expanded, focusSearch = false) {{
      const nextExpanded = !!expanded;
      if (chatEmojiMode !== "react") return false;
      if (chatReactionPickerExpanded === nextExpanded) {{
        syncChatReactionAnchorLabels();
        return false;
      }}
      const panel = chatEmojiPanelElement();
      const previousRect = (
        panel instanceof HTMLElement && !panel.hidden
          ? panel.getBoundingClientRect()
          : null
      );
      chatReactionPickerExpanded = nextExpanded;
      clearChatReactionPickerHideTimer();
      renderChatEmojiPickerPanel();
      positionChatEmojiPanel();
      animateChatEmojiPanelTransition(previousRect, {{
        duration: 170,
        offsetY: nextExpanded ? 4 : -4,
      }});
      if (nextExpanded && focusSearch) {{
        focusChatEmojiSearchInput();
      }}
      return true;
    }}

    function isChatReactionPickerHoverActive() {{
      if (chatEmojiTopDragEmoji) {{
        return true;
      }}
      const panel = chatEmojiPanelElement();
      if (panel instanceof HTMLElement && panel.matches(":hover")) {{
        return true;
      }}
      return chatEmojiAnchorElement instanceof HTMLElement && chatEmojiAnchorElement.matches(":hover");
    }}

    function scheduleChatReactionPickerHide(delayMs = 260) {{
      clearChatReactionPickerHideTimer();
      chatReactionPickerHideTimer = window.setTimeout(() => {{
        if (
          chatEmojiMode === "react"
          && !chatReactionPickerExpanded
          && !isChatReactionPickerHoverActive()
        ) {{
          closeChatEmojiPanel();
        }}
      }}, Math.max(0, Number(delayMs) || 0));
    }}

    function estimateChatReactionCompactPanelHeight(panel) {{
      if (!(panel instanceof HTMLElement)) return 88;
      const topLabel = document.getElementById("chat-emoji-top-label");
      const topGrid = document.getElementById("chat-emoji-top-grid");
      const toggleRow = document.getElementById("chat-emoji-react-toggle-row");
      const computed = window.getComputedStyle(panel);
      const paddingTop = parseFloat(computed.paddingTop || "0") || 0;
      const paddingBottom = parseFloat(computed.paddingBottom || "0") || 0;
      const gap = parseFloat(computed.rowGap || computed.gap || "0") || 0;
      const labelHeight = topLabel instanceof HTMLElement ? topLabel.offsetHeight : 0;
      const gridHeight = topGrid instanceof HTMLElement ? topGrid.offsetHeight : 0;
      const toggleHeight = (toggleRow instanceof HTMLElement && !toggleRow.hidden) ? toggleRow.offsetHeight : 0;
      let gapCount = 0;
      if (labelHeight > 0 && gridHeight > 0) gapCount += 1;
      if (gridHeight > 0 && toggleHeight > 0) gapCount += 1;
      const total = paddingTop + paddingBottom + labelHeight + gridHeight + toggleHeight + (gap * gapCount);
      return Math.max(88, Math.round(total));
    }}

    function estimateChatReactionCompactToggleTop(panel) {{
      if (!(panel instanceof HTMLElement)) return 0;
      const computed = window.getComputedStyle(panel);
      return Math.max(0, parseFloat(computed.paddingTop || "0") || 0);
    }}

    function setChatEmojiButtonsExpanded(expanded, anchor = null) {{
      const activeAnchor = anchor instanceof HTMLButtonElement ? anchor : null;
      for (const btn of chatEmojiComposeButtons()) {{
        if (!(btn instanceof HTMLButtonElement)) continue;
        const isExpanded = !!expanded && !!activeAnchor && btn === activeAnchor;
        btn.setAttribute("aria-expanded", isExpanded ? "true" : "false");
      }}
    }}

    function chatEmojiTopOrdersEqual(a, b) {{
      const left = Array.isArray(a) ? a : [];
      const right = Array.isArray(b) ? b : [];
      return left.length === right.length && left.every((emoji, index) => emoji === right[index]);
    }}

    function chatEmojiTopItems(topGrid) {{
      if (!(topGrid instanceof HTMLElement)) return [];
      return Array.from(topGrid.querySelectorAll(".chat-emoji-top-item:not(.drag-evicted)"))
        .filter((node) => node instanceof HTMLElement);
    }}

    function chatEmojiTopCurrentOrder(topGrid) {{
      return chatEmojiTopItems(topGrid)
        .map((node) => String(node.getAttribute("data-emoji") || "").trim())
        .filter(Boolean);
    }}

    function chatEmojiTopItemEmoji(item) {{
      if (!(item instanceof HTMLElement)) return "";
      return String(item.dataset.emoji || item.getAttribute("data-emoji") || "").trim();
    }}

    function chatEmojiTopNodeForEmoji(topGrid, emoji) {{
      const target = String(emoji || "").trim();
      if (!target) return null;
      for (const node of chatEmojiTopItems(topGrid)) {{
        if (chatEmojiTopItemEmoji(node) === target) return node;
      }}
      return null;
    }}

    function isChatEmojiPointInTopGrid(topGrid, clientX, clientY, margin = 0) {{
      if (!(topGrid instanceof HTMLElement)) return false;
      const rect = topGrid.getBoundingClientRect();
      if (rect.width <= 0 || rect.height <= 0) return false;
      return (
        Number(clientX) >= rect.left - margin
        && Number(clientX) <= rect.right + margin
        && Number(clientY) >= rect.top - margin
        && Number(clientY) <= rect.bottom + margin
      );
    }}

    function isChatEmojiPointInPickerBody(topGrid, clientX, clientY) {{
      const panel = chatEmojiPanelElement();
      if (!(panel instanceof HTMLElement) || panel.hidden) return false;
      const rect = panel.getBoundingClientRect();
      if (rect.width <= 0 || rect.height <= 0) return false;
      return (
        Number(clientX) >= rect.left
        && Number(clientX) <= rect.right
        && Number(clientY) >= rect.top
        && Number(clientY) <= rect.bottom
        && !isChatEmojiPointInTopGrid(topGrid, clientX, clientY, 14)
      );
    }}

    function chatEmojiTopInsertionIndex(topGrid, clientX) {{
      let index = 0;
      for (const item of chatEmojiTopItems(topGrid)) {{
        if (chatEmojiTopItemEmoji(item) === chatEmojiTopDragEmoji) continue;
        const rect = item.getBoundingClientRect();
        if (rect.width <= 0) continue;
        if (Number(clientX) > rect.left + (rect.width / 2)) {{
          index += 1;
        }}
      }}
      return index;
    }}

    function chatEmojiTopNextOrder(sourceEmoji, insertionIndex, currentOrder = []) {{
      const source = String(sourceEmoji || "").trim();
      if (!source) return [];
      const visible = normalizeChatEmojiPinnedChoices(currentOrder, chatEmojiTopUsageCount);
      const working = visible.filter((emoji) => emoji !== source);
      const sourceInVisible = working.length !== visible.length;
      let insertAt = Math.max(0, Math.min(working.length, Math.trunc(Number(insertionIndex) || 0)));
      if (!sourceInVisible && insertAt >= chatEmojiTopUsageCount) {{
        insertAt = chatEmojiTopUsageCount - 1;
      }}
      working.splice(insertAt, 0, source);
      const next = working.slice(0, chatEmojiTopUsageCount);
      return chatEmojiTopOrdersEqual(next, visible) ? [] : next;
    }}

    function chatEmojiTopCaptureRects(topGrid) {{
      const rects = new Map();
      for (const node of chatEmojiTopItems(topGrid)) {{
        const emoji = chatEmojiTopItemEmoji(node);
        if (emoji && !rects.has(emoji)) {{
          rects.set(emoji, node.getBoundingClientRect());
        }}
      }}
      return rects;
    }}

    function animateChatEmojiTopLayout(topGrid, previousRects) {{
      if (
        !(topGrid instanceof HTMLElement)
        || !(previousRects instanceof Map)
        || prefersReducedChatEmojiMotion()
      ) {{
        return;
      }}
      for (const node of chatEmojiTopItems(topGrid)) {{
        if (typeof node.animate !== "function") continue;
        const emoji = chatEmojiTopItemEmoji(node);
        const previous = previousRects.get(emoji);
        if (!previous) continue;
        const next = node.getBoundingClientRect();
        const dx = previous.left - next.left;
        const dy = previous.top - next.top;
        if (Math.abs(dx) < 1 && Math.abs(dy) < 1) continue;
        if (typeof node.getAnimations === "function") {{
          for (const animation of node.getAnimations()) {{
            animation.cancel();
          }}
        }}
        const placeholderScale = node.classList.contains("dragging") ? " scale(0.9)" : "";
        node.animate(
          [
            {{ transform: `translate(${{dx}}px, ${{dy}}px)${{placeholderScale}}` }},
            {{ transform: `translate(0px, 0px)${{placeholderScale}}` }},
          ],
          {{ duration: 180, easing: "cubic-bezier(0.22, 1, 0.36, 1)" }},
        );
      }}
    }}

    function decorateChatEmojiTopItemNode(node, emoji) {{
      if (!(node instanceof HTMLElement)) return;
      node.title = `${{emoji}}. Drag to rearrange or remove from your top 8.`;
      node.setAttribute("aria-label", `${{emoji}}. Drag to rearrange or remove from your top 8.`);
    }}

    function applyChatEmojiTopPreviewOrder(topGrid, nextOrder) {{
      if (!(topGrid instanceof HTMLElement) || !Array.isArray(nextOrder) || !nextOrder.length) {{
        return false;
      }}
      const currentOrder = chatEmojiTopCurrentOrder(topGrid);
      if (chatEmojiTopOrdersEqual(currentOrder, nextOrder)) {{
        return false;
      }}
      const reduceMotion = prefersReducedChatEmojiMotion();
      const previousRects = chatEmojiTopCaptureRects(topGrid);
      const nodesByEmoji = new Map();
      for (const node of chatEmojiTopItems(topGrid)) {{
        const emoji = chatEmojiTopItemEmoji(node);
        if (emoji && !nodesByEmoji.has(emoji)) {{
          nodesByEmoji.set(emoji, node);
        }}
      }}
      for (const empty of topGrid.querySelectorAll(".chat-emoji-top-empty")) {{
        empty.remove();
      }}
      const keep = new Set(nextOrder);
      const gridRect = topGrid.getBoundingClientRect();
      for (const [emoji, node] of nodesByEmoji) {{
        if (keep.has(emoji)) continue;
        const rect = previousRects.get(emoji);
        if (reduceMotion || !rect || typeof node.animate !== "function") {{
          node.remove();
          continue;
        }}
        node.classList.add("drag-evicted");
        node.style.left = `${{Math.round(rect.left - gridRect.left)}}px`;
        node.style.top = `${{Math.round(rect.top - gridRect.top)}}px`;
        const exit = node.animate([
          {{ opacity: 1, transform: "scale(1)" }},
          {{ opacity: 0, transform: "translateY(7px) scale(0.55)" }},
        ], {{ duration: 170, easing: "cubic-bezier(0.4, 0, 1, 1)", fill: "forwards" }});
        exit.finished.catch(() => {{}}).finally(() => {{
          node.remove();
        }});
      }}
      const fragment = document.createDocumentFragment();
      for (const emoji of nextOrder) {{
        let node = nodesByEmoji.get(emoji);
        if (!node) {{
          node = buildChatEmojiNode(emoji, "chat-emoji-top-item");
          decorateChatEmojiTopItemNode(node, emoji);
          if (emoji === chatEmojiTopDragEmoji) {{
            node.classList.add("dragging");
          }} else if (!reduceMotion && typeof node.animate === "function") {{
            node.animate([
              {{ opacity: 0, transform: "scale(0.4)" }},
              {{ opacity: 1, transform: "scale(1)" }},
            ], {{ duration: 180, easing: "cubic-bezier(0.22, 1, 0.36, 1)" }});
          }}
        }}
        fragment.appendChild(node);
      }}
      topGrid.insertBefore(fragment, topGrid.firstChild);
      topGrid.dataset.signature = "";
      chatEmojiTopDragPreviewActive = true;
      animateChatEmojiTopLayout(topGrid, previousRects);
      return true;
    }}

    function revertChatEmojiTopPreview(topGrid) {{
      if (!chatEmojiTopDragPreviewActive) return true;
      if (!(topGrid instanceof HTMLElement)) return false;
      if (!Array.isArray(chatEmojiTopDragStartOrder) || !chatEmojiTopDragStartOrder.length) {{
        return false;
      }}
      if (chatEmojiTopOrdersEqual(chatEmojiTopCurrentOrder(topGrid), chatEmojiTopDragStartOrder)) {{
        chatEmojiTopDragPreviewActive = false;
        return true;
      }}
      const reverted = applyChatEmojiTopPreviewOrder(topGrid, chatEmojiTopDragStartOrder);
      if (reverted) {{
        chatEmojiTopDragPreviewActive = false;
        chatEmojiTopDragLastPreviewAt = 0;
        chatEmojiTopDragLastPreviewKey = "";
      }}
      return reverted;
    }}

    function previewChatEmojiTopDragOver(topGrid, pointer, options = null) {{
      if (
        !(topGrid instanceof HTMLElement)
        || !pointer
        || !chatEmojiTopDragEmoji
        || topGrid.dataset.sortable !== "1"
      ) {{
        return false;
      }}
      const insertionIndex = chatEmojiTopInsertionIndex(topGrid, Number(pointer.clientX));
      const next = chatEmojiTopNextOrder(
        chatEmojiTopDragEmoji,
        insertionIndex,
        chatEmojiTopCurrentOrder(topGrid),
      );
      if (!next.length) return false;
      if (!(options && options.force)) {{
        const nowMs = Date.now();
        const previewKey = next.join("\u0000");
        if (
          previewKey === chatEmojiTopDragLastPreviewKey
          && (nowMs - chatEmojiTopDragLastPreviewAt) < 90
        ) {{
          return false;
        }}
        chatEmojiTopDragLastPreviewKey = previewKey;
        chatEmojiTopDragLastPreviewAt = nowMs;
      }}
      return applyChatEmojiTopPreviewOrder(topGrid, next);
    }}

    function removeChatEmojiDragGhost() {{
      const ghost = chatEmojiTopDragGhost;
      chatEmojiTopDragGhost = null;
      if (ghost instanceof HTMLElement) {{
        ghost.remove();
      }}
    }}

    function createChatEmojiDragGhost(emoji) {{
      removeChatEmojiDragGhost();
      const clean = String(emoji || "").trim();
      if (!clean) return null;
      const ghost = document.createElement("div");
      ghost.className = "chat-emoji-drag-ghost";
      ghost.setAttribute("aria-hidden", "true");
      const glyph = document.createElement("canvas");
      glyph.className = "chat-emoji-glyph";
      glyph.dataset.emoji = clean;
      drawChatEmojiGlyph(glyph);
      ghost.appendChild(glyph);
      ghost.style.transform = "translate3d(-200px, -200px, 0)";
      document.body.appendChild(ghost);
      chatEmojiTopDragGhost = ghost;
      return ghost;
    }}

    function moveChatEmojiDragGhost(clientX, clientY) {{
      const ghost = chatEmojiTopDragGhost;
      if (!(ghost instanceof HTMLElement)) return;
      const x = Math.round((Number(clientX) || 0) - 17);
      const y = Math.round((Number(clientY) || 0) - 19);
      ghost.style.transform = `translate3d(${{x}}px, ${{y}}px, 0) scale(1.16)`;
    }}

    function dismissChatEmojiDragGhost(targetRect = null) {{
      const ghost = chatEmojiTopDragGhost;
      chatEmojiTopDragGhost = null;
      if (!(ghost instanceof HTMLElement)) return;
      if (
        prefersReducedChatEmojiMotion()
        || typeof ghost.animate !== "function"
        || !targetRect
        || !(Number(targetRect.width) > 0)
      ) {{
        ghost.remove();
        return;
      }}
      const toX = Math.round(targetRect.left + ((targetRect.width - 34) / 2));
      const toY = Math.round(targetRect.top + ((targetRect.height - 32) / 2));
      const animation = ghost.animate([
        {{ transform: ghost.style.transform || "translate3d(0px, 0px, 0)", opacity: 1 }},
        {{ transform: `translate3d(${{toX}}px, ${{toY}}px, 0) scale(1)`, opacity: 0.2 }},
      ], {{ duration: 170, easing: "cubic-bezier(0.22, 1, 0.36, 1)", fill: "forwards" }});
      animation.finished.catch(() => {{}}).finally(() => {{
        ghost.remove();
      }});
    }}

    function beginChatEmojiTopDrag(emoji, sourceItem = null) {{
      const topGrid = document.getElementById("chat-emoji-top-grid");
      const panel = chatEmojiPanelElement();
      chatEmojiTopDragEmoji = String(emoji || "").trim();
      chatEmojiTopDragStartOrder = chatEmojiTopCurrentOrder(topGrid);
      chatEmojiTopDragPreviewActive = false;
      chatEmojiTopDragLastPreviewAt = 0;
      chatEmojiTopDragLastPreviewKey = "";
      chatEmojiTopDragSourceInTop = !!(
        sourceItem instanceof HTMLElement
        && topGrid instanceof HTMLElement
        && sourceItem.classList.contains("chat-emoji-top-item")
        && topGrid.contains(sourceItem)
      );
      if (sourceItem instanceof HTMLElement) {{
        sourceItem.classList.add("dragging");
      }}
      if (topGrid instanceof HTMLElement) {{
        topGrid.classList.add("dragging");
      }}
      if (panel instanceof HTMLElement) {{
        panel.classList.add("is-emoji-dragging");
      }}
      createChatEmojiDragGhost(chatEmojiTopDragEmoji);
    }}

    function clearChatEmojiTopDragState(topGrid, options = null) {{
      const keepPreview = !!(options && options.keepPreview);
      const shouldRestorePreview = chatEmojiTopDragPreviewActive && !keepPreview;
      const panel = chatEmojiPanelElement();
      const activeTopGrid = topGrid instanceof HTMLElement
        ? topGrid
        : (document.getElementById("chat-emoji-top-grid") instanceof HTMLElement
          ? document.getElementById("chat-emoji-top-grid")
          : null);

      chatEmojiTopDragEmoji = "";
      chatEmojiTopPointerDrag = null;
      chatEmojiTopDragStartOrder = [];
      chatEmojiTopDragSourceInTop = false;
      chatEmojiTopDragPreviewActive = false;
      chatEmojiTopDragLastPreviewAt = 0;
      chatEmojiTopDragLastPreviewKey = "";
      removeChatEmojiDragGhost();

      if (activeTopGrid instanceof HTMLElement) {{
        activeTopGrid.classList.remove("dragging");
      }}
      if (panel instanceof HTMLElement) {{
        panel.classList.remove("is-emoji-dragging");
      }}
      const root = panel instanceof HTMLElement ? panel : activeTopGrid;
      if (root instanceof HTMLElement) {{
        for (const item of root.querySelectorAll(".chat-emoji-item.dragging")) {{
          if (!(item instanceof HTMLElement)) continue;
          item.classList.remove("dragging");
        }}
      }}
      if (shouldRestorePreview && activeTopGrid instanceof HTMLElement) {{
        activeTopGrid.dataset.signature = "";
        renderChatEmojiTopRow();
      }}
    }}

    function chatEmojiTopDragLandingRect(topGrid, drag, emoji, droppedOnTop) {{
      if (droppedOnTop) {{
        const node = chatEmojiTopNodeForEmoji(topGrid, emoji);
        if (node) return node.getBoundingClientRect();
      }}
      if (drag && drag.source instanceof HTMLElement && drag.source.isConnected) {{
        return drag.source.getBoundingClientRect();
      }}
      const node = chatEmojiTopNodeForEmoji(topGrid, emoji);
      return node ? node.getBoundingClientRect() : null;
    }}

    function finishChatEmojiTopPointerDrag(ev, commit = false) {{
      const drag = chatEmojiTopPointerDrag;
      const topGrid = document.getElementById("chat-emoji-top-grid");
      if (drag && drag.source instanceof HTMLElement) {{
        try {{
          if (drag.source.hasPointerCapture && drag.source.hasPointerCapture(drag.pointerId)) {{
            drag.source.releasePointerCapture(drag.pointerId);
          }}
        }} catch (err) {{}}
      }}
      const wasActive = !!(drag && drag.active);
      const draggedEmoji = chatEmojiTopDragEmoji;
      const droppedOnTop = !!(
        commit
        && wasActive
        && topGrid instanceof HTMLElement
        && topGrid.dataset.sortable === "1"
        && isChatEmojiPointInTopGrid(topGrid, ev.clientX, ev.clientY, 14)
      );
      const droppedBackFromTop = !!(
        commit
        && wasActive
        && chatEmojiTopDragSourceInTop
        && topGrid instanceof HTMLElement
        && topGrid.dataset.sortable === "1"
        && !droppedOnTop
        && isChatEmojiPointInPickerBody(topGrid, ev.clientX, ev.clientY)
      );
      let changed = false;
      if (droppedOnTop) {{
        previewChatEmojiTopDragOver(topGrid, ev, {{ force: true }});
        const nextOrder = chatEmojiTopCurrentOrder(topGrid);
        changed = !chatEmojiTopOrdersEqual(nextOrder, chatEmojiTopDragStartOrder)
          && setChatEmojiTopPinnedChoices(nextOrder, true);
      }} else if (droppedBackFromTop) {{
        revertChatEmojiTopPreview(topGrid);
        changed = removeChatEmojiTopChoice(draggedEmoji);
      }}
      let reverted = false;
      if (wasActive && !droppedOnTop && !droppedBackFromTop) {{
        reverted = revertChatEmojiTopPreview(topGrid);
      }}
      if (wasActive) {{
        chatEmojiTopSuppressClickUntilMs = Date.now() + 260;
        dismissChatEmojiDragGhost(
          droppedBackFromTop
            ? null
            : chatEmojiTopDragLandingRect(topGrid, drag, draggedEmoji, droppedOnTop)
        );
      }}
      clearChatEmojiTopDragState(topGrid, {{ keepPreview: changed || reverted }});
      if (changed) {{
        renderChatEmojiPickerPanel();
        setChatSendStatus(
          droppedBackFromTop ? "Removed top emoji shortcut." : "Updated top emoji shortcuts.",
          false,
        );
      }}
      return changed;
    }}

    function renderChatEmojiTopRow(options = null) {{
      const topLabel = document.getElementById("chat-emoji-top-label");
      const topGrid = document.getElementById("chat-emoji-top-grid");
      if (!(topGrid instanceof HTMLElement)) return;

      const preferredChoices = normalizeChatEmojiPinnedChoices(
        options && Array.isArray(options.choices) ? options.choices : [],
        chatEmojiTopUsageCount,
      );
      const usePreferredChoices = preferredChoices.length > 0;
      const sourceChoices = usePreferredChoices ? preferredChoices : chatEmojiTopChoices();
      const canManageOrder = !usePreferredChoices;
      const labelText = usePreferredChoices
        ? String((options && options.label) || "Top matches").trim() || "Top matches"
        : "Top used (drag from below to add)";
      const choices = chatEmojiMode === "react"
        ? reactionCompatibleEmojiChoices(sourceChoices)
        : sourceChoices;
      const signature = `${{chatEmojiMode}}:${{canManageOrder ? "manage" : "static"}}:${{labelText}}:${{choices.join("\u0000")}}`;
      if ((topGrid.dataset.signature || "") === signature) {{
        return;
      }}

      if (topLabel instanceof HTMLElement) {{
        topLabel.textContent = labelText;
      }}
      topGrid.setAttribute("aria-label", labelText);
      topGrid.dataset.sortable = canManageOrder ? "1" : "0";
      topGrid.classList.toggle("is-sortable", canManageOrder);

      if (!choices.length) {{
        const empty = document.createElement("div");
        empty.className = "chat-emoji-top-empty";
        empty.textContent = usePreferredChoices
          ? (chatEmojiMode === "react"
            ? "No compatible matches found."
            : "No quick matches found.")
          : (chatEmojiMode === "react"
            ? "No compatible reaction emojis in your top list yet."
            : "Use emojis and your top 8 will appear here.");
        topGrid.replaceChildren(empty);
        topGrid.dataset.signature = signature;
        return;
      }}
      const nodes = choices.map((emoji) => {{
        const node = buildChatEmojiNode(emoji, "chat-emoji-top-item");
        if (canManageOrder) {{
          decorateChatEmojiTopItemNode(node, emoji);
        }}
        return node;
      }});
      topGrid.replaceChildren(...nodes);
      topGrid.dataset.signature = signature;
    }}

    function renderChatEmojiPickerPanel() {{
      const panel = chatEmojiPanelElement();
      const currentReactionsShell = document.getElementById("chat-emoji-current-reactions-shell");
      const topLabel = document.getElementById("chat-emoji-top-label");
      const groupSelect = document.getElementById("chat-emoji-group-select");
      const searchInput = document.getElementById("chat-emoji-search");
      const searchRow = document.getElementById("chat-emoji-search-row");
      const controlsRow = document.getElementById("chat-emoji-controls-row");
      const reactToggleRow = document.getElementById("chat-emoji-react-toggle-row");
      const reactToggleBtn = document.getElementById("chat-emoji-react-toggle");
      const grid = document.getElementById("chat-emoji-grid");
      const meta = document.getElementById("chat-emoji-meta");
      if (!(grid instanceof HTMLElement)) return;
      const reactionAnchorOwnsToggle = (
        chatEmojiMode === "react"
        && isChatReactionAnchorToggleSource(chatEmojiAnchorElement)
      );
      const reactionCollapsed = chatEmojiMode === "react" && !chatReactionPickerExpanded;
      const reactionExpanded = chatEmojiMode === "react" && chatReactionPickerExpanded;

      if (panel instanceof HTMLElement) {{
        panel.classList.toggle("chat-emoji-panel-react-collapsed", reactionCollapsed);
        panel.classList.toggle("chat-emoji-panel-react-expanded", reactionExpanded);
        panel.classList.toggle("chat-emoji-panel-react-anchor-toggle", reactionAnchorOwnsToggle);
      }}
      renderChatEmojiReactionSummaryRow(
        chatEmojiAnchorElement instanceof HTMLButtonElement ? chatEmojiAnchorElement : null
      );
      if (currentReactionsShell instanceof HTMLElement) {{
        currentReactionsShell.hidden = currentReactionsShell.hidden || chatEmojiMode !== "react";
      }}
      if (reactToggleRow instanceof HTMLElement) {{
        reactToggleRow.hidden = chatEmojiMode !== "react" || chatReactionPickerExpanded;
      }}
      if (topLabel instanceof HTMLElement) {{
        topLabel.hidden = chatEmojiMode === "react";
      }}
      if (reactToggleBtn instanceof HTMLButtonElement) {{
        reactToggleBtn.textContent = reactionCollapsed ? "More" : "Less reactions";
        reactToggleBtn.setAttribute("aria-expanded", reactionCollapsed ? "false" : "true");
      }}
      if (searchRow instanceof HTMLElement) {{
        searchRow.hidden = reactionCollapsed;
      }}
      if (controlsRow instanceof HTMLElement) {{
        controlsRow.hidden = reactionCollapsed;
      }}
      grid.hidden = reactionCollapsed;

      const selectedSearch = normalizeChatEmojiSearchQuery(
        (searchInput instanceof HTMLInputElement)
          ? searchInput.value
          : chatEmojiSearchQuery
      );
      chatEmojiSearchQuery = selectedSearch;
      if (searchInput instanceof HTMLInputElement && searchInput.value !== selectedSearch) {{
        searchInput.value = selectedSearch;
      }}

      if (!chatEmojiCatalogLoaded) {{
        if (groupSelect instanceof HTMLSelectElement) {{
          const loadingOption = '<option value="all">All groups (loading...)</option>';
          if (groupSelect.innerHTML !== loadingOption) {{
            groupSelect.innerHTML = loadingOption;
          }}
          groupSelect.value = "all";
          groupSelect.disabled = true;
        }}
        if (searchInput instanceof HTMLInputElement) {{
          searchInput.disabled = true;
        }}
        if (meta instanceof HTMLElement) {{
          if (chatEmojiCatalogLoadError) {{
            meta.textContent = "Emoji catalog unavailable";
            meta.title = chatEmojiCatalogLoadError;
          }} else {{
            meta.textContent = "Loading emoji catalog...";
            meta.title = "Fetching Unicode emoji catalog...";
          }}
        }}
        const loadingKey = chatEmojiCatalogLoadError ? "emoji-catalog:error" : "emoji-catalog:loading";
        if ((grid.dataset.key || "") !== loadingKey) {{
          const empty = document.createElement("div");
          empty.className = "chat-emoji-empty";
          empty.textContent = chatEmojiCatalogLoadError
            ? "Emoji catalog unavailable. Try again in a moment."
            : "Loading emoji catalog...";
          grid.replaceChildren(empty);
          grid.dataset.key = loadingKey;
          grid.scrollTop = 0;
        }}
        renderChatEmojiTopRow(null);
        syncChatReactionAnchorLabels();
        positionChatEmojiPanel();
        return;
      }}

      if (searchInput instanceof HTMLInputElement) {{
        searchInput.disabled = reactionCollapsed;
      }}
      if (groupSelect instanceof HTMLSelectElement) {{
        groupSelect.disabled = reactionCollapsed;
        const catalogSignature = `${{chatEmojiTotalChoices}}:${{chatEmojiGroups.map((group) => `${{group.id}}:${{group.emojis.length}}`).join("|")}}`;
        if ((groupSelect.dataset.catalogSignature || "") !== catalogSignature) {{
          const groupOptions = [
            `<option value="all">All groups (${{chatEmojiTotalChoices}})</option>`,
            ...chatEmojiGroups.map((group) => (
              `<option value="${{escAttr(group.id)}}">${{escAttr(group.label)}} (${{group.emojis.length}})</option>`
            )),
          ].join("");
          groupSelect.innerHTML = groupOptions;
          groupSelect.dataset.catalogSignature = catalogSignature;
          groupSelect.value = normalizeChatEmojiGroup(chatEmojiPickerGroup);
        }}
      }}

      const selectedGroup = normalizeChatEmojiGroup(
        (groupSelect instanceof HTMLSelectElement)
          ? groupSelect.value
          : chatEmojiPickerGroup
      );
      const previousGroup = chatEmojiPickerGroup;
      chatEmojiPickerGroup = selectedGroup;
      if (groupSelect instanceof HTMLSelectElement && groupSelect.value !== selectedGroup) {{
        groupSelect.value = selectedGroup;
      }}

      const searchActive = !!selectedSearch;
      const sourceChoices = searchActive
        ? chatEmojiChoicesForSearch(selectedSearch)
        : chatEmojiChoicesForGroup(selectedGroup);
      const choices = chatEmojiMode === "react"
        ? reactionCompatibleEmojiChoices(sourceChoices)
        : sourceChoices;
      const groupLabel = searchActive
        ? `Search all: "${{selectedSearch}}"`
        : (selectedGroup === "all"
          ? "All groups"
          : ((chatEmojiGroupsById.get(selectedGroup) || {{}}).label || "All groups"));
      if (meta instanceof HTMLElement) {{
        const countText = chatEmojiMode === "react"
          ? `${{choices.length}} / ${{sourceChoices.length}} compatible`
          : `${{choices.length}} / ${{chatEmojiTotalChoices}}`;
        meta.textContent = `${{groupLabel}} · ${{countText}}`;
        meta.title = `Unicode Emoji ${{chatEmojiDataVersion}} (${{
          chatEmojiDataDate
        }})`;
      }}
      const renderModeKey = chatEmojiMode === "react" ? "react" : "compose";
      const renderKey = searchActive
        ? `${{renderModeKey}}:search:${{selectedSearch}}`
        : `${{renderModeKey}}:group:${{selectedGroup}}`;
      if ((grid.dataset.key || "") !== renderKey) {{
        if (choices.length) {{
          const shouldUseCachedGroupNodes = !searchActive && chatEmojiMode !== "react";
          const nodes = shouldUseCachedGroupNodes
            ? chatEmojiNodesForGroup(selectedGroup)
            : choices.map((emoji) => buildChatEmojiNode(emoji));
          grid.replaceChildren(...nodes);
        }} else {{
          const empty = document.createElement("div");
          empty.className = "chat-emoji-empty";
          empty.textContent = chatEmojiMode === "react"
            ? "No compatible single-codepoint emojis matched."
            : "No emojis matched your search.";
          grid.replaceChildren(empty);
        }}
        grid.dataset.key = renderKey;
        grid.scrollTop = 0;
      }}
      if (previousGroup !== selectedGroup) {{
        persistChatEmojiPickerState();
      }}
      renderChatEmojiTopRow(null);
      syncChatReactionAnchorLabels();
      positionChatEmojiPanel();
    }}

    function focusChatEmojiSearchInput() {{
      const panel = chatEmojiPanelElement();
      const searchInput = document.getElementById("chat-emoji-search");
      if (!(panel instanceof HTMLElement) || panel.hidden) {{
        return false;
      }}
      if (!(searchInput instanceof HTMLInputElement)) {{
        return false;
      }}
      requestAnimationFrame(() => {{
        if (panel.hidden) return;
        searchInput.focus({{ preventScroll: true }});
        const end = searchInput.value.length;
        searchInput.setSelectionRange(end, end);
      }});
      return true;
    }}

    function resolveChatEmojiPanelAnchor() {{
      if (chatEmojiAnchorElement instanceof HTMLElement && document.contains(chatEmojiAnchorElement)) {{
        return chatEmojiAnchorElement;
      }}
      if (chatEmojiTagTargetInput instanceof HTMLElement && document.contains(chatEmojiTagTargetInput)) {{
        return chatEmojiTagTargetInput;
      }}
      if (activeLayoutView === "games") {{
        const gamesBtn = document.getElementById("games-emoji-btn");
        if (gamesBtn instanceof HTMLElement) return gamesBtn;
      }}
      const composeBtn = document.getElementById("chat-emoji-btn");
      if (composeBtn instanceof HTMLElement) return composeBtn;
      const gamesBtn = document.getElementById("games-emoji-btn");
      return gamesBtn instanceof HTMLElement ? gamesBtn : null;
    }}

    function positionChatEmojiPanel() {{
      const panel = chatEmojiPanelElement();
      if (!(panel instanceof HTMLElement) || panel.hidden) return;
      const anchor = resolveChatEmojiPanelAnchor();
      if (!(anchor instanceof HTMLElement)) return;

      const anchorRect = anchor.getBoundingClientRect();
      const margin = 8;
      const viewportWidth = window.innerWidth || document.documentElement.clientWidth || 1280;
      const viewportHeight = window.innerHeight || document.documentElement.clientHeight || 720;
      const reactionAnchorOwnsToggle = (
        chatEmojiMode === "react"
        && isChatReactionAnchorToggleSource(anchor)
      );
      const reactionCompact = chatEmojiMode === "react" && !chatReactionPickerExpanded;
      const reactionExpandedFromAnchor = (
        chatEmojiMode === "react"
        && chatReactionPickerExpanded
        && reactionAnchorOwnsToggle
      );
      const reactionAnchorGap = reactionAnchorOwnsToggle ? 0 : 6;
      const topbar = document.querySelector(".topbar");
      const topbarBottom = (
        topbar instanceof HTMLElement
          ? Math.max(0, Math.trunc(topbar.getBoundingClientRect().bottom))
          : 0
      );
      const minTop = Math.max(margin, topbarBottom + 6);

      if (reactionExpandedFromAnchor) {{
        const availableAbove = Math.max(220, Math.round(anchorRect.top - minTop + 2));
        panel.style.maxHeight = `${{availableAbove}}px`;
      }} else {{
        panel.style.maxHeight = "";
      }}

      const computedPanelStyle = window.getComputedStyle(panel);
      const panelPaddingLeft = parseFloat(computedPanelStyle.paddingLeft || "0") || 0;
      const width = panel.offsetWidth || 320;
      const height = panel.offsetHeight || 240;

      let left = anchorRect.right - width;
      if (chatEmojiMode === "react") {{
        left = anchorRect.left - panelPaddingLeft;
      }}
      if (left < margin) left = margin;
      if ((left + width) > (viewportWidth - margin)) {{
        left = Math.max(margin, viewportWidth - width - margin);
      }}

      let top;
      if (reactionExpandedFromAnchor) {{
        top = anchorRect.top - height + 2;
      }} else if (reactionCompact) {{
        top = anchorRect.bottom + reactionAnchorGap;
        if ((top + height) > (viewportHeight - margin)) {{
          top = anchorRect.top - height - reactionAnchorGap;
        }}
      }} else {{
        top = anchorRect.bottom + reactionAnchorGap;
        if ((top + height) > (viewportHeight - margin)) {{
          top = anchorRect.top - height - reactionAnchorGap;
        }}
      }}
      if (top < minTop) top = minTop;
      if ((top + height) > (viewportHeight - margin)) {{
        top = Math.max(minTop, viewportHeight - height - margin);
      }}

      panel.style.position = "fixed";
      panel.style.left = `${{Math.round(left)}}px`;
      panel.style.top = `${{Math.round(top)}}px`;
      panel.style.right = "auto";
      panel.style.bottom = "auto";
    }}

    function openChatEmojiPanel(mode = "compose", reactionTargetId = null, anchorEl = null, expandReactionPicker = false, tagTargetInput = null) {{
      const panel = chatEmojiPanelElement();
      const chatBtn = document.getElementById("chat-emoji-btn");
      if (!(panel instanceof HTMLElement)) return;
      clearChatReactionPickerHideTimer();
      cancelChatEmojiPanelAnimations(panel);
      panel.dataset.closing = "0";
      panel.dataset.closeNonce = "";
      panel.classList.remove("is-closing");
      chatEmojiMode = mode === "react"
        ? "react"
        : (mode === "tag" ? "tag" : "compose");
      chatReactionPickerExpanded = chatEmojiMode === "react"
        ? !!expandReactionPicker
        : true;
      const parsedTarget = Number(reactionTargetId);
      chatReactionTargetId = (
        chatEmojiMode === "react" && Number.isInteger(parsedTarget) && parsedTarget > 0
      ) ? parsedTarget : null;
      chatEmojiAnchorElement = anchorEl instanceof HTMLElement
        ? anchorEl
        : (chatBtn instanceof HTMLElement ? chatBtn : null);
      chatEmojiTagTargetInput = (
        chatEmojiMode === "tag" && tagTargetInput instanceof HTMLInputElement
      ) ? tagTargetInput : (
        chatEmojiMode === "tag" && anchorEl instanceof HTMLInputElement
      ) ? anchorEl : null;
      if (chatEmojiMode === "react") {{
        suppressChatReactionContextTooltip(chatEmojiAnchorElement);
      }} else {{
        restoreChatReactionContextTooltip();
      }}
      renderChatEmojiPickerPanel();
      panel.hidden = false;
      positionChatEmojiPanel();
      syncChatReactionAnchorLabels();
      animateChatEmojiPanelTransition(null, {{
        duration: 160,
        offsetY: chatEmojiMode === "react" && !chatReactionPickerExpanded ? 4 : 8,
      }});
      if (!(chatEmojiMode === "react" && !chatReactionPickerExpanded)) {{
        focusChatEmojiSearchInput();
      }}
      const expandedAnchor = chatEmojiAnchorElement instanceof HTMLButtonElement ? chatEmojiAnchorElement : null;
      setChatEmojiButtonsExpanded(true, expandedAnchor);
      if (!chatEmojiCatalogLoaded) {{
        void ensureChatEmojiCatalogLoaded(true).then((loaded) => {{
          if (!loaded || panel.hidden) return;
          renderChatEmojiPickerPanel();
          positionChatEmojiPanel();
        }});
      }}
    }}

    function closeChatEmojiPanel() {{
      const panel = chatEmojiPanelElement();
      clearChatReactionPickerHideTimer();
      if (!(panel instanceof HTMLElement) || panel.hidden) {{
        finalizeChatEmojiPanelClose(panel);
        return;
      }}
      const closeOffsetY = (
        chatEmojiMode === "react" && chatReactionPickerExpanded
          ? -4
          : 4
      );
      animateChatEmojiPanelClose({{
        duration: 135,
        offsetY: closeOffsetY,
      }});
    }}

    function insertEmojiAtCursor(emoji) {{
      if (chatEmojiMode === "tag" && chatEmojiTagTargetInput instanceof HTMLInputElement) {{
        const input = chatEmojiTagTargetInput;
        input.value = emoji;
        input.dispatchEvent(new Event("input", {{ bubbles: true }}));
        input.dispatchEvent(new Event("change", {{ bubbles: true }}));
        input.focus({{ preventScroll: true }});
        const end = input.value.length;
        input.setSelectionRange(end, end);
        return;
      }}
      const chatInput = document.getElementById("chat-input");
      const gamesInput = document.getElementById("games-chat-input");
      const focused = document.activeElement;
      let input = null;
      if (focused instanceof HTMLInputElement && focused.id === "games-chat-input") {{
        input = focused;
      }} else if (focused instanceof HTMLInputElement && focused.id === "chat-input") {{
        input = focused;
      }} else if (activeLayoutView === "games" && gamesInput instanceof HTMLInputElement) {{
        input = gamesInput;
      }} else if (chatInput instanceof HTMLInputElement) {{
        input = chatInput;
      }} else if (gamesInput instanceof HTMLInputElement) {{
        input = gamesInput;
      }}
      if (!(input instanceof HTMLInputElement)) return;
      const value = input.value || "";
      const start = Number.isFinite(input.selectionStart) ? input.selectionStart : value.length;
      const end = Number.isFinite(input.selectionEnd) ? input.selectionEnd : value.length;
      input.value = value.slice(0, start) + emoji + value.slice(end);
      const next = start + emoji.length;
      input.focus({{ preventScroll: true }});
      input.setSelectionRange(next, next);
    }}

    function bindEmojiPicker() {{
      const panel = chatEmojiPanelElement();
      const composeButtons = chatEmojiComposeButtons();
      if (!(panel instanceof HTMLElement) || !composeButtons.length) return;

      if (panel.dataset.init !== "1") {{
        const groupOptions = '<option value="all">All groups (loading...)</option>';
        panel.innerHTML = `<div id="chat-emoji-current-reactions-shell" class="chat-emoji-current-reactions-shell" hidden>
          <div id="chat-emoji-current-reactions" class="chat-emoji-current-reactions" aria-label="Current reactions"></div>
        </div>
        <div id="chat-emoji-top-label" class="chat-emoji-top-label">Top used</div>
        <div id="chat-emoji-top-grid" class="chat-emoji-top-grid" aria-label="Top used"></div>
          <div id="chat-emoji-react-toggle-row" class="chat-emoji-react-toggle-row" hidden>
            <button id="chat-emoji-react-toggle" class="chat-emoji-react-toggle-btn" type="button" aria-expanded="false">More</button>
          </div>
        <div id="chat-emoji-controls-row" class="chat-emoji-toolbar">
          <select id="chat-emoji-group-select" class="chat-emoji-filter" aria-label="Emoji group">
            ${{groupOptions}}
          </select>
          <span id="chat-emoji-meta" class="chat-emoji-meta"></span>
        </div>
        <div id="chat-emoji-search-row" class="chat-emoji-toolbar chat-emoji-search-row">
          <input
            id="chat-emoji-search"
            class="chat-emoji-filter chat-emoji-search"
            type="search"
            placeholder="Search all categories..."
            aria-label="Search emojis across all categories"
            autocomplete="off"
            spellcheck="false"
            title="Shortcut: Ctrl/Cmd+E"
          />
        </div>
        <div id="chat-emoji-grid" class="chat-emoji-grid"></div>`;
        panel.dataset.init = "1";

        const groupSelect = document.getElementById("chat-emoji-group-select");
        if (groupSelect instanceof HTMLSelectElement && groupSelect.dataset.bound !== "1") {{
          groupSelect.dataset.bound = "1";
          groupSelect.value = normalizeChatEmojiGroup(chatEmojiPickerGroup);
          groupSelect.addEventListener("change", () => {{
            renderChatEmojiPickerPanel();
          }});
        }}
        const searchInput = document.getElementById("chat-emoji-search");
        if (searchInput instanceof HTMLInputElement && searchInput.dataset.bound !== "1") {{
          searchInput.dataset.bound = "1";
          searchInput.value = chatEmojiSearchQuery;
          searchInput.addEventListener("input", () => {{
            chatEmojiSearchQuery = normalizeChatEmojiSearchQuery(searchInput.value);
            renderChatEmojiPickerPanel();
          }});
        }}
        const reactToggleBtn = document.getElementById("chat-emoji-react-toggle");
        if (reactToggleBtn instanceof HTMLButtonElement && reactToggleBtn.dataset.bound !== "1") {{
          reactToggleBtn.dataset.bound = "1";
          reactToggleBtn.addEventListener("click", (ev) => {{
            ev.preventDefault();
            setChatReactionPickerExpanded(!chatReactionPickerExpanded, true);
          }});
        }}

        void ensureChatEmojiCatalogLoaded(false).then((loaded) => {{
          if (!loaded || panel.hidden) return;
          renderChatEmojiPickerPanel();
        }});
      }}

      for (const btn of composeButtons) {{
        if (!(btn instanceof HTMLButtonElement) || btn.dataset.emojiBound === "1") continue;
        btn.dataset.emojiBound = "1";
        btn.addEventListener("click", (ev) => {{
          ev.preventDefault();
          if (btn.id === "chat-emoji-btn" && chatSendInFlight) return;
          if (panel.hidden) {{
            openChatEmojiPanel("compose", null, btn);
          }} else {{
            closeChatEmojiPanel();
          }}
        }});
      }}

      if (panel.dataset.bound !== "1") {{
        panel.dataset.bound = "1";
        panel.addEventListener("pointerenter", () => {{
          if (chatEmojiMode === "react") {{
            clearChatReactionPickerHideTimer();
          }}
        }});
        panel.addEventListener("pointerleave", () => {{
          if (chatEmojiMode === "react" && !chatReactionPickerExpanded && !chatEmojiTopDragEmoji) {{
            scheduleChatReactionPickerHide(260);
          }}
        }});
        panel.addEventListener("pointerdown", (ev) => {{
          if (ev.button !== 0) return;
          const target = ev.target;
          if (!(target instanceof Element)) return;
          const emojiBtn = target.closest(".chat-emoji-item");
          if (!(emojiBtn instanceof HTMLButtonElement)) return;
          const topGrid = document.getElementById("chat-emoji-top-grid");
          if (!(topGrid instanceof HTMLElement) || topGrid.dataset.sortable !== "1") return;
          const emoji = String(emojiBtn.getAttribute("data-emoji") || emojiBtn.textContent || "").trim();
          if (!emoji) return;
          chatEmojiTopPointerDrag = {{
            active: false,
            emoji,
            pointerId: ev.pointerId,
            source: emojiBtn,
            startX: ev.clientX,
            startY: ev.clientY,
          }};
          try {{
            emojiBtn.setPointerCapture(ev.pointerId);
          }} catch (err) {{}}
        }});
        panel.addEventListener("pointermove", (ev) => {{
          const drag = chatEmojiTopPointerDrag;
          if (!drag || drag.pointerId !== ev.pointerId) return;
          const topGrid = document.getElementById("chat-emoji-top-grid");
          if (!(topGrid instanceof HTMLElement) || topGrid.dataset.sortable !== "1") {{
            finishChatEmojiTopPointerDrag(ev, false);
            return;
          }}
          const distance = Math.hypot(ev.clientX - drag.startX, ev.clientY - drag.startY);
          if (!drag.active && distance < 5) return;
          if (!drag.active) {{
            drag.active = true;
            clearChatReactionPickerHideTimer();
            beginChatEmojiTopDrag(drag.emoji, drag.source);
          }}
          ev.preventDefault();
          moveChatEmojiDragGhost(ev.clientX, ev.clientY);
          if (isChatEmojiPointInTopGrid(topGrid, ev.clientX, ev.clientY, 14)) {{
            previewChatEmojiTopDragOver(topGrid, ev);
          }} else {{
            revertChatEmojiTopPreview(topGrid);
          }}
        }});
        panel.addEventListener("pointerup", (ev) => {{
          const drag = chatEmojiTopPointerDrag;
          if (!drag || drag.pointerId !== ev.pointerId) return;
          if (drag.active) {{
            ev.preventDefault();
            ev.stopPropagation();
          }}
          finishChatEmojiTopPointerDrag(ev, true);
        }});
        panel.addEventListener("pointercancel", (ev) => {{
          const drag = chatEmojiTopPointerDrag;
          if (!drag || drag.pointerId !== ev.pointerId) return;
          finishChatEmojiTopPointerDrag(ev, false);
        }});
        panel.addEventListener("click", (ev) => {{
          if (chatEmojiTopSuppressClickUntilMs && Date.now() < chatEmojiTopSuppressClickUntilMs) {{
            ev.preventDefault();
            ev.stopPropagation();
            return;
          }}
          const target = ev.target;
          if (!(target instanceof Element)) return;
          const reactionChip = target.closest(".chat-emoji-current-reaction-chip");
          if (reactionChip instanceof HTMLButtonElement) {{
            const emoji = String(reactionChip.getAttribute("data-emoji") || "").trim();
            if (!emoji) return;
            noteChatEmojiUsage(emoji);
            if (chatEmojiMode === "react" && Number.isInteger(chatReactionTargetId) && chatReactionTargetId > 0) {{
              sendChatReaction(chatReactionTargetId, emoji);
            }} else {{
              insertEmojiAtCursor(emoji);
            }}
            closeChatEmojiPanel();
            return;
          }}
          const emojiBtn = target.closest(".chat-emoji-item");
          if (!(emojiBtn instanceof HTMLButtonElement)) return;
          const emoji = String(emojiBtn.getAttribute("data-emoji") || emojiBtn.textContent || "").trim();
          if (!emoji) return;
          if (chatEmojiMode === "react" && !isReactionCompatibleEmoji(emoji)) {{
            setChatSendStatus("Choose a single-codepoint emoji for reactions.", true);
            return;
          }}
          noteChatEmojiUsage(emoji);
          if (chatEmojiMode === "react" && Number.isInteger(chatReactionTargetId) && chatReactionTargetId > 0) {{
            sendChatReaction(chatReactionTargetId, emoji);
          }} else {{
            insertEmojiAtCursor(emoji);
          }}
          closeChatEmojiPanel();
        }});
        panel.addEventListener("wheel", (ev) => {{
          if (chatEmojiMode !== "react" || !chatReactionPickerExpanded) return;
          const grid = document.getElementById("chat-emoji-grid");
          if (!(grid instanceof HTMLElement) || grid.hidden) return;
          const maxScroll = Math.max(0, grid.scrollHeight - grid.clientHeight);
          if (maxScroll <= 0) return;
          const deltaY = Number(ev.deltaY) || 0;
          if (!deltaY) return;
          const next = Math.max(0, Math.min(maxScroll, grid.scrollTop + deltaY));
          if (next === grid.scrollTop) return;
          ev.preventDefault();
          grid.scrollTop = next;
        }}, {{ passive: false }});
      }}

      if (document.body.dataset.chatEmojiCloseBound !== "1") {{
        document.body.dataset.chatEmojiCloseBound = "1";
        document.addEventListener("pointerdown", (ev) => {{
          const target = ev.target;
          if (!(target instanceof Element)) return;
          if (target.closest("#chat-emoji-panel")) return;
          if (target.closest("#chat-emoji-btn") || target.closest("#games-emoji-btn")) return;
          if (target.closest("#chat-node-details-icon-btn")) return;
          if (target.closest("#favorite-menu-tag-emoji-input")) return;
          if (target.closest("#favorite-menu-node-emoji-input")) return;
          if (target.closest("#chat-node-details-head-icon-input")) return;
          if (target.closest("#settings-node-tag-emoji-input")) return;
          if (target.closest(".chat-reaction-summary") || target.closest(".chat-react-btn")) return;
          if (chatEmojiMode === "react") {{
            chatReactionPickerSuppressOpenUntilMs = Date.now() + 160;
          }}
          closeChatEmojiPanel();
        }});
        document.addEventListener("keydown", (ev) => {{
          if (ev.key === "Escape") {{
            const drag = chatEmojiTopPointerDrag;
            if (drag && drag.active) {{
              finishChatEmojiTopPointerDrag(
                {{ clientX: -9999, clientY: -9999, pointerId: drag.pointerId }},
                false,
              );
              return;
            }}
            closeChatEmojiPanel();
            return;
          }}
          const key = String(ev.key || "").toLowerCase();
          if ((ev.ctrlKey || ev.metaKey) && !ev.altKey && !ev.shiftKey && key === "e") {{
            ev.preventDefault();
            const preferredBtn = activeLayoutView === "games"
              ? document.getElementById("games-emoji-btn")
              : document.getElementById("chat-emoji-btn");
            const fallbackBtn = document.getElementById("chat-emoji-btn");
            const targetBtn = preferredBtn instanceof HTMLButtonElement
              ? preferredBtn
              : (fallbackBtn instanceof HTMLButtonElement ? fallbackBtn : null);
            if (panel.hidden) {{
              if (targetBtn instanceof HTMLButtonElement && targetBtn.id === "chat-emoji-btn" && chatSendInFlight) return;
              openChatEmojiPanel("compose", null, targetBtn);
              return;
            }}
            focusChatEmojiSearchInput();
          }}
        }});
      }}

      if (document.body.dataset.chatEmojiPositionBound !== "1") {{
        document.body.dataset.chatEmojiPositionBound = "1";
        window.addEventListener("resize", () => {{
          positionChatEmojiPanel();
        }});
        window.addEventListener("scroll", (ev) => {{
          const target = ev.target;
          if (target instanceof Element && target.closest("#chat-emoji-panel")) {{
            return;
          }}
          positionChatEmojiPanel();
        }}, true);
      }}
    }}
