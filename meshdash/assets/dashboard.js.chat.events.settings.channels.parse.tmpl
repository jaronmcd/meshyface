    function looksLikeMeshtasticChannelUrl(rawValue) {{
      const text = String(rawValue == null ? "" : rawValue).trim();
      if (!text) return false;
      if (!text.includes("#")) return false;
      return /^https?:\/\//i.test(text) || /^meshtastic:\/\//i.test(text);
    }}

    async function handleChannelImportUrl(addOnly) {{
      const input = document.getElementById("settings-channels-import-url");
      if (!(input instanceof HTMLInputElement)) return;
      const url = String(input.value || "").trim();
      if (!url) {{
        setChannelsStatusText("Paste a Meshtastic channel URL first.");
        return;
      }}
      if (!looksLikeMeshtasticChannelUrl(url)) {{
        setChannelsStatusText("That does not look like a Meshtastic channel URL (expected ...#...).");
        return;
      }}

      const add = !!addOnly;
      const warning = add
        ? "Add channels from this URL?\n\nThis STILL applies LoRa settings from the URL (region/preset/frequency slot) and may reboot the radio.\n\nOnly proceed if you trust the source."
        : "Join from this URL?\n\nThis replaces your channel settings and applies LoRa settings from the URL (region/preset/frequency slot). The radio may reboot.\n\nOnly proceed if you trust the source.";
      if (!window.confirm(warning)) return;

      const payload = {{
        action: "import_url",
        url,
        add_only: add,
      }};
      const pending = add ? "Adding channels from URL…" : "Joining from URL…";
      const success = add ? "Channel URL applied (add-only)" : "Channel URL applied";
      const res = await postChannelSettingsPayload(payload, pending, success);
      if (res.ok) {{
        input.value = "";
        setTimeout(() => {{
          void fetchSettingsFromRadio();
        }}, 900);
      }}
    }}

    async function handleCreatePrivateChannel() {{
      const input = document.getElementById("settings-channels-private-name");
      if (!(input instanceof HTMLInputElement)) return;
      const name = String(input.value || "").trim();
      if (!name) {{
        setChannelsStatusText("Enter a private channel name first.");
        return;
      }}

      const payload = {{
        action: "upsert",
        role: "SECONDARY",
        settings: {{
          name,
          psk: "random",
          uplink_enabled: false,
          downlink_enabled: false,
        }},
      }};
      const res = await postChannelSettingsPayload(
        payload,
        "Creating private channel…",
        "Private channel created"
      );
      if (res.ok) {{
        input.value = "";
        setTimeout(() => {{
          void fetchSettingsFromRadio();
        }}, 700);
      }}
    }}


    function parseSectionJsonTextarea(textareaId) {{
      const textarea = document.getElementById(textareaId);
      if (!(textarea instanceof HTMLTextAreaElement)) {{
        return {{ ok: false, error: "Editor is unavailable", value: null }};
      }}
      const raw = String(textarea.value || "").trim();
      if (!raw) {{
        return {{ ok: false, error: "Enter a JSON object before applying", value: null }};
      }}
      try {{
        const parsed = JSON.parse(raw);
        if (!parsed || typeof parsed !== "object" || Array.isArray(parsed)) {{
          return {{ ok: false, error: "JSON must be an object (field/value pairs)", value: null }};
        }}
        return {{ ok: true, error: "", value: parsed }};
      }} catch (err) {{
        const msg = err instanceof Error ? err.message : String(err || "invalid JSON");
        return {{ ok: false, error: `Invalid JSON: ${{msg}}`, value: null }};
      }}
    }}

    function buildTimeSyncStatusHint(timeSyncRaw) {{
      if (!timeSyncRaw || typeof timeSyncRaw !== "object") return "";
      const source = String(timeSyncRaw.source || "").trim().toLowerCase();
      const server = String(timeSyncRaw.server || "").trim();
      const appliedUtc = String(timeSyncRaw.applied_utc || "").trim();
      const appliedLocal = String(timeSyncRaw.applied_local || "").trim();
      const timezone = String(timeSyncRaw.timezone || "").trim();
      const offset = Number(timeSyncRaw.offset_seconds);
      const parts = [];
      if (source === "time_server") {{
        parts.push(` Time source: ${{server || "time server"}}.`);
      }} else if (source === "host_clock") {{
        parts.push(" Time source: dashboard host clock.");
      }}
      if (source === "time_server" && Number.isFinite(offset)) {{
        parts.push(` Host offset: ${{offset >= 0 ? "+" : ""}}${{offset.toFixed(3)}}s.`);
      }}
      if (appliedUtc) {{
        parts.push(` Applied UTC: ${{appliedUtc}}.`);
      }}
      if (appliedLocal) {{
        if (timezone && timezone !== "local") {{
          parts.push(` ${{timezone}}: ${{appliedLocal}}.`);
        }} else {{
          parts.push(` Local: ${{appliedLocal}}.`);
        }}
      }}
      return parts.join("");
    }}

    async function postRadioSettingsPayload(payload, pendingLabel, successLabel) {{
      if (settingsApplyInFlight) return false;
      settingsApplyInFlight = true;
      setSettingsButtonsDisabled(true);
      setSettingsStatusText(pendingLabel);
      try {{
        const resp = await fetch(radioSettingsEndpoint, {{
          method: "POST",
          headers: {{ "Content-Type": "application/json" }},
          body: JSON.stringify(payload),
        }});

        const text = await resp.text();
        let parsed = null;
        try {{
          parsed = text ? JSON.parse(text) : null;
        }} catch (_err) {{
        }}

        if (!resp.ok) {{
          const errMsg = parsed && parsed.error ? String(parsed.error) : (text || `HTTP ${{resp.status}}`);
          setSettingsStatusText(`Apply failed: ${{errMsg}}`);
          appendConsoleLine(`settings|${{Date.now()}}|error`, `[settings] apply failed: ${{errMsg}}`);
          return false;
        }}

        const rebootHint = parsed && parsed.reboot_expected ? " Radio may reconnect." : "";
        const actionHint =
          parsed && Array.isArray(parsed.actions_applied) && parsed.actions_applied.length
            ? ` Actions: ${{parsed.actions_applied.join(", ")}}.`
            : "";
        const deletedHint =
          parsed && Number.isFinite(Number(parsed.deleted_history_rows))
            ? ` Cleared rows: ${{Number(parsed.deleted_history_rows)}}.`
            : "";
        const timeSyncHint = buildTimeSyncStatusHint(parsed && parsed.time_sync);
        setSettingsStatusText(`Applied. ${{successLabel}}.${{rebootHint}}${{actionHint}}${{deletedHint}}${{timeSyncHint}}`);
        appendConsoleLine(
          `settings|${{Date.now()}}|ok`,
          `[settings] ${{successLabel}}.${{rebootHint}}${{actionHint}}${{deletedHint}}${{timeSyncHint}}`
        );
        clearSettingsDirty();
        invalidateStateSnapshotCache(parsed && parsed.reboot_expected ? 200 : 20);
        return true;
      }} catch (err) {{
        const msg = err instanceof Error ? err.message : String(err || "unknown error");
        setSettingsStatusText(`Apply error: ${{msg}}`);
        appendConsoleLine(`settings|${{Date.now()}}|error`, `[settings] apply error: ${{msg}}`);
        return false;
      }} finally {{
        settingsApplyInFlight = false;
        setSettingsButtonsDisabled(false);
      }}
    }}
