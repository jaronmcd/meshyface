    function selectNode(nodeId, shouldFocus = true, toggleIfSelected = true) {{
      const normalized = normalizeNodeId(nodeId);
      if (!isSelectableNodeId(normalized)) return;
      const perfToken = beginNodeSelectionPerf(normalized, {{
        activeLayoutView,
        activeNetworkSubview,
        shouldFocus: !!shouldFocus,
      }});
      const dispatchStartedAtMs = nodeSelectionPerfNow();
      if (!chatFeedSelectionSyncInProgress && typeof clearChatFeedRepeatToggleState === "function") {{
        clearChatFeedRepeatToggleState();
      }}
      const activeNetworkSubviewName = (typeof normalizeNetworkSubview === "function")
        ? normalizeNetworkSubview(activeNetworkSubview)
        : String(activeNetworkSubview || "map").trim().toLowerCase();
      const networkGraphSelectionActive = activeLayoutView === "network" && activeNetworkSubviewName === "graph" && !networkSubviewUsesMap(activeNetworkSubviewName);
      const syncSelectionToNetworkGraph = (
        networkGraphSelectionActive
        && !networkGraphRootSyncInProgress
        && typeof focusNetworkGraphNodeFromSelection === "function"
      );
      const previousSelectedId = normalizeNodeId(selectedNodeId || "");
      if (normalized !== previousSelectedId) {{
        networkNodeInfoCollapsedNodeId = "";
      }} else if (shouldFocus && !toggleIfSelected) {{
        // Explicit reselect (e.g., clicking a node marker again) should reopen popup.
        networkNodeInfoCollapsedNodeId = "";
      }}
      if (toggleIfSelected && selectedNodeId && normalized === selectedNodeId) {{
        clearNodeSelection();
        return;
      }}
      selectedNodeId = normalized;
      if (activeLayoutView === "files" && typeof syncFileTransferDestinationFromSelectedNode === "function") {{
        syncFileTransferDestinationFromSelectedNode(latestState, {{ persist: true }});
      }}
      let graphSelectionHandled = false;
      if (syncSelectionToNetworkGraph) {{
        graphSelectionHandled = focusNetworkGraphNodeFromSelection(normalized, {{
          pushHistory: true,
          rerender: false,
        }});
      }}
      if (typeof clearChatNodeNavigatorSelectionScrollLock === "function") {{
        clearChatNodeNavigatorSelectionScrollLock();
      }}
      // Keep History view pinned to trend mode; node selection should not yank
      // the left pane into live Map Data tables.
      mapDataFocus = activeLayoutView === "history" ? "activity" : "auto";
      pendingSelectionScroll = true;
      persistSelection();
      renderSelectionStatus();
      renderSavedNodeSearchDropdown(latestState);
      highlightNodeSelection(previousSelectedId, normalized);
      if (latestState) {{
        renderSummary(latestState);
      }}
      if (
        typeof renderEnvironmentMetricsView === "function"
        && activeLayoutView === "network"
        && activeNetworkSubviewName === "sensors"
      ) {{
        void renderEnvironmentMetricsView(false);
      }}
      if (
        activeLayoutView === "network"
        && activeNetworkSubviewName === "routes"
        && typeof syncNetworkRoutesFromSelectedNode === "function"
        && typeof renderNetworkRoutes === "function"
      ) {{
        syncNetworkRoutesFromSelectedNode(latestState, {{ preferSelectedTarget: true }});
        renderNetworkRoutes(latestState);
      }}
      markNodeSelectionPerf(perfToken, "selection.dispatch", dispatchStartedAtMs, {{
        previousSelectedId,
      }});
      if (isChatWorkspaceLayoutView(activeLayoutView)) {{
        pendingMapHistoryFocus = false;
        const shouldOpenDrawer = (
          shouldFocus
          && typeof setChatNodeDetailsDrawerExpanded === "function"
        );
        if (shouldOpenDrawer) {{
          setChatNodeDetailsDrawerExpanded(true, {{
            fetchHistory: true,
            rerender: false,
          }});
        }}
        // Chat-only selection should not trigger map/history work.
        applyChatChannel(activeChatChannel, false);
        if (!shouldOpenDrawer && typeof syncChatNodeDetailsDrawer === "function") {{
          syncChatNodeDetailsDrawer(latestState, {{
            fetchHistory: true,
          }});
        }}
        finishNodeSelectionPerf(perfToken, "chat-workspace");
        return;
      }}
      if (
        shouldFocus
        && activeLayoutView !== "network"
        && typeof setChatNodeDetailsDrawerExpanded === "function"
      ) {{
        setChatNodeDetailsDrawerExpanded(true, {{
          fetchHistory: true,
          rerender: false,
        }});
      }}
      if (
        activeLayoutView === "network"
        && shouldFocus
        && typeof setChatNodeDetailsDrawerExpanded === "function"
        && !selectedNetworkNodeInfoCollapsed(normalized)
      ) {{
        setChatNodeDetailsDrawerExpanded(true, {{
          fetchHistory: true,
          rerender: false,
        }});
      }}
      const focusSelection = (
        shouldFocus
        && activeLayoutView !== "saved"
        && (
          activeLayoutView !== "network"
          || (
            typeof networkSubviewUsesMap === "function"
              ? networkSubviewUsesMap(activeNetworkSubviewName)
              : activeNetworkSubviewName === "map"
          )
        )
      );
      pendingMapHistoryFocus = focusSelection;
      if (
        networkGraphSelectionActive
        && !networkGraphRootSyncInProgress
        && !(networkGraphViewState && networkGraphViewState.pendingFocusTransition)
        && typeof renderNetworkGraphView === "function"
      ) {{
        renderNetworkGraphView(latestState);
      }}
      scheduleNodeSelectionUiRefresh({{ shouldFocus: focusSelection, perfToken }});
    }}

    function clearNodeSelection() {{
      if (typeof clearChatFeedRepeatToggleState === "function") {{
        clearChatFeedRepeatToggleState();
      }}
      selectedNodeId = null;
      selfTickerAlternateNodeId = "";
      networkNodeInfoCollapsedNodeId = "";
      chatNodeDetailsDrawerExpanded = false;
      chatNodeDetailsPromoted = false;
      pendingMapHistoryFocus = false;
      abortNodeHistoryFetch();
      resetSignalChartZoom("");
      signalChartPoints = [];
      pendingSelectionScroll = false;
      persistSelection();
      renderSelectionStatus();
      renderSavedNodeSearchDropdown(latestState);
      if (latestState) {{
        renderSummary(latestState);
      }}
      const activeNetworkSubviewName = (typeof normalizeNetworkSubview === "function")
        ? normalizeNetworkSubview(activeNetworkSubview)
        : String(activeNetworkSubview || "map").trim().toLowerCase();
      if (
        typeof renderEnvironmentMetricsView === "function"
        && activeLayoutView === "network"
        && activeNetworkSubviewName === "sensors"
      ) {{
        void renderEnvironmentMetricsView(false);
      }}
      if (isChatWorkspaceLayoutView(activeLayoutView)) {{
        applyChatChannel(activeChatChannel, false);
        if (typeof syncChatNodeDetailsDrawer === "function") {{
          syncChatNodeDetailsDrawer(latestState, {{
            fetchHistory: false,
          }});
        }}
        return;
      }}
      highlightNodeSelection();
      // If the saved-view freshness chip was showing for a selected node, hide it
      // immediately. (The poll loop might see 304s and skip renderSummary.)
      const chip = document.getElementById("updated-freshness");
      if (chip instanceof HTMLElement) {{
        chip.textContent = "";
        chip.hidden = true;
        applyFreshnessClass(chip, "unknown");
      }}
      updateMapSelection(false);
      map.closePopup();
      setMapDataMode(mapDataFocus === "activity" ? "activity" : "live");
      applyChatChannel(activeChatChannel, false);
      if (typeof syncChatNodeDetailsDrawer === "function") {{
        syncChatNodeDetailsDrawer(latestState, {{
          fetchHistory: false,
        }});
      }}
      const shouldRenderSelectionMap = (
        typeof isMapVisibleLayoutView === "function"
          ? isMapVisibleLayoutView(activeLayoutView)
          : (activeLayoutView === "saved" || activeLayoutView === "network")
      );
      if (latestState) {{
        if (shouldRenderSelectionMap) {{
          renderMap(latestState.nodes || [], (latestState.traffic || {{}}).edges || [], null);
        }}
        renderTraffic(latestState.traffic || {{}}, latestState.nodes || [], null);
        renderSavedNodeDetails(latestState, null);
      }} else {{
        renderSavedNodeDetails({{}}, null);
      }}
      if (
        activeLayoutView === "network"
        && activeNetworkSubviewName === "graph"
        && !networkSubviewUsesMap(activeNetworkSubviewName)
        && typeof renderNetworkGraphView === "function"
      ) {{
        renderNetworkGraphView(latestState);
      }}
      if (activeLayoutView === "games") {{
        renderGamesView(latestState);
      }} else if (activeLayoutView === "files") {{
        renderFilesView(latestState);
      }}
    }}

    function bindNodeRowClicks() {{
      const tbody = document.querySelector("#nodes-table tbody");
      if (!(tbody instanceof HTMLElement) || tbody.dataset.bound === "1") return;
      tbody.dataset.bound = "1";
      tbody.addEventListener("click", (ev) => {{
        const target = ev.target;
        if (!(target instanceof Element)) return;
        const row = target.closest("tr.node-selectable");
        if (!(row instanceof HTMLElement)) return;
        selectNode(row.dataset.nodeId || "", true, false);
      }});
    }}

    function isNodeDirectionalKeyTargetEditable(target) {{
      if (target instanceof HTMLTextAreaElement) return true;
      if (target instanceof HTMLSelectElement) return true;
      if (
        target instanceof HTMLInputElement
        && target.type !== "button"
        && target.type !== "checkbox"
        && target.type !== "radio"
        && target.type !== "range"
      ) {{
        return true;
      }}
      if (target instanceof HTMLElement && target.isContentEditable) return true;
      if (target instanceof Element) {{
        const editableAncestor = target.closest("[contenteditable=\"true\"]");
        if (editableAncestor instanceof HTMLElement) return true;
      }}
      return false;
    }}

    function nodeDirectionalEntriesFrom(containerSelector, itemSelector, options = null) {{
      const opts = options && typeof options === "object" ? options : {{}};
      const requireVisible = opts.requireVisible !== false;
      const container = document.querySelector(containerSelector);
      if (!(container instanceof HTMLElement)) return [];
      if (requireVisible && !isVisibleForSelectionScroll(container)) return [];
      const entries = [];
      for (const item of container.querySelectorAll(itemSelector)) {{
        if (!(item instanceof HTMLElement)) continue;
        if (requireVisible && !isVisibleForSelectionScroll(item)) continue;
        const nodeId = normalizeNodeId(item.dataset.nodeId || "");
        if (!isSelectableNodeId(nodeId)) continue;
        entries.push({{
          id: nodeId,
          element: item,
        }});
      }}
      return entries;
    }}

    function visibleNodeDirectionalEntriesFrom(containerSelector, itemSelector) {{
      return nodeDirectionalEntriesFrom(containerSelector, itemSelector, {{
        requireVisible: true,
      }});
    }}

    function chatRosterDirectionalEntries({{ requireVisible = true }} = {{}}) {{
      const defs = [
        ["#chat-room-unread-list", ".chat-member-item[data-node-id]"],
        ["#chat-room-meshtastic-list", ".chat-member-item[data-node-id]"],
        ["#chat-room-pinned-list", ".chat-member-item[data-node-id]"],
        ["#chat-room-list", ".chat-member-item[data-node-id]"],
      ];
      const entries = [];
      const seen = new Set();
      for (const [containerSelector, itemSelector] of defs) {{
        for (const entry of nodeDirectionalEntriesFrom(containerSelector, itemSelector, {{ requireVisible }})) {{
          if (seen.has(entry.id)) continue;
          seen.add(entry.id);
          entries.push(entry);
        }}
      }}
      return entries;
    }}

    function resolveDirectionalNodeEntries() {{
      const selectedId = normalizeNodeId(selectedNodeId || "");
      if (
        isChatWorkspaceLayoutView(activeLayoutView)
        && typeof isChatNodeDetailsDrawerExpanded === "function"
        && isChatNodeDetailsDrawerExpanded()
        && !(
          typeof isChatNodeDetailsPromotedActive === "function"
          && isChatNodeDetailsPromotedActive()
        )
      ) {{
        const rosterEntries = chatRosterDirectionalEntries({{ requireVisible: false }});
        if (rosterEntries.some((entry) => entry.id === selectedId)) {{
          return rosterEntries;
        }}
      }}
      const defs = isChatWorkspaceLayoutView(activeLayoutView)
        ? [
            ["#chat-room-list", ".chat-member-item[data-node-id]"],
            ["#favorites-list", ".favorite-node-item[data-node-id]"],
            ["#nodes-table", "tbody tr.node-selectable[data-node-id]"],
          ]
        : (activeLayoutView === "saved"
          ? [
              ["#favorites-list", ".favorite-node-item[data-node-id]"],
              ["#nodes-table", "tbody tr.node-selectable[data-node-id]"],
              ["#chat-room-list", ".chat-member-item[data-node-id]"],
            ]
          : [
              ["#nodes-table", "tbody tr.node-selectable[data-node-id]"],
              ["#favorites-list", ".favorite-node-item[data-node-id]"],
              ["#chat-room-list", ".chat-member-item[data-node-id]"],
            ]);
      let fallback = [];
      for (const [containerSelector, itemSelector] of defs) {{
        const entries = visibleNodeDirectionalEntriesFrom(containerSelector, itemSelector);
        if (!entries.length) continue;
        if (!fallback.length) {{
          fallback = entries;
        }}
        if (entries.some((entry) => entry.id === selectedId)) {{
          return entries;
        }}
      }}
      return fallback;
    }}

    function moveSelectedNodeByDirection(step) {{
      const delta = Number(step);
      if (!Number.isFinite(delta) || delta === 0) return false;
      const selectedId = normalizeNodeId(selectedNodeId || "");
      if (!isSelectableNodeId(selectedId)) return false;
      const entries = resolveDirectionalNodeEntries();
      if (!entries.length) return false;
      const currentIndex = entries.findIndex((entry) => entry.id === selectedId);
      if (currentIndex < 0) return false;
      const nextIndex = Math.max(0, Math.min(entries.length - 1, currentIndex + (delta < 0 ? -1 : 1)));
      if (nextIndex !== currentIndex) {{
        selectNode(entries[nextIndex].id, true, false);
      }}
      return true;
    }}

    function bindNodeDirectionalKeys() {{
      if (document.body.dataset.nodeDirectionalKeysBound === "1") return;
      document.body.dataset.nodeDirectionalKeysBound = "1";
      document.addEventListener("keydown", (ev) => {{
        if (ev.defaultPrevented) return;
        const target = ev.target;
        if (isNodeDirectionalKeyTargetEditable(target)) return;
        if (ev.key === "Escape") {{
          if (ev.altKey || ev.ctrlKey || ev.metaKey || ev.shiftKey) return;
          if (!isSelectableNodeId(selectedNodeId || "")) return;
          clearNodeSelection();
          return;
        }}
        if (ev.key !== "ArrowUp" && ev.key !== "ArrowDown") return;
        if (ev.altKey || ev.ctrlKey || ev.metaKey || ev.shiftKey) return;
        const handled = moveSelectedNodeByDirection(ev.key === "ArrowUp" ? -1 : 1);
        if (!handled) return;
        ev.preventDefault();
        ev.stopPropagation();
      }});
    }}

    function selectNodeFromDirectionalRow(row, targetCell, fromColIndex, toColIndex) {{
      if (!(row instanceof HTMLTableRowElement)) return "";
      const fromNodeId = normalizeNodeId(row.dataset.fromNodeId || "");
      const toNodeId = normalizeNodeId(row.dataset.toNodeId || "");
      const fromSelectable = isSelectableNodeId(fromNodeId);
      const toSelectable = isSelectableNodeId(toNodeId);
      if (!(fromSelectable || toSelectable)) return "";

      if (targetCell instanceof HTMLTableCellElement && targetCell.parentElement === row) {{
        const colIndex = Array.from(row.cells).indexOf(targetCell);
        if (colIndex === fromColIndex && fromSelectable) return fromNodeId;
        if (colIndex === toColIndex && toSelectable) return toNodeId;
      }}

      if (fromSelectable) return fromNodeId;
      if (toSelectable) return toNodeId;
      return "";
    }}

    function bindEncriptionRowClicks() {{
      const bindTable = (tableId, fromColIndex, toColIndex) => {{
        const tbody = document.querySelector(`#${{tableId}} tbody`);
        if (!(tbody instanceof HTMLElement) || tbody.dataset.bound === "1") return;
        tbody.dataset.bound = "1";
        tbody.addEventListener("click", (ev) => {{
          const target = ev.target;
          if (!(target instanceof Element)) return;
          const row = target.closest("tr");
          if (!(row instanceof HTMLTableRowElement)) return;
          const cell = target.closest("td");
          const nodeId = selectNodeFromDirectionalRow(
            row,
            cell instanceof HTMLTableCellElement ? cell : null,
            fromColIndex,
            toColIndex
          );
          if (!isSelectableNodeId(nodeId)) return;
          selectNode(nodeId, true, false);
        }});
      }};
      bindTable("encription-packets-table", 1, 2);
      bindTable("encription-traffic-table", 0, 1);
    }}

    function bindHistoryChatRowClicks() {{
      const tbody = document.querySelector("#history-chat-table tbody");
      if (!(tbody instanceof HTMLElement) || tbody.dataset.bound === "1") return;
      tbody.dataset.bound = "1";
      tbody.addEventListener("click", (ev) => {{
        const target = ev.target;
        if (!(target instanceof Element)) return;
        if (target.closest("a.chat-link")) {{
          return;
        }}
        const row = target.closest("tr");
        if (!(row instanceof HTMLTableRowElement)) return;
        const cell = target.closest("td");
        const nodeId = selectNodeFromDirectionalRow(
          row,
          cell instanceof HTMLTableCellElement ? cell : null,
          1,
          2
        );
        if (!isSelectableNodeId(nodeId)) return;
        selectNode(nodeId, true, false);
      }});
    }}
