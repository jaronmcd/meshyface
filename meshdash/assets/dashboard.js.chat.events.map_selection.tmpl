    const nodeSelectionUiState = {{
      frame: null,
      pendingShouldFocus: false,
      pendingPerfToken: 0,
    }};

    const nodeSelectionPerfState = {{
      nextToken: 0,
      activeToken: 0,
      runs: [],
    }};

    function nodeSelectionPerfNow() {{
      return (typeof performance !== "undefined" && performance && typeof performance.now === "function")
        ? performance.now()
        : Date.now();
    }}

    function nodeSelectionPerfStore() {{
      if (typeof window === "undefined") return null;
      const existing = window.__meshNodeSelectionPerf;
      if (existing && typeof existing === "object") return existing;
      const created = {{
        runs: [],
        lastRun: null,
      }};
      window.__meshNodeSelectionPerf = created;
      return created;
    }}

    nodeSelectionPerfStore();

    function findNodeSelectionPerfRun(token) {{
      const targetToken = Math.trunc(Number(token) || 0);
      if (!(targetToken > 0)) return null;
      const runs = Array.isArray(nodeSelectionPerfState.runs) ? nodeSelectionPerfState.runs : [];
      for (let index = runs.length - 1; index >= 0; index -= 1) {{
        const entry = runs[index];
        if (entry && Math.trunc(Number(entry.token) || 0) === targetToken) {{
          return entry;
        }}
      }}
      return null;
    }}

    function beginNodeSelectionPerf(nodeId, meta = {{}}) {{
      const token = (Math.trunc(Number(nodeSelectionPerfState.nextToken) || 0) + 1);
      nodeSelectionPerfState.nextToken = token;
      nodeSelectionPerfState.activeToken = token;
      const run = {{
        token,
        nodeId: normalizeNodeId(nodeId || ""),
        startedAtMs: nodeSelectionPerfNow(),
        phases: [],
        meta: (meta && typeof meta === "object") ? {{ ...meta }} : {{}},
        status: "active",
      }};
      nodeSelectionPerfState.runs.push(run);
      while (nodeSelectionPerfState.runs.length > 40) {{
        nodeSelectionPerfState.runs.shift();
      }}
      const store = nodeSelectionPerfStore();
      if (store) {{
        store.runs = nodeSelectionPerfState.runs.slice();
        store.lastRun = run;
      }}
      return token;
    }}

    function currentNodeSelectionPerfToken() {{
      return Math.trunc(Number(nodeSelectionPerfState.activeToken) || 0);
    }}

    function markNodeSelectionPerf(token, phase, startedAtMs, extra = null) {{
      const run = findNodeSelectionPerfRun(token);
      if (!run) return 0;
      const startMs = Number(startedAtMs);
      const endMs = nodeSelectionPerfNow();
      const durationMs = Number.isFinite(startMs) ? Math.max(0, endMs - startMs) : 0;
      const phaseEntry = {{
        phase: String(phase || "unknown"),
        durationMs: Math.round(durationMs * 100) / 100,
      }};
      if (extra && typeof extra === "object") {{
        phaseEntry.extra = {{ ...extra }};
      }}
      run.phases.push(phaseEntry);
      const store = nodeSelectionPerfStore();
      if (store) {{
        store.runs = nodeSelectionPerfState.runs.slice();
        store.lastRun = run;
      }}
      return durationMs;
    }}

    function finishNodeSelectionPerf(token, status = "complete", extra = null) {{
      const run = findNodeSelectionPerfRun(token);
      if (!run) return null;
      run.status = String(status || "complete");
      run.totalDurationMs = Math.round(Math.max(0, nodeSelectionPerfNow() - Number(run.startedAtMs || 0)) * 100) / 100;
      if (extra && typeof extra === "object") {{
        run.result = {{ ...extra }};
      }}
      if (currentNodeSelectionPerfToken() === Math.trunc(Number(token) || 0)) {{
        nodeSelectionPerfState.activeToken = 0;
      }}
      const store = nodeSelectionPerfStore();
      if (store) {{
        store.runs = nodeSelectionPerfState.runs.slice();
        store.lastRun = run;
      }}
      return run;
    }}

    function cssEscapeAttrValue(value) {{
      const text = String(value == null ? "" : value);
      if (typeof CSS !== "undefined" && typeof CSS.escape === "function") {{
        return CSS.escape(text);
      }}
      return text.replace(/\\/g, "\\\\").replace(/"/g, '\\"');
    }}

    function applySelectedNodeClassToSelector(selector, isSelected) {{
      if (!selector) return;
      for (const element of document.querySelectorAll(selector)) {{
        if (!(element instanceof HTMLElement)) continue;
        element.classList.toggle("selected-node", !!isSelected);
      }}
    }}

    function refreshNodeSelectionCrossReferenceRows(nodeId, isSelected) {{
      const cleanNodeId = normalizeNodeId(nodeId || "");
      if (!isSelectableNodeId(cleanNodeId)) return;
      const rowMatchers = [
        "#encription-packets-table tbody tr",
        "#encription-traffic-table tbody tr",
        "#history-chat-table tbody tr",
      ];
      for (const selector of rowMatchers) {{
        for (const row of document.querySelectorAll(selector)) {{
          if (!(row instanceof HTMLTableRowElement)) continue;
          const fromNodeId = normalizeNodeId(row.dataset.fromNodeId || "");
          const toNodeId = normalizeNodeId(row.dataset.toNodeId || "");
          if (fromNodeId !== cleanNodeId && toNodeId !== cleanNodeId) continue;
          row.classList.toggle("selected-node", !!isSelected);
        }}
      }}
    }}

    function highlightNodeSelection(previousNodeId = "", nextNodeId = selectedNodeId) {{
      const previousId = normalizeNodeId(previousNodeId || "");
      const nextId = normalizeNodeId(nextNodeId || "");
      const directSelectors = [
        '#nodes-table tbody tr[data-node-id="%ID%"]',
        '#chat-feed .chat-feed-item[data-node-id="%ID%"]',
        '#chat-room-unread-list .chat-member-item[data-node-id="%ID%"]',
        '#chat-room-meshtastic-list .chat-member-item[data-node-id="%ID%"]',
        '#chat-room-pinned-list .chat-member-item[data-node-id="%ID%"]',
        '#chat-room-list .chat-member-item[data-node-id="%ID%"]',
        '#favorites-list .favorite-node-item[data-node-id="%ID%"]',
      ];
      const applyNodeIdSelection = (nodeId, isSelected) => {{
        const cleanNodeId = normalizeNodeId(nodeId || "");
        if (!isSelectableNodeId(cleanNodeId)) return;
        const escapedId = cssEscapeAttrValue(cleanNodeId);
        for (const pattern of directSelectors) {{
          applySelectedNodeClassToSelector(pattern.replace("%ID%", escapedId), isSelected);
        }}
        refreshNodeSelectionCrossReferenceRows(cleanNodeId, isSelected);
      }};

      if (previousId && previousId !== nextId) {{
        applyNodeIdSelection(previousId, false);
      }}
      if (nextId) {{
        applyNodeIdSelection(nextId, true);
      }}
    }}

    function flushNodeSelectionUiRefresh() {{
      const perfToken = Math.trunc(Number(nodeSelectionUiState.pendingPerfToken) || 0);
      const flushStartedAtMs = perfToken > 0 ? nodeSelectionPerfNow() : 0;
      if (nodeSelectionUiState.frame !== null) {{
        window.cancelAnimationFrame(nodeSelectionUiState.frame);
      }}
      nodeSelectionUiState.frame = null;
      nodeSelectionUiState.pendingPerfToken = 0;

      const activeSelectedId = normalizeNodeId(selectedNodeId || "");
      if (!isSelectableNodeId(activeSelectedId)) {{
        if (perfToken > 0) {{
          markNodeSelectionPerf(perfToken, "selection.ui_flush", flushStartedAtMs, {{
            skipped: true,
            reason: "no-selection",
          }});
          finishNodeSelectionPerf(perfToken, "no-selection");
        }}
        return;
      }}

      const shouldFocus = !!nodeSelectionUiState.pendingShouldFocus;
      nodeSelectionUiState.pendingShouldFocus = false;

      let cachedHistory = null;
      if (latestState && (activeLayoutView === "saved" || activeLayoutView === "network")) {{
        cachedHistory = cachedNodeHistory(activeSelectedId);
      }}
      const activeNetworkSubviewName = (typeof normalizeNetworkSubview === "function")
        ? normalizeNetworkSubview(activeNetworkSubview)
        : String(activeNetworkSubview || "map").trim().toLowerCase();
      const networkMapVisible = activeLayoutView === "network" && (
        typeof networkSubviewUsesMap === "function"
          ? networkSubviewUsesMap(activeNetworkSubviewName)
          : activeNetworkSubviewName === "map"
      );
      const networkGraphVisible = activeLayoutView === "network" && activeNetworkSubviewName === "graph" && !networkSubviewUsesMap(activeNetworkSubviewName);

      if (activeLayoutView === "saved") {{
        const phaseStartMs = perfToken > 0 ? nodeSelectionPerfNow() : 0;
        if (cachedHistory) {{
          renderTraffic((latestState && latestState.traffic) || {{}}, (latestState && latestState.nodes) || [], cachedHistory);
          renderSavedNodeDetails(latestState || {{}}, cachedHistory);
        }} else {{
          renderNodeHistoryLoading(activeSelectedId);
        }}
        if (perfToken > 0) {{
          markNodeSelectionPerf(perfToken, "selection.saved_view", phaseStartMs, {{
            cachedHistory: !!cachedHistory,
          }});
        }}
      }} else if (activeLayoutView === "network") {{
        const phaseStartMs = perfToken > 0 ? nodeSelectionPerfNow() : 0;
        if (networkMapVisible) {{
          renderTraffic((latestState && latestState.traffic) || {{}}, (latestState && latestState.nodes) || [], cachedHistory);
          setMapDataMode(mapDataFocus === "activity" ? "activity" : "live");
        }}
        if (perfToken > 0) {{
          markNodeSelectionPerf(perfToken, "selection.network_view", phaseStartMs, {{
            cachedHistory: !!cachedHistory,
            subview: activeNetworkSubviewName,
          }});
        }}
      }} else if (activeLayoutView === "history") {{
        setMapDataMode("activity");
      }} else {{
        setMapDataMode("live");
      }}

      if (latestState && (activeLayoutView !== "network" || networkMapVisible)) {{
        const phaseStartMs = perfToken > 0 ? nodeSelectionPerfNow() : 0;
        renderMap(latestState.nodes || [], (latestState.traffic || {{}}).edges || [], cachedHistory);
        if (perfToken > 0) {{
          markNodeSelectionPerf(perfToken, "selection.map_render", phaseStartMs);
        }}
      }}
      if (typeof renderNetworkGraphView === "function") {{
        const networkGraphActive = networkGraphVisible;
        if (
          networkGraphActive
          && !networkGraphRootSyncInProgress
          && !(networkGraphViewState && networkGraphViewState.pendingFocusTransition)
        ) {{
          if (networkGraphViewState && typeof networkGraphViewState === "object") {{
            networkGraphViewState.skipSceneAnimationOnce = true;
          }}
          renderNetworkGraphView(latestState);
        }}
      }}

      const focusSelection = (
        shouldFocus
        && activeLayoutView !== "saved"
        && (
          activeLayoutView !== "network"
          || networkMapVisible
        )
      );
      const focusStartMs = perfToken > 0 ? nodeSelectionPerfNow() : 0;
      if (activeLayoutView !== "network" || networkMapVisible) {{
        updateMapSelection(focusSelection);
      }}
      scrollSelectionIntoView();
      if (perfToken > 0) {{
        markNodeSelectionPerf(perfToken, "selection.focus_scroll", focusStartMs, {{
          focusSelection: !!focusSelection,
        }});
      }}
      void refreshSelectedNodeHistory(false);
      const channelStartMs = perfToken > 0 ? nodeSelectionPerfNow() : 0;
      applyChatChannel(activeChatChannel, false);
      if (perfToken > 0) {{
        markNodeSelectionPerf(perfToken, "selection.chat_channel", channelStartMs);
      }}
      if (typeof syncChatNodeDetailsDrawer === "function") {{
        syncChatNodeDetailsDrawer(latestState, {{
          fetchHistory: false,
        }});
      }}
      if (networkGraphVisible && typeof renderNetworkGraphView === "function") {{
        window.requestAnimationFrame(() => {{
          const stableNetworkSubviewName = (typeof normalizeNetworkSubview === "function")
            ? normalizeNetworkSubview(activeNetworkSubview)
            : String(activeNetworkSubview || "map").trim().toLowerCase();
          if (activeLayoutView !== "network" || stableNetworkSubviewName !== "graph") return;
          renderNetworkGraphView(latestState);
          window.setTimeout(() => {{
            const finalNetworkSubviewName = (typeof normalizeNetworkSubview === "function")
              ? normalizeNetworkSubview(activeNetworkSubview)
              : String(activeNetworkSubview || "map").trim().toLowerCase();
            if (activeLayoutView !== "network" || finalNetworkSubviewName !== "graph") return;
            renderNetworkGraphView(latestState);
          }}, 80);
        }});
      }}
      if (activeLayoutView === "games") {{
        renderGamesView(latestState);
      }} else if (activeLayoutView === "files") {{
        renderFilesView(latestState);
      }}
      if (perfToken > 0) {{
        markNodeSelectionPerf(perfToken, "selection.ui_flush", flushStartedAtMs, {{
          activeLayoutView,
          activeNetworkSubview,
        }});
      }}
    }}

    function scheduleNodeSelectionUiRefresh(options = null) {{
      const opts = options && typeof options === "object" ? options : {{}};
      nodeSelectionUiState.pendingShouldFocus = nodeSelectionUiState.pendingShouldFocus || !!opts.shouldFocus;
      const perfToken = Math.trunc(Number(opts.perfToken) || 0);
      if (perfToken > 0) {{
        nodeSelectionUiState.pendingPerfToken = perfToken;
      }}
      if (nodeSelectionUiState.frame !== null) return;
      nodeSelectionUiState.frame = window.requestAnimationFrame(() => {{
        flushNodeSelectionUiRefresh();
      }});
    }}

    function isVisibleForSelectionScroll(el) {{
      if (!(el instanceof HTMLElement)) return false;
      const rect = el.getBoundingClientRect();
      if (rect.width <= 2 || rect.height <= 2) return false;
      const style = window.getComputedStyle(el);
      if (!style || style.display === "none" || style.visibility === "hidden") return false;
      return true;
    }}

    function scrollSelectionIntoView() {{
      if (!selectedNodeId) {{
        pendingSelectionScroll = false;
        return;
      }}

      let didScroll = false;
      for (const tableId of ["nodes-table"]) {{
        let targetRow = null;
        for (const row of document.querySelectorAll(`#${{tableId}} tbody tr`)) {{
          if (normalizeNodeId(row.dataset.nodeId || "") === selectedNodeId) {{
            targetRow = row;
            break;
          }}
        }}
        if (!targetRow) continue;

        const table = document.getElementById(tableId);
        const scroller = table ? table.closest(".scroll") : null;
        if (!isVisibleForSelectionScroll(scroller)) {{
          continue;
        }}

        const header = table ? table.querySelector("thead") : null;
        const headerHeight = header ? header.getBoundingClientRect().height : 0;
        const scrollerRect = scroller.getBoundingClientRect();
        const rowRect = targetRow.getBoundingClientRect();
        const topSafe = scrollerRect.top + headerHeight + 3;
        const bottomSafe = scrollerRect.bottom - 3;

        if (rowRect.top < topSafe) {{
          const delta = rowRect.top - topSafe;
          scroller.scrollTo({{ top: scroller.scrollTop + delta, behavior: "smooth" }});
        }} else if (rowRect.bottom > bottomSafe) {{
          const delta = rowRect.bottom - bottomSafe;
          scroller.scrollTo({{ top: scroller.scrollTop + delta, behavior: "smooth" }});
        }}
        const nameCell = targetRow.cells && targetRow.cells.length > 2
          ? targetRow.cells[2]
          : null;
        if (nameCell instanceof HTMLTableCellElement) {{
          const nameRect = nameCell.getBoundingClientRect();
          const leftSafe = scrollerRect.left + 3;
          const rightSafe = scrollerRect.right - 3;
          if (nameRect.left < leftSafe) {{
            const delta = nameRect.left - leftSafe;
            scroller.scrollTo({{ left: scroller.scrollLeft + delta, behavior: "smooth" }});
          }} else if (nameRect.right > rightSafe) {{
            const delta = nameRect.right - rightSafe;
            scroller.scrollTo({{ left: scroller.scrollLeft + delta, behavior: "smooth" }});
          }}
        }}
        didScroll = true;
      }}

      const suppressChatRosterSelectionScroll = (
        !!chatNodeNavigatorSelectionScrollLocked
      );
      if (!suppressChatRosterSelectionScroll) {{
        for (const chatRoomList of [
          document.getElementById("chat-room-unread-list"),
          document.getElementById("chat-room-meshtastic-list"),
          document.getElementById("chat-room-pinned-list"),
          document.getElementById("chat-room-list"),
        ]) {{
          if (!isVisibleForSelectionScroll(chatRoomList)) {{
            continue;
          }}
          let selectedMember = null;
          for (const member of chatRoomList.querySelectorAll(".chat-member-item")) {{
            if (normalizeNodeId(member.dataset.nodeId || "") === selectedNodeId) {{
              selectedMember = member;
              break;
            }}
          }}
          if (!(selectedMember instanceof HTMLElement)) {{
            continue;
          }}
          const listRect = chatRoomList.getBoundingClientRect();
          const rowRect = selectedMember.getBoundingClientRect();
          const topSafe = listRect.top + 3;
          let bottomSafe = listRect.bottom - 3;
          const detailsDrawer = document.getElementById("chat-node-details-drawer");
          if (
            chatRoomList.id === "chat-room-list"
            && detailsDrawer instanceof HTMLElement
            && !detailsDrawer.hidden
            && isVisibleForSelectionScroll(detailsDrawer)
          ) {{
            const drawerRect = detailsDrawer.getBoundingClientRect();
            bottomSafe = Math.min(bottomSafe, drawerRect.top - 3);
          }}
          if (bottomSafe <= topSafe + 8) {{
            bottomSafe = topSafe + 8;
          }}
          if (rowRect.top < topSafe) {{
            const delta = rowRect.top - topSafe;
            chatRoomList.scrollTo({{ top: chatRoomList.scrollTop + delta, behavior: "smooth" }});
          }} else if (rowRect.bottom > bottomSafe) {{
            const delta = rowRect.bottom - bottomSafe;
            chatRoomList.scrollTo({{ top: chatRoomList.scrollTop + delta, behavior: "smooth" }});
          }}
          didScroll = true;
          break;
        }}
      }}

      const favoritesList = document.getElementById("favorites-list");
      if (isVisibleForSelectionScroll(favoritesList)) {{
        let favoriteItem = null;
        for (const row of favoritesList.querySelectorAll(".favorite-node-item")) {{
          if (normalizeNodeId(row.dataset.nodeId || "") === selectedNodeId) {{
            favoriteItem = row;
            break;
          }}
        }}
        if (favoriteItem instanceof HTMLElement) {{
          const listRect = favoritesList.getBoundingClientRect();
          const rowRect = favoriteItem.getBoundingClientRect();
          const topSafe = listRect.top + 3;
          const bottomSafe = listRect.bottom - 3;
          if (rowRect.top < topSafe) {{
            const delta = rowRect.top - topSafe;
            favoritesList.scrollTo({{ top: favoritesList.scrollTop + delta, behavior: "smooth" }});
          }} else if (rowRect.bottom > bottomSafe) {{
            const delta = rowRect.bottom - bottomSafe;
            favoritesList.scrollTo({{ top: favoritesList.scrollTop + delta, behavior: "smooth" }});
          }}
          didScroll = true;
        }}
      }}

      pendingSelectionScroll = isChatWorkspaceLayoutView(activeLayoutView) ? false : !didScroll;
    }}

    function withProgrammaticMapMove(fn) {{
      const depth = Number.isFinite(Number(programmaticMapMoveDepth)) ? Math.trunc(Number(programmaticMapMoveDepth)) : 0;
      programmaticMapMoveDepth = depth + 1;
      try {{
        return fn();
      }} finally {{
        const after = Number.isFinite(Number(programmaticMapMoveDepth)) ? Math.trunc(Number(programmaticMapMoveDepth)) : 1;
        programmaticMapMoveDepth = Math.max(0, after - 1);
      }}
    }}

    function collectHistoryLatLngs(history) {{
      const pts = [];
      const raw = history && Array.isArray(history.positions) ? history.positions : [];
      for (const point of raw) {{
        const lat = Number(point && point.lat);
        const lon = Number(point && point.lon);
        if (!isValidMapCoord(lat, lon)) continue;
        pts.push([lat, lon]);
      }}
      return pts;
    }}

    function selectedNetworkNodeInfoCollapsed(nodeId = selectedNodeId) {{
      const normalized = normalizeNodeId(nodeId || "");
      if (!isSelectableNodeId(normalized)) return false;
      return (
        activeLayoutView === "network"
        && normalizeNodeId(networkNodeInfoCollapsedNodeId || "") === normalized
      );
    }}

    function withProgrammaticNetworkNodeInfoPopup(fn) {{
      const depth = Number.isFinite(Number(networkNodeInfoPopupProgrammaticDepth))
        ? Math.max(0, Math.trunc(Number(networkNodeInfoPopupProgrammaticDepth)))
        : 0;
      networkNodeInfoPopupProgrammaticDepth = depth + 1;
      try {{
        return fn();
      }} finally {{
        const after = Number.isFinite(Number(networkNodeInfoPopupProgrammaticDepth))
          ? Math.max(0, Math.trunc(Number(networkNodeInfoPopupProgrammaticDepth)) - 1)
          : 0;
        networkNodeInfoPopupProgrammaticDepth = after;
      }}
    }}

    function focusSelectedNodeOnMap(historyOverride = null, opts = null) {{
      const options = (opts && typeof opts === "object") ? opts : {{}};
      const focusView = options.focusView !== false;
      const openPopup = options.openPopup !== false;
      const focusNodeId = normalizeNodeId(options.nodeId || selectedNodeId || "");
      if (!isSelectableNodeId(focusNodeId)) return false;
      const history = historyOverride || cachedNodeHistory(focusNodeId);
      const trailPts = collectHistoryLatLngs(history);
      const marker = nodeMarkers.get(focusNodeId);
      if (!marker) {{
        let usedHistory = false;
        let usedOverviewFallback = false;
        if (focusView && typeof L !== "undefined" && map && typeof map.getZoom === "function" && trailPts.length > 0) {{
          if (trailPts.length > 1) {{
            const trailBounds = L.latLngBounds(trailPts);
            if (trailBounds.isValid()) {{
              withProgrammaticMapMove(() => {{
                map.fitBounds(trailBounds.pad(0.22), {{ animate: false, maxZoom: 16 }});
              }});
              usedHistory = true;
            }}
          }}
          if (!usedHistory) {{
            const targetZoom = Math.min(16, Math.max(map.getZoom(), 11));
            const newestPt = trailPts[trailPts.length - 1];
            withProgrammaticMapMove(() => {{
              map.setView(newestPt, targetZoom, {{ animate: false }});
            }});
            usedHistory = true;
          }}
          requestMapResize();
        }}

        if (focusView && !usedHistory && trailPts.length === 0 && activeLayoutView === "network") {{
          const nodesForOverview = latestState && Array.isArray(latestState.nodes) ? latestState.nodes : [];
          map.closePopup();
          const didFitOverview = fitMapToMostNodes(nodesForOverview, {{ pad: 0.18, maxZoom: 13 }});
          if (didFitOverview) {{
            usedOverviewFallback = true;
          }} else {{
            requestMapResize();
          }}
        }}

        if (
          !openPopup
          || selectedNetworkNodeInfoCollapsed(focusNodeId)
          || (usedOverviewFallback && trailPts.length === 0)
        ) {{
          return usedHistory || usedOverviewFallback;
        }}
        if (activeLayoutView === "network" && typeof L !== "undefined" && map && typeof map.getCenter === "function") {{
          const nodes = latestState && Array.isArray(latestState.nodes) ? latestState.nodes : [];
          const selectedNode = nodes.find((node) => (
            normalizeNodeId(node && node.id) === focusNodeId
          ));
          const popupAnchor = trailPts.length > 0
            ? trailPts[trailPts.length - 1]
            : null;
          if (selectedNode) {{
            const lat = Number(selectedNode.lat);
            const lon = Number(selectedNode.lon);
            const hasGps = isValidMapCoord(lat, lon);
            if (!hasGps && trailPts.length === 0) {{
              return usedHistory || usedOverviewFallback;
            }}
            const targetPopupAnchor = popupAnchor || [lat, lon];
            const posLabel = hasGps
              ? `${{lat.toFixed(5)}}, ${{lon.toFixed(5)}}`
              : "No GPS fix";
            const popupHtml = buildMapNodeInfoHtml(selectedNode, {{
              nodeId: focusNodeId || selectedNode.id || "",
              nowUnix: Math.floor(Date.now() / 1000),
              state: latestState,
              positionBadge: {{
                label: hasGps ? "Map Position" : "No Position",
                className: hasGps ? "live" : "unknown",
                title: hasGps ? `Marker currently focused at ${{posLabel}}.` : "No usable position is available for this node.",
              }},
              trailPointsCount: trailPts.length,
            }});
            withProgrammaticNetworkNodeInfoPopup(() => {{
              L.popup({{ closeButton: true, autoPan: true, className: "map-node-popup", maxWidth: 320 }})
                .setLatLng(targetPopupAnchor)
                .setContent(popupHtml)
                .openOn(map);
            }});
            requestMapResize();
          }} else if (popupAnchor) {{
            const popupHtml = `
              <div class="map-node-info-card">
                <div class="map-node-info-header">
                  <div class="map-node-info-title-wrap">
                    <div class="map-node-info-title">History-only node</div>
                    <div class="map-node-info-subtitle">${{escAttr(focusNodeId || "n/a")}}</div>
                  </div>
                </div>
                <div class="map-node-info-grid">
                  <div class="map-node-info-row">
                    <span class="map-node-info-label">Trail Points</span>
                    <span class="map-node-info-value">${{escAttr(trailPts.length)}}</span>
                  </div>
                  <div class="map-node-info-row">
                    <span class="map-node-info-label">Latest Trail</span>
                    <span class="map-node-info-value">${{escAttr(history && history.summary ? (history.summary.trail_end || "n/a") : "n/a")}}</span>
                  </div>
                </div>
              </div>
            `;
            withProgrammaticNetworkNodeInfoPopup(() => {{
              L.popup({{ closeButton: true, autoPan: true, className: "map-node-popup", maxWidth: 320 }})
                .setLatLng(popupAnchor)
                .setContent(popupHtml)
                .openOn(map);
            }});
            requestMapResize();
          }}
        }}
        return usedHistory || usedOverviewFallback;
      }}
      const markerLatLng = marker.getLatLng();
      let usedHistory = false;

      if (focusView) {{
        if (trailPts.length > 1) {{
          const bounds = L.latLngBounds(trailPts);
          bounds.extend(markerLatLng);
          if (bounds.isValid()) {{
            withProgrammaticMapMove(() => {{
              map.fitBounds(bounds.pad(0.22), {{ animate: false, maxZoom: 16 }});
            }});
            usedHistory = true;
          }}
        }}

        if (!usedHistory) {{
          const targetZoom = Math.min(16, Math.max(map.getZoom(), 11));
          withProgrammaticMapMove(() => {{
            map.setView(markerLatLng, targetZoom, {{ animate: false }});
          }});
        }}
      }}

      requestMapResize();
      if (openPopup && !selectedNetworkNodeInfoCollapsed(focusNodeId)) {{
        withProgrammaticNetworkNodeInfoPopup(() => {{
          marker.openPopup();
        }});
      }}
      return usedHistory;
    }}

    function refreshMapMarkerStyles() {{
      for (const [nodeId, marker] of nodeMarkers.entries()) {{
        const isSelected = !!selectedNodeId && nodeId === selectedNodeId;
        const markerKind = nodeMarkerKinds.get(nodeId) || "actual";
        const markerConfidence = Number(nodeMarkerConfidence.get(nodeId));
        refreshMapNodeMarkerPresentation(
          marker,
          nodeId,
          isSelected,
          markerKind,
          Number.isFinite(markerConfidence) ? markerConfidence : 0.45,
          latestState
        );
      }}
    }}

    function updateMapSelection(shouldFocus = false) {{
      refreshMapMarkerStyles();
      const shouldAutoFocusView = (
        !!selectedNodeId
        && (!!shouldFocus || !!pendingMapHistoryFocus)
      );
      const shouldAutoOpenInfo = (
        !!selectedNodeId
        && activeLayoutView === "network"
        && !selectedNetworkNodeInfoCollapsed(selectedNodeId)
        && !!shouldFocus
      );
      if (!selectedNodeId || (!shouldAutoFocusView && !shouldAutoOpenInfo)) return;
      const usedHistory = focusSelectedNodeOnMap(null, {{
        focusView: shouldAutoFocusView,
        openPopup: shouldAutoOpenInfo,
      }});
      if (shouldAutoFocusView) {{
        if (usedHistory) {{
          pendingMapHistoryFocus = false;
        }} else {{
          const cached = cachedNodeHistory(selectedNodeId);
          if (cached) {{
            // History is loaded but has no valid trail points. Don't keep auto-fit pending.
            pendingMapHistoryFocus = false;
          }}
        }}
      }}
    }}

    function selectedNodeFrom(nodes) {{
      if (!selectedNodeId) return null;
      for (const node of (nodes || [])) {{
        if (normalizeNodeId(node.id || "") === selectedNodeId) {{
          return node;
        }}
      }}
      return null;
    }}

    function nextAnimationFrame() {{
      return new Promise((resolve) => {{
        window.requestAnimationFrame(() => resolve());
      }});
    }}

    function mapBootstrapInterestNode(nodes, state = latestState) {{
      const allNodes = Array.isArray(nodes) ? nodes : [];
      if (allNodes.length === 0) return {{ node: null, source: "none" }};

      const selected = selectedNodeFrom(allNodes);
      if (selected && isValidMapCoord(Number(selected.lat), Number(selected.lon))) {{
        return {{ node: selected, source: "selected" }};
      }}

      const localId = resolveLocalNodeId(state);
      if (isCanonicalNodeId(localId)) {{
        for (const node of allNodes) {{
          if (normalizeNodeId(node && node.id) !== localId) continue;
          if (isValidMapCoord(Number(node && node.lat), Number(node && node.lon))) {{
            return {{ node, source: "local" }};
          }}
          break;
        }}
      }}

      for (const node of allNodes) {{
        if (isValidMapCoord(Number(node && node.lat), Number(node && node.lon))) {{
          return {{ node, source: "first-positioned" }};
        }}
      }}
      return {{ node: null, source: "none" }};
    }}

    function applyMapBootstrapFocus(nodes, state = latestState) {{
      if (activeLayoutView === "network") {{
        const didFit = fitMapToMostNodes(nodes, {{ pad: 0.18, maxZoom: 13 }});
        if (didFit) {{
          return {{ didFocus: true, source: "network-overview" }};
        }}
      }}
      const interest = mapBootstrapInterestNode(nodes, state);
      const node = interest.node;
      if (!node) return {{ didFocus: false, source: interest.source }};
      const lat = Number(node.lat);
      const lon = Number(node.lon);
      const baseZoom = interest.source === "first-positioned" ? 9 : 11;
      withProgrammaticMapMove(() => {{
        map.setView([lat, lon], Math.max(map.getZoom(), baseZoom), {{ animate: false }});
      }});
      requestMapResize();
      return {{ didFocus: true, source: interest.source }};
    }}

    function setMapDataMode(mode) {{
      const normalized = mode === "node" || mode === "activity" ? mode : "live";
      activeMapDataMode = normalized;
      const live = document.getElementById("map-data-live");
