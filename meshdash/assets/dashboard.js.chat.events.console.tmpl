    function formatConsolePromptInputLine(promptLabel, draftValue) {{
      const prompt = String(promptLabel == null ? "" : promptLabel).trim() || "$";
      const draft = String(draftValue == null ? "" : draftValue);
      const separator = /[$>]$/.test(prompt) ? "" : " ";
      const promptWithSeparator = `${{prompt}}${{separator}}`;
      const input = consoleCommandInputElement();
      const focused = input instanceof HTMLInputElement && document.activeElement === input;
      if (!(activeLayoutView === "console" && focused && consoleCursorVisible)) {{
        return escAttr(`${{promptWithSeparator}}${{draft}}`);
      }}
      const rawCaretIndex = input instanceof HTMLInputElement ? input.selectionStart : draft.length;
      const caretIndex = Math.max(
        0,
        Math.min(
          draft.length,
          Math.trunc(Number.isFinite(rawCaretIndex) ? rawCaretIndex : draft.length)
        )
      );
      const beforeCaret = draft.slice(0, caretIndex);
      const afterCaret = draft.slice(caretIndex);
      return `${{escAttr(`${{promptWithSeparator}}${{beforeCaret}}`)}}<span class="console-caret" aria-hidden="true"></span>${{escAttr(afterCaret)}}`;
    }}

    function formatConsolePromptEchoLine(promptLabel, commandText) {{
