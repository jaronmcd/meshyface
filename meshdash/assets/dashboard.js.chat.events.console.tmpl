          const entries = Array.isArray(payload.entries) ? payload.entries : [];
          const totalMatchesRaw = Number(payload.matches);
          const shownMatchesRaw = Number(payload.returned_matches);
          const scannedPacketsRaw = Number(payload.scanned_packets);
          const totalMatches = Number.isFinite(totalMatchesRaw) ? Math.max(0, Math.trunc(totalMatchesRaw)) : 0;
          const shownMatches = Number.isFinite(shownMatchesRaw) ? Math.max(0, Math.trunc(shownMatchesRaw)) : totalMatches;
          const scannedPackets = Number.isFinite(scannedPacketsRaw) ? Math.max(0, Math.trunc(scannedPacketsRaw)) : 0;
          const queryLabel = String(payload.query || queryText);
          const scopeLabel = String(payload.scope || scope);
