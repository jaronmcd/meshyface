            }}
          }}
          const limitRaw = Number(options.limit ?? options.n ?? 50);
          const limit = Math.min(500, Math.max(1, Math.floor(Number.isFinite(limitRaw) ? limitRaw : 50)));
          const rows = collectConsoleNodeRows(ctx && ctx.state);
          const filtered = rows.filter((row) => {{
