          const comparisons = Array.isArray(ctx && ctx.comparisons) ? ctx.comparisons : [];
          const rawArgs = Array.isArray(ctx && ctx.args) ? ctx.args : [];
          const idPattern = normalizeWildcardPattern(options.id || "");
          const namePattern = normalizeWildcardPattern(options.name || "");
          const statusPattern = normalizeWildcardPattern(options.status || "");
          const portPattern = normalizeWildcardPattern(options.port ?? options.p ?? "");
          const parseBoolFilter = (rawValue) => {{
            if (typeof rawValue === "boolean") return rawValue;
            const clean = String(rawValue == null ? "" : rawValue).trim().toLowerCase();
            if (!clean) return null;
            if (["1", "true", "yes", "y", "on", "gps", "with"].includes(clean)) return true;
