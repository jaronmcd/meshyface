    function pingReplyNodeHops(node) {{
      if (!node || typeof node !== "object") return null;
      const hopKeys = ["hops_away", "hopsAway", "hops", "last_hops", "lastHops"];
      for (const key of hopKeys) {{
        const hops = nonNegativeIntegerOrNull(node[key]);
        if (hops != null) return hops;
      }}
      return null;
    }}

    function effectiveAckReplyHops(options = null, sourceNode = null) {{
      const direct = nonNegativeIntegerOrNull(options && options.hops);
      if (direct != null) return direct;
      const hopStart = optionalFiniteNumber(options && (options.hop_start ?? options.hopStart));
      const hopLimit = optionalFiniteNumber(options && (options.hop_limit ?? options.hopLimit));
      if (hopStart != null && hopLimit != null) {{
        const derived = Math.trunc(hopStart) - Math.trunc(hopLimit);
        if (derived >= 0) return derived;
      }}
      return pingReplyNodeHops(sourceNode);
    }}


    async function buildPongStyleAckReplyText(options = null, state = latestState) {{
      const safeState = (state && typeof state === "object") ? state : {{}};
      const nodes = Array.isArray(safeState.nodes) ? safeState.nodes : [];
      const sourceId = normalizeNodeId((options && options.source_id) || "");
      const sourceNode = nodes.find((node) => normalizeNodeId(node && node.id) === sourceId) || null;
      const hops = effectiveAckReplyHops(options, sourceNode);
      const hopText = formatHopCountLabel(hops, "hop count n/a");

      const localNodeId = normalizeNodeId(resolveLocalNodeId(safeState) || "");
      const localNode = nodes.find((node) => normalizeNodeId(node && node.id) === localNodeId) || null;
      const localCoords = nodeCoordsFromStateEntry(localNode);
      let cityHint = "";
      if (localCoords) {{
        cityHint = await nearestOfflineCityHintFromCoords(
          localCoords.lat,
          localCoords.lon,
          offlineCityHintMaxDistanceKm
        );
      }}

      if (cityHint) {{
        return `${{hopText}}, near ${{cityHint}}.`;
      }}
      return `${{hopText}}.`;
    }}

    function deliveryStateLabel(state) {{
      const clean = normalizeDeliveryState(state);
      if (clean === "pending") return "Pending";
      if (clean === "acked") return "Delivered";
      if (clean === "nak") return "Failed";
      if (clean === "timeout") return "Timed out";
      if (clean === "error") return "Error";
      if (clean === "sent") return "Sent";
      return "";
    }}

    function deliveryStateTitle(state, errorText = "", ackDetailText = "") {{
      const clean = normalizeDeliveryState(state);
      const detail = String(errorText || "").trim();
      if (!clean) return "";
      if (detail) return `${{deliveryStateLabel(clean)}}. ${{detail}}`;
      if (clean === "pending") return "Awaiting mesh ACK";
      if (clean === "acked") {{
        const ackDetail = String(ackDetailText || "").trim();
        return ackDetail ? `ACK received. ${{ackDetail}}` : "ACK received";
      }}
      if (clean === "nak") return "NAK received";
      if (clean === "timeout") return "No ACK received before timeout";
      if (clean === "error") return "Delivery status error";
      return "Message sent";
    }}

    function isRetryableDeliveryState(state) {{
      const clean = normalizeDeliveryState(state);
      return clean === "nak" || clean === "timeout" || clean === "error";
    }}
