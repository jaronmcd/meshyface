        for (const item of favList.querySelectorAll(".favorite-node-item[data-node-id]")) {{
          if (!(item instanceof HTMLElement)) continue;
          const freshness = freshnessForNode(item.dataset.nodeId || "");
          if (!freshness) continue;
          applyFreshnessClass(item, freshness.status);
        }}

        const caption = document.getElementById("favorites-caption");
        if (caption) {{
          const favoriteIds = visibleFavoriteNodeIds();
          let onlineCount = 0;
          let warnCount = 0;
          let staleCount = 0;
          for (const nodeId of favoriteIds) {{
            const freshness = freshnessForNode(nodeId);
            if (!freshness) continue;
            if (freshness.key === "online") onlineCount += 1;
            else if (freshness.key === "warn") warnCount += 1;
            else if (freshness.key === "stale") staleCount += 1;
          }}
          caption.textContent = `Tagged subsection: ${{favoriteIds.length}} total (${{onlineCount}} online, ${{warnCount}} aging, ${{staleCount}} stale)`;
        }}
      }}

