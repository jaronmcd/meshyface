    async function executeConsoleCommand(parsed, line) {{
      ensureConsoleCommandsRegistered();
      const commandDef = consoleCommandRegistry.get(parsed.command);
      if (!commandDef) {{
        appendConsoleEventLine(`[console] unknown command: ${{parsed.command}} (try "help")`);
        return;
      }}
      const parseVerbosityArgs = (rawArgs, commandName = "") => {{
        const source = Array.isArray(rawArgs) ? rawArgs : [];
        const cleaned = [];
        const cleanCommandName = String(commandName || "").trim().toLowerCase();
        const stopAtLiveFilter = cleanCommandName === "live";
        let insideLiveFilter = false;
        let verbosity = 0;
        for (const token of source) {{
          const text = String(token == null ? "" : token).trim();
          if (stopAtLiveFilter && /^(grep|rg|filter|search|match)$/i.test(text)) {{
            insideLiveFilter = true;
            cleaned.push(token);
            continue;
          }}
          const match = text.match(/^-v{1,4}$/i);
          if (match && !insideLiveFilter) {{
            const level = Math.max(0, Math.min(4, text.length - 1));
            verbosity = Math.max(verbosity, level);
            continue;
          }}
          cleaned.push(token);
        }}
        return {{ args: cleaned, verbosity }};
      }};
      const parsedArgs = Array.isArray(parsed.args) ? parsed.args : [];
      const supportsVerbosity = !!commandDef.supportsVerbosity;
      let commandArgs = parsedArgs;
      let commandVerbosity = 0;
      if (supportsVerbosity) {{
        const parsedVerbosity = parseVerbosityArgs(parsedArgs, parsed.command);
        commandArgs = parsedVerbosity.args;
        commandVerbosity = parsedVerbosity.verbosity;
      }} else {{
        const hasVerbosityToken = parsedArgs.some((token) => /^-v{1,4}$/i.test(String(token == null ? "" : token).trim()));
        if (hasVerbosityToken) {{
          appendConsoleEventLine(`[${{parsed.command}}] -v is only supported for utility commands.`);
          return;
        }}
      }}
      try {{
        const result = await commandDef.run({{
          line,
          command: parsed.command,
          args: commandArgs,
          verbosity: commandVerbosity,
          options: parsed.options,
          comparisons: parsed.comparisons,
          state: latestState,
          wildcardMatches,
          append: (msg) => appendConsoleEventLine(msg),
        }});
        if (Array.isArray(result)) {{
          for (const lineOut of result) {{
            const text = String(lineOut == null ? "" : lineOut).trimEnd();
            if (text) appendConsoleEventLine(text);
          }}
          return;
        }}
        if (result && typeof result === "object") {{
          if (typeof result.message === "string" && result.message.trim()) {{
            appendConsoleEventLine(result.message.trim());
            return;
          }}
          try {{
            appendConsoleEventLine(JSON.stringify(result));
            return;
          }} catch (_err) {{
            return;
          }}
        }}
        const text = String(result == null ? "" : result).trim();
        if (text) {{
          appendConsoleEventLine(text);
        }}
      }} catch (err) {{
        const msg = err instanceof Error ? err.message : String(err || "unknown error");
        appendConsoleEventLine(`[${{parsed.command}}] error: ${{msg}}`);
      }}
    }}

    function registerConsoleCommand(commandDef) {{
      if (!commandDef || typeof commandDef !== "object") return;
      const name = String(commandDef.name || "").trim().toLowerCase();
      if (!name) return;
      const run = typeof commandDef.run === "function"
        ? commandDef.run
        : () => `[${{name}}] not implemented`;
      consoleCommandRegistry.set(name, {{
        name,
        usage: String(commandDef.usage || name).trim() || name,
        description: String(commandDef.description || "").trim(),
        supportsVerbosity: !!commandDef.supportsVerbosity,
        hiddenFromHelp: name.startsWith("--") || commandDef.hiddenFromHelp === true,
        run,
      }});
    }}

    const consoleNodeTargetAutocompleteCommands = new Set([
      "lookup",
      "node",
      "ping",
      "--ping",
      "request-position",
      "--request-position",
      "where",
      "request-telemetry",
      "--request-telemetry",
      "telemetry",
      "traceroute",
      "--traceroute",
      "send-alert",
      "--send-alert",
      "sendtext",
      "--sendtext",
      "request-config",
      "--request-config",
      "request-channels",
      "--request-channels",
      "device-metadata",
      "--device-metadata",
      "reset-nodedb",
      "--reset-nodedb",
      "factory-reset",
      "--factory-reset",
      "factory-reset-device",
      "--factory-reset-device",
      "reboot",
      "--reboot",
      "shutdown",
      "--shutdown",
      "set-time",
      "--set-time",
    ]);
    const consoleSelfTargetMacro = "%self";

    function normalizeConsoleAutocompleteCandidate(candidate) {{
      const source = (candidate && typeof candidate === "object")
        ? candidate
        : {{ insertText: candidate, displayText: candidate }};
      const insertText = String(
        source.insertText ?? source.value ?? source.text ?? ""
      ).trim();
      if (!insertText) return null;
      const displayText = String(
        source.displayText ?? source.label ?? insertText
      ).trim() || insertText;
      return {{
        ...source,
        insertText,
        displayText,
      }};
    }}

    function escapeConsoleCompletionToken(value) {{
      const clean = String(value == null ? "" : value).trim();
      if (!clean) return "";
      if (!/[\s"'\\]/.test(clean)) {{
        return clean;
      }}
      return `"${{clean
        .replace(/\\/g, "\\\\")
        .replace(/"/g, '\\"')}}"`;
    }}

    function consoleNodeAutocompleteEmoji(row) {{
      const safeRow = (row && typeof row === "object") ? row : {{}};
      const raw = (safeRow.raw && typeof safeRow.raw === "object") ? safeRow.raw : {{}};
      const nodeId = normalizeNodeId(safeRow.id || raw.id || raw.node_id || raw.nodeId || "");
      const values = [];
      if (nodeId && typeof nodeEmojiOverrideForNode === "function") {{
        values.push(nodeEmojiOverrideForNode(nodeId));
      }}
      if (nodeId && typeof nodeTagEmojiForNode === "function") {{
        values.push(nodeTagEmojiForNode(nodeId));
      }}
      if (nodeId && typeof nodeHistoryCapsEmojiForNode === "function") {{
        values.push(nodeHistoryCapsEmojiForNode(nodeId, latestState));
      }}
      values.push(raw.node_emoji, raw.nodeEmoji, raw.emoji, raw.icon);
      for (const value of values) {{
        const clean = String(value == null ? "" : value).trim();
        if (clean) return clean;
      }}
      return "";
    }}

    function consoleNodeAutocompleteTagLabel(row) {{
      const safeRow = (row && typeof row === "object") ? row : {{}};
      const raw = (safeRow.raw && typeof safeRow.raw === "object") ? safeRow.raw : {{}};
      const nodeId = normalizeNodeId(safeRow.id || raw.id || raw.node_id || raw.nodeId || "");
      if (!nodeId || typeof nodeTagLabelForNode !== "function") return "";
      return String(nodeTagLabelForNode(nodeId) || "").trim();
    }}

    function collectConsoleNodeTagLookupVariants(row) {{
      const safeRow = (row && typeof row === "object") ? row : {{}};
      const raw = (safeRow.raw && typeof safeRow.raw === "object") ? safeRow.raw : {{}};
      const nodeId = normalizeNodeId(safeRow.id || raw.id || raw.node_id || raw.nodeId || "");
      const seen = new Set();
      const values = [];
      const push = (value) => {{
        const clean = String(value == null ? "" : value).trim();
        if (!clean) return;
        const key = clean.toLowerCase();
        if (seen.has(key)) return;
        seen.add(key);
        values.push(clean);
      }};
      if (nodeId && typeof nodeTagLabelForNode === "function") {{
        push(nodeTagLabelForNode(nodeId));
      }}
      if (nodeId && typeof nodeTagEntryForNode === "function") {{
        const tagEntry = nodeTagEntryForNode(nodeId);
        if (tagEntry && typeof tagEntry === "object") {{
          push(tagEntry.presetId);
          const preset = (tagEntry.preset && typeof tagEntry.preset === "object") ? tagEntry.preset : null;
          if (preset) {{
            push(preset.name);
            push(preset.id);
            push(preset.emoji);
          }}
        }}
      }}
      push(raw.tag);
      push(raw.tag_name);
      push(raw.tagName);
      push(raw.node_tag);
      push(raw.nodeTag);
      return values;
    }}

    function buildConsoleNodeAutocompleteCandidate(row) {{
      const safeRow = (row && typeof row === "object") ? row : {{}};
      const raw = (safeRow.raw && typeof safeRow.raw === "object") ? safeRow.raw : {{}};
      const nodeId = normalizeNodeId(safeRow.id || raw.id || raw.node_id || raw.nodeId || "");
      if (!nodeId) return null;
      const insertText = escapeConsoleCompletionToken(nodeId);
      if (!insertText) return null;
      const longName = String(raw.long_name || raw.longName || safeRow.name || "").trim();
      const shortName = String(raw.short_name || raw.shortName || "").trim();
      const nodeName = String(safeRow.name || longName || shortName || nodeId).trim() || nodeId;
      const status = String(safeRow.status || "").trim();
      const hopsRaw = Number(safeRow.hops);
      const hops = Number.isFinite(hopsRaw) ? Math.trunc(hopsRaw) : null;
      const nodeNum = consoleNodeRowNum(safeRow);
      const lastSeen = String(safeRow.lastSeenLabel || "").trim();
      const portsLabel = formatConsolePortSummary(safeRow.ports, 2);
      const tagLabel = consoleNodeAutocompleteTagLabel(safeRow);
      const metaParts = [];
      if (shortName && shortName !== nodeName) metaParts.push(`short=${{shortName}}`);
      if (tagLabel) metaParts.push(`tag=${{tagLabel}}`);
      if (status) metaParts.push(`status=${{status}}`);
      if (Number.isInteger(hops) && hops >= 0) metaParts.push(`hops=${{hops}}`);
      if (safeRow.hasGps === true) metaParts.push("gps");
      if (lastSeen) metaParts.push(`last=${{lastSeen}}`);
      if (portsLabel && portsLabel !== "n/a") metaParts.push(`ports=${{portsLabel}}`);
      if (Number.isInteger(nodeNum) && nodeNum >= 0) metaParts.push(`num=${{nodeNum}}`);
      return {{
        kind: "node",
        insertText,
        displayText: nodeId,
        ghostText: nodeId,
        nodeId,
        nodeName,
        nodeLongName: longName,
        nodeShortName: shortName,
        nodeEmoji: consoleNodeAutocompleteEmoji(safeRow),
        nodeTagLabel: tagLabel,
        nodeStatus: status,
        nodeHops: hops,
        nodeNum,
        nodeLastSeen: lastSeen,
        nodePorts: portsLabel,
        nodeHasGps: safeRow.hasGps === true,
        metaText: metaParts.join("  "),
      }};
    }}

    function isConsoleSelfTargetMacro(rawTarget) {{
      return String(rawTarget == null ? "" : rawTarget).trim().toLowerCase() === consoleSelfTargetMacro;
    }}

    function resolveConsoleSelfTargetId(state = latestState) {{
      const localId = (typeof resolveLocalNodeId === "function")
        ? normalizeNodeId(resolveLocalNodeId(state) || "")
        : "";
      return isCanonicalNodeId(localId) ? localId : "";
    }}

    function resolveConsoleSelfTargetRow(state = latestState) {{
      const selfId = resolveConsoleSelfTargetId(state);
      if (!selfId) return null;
      const rows = collectConsoleNodeRows(state);
      return rows.find((row) => normalizeNodeId(row && row.id) === selfId)
        || resolveConsoleCachedNodeRow(selfId, state)
        || null;
    }}

    function buildConsoleSelfMacroAutocompleteCandidate(state = latestState) {{
      const selfId = resolveConsoleSelfTargetId(state);
      if (!selfId) return null;
      const selfRow = resolveConsoleSelfTargetRow(state);
      const nodeCandidate = selfRow ? buildConsoleNodeAutocompleteCandidate(selfRow) : null;
      const rowMeta = String(nodeCandidate && nodeCandidate.metaText || "").trim();
      const metaParts = [`macro=${{selfId}}`];
      if (rowMeta) metaParts.push(rowMeta);
      return {{
        kind: "node",
        insertText: consoleSelfTargetMacro,
        displayText: consoleSelfTargetMacro,
        ghostText: consoleSelfTargetMacro,
        nodeId: selfId,
        nodeName: String(nodeCandidate && nodeCandidate.nodeName || "Local radio").trim() || "Local radio",
        nodeLongName: String(nodeCandidate && nodeCandidate.nodeLongName || "").trim(),
        nodeShortName: String(nodeCandidate && nodeCandidate.nodeShortName || "").trim(),
        nodeEmoji: String(nodeCandidate && nodeCandidate.nodeEmoji || "").trim(),
        nodeTagLabel: "macro",
        nodeStatus: String(nodeCandidate && nodeCandidate.nodeStatus || "").trim(),
        nodeHops: nodeCandidate ? nodeCandidate.nodeHops : null,
        nodeNum: nodeCandidate ? nodeCandidate.nodeNum : null,
        nodeLastSeen: String(nodeCandidate && nodeCandidate.nodeLastSeen || "").trim(),
        nodePorts: String(nodeCandidate && nodeCandidate.nodePorts || "").trim(),
        nodeHasGps: !!(nodeCandidate && nodeCandidate.nodeHasGps),
        metaText: metaParts.join("  "),
      }};
    }}

    function resolveConsoleSelectedNodeAutocompleteCandidate(state = latestState) {{
      const selectedId = normalizeNodeId(selectedNodeId || "");
      if (!isCanonicalNodeId(selectedId)) return null;
      const rows = collectConsoleNodeRows(state);
      const selectedRow = rows.find((row) => normalizeNodeId(row && row.id) === selectedId);
      return selectedRow ? buildConsoleNodeAutocompleteCandidate(selectedRow) : null;
    }}

    function resolveConsoleCommandCompletionCandidates(rawPrefix, options = null) {{
      ensureConsoleCommandsRegistered();
      const opts = (options && typeof options === "object") ? options : {{}};
      const allowSearch = opts.allowSearch === true;
      const leadingSlash = opts.leadingSlash === true;
      const prefix = String(rawPrefix == null ? "" : rawPrefix).trim().toLowerCase();
      const includeHidden = prefix.startsWith("--");
      const names = Array.from(consoleCommandRegistry.values())
        .filter((entry) => entry && typeof entry === "object")
        .filter((entry) => includeHidden || !entry.hiddenFromHelp)
        .map((entry) => String(entry.name == null ? "" : entry.name).trim().toLowerCase())
        .filter((name) => !!name);
      if (allowSearch) {{
        names.push("search");
      }}
      const unique = Array.from(new Set(names)).sort((a, b) => a.localeCompare(b));
      if (!prefix) return [];
      return unique
        .filter((name) => name.startsWith(prefix))
        .map((name) => {{
          const text = leadingSlash ? `/${{name}}` : name;
          return {{
            insertText: text,
            displayText: text,
          }};
        }});
    }}

    function resolveConsoleNodeCompletionCandidates(rawPrefix, state = latestState, options = null) {{
      const opts = (options && typeof options === "object") ? options : {{}};
      const preferSelected = opts.preferSelected !== false;
      const prefix = String(rawPrefix == null ? "" : rawPrefix).trim();
      const selectedCandidate = preferSelected
        ? resolveConsoleSelectedNodeAutocompleteCandidate(state)
        : null;
      const clean = prefix.toLowerCase();
      const rows = collectConsoleNodeRows(state);
      const seen = new Set();
      const out = [];
      const pushRow = (row) => {{
        const candidate = buildConsoleNodeAutocompleteCandidate(row);
        if (!candidate) return;
        const dedupeKey = String(candidate.nodeId || candidate.insertText || "").toLowerCase();
        if (seen.has(dedupeKey)) return;
        seen.add(dedupeKey);
        out.push(candidate);
      }};
      const matchId = (value) => {{
        const nodeId = String(value == null ? "" : value).trim().toLowerCase();
        if (!nodeId) return false;
        return nodeId.startsWith(clean);
      }};
      const matchNum = (row) => {{
        const nodeNum = consoleNodeRowNum(row);
        if (!Number.isInteger(nodeNum) || nodeNum < 0) return false;
        return String(nodeNum).startsWith(prefix);
      }};
      const matchName = (value) => String(value == null ? "" : value).trim().toLowerCase().startsWith(clean);

      if (clean.startsWith("%")) {{
        const macroCandidate = buildConsoleSelfMacroAutocompleteCandidate(state);
        return (macroCandidate && consoleSelfTargetMacro.startsWith(clean)) ? [macroCandidate] : [];
      }}

      if (!prefix) {{
        if (selectedCandidate) {{
          const selectedId = String(selectedCandidate.nodeId || selectedCandidate.insertText || "").toLowerCase();
          if (selectedId) {{
            seen.add(selectedId);
            out.push(selectedCandidate);
          }}
        }}
        for (const row of rows) {{
          pushRow(row);
        }}
        return out;
      }}

      if (/^\d+$/.test(prefix)) {{
        for (const row of rows) {{
          if (matchNum(row)) {{
            pushRow(row);
          }}
        }}
      }}
      if (clean.startsWith("!")) {{
        for (const row of rows) {{
          if (matchId(row && row.id)) {{
            pushRow(row);
          }}
        }}
      }} else if (!/^\d+$/.test(prefix)) {{
        for (const row of rows) {{
          const matchTerms = [
            ...collectConsoleNodeLookupNameVariants(row),
            ...collectConsoleNodeTagLookupVariants(row),
          ];
          for (const value of matchTerms) {{
            if (matchName(value)) {{
              pushRow(row);
              break;
            }}
          }}
        }}
      }}
      if (selectedCandidate && out.length > 1) {{
        const selectedInsertText = String(selectedCandidate.nodeId || selectedCandidate.insertText || "").toLowerCase();
        const selectedIdx = out.findIndex((candidate) => (
          String(candidate && (candidate.nodeId || candidate.insertText) || "").toLowerCase() === selectedInsertText
        ));
        if (selectedIdx > 0) {{
          const [selectedFirst] = out.splice(selectedIdx, 1);
          out.unshift(selectedFirst);
        }}
      }}
      return out;
    }}

    function consoleAutocompleteSuppressedByRunningCommand() {{
      return !!(consoleRunningCommand && String(consoleRunningCommand.name || "").trim());
    }}

    function resolveConsoleAutocompleteCandidates(context, state = latestState) {{
      if (consoleAutocompleteSuppressedByRunningCommand()) {{
        return [];
      }}
      const ctx = (context && typeof context === "object") ? context : {{}};
      const tokenIndex = Math.max(0, Math.trunc(Number(ctx.tokenIndex) || 0));
      const rawToken = String(ctx.tokenText == null ? "" : ctx.tokenText);
      const commandName = String(ctx.commandName == null ? "" : ctx.commandName).trim().toLowerCase();
      const leadingSlash = ctx.leadingSlash === true;
      if (tokenIndex === 0) {{
        const prefix = leadingSlash ? rawToken.replace(/^\//, "") : rawToken;
        return resolveConsoleCommandCompletionCandidates(prefix, {{
          allowSearch: leadingSlash,
          leadingSlash,
        }});
      }}
      if (tokenIndex === 1 && consoleNodeTargetAutocompleteCommands.has(commandName)) {{
        return resolveConsoleNodeCompletionCandidates(rawToken, state, {{ preferSelected: true }});
      }}
      return [];
    }}

    function formatConsoleListTime(unixSeconds) {{
      const ts = Number(unixSeconds);
      if (!Number.isFinite(ts) || ts <= 0) return "n/a";
      try {{
        return new Date(Math.floor(ts) * 1000).toISOString().replace("T", " ").replace(".000Z", "Z");
      }} catch (_err) {{
        return "n/a";
      }}
    }}

    function safeConsoleDownloadName(rawName) {{
      const fallback = "console.txt";
      const clean = String(rawName == null ? "" : rawName)
        .trim()
        .replace(/[\\/:*?"<>|]+/g, "-")
        .replace(/\s+/g, " ")
        .replace(/^\.+/, "")
        .replace(/[. ]+$/g, "")
        .slice(0, 96);
      const base = clean || fallback;
      return /\.txt$/i.test(base) ? base : `${{base}}.txt`;
    }}

    function resolveVisibleConsoleSnapshotLines() {{
      const filteredPayload = resolveFilteredConsoleLines(
        resolveConsoleFilterExpression(consoleFilterText)
      );
      const filtered = (filteredPayload && filteredPayload.result && typeof filteredPayload.result === "object")
        ? filteredPayload.result
        : null;
      const lines = Array.isArray(filtered && filtered.lines) ? filtered.lines.slice() : [];
      if (filtered && filtered.active && lines.length < 1) {{
        lines.push(`[filter] no matches for "${{String(filtered.needle || "")}}"`);
      }}
      return lines;
    }}

    function downloadVisibleConsoleSnapshot(rawName = "") {{
      const filename = safeConsoleDownloadName(rawName);
      const visibleLines = resolveVisibleConsoleSnapshotLines();
      const payload = visibleLines.length ? `${{visibleLines.join("\n")}}\n` : "";
      let url = "";
      try {{
        const blob = new Blob([payload], {{ type: "text/plain;charset=utf-8" }});
        url = URL.createObjectURL(blob);
      }} catch (_err) {{
        url = "";
      }}
      if (!url) {{
        return {{
          ok: false,
          filename,
          lineCount: visibleLines.length,
          error: "could not prepare text download",
        }};
      }}
      try {{
        const anchor = document.createElement("a");
        anchor.href = url;
        anchor.download = filename;
        anchor.rel = "noopener";
        anchor.style.display = "none";
        document.body.appendChild(anchor);
        anchor.click();
        anchor.remove();
      }} catch (err) {{
        try {{
          URL.revokeObjectURL(url);
        }} catch (_revokeErr) {{
        }}
        return {{
          ok: false,
          filename,
          lineCount: visibleLines.length,
          error: err instanceof Error ? err.message : "download failed",
        }};
      }}
      window.setTimeout(() => {{
        try {{
          URL.revokeObjectURL(url);
        }} catch (_err) {{
        }}
      }}, 20000);
      return {{
        ok: true,
        filename,
        lineCount: visibleLines.length,
      }};
    }}

    function collectConsoleNodePortMap(state = latestState) {{
      const safeState = (state && typeof state === "object") ? state : {{}};
      const traffic = (safeState.traffic && typeof safeState.traffic === "object") ? safeState.traffic : {{}};
      const packets = Array.isArray(traffic.recent_packets) ? traffic.recent_packets : [];
      const byNodeId = new Map();
      const addPort = (nodeId, portValue) => {{
        const cleanId = normalizeNodeId(nodeId || "");
        const cleanPort = String(portValue == null ? "" : portValue).trim();
        if (!cleanId || !cleanPort || cleanId === "^all") return;
        let bucket = byNodeId.get(cleanId);
        if (!(bucket instanceof Set)) {{
          bucket = new Set();
          byNodeId.set(cleanId, bucket);
        }}
        bucket.add(cleanPort);
      }};
      for (const entry of packets) {{
        const summary = (entry && typeof entry.summary === "object") ? entry.summary : {{}};
        const packet = (entry && typeof entry.packet === "object") ? entry.packet : {{}};
        const port = summary.portnum ?? packet.portnum ?? "";
        if (!String(port == null ? "" : port).trim()) continue;
        addPort(summary.from ?? packet.from ?? "", port);
        addPort(summary.to ?? packet.to ?? "", port);
      }}
      return byNodeId;
    }}

    function formatConsolePortSummary(ports, maxPorts = 3) {{
      const list = Array.isArray(ports) ? ports.filter((port) => !!String(port || "").trim()) : [];
      if (!list.length) return "n/a";
      const cap = Math.max(1, Math.floor(Number(maxPorts) || 3));
      const head = list.slice(0, cap).join(",");
      if (list.length <= cap) return head;
      return `${{head}} +${{list.length - cap}}`;
    }}

    function buildConsoleNodeRowsFromState(state = latestState) {{
      const safeState = (state && typeof state === "object") ? state : {{}};
      const nodes = Array.isArray(safeState.nodes) ? safeState.nodes : [];
      const portsByNodeId = collectConsoleNodePortMap(safeState);
      const nowUnix = Math.floor(Date.now() / 1000);
      const rows = [];
      for (const node of nodes) {{
        if (!node || typeof node !== "object") continue;
        const nodeId = normalizeNodeId(node.id || node.node_id || node.nodeId || "");
        if (!nodeId) continue;
        const nodeName = preferredNodeName(node) || String(nodeLabel(node) || "Unknown");
        const lastSeenUnix = nodeLastHeardUnix(node);
        const status = freshnessStatus(lastSeenUnix, nowUnix);
        const hopsNum = Number(node.hops_away);
        const ports = Array.from(portsByNodeId.get(nodeId) || [])
          .map((port) => String(port == null ? "" : port).trim())
          .filter((port) => !!port)
          .sort((a, b) => a.localeCompare(b));
        const lat = Number(node.lat);
        const lon = Number(node.lon);
        const hasGps = isValidMapCoord(lat, lon);
        rows.push({{
          id: nodeId,
          name: nodeName,
          status,
          hops: Number.isFinite(hopsNum) ? Math.trunc(hopsNum) : null,
          lastSeenUnix: Number.isFinite(lastSeenUnix) ? Math.trunc(lastSeenUnix) : null,
          lastSeenLabel: typeof nodeLastHeardLabel === "function"
            ? nodeLastHeardLabel(node, "n/a", nowUnix)
            : String(node.last_heard || "").trim(),
          ports,
          hasGps,
          raw: node,
        }});
      }}
      rows.sort((a, b) => {{
        const statusCmp = statusRank(a.status) - statusRank(b.status);
        if (statusCmp !== 0) return statusCmp;
        const aLast = Number(a.lastSeenUnix || 0);
        const bLast = Number(b.lastSeenUnix || 0);
        if (aLast !== bLast) return bLast - aLast;
        return String(a.name || "").localeCompare(String(b.name || ""));
      }});
      return rows;
    }}

    function mergeConsoleNodeRowForCache(previous, next) {{
      const prev = (previous && typeof previous === "object") ? previous : {{}};
      const row = (next && typeof next === "object") ? next : {{}};
      const prevRaw = (prev.raw && typeof prev.raw === "object") ? prev.raw : {{}};
      const rowRaw = (row.raw && typeof row.raw === "object") ? row.raw : {{}};
      const mergedRaw = {{ ...prevRaw, ...rowRaw }};
      const prevPorts = Array.isArray(prev.ports) ? prev.ports : [];
      const rowPorts = Array.isArray(row.ports) ? row.ports : [];
      const ports = Array.from(new Set([...prevPorts, ...rowPorts]
        .map((port) => String(port == null ? "" : port).trim())
        .filter((port) => !!port)
      )).sort((a, b) => a.localeCompare(b));
      const prevLast = Number(prev.lastSeenUnix);
      const rowLast = Number(row.lastSeenUnix);
      const lastSeenUnix = Number.isFinite(rowLast) && rowLast > 0
        ? Math.max(rowLast, Number.isFinite(prevLast) ? prevLast : 0)
        : (Number.isFinite(prevLast) ? prevLast : row.lastSeenUnix);
      return {{
        ...prev,
        ...row,
        name: String(row.name || "").trim() || prev.name,
        status: String(row.status || "").trim() || prev.status,
        hops: row.hops == null ? prev.hops : row.hops,
        lastSeenUnix,
        lastSeenLabel: String(row.lastSeenLabel || "").trim() && String(row.lastSeenLabel || "").trim().toLowerCase() !== "n/a"
          ? row.lastSeenLabel
          : prev.lastSeenLabel,
        ports,
        hasGps: row.hasGps === true || prev.hasGps === true,
        raw: mergedRaw,
      }};
    }}

    function consoleNodeRowCacheSignature(row) {{
      const safeRow = (row && typeof row === "object") ? row : {{}};
      const raw = (safeRow.raw && typeof safeRow.raw === "object") ? safeRow.raw : {{}};
      return [
        normalizeNodeId(safeRow.id),
        safeRow.name,
        safeRow.status,
        safeRow.hops,
        safeRow.lastSeenUnix,
        safeRow.lastSeenLabel,
        Array.isArray(safeRow.ports) ? safeRow.ports.join(",") : "",
        safeRow.hasGps === true ? "gps" : "nogps",
        raw.long_name,
        raw.short_name,
        raw.lat,
        raw.lon,
        raw.altitude ?? raw.alt,
        raw.battery_level ?? raw.batteryLevel,
        raw.voltage,
        raw.channel_utilization ?? raw.channelUtilization,
        raw.air_util_tx ?? raw.airUtilTx,
      ].map((value) => String(value == null ? "" : value)).join("|");
    }}

    function refreshConsoleNodeRowsCache(state = latestState) {{
      const rows = buildConsoleNodeRowsFromState(state);
      if (!Array.isArray(rows) || rows.length < 1) return rows;
      let changed = false;
      for (const row of rows) {{
        const nodeId = normalizeNodeId(row && row.id);
        if (!nodeId) continue;
        const previous = consoleNodeRowsByIdCache.get(nodeId);
        const merged = mergeConsoleNodeRowForCache(previous, row);
        const signature = consoleNodeRowCacheSignature(merged);
        if (!previous || previous._consoleCacheSignature !== signature) {{
          merged._consoleCacheSignature = signature;
          consoleNodeRowsByIdCache.set(nodeId, merged);
          changed = true;
        }}
      }}
      if (changed) {{
        consoleNodeRowsCacheVersion += 1;
        consoleRenderedLogCacheKey = "";
      }}
      return rows;
    }}

    function collectConsoleNodeRows(state = latestState) {{
      return refreshConsoleNodeRowsCache(state);
    }}

    function resolveConsoleCachedNodeRow(rawNodeId, state = latestState) {{
      const nodeId = normalizeNodeId(rawNodeId);
      if (!nodeId) return null;
      for (const candidateState of [state, latestRawState]) {{
        const rows = buildConsoleNodeRowsFromState(candidateState);
        const row = rows.find((entry) => normalizeNodeId(entry && entry.id) === nodeId);
        if (row) {{
          refreshConsoleNodeRowsCache(candidateState);
          return consoleNodeRowsByIdCache.get(nodeId) || row;
        }}
      }}
      return consoleNodeRowsByIdCache.get(nodeId) || null;
    }}

    function normalizeConsoleNodeListLabel(value = "nodes") {{
      const clean = String(value == null ? "" : value).trim().toLowerCase();
      if (!clean) return "nodes";
      return clean.replace(/^-+/, "") || "nodes";
    }}

    function runConsoleNodeListCommand(ctx, label = "") {{
      const options = (ctx && ctx.options && typeof ctx.options === "object")
        ? ctx.options
        : {{}};
      const verbosity = Math.max(0, Math.min(4, Number(ctx && ctx.verbosity) || 0));
      const comparisons = Array.isArray(ctx && ctx.comparisons) ? ctx.comparisons : [];
      const rawArgs = Array.isArray(ctx && ctx.args) ? ctx.args : [];
      const outputLabel = normalizeConsoleNodeListLabel(label || (ctx && ctx.command) || "nodes");
      const idPattern = normalizeWildcardPattern(options.id || "");
      const namePattern = normalizeWildcardPattern(options.name || "");
      const statusPattern = normalizeWildcardPattern(options.status || "");
      const portPattern = normalizeWildcardPattern(options.port ?? options.p ?? "");
      const parseBoolFilter = (rawValue) => {{
        if (typeof rawValue === "boolean") return rawValue;
        const clean = String(rawValue == null ? "" : rawValue).trim().toLowerCase();
        if (!clean) return null;
        if (["1", "true", "yes", "y", "on", "gps", "with"].includes(clean)) return true;
        if (["0", "false", "no", "n", "off", "none", "without", "nogps", "no-gps"].includes(clean)) return false;
        return null;
      }};
      let gpsFilter = null;
      if (Object.prototype.hasOwnProperty.call(options, "gps")) {{
        gpsFilter = parseBoolFilter(options.gps);
        if (gpsFilter == null) {{
          return `[${{outputLabel}}] invalid gps value: ${{String(options.gps)}}`;
        }}
      }}
      const args = [];
      for (const arg of rawArgs) {{
        const clean = String(arg || "").trim().toLowerCase();
        if (!Object.prototype.hasOwnProperty.call(options, "gps")) {{
          if (clean === "gps") {{
            gpsFilter = true;
            continue;
          }}
          if (clean === "nogps" || clean === "no-gps") {{
            gpsFilter = false;
            continue;
          }}
        }}
        args.push(arg);
      }}
      const freePattern = normalizeWildcardPattern(args[0] || "");
      const hopsComparators = [];
      const pushHopsComparator = (op, rawValue) => {{
        const numeric = Number(rawValue);
        if (!Number.isFinite(numeric)) {{
          return false;
        }}
        hopsComparators.push({{ op: String(op || "="), value: numeric }});
        return true;
      }};
      if (Object.prototype.hasOwnProperty.call(options, "hops")) {{
        if (!pushHopsComparator("=", options.hops)) {{
          return `[${{outputLabel}}] invalid hops value: ${{String(options.hops)}}`;
        }}
      }}
      for (const cmp of comparisons) {{
        if (!cmp || typeof cmp !== "object") continue;
        const cmpKey = String(cmp.key || "").trim().toLowerCase();
        if (cmpKey !== "hops" && cmpKey !== "hop") continue;
        const cmpOp = String(cmp.op || "").trim();
        if (!["<", ">", "<=", ">="].includes(cmpOp)) continue;
        if (!pushHopsComparator(cmpOp, cmp.value)) {{
          return `[${{outputLabel}}] invalid hops comparator: ${{cmpKey}}${{cmpOp}}${{String(cmp.value || "")}}`;
        }}
      }}
      const limitRaw = Number(options.limit ?? options.n ?? 50);
      const limit = Math.min(500, Math.max(1, Math.floor(Number.isFinite(limitRaw) ? limitRaw : 50)));
      const rows = collectConsoleNodeRows(ctx && ctx.state);
      const filtered = rows.filter((row) => {{
        if (freePattern) {{
          const freeHit = wildcardMatches(freePattern, row.id) || wildcardMatches(freePattern, row.name);
          if (!freeHit) return false;
        }}
        if (idPattern && !wildcardMatches(idPattern, row.id)) return false;
        if (namePattern && !wildcardMatches(namePattern, row.name)) return false;
        if (statusPattern && !wildcardMatches(statusPattern, row.status)) return false;
        if (portPattern) {{
          const hasPortMatch = Array.isArray(row.ports)
            && row.ports.some((portValue) => wildcardMatches(portPattern, portValue));
          if (!hasPortMatch) return false;
        }}
        if (gpsFilter != null && Boolean(row.hasGps) !== gpsFilter) return false;
        if (hopsComparators.length) {{
          const hopsValue = Number(row.hops);
          if (!Number.isFinite(hopsValue)) return false;
          for (const cmp of hopsComparators) {{
            const target = Number(cmp.value);
            if (cmp.op === ">" && !(hopsValue > target)) return false;
            if (cmp.op === "<" && !(hopsValue < target)) return false;
            if (cmp.op === ">=" && !(hopsValue >= target)) return false;
            if (cmp.op === "<=" && !(hopsValue <= target)) return false;
            if (cmp.op === "=" && !(hopsValue === target)) return false;
          }}
        }}
        return true;
      }});
      const show = filtered.slice(0, limit);
      const lines = [
        `[${{outputLabel}}] matched ${{filtered.length}} node(s); showing ${{show.length}}.`,
      ];
      for (const row of show) {{
        const hopsLabel = row.hops == null ? "n/a" : String(row.hops);
        const portsLabel = formatConsolePortSummary(row.ports, 3);
        const gpsLabel = row.hasGps ? "yes" : "no";
        const lat = Number(row && row.raw && row.raw.lat);
        const lon = Number(row && row.raw && row.raw.lon);
        const posLabel = row.hasGps
          ? `${{lat.toFixed(5)}},${{lon.toFixed(5)}}`
          : "n/a";
        lines.push(
          `${{row.id}} | ${{row.name}} | status=${{row.status}} | gps=${{gpsLabel}} | hops=${{hopsLabel}} | ports=${{portsLabel}} | last=${{formatConsoleListTime(row.lastSeenUnix)}}${{verbosity > 0 ? ` | pos=${{posLabel}}` : ""}}`
        );
        if (verbosity >= 2) {{
          const altitude = Number(row && row.raw && row.raw.altitude);
          const battery = Number(row && row.raw && row.raw.battery_level);
          const detail = [];
          if (Number.isFinite(altitude)) detail.push(`alt=${{Math.trunc(altitude)}}m`);
          if (Number.isFinite(battery)) detail.push(`batt=${{Math.round(battery)}}%`);
          if (detail.length) {{
            lines.push(`  details: ${{detail.join(" | ")}}`);
          }}
        }}
      }}
      if (!show.length) {{
        lines.push(`[${{outputLabel}}] no matches. Try ${{outputLabel}} * or ${{outputLabel}} name=*pattern*`);
      }} else if (filtered.length > show.length) {{
        lines.push(`[${{outputLabel}}] truncated. Use limit=<n> up to 500.`);
      }}
      return lines;
    }}

    function consoleNodeRowNum(row) {{
      const safeRow = (row && typeof row === "object") ? row : {{}};
      const raw = (safeRow.raw && typeof safeRow.raw === "object") ? safeRow.raw : {{}};
      for (const value of [safeRow.num, raw.num, raw.node_num, raw.nodeNum]) {{
        const parsed = parseNodeNum(value);
        if (Number.isInteger(parsed) && parsed >= 0) {{
          return parsed;
        }}
      }}
      return null;
    }}

    function resolveConsoleNodeTarget(rawTarget, state = latestState) {{
      const target = String(rawTarget == null ? "" : rawTarget).trim();
      const rows = collectConsoleNodeRows(state);
      if (!target) {{
        return {{
          target,
          rows,
          matches: [],
          mode: "missing",
        }};
      }}

      if (isConsoleSelfTargetMacro(target)) {{
        const selfRow = resolveConsoleSelfTargetRow(state);
        return {{
          target,
          rows,
          matches: selfRow ? [selfRow] : [],
          mode: selfRow ? "self-macro" : "missing-self",
        }};
      }}

      const normalizedId = normalizeNodeId(target);
      if (isCanonicalNodeId(normalizedId)) {{
        const exactIdMatches = rows.filter((row) => normalizeNodeId(row && row.id) === normalizedId);
        if (exactIdMatches.length) {{
          return {{
            target,
            rows,
            matches: exactIdMatches,
            mode: "exact-id",
          }};
        }}
      }}

      const targetNum = parseNodeNum(target);
      if (Number.isInteger(targetNum) && targetNum >= 0) {{
        const exactNumMatches = rows.filter((row) => consoleNodeRowNum(row) === targetNum);
        if (exactNumMatches.length) {{
          return {{
            target,
            rows,
            matches: exactNumMatches,
            mode: "exact-num",
          }};
        }}
      }}

      const exactName = target.toLowerCase();
      const exactNameMatches = rows.filter((row) => (
        collectConsoleNodeLookupNameVariants(row)
          .some((value) => String(value == null ? "" : value).trim().toLowerCase() === exactName)
      ));
      if (exactNameMatches.length) {{
        return {{
          target,
          rows,
          matches: exactNameMatches,
          mode: "exact-name",
        }};
      }}

      const pattern = normalizeWildcardPattern(target);
      const partialIdMatches = rows.filter((row) => wildcardMatches(pattern, row && row.id ? row.id : ""));
      if (partialIdMatches.length === 1) {{
        return {{
          target,
          rows,
          matches: partialIdMatches,
          mode: "partial-id",
        }};
      }}

      const partialNameMatches = rows.filter((row) => (
        collectConsoleNodeLookupNameVariants(row)
          .some((value) => wildcardMatches(pattern, value))
      ));
      if (partialNameMatches.length === 1) {{
        return {{
          target,
          rows,
          matches: partialNameMatches,
          mode: "partial-name",
        }};
      }}

      const deduped = [];
      const seen = new Set();
      const pushRows = (entries) => {{
        for (const row of entries) {{
          const key = normalizeNodeId(row && row.id);
          if (!key || seen.has(key)) continue;
          seen.add(key);
          deduped.push(row);
        }}
      }};
      pushRows(partialIdMatches);
      pushRows(partialNameMatches);
      return {{
        target,
        rows,
        matches: deduped,
        mode: deduped.length ? "ambiguous" : "none",
      }};
    }}

    function collectConsoleNodeLookupNameVariants(row) {{
      const safeRow = (row && typeof row === "object") ? row : {{}};
      const raw = (safeRow.raw && typeof safeRow.raw === "object") ? safeRow.raw : {{}};
      const seen = new Set();
      const values = [];
      const push = (value) => {{
        const clean = String(value == null ? "" : value).trim();
        if (!clean) return;
        const key = clean.toLowerCase();
        if (seen.has(key)) return;
        seen.add(key);
        values.push(clean);
      }};
      push(safeRow.name);
      push(raw.long_name);
      push(raw.short_name);
      return values;
    }}

    function resolveConsoleNodeLookupMatches(rawTarget, state = latestState) {{
      const target = String(rawTarget == null ? "" : rawTarget).trim();
      const rows = collectConsoleNodeRows(state);
      if (!target) {{
        return {{
          target,
          rows,
          matches: [],
          mode: "missing",
        }};
      }}
      if (isConsoleSelfTargetMacro(target)) {{
        const selfRow = resolveConsoleSelfTargetRow(state);
        return {{
          target,
          rows,
          matches: selfRow ? [selfRow] : [],
          mode: selfRow ? "self-macro" : "missing-self",
        }};
      }}
      const targetId = normalizeNodeId(target).toLowerCase();
      const targetName = target.toLowerCase();
      const exactIdMatches = rows.filter((row) => (
        String(normalizeNodeId(row && row.id ? row.id : "")).toLowerCase() === targetId
      ));
      if (exactIdMatches.length) {{
        return {{
          target,
          rows,
          matches: exactIdMatches,
          mode: "exact-id",
        }};
      }}
      const exactNameMatches = rows.filter((row) => (
        collectConsoleNodeLookupNameVariants(row)
          .some((value) => String(value == null ? "" : value).trim().toLowerCase() === targetName)
      ));
      if (exactNameMatches.length) {{
        return {{
          target,
          rows,
          matches: exactNameMatches,
          mode: "exact-name",
        }};
      }}
      const pattern = normalizeWildcardPattern(target);
      const fuzzyMatches = rows.filter((row) => {{
        if (wildcardMatches(pattern, row && row.id ? row.id : "")) return true;
        return collectConsoleNodeLookupNameVariants(row)
          .some((value) => wildcardMatches(pattern, value));
      }});
      return {{
        target,
        rows,
        matches: fuzzyMatches,
        mode: "fuzzy",
      }};
    }}

    function formatConsoleNodeLookupListLine(row) {{
      const safeRow = (row && typeof row === "object") ? row : {{}};
      const id = String(safeRow.id || "n/a").trim() || "n/a";
      const name = String(safeRow.name || "Unknown").trim() || "Unknown";
      const status = String(safeRow.status || "unknown").trim() || "unknown";
      const lastSeen = formatConsoleListTime(safeRow.lastSeenUnix);
      const hops = safeRow.hops == null ? "n/a" : String(safeRow.hops);
      return `${{id}} | ${{name}} | status=${{status}} | last=${{lastSeen}} | hops=${{hops}}`;
    }}

    function formatConsoleNodeLookupDetails(row, verbosity = 0) {{
      const safeRow = (row && typeof row === "object") ? row : {{}};
      const raw = (safeRow.raw && typeof safeRow.raw === "object") ? safeRow.raw : {{}};
      const lines = [];
      const id = String(safeRow.id || "n/a").trim() || "n/a";
      const name = String(safeRow.name || "Unknown").trim() || "Unknown";
      const status = String(safeRow.status || "unknown").trim() || "unknown";
      const hops = safeRow.hops == null ? "n/a" : String(safeRow.hops);
      const lastSeen = formatConsoleListTime(safeRow.lastSeenUnix);
      const lat = Number(raw.lat);
      const lon = Number(raw.lon);
      const hasGps = Boolean(safeRow.hasGps) && isValidMapCoord(lat, lon);
      const coordDigits = verbosity > 0 ? 7 : 5;
      const altitude = Number(raw.altitude ?? raw.alt ?? raw.altitude_m ?? raw.altitudeM);
      const battery = Number(raw.battery_level ?? raw.batteryLevel);
      const voltage = Number(raw.voltage);
      const channelUtil = Number(raw.channel_utilization ?? raw.channelUtilization);
      const airUtilTx = Number(raw.air_util_tx ?? raw.airUtilTx);

      lines.push(`${{id}} | ${{name}}`);
      lines.push(`  status=${{status}} | last=${{lastSeen}} | hops=${{hops}}`);

      const gpsParts = [`gps=${{hasGps ? "yes" : "no"}}`];
      if (hasGps) {{
        gpsParts.push(`pos=${{lat.toFixed(coordDigits)}},${{lon.toFixed(coordDigits)}}`);
      }}
      if (Number.isFinite(altitude)) {{
        gpsParts.push(`altitude=${{Math.trunc(altitude)}}m`);
      }}
      lines.push(`  ${{gpsParts.join(" | ")}}`);

      const powerParts = [];
      if (Number.isFinite(battery)) {{
        powerParts.push(`battery=${{Math.round(battery)}}%`);
      }}
      if (Number.isFinite(voltage)) {{
        powerParts.push(`voltage=${{voltage.toFixed(verbosity > 0 ? 3 : 2)}}V`);
      }}
      if (Number.isFinite(channelUtil)) {{
        powerParts.push(`channel_util=${{channelUtil.toFixed(verbosity > 0 ? 2 : 1)}}%`);
      }}
      if (Number.isFinite(airUtilTx)) {{
        powerParts.push(`air_util_tx=${{airUtilTx.toFixed(verbosity > 0 ? 2 : 1)}}%`);
      }}
      if (powerParts.length) {{
        lines.push(`  ${{powerParts.join(" | ")}}`);
      }}

      lines.push(`  ports=${{formatConsolePortSummary(safeRow.ports, verbosity > 0 ? 12 : 8)}}`);

      if (verbosity >= 2) {{
        const detailParts = [];
        const displayName = name.toLowerCase();
        const shortName = String(raw.short_name || "").trim();
        const longName = String(raw.long_name || "").trim();
        const lastSeenUnix = Number(safeRow.lastSeenUnix);
        if (shortName && shortName.toLowerCase() !== displayName) {{
          detailParts.push(`short=${{shortName}}`);
        }}
        if (longName && longName.toLowerCase() !== displayName) {{
          detailParts.push(`long=${{longName}}`);
        }}
        if (Number.isFinite(lastSeenUnix) && lastSeenUnix > 0) {{
          detailParts.push(`last_heard_unix=${{Math.trunc(lastSeenUnix)}}`);
        }}
        if (hasGps) {{
          detailParts.push(`lat=${{lat.toFixed(7)}}`);
          detailParts.push(`lon=${{lon.toFixed(7)}}`);
        }}
        if (detailParts.length) {{
          lines.push(`  details: ${{detailParts.join(" | ")}}`);
        }}
      }}

      return lines;
    }}

    function parseConsoleNetworkIntOption(options, names, label, minValue, commandLabel) {{
      const optionNames = Array.isArray(names) ? names : [names];
      let rawValue = null;
      for (const name of optionNames) {{
        if (Object.prototype.hasOwnProperty.call(options || {{}}, name)) {{
          rawValue = options[name];
          break;
        }}
      }}
      if (rawValue == null) return {{ ok: true, value: null }};
      const clean = String(rawValue).trim();
      if (!clean) return {{ ok: true, value: null }};
      const numeric = Number(clean);
      if (!Number.isFinite(numeric) || !Number.isInteger(numeric)) {{
        return {{ ok: false, error: `[${{commandLabel}}] invalid ${{label}}: ${{clean}}` }};
      }}
      if (numeric < minValue) {{
        return {{ ok: false, error: `[${{commandLabel}}] ${{label}} must be >= ${{minValue}}` }};
      }}
      return {{ ok: true, value: Math.trunc(numeric) }};
    }}

    function resolveConsoleNetworkCommandDestination(rawTarget, state, commandLabel) {{
      if (isConsoleSelfTargetMacro(rawTarget)) {{
        const selfDestination = resolveConsoleSelfTargetId(state);
        if (isCanonicalNodeId(selfDestination)) {{
          return {{ ok: true, destination: selfDestination }};
        }}
        return {{
          ok: false,
          lines: [`[${{commandLabel}}] %self is unavailable: local radio ID is not known yet.`],
        }};
      }}

      const normalizedDirectId = normalizeNodeId(rawTarget);
      if (isCanonicalNodeId(normalizedDirectId)) {{
        return {{ ok: true, destination: normalizedDirectId }};
      }}

      const lookup = resolveConsoleNodeTarget(rawTarget, state);
      const matches = Array.isArray(lookup && lookup.matches) ? lookup.matches : [];
      if (matches.length < 1) {{
        const quotedTarget = /[\s"]/.test(rawTarget) ? JSON.stringify(rawTarget) : rawTarget;
        return {{
          ok: false,
          lines: [
            `[${{commandLabel}}] unknown target: ${{rawTarget}}`,
            `[${{commandLabel}}] try: nodes ${{quotedTarget}}`,
          ],
        }};
      }}
      if (matches.length > 1) {{
        const show = matches.slice(0, 10);
        const lines = [`[${{commandLabel}}] ambiguous target "${{rawTarget}}". Matches:`];
        for (const row of show) {{
          lines.push(`  ${{formatConsoleNodeLookupListLine(row)}}`);
        }}
        if (matches.length > show.length) {{
          lines.push(`  ... ${{matches.length - show.length}} more match(es).`);
        }}
        lines.push(`[${{commandLabel}}] retry with a more specific id, name, or node number.`);
        return {{ ok: false, lines }};
      }}
      return {{
        ok: true,
        destination: String(matches[0] && matches[0].id ? matches[0].id : "").trim(),
      }};
    }}

    async function runConsoleNetworkNodeCommand(ctx, config) {{
      const options = (ctx && ctx.options && typeof ctx.options === "object")
        ? ctx.options
        : {{}};
      const args = Array.isArray(ctx && ctx.args) ? ctx.args : [];
      const commandLabel = String(config && config.label ? config.label : "network").trim() || "network";
      const networkCommand = String(config && config.command ? config.command : commandLabel).trim();
      const missingExample = String(config && config.example ? config.example : `${{commandLabel}} !abcd1234`);
      const allowHopLimit = !!(config && config.allowHopLimit);

      const channelIndexParsed = parseConsoleNetworkIntOption(
        options,
        ["ch-index", "ch_index", "channel-index", "channel_index"],
        "ch-index",
        0,
        commandLabel,
      );
      if (!channelIndexParsed.ok) return channelIndexParsed.error;
      const hopLimitParsed = allowHopLimit
        ? parseConsoleNetworkIntOption(options, ["hop-limit", "hop_limit"], "hop-limit", 1, commandLabel)
        : {{ ok: true, value: null }};
      if (!hopLimitParsed.ok) return hopLimitParsed.error;
      const timeoutParsed = parseConsoleNetworkIntOption(
        options,
        ["timeout", "timeout_ms"],
        "timeout",
        1,
        commandLabel,
      );
      if (!timeoutParsed.ok) return timeoutParsed.error;

      const explicitDest = String(options.dest ?? options.destination ?? "").trim();
      const rawTarget = String(explicitDest || args.join(" ")).trim();
      if (!rawTarget) {{
        return `[${{commandLabel}}] missing target. Example: ${{missingExample}}`;
      }}

      const resolved = resolveConsoleNetworkCommandDestination(rawTarget, ctx && ctx.state, commandLabel);
      if (!resolved.ok) {{
        return Array.isArray(resolved.lines) ? resolved.lines : `[${{commandLabel}}] invalid target: ${{rawTarget}}`;
      }}
      const destination = String(resolved.destination || "").trim();

      if (!isCanonicalNodeId(destination)) {{
        return `[${{commandLabel}}] invalid destination: ${{destination || rawTarget}}`;
      }}

      const body = {{
        command: networkCommand,
        destination,
      }};
      if (channelIndexParsed.value != null) {{
        body.channel_index = channelIndexParsed.value;
