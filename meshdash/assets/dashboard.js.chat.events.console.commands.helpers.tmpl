      const clean = String(rawType == null ? "" : rawType).trim().toLowerCase();
      if (!clean) return "device_metrics";
      return consoleTelemetryTypeAliases[clean] || "";
    }}

    function telemetryConsoleTypeLabel(telemetryType) {{
      const clean = String(telemetryType || "").trim();
      if (!clean) return "device";
      return clean.replace(/_metrics$/i, "").replace(/_/g, "-");
    }}

    function startConsoleTelemetryWaitFeedback(ctx, destination, telemetryType, timeoutMs) {{
      const append = ctx && typeof ctx.append === "function"
        ? ctx.append
        : (msg) => appendConsoleEventLine(msg);
      const cleanDestination = String(destination || "").trim() || "unknown";
      const cleanType = telemetryConsoleTypeLabel(telemetryType);
      const cleanTimeoutMs = Math.max(1, Math.trunc(Number(timeoutMs) || 12000));
      const timeoutSeconds = Math.max(1, Math.ceil(cleanTimeoutMs / 1000));
      append(`[telemetry] ${{cleanDestination}} | type=${{cleanType}} | request sent`);
      append(`[telemetry] ${{cleanDestination}} | waiting up to ${{timeoutSeconds}}s for response`);
      let tick = 0;
      let timeoutNoticeShown = false;
      const intervalMs = 3000;
      const timer = window.setInterval(() => {{
        tick += 1;
        const elapsedSeconds = Math.min(timeoutSeconds, Math.round((tick * intervalMs) / 1000));
        if (elapsedSeconds >= timeoutSeconds) {{
          if (!timeoutNoticeShown) {{
            timeoutNoticeShown = true;
            append(`[telemetry] ${{cleanDestination}} | still waiting (${{timeoutSeconds}}s timeout nearly reached)`);
          }}
          return;
        }}
        append(`[telemetry] ${{cleanDestination}} | still waiting (${{elapsedSeconds}}s elapsed)`);
      }}, intervalMs);
      return () => {{
        window.clearInterval(timer);
      }};
    }}

    async function runConsoleRequestTelemetryCommand(ctx) {{
      const options = (ctx && ctx.options && typeof ctx.options === "object")
        ? ctx.options
        : {{}};
      const args = Array.isArray(ctx && ctx.args) ? ctx.args : [];
      const commandLabel = "telemetry";

      const channelIndexParsed = parseConsoleNetworkIntOption(
        options,
        ["ch-index", "ch_index", "channel-index", "channel_index"],
        "ch-index",
        0,
        commandLabel,
      );
      if (!channelIndexParsed.ok) return channelIndexParsed.error;
      const hopLimitParsed = parseConsoleNetworkIntOption(
        options,
        ["hop-limit", "hop_limit"],
        "hop-limit",
        1,
        commandLabel,
      );
      if (!hopLimitParsed.ok) return hopLimitParsed.error;
      const timeoutParsed = parseConsoleNetworkIntOption(
        options,
        ["timeout", "timeout_ms"],
        "timeout",
        1,
        commandLabel,
      );
      if (!timeoutParsed.ok) return timeoutParsed.error;

      const explicitDest = String(options.dest ?? options.destination ?? "").trim();
      const explicitTypeRaw = String(options.type ?? options.telemetry_type ?? options["telemetry-type"] ?? "").trim();

      let rawTarget = "";
      let rawType = explicitTypeRaw;
      if (explicitDest) {{
        rawTarget = explicitDest;
        if (args.length > 1) {{
          return `[${{commandLabel}}] too many positional arguments. Use one optional telemetry type.`;
        }}
        if (!rawType && args.length === 1) {{
          rawType = String(args[0] || "").trim();
        }}
      }} else {{
        rawTarget = String(args[0] || "").trim();
        if (!rawTarget) {{
          return `[${{commandLabel}}] missing target. Example: request-telemetry !abcd1234`;
        }}
        if (!rawType && args.length > 1) {{
          rawType = String(args[1] || "").trim();
        }}
        if (args.length > 2) {{
          return `[${{commandLabel}}] too many positional arguments.`;
        }}
      }}

      const resolved = resolveConsoleNetworkCommandDestination(rawTarget, ctx && ctx.state, commandLabel);
      if (!resolved.ok) {{
        return Array.isArray(resolved.lines) ? resolved.lines : `[${{commandLabel}}] invalid target: ${{rawTarget}}`;
      }}
      const destination = String(resolved.destination || "").trim();
      if (!isCanonicalNodeId(destination)) {{
        return `[${{commandLabel}}] invalid destination: ${{destination || rawTarget}}`;
      }}

      const telemetryType = normalizeConsoleTelemetryType(rawType);
      if (!telemetryType) {{
        return `[${{commandLabel}}] invalid telemetry type: ${{rawType}} (use device|environment|air_quality|power|localstats)`;
      }}

      const body = {{
        command: "request-telemetry",
        destination,
        telemetry_type: telemetryType,
      }};
      if (channelIndexParsed.value != null) {{
        body.channel_index = channelIndexParsed.value;
      }}
      if (hopLimitParsed.value != null) {{
        body.hop_limit = hopLimitParsed.value;
      }}
      if (timeoutParsed.value != null) {{
        body.timeout_ms = timeoutParsed.value;
      }}

      const stopWaitFeedback = startConsoleTelemetryWaitFeedback(
        ctx,
        destination,
        telemetryType,
        timeoutParsed.value != null ? timeoutParsed.value : 12000,
      );
      try {{
        const payload = await postNetworkToolCommand(body);
        stopWaitFeedback();
        const lines = Array.isArray(payload && payload.console_lines)
          ? payload.console_lines
              .map((line) => String(line == null ? "" : line).trimEnd())
              .filter((line) => !!line)
          : [];
        return lines.length ? lines : [`[${{commandLabel}}] ${{destination}} | request completed`];
      }} catch (err) {{
        stopWaitFeedback();
        const payload = (err && typeof err === "object") ? err.payload : null;
        const lines = Array.isArray(payload && payload.console_lines)
          ? payload.console_lines
              .map((line) => String(line == null ? "" : line).trimEnd())
              .filter((line) => !!line)
          : [];
        if (lines.length) {{
          return lines;
        }}
        throw err;
      }}
    }}

    async function runConsoleRequestPositionCommand(ctx) {{
      return runConsoleNetworkNodeCommand(ctx, {{
        command: "request-position",
        label: "position",
        example: "request-position !abcd1234",
        allowHopLimit: false,
      }});
    }}

    async function runConsoleTracerouteCommand(ctx) {{
      return runConsoleNetworkNodeCommand(ctx, {{
        command: "traceroute",
        label: "traceroute",
        example: "traceroute !abcd1234",
        allowHopLimit: true,
      }});
    }}

    function parseConsoleLiveLayerCsv(rawValue) {{
      const clean = String(rawValue == null ? "" : rawValue).trim().toLowerCase();
      if (!clean) {{
        return {{ layers: [], error: "" }};
      }}
      const tokens = clean
        .split(/[,\s]+/)
        .map((token) => String(token == null ? "" : token).trim())
        .filter((token) => !!token);
      if (!tokens.length) {{
        return {{ layers: [], error: "" }};
      }}
      const layers = [];
      for (const token of tokens) {{
        const match = token.match(/^l?([123])$/i);
        if (!match) {{
          return {{ layers: [], error: token }};
        }}
        layers.push(Number(match[1]));
      }}
      return {{ layers, error: "" }};
    }}

    function parseConsoleLiveLayerSelection(ctx) {{
      const rawArgs = Array.isArray(ctx && ctx.args) ? ctx.args : [];
      const options = (ctx && ctx.options && typeof ctx.options === "object") ? ctx.options : {{}};
      const state = (ctx && ctx.state && typeof ctx.state === "object") ? ctx.state : latestState;
      const selectedLayers = new Set();
      const includeTerms = [];
      const excludeTerms = [];
      const fieldConditions = [];
      const unresolvedMacros = [];
      const unknownArgs = [];
      const unknownOptions = [];
      let filterRequested = false;
      let pendingExclude = false;
      let ignoreCase = true;

      const liveFilterOptionKeys = new Set(["filter", "grep", "rg", "search", "match", "q", "query"]);
      const liveFilterArgKeys = new Set(["filter", "grep", "rg", "search", "match"]);
      const liveFilterFieldKeys = new Set(["from", "to", "port", "portnum", "text", "channel", "ch", "id", "packet"]);

      const parseBoolLike = (rawValue) => {{
        if (rawValue === true) return true;
        if (rawValue === false) return false;
        const clean = String(rawValue == null ? "" : rawValue).trim().toLowerCase();
        if (!clean || clean === "1" || clean === "true" || clean === "yes" || clean === "on") return true;
        if (clean === "0" || clean === "false" || clean === "no" || clean === "off") return false;
        return null;
      }};

      const addUnknownOption = (key, rawValue) => {{
        const valueText = String(rawValue == null ? "" : rawValue).trim();
        unknownOptions.push(valueText ? `${{key}}=${{valueText}}` : key);
      }};

      const resolveFilterValue = (rawValue) => {{
        const display = String(rawValue == null ? "" : rawValue).trim();
        if (!display) return {{ ok: false, missing: true, display, value: "" }};
        if (isConsoleSelfTargetMacro(display)) {{
          const selfId = resolveConsoleSelfTargetId(state);
          if (!isCanonicalNodeId(selfId)) {{
            return {{
              ok: false,
              missing: false,
              display,
              value: "",
              error: "%self is unavailable: local radio ID is not known yet.",
            }};
          }}
          return {{ ok: true, display, value: selfId, macro: consoleSelfTargetMacro }};
        }}
        return {{ ok: true, display, value: display }};
      }};

      const addIncludeTerm = (rawValue) => {{
        const resolved = resolveFilterValue(rawValue);
        if (resolved.error) unresolvedMacros.push(resolved.error);
        if (!resolved.ok) return false;
        includeTerms.push({{
          value: resolved.value,
          display: resolved.display,
        }});
        return true;
      }};

      const addExcludeTerm = (rawValue) => {{
        const resolved = resolveFilterValue(rawValue);
        if (resolved.error) unresolvedMacros.push(resolved.error);
        if (!resolved.ok) return false;
        excludeTerms.push({{
          value: resolved.value,
          display: resolved.display,
        }});
        return true;
      }};

      const addFieldCondition = (field, op, rawValue) => {{
        const cleanField = String(field == null ? "" : field).trim().toLowerCase();
        const cleanOp = String(op || "=").trim() || "=";
        if (!liveFilterFieldKeys.has(cleanField) || !["=", "!="].includes(cleanOp)) return false;
        const resolved = resolveFilterValue(rawValue);
        if (resolved.error) unresolvedMacros.push(resolved.error);
        if (!resolved.ok) return false;
        fieldConditions.push({{
          field: cleanField,
          op: cleanOp,
          value: resolved.value,
          display: resolved.display,
        }});
        return true;
      }};

      const parseFieldConditionToken = (rawToken) => {{
        const clean = String(rawToken == null ? "" : rawToken).trim();
        const match = clean.match(/^([a-zA-Z_][a-zA-Z0-9_-]*)(!?=)(.+)$/);
        if (!match) return false;
        return addFieldCondition(match[1], match[2], match[3]);
      }};

      const pushFilterArg = (clean) => {{
        if (!clean) return;
        const lowered = clean.toLowerCase();
        if (lowered === "-i" || lowered === "--ignore-case") {{
          ignoreCase = true;
          filterRequested = true;
          return;
        }}
        if (lowered === "-v" || lowered === "--invert-match" || lowered === "--exclude") {{
          pendingExclude = true;
          filterRequested = true;
          return;
        }}
        if (parseFieldConditionToken(clean)) {{
          filterRequested = true;
          pendingExclude = false;
          return;
        }}
        if (clean.startsWith("-")) {{
          unknownArgs.push(clean);
          return;
        }}
        filterRequested = true;
        if (pendingExclude) {{
          addExcludeTerm(clean);
          pendingExclude = false;
          return;
        }}
        addIncludeTerm(clean);
      }};

      for (let i = 0; i < rawArgs.length; i += 1) {{
        const arg = rawArgs[i];
        const clean = String(arg == null ? "" : arg).trim();
        if (!clean) continue;
        const shortMatch = clean.match(/^-l([123])$/i);
        if (shortMatch) {{
          selectedLayers.add(Number(shortMatch[1]));
          continue;
        }}
        const lowered = clean.toLowerCase();
        if (liveFilterArgKeys.has(lowered) && !filterRequested) {{
          filterRequested = true;
          continue;
        }}
        if (!filterRequested && clean.startsWith("-")) {{
          unknownArgs.push(clean);
          continue;
        }}
        pushFilterArg(clean);
      }}

      for (const [rawKey, rawValue] of Object.entries(options)) {{
        const key = String(rawKey == null ? "" : rawKey).trim().toLowerCase();
        if (!key) continue;
        if (key === "layer" || key === "layers") {{
          const parsedLayers = parseConsoleLiveLayerCsv(rawValue);
          if (parsedLayers.error) {{
            addUnknownOption(key, rawValue);
            continue;
          }}
          for (const layer of parsedLayers.layers) {{
            selectedLayers.add(layer);
          }}
          continue;
        }}
        if (key === "l1" || key === "l2" || key === "l3") {{
          const enabled = parseBoolLike(rawValue);
          if (enabled == null) {{
            addUnknownOption(key, rawValue);
            continue;
          }}
          if (enabled) {{
            selectedLayers.add(Number(key.slice(1)));
          }}
          continue;
        }}
        if (key === "i" || key === "ignore-case") {{
          const enabled = parseBoolLike(rawValue);
          if (enabled == null) {{
            addUnknownOption(key, rawValue);
            continue;
          }}
          ignoreCase = enabled !== false;
          filterRequested = true;
          continue;
        }}
        if (key === "exclude" || key === "invert-match") {{
          const valueText = String(rawValue == null ? "" : rawValue).trim();
          const boolValue = parseBoolLike(rawValue);
          filterRequested = true;
          if (boolValue === true && /^(1|true|yes|on)?$/i.test(valueText)) {{
            pendingExclude = true;
            continue;
          }}
          if (valueText) {{
            addExcludeTerm(valueText);
            pendingExclude = false;
            continue;
          }}
          pendingExclude = true;
          continue;
        }}
        const fieldOptionMatch = key.match(/^([a-zA-Z_][a-zA-Z0-9_-]*)(!)?$/);
        if (fieldOptionMatch && liveFilterFieldKeys.has(fieldOptionMatch[1])) {{
          const op = fieldOptionMatch[2] ? "!=" : "=";
          if (addFieldCondition(fieldOptionMatch[1], op, rawValue)) {{
            filterRequested = true;
            pendingExclude = false;
            continue;
          }}
        }}
        if (liveFilterOptionKeys.has(key)) {{
          const boolValue = parseBoolLike(rawValue);
          const valueText = String(rawValue == null ? "" : rawValue).trim();
          if (boolValue === false && /^(0|false|no|off)$/i.test(valueText)) {{
            continue;
          }}
          filterRequested = true;
          if (boolValue === true && /^(1|true|yes|on)?$/i.test(valueText)) {{
            continue;
          }}
          if (valueText) {{
            addIncludeTerm(valueText);
          }}
          continue;
        }}
        addUnknownOption(key, rawValue);
      }}

      const displayParts = [];
      for (const term of includeTerms) {{
        displayParts.push(term.display);
      }}
      for (const term of excludeTerms) {{
        displayParts.push(`-v ${{term.display}}`);
      }}
      for (const condition of fieldConditions) {{
        displayParts.push(`${{condition.field}}${{condition.op}}${{condition.display}}`);
      }}
      const filterText = displayParts
        .join(" ")
        .replace(/\s+/g, " ")
        .trim()
        .slice(0, 220);
      const hasFilter = !!(includeTerms.length || excludeTerms.length || fieldConditions.length);
      const filterSpec = {{
        includeTerms,
        excludeTerms,
        fieldConditions,
        ignoreCase,
        text: filterText,
      }};

      return {{
        layers: selectedLayers.size ? selectedLayers : null,
        filterText,
        filterSpec: hasFilter ? filterSpec : null,
        filterRequested,
        missingFilter: (filterRequested && !hasFilter) || pendingExclude,
        unresolvedMacros: Array.from(new Set(unresolvedMacros)),
        unknownArgs,
        unknownOptions,
      }};
    }}

    function formatConsoleLiveLayerLabel(layers) {{
      if (!(layers instanceof Set) || layers.size < 1) return "";
      const ordered = [1, 2, 3]
        .filter((layer) => layers.has(layer))
        .map((layer) => `l${{layer}}`);
      return ordered.length ? ` layers=${{ordered.join(",")}}` : "";
    }}

    function normalizeConsoleLiveFilterSpec(filterSpecOrText) {{
      if (filterSpecOrText && typeof filterSpecOrText === "object") {{
        const includeTerms = Array.isArray(filterSpecOrText.includeTerms)
          ? filterSpecOrText.includeTerms
              .map((term) => {{
                const source = (term && typeof term === "object") ? term : {{ value: term, display: term }};
                const value = String(source.value == null ? "" : source.value).trim();
                const display = String(source.display == null ? value : source.display).trim() || value;
                return value ? {{ value, display }} : null;
              }})
              .filter((term) => !!term)
          : [];
        const excludeTerms = Array.isArray(filterSpecOrText.excludeTerms)
          ? filterSpecOrText.excludeTerms
              .map((term) => {{
                const source = (term && typeof term === "object") ? term : {{ value: term, display: term }};
                const value = String(source.value == null ? "" : source.value).trim();
                const display = String(source.display == null ? value : source.display).trim() || value;
                return value ? {{ value, display }} : null;
              }})
              .filter((term) => !!term)
          : [];
        const fieldConditions = Array.isArray(filterSpecOrText.fieldConditions)
          ? filterSpecOrText.fieldConditions
              .map((condition) => {{
                const source = (condition && typeof condition === "object") ? condition : {{}};
                const field = String(source.field || "").trim().toLowerCase();
                const op = String(source.op || "=").trim() === "!=" ? "!=" : "=";
                const value = String(source.value == null ? "" : source.value).trim();
                const display = String(source.display == null ? value : source.display).trim() || value;
                return (field && value) ? {{ field, op, value, display }} : null;
              }})
              .filter((condition) => !!condition)
          : [];
        const text = String(filterSpecOrText.text || "").replace(/\s+/g, " ").trim();
        return {{
          includeTerms,
          excludeTerms,
          fieldConditions,
          ignoreCase: filterSpecOrText.ignoreCase !== false,
          text,
        }};
      }}
      const clean = String(filterSpecOrText == null ? "" : filterSpecOrText).replace(/\s+/g, " ").trim();
      return {{
        includeTerms: clean ? [{{ value: clean, display: clean }}] : [],
        excludeTerms: [],
        fieldConditions: [],
        ignoreCase: true,
        text: clean,
      }};
    }}

    function formatConsoleLiveFilterLabel(filterSpecOrText) {{
      const spec = normalizeConsoleLiveFilterSpec(filterSpecOrText);
      const clean = String(spec.text || "").replace(/\s+/g, " ").trim();
      if (!clean) return "";
      const preview = clean.length > 80 ? `${{clean.slice(0, 77)}}...` : clean;
      return ` filter="${{preview.replace(/"/g, "'")}}"`;
    }}

    function consoleLiveLineListContainsTerm(lineList, rawNeedle, ignoreCase = true) {{
      const needleRaw = String(rawNeedle == null ? "" : rawNeedle).trim();
      if (!needleRaw) return false;
      const needle = ignoreCase ? needleRaw.toLowerCase() : needleRaw;
      const lines = Array.isArray(lineList) ? lineList : [lineList];
      return lines.some((line) => {{
        const haystackRaw = String(line == null ? "" : line);
        const haystack = ignoreCase ? haystackRaw.toLowerCase() : haystackRaw;
        return haystack.includes(needle);
      }});
    }}

    function consoleLiveLineListMatchesFilter(lineList, filterSpecOrText) {{
      const spec = normalizeConsoleLiveFilterSpec(filterSpecOrText);
      for (const term of spec.includeTerms) {{
        if (!consoleLiveLineListContainsTerm(lineList, term.value, spec.ignoreCase)) return false;
      }}
      for (const term of spec.excludeTerms) {{
        if (consoleLiveLineListContainsTerm(lineList, term.value, spec.ignoreCase)) return false;
      }}
      return true;
    }}

    function consoleLivePacketFieldValue(entry, rawField) {{
      const field = String(rawField == null ? "" : rawField).trim().toLowerCase();
      const summary = (entry && entry.summary && typeof entry.summary === "object") ? entry.summary : {{}};
      const packet = (entry && entry.packet && typeof entry.packet === "object") ? entry.packet : {{}};
      const decoded = (packet && packet.decoded && typeof packet.decoded === "object") ? packet.decoded : {{}};
      if (field === "from") {{
        return normalizeNodeId(summary.from ?? summary.from_id ?? summary.fromId ?? packet.fromId ?? packet.from_id ?? packet.from ?? "");
      }}
      if (field === "to") {{
        return normalizeNodeId(summary.to ?? summary.to_id ?? summary.toId ?? packet.toId ?? packet.to_id ?? packet.to ?? "");
      }}
      if (field === "port" || field === "portnum") {{
        return String(summary.portnum ?? decoded.portnum ?? packet.portnum ?? "").trim();
      }}
      if (field === "text") {{
        return String(summary.text ?? summary.decoded_text ?? summary.payload_text ?? packet.text ?? "").trim();
      }}
      if (field === "channel" || field === "ch") {{
        return String(packet.channel ?? summary.channel ?? "").trim();
      }}
      if (field === "id" || field === "packet") {{
        return String(packet.id ?? packet.packet_id ?? packet.message_id ?? summary.packet_id ?? "").trim();
      }}
      return "";
    }}

    function consoleLiveEntryMatchesFieldConditions(entry, filterSpecOrText) {{
      const spec = normalizeConsoleLiveFilterSpec(filterSpecOrText);
      for (const condition of spec.fieldConditions) {{
        const fieldValueRaw = consoleLivePacketFieldValue(entry, condition.field);
        const needleRaw = String(condition.value == null ? "" : condition.value).trim();
        const fieldValue = spec.ignoreCase ? fieldValueRaw.toLowerCase() : fieldValueRaw;
        const needle = spec.ignoreCase ? needleRaw.toLowerCase() : needleRaw;
        const matched = fieldValue === needle;
        if (condition.op === "!=" ? matched : !matched) {{
          return false;
        }}
      }}
      return true;
    }}

    function consoleLiveEntryMatchesFilter(entry, lineList, filterSpecOrText) {{
      return consoleLiveEntryMatchesFieldConditions(entry, filterSpecOrText)
        && consoleLiveLineListMatchesFilter(lineList, filterSpecOrText);
    }}

    function consoleLiveFilterSignature(filterSpecOrText) {{
      const spec = normalizeConsoleLiveFilterSpec(filterSpecOrText);
      if (!spec.includeTerms.length && !spec.excludeTerms.length && !spec.fieldConditions.length) return "nofilter";
      const clean = [
        spec.includeTerms.map((term) => `+${{term.value}}`).join("|"),
        spec.excludeTerms.map((term) => `-${{term.value}}`).join("|"),
        spec.fieldConditions.map((condition) => `${{condition.field}}${{condition.op}}${{condition.value}}`).join("|"),
        spec.ignoreCase === false ? "case" : "icase",
      ].join(" ");
      const compact = clean.toLowerCase().replace(/[^a-z0-9]+/g, "_").replace(/^_+|_+$/g, "").slice(0, 48);
      return `filter:${{compact || "text"}}:${{clean.length}}`;
    }}
