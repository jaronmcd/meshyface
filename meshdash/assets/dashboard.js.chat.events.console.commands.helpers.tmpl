    async function executeConsoleCommand(parsed, line) {{
      ensureConsoleCommandsRegistered();
      const commandDef = consoleCommandRegistry.get(parsed.command);
      if (!commandDef) {{
        appendConsoleEventLine(`[console] unknown command: ${{parsed.command}} (try "help")`);
        return;
      }}
      const parseVerbosityArgs = (rawArgs) => {{
        const source = Array.isArray(rawArgs) ? rawArgs : [];
        const cleaned = [];
        let verbosity = 0;
        for (const token of source) {{
          const text = String(token == null ? "" : token).trim();
          const match = text.match(/^-v{1,4}$/i);
          if (match) {{
            const level = Math.max(0, Math.min(4, text.length - 1));
            verbosity = Math.max(verbosity, level);
            continue;
          }}
          cleaned.push(token);
        }}
        return {{ args: cleaned, verbosity }};
      }};
      const parsedArgs = Array.isArray(parsed.args) ? parsed.args : [];
      const supportsVerbosity = !!commandDef.supportsVerbosity;
      let commandArgs = parsedArgs;
      let commandVerbosity = 0;
      if (supportsVerbosity) {{
        const parsedVerbosity = parseVerbosityArgs(parsedArgs);
        commandArgs = parsedVerbosity.args;
        commandVerbosity = parsedVerbosity.verbosity;
      }} else {{
        const hasVerbosityToken = parsedArgs.some((token) => /^-v{1,4}$/i.test(String(token == null ? "" : token).trim()));
        if (hasVerbosityToken) {{
          appendConsoleEventLine(`[${{parsed.command}}] -v is only supported for utility commands.`);
          return;
        }}
      }}
      try {{
        const result = await commandDef.run({{
          line,
          command: parsed.command,
          args: commandArgs,
          verbosity: commandVerbosity,
          options: parsed.options,
          comparisons: parsed.comparisons,
          state: latestState,
          wildcardMatches,
          append: (msg) => appendConsoleEventLine(msg),
        }});
        if (Array.isArray(result)) {{
          for (const lineOut of result) {{
            const text = String(lineOut == null ? "" : lineOut).trimEnd();
            if (text) appendConsoleEventLine(text);
          }}
          return;
        }}
        if (result && typeof result === "object") {{
          if (typeof result.message === "string" && result.message.trim()) {{
            appendConsoleEventLine(result.message.trim());
            return;
          }}
          try {{
            appendConsoleEventLine(JSON.stringify(result));
            return;
          }} catch (_err) {{
            return;
          }}
        }}
        const text = String(result == null ? "" : result).trim();
        if (text) {{
          appendConsoleEventLine(text);
        }}
      }} catch (err) {{
        const msg = err instanceof Error ? err.message : String(err || "unknown error");
        appendConsoleEventLine(`[${{parsed.command}}] error: ${{msg}}`);
      }}
    }}

    function registerConsoleCommand(commandDef) {{
      if (!commandDef || typeof commandDef !== "object") return;
      const name = String(commandDef.name || "").trim().toLowerCase();
      if (!name) return;
      const run = typeof commandDef.run === "function"
        ? commandDef.run
        : () => `[${{name}}] not implemented`;
      consoleCommandRegistry.set(name, {{
        name,
        usage: String(commandDef.usage || name).trim() || name,
        description: String(commandDef.description || "").trim(),
        supportsVerbosity: !!commandDef.supportsVerbosity,
        run,
      }});
    }}

    function formatConsoleListTime(unixSeconds) {{
      const ts = Number(unixSeconds);
      if (!Number.isFinite(ts) || ts <= 0) return "n/a";
      try {{
        return new Date(Math.floor(ts) * 1000).toISOString().replace("T", " ").replace(".000Z", "Z");
      }} catch (_err) {{
        return "n/a";
      }}
    }}

    function safeConsoleDownloadName(rawName) {{
      const fallback = "console.txt";
      const clean = String(rawName == null ? "" : rawName)
        .trim()
        .replace(/[\\/:*?"<>|]+/g, "-")
        .replace(/\s+/g, " ")
        .replace(/^\.+/, "")
        .replace(/[. ]+$/g, "")
        .slice(0, 96);
      const base = clean || fallback;
      return /\.txt$/i.test(base) ? base : `${{base}}.txt`;
    }}

    function resolveVisibleConsoleSnapshotLines() {{
      const filteredPayload = resolveFilteredConsoleLines(
        resolveConsoleFilterExpression(consoleFilterText)
      );
      const filtered = (filteredPayload && filteredPayload.result && typeof filteredPayload.result === "object")
        ? filteredPayload.result
        : null;
      const lines = Array.isArray(filtered && filtered.lines) ? filtered.lines.slice() : [];
      if (filtered && filtered.active && lines.length < 1) {{
        lines.push(`[filter] no matches for "${{String(filtered.needle || "")}}"`);
      }}
      return lines;
    }}

    function downloadVisibleConsoleSnapshot(rawName = "") {{
      const filename = safeConsoleDownloadName(rawName);
      const visibleLines = resolveVisibleConsoleSnapshotLines();
      const payload = visibleLines.length ? `${{visibleLines.join("\n")}}\n` : "";
      let url = "";
      try {{
        const blob = new Blob([payload], {{ type: "text/plain;charset=utf-8" }});
        url = URL.createObjectURL(blob);
      }} catch (_err) {{
        url = "";
      }}
      if (!url) {{
        return {{
          ok: false,
          filename,
          lineCount: visibleLines.length,
          error: "could not prepare text download",
        }};
      }}
      try {{
        const anchor = document.createElement("a");
        anchor.href = url;
        anchor.download = filename;
        anchor.rel = "noopener";
        anchor.style.display = "none";
        document.body.appendChild(anchor);
        anchor.click();
        anchor.remove();
      }} catch (err) {{
        try {{
          URL.revokeObjectURL(url);
        }} catch (_revokeErr) {{
        }}
        return {{
          ok: false,
          filename,
          lineCount: visibleLines.length,
          error: err instanceof Error ? err.message : "download failed",
        }};
      }}
      window.setTimeout(() => {{
        try {{
          URL.revokeObjectURL(url);
        }} catch (_err) {{
        }}
      }}, 20000);
      return {{
        ok: true,
        filename,
        lineCount: visibleLines.length,
      }};
    }}

    function collectConsoleNodePortMap(state = latestState) {{
      const safeState = (state && typeof state === "object") ? state : {{}};
      const traffic = (safeState.traffic && typeof safeState.traffic === "object") ? safeState.traffic : {{}};
      const packets = Array.isArray(traffic.recent_packets) ? traffic.recent_packets : [];
      const byNodeId = new Map();
      const addPort = (nodeId, portValue) => {{
        const cleanId = normalizeNodeId(nodeId || "");
        const cleanPort = String(portValue == null ? "" : portValue).trim();
        if (!cleanId || !cleanPort || cleanId === "^all") return;
        let bucket = byNodeId.get(cleanId);
        if (!(bucket instanceof Set)) {{
          bucket = new Set();
          byNodeId.set(cleanId, bucket);
        }}
        bucket.add(cleanPort);
      }};
      for (const entry of packets) {{
        const summary = (entry && typeof entry.summary === "object") ? entry.summary : {{}};
        const packet = (entry && typeof entry.packet === "object") ? entry.packet : {{}};
        const port = summary.portnum ?? packet.portnum ?? "";
        if (!String(port == null ? "" : port).trim()) continue;
        addPort(summary.from ?? packet.from ?? "", port);
        addPort(summary.to ?? packet.to ?? "", port);
      }}
      return byNodeId;
    }}

    function formatConsolePortSummary(ports, maxPorts = 3) {{
      const list = Array.isArray(ports) ? ports.filter((port) => !!String(port || "").trim()) : [];
      if (!list.length) return "n/a";
      const cap = Math.max(1, Math.floor(Number(maxPorts) || 3));
      const head = list.slice(0, cap).join(",");
      if (list.length <= cap) return head;
      return `${{head}} +${{list.length - cap}}`;
    }}

    function collectConsoleNodeRows(state = latestState) {{
      const safeState = (state && typeof state === "object") ? state : {{}};
      const nodes = Array.isArray(safeState.nodes) ? safeState.nodes : [];
      const portsByNodeId = collectConsoleNodePortMap(safeState);
      const nowUnix = Math.floor(Date.now() / 1000);
      const rows = [];
      for (const node of nodes) {{
        if (!node || typeof node !== "object") continue;
        const nodeId = normalizeNodeId(node.id || node.node_id || node.nodeId || "");
        if (!nodeId) continue;
        const nodeName = preferredNodeName(node) || String(nodeLabel(node) || "Unknown");
        const lastSeenUnix = nodeLastHeardUnix(node);
        const status = freshnessStatus(lastSeenUnix, nowUnix);
        const hopsNum = Number(node.hops_away);
        const ports = Array.from(portsByNodeId.get(nodeId) || [])
          .map((port) => String(port == null ? "" : port).trim())
          .filter((port) => !!port)
          .sort((a, b) => a.localeCompare(b));
        const lat = Number(node.lat);
        const lon = Number(node.lon);
        const hasGps = isValidMapCoord(lat, lon);
        rows.push({{
          id: nodeId,
          name: nodeName,
          status,
          hops: Number.isFinite(hopsNum) ? Math.trunc(hopsNum) : null,
          lastSeenUnix: Number.isFinite(lastSeenUnix) ? Math.trunc(lastSeenUnix) : null,
          ports,
          hasGps,
          raw: node,
        }});
      }}
      rows.sort((a, b) => {{
        const statusCmp = statusRank(a.status) - statusRank(b.status);
        if (statusCmp !== 0) return statusCmp;
        const aLast = Number(a.lastSeenUnix || 0);
        const bLast = Number(b.lastSeenUnix || 0);
        if (aLast !== bLast) return bLast - aLast;
        return String(a.name || "").localeCompare(String(b.name || ""));
      }});
      return rows;
    }}

    function normalizeConsoleNodeListLabel(value = "list") {{
      const clean = String(value == null ? "" : value).trim().toLowerCase();
      if (!clean) return "list";
      return clean.replace(/^-+/, "") || "list";
    }}

    function runConsoleNodeListCommand(ctx, label = "") {{
      const options = (ctx && ctx.options && typeof ctx.options === "object")
        ? ctx.options
        : {{}};
      const verbosity = Math.max(0, Math.min(4, Number(ctx && ctx.verbosity) || 0));
      const comparisons = Array.isArray(ctx && ctx.comparisons) ? ctx.comparisons : [];
      const rawArgs = Array.isArray(ctx && ctx.args) ? ctx.args : [];
      const outputLabel = normalizeConsoleNodeListLabel(label || (ctx && ctx.command) || "list");
      const idPattern = normalizeWildcardPattern(options.id || "");
      const namePattern = normalizeWildcardPattern(options.name || "");
      const statusPattern = normalizeWildcardPattern(options.status || "");
      const portPattern = normalizeWildcardPattern(options.port ?? options.p ?? "");
      const parseBoolFilter = (rawValue) => {{
        if (typeof rawValue === "boolean") return rawValue;
        const clean = String(rawValue == null ? "" : rawValue).trim().toLowerCase();
        if (!clean) return null;
        if (["1", "true", "yes", "y", "on", "gps", "with"].includes(clean)) return true;
        if (["0", "false", "no", "n", "off", "none", "without", "nogps", "no-gps"].includes(clean)) return false;
        return null;
      }};
      let gpsFilter = null;
      if (Object.prototype.hasOwnProperty.call(options, "gps")) {{
        gpsFilter = parseBoolFilter(options.gps);
        if (gpsFilter == null) {{
          return `[${{outputLabel}}] invalid gps value: ${{String(options.gps)}}`;
        }}
      }}
      const args = [];
      for (const arg of rawArgs) {{
        const clean = String(arg || "").trim().toLowerCase();
        if (!Object.prototype.hasOwnProperty.call(options, "gps")) {{
          if (clean === "gps") {{
            gpsFilter = true;
            continue;
          }}
          if (clean === "nogps" || clean === "no-gps") {{
            gpsFilter = false;
            continue;
          }}
        }}
        args.push(arg);
      }}
      const freePattern = normalizeWildcardPattern(args[0] || "");
      const hopsComparators = [];
      const pushHopsComparator = (op, rawValue) => {{
        const numeric = Number(rawValue);
        if (!Number.isFinite(numeric)) {{
          return false;
        }}
        hopsComparators.push({{ op: String(op || "="), value: numeric }});
        return true;
      }};
      if (Object.prototype.hasOwnProperty.call(options, "hops")) {{
        if (!pushHopsComparator("=", options.hops)) {{
          return `[${{outputLabel}}] invalid hops value: ${{String(options.hops)}}`;
        }}
      }}
      for (const cmp of comparisons) {{
        if (!cmp || typeof cmp !== "object") continue;
        const cmpKey = String(cmp.key || "").trim().toLowerCase();
        if (cmpKey !== "hops" && cmpKey !== "hop") continue;
        const cmpOp = String(cmp.op || "").trim();
        if (!["<", ">", "<=", ">="].includes(cmpOp)) continue;
        if (!pushHopsComparator(cmpOp, cmp.value)) {{
          return `[${{outputLabel}}] invalid hops comparator: ${{cmpKey}}${{cmpOp}}${{String(cmp.value || "")}}`;
        }}
      }}
      const limitRaw = Number(options.limit ?? options.n ?? 50);
      const limit = Math.min(500, Math.max(1, Math.floor(Number.isFinite(limitRaw) ? limitRaw : 50)));
      const rows = collectConsoleNodeRows(ctx && ctx.state);
      const filtered = rows.filter((row) => {{
        if (freePattern) {{
          const freeHit = wildcardMatches(freePattern, row.id) || wildcardMatches(freePattern, row.name);
          if (!freeHit) return false;
        }}
        if (idPattern && !wildcardMatches(idPattern, row.id)) return false;
        if (namePattern && !wildcardMatches(namePattern, row.name)) return false;
        if (statusPattern && !wildcardMatches(statusPattern, row.status)) return false;
        if (portPattern) {{
          const hasPortMatch = Array.isArray(row.ports)
            && row.ports.some((portValue) => wildcardMatches(portPattern, portValue));
          if (!hasPortMatch) return false;
        }}
        if (gpsFilter != null && Boolean(row.hasGps) !== gpsFilter) return false;
        if (hopsComparators.length) {{
          const hopsValue = Number(row.hops);
          if (!Number.isFinite(hopsValue)) return false;
          for (const cmp of hopsComparators) {{
            const target = Number(cmp.value);
            if (cmp.op === ">" && !(hopsValue > target)) return false;
            if (cmp.op === "<" && !(hopsValue < target)) return false;
            if (cmp.op === ">=" && !(hopsValue >= target)) return false;
            if (cmp.op === "<=" && !(hopsValue <= target)) return false;
            if (cmp.op === "=" && !(hopsValue === target)) return false;
          }}
        }}
        return true;
      }});
      const show = filtered.slice(0, limit);
      const lines = [
        `[${{outputLabel}}] matched ${{filtered.length}} node(s); showing ${{show.length}}.`,
      ];
      for (const row of show) {{
        const hopsLabel = row.hops == null ? "n/a" : String(row.hops);
        const portsLabel = formatConsolePortSummary(row.ports, 3);
        const gpsLabel = row.hasGps ? "yes" : "no";
        const lat = Number(row && row.raw && row.raw.lat);
        const lon = Number(row && row.raw && row.raw.lon);
        const posLabel = row.hasGps
          ? `${{lat.toFixed(5)}},${{lon.toFixed(5)}}`
          : "n/a";
        lines.push(
          `${{row.id}} | ${{row.name}} | status=${{row.status}} | gps=${{gpsLabel}} | hops=${{hopsLabel}} | ports=${{portsLabel}} | last=${{formatConsoleListTime(row.lastSeenUnix)}}${{verbosity > 0 ? ` | pos=${{posLabel}}` : ""}}`
        );
        if (verbosity >= 2) {{
          const altitude = Number(row && row.raw && row.raw.altitude);
          const battery = Number(row && row.raw && row.raw.battery_level);
          const detail = [];
          if (Number.isFinite(altitude)) detail.push(`alt=${{Math.trunc(altitude)}}m`);
          if (Number.isFinite(battery)) detail.push(`batt=${{Math.round(battery)}}%`);
          if (detail.length) {{
            lines.push(`  details: ${{detail.join(" | ")}}`);
          }}
        }}
      }}
      if (!show.length) {{
        lines.push(`[${{outputLabel}}] no matches. Try ${{outputLabel}} * or ${{outputLabel}} name=*pattern*`);
      }} else if (filtered.length > show.length) {{
        lines.push(`[${{outputLabel}}] truncated. Use limit=<n> up to 500.`);
      }}
      return lines;
    }}

    function consoleNodeRowNum(row) {{
      const safeRow = (row && typeof row === "object") ? row : {{}};
      const raw = (safeRow.raw && typeof safeRow.raw === "object") ? safeRow.raw : {{}};
      for (const value of [safeRow.num, raw.num, raw.node_num, raw.nodeNum]) {{
        const parsed = parseNodeNum(value);
        if (Number.isInteger(parsed) && parsed >= 0) {{
          return parsed;
        }}
      }}
      return null;
    }}

    function resolveConsoleNodeTarget(rawTarget, state = latestState) {{
      const target = String(rawTarget == null ? "" : rawTarget).trim();
      const rows = collectConsoleNodeRows(state);
      if (!target) {{
        return {{
          target,
          rows,
          matches: [],
          mode: "missing",
        }};
      }}

      const normalizedId = normalizeNodeId(target);
      if (isCanonicalNodeId(normalizedId)) {{
        const exactIdMatches = rows.filter((row) => normalizeNodeId(row && row.id) === normalizedId);
        if (exactIdMatches.length) {{
          return {{
            target,
            rows,
            matches: exactIdMatches,
            mode: "exact-id",
          }};
        }}
      }}

      const targetNum = parseNodeNum(target);
      if (Number.isInteger(targetNum) && targetNum >= 0) {{
        const exactNumMatches = rows.filter((row) => consoleNodeRowNum(row) === targetNum);
        if (exactNumMatches.length) {{
          return {{
            target,
            rows,
            matches: exactNumMatches,
            mode: "exact-num",
          }};
        }}
      }}

      const exactName = target.toLowerCase();
      const exactNameMatches = rows.filter((row) => (
        collectConsoleNodeLookupNameVariants(row)
          .some((value) => String(value == null ? "" : value).trim().toLowerCase() === exactName)
      ));
      if (exactNameMatches.length) {{
        return {{
          target,
          rows,
          matches: exactNameMatches,
          mode: "exact-name",
        }};
      }}

      const pattern = normalizeWildcardPattern(target);
      const partialIdMatches = rows.filter((row) => wildcardMatches(pattern, row && row.id ? row.id : ""));
      if (partialIdMatches.length === 1) {{
        return {{
          target,
          rows,
          matches: partialIdMatches,
          mode: "partial-id",
        }};
      }}

      const partialNameMatches = rows.filter((row) => (
        collectConsoleNodeLookupNameVariants(row)
          .some((value) => wildcardMatches(pattern, value))
      ));
      if (partialNameMatches.length === 1) {{
        return {{
          target,
          rows,
          matches: partialNameMatches,
          mode: "partial-name",
        }};
      }}

      const deduped = [];
      const seen = new Set();
      const pushRows = (entries) => {{
        for (const row of entries) {{
          const key = normalizeNodeId(row && row.id);
          if (!key || seen.has(key)) continue;
          seen.add(key);
          deduped.push(row);
        }}
      }};
      pushRows(partialIdMatches);
      pushRows(partialNameMatches);
      return {{
        target,
        rows,
        matches: deduped,
        mode: deduped.length ? "ambiguous" : "none",
      }};
    }}

    function collectConsoleNodeLookupNameVariants(row) {{
      const safeRow = (row && typeof row === "object") ? row : {{}};
      const raw = (safeRow.raw && typeof safeRow.raw === "object") ? safeRow.raw : {{}};
      const seen = new Set();
      const values = [];
      const push = (value) => {{
        const clean = String(value == null ? "" : value).trim();
        if (!clean) return;
        const key = clean.toLowerCase();
        if (seen.has(key)) return;
        seen.add(key);
        values.push(clean);
      }};
      push(safeRow.name);
      push(raw.long_name);
      push(raw.short_name);
      return values;
    }}

    function resolveConsoleNodeLookupMatches(rawTarget, state = latestState) {{
      const target = String(rawTarget == null ? "" : rawTarget).trim();
      const rows = collectConsoleNodeRows(state);
      if (!target) {{
        return {{
          target,
          rows,
          matches: [],
          mode: "missing",
        }};
      }}
      const targetId = normalizeNodeId(target).toLowerCase();
      const targetName = target.toLowerCase();
      const exactIdMatches = rows.filter((row) => (
        String(normalizeNodeId(row && row.id ? row.id : "")).toLowerCase() === targetId
      ));
      if (exactIdMatches.length) {{
        return {{
          target,
          rows,
          matches: exactIdMatches,
          mode: "exact-id",
        }};
      }}
      const exactNameMatches = rows.filter((row) => (
        collectConsoleNodeLookupNameVariants(row)
          .some((value) => String(value == null ? "" : value).trim().toLowerCase() === targetName)
      ));
      if (exactNameMatches.length) {{
        return {{
          target,
          rows,
          matches: exactNameMatches,
          mode: "exact-name",
        }};
      }}
      const pattern = normalizeWildcardPattern(target);
      const fuzzyMatches = rows.filter((row) => {{
        if (wildcardMatches(pattern, row && row.id ? row.id : "")) return true;
        return collectConsoleNodeLookupNameVariants(row)
          .some((value) => wildcardMatches(pattern, value));
      }});
      return {{
        target,
        rows,
        matches: fuzzyMatches,
        mode: "fuzzy",
      }};
    }}

    function formatConsoleNodeLookupListLine(row) {{
      const safeRow = (row && typeof row === "object") ? row : {{}};
      const id = String(safeRow.id || "n/a").trim() || "n/a";
      const name = String(safeRow.name || "Unknown").trim() || "Unknown";
      const status = String(safeRow.status || "unknown").trim() || "unknown";
      const lastSeen = formatConsoleListTime(safeRow.lastSeenUnix);
      const hops = safeRow.hops == null ? "n/a" : String(safeRow.hops);
      return `${{id}} | ${{name}} | status=${{status}} | last=${{lastSeen}} | hops=${{hops}}`;
    }}

    function formatConsoleNodeLookupDetails(row, verbosity = 0) {{
      const safeRow = (row && typeof row === "object") ? row : {{}};
      const raw = (safeRow.raw && typeof safeRow.raw === "object") ? safeRow.raw : {{}};
      const lines = [];
      const id = String(safeRow.id || "n/a").trim() || "n/a";
      const name = String(safeRow.name || "Unknown").trim() || "Unknown";
      const status = String(safeRow.status || "unknown").trim() || "unknown";
      const hops = safeRow.hops == null ? "n/a" : String(safeRow.hops);
      const lastSeen = formatConsoleListTime(safeRow.lastSeenUnix);
      const lat = Number(raw.lat);
      const lon = Number(raw.lon);
      const hasGps = Boolean(safeRow.hasGps) && isValidMapCoord(lat, lon);
      const coordDigits = verbosity > 0 ? 7 : 5;
      const altitude = Number(raw.altitude ?? raw.alt ?? raw.altitude_m ?? raw.altitudeM);
      const battery = Number(raw.battery_level ?? raw.batteryLevel);
      const voltage = Number(raw.voltage);
      const channelUtil = Number(raw.channel_utilization ?? raw.channelUtilization);
      const airUtilTx = Number(raw.air_util_tx ?? raw.airUtilTx);

      lines.push(`${{id}} | ${{name}}`);
      lines.push(`  status=${{status}} | last=${{lastSeen}} | hops=${{hops}}`);

      const gpsParts = [`gps=${{hasGps ? "yes" : "no"}}`];
      if (hasGps) {{
        gpsParts.push(`pos=${{lat.toFixed(coordDigits)}},${{lon.toFixed(coordDigits)}}`);
      }}
      if (Number.isFinite(altitude)) {{
        gpsParts.push(`altitude=${{Math.trunc(altitude)}}m`);
      }}
      lines.push(`  ${{gpsParts.join(" | ")}}`);

      const powerParts = [];
      if (Number.isFinite(battery)) {{
        powerParts.push(`battery=${{Math.round(battery)}}%`);
      }}
      if (Number.isFinite(voltage)) {{
        powerParts.push(`voltage=${{voltage.toFixed(verbosity > 0 ? 3 : 2)}}V`);
      }}
      if (Number.isFinite(channelUtil)) {{
        powerParts.push(`channel_util=${{channelUtil.toFixed(verbosity > 0 ? 2 : 1)}}%`);
      }}
      if (Number.isFinite(airUtilTx)) {{
        powerParts.push(`air_util_tx=${{airUtilTx.toFixed(verbosity > 0 ? 2 : 1)}}%`);
      }}
      if (powerParts.length) {{
        lines.push(`  ${{powerParts.join(" | ")}}`);
      }}

      lines.push(`  ports=${{formatConsolePortSummary(safeRow.ports, verbosity > 0 ? 12 : 8)}}`);

      if (verbosity >= 2) {{
        const detailParts = [];
        const displayName = name.toLowerCase();
        const shortName = String(raw.short_name || "").trim();
        const longName = String(raw.long_name || "").trim();
        const lastSeenUnix = Number(safeRow.lastSeenUnix);
        if (shortName && shortName.toLowerCase() !== displayName) {{
          detailParts.push(`short=${{shortName}}`);
        }}
        if (longName && longName.toLowerCase() !== displayName) {{
          detailParts.push(`long=${{longName}}`);
        }}
        if (Number.isFinite(lastSeenUnix) && lastSeenUnix > 0) {{
          detailParts.push(`last_heard_unix=${{Math.trunc(lastSeenUnix)}}`);
        }}
        if (hasGps) {{
          detailParts.push(`lat=${{lat.toFixed(7)}}`);
          detailParts.push(`lon=${{lon.toFixed(7)}}`);
        }}
        if (detailParts.length) {{
          lines.push(`  details: ${{detailParts.join(" | ")}}`);
        }}
      }}

      return lines;
    }}

    async function runConsoleTracerouteCommand(ctx) {{
      const options = (ctx && ctx.options && typeof ctx.options === "object")
        ? ctx.options
        : {{}};
      const args = Array.isArray(ctx && ctx.args) ? ctx.args : [];
      const parseIntOption = (rawValue, label, minValue) => {{
        if (rawValue == null) return {{ ok: true, value: null }};
        const clean = String(rawValue).trim();
        if (!clean) return {{ ok: true, value: null }};
        const numeric = Number(clean);
        if (!Number.isFinite(numeric) || !Number.isInteger(numeric)) {{
          return {{ ok: false, error: `[traceroute] invalid ${{label}}: ${{clean}}` }};
        }}
        if (numeric < minValue) {{
          return {{ ok: false, error: `[traceroute] ${{label}} must be >= ${{minValue}}` }};
        }}
        return {{ ok: true, value: Math.trunc(numeric) }};
      }};

      const channelIndexParsed = parseIntOption(
        options["ch-index"] ?? options.ch_index ?? options["channel-index"] ?? options.channel_index,
        "ch-index",
        0,
      );
      if (!channelIndexParsed.ok) return channelIndexParsed.error;
      const hopLimitParsed = parseIntOption(options["hop-limit"] ?? options.hop_limit, "hop-limit", 1);
      if (!hopLimitParsed.ok) return hopLimitParsed.error;
      const timeoutParsed = parseIntOption(options.timeout ?? options.timeout_ms, "timeout", 1);
      if (!timeoutParsed.ok) return timeoutParsed.error;

      const explicitDest = String(options.dest ?? options.destination ?? "").trim();
      const rawTarget = String(explicitDest || args.join(" ")).trim();
      if (!rawTarget) {{
        return "[traceroute] missing target. Example: traceroute !abcd1234";
      }}

      let destination = "";
      const normalizedDirectId = normalizeNodeId(rawTarget);
      if (isCanonicalNodeId(normalizedDirectId)) {{
        destination = normalizedDirectId;
      }} else {{
        const lookup = resolveConsoleNodeTarget(rawTarget, ctx && ctx.state);
        const matches = Array.isArray(lookup && lookup.matches) ? lookup.matches : [];
        if (matches.length < 1) {{
          const quotedTarget = /[\s"]/.test(rawTarget) ? JSON.stringify(rawTarget) : rawTarget;
          return [
            `[traceroute] unknown target: ${{rawTarget}}`,
            `[traceroute] try: list ${{quotedTarget}}`,
          ];
        }}
        if (matches.length > 1) {{
          const show = matches.slice(0, 10);
          const lines = [`[traceroute] ambiguous target "${{rawTarget}}". Matches:`];
          for (const row of show) {{
            lines.push(`  ${{formatConsoleNodeLookupListLine(row)}}`);
          }}
          if (matches.length > show.length) {{
            lines.push(`  ... ${{matches.length - show.length}} more match(es).`);
          }}
          lines.push("[traceroute] retry with a more specific id, name, or node number.");
          return lines;
        }}
        destination = String(matches[0] && matches[0].id ? matches[0].id : "").trim();
      }}

      if (!isCanonicalNodeId(destination)) {{
        return `[traceroute] invalid destination: ${{destination || rawTarget}}`;
      }}

      const body = {{
        command: "traceroute",
        destination,
      }};
      if (channelIndexParsed.value != null) {{
        body.channel_index = channelIndexParsed.value;
      }}
      if (hopLimitParsed.value != null) {{
        body.hop_limit = hopLimitParsed.value;
      }}
      if (timeoutParsed.value != null) {{
        body.timeout_ms = timeoutParsed.value;
      }}

      try {{
        const payload = await postNetworkToolCommand(body);
        const lines = Array.isArray(payload && payload.console_lines)
          ? payload.console_lines
              .map((line) => String(line == null ? "" : line).trimEnd())
              .filter((line) => !!line)
          : [];
        return lines.length ? lines : [`[traceroute] ${{destination}} | request completed`];
      }} catch (err) {{
        const payload = (err && typeof err === "object") ? err.payload : null;
        const lines = Array.isArray(payload && payload.console_lines)
          ? payload.console_lines
              .map((line) => String(line == null ? "" : line).trimEnd())
              .filter((line) => !!line)
          : [];
        if (lines.length) {{
          return lines;
        }}
        throw err;
      }}
    }}

    function parseConsoleLiveLayerCsv(rawValue) {{
      const clean = String(rawValue == null ? "" : rawValue).trim().toLowerCase();
      if (!clean) {{
        return {{ layers: [], error: "" }};
      }}
      const tokens = clean
        .split(/[,\s]+/)
        .map((token) => String(token == null ? "" : token).trim())
        .filter((token) => !!token);
      if (!tokens.length) {{
        return {{ layers: [], error: "" }};
      }}
      const layers = [];
      for (const token of tokens) {{
        const match = token.match(/^l?([123])$/i);
        if (!match) {{
          return {{ layers: [], error: token }};
        }}
        layers.push(Number(match[1]));
      }}
      return {{ layers, error: "" }};
    }}

    function parseConsoleLiveLayerSelection(ctx) {{
      const rawArgs = Array.isArray(ctx && ctx.args) ? ctx.args : [];
      const options = (ctx && ctx.options && typeof ctx.options === "object") ? ctx.options : {{}};
      const selectedLayers = new Set();
      const unknownArgs = [];
      const unknownOptions = [];

      for (const arg of rawArgs) {{
        const clean = String(arg == null ? "" : arg).trim();
        if (!clean) continue;
        const shortMatch = clean.match(/^-l([123])$/i);
        if (shortMatch) {{
          selectedLayers.add(Number(shortMatch[1]));
          continue;
        }}
        unknownArgs.push(clean);
      }}

      const parseBoolLike = (rawValue) => {{
        if (rawValue === true) return true;
        if (rawValue === false) return false;
        const clean = String(rawValue == null ? "" : rawValue).trim().toLowerCase();
        if (!clean || clean === "1" || clean === "true" || clean === "yes" || clean === "on") return true;
        if (clean === "0" || clean === "false" || clean === "no" || clean === "off") return false;
        return null;
      }};

      const addUnknownOption = (key, rawValue) => {{
        const valueText = String(rawValue == null ? "" : rawValue).trim();
        unknownOptions.push(valueText ? `${{key}}=${{valueText}}` : key);
      }};

      for (const [rawKey, rawValue] of Object.entries(options)) {{
        const key = String(rawKey == null ? "" : rawKey).trim().toLowerCase();
        if (!key) continue;
        if (key === "layer" || key === "layers") {{
          const parsedLayers = parseConsoleLiveLayerCsv(rawValue);
          if (parsedLayers.error) {{
            addUnknownOption(key, rawValue);
            continue;
          }}
          for (const layer of parsedLayers.layers) {{
            selectedLayers.add(layer);
          }}
          continue;
        }}
        if (key === "l1" || key === "l2" || key === "l3") {{
          const enabled = parseBoolLike(rawValue);
          if (enabled == null) {{
            addUnknownOption(key, rawValue);
            continue;
          }}
          if (enabled) {{
            selectedLayers.add(Number(key.slice(1)));
          }}
          continue;
        }}
        addUnknownOption(key, rawValue);
      }}

      return {{
        layers: selectedLayers.size ? selectedLayers : null,
        unknownArgs,
        unknownOptions,
      }};
    }}

    function formatConsoleLiveLayerLabel(layers) {{
      if (!(layers instanceof Set) || layers.size < 1) return "";
      const ordered = [1, 2, 3]
        .filter((layer) => layers.has(layer))
        .map((layer) => `l${{layer}}`);
      return ordered.length ? ` layers=${{ordered.join(",")}}` : "";
    }}
