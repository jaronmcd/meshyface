    function meshGuiBenchmarkDispatchInput(el) {{
      if (!(el instanceof HTMLElement)) return;
      try {{
        el.dispatchEvent(new Event("input", {{ bubbles: true, cancelable: true }}));
      }} catch (_err) {{
      }}
      try {{
        el.dispatchEvent(new Event("change", {{ bubbles: true, cancelable: true }}));
      }} catch (_err) {{
      }}
    }}

    function meshGuiBenchmarkDispatchTextKeyEvent(el, type, ch) {{
      if (!(el instanceof HTMLElement)) return false;
      try {{
        const event = new KeyboardEvent(type, {{
          bubbles: true,
          cancelable: true,
          key: ch,
          code: ch === " " ? "Space" : `Key${{String(ch || "").toUpperCase()}}`,
        }});
        return el.dispatchEvent(event);
      }} catch (_err) {{
        return true;
      }}
    }}

    function meshGuiBenchmarkDispatchBeforeInput(el, ch) {{
      if (!(el instanceof HTMLElement)) return false;
      try {{
        const event = typeof InputEvent === "function"
          ? new InputEvent("beforeinput", {{
              bubbles: true,
              cancelable: true,
              inputType: "insertText",
              data: ch,
            }})
          : new Event("beforeinput", {{ bubbles: true, cancelable: true }});
        return el.dispatchEvent(event);
      }} catch (_err) {{
        return true;
      }}
    }}

    async function meshGuiBenchmarkTypeChatInput() {{
      const input = document.getElementById("chat-input");
      if (!(input instanceof HTMLTextAreaElement) && !(input instanceof HTMLInputElement)) {{
        return {{ skipped: true, reason: "chat input missing" }};
      }}
      const previousValue = String(input.value || "");
      const text = `benchmark responsiveness ${{Date.now()}}`;
      input.focus();
      input.value = "";
      meshGuiBenchmarkDispatchInput(input);
      const startedAtMs = meshGuiBenchmarkNowMs();
      let maxCharSyncMs = 0;
      let eventsDispatched = 0;
      for (const ch of text) {{
        const charStartedAtMs = meshGuiBenchmarkNowMs();
        if (meshGuiBenchmarkDispatchTextKeyEvent(input, "keydown", ch) !== false) eventsDispatched += 1;
        if (meshGuiBenchmarkDispatchBeforeInput(input, ch) !== false) eventsDispatched += 1;
        input.value += ch;
        meshGuiBenchmarkDispatchInput(input);
        eventsDispatched += 2;
        if (meshGuiBenchmarkDispatchTextKeyEvent(input, "keyup", ch) !== false) eventsDispatched += 1;
        maxCharSyncMs = Math.max(maxCharSyncMs, meshGuiBenchmarkNowMs() - charStartedAtMs);
      }}
      const actionSyncMs = meshGuiBenchmarkNowMs() - startedAtMs;
      await meshGuiBenchmarkNextFrame();
      const typedLength = input.value.length;
      input.value = previousValue;
      meshGuiBenchmarkDispatchInput(input);
      return {{
        skipped: false,
        typedLength,
        actionSyncMs: meshGuiBenchmarkRoundMs(actionSyncMs),
        inputLoopMs: meshGuiBenchmarkRoundMs(actionSyncMs),
        maxCharSyncMs: meshGuiBenchmarkRoundMs(maxCharSyncMs),
        eventsDispatched,
        restoredLength: previousValue.length,
      }};
    }}

    async function meshGuiBenchmarkScrollChatFeed() {{
      const scroller = (typeof getChatScroller === "function")
        ? getChatScroller()
        : null;
      const feed = document.getElementById("chat-feed");
      if (!(scroller instanceof HTMLElement)) {{
        return {{ skipped: true, reason: "chat scroller missing", feedPresent: feed instanceof HTMLElement }};
      }}
      const previousTop = Number(scroller.scrollTop) || 0;
      const maxTop = Math.max(0, scroller.scrollHeight - scroller.clientHeight);
      if (maxTop <= 0) {{
        return {{ skipped: true, reason: "chat feed not scrollable", scrollHeight: scroller.scrollHeight, clientHeight: scroller.clientHeight }};
      }}
      const startedAtMs = meshGuiBenchmarkNowMs();
      scroller.scrollTop = 0;
      scroller.dispatchEvent(new Event("scroll", {{ bubbles: true }}));
      const topAfterFirstSet = Number(scroller.scrollTop) || 0;
      scroller.scrollTop = maxTop;
      scroller.dispatchEvent(new Event("scroll", {{ bubbles: true }}));
      const finalTop = Number(scroller.scrollTop) || 0;
      const actionSyncMs = meshGuiBenchmarkNowMs() - startedAtMs;
      await meshGuiBenchmarkNextFrame();
      scroller.scrollTop = Math.max(0, Math.min(maxTop, previousTop));
      scroller.dispatchEvent(new Event("scroll", {{ bubbles: true }}));
      return {{
        skipped: false,
        actionSyncMs: meshGuiBenchmarkRoundMs(actionSyncMs),
        scrollerClass: String(scroller.className || ""),
        scrollHeight: scroller.scrollHeight,
        clientHeight: scroller.clientHeight,
        topAfterFirstSet: meshGuiBenchmarkRoundMs(topAfterFirstSet),
        finalTop: meshGuiBenchmarkRoundMs(finalTop),
      }};
    }}

