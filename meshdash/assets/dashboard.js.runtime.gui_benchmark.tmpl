    async function meshGuiBenchmarkWaitForEnvironmentMetricsRender(startIndex, timeoutMs = 1500) {{
      const safeStart = Math.max(0, Math.trunc(Number(startIndex) || 0));
      const startedAtMs = meshGuiBenchmarkNowMs();
      while ((meshGuiBenchmarkNowMs() - startedAtMs) < Math.max(0, Number(timeoutMs) || 0)) {{
        if (meshGuiBenchmarkEnvironmentMetricsRenderRunCount() > safeStart) {{
          return true;
