    async function meshGuiBenchmarkPollView(viewName, subviewName = "", options = null) {{
      const pollOptions = options && typeof options === "object" ? options : {{}};
      const forceReload = pollOptions.forceReload !== false;
      const view = normalizeLayoutView(viewName || activeLayoutView);
      const subview = view === "network" ? normalizeNetworkSubview(subviewName || activeNetworkSubview) : "";
      const alreadyActive = meshGuiBenchmarkIsViewActive(view, subview);
      if (!alreadyActive && view === "network" && subview) {{
        setActiveNetworkSubview(subview, {{ persist: false }});
      }}
      if (!alreadyActive) {{
        applyLayoutView(view, false);
        await meshGuiBenchmarkNextFrame();
      }}
      if (forceReload) {{
        try {{
          stateEtag = "";
          forceStateReloadOnce = true;
        }} catch (_err) {{
        }}
      }}
      const beforeChatSamples = chatPerfStats.samples;
      const beforeChatRuns = meshGuiBenchmarkChatRenderRunCount();
      const beforeGraphRuns = meshGuiBenchmarkNetworkGraphRenderRunCount();
      const beforePollRuns = meshGuiBenchmarkPollPerfRunCount();
      const beforeEnvMetricsRuns = meshGuiBenchmarkEnvironmentMetricsRenderRunCount();
