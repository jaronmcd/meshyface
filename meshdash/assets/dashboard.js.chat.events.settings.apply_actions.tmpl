    async function setFixedPosition() {{
      if (settingsApplyInFlight) return;
      if (normalizeSettingsPositionSource(readSettingsPositionSourceSelection()) !== "fixed") {{
        setText("settings-apply-status", "Select Fixed position source before setting a fixed location.");
        return;
      }}

      const lat = readNumberValue("settings-fixed-latitude", true);
      const lon = readNumberValue("settings-fixed-longitude", true);
      const alt = readNumberValue("settings-fixed-altitude");
      if (lat == null || lon == null) {{
        setText("settings-apply-status", "Fixed position requires latitude and longitude.");
        return;
      }}
      if (lat < -90 || lat > 90) {{
        setText("settings-apply-status", "Latitude must be between -90 and 90.");
        return;
      }}
      if (lon < -180 || lon > 180) {{
        setText("settings-apply-status", "Longitude must be between -180 and 180.");
        return;
      }}

      const payload = {{
        actions: {{ set_fixed_position: true }},
        fixed_position: {{
          lat,
          lon,
        }},
      }};
      if (alt != null) {{
        payload.fixed_position.alt = alt;
      }}

      const ok = await postRadioSettingsPayload(
        payload,
        "Setting fixed GPS position on radio…",
        "fixed GPS position saved"
      );
      if (ok) {{
        persistSettingsFixedPositionCache({{ lat, lon, alt }});
        setTimeout(() => {{
          void fetchSettingsFromRadio();
        }}, 600);
      }}
    }}

    async function clearFixedPosition(positionSource = null) {{
      if (settingsApplyInFlight) return;

      const mode = normalizeSettingsPositionSource(
        positionSource == null ? readSettingsPositionSourceSelection() : positionSource
      );
      const modeLabel = mode === "none" ? "None" : (mode === "gps" ? "GPS" : "Fixed");

      const confirmed = window.confirm(
        mode === "fixed"
          ? "Clear fixed GPS position on the radio? The node will stop using a pinned location."
          : `Apply ${modeLabel} mode by clearing fixed GPS position override on the radio?`
      );
      if (!confirmed) return;

      const ok = await postRadioSettingsPayload(
        {{ actions: {{ clear_fixed_position: true }} }},
        mode === "fixed" ? "Clearing fixed GPS position…" : `Applying ${modeLabel} mode…`,
        mode === "fixed" ? "fixed GPS position cleared" : `${modeLabel} mode applied (fixed override cleared)`
      );
      if (ok) {{
        clearSettingsFixedPositionCache();
        setTimeout(() => {{
          void fetchSettingsFromRadio();
        }}, 600);
      }}
    }}

