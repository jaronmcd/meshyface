      if (drawer instanceof HTMLElement) {{
        for (const tabBtn of drawer.querySelectorAll(".chat-node-details-tab-btn")) {{
          if (!(tabBtn instanceof HTMLButtonElement) || tabBtn.dataset.bound === "1") continue;
          tabBtn.dataset.bound = "1";
          tabBtn.addEventListener("click", () => {{
            setChatNodeDetailsDrawerTab(tabBtn.dataset.drawerTab || "details", {{
              fetchHistory: true,
            }});
          }});
