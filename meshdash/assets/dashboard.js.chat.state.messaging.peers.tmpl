    function chatNodeNavigatorNetworkHistoryModeForSearch() {{
      const layout = String(activeLayoutView || "").trim().toLowerCase();
      if (layout !== "network") return "max";
      const subview = (typeof normalizeNetworkSubview === "function")
        ? normalizeNetworkSubview(activeNetworkSubview)
        : String(activeNetworkSubview || "").trim().toLowerCase();
      if (subview === "routes") {{
        return (typeof normalizeNetworkGraphEdgeMode === "function")
          ? normalizeNetworkGraphEdgeMode(networkRoutesWindow)
          : String(networkRoutesWindow || "7d").trim().toLowerCase();
      }}
      if (subview === "graph") {{
        return (typeof normalizeNetworkGraphEdgeMode === "function")
          ? normalizeNetworkGraphEdgeMode(networkGraphEdgeMode)
          : String(networkGraphEdgeMode || "7d").trim().toLowerCase();
      }}
