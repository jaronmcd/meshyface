    function normalizeChatNodeNavigatorSortKeyPref(value) {{
      const clean = String(value || "").trim().toLowerCase();
      return chatNodeNavigatorSortDefById.has(clean) ? clean : chatNodeNavigatorDefaultSortKey;
    }}

    function normalizeChatNodeNavigatorSortDirPref(value) {{
      const clean = String(value || "").trim().toLowerCase();
      return clean === "desc" ? "desc" : "asc";
    }}

    function normalizeChatNodeNavigatorShowPacketDirectionPref(value) {{
      if (typeof parseBoolToken === "function") {{
        return parseBoolToken(value, true);
      }}
      if (value == null) return true;
      const clean = String(value).trim().toLowerCase();
      return !(clean === "0" || clean === "false" || clean === "off" || clean === "no");
    }}

    function normalizeChatNodeNavigatorMetaFieldIdsPref(rawIds, options = null) {{
      const opts = options && typeof options === "object" ? options : {{}};
      const fallbackToDefaults = opts.fallbackToDefaults !== false;
      const defs = nodeExplorerRosterMetadataFieldDefs();
      const allowed = new Set(defs.map((def) => String(def && def.id || "")));
      const source = Array.isArray(rawIds)
        ? rawIds
        : (rawIds == null ? [] : [rawIds]);
      const normalized = [];
      for (const value of source) {{
        const fieldId = normalizeNodeExplorerFieldId(value);
        if (!fieldId || !allowed.has(fieldId) || normalized.includes(fieldId)) continue;
        normalized.push(fieldId);
      }}
      if (normalized.length > 0) return normalized;
      return fallbackToDefaults
        ? nodeExplorerDefaultRosterMetadataFieldIds()
        : [];
    }}

    function chatNodeNavigatorMetaFieldIdsEqual(a, b) {{
      const left = Array.isArray(a) ? a : [];
      const right = Array.isArray(b) ? b : [];
      if (left.length !== right.length) return false;
      for (let i = 0; i < left.length; i += 1) {{
        if (String(left[i] || "") !== String(right[i] || "")) return false;
      }}
      return true;
    }}

    function persistChatNodeNavigatorPreferences() {{
      try {{
        const payload = {{
          sortKey: normalizeChatNodeNavigatorSortKeyPref(chatNodeNavigatorSortKey),
          sortDir: normalizeChatNodeNavigatorSortDirPref(chatNodeNavigatorSortDir),
          showPacketDirection: normalizeChatNodeNavigatorShowPacketDirectionPref(chatNodeNavigatorShowPacketDirection),
          metaFields: normalizeChatNodeNavigatorMetaFieldIdsPref(chatNodeNavigatorMetaFieldIds, {{
            fallbackToDefaults: false,
          }}),
        }};
        window.localStorage.setItem(chatNodeNavigatorPrefsStorageKey, JSON.stringify(payload));
      }} catch (_err) {{
      }}
    }}

    function applyChatNodeNavigatorPreferences(nextPrefs, options = null) {{
      const prefs = nextPrefs && typeof nextPrefs === "object" ? nextPrefs : {{}};
      const opts = options && typeof options === "object" ? options : {{}};
      const nextSortKey = normalizeChatNodeNavigatorSortKeyPref(
        prefs.sortKey != null ? prefs.sortKey : chatNodeNavigatorSortKey
      );
      const nextSortDir = normalizeChatNodeNavigatorSortDirPref(
        prefs.sortDir != null ? prefs.sortDir : chatNodeNavigatorSortDir
      );
      const nextShowPacketDirection = normalizeChatNodeNavigatorShowPacketDirectionPref(
        prefs.showPacketDirection != null ? prefs.showPacketDirection : chatNodeNavigatorShowPacketDirection
      );
      const nextMetaFieldIds = normalizeChatNodeNavigatorMetaFieldIdsPref(
        prefs.metaFields != null ? prefs.metaFields : chatNodeNavigatorMetaFieldIds,
        {{ fallbackToDefaults: false }}
      );
      const changed = (
        nextSortKey !== chatNodeNavigatorSortKey
        || nextSortDir !== chatNodeNavigatorSortDir
        || nextShowPacketDirection !== chatNodeNavigatorShowPacketDirection
        || !chatNodeNavigatorMetaFieldIdsEqual(nextMetaFieldIds, chatNodeNavigatorMetaFieldIds)
      );
      chatNodeNavigatorSortKey = nextSortKey;
      chatNodeNavigatorSortDir = nextSortDir;
      chatNodeNavigatorShowPacketDirection = nextShowPacketDirection;
      chatNodeNavigatorMetaFieldIds = nextMetaFieldIds;
      if (opts.persist !== false) {{
        persistChatNodeNavigatorPreferences();
      }}
      renderChatNodeNavigatorMenuControls();
      if (changed && opts.rerender !== false && latestState) {{
        renderChat(latestState);
      }}
      return changed;
    }}

    function loadChatNodeNavigatorPreferences() {{
      let parsed = null;
      try {{
        const raw = window.localStorage.getItem(chatNodeNavigatorPrefsStorageKey);
        parsed = raw ? JSON.parse(raw) : null;
      }} catch (_err) {{
      }}
      applyChatNodeNavigatorPreferences(parsed || {{}}, {{
        persist: false,
        rerender: false,
      }});
    }}

    function chatNodeNavigatorCompareSortValues(left, right) {{
      if (typeof normalizeSortValue === "function" && typeof compareSortValues === "function") {{
        return compareSortValues(normalizeSortValue(left), normalizeSortValue(right));
      }}
      const leftNum = Number(left);
      const rightNum = Number(right);
      const leftHasNum = Number.isFinite(leftNum);
      const rightHasNum = Number.isFinite(rightNum);
      if (leftHasNum && rightHasNum) return leftNum - rightNum;
      return String(left == null ? "" : left).localeCompare(String(right == null ? "" : right));
    }}

    function chatNodeNavigatorSortValue(item, projection, sortKeyRaw, nowUnixRaw = null) {{
      const sortKey = normalizeChatNodeNavigatorSortKeyPref(sortKeyRaw);
      const safeItem = item && typeof item === "object" ? item : {{}};
      const safeProjection = projection && typeof projection === "object"
        ? projection
        : nodeExplorerBuildProjection(null);
      const nowUnix = Number.isFinite(Number(nowUnixRaw))
        ? Math.trunc(Number(nowUnixRaw))
        : Math.floor(Date.now() / 1000);
      if (sortKey === "status") {{
        return Number.isFinite(Number(safeProjection.statusSort))
          ? Number(safeProjection.statusSort)
          : 99;
      }}
      if (sortKey === "activity") {{
        return Number(safeItem.lastMessageUnix) || 0;
      }}
      if (sortKey === "idle") {{
        const lastSeenFromRoster = Number(safeItem && safeItem.lastSeenUnix);
        const lastSeenFromProjection = Number(
          safeProjection
          && safeProjection.fields
          && safeProjection.fields.last_heard
          && safeProjection.fields.last_heard.sort
        );
        const lastSeenUnix = Number.isFinite(lastSeenFromRoster) && lastSeenFromRoster > 0
          ? Math.trunc(lastSeenFromRoster)
          : (Number.isFinite(lastSeenFromProjection) && lastSeenFromProjection > 0
            ? Math.trunc(lastSeenFromProjection)
            : 0);
        if (!Number.isFinite(lastSeenUnix) || lastSeenUnix <= 0) {{
          return Number.MAX_SAFE_INTEGER;
        }}
        return Math.max(0, nowUnix - lastSeenUnix);
      }}
      const fieldId = normalizeNodeExplorerFieldId(sortKey);
      const field = fieldId && safeProjection.fields
        ? safeProjection.fields[fieldId]
        : null;
      return field ? field.sort : "";
    }}

    function sortChatNodeNavigatorParticipants(participantsList, nodesById, nowUnix = Math.floor(Date.now() / 1000)) {{
      const rows = Array.isArray(participantsList) ? participantsList : [];
      const sourceNodes = nodesById instanceof Map ? nodesById : new Map();
      const sortKey = normalizeChatNodeNavigatorSortKeyPref(chatNodeNavigatorSortKey);
      const sortDir = normalizeChatNodeNavigatorSortDirPref(chatNodeNavigatorSortDir);
      const projectionById = new Map();
      const projectionFor = (entry) => {{
        const nodeId = normalizeNodeId(entry && entry.id);
        if (projectionById.has(nodeId)) {{
          return projectionById.get(nodeId);
        }}
        const node = sourceNodes.get(nodeId) || null;
        const projection = nodeExplorerBuildProjection(
          node || {{ id: nodeId, long_name: (entry && entry.name) || nodeId }},
          {{ nowUnix }}
        );
        projectionById.set(nodeId, projection);
        return projection;
      }};
      rows.sort((a, b) => {{
        const pinDiff = Number(!!(b && b.p2pPinned)) - Number(!!(a && a.p2pPinned));
        if (pinDiff !== 0) return pinDiff;

        const aProjection = projectionFor(a);
        const bProjection = projectionFor(b);
        const aValue = chatNodeNavigatorSortValue(a, aProjection, sortKey, nowUnix);
        const bValue = chatNodeNavigatorSortValue(b, bProjection, sortKey, nowUnix);
        const cmp = chatNodeNavigatorCompareSortValues(aValue, bValue);
        if (cmp !== 0) {{
          return sortDir === "desc" ? -cmp : cmp;
        }}

        const statusCmp = chatNodeNavigatorCompareSortValues(aProjection.statusSort, bProjection.statusSort);
        if (statusCmp !== 0) return statusCmp;

        const activityCmp = chatNodeNavigatorCompareSortValues(
          Number(b && b.lastMessageUnix) || 0,
          Number(a && a.lastMessageUnix) || 0
        );
        if (activityCmp !== 0) return activityCmp;

        const nameCmp = String((a && (a.name || a.id)) || "").localeCompare(String((b && (b.name || b.id)) || ""));
        if (nameCmp !== 0) return nameCmp;
        return String((a && a.id) || "").localeCompare(String((b && b.id) || ""));
      }});
      return rows;
    }}

    function renderChatNodeNavigatorMenuControls() {{
      const menuBtn = document.getElementById("chat-node-navigator-menu-btn");
      const menu = document.getElementById("chat-node-navigator-menu");
      const sortSelect = document.getElementById("chat-node-navigator-sort-select");
      const dirBtn = document.getElementById("chat-node-navigator-sort-dir-btn");
      const fieldsHost = document.getElementById("chat-node-navigator-fields");

      if (menuBtn instanceof HTMLButtonElement) {{
        menuBtn.setAttribute("aria-expanded", chatNodeNavigatorMenuOpen ? "true" : "false");
      }}
      if (menu instanceof HTMLElement) {{
        menu.hidden = !chatNodeNavigatorMenuOpen;
      }}

      if (sortSelect instanceof HTMLSelectElement) {{
        const optionsHtml = chatNodeNavigatorSortDefs.map((def) => (
          `<option value="${{escAttr(def.id)}}">${{escAttr(def.label)}}</option>`
        )).join("");
        if (sortSelect.__meshOptionsHtml !== optionsHtml) {{
          sortSelect.innerHTML = optionsHtml;
          sortSelect.__meshOptionsHtml = optionsHtml;
        }}
        const sortKey = normalizeChatNodeNavigatorSortKeyPref(chatNodeNavigatorSortKey);
        if (sortSelect.value !== sortKey) {{
          sortSelect.value = sortKey;
        }}
      }}

      if (dirBtn instanceof HTMLButtonElement) {{
        const dir = normalizeChatNodeNavigatorSortDirPref(chatNodeNavigatorSortDir);
        dirBtn.textContent = dir === "desc" ? "Desc" : "Asc";
        dirBtn.title = dir === "desc"
          ? "Sorting descending. Click to sort ascending."
          : "Sorting ascending. Click to sort descending.";
        dirBtn.setAttribute("aria-label", dirBtn.title);
      }}

      if (fieldsHost instanceof HTMLElement) {{
        const selected = new Set(
          normalizeChatNodeNavigatorMetaFieldIdsPref(chatNodeNavigatorMetaFieldIds, {{
            fallbackToDefaults: false,
          }})
        );
        const showPacketDirection = normalizeChatNodeNavigatorShowPacketDirectionPref(
          chatNodeNavigatorShowPacketDirection
        );
        const fieldsHtml = nodeExplorerRosterMetadataFieldDefs().map((def) => {{
          const fieldId = normalizeNodeExplorerFieldId(def && def.id);
          if (!fieldId) return "";
          const checked = selected.has(fieldId) ? " checked" : "";
          return `<label class="chat-node-navigator-field-option">
            <input type="checkbox" data-meta-field-id="${{escAttr(fieldId)}}"${{checked}} />
            <span>${{escAttr(def.label || fieldId)}}</span>
          </label>`;
        }}).join("")
          + `<label class="chat-node-navigator-field-option">
            <input type="checkbox" data-nav-toggle-id="packet-direction"${{showPacketDirection ? " checked" : ""}} />
            <span>TX/RX + Plot</span>
          </label>`;
        if (fieldsHost.__meshFieldsHtml !== fieldsHtml) {{
          fieldsHost.innerHTML = fieldsHtml;
          fieldsHost.__meshFieldsHtml = fieldsHtml;
        }} else {{
          for (const input of fieldsHost.querySelectorAll('input[type="checkbox"][data-meta-field-id]')) {{
            if (!(input instanceof HTMLInputElement)) continue;
            const fieldId = normalizeNodeExplorerFieldId(input.dataset.metaFieldId || "");
            input.checked = selected.has(fieldId);
          }}
          for (const input of fieldsHost.querySelectorAll('input[type="checkbox"][data-nav-toggle-id]')) {{
            if (!(input instanceof HTMLInputElement)) continue;
            const toggleId = String(input.dataset.navToggleId || "").trim().toLowerCase();
            if (toggleId === "packet-direction") {{
              input.checked = showPacketDirection;
            }}
          }}
        }}
      }}
    }}

    function bindChatNodeNavigatorMenuControls() {{
      const menuBtn = document.getElementById("chat-node-navigator-menu-btn");
      const sortSelect = document.getElementById("chat-node-navigator-sort-select");
      const dirBtn = document.getElementById("chat-node-navigator-sort-dir-btn");
      const fieldsHost = document.getElementById("chat-node-navigator-fields");

      if (menuBtn instanceof HTMLButtonElement && menuBtn.dataset.bound !== "1") {{
        menuBtn.dataset.bound = "1";
        menuBtn.addEventListener("click", (ev) => {{
          ev.preventDefault();
          chatNodeNavigatorMenuOpen = !chatNodeNavigatorMenuOpen;
          renderChatNodeNavigatorMenuControls();
        }});
      }}

      if (sortSelect instanceof HTMLSelectElement && sortSelect.dataset.bound !== "1") {{
        sortSelect.dataset.bound = "1";
        sortSelect.addEventListener("change", () => {{
          applyChatNodeNavigatorPreferences({{
            sortKey: sortSelect.value,
          }}, {{
            persist: true,
            rerender: true,
          }});
        }});
      }}

      if (dirBtn instanceof HTMLButtonElement && dirBtn.dataset.bound !== "1") {{
        dirBtn.dataset.bound = "1";
        dirBtn.addEventListener("click", (ev) => {{
          ev.preventDefault();
          const currentDir = normalizeChatNodeNavigatorSortDirPref(chatNodeNavigatorSortDir);
          const nextDir = currentDir === "desc" ? "asc" : "desc";
          applyChatNodeNavigatorPreferences({{
            sortDir: nextDir,
          }}, {{
            persist: true,
            rerender: true,
          }});
        }});
      }}

      if (fieldsHost instanceof HTMLElement && fieldsHost.dataset.bound !== "1") {{
        fieldsHost.dataset.bound = "1";
        fieldsHost.addEventListener("change", (ev) => {{
          const target = ev.target;
          if (!(target instanceof HTMLInputElement)) return;
          if (target.type !== "checkbox") return;
          const toggleId = String(target.dataset.navToggleId || "").trim().toLowerCase();
          if (toggleId === "packet-direction") {{
            applyChatNodeNavigatorPreferences({{
              showPacketDirection: !!target.checked,
            }}, {{
              persist: true,
              rerender: true,
            }});
            return;
          }}
          const nextFields = [];
          for (const input of fieldsHost.querySelectorAll('input[type="checkbox"][data-meta-field-id]')) {{
            if (!(input instanceof HTMLInputElement) || !input.checked) continue;
            nextFields.push(input.dataset.metaFieldId || "");
          }}
          applyChatNodeNavigatorPreferences({{
            metaFields: nextFields,
          }}, {{
            persist: true,
            rerender: true,
          }});
        }});
      }}

      if (document.body.dataset.chatNodeNavigatorMenuOutsideBound !== "1") {{
        document.body.dataset.chatNodeNavigatorMenuOutsideBound = "1";
        document.addEventListener("pointerdown", (ev) => {{
          if (!chatNodeNavigatorMenuOpen) return;
          const target = ev.target;
          if (!(target instanceof Node)) return;
          const btn = document.getElementById("chat-node-navigator-menu-btn");
          const panel = document.getElementById("chat-node-navigator-menu");
          if ((btn instanceof HTMLElement) && btn.contains(target)) return;
          if ((panel instanceof HTMLElement) && panel.contains(target)) return;
          chatNodeNavigatorMenuOpen = false;
          renderChatNodeNavigatorMenuControls();
        }});
      }}

      renderChatNodeNavigatorMenuControls();
    }}

    function normalizeChatNodeDetailsDrawerTab(value) {{
      const clean = String(value || "").trim().toLowerCase();
      if (clean === "history") return "history";
      if (clean === "tag") return "tag";
      return "details";
    }}

    function chatNodeDetailsDrawerTargetNodeId(rawNodeId = selectedNodeId) {{
      const clean = normalizeNodeId(rawNodeId || "");
      return isSelectableNodeId(clean) ? clean : "";
    }}

    function chatNodeDetailsDrawerExpandedForNode(rawNodeId = selectedNodeId) {{
      const nodeId = chatNodeDetailsDrawerTargetNodeId(rawNodeId);
      return !!chatNodeDetailsDrawerExpanded && isSelectableNodeId(nodeId);
    }}

    function isChatNodeDetailsDrawerExpanded() {{
      return chatNodeDetailsDrawerExpandedForNode(selectedNodeId);
    }}

    function isChatNodeDetailsHistoryActive() {{
      return isChatNodeDetailsDrawerExpanded()
        && normalizeChatNodeDetailsDrawerTab(chatNodeDetailsDrawerTab) === "history";
    }}

    function syncSavedNodeDetailsDock(forceToSaved = false) {{
      const detailsHost = document.getElementById("saved-node-details");
      if (!(detailsHost instanceof HTMLElement)) return;
      const savedPane = document.querySelector(".saved-node-pane");
      const drawerHost = document.getElementById("chat-node-details-content-host");
      const useDrawerHost = !forceToSaved
        && isChatNodeDetailsDrawerExpanded()
        && (drawerHost instanceof HTMLElement);
      const target = useDrawerHost ? drawerHost : savedPane;
      if (!(target instanceof HTMLElement)) return;
      if (detailsHost.parentElement !== target) {{
        target.appendChild(detailsHost);
      }}
    }}

    function syncChatNodeDetailsDrawer(state = latestState, options = null) {{
      const opts = options && typeof options === "object" ? options : {{}};
      const drawer = document.getElementById("chat-node-details-drawer");
      const titleEl = document.getElementById("chat-node-details-title");
      const closeBtn = document.getElementById("chat-node-details-close-btn");
      const muteBtn = document.getElementById("chat-node-details-mute-btn");
      const dmBtn = document.getElementById("chat-node-details-dm-btn");
      const detailsTabBtn = document.getElementById("chat-node-details-tab-details");
      const historyTabBtn = document.getElementById("chat-node-details-tab-history");
      const tagTabBtn = document.getElementById("chat-node-details-tab-tag");
      const tagTabLabel = document.getElementById("chat-node-details-tab-tag-label");
      const tagTabChip = document.getElementById("chat-node-details-tab-tag-chip");
      const detailsPanel = document.getElementById("chat-node-details-panel-details");
      const historyPanel = document.getElementById("chat-node-details-panel-history");
      const tagPanel = document.getElementById("chat-node-details-panel-tag");
      const tagHost = document.getElementById("chat-node-details-tag-host");
      if (!(drawer instanceof HTMLElement)) return;

      const safeState = (state && typeof state === "object") ? state : (latestState || {{}});
      const selectedId = chatNodeDetailsDrawerTargetNodeId(selectedNodeId);
      const expanded = !!chatNodeDetailsDrawerExpanded && isSelectableNodeId(selectedId);
      chatNodeDetailsDrawerTab = normalizeChatNodeDetailsDrawerTab(chatNodeDetailsDrawerTab);

      drawer.hidden = !expanded;
      if (closeBtn instanceof HTMLButtonElement) {{
        closeBtn.disabled = !expanded;
      }}
      if (muteBtn instanceof HTMLButtonElement) {{
        muteBtn.hidden = true;
        muteBtn.disabled = true;
        muteBtn.dataset.nodeId = "";
        muteBtn.classList.remove("active");
        muteBtn.setAttribute("aria-pressed", "false");
        const muteLabel = muteBtn.querySelector(".chat-node-details-mute-label");
        if (muteLabel instanceof HTMLElement) {{
          muteLabel.textContent = "Mute";
        }}
      }}
      if (dmBtn instanceof HTMLButtonElement) {{
        dmBtn.hidden = true;
        dmBtn.disabled = true;
        dmBtn.dataset.nodeId = "";
      }}
      if (!expanded) {{
        syncSavedNodeDetailsDock(true);
        syncNodeHistoryDock();
        return;
      }}

      const activeTab = normalizeChatNodeDetailsDrawerTab(chatNodeDetailsDrawerTab);
      if (detailsTabBtn instanceof HTMLButtonElement) {{
        const isActive = activeTab === "details";
        detailsTabBtn.classList.toggle("is-active", isActive);
        detailsTabBtn.setAttribute("aria-selected", isActive ? "true" : "false");
      }}
      if (historyTabBtn instanceof HTMLButtonElement) {{
        const isActive = activeTab === "history";
        historyTabBtn.classList.toggle("is-active", isActive);
        historyTabBtn.setAttribute("aria-selected", isActive ? "true" : "false");
      }}
      if (tagTabBtn instanceof HTMLButtonElement) {{
        const isActive = activeTab === "tag";
        tagTabBtn.classList.toggle("is-active", isActive);
        tagTabBtn.setAttribute("aria-selected", isActive ? "true" : "false");
      }}
      if (detailsPanel instanceof HTMLElement) {{
        detailsPanel.hidden = activeTab !== "details";
      }}
      if (historyPanel instanceof HTMLElement) {{
        historyPanel.hidden = activeTab !== "history";
      }}
      if (tagPanel instanceof HTMLElement) {{
        tagPanel.hidden = activeTab !== "tag";
      }}

      const tagEntry = nodeTagEntryForNode(selectedId);
      const tagPreset = tagEntry && tagEntry.preset ? tagEntry.preset : null;
      const hasTag = !!tagPreset;
      const tagLabel = hasTag
        ? normalizeNodeTagPresetName(tagPreset.name, "Tagged")
        : "+tag";
      if (tagTabLabel instanceof HTMLElement) {{
        tagTabLabel.textContent = tagLabel;
      }}
      if (tagTabBtn instanceof HTMLButtonElement) {{
        const tagTitle = hasTag
          ? `Edit tag: ${{tagLabel}}`
          : "Add or edit node tag";
        tagTabBtn.title = tagTitle;
        tagTabBtn.setAttribute("aria-label", tagTitle);
      }}
      if (tagTabChip instanceof HTMLElement) {{
        if (hasTag) {{
          tagTabChip.classList.add("is-tagged");
          tagTabChip.setAttribute("style", nodeTagStyleVars(tagEntry));
        }} else {{
          tagTabChip.classList.remove("is-tagged");
          tagTabChip.removeAttribute("style");
        }}
      }}
      if (tagHost instanceof HTMLElement) {{
        const existingEditor = tagHost.querySelector("#favorite-menu-tag-editor");
        const existingNodeId = existingEditor instanceof HTMLElement
          ? normalizeNodeId(existingEditor.dataset.nodeId || "")
          : "";
        if (!(existingEditor instanceof HTMLElement) || existingNodeId !== selectedId) {{
          tagHost.innerHTML = favoriteMenuTagEditorHtml(selectedId);
        }}
        bindFavoriteMenuTagEditorControls(selectedId);
      }}

      const resolvedName = (typeof resolveSavedViewNodeName === "function")
        ? resolveSavedViewNodeName(safeState, selectedId)
        : "";
      const fallbackName = nodeNameCache.get(selectedId) || selectedId;
      const titleName = String(resolvedName || fallbackName || selectedId);
      if (titleEl instanceof HTMLElement) {{
        titleEl.textContent = `${{titleName}} (${selectedId})`;
      }}
      if (dmBtn instanceof HTMLButtonElement) {{
        const canOpenPeerDm = isCanonicalNodeId(selectedId) && !isSelfNodeId(selectedId);
        dmBtn.hidden = !canOpenPeerDm;
        dmBtn.disabled = !canOpenPeerDm;
        dmBtn.dataset.nodeId = canOpenPeerDm ? selectedId : "";
        dmBtn.title = canOpenPeerDm
          ? `Open peer message window with ${{titleName}}`
          : "Send message unavailable for this node";
      }}
      if (muteBtn instanceof HTMLButtonElement) {{
        const canMute = isCanonicalNodeId(selectedId) && !isSelfNodeId(selectedId);
        const active = canMute && isMutedNode(selectedId);
        muteBtn.hidden = !canMute;
        muteBtn.disabled = !canMute;
        muteBtn.dataset.nodeId = canMute ? selectedId : "";
        muteBtn.classList.toggle("active", active);
        muteBtn.setAttribute("aria-pressed", active ? "true" : "false");
        muteBtn.title = canMute
          ? (active ? "Unmute this user in chat feed" : "Mute this user in chat feed")
          : "Mute unavailable for this node";
        const muteLabel = muteBtn.querySelector(".chat-node-details-mute-label");
        if (muteLabel instanceof HTMLElement) {{
          muteLabel.textContent = active ? "Muted" : "Mute";
        }}
      }}

      syncSavedNodeDetailsDock(false);
      const cachedHistory = cachedNodeHistory(selectedId);
      renderSavedNodeDetails(safeState, cachedHistory);
      if (opts.fetchHistory !== false) {{
        // Even on the Details tab we want the network map trail ready when the drawer opens.
        void refreshSelectedNodeHistory(false);
      }}

      if (activeTab === "history") {{
        setMapDataMode("node");
        syncNodeHistoryDock();
        if (cachedHistory) {{
          const nodes = Array.isArray(safeState.nodes) ? safeState.nodes : [];
          renderNodeHistory(cachedHistory, nodes);
        }} else {{
          renderNodeHistoryLoading(selectedId);
        }}
      }} else {{
        syncNodeHistoryDock();
      }}
    }}

    function setChatNodeDetailsDrawerExpanded(expanded, options = null) {{
      const opts = options && typeof options === "object" ? options : {{}};
      const nextExpanded = !!expanded;
      const nextTab = normalizeChatNodeDetailsDrawerTab(
        opts.tab != null ? opts.tab : chatNodeDetailsDrawerTab
      );
      const currentExpanded = !!chatNodeDetailsDrawerExpanded;
      const currentTab = normalizeChatNodeDetailsDrawerTab(chatNodeDetailsDrawerTab);
      if (nextExpanded && !isSelectableNodeId(chatNodeDetailsDrawerTargetNodeId(selectedNodeId))) {{
        chatNodeDetailsDrawerExpanded = false;
        chatNodeDetailsDrawerTab = nextTab;
        syncChatNodeDetailsDrawer(latestState, {{
          fetchHistory: false,
        }});
        return false;
      }}
      const changed = currentExpanded !== nextExpanded || currentTab !== nextTab;
      chatNodeDetailsDrawerExpanded = nextExpanded;
      chatNodeDetailsDrawerTab = nextTab;
      if (activeLayoutView === "network") {{
        const selectedId = chatNodeDetailsDrawerTargetNodeId(selectedNodeId);
        if (isSelectableNodeId(selectedId)) {{
          if (nextExpanded) {{
            networkNodeInfoCollapsedNodeId = "";
          }} else {{
            networkNodeInfoCollapsedNodeId = selectedId;
          }}
        }}
      }}
      const shouldRerender = opts.rerender === true;
      if (shouldRerender && latestState) {{
        renderChat(latestState);
      }} else {{
        syncChatNodeDetailsDrawer(latestState, {{
          fetchHistory: opts.fetchHistory !== false,
        }});
      }}
      return changed;
    }}

    function setChatNodeDetailsDrawerTab(tab, options = null) {{
      const nextTab = normalizeChatNodeDetailsDrawerTab(tab);
      const opts = options && typeof options === "object" ? options : {{}};
      chatNodeDetailsDrawerTab = nextTab;
      syncChatNodeDetailsDrawer(latestState, {{
        fetchHistory: opts.fetchHistory !== false,
      }});
      return nextTab;
    }}

    function toggleChatNodeDetailsDrawerForNode(rawNodeId) {{
      const nodeId = chatNodeDetailsDrawerTargetNodeId(rawNodeId);
      if (!isSelectableNodeId(nodeId)) return false;
      const selectedId = chatNodeDetailsDrawerTargetNodeId(selectedNodeId);
      const sameNode = selectedId === nodeId;
      const expandedForNode = sameNode && isChatNodeDetailsDrawerExpanded();
      if (!sameNode) {{
        selectNode(nodeId, true, false);
      }}
      setChatNodeDetailsDrawerExpanded(!expandedForNode, {{
        fetchHistory: !expandedForNode,
        rerender: false,
      }});
      return true;
    }}

