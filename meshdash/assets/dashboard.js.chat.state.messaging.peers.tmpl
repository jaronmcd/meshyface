    function toggleChatNodeDetailsDrawerForNode(rawNodeId) {{
      const nodeId = chatNodeDetailsDrawerTargetNodeId(rawNodeId);
      if (!isSelectableNodeId(nodeId)) return false;
      const selectedId = chatNodeDetailsDrawerTargetNodeId(selectedNodeId);
      const sameNode = selectedId === nodeId;
      const expandedForNode = sameNode && isChatNodeDetailsDrawerExpanded();
      if (!sameNode) {{
        selectNode(nodeId, true, false);
      }}
      setChatNodeDetailsDrawerExpanded(!expandedForNode, {{
        fetchHistory: !expandedForNode,
        rerender: false,
      }});
      return true;
