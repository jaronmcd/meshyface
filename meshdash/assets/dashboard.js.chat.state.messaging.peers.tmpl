        pathCount += 1;
        const routeEdges = Array.isArray(inferred && inferred.edges) ? inferred.edges : [];
        for (let edgeIndex = 0; edgeIndex < routeEdges.length; edgeIndex += 1) {{
          const a = path[edgeIndex];
          const b = path[edgeIndex + 1];
          const edgeKey = chatNodeNavigatorLinkQualityEdgeKey(a, b);
          if (edgeKey) blockedEdgeKeys.add(edgeKey);
        }}
      }}
      return {{
        pathCount,
        hops: shortestHops,
        reachable: pathCount > 0,
      }};
    }}

    function chatNodeNavigatorInferLinkQuality(hopsValue, pathCountValue, options = null) {{
      const opts = (options && typeof options === "object") ? options : {{}};
      const isSelf = !!opts.isSelf;
      if (isSelf) {{
        return {{
          bars: 4,
          score: 100,
          level: "excellent",
          hops: 0,
          pathCount: 4,
          title: "Self node: direct local link",
          ariaLabel: "Link quality 4 of 4 bars",
        }};
      }}
      const hopsRaw = Number(hopsValue);
      const hops = Number.isFinite(hopsRaw) && hopsRaw >= 0
        ? Math.max(0, Math.trunc(hopsRaw))
        : null;
      const pathCountRaw = Number(pathCountValue);
      const pathCount = Number.isFinite(pathCountRaw) && pathCountRaw >= 0
        ? Math.max(0, Math.trunc(pathCountRaw))
        : 0;
      const reachable = !!opts.reachable || hops != null || pathCount > 0;
      if (!reachable) {{
        return {{
          bars: 0,
          score: 0,
          level: "none",
          hops: null,
          pathCount: 0,
          title: "No inferred route history from self",
          ariaLabel: "Link quality 0 of 4 bars",
        }};
      }}

      const hopsScore = hops == null
        ? 42
        : Math.max(0, Math.min(100, Math.round(100 * (1 - Math.min(1, Math.max(0, hops - 1) / 6)))));
      const pathScore = pathCount >= 4
        ? 100
        : (pathCount === 3 ? 84 : (pathCount === 2 ? 66 : (pathCount === 1 ? 38 : 0)));
      let score = Math.round((hopsScore * 0.7) + (pathScore * 0.3));
      if (hops != null && pathCount <= 0) {{
        score = Math.min(score, 46);
      }}
      if (hops != null && hops <= 2 && pathCount >= 2) {{
        score = Math.min(100, score + 8);
      }}

      const bars = score >= 86
        ? 4
        : (score >= 64 ? 3 : (score >= 42 ? 2 : (score >= 20 ? 1 : 0)));
      const level = bars >= 4
        ? "excellent"
        : (bars === 3 ? "good" : (bars === 2 ? "fair" : (bars === 1 ? "weak" : "none")));
      const parts = [`Estimated link quality ${{bars}}/4 bars (${{score}}%)`];
      if (hops != null) {{
        parts.push(`${{hops}} hop${{hops === 1 ? "" : "s"}}`);
      }}
      parts.push(`${{pathCount}} historical path${{pathCount === 1 ? "" : "s"}}`);
      return {{
        bars,
        score,
        level,
        hops,
        pathCount,
        title: parts.join(" · "),
        ariaLabel: `Link quality ${{bars}} of 4 bars`,
      }};
    }}

    function buildChatNodeNavigatorLinkQualityByNode(
      state = latestState,
      nodesById = null,
      historyCapsById = null,
      participantNodeIds = []
    ) {{
      const safeState = (state && typeof state === "object") ? state : (latestState || {{}});
      const sourceNodesById = nodesById instanceof Map ? nodesById : new Map();
      const sourceHistoryCapsById = historyCapsById instanceof Map ? historyCapsById : new Map();
      const nodeIds = Array.isArray(participantNodeIds) ? participantNodeIds : [];
      const out = new Map();
      const localNodeId = normalizeNodeId(
        (typeof resolveLocalNodeId === "function" ? resolveLocalNodeId(safeState) : "")
      );
      if (!isSelectableNodeId(localNodeId)) return out;

      const historyMode = chatNodeNavigatorNetworkHistoryModeForSearch();
      const participantSignature = chatNodeNavigatorLinkQualityParticipantSignature(nodeIds);
      const cacheSignature = `${{historyMode}}::${{localNodeId}}::${{participantSignature}}`;
      if (chatNodeNavigatorLinkQualityCacheByState instanceof WeakMap && safeState && typeof safeState === "object") {{
        const cached = chatNodeNavigatorLinkQualityCacheByState.get(safeState);
        if (
          cached
          && typeof cached === "object"
          && cached.signature === cacheSignature
          && cached.value instanceof Map
        ) {{
          return cached.value;
        }}
      }}
      const traffic = (safeState.traffic && typeof safeState.traffic === "object")
        ? safeState.traffic
        : {{}};
      const baseEdges = Array.isArray(traffic.edges) ? traffic.edges : [];
      const rawEdgesForMode = (typeof networkGraphRawEdgesForMode === "function")
        ? networkGraphRawEdgesForMode(baseEdges, historyMode)
        : baseEdges;
      const filteredRawEdges = (typeof filterNetworkGraphRawEdgesByMode === "function")
        ? filterNetworkGraphRawEdgesByMode(rawEdgesForMode, historyMode)
        : rawEdgesForMode;

      const baseHistoryCaps = (safeState.history_caps && typeof safeState.history_caps === "object")
        ? safeState.history_caps
        : {{}};
      const historyCapsForMode = (typeof networkGraphHistoryCapsForMode === "function")
        ? networkGraphHistoryCapsForMode(baseHistoryCaps, historyMode)
        : baseHistoryCaps;
      const historyCapsMergedById = new Map(sourceHistoryCapsById);
      for (const [rawNodeId, rawCaps] of Object.entries(historyCapsForMode || {{}})) {{
        const nodeId = normalizeNodeId(rawNodeId || "");
        const caps = (rawCaps && typeof rawCaps === "object") ? rawCaps : null;
        if (!isSelectableNodeId(nodeId) || !caps || historyCapsMergedById.has(nodeId)) continue;
        historyCapsMergedById.set(nodeId, caps);
      }}

      const participantSet = new Set();
      participantSet.add(localNodeId);
      for (const rawNodeId of nodeIds) {{
        const nodeId = normalizeNodeId(rawNodeId || "");
        if (isSelectableNodeId(nodeId)) participantSet.add(nodeId);
      }}

      const liveNodes = Array.isArray(safeState.nodes) ? safeState.nodes : [];
      const nodeMap = (typeof buildNetworkGraphNodeMap === "function")
        ? buildNetworkGraphNodeMap(liveNodes, historyCapsForMode, filteredRawEdges, {{
            includeAllLiveNodes: true,
            pinnedNodeIds: Array.from(participantSet),
          }})
        : new Map(sourceNodesById);
      const combinedEdges = (typeof combineNetworkGraphEdges === "function")
        ? combineNetworkGraphEdges(filteredRawEdges, nodeMap, {{ mode: historyMode }})
        : [];
      const adjacency = (typeof buildNetworkGraphAdjacency === "function")
        ? buildNetworkGraphAdjacency(nodeMap, combinedEdges)
        : new Map();

      out.set(localNodeId, chatNodeNavigatorInferLinkQuality(0, 4, {{ isSelf: true }}));
      for (const nodeId of participantSet) {{
        if (!isSelectableNodeId(nodeId) || nodeId === localNodeId) continue;
        const node = sourceNodesById.get(nodeId) || nodeMap.get(nodeId) || null;
        const caps = historyCapsMergedById.get(nodeId) || null;
        const hopCandidates = [];
        const liveHopsRaw = Number(node && (node.hops_away ?? node.hopsAway));
        if (Number.isFinite(liveHopsRaw) && liveHopsRaw >= 0) {{
          hopCandidates.push(Math.max(0, Math.trunc(liveHopsRaw)));
        }}
        const capsHopsRaw = Number(caps && caps.last_hops);
        if (Number.isFinite(capsHopsRaw) && capsHopsRaw >= 0) {{
          hopCandidates.push(Math.max(0, Math.trunc(capsHopsRaw)));
        }}
        const pathStats = chatNodeNavigatorEstimatePathDiversity(localNodeId, nodeId, adjacency, 4);
        const inferredHopCount = Number.isFinite(Number(pathStats && pathStats.hops))
          ? Math.max(0, Math.trunc(Number(pathStats.hops)))
          : null;
        const hopCount = hopCandidates.length > 0
          ? Math.min(...hopCandidates)
          : inferredHopCount;
        out.set(nodeId, chatNodeNavigatorInferLinkQuality(hopCount, pathStats.pathCount, {{
          reachable: !!(pathStats && pathStats.reachable),
        }}));
      }}
      if (chatNodeNavigatorLinkQualityCacheByState instanceof WeakMap && safeState && typeof safeState === "object") {{
        chatNodeNavigatorLinkQualityCacheByState.set(safeState, {{
          signature: cacheSignature,
          value: out,
        }});
      }}
      return out;
    }}

    function noteChatNodeNavigatorProgrammaticScrollReset(durationMs = 700) {{
      const duration = Number.isFinite(Number(durationMs))
        ? Math.max(120, Math.trunc(Number(durationMs)))
        : 700;
      chatNodeNavigatorProgrammaticScrollResetUntilMs = Date.now() + duration;
    }}

    function normalizedChatNodeNavigatorTraceVisibilityState(rawState = chatNodeNavigatorTraceVisibilityState) {{
      const safe = (rawState && typeof rawState === "object") ? rawState : {{}};
      return {{
        active: !!safe.active,
        targetId: normalizeNodeId(safe.targetId || ""),
        startedMs: Math.max(0, Number(safe.startedMs) || 0),
        userReleased: !!safe.userReleased,
      }};
    }}

    function syncChatNodeNavigatorTraceVisibilityState() {{
      const previous = normalizedChatNodeNavigatorTraceVisibilityState(chatNodeNavigatorTraceVisibilityState);
      let active = false;
      let targetId = "";
      let startedMs = 0;
      if (typeof normalizedNetworkRoutesLiveTraceState === "function") {{
        const liveState = normalizedNetworkRoutesLiveTraceState(networkRoutesLiveTraceState);
        const liveTargetId = normalizeNodeId(liveState && liveState.targetId);
        if (
          liveState
          && liveState.running === true
          && isSelectableNodeId(liveTargetId)
        ) {{
          active = true;
          targetId = liveTargetId;
          startedMs = Math.max(0, Number(liveState.updatedMs) || 0);
        }}
      }}
      const preserveRelease = (
        active
        && previous.active
        && previous.targetId === targetId
        && previous.startedMs === startedMs
      );
      chatNodeNavigatorTraceVisibilityState = {{
        active,
        targetId: active ? targetId : "",
        startedMs: active ? startedMs : 0,
        userReleased: preserveRelease ? previous.userReleased : false,
      }};
      return chatNodeNavigatorTraceVisibilityState;
    }}

    function chatNodeNavigatorRowForNodeIdInList(listEl, rawNodeId) {{
      const nodeId = normalizeNodeId(rawNodeId || "");
      if (!(listEl instanceof HTMLElement) || !isSelectableNodeId(nodeId)) return null;
      for (const member of listEl.querySelectorAll(".chat-member-item")) {{
        if (normalizeNodeId(member.dataset.nodeId || "") === nodeId) {{
          return member;
        }}
      }}
      return null;
    }}

    function chatNodeNavigatorRowOutOfView(listEl, rowEl) {{
      if (!(listEl instanceof HTMLElement) || !(rowEl instanceof HTMLElement)) return false;
      const listRect = listEl.getBoundingClientRect();
      if (listRect.height <= 2 || listRect.width <= 2) return false;
      const rowRect = rowEl.getBoundingClientRect();
      const topSafe = listRect.top + 3;
      let bottomSafe = listRect.bottom - 3;
      const detailsDrawer = document.getElementById("chat-node-details-drawer");
      if (
        listEl.id === "chat-room-list"
        && detailsDrawer instanceof HTMLElement
        && !detailsDrawer.hidden
        && typeof isVisibleForSelectionScroll === "function"
        && isVisibleForSelectionScroll(detailsDrawer)
      ) {{
        const drawerRect = detailsDrawer.getBoundingClientRect();
        bottomSafe = Math.min(bottomSafe, drawerRect.top - 3);
      }}
      if (bottomSafe <= topSafe + 8) {{
        bottomSafe = topSafe + 8;
      }}
      return rowRect.bottom < topSafe || rowRect.top > bottomSafe;
    }}

    function chatNodeNavigatorFindRowForNodeId(rawNodeId) {{
      const nodeId = normalizeNodeId(rawNodeId || "");
      if (!isSelectableNodeId(nodeId)) return null;
      for (const listId of [
        "chat-room-unread-list",
        "chat-room-meshtastic-list",
        "chat-room-pinned-list",
        "chat-room-list",
      ]) {{
        const listEl = document.getElementById(listId);
        const rowEl = chatNodeNavigatorRowForNodeIdInList(listEl, nodeId);
        if (rowEl instanceof HTMLElement && listEl instanceof HTMLElement) {{
          return {{ listEl, rowEl }};
        }}
      }}
      return null;
    }}

    function keepTraceTargetNodeVisibleInNavigator() {{
      const traceState = syncChatNodeNavigatorTraceVisibilityState();
      if (!traceState.active || traceState.userReleased) return false;
      const located = chatNodeNavigatorFindRowForNodeId(traceState.targetId);
      if (!located) return false;
      if (!chatNodeNavigatorRowOutOfView(located.listEl, located.rowEl)) return false;
      noteChatNodeNavigatorProgrammaticScrollReset(420);
      located.rowEl.scrollIntoView({{ block: "nearest", inline: "nearest" }});
      return true;
    }}

    function clearChatNodeNavigatorSelectionScrollLock() {{
      chatNodeNavigatorSelectionScrollLocked = false;
      chatNodeNavigatorProgrammaticScrollResetUntilMs = 0;
    }}

    function resetChatNodeNavigatorViewport() {{
      const scrollLists = [
        document.getElementById("chat-room-unread-list"),
        document.getElementById("chat-room-meshtastic-list"),
        document.getElementById("chat-room-pinned-list"),
        document.getElementById("chat-room-list"),
      ].filter((listEl) => listEl instanceof HTMLElement);
      if (scrollLists.length <= 0) return;
      const roomList = document.getElementById("chat-room-list");
      const applyReset = () => {{
        noteChatNodeNavigatorProgrammaticScrollReset();
        for (const listEl of scrollLists) {{
          listEl.scrollTop = 0;
        }}
        if (roomList instanceof HTMLElement) {{
          roomList.scrollTop = 0;
          const parentPane = roomList.closest(".chat-member-pane");
          if (parentPane instanceof HTMLElement) {{
            parentPane.scrollTop = 0;
          }}
        }}
      }};
      applyReset();
      requestAnimationFrame(() => {{
        applyReset();
        requestAnimationFrame(() => {{
          applyReset();
        }});
      }});
    }}

    function chatNodeNavigatorStatusSortValue(item, projection) {{
      const statusKey = normalizeFreshnessKey(item && item.status);
      if (statusKey && statusKey !== "unknown") {{
        return (typeof statusRank === "function") ? statusRank(statusKey) : 99;
      }}
      return Number.isFinite(Number(projection && projection.statusSort))
        ? Number(projection.statusSort)
        : 99;
    }}

    function chatNodeNavigatorLastUpdateUnix(item, projection) {{
      const lastSeenFromRoster = Number(item && item.lastSeenUnix);
      if (Number.isFinite(lastSeenFromRoster) && lastSeenFromRoster > 0) {{
        return Math.trunc(lastSeenFromRoster);
      }}
      const lastSeenFromProjection = Number(
        projection
        && projection.fields
        && projection.fields.last_heard
        && projection.fields.last_heard.sort
      );
      if (Number.isFinite(lastSeenFromProjection) && lastSeenFromProjection > 0) {{
        return Math.trunc(lastSeenFromProjection);
      }}
      return 0;
    }}

    function chatNodeNavigatorSortValue(item, projection, sortKeyRaw, nowUnixRaw = null) {{
      const sortKey = normalizeChatNodeNavigatorSortKeyPref(sortKeyRaw);
      const safeItem = item && typeof item === "object" ? item : {{}};
      const safeProjection = projection && typeof projection === "object"
        ? projection
        : nodeExplorerBuildProjection(null);
      const nowUnix = Number.isFinite(Number(nowUnixRaw))
        ? Math.trunc(Number(nowUnixRaw))
        : Math.floor(Date.now() / 1000);
      if (sortKey === "status") {{
        return chatNodeNavigatorStatusSortValue(safeItem, safeProjection);
      }}
      if (sortKey === "activity") {{
        return Number(safeItem.lastMessageUnix) || 0;
      }}
      if (sortKey === "idle") {{
        const lastSeenUnix = chatNodeNavigatorLastUpdateUnix(safeItem, safeProjection);
        if (!Number.isFinite(lastSeenUnix) || lastSeenUnix <= 0) {{
          return Number.MAX_SAFE_INTEGER;
        }}
        return Math.max(0, nowUnix - lastSeenUnix);
      }}
      if (sortKey === "last_heard") {{
        return chatNodeNavigatorLastUpdateUnix(safeItem, safeProjection);
      }}
      const fieldId = normalizeNodeExplorerFieldId(sortKey);
      const field = fieldId && safeProjection.fields
        ? safeProjection.fields[fieldId]
        : null;
      return field ? field.sort : "";
    }}

    function sortChatNodeNavigatorParticipants(
      participantsList,
      nodesById,
      nowUnix = Math.floor(Date.now() / 1000),
      historyCapsById = null,
      unreadDirectByPeer = null,
      linkQualityByNode = null
    ) {{
      const rows = Array.isArray(participantsList) ? participantsList : [];
      const sourceNodes = nodesById instanceof Map ? nodesById : new Map();
      const sourceHistoryCaps = historyCapsById instanceof Map ? historyCapsById : new Map();
      const sourceUnreadDirectByPeer = normalizeChatNodeNavigatorUnreadDirectByPeer(unreadDirectByPeer);
      const sourceLinkQualityByNode = linkQualityByNode instanceof Map ? linkQualityByNode : new Map();
      const sortKey = normalizeChatNodeNavigatorSortKeyPref(chatNodeNavigatorSortKey);
      const sortDir = normalizeChatNodeNavigatorSortDirPref(chatNodeNavigatorSortDir);
      const usePrioritySections = chatNodeNavigatorUsesPrioritySections(sortKey);
      const projectionById = new Map();
      const projectionFor = (entry) => {{
        const nodeId = normalizeNodeId(entry && entry.id);
        if (projectionById.has(nodeId)) {{
          return projectionById.get(nodeId);
        }}
        const node = sourceNodes.get(nodeId) || null;
        const projection = nodeExplorerBuildProjection(
          node || {{ id: nodeId, long_name: (entry && entry.name) || nodeId }},
          {{
            nowUnix,
            historyCaps: sourceHistoryCaps.get(nodeId) || null,
            linkQuality: sourceLinkQualityByNode.get(nodeId) || null,
            freshnessUnix: entry && entry.lastSeenUnix,
          }}
        );
        projectionById.set(nodeId, projection);
        return projection;
      }};
      rows.sort((a, b) => {{
        const unreadDiff = (
          chatNodeNavigatorUnreadDirectCount(sourceUnreadDirectByPeer, b && b.id)
          - chatNodeNavigatorUnreadDirectCount(sourceUnreadDirectByPeer, a && a.id)
        );
        if (unreadDiff !== 0) return unreadDiff;

        const pinDiff = activeChatChannel === "direct" && usePrioritySections
          ? (Number(!!(b && b.p2pPinned)) - Number(!!(a && a.p2pPinned)))
          : 0;
        if (pinDiff !== 0) return pinDiff;

        const aProjection = projectionFor(a);
        const bProjection = projectionFor(b);
        const aValue = chatNodeNavigatorSortValue(a, aProjection, sortKey, nowUnix);
        const bValue = chatNodeNavigatorSortValue(b, bProjection, sortKey, nowUnix);
        const cmp = chatNodeNavigatorCompareSortValues(aValue, bValue);
        if (cmp !== 0) {{
          return sortDir === "desc" ? -cmp : cmp;
        }}

        const statusCmp = chatNodeNavigatorCompareSortValues(
          chatNodeNavigatorStatusSortValue(a, aProjection),
          chatNodeNavigatorStatusSortValue(b, bProjection)
        );
        if (statusCmp !== 0) return statusCmp;

        // Status is the default grouped view. Within each freshness bucket,
        // keep the nodes we most recently received from at the top.
        if (sortKey === "status") {{
          const receivedCmp = chatNodeNavigatorCompareSortValues(
            chatNodeNavigatorLastUpdateUnix(b, bProjection),
            chatNodeNavigatorLastUpdateUnix(a, aProjection)
          );
          if (receivedCmp !== 0) return receivedCmp;
        }}

        const activityCmp = chatNodeNavigatorCompareSortValues(
          Number(b && b.lastMessageUnix) || 0,
          Number(a && a.lastMessageUnix) || 0
        );
        if (activityCmp !== 0) return activityCmp;

        const nameCmp = String((a && (a.name || a.id)) || "").localeCompare(String((b && (b.name || b.id)) || ""));
        if (nameCmp !== 0) return nameCmp;
        return String((a && a.id) || "").localeCompare(String((b && b.id) || ""));
      }});
      return rows;
    }}

    function buildChatNodeNavigatorPacketSparklinePath(bucketValuesRaw, width = 56, height = 12) {{
      const buckets = Array.isArray(bucketValuesRaw)
        ? bucketValuesRaw.map((value) => Math.max(0, Number(value) || 0))
        : [];
      const plotWidth = Math.max(12, Number(width) || 56);
      const plotHeight = Math.max(8, Number(height) || 12);
      const baselineY = Math.max(1, plotHeight - 1);
      if (buckets.length <= 0) {{
        return `M 0 ${{baselineY.toFixed(2)}} L ${{plotWidth.toFixed(2)}} ${{baselineY.toFixed(2)}}`;
      }}
      const maxValue = Math.max(0, ...buckets);
      const padY = 1;
      const usableHeight = Math.max(2, plotHeight - (padY * 2));
      const points = buckets.map((value, idx) => {{
        const x = buckets.length <= 1
          ? (plotWidth / 2)
          : ((idx / Math.max(1, buckets.length - 1)) * plotWidth);
        const y = maxValue > 0
          ? (padY + ((maxValue - value) / maxValue) * usableHeight)
          : baselineY;
        return {{ x, y }};
      }});
      if (typeof buildSmoothSvgPath === "function") {{
        const smoothPath = buildSmoothSvgPath(points, 0.2);
        if (smoothPath) {{
          return smoothPath;
        }}
      }}
      return points.map((point, idx) => (
        `${{idx === 0 ? "M" : "L"}} ${{point.x.toFixed(2)}} ${{point.y.toFixed(2)}}`
      )).join(" ");
    }}

    function classifyChatNodeNavigatorPacketSparklineTrend(bucketValuesRaw) {{
      const buckets = Array.isArray(bucketValuesRaw)
        ? bucketValuesRaw.map((value) => Math.max(0, Number(value) || 0))
        : [];
      if (buckets.length <= 1) return "trend-flat";
      const segmentSize = Math.max(1, Math.trunc(buckets.length / 3));
      const startSlice = buckets.slice(0, segmentSize);
      const endSlice = buckets.slice(-segmentSize);
      const avg = (rows) => {{
        const list = Array.isArray(rows) ? rows : [];
        if (list.length === 0) return 0;
        const total = list.reduce((sum, value) => sum + (Number(value) || 0), 0);
        return total / Math.max(1, list.length);
      }};
      const startAvg = avg(startSlice);
      const endAvg = avg(endSlice);
      const delta = endAvg - startAvg;
      const threshold = Math.max(0.5, Math.max(...buckets, 0) * 0.15);
      if (delta > threshold) return "trend-up";
      if (delta < -threshold) return "trend-down";
      return "trend-flat";
    }}

    function buildChatNodeNavigatorPacketTrendMapsFromPayload(trendPayload) {{
      const payload = (trendPayload && typeof trendPayload === "object") ? trendPayload : null;
      const packetTickerByNode = new Map();
      const packetSparklineByNode = new Map();
      const nodesPayload = payload && payload.nodes && typeof payload.nodes === "object"
        ? payload.nodes
        : null;
      if (!nodesPayload) {{
        return null;
      }}
      const windowSec = Math.max(
        60,
        Math.trunc(Number(payload.window_seconds ?? payload.windowSeconds ?? 3600) || 3600)
      );
      const bucketCount = Math.max(
        1,
        Math.trunc(Number(payload.bucket_count ?? payload.bucketCount ?? 24) || 24)
      );
      for (const [rawNodeId, rawNodeTrend] of Object.entries(nodesPayload)) {{
        const nodeId = normalizeNodeId(rawNodeId);
        if (!isSelectableNodeId(nodeId)) continue;
        const trend = rawNodeTrend && typeof rawNodeTrend === "object" ? rawNodeTrend : {{}};
        const buckets = Array.isArray(trend.buckets)
          ? trend.buckets.slice(0, bucketCount).map((value) => Math.max(0, Math.trunc(Number(value) || 0)))
          : [];
        while (buckets.length < bucketCount) {{
          buckets.push(0);
        }}
        const txTotal = Math.max(0, Math.trunc(Number(trend.txTotal ?? trend.tx_total ?? 0) || 0));
        const txRecent5m = Math.max(0, Math.trunc(Number(trend.txRecent5m ?? trend.tx_recent_5m ?? 0) || 0));
        const rxTotal = Math.max(0, Math.trunc(Number(trend.rxTotal ?? trend.rx_total ?? 0) || 0));
        const rxRecent5m = Math.max(0, Math.trunc(Number(trend.rxRecent5m ?? trend.rx_recent_5m ?? 0) || 0));
        const lastTxUnix = Number(trend.lastTxUnix ?? trend.last_tx_unix);
        const lastRxUnix = Number(trend.lastRxUnix ?? trend.last_rx_unix);
        const lastPacketUnix = Number(trend.lastPacketUnix ?? trend.last_packet_unix);
        packetTickerByNode.set(nodeId, {{
          total: Math.max(0, Math.trunc(Number(trend.total) || (txTotal + rxTotal))),
          recent5m: Math.max(0, Math.trunc(Number(trend.recent5m ?? trend.recent_5m) || (txRecent5m + rxRecent5m))),
          txTotal,
          txRecent5m,
          rxTotal,
          rxRecent5m,
          lastPacketUnix: Number.isFinite(lastPacketUnix) && lastPacketUnix > 0
            ? lastPacketUnix
            : latestUnixTimestamp(lastTxUnix, lastRxUnix),
          lastTxUnix: Number.isFinite(lastTxUnix) && lastTxUnix > 0 ? lastTxUnix : null,
          lastRxUnix: Number.isFinite(lastRxUnix) && lastRxUnix > 0 ? lastRxUnix : null,
        }});
        packetSparklineByNode.set(nodeId, {{
          buckets,
          windowSec,
          bucketCount,
        }});
      }}
      return {{ packetTickerByNode, packetSparklineByNode }};
    }}

    function buildChatNodeNavigatorPacketTrendMaps(
      rawPackets = [],
      localNodeId = "",
      nowUnix = Math.floor(Date.now() / 1000),
      trendPayload = null
    ) {{
      const packetTickerByNode = new Map();
      const packetSparklineByNode = new Map();
      if (!nodeNavigatorPacketTrendEnabled()) {{
        return {{ packetTickerByNode, packetSparklineByNode }};
      }}
      const persistedMaps = buildChatNodeNavigatorPacketTrendMapsFromPayload(trendPayload);
      if (persistedMaps) {{
        return persistedMaps;
      }}

      const packetSparklineWindowSec = 60 * 60;
      const packetSparklineBucketCount = 24;
      const packetSparklineBucketSpanSec = packetSparklineWindowSec / packetSparklineBucketCount;

      const ensurePacketBucket = (nodeId) => {{
        if (!isSelectableNodeId(nodeId)) return null;
        let bucket = packetTickerByNode.get(nodeId);
        if (!bucket) {{
          bucket = {{
            total: 0,
            recent5m: 0,
            txTotal: 0,
            txRecent5m: 0,
            rxTotal: 0,
            rxRecent5m: 0,
            lastPacketUnix: null,
            lastTxUnix: null,
            lastRxUnix: null,
          }};
          packetTickerByNode.set(nodeId, bucket);
        }}
        return bucket;
      }};

      const ensureSparklineBucket = (nodeId) => {{
        if (!isSelectableNodeId(nodeId)) return null;
        let spark = packetSparklineByNode.get(nodeId);
        if (!spark) {{
          spark = {{
            buckets: new Array(packetSparklineBucketCount).fill(0),
            windowSec: packetSparklineWindowSec,
            bucketCount: packetSparklineBucketCount,
          }};
          packetSparklineByNode.set(nodeId, spark);
        }}
        return spark;
      }};

      const touchPacketDirection = (nodeId, direction, packetUnix, inRecent5m) => {{
        const bucket = ensurePacketBucket(nodeId);
        if (!bucket) return;
        if (direction === "tx") {{
          bucket.txTotal += 1;
          bucket.lastTxUnix = latestUnixTimestamp(bucket.lastTxUnix, packetUnix);
          if (inRecent5m) bucket.txRecent5m += 1;
        }} else if (direction === "rx") {{
          bucket.rxTotal += 1;
          bucket.lastRxUnix = latestUnixTimestamp(bucket.lastRxUnix, packetUnix);
          if (inRecent5m) bucket.rxRecent5m += 1;
        }}
        bucket.total = Math.max(
          0,
          Math.trunc(Number(bucket.txTotal) || 0) + Math.trunc(Number(bucket.rxTotal) || 0)
        );
        bucket.recent5m = Math.max(
          0,
          Math.trunc(Number(bucket.txRecent5m) || 0) + Math.trunc(Number(bucket.rxRecent5m) || 0)
        );
        bucket.lastPacketUnix = latestUnixTimestamp(bucket.lastTxUnix, bucket.lastRxUnix, packetUnix);
      }};

      const touchSparkline = (nodeId, packetUnix) => {{
        if (!Number.isFinite(packetUnix) || packetUnix <= 0) return;
        const spark = ensureSparklineBucket(nodeId);
        if (!spark) return;
        const ageSec = nowUnix - packetUnix;
        if (ageSec < 0 || ageSec > packetSparklineWindowSec) return;
        let bucketIndex = Math.floor((packetSparklineWindowSec - ageSec) / packetSparklineBucketSpanSec);
        if (!Number.isFinite(bucketIndex)) {{
          bucketIndex = packetSparklineBucketCount - 1;
        }}
        bucketIndex = Math.max(0, Math.min(packetSparklineBucketCount - 1, Math.trunc(bucketIndex)));
        spark.buckets[bucketIndex] = Math.max(
          0,
          Math.trunc(Number(spark.buckets[bucketIndex]) || 0) + 1
        );
      }};

      for (const packetEntry of (Array.isArray(rawPackets) ? rawPackets : [])) {{
        const summary = (packetEntry && packetEntry.summary && typeof packetEntry.summary === "object")
          ? packetEntry.summary
          : {{}};
        const packet = (packetEntry && packetEntry.packet && typeof packetEntry.packet === "object")
          ? packetEntry.packet
          : {{}};
        const isRadioPacket = (typeof isMeshRadioActivityPacket === "function")
          ? isMeshRadioActivityPacket(packetEntry, localNodeId)
          : true;
        if (!isRadioPacket) continue;
        const fromId = normalizeNodeId(
          summary.from_id
          ?? summary.fromId
          ?? summary.from
          ?? packet.from_id
          ?? packet.fromId
          ?? packet.from
        );
        const toId = normalizeNodeId(
          summary.to_id
          ?? summary.toId
          ?? summary.to
          ?? packet.to_id
          ?? packet.toId
          ?? packet.to
          ?? packet.destination
        );
        const packetUnix = latestUnixTimestamp(
          summary.rx_time_unix,
          summary.captured_at,
          summary.rx_time,
          summary.time,
          packetEntry && (packetEntry.captured_at || packetEntry.rx_time || packetEntry.time),
          packet.rxTime,
        );
        const inRecent5m = (
          Number.isFinite(packetUnix)
          && packetUnix > 0
          && (nowUnix - packetUnix) <= 300
        );
        touchPacketDirection(fromId, "tx", packetUnix, inRecent5m);
        touchPacketDirection(toId, "rx", packetUnix, inRecent5m);
        touchSparkline(fromId, packetUnix);
        touchSparkline(toId, packetUnix);
      }}

      return {{ packetTickerByNode, packetSparklineByNode }};
    }}

    function bindChatNodeNavigatorListInteractions(roomList = null) {{
      const targetList = roomList instanceof HTMLElement
        ? roomList
        : document.getElementById("chat-room-list");
      if (!(targetList instanceof HTMLElement) || targetList.dataset.memberClickBound === "1") return;
      targetList.dataset.memberClickBound = "1";
      targetList.addEventListener("scroll", () => {{
        const nowMs = Date.now();
        if (
          nowMs > Number(chatNodeNavigatorProgrammaticScrollResetUntilMs || 0)
          && typeof syncChatNodeNavigatorTraceVisibilityState === "function"
        ) {{
          const traceState = syncChatNodeNavigatorTraceVisibilityState();
          if (traceState.active && !traceState.userReleased) {{
            const rowEl = chatNodeNavigatorRowForNodeIdInList(targetList, traceState.targetId);
            if (rowEl instanceof HTMLElement && chatNodeNavigatorRowOutOfView(targetList, rowEl)) {{
              chatNodeNavigatorTraceVisibilityState = {{
                ...traceState,
                userReleased: true,
              }};
            }}
          }}
        }}
        if (!chatNodeNavigatorSelectionScrollLocked) return;
        if (nowMs <= Number(chatNodeNavigatorProgrammaticScrollResetUntilMs || 0)) return;
        clearChatNodeNavigatorSelectionScrollLock();
      }}, {{ passive: true }});
      targetList.addEventListener("click", (ev) => {{
        const target = ev.target;
        if (!(target instanceof Element)) return;
        const showMoreBtn = target.closest(".chat-roster-load-btn");
        if (showMoreBtn instanceof HTMLButtonElement && targetList.contains(showMoreBtn)) {{
          ev.preventDefault();
          ev.stopPropagation();
          const baseLimit = Math.max(1, Math.trunc(Number(chatRosterMaxEntries) || 180));
          const currentLimit = Math.max(baseLimit, Math.trunc(Number(chatRosterVisibleLimit) || baseLimit));
          const hiddenCount = Math.max(0, Math.trunc(Number(showMoreBtn.dataset.rosterHiddenCount) || 0));
          chatRosterVisibleLimit = currentLimit + Math.max(1, Math.min(baseLimit, hiddenCount || baseLimit));
          if (typeof renderChatNodeNavigatorList === "function" && latestState) {{
            renderChatNodeNavigatorList(latestState);
          }}
          return;
        }}
        const removeBtn = target.closest(".chat-peer-remove-btn");
        if (removeBtn instanceof HTMLButtonElement) {{
          ev.preventDefault();
          ev.stopPropagation();
          const nodeId = normalizeNodeId(removeBtn.dataset.nodeId || "");
          if (!isCanonicalNodeId(nodeId)) return;
          const removed = removeManualDirectPeer(nodeId);
          if (!removed) return;
          setChatSendStatus(`Peer ${{nodeId}} removed from peer-to-peer list.`);
          renderChatPeerAddPanel(latestState);
          if (typeof renderChatNodeNavigatorList === "function" && latestState) {{
            renderChatNodeNavigatorList(latestState);
          }}
          return;
        }}
        if (target.closest("button")) return;
        const member = target.closest(".chat-member-item");
        if (!(member instanceof HTMLElement) || !targetList.contains(member)) return;
        const nodeId = normalizeNodeId(member.dataset.nodeId || "");
        const unreadDirectCount = Math.max(0, Math.trunc(Number(member.dataset.unreadDirectCount) || 0));
        if (!isSelectableNodeId(nodeId)) return;
        selectNode(nodeId, true, false);
        const selectedAfterClick = normalizeNodeId(selectedNodeId || "");
        if (
          unreadDirectCount > 0
          && selectedAfterClick === nodeId
          && typeof setChatNodeDetailsDrawerTab === "function"
        ) {{
          setChatNodeDetailsDrawerTab("messages", {{
            fetchHistory: false,
          }});
        }}
      }});
    }}

    function chatNodeNavigatorHistoryCapsDisplayName(caps, fallbackNodeId = "") {{
      const safeCaps = (caps && typeof caps === "object") ? caps : null;
      const longName = String(safeCaps && safeCaps.last_long_name || "").trim();
      if (longName) return longName;
      const shortName = String(safeCaps && safeCaps.last_short_name || "").trim();
      if (shortName) return shortName;
      return String(fallbackNodeId || "").trim();
