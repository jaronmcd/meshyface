        let index = 0;
        while (true) {{
          const left = (index * 2) + 1;
          const right = left + 1;
          let smallest = index;
          if (left < heap.length && heap[left].distance < heap[smallest].distance) {{
            smallest = left;
          }}
          if (right < heap.length && heap[right].distance < heap[smallest].distance) {{
            smallest = right;
          }}
          if (smallest === index) break;
          const swap = heap[index];
          heap[index] = heap[smallest];
          heap[smallest] = swap;
          index = smallest;
        }}
      }}
      return first;
    }}

    function chatNodeNavigatorFindWeightedPath(sourceNodeId, targetNodeId, adjacency, blockedEdgeKeys = null) {{
      const source = normalizeNodeId(sourceNodeId || "");
      const target = normalizeNodeId(targetNodeId || "");
      if (
        !isSelectableNodeId(source)
        || !isSelectableNodeId(target)
        || !(adjacency instanceof Map)
        || !adjacency.has(source)
        || !adjacency.has(target)
      ) {{
        return {{ path: [], edges: [], cost: Infinity }};
