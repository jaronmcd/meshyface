    let chatNodeNavigatorSearchBoundsResizeBound = false;

    function syncChatNodeNavigatorSearchBounds() {{
      const panel = document.getElementById("chat-left-panel");
      const unreadList = document.getElementById("chat-room-unread-list");
      const meshtasticList = document.getElementById("chat-room-meshtastic-list");
      const pinnedList = document.getElementById("chat-room-pinned-list");
      const roomList = document.getElementById("chat-room-list");
      const bottomBar = document.querySelector(".chat-left-bottom-bar");
      const anchor = (
        unreadList instanceof HTMLElement
          ? unreadList.querySelector(".chat-member-item, .chat-member-empty")
          : null
      ) || (
        meshtasticList instanceof HTMLElement
          ? meshtasticList.querySelector(".chat-member-item, .chat-member-empty")
          : null
      ) || (
        pinnedList instanceof HTMLElement
          ? pinnedList.querySelector(".chat-member-item, .chat-member-empty")
          : null
      ) || (
        roomList instanceof HTMLElement
          ? roomList.querySelector(".chat-member-item, .chat-member-empty")
          : null
      );
      if (!(panel instanceof HTMLElement) || !(bottomBar instanceof HTMLElement)) return;

      const defaultInset = "6px";
      if (!(anchor instanceof HTMLElement)) {{
        bottomBar.style.setProperty("--chat-user-search-inline-start", defaultInset);
        bottomBar.style.setProperty("--chat-user-search-inline-end", defaultInset);
        return;
      }}

      const panelRect = panel.getBoundingClientRect();
      const anchorRect = anchor.getBoundingClientRect();
      const leftInset = Math.max(0, Math.round((anchorRect.left - panelRect.left) * 100) / 100);
      const rightInset = Math.max(0, Math.round((panelRect.right - anchorRect.right) * 100) / 100);
      bottomBar.style.setProperty("--chat-user-search-inline-start", `${leftInset}px`);
      bottomBar.style.setProperty("--chat-user-search-inline-end", `${rightInset}px`);
    }}

    function scheduleChatNodeNavigatorSearchBoundsSync() {{
      if (typeof requestAnimationFrame === "function") {{
        requestAnimationFrame(() => {{
          syncChatNodeNavigatorSearchBounds();
        }});
      }} else {{
        syncChatNodeNavigatorSearchBounds();
      }}
    }}

    function renderChatNodeNavigatorList(state = latestState, options = null) {{
      const opts = options && typeof options === "object" ? options : {{}};
      const safeState = state && typeof state === "object" ? state : (latestState || {{}});
      const unreadShell = document.getElementById("chat-room-unread-shell");
      const unreadList = document.getElementById("chat-room-unread-list");
      const unreadCountEl = document.getElementById("chat-room-unread-count");
      const meshtasticShell = document.getElementById("chat-room-meshtastic-shell");
      const meshtasticList = document.getElementById("chat-room-meshtastic-list");
      const meshtasticCountEl = document.getElementById("chat-room-meshtastic-count");
      const pinnedShell = document.getElementById("chat-room-pinned-shell");
      const pinnedList = document.getElementById("chat-room-pinned-list");
      const pinnedCountEl = document.getElementById("chat-room-pinned-count");
      const roomList = document.getElementById("chat-room-list");
      if (!(roomList instanceof HTMLElement)) return null;
      const inlineHost = document.getElementById("chat-node-details-inline-host");
      let forceRosterSectionRender = false;
      if (inlineHost instanceof HTMLElement && inlineHost.closest(".chat-member-list, .chat-member-pinned-list")) {{
        forceRosterSectionRender = true;
        resetChatNodeDetailsInlineHost(inlineHost);
        syncChatNodeDetailsInlineDockState(null);
      }}
      if (!chatNodeNavigatorSearchBoundsResizeBound && typeof window !== "undefined" && typeof window.addEventListener === "function") {{
        chatNodeNavigatorSearchBoundsResizeBound = true;
        window.addEventListener("resize", scheduleChatNodeNavigatorSearchBoundsSync);
      }}
      const usersTitle = document.getElementById("chat-users-title");
      if (usersTitle instanceof HTMLElement) {{
        usersTitle.textContent = activeChatChannel === "direct"
          ? "Users (Peer-to-peer)"
          : "Users (Everyone)";
      }}
      const nowUnix = Number.isFinite(Number(opts.nowUnix))
        ? Math.trunc(Number(opts.nowUnix))
        : Math.floor(Date.now() / 1000);
      const nodes = Array.isArray(safeState.nodes) ? safeState.nodes : [];
      const nodesById = opts.nodesById instanceof Map
        ? opts.nodesById
        : new Map(nodes.map((node) => [normalizeNodeId(node && node.id), node]));
      const historyCapsObj = (safeState && safeState.history_caps && typeof safeState.history_caps === "object")
        ? safeState.history_caps
        : null;
      const historyCapsById = opts.historyCapsById instanceof Map
        ? opts.historyCapsById
        : new Map(
            Object.entries(historyCapsObj || {{}})
              .map(([rawNodeId, caps]) => [normalizeNodeId(rawNodeId), caps])
              .filter(([nodeId, caps]) => isSelectableNodeId(nodeId) && caps && typeof caps === "object")
          );
      const recentChat = Array.isArray((safeState.traffic || {{}}).recent_chat)
        ? (safeState.traffic || {{}}).recent_chat
        : [];
      const latestChatTouchByNode = (typeof mapLatestChatTouchInfo === "function")
        ? mapLatestChatTouchInfo(recentChat)
        : new Map();
      const resolveChatNodeFreshnessFn = (typeof opts.resolveChatNodeFreshnessFn === "function")
        ? opts.resolveChatNodeFreshnessFn
        : ((rawNodeId) => {{
            const nodeId = normalizeNodeId(rawNodeId || "");
            const node = nodesById.get(nodeId) || null;
            const caps = historyCapsById.get(nodeId) || null;
            const chatTouch = latestChatTouchByNode.get(nodeId) || null;
            const lastSeenUnix = computeNodeFreshnessUnix(node, caps, chatTouch);
            return {{
              id: nodeId,
              node,
              historyCaps: caps,
              lastSeenUnix,
              status: freshnessStatus(lastSeenUnix, nowUnix),
            }};
          }});
      const packetMaps = (
        opts.packetTickerByNode instanceof Map
        && opts.packetSparklineByNode instanceof Map
      )
        ? {{
            packetTickerByNode: opts.packetTickerByNode,
            packetSparklineByNode: opts.packetSparklineByNode,
          }}
        : buildChatNodeNavigatorPacketTrendMaps(
            Array.isArray((safeState.traffic || {{}}).recent_packets)
              ? (safeState.traffic || {{}}).recent_packets
              : [],
            resolveLocalNodeId(safeState),
            nowUnix,
            (safeState.traffic && typeof safeState.traffic === "object")
              ? safeState.traffic.node_packet_trends
              : null
          );
      const malformedTextByNode = opts.malformedTextByNode instanceof Map
        ? opts.malformedTextByNode
        : (
            typeof mapMalformedTextPayloadByNode === "function"
              ? mapMalformedTextPayloadByNode(
                  Array.isArray((safeState.traffic || {{}}).recent_packets)
                    ? (safeState.traffic || {{}}).recent_packets
                    : []
                )
              : new Map()
          );
      const unreadDirectByPeer = normalizeChatNodeNavigatorUnreadDirectByPeer(opts.unreadDirectByPeer);
      const pinDirectHistory = normalizeChatNodeNavigatorPinDirectHistoryPref(chatNodeNavigatorPinDirectHistory);
      const directHistoryPeerIds = chatNodeNavigatorDirectHistoryPeerIds(safeState);
      const visibleMetaFieldIds = normalizeChatNodeNavigatorMetaFieldIdsPref(chatNodeNavigatorMetaFieldIds, {{
        fallbackToDefaults: false,
      }});
      const shouldComputeLinkQuality = chatNodeNavigatorShouldComputeLinkQuality(
        visibleMetaFieldIds,
        chatNodeNavigatorSortKey
      );
      const rosterQuery = globalNodeSearchQuery();
      const rosterSource = Array.isArray(opts.rosterAll)
        ? opts.rosterAll.slice()
        : buildChatNodeNavigatorDefaultRoster(
            safeState,
            nodesById,
            historyCapsById,
            resolveChatNodeFreshnessFn,
            nowUnix,
            {{
              searchQuery: rosterQuery,
              includeHistoricalOnDemand: true,
            }}
          );
      const rosterNodeIds = rosterSource.map((item) => normalizeNodeId(item && item.id || ""));
      const linkQualityByNode = opts.linkQualityByNode instanceof Map
        ? opts.linkQualityByNode
        : (
            shouldComputeLinkQuality
              ? buildChatNodeNavigatorLinkQualityByNode(
                  safeState,
                  nodesById,
                  historyCapsById,
                  rosterNodeIds
                )
              : new Map()
          );
      const rosterAll = typeof sortChatNodeNavigatorParticipants === "function"
        ? sortChatNodeNavigatorParticipants(
            rosterSource,
            nodesById,
            nowUnix,
            historyCapsById,
            unreadDirectByPeer,
            linkQualityByNode
          )
        : rosterSource;
      const rosterFiltered = rosterAll.filter((item) => (
        matchesIdOrNameQuery(item && item.id, item && item.name, rosterQuery, {{
          node: nodesById.get(normalizeNodeId(item && item.id)),
        }})
      ));
      chatRosterModel = rosterAll;
      const usePrioritySections = chatNodeNavigatorUsesPrioritySections(chatNodeNavigatorSortKey);
      const meshtasticFavoriteIds = (typeof meshtasticFavoriteNodeIdsFromState === "function")
        ? meshtasticFavoriteNodeIdsFromState(safeState)
        : new Set();
      const pinnedUnreadRows = [];
      const meshtasticRows = [];
      const pinnedManualRows = [];
      const historyPriorityRows = [];
      const regularRows = [];
      for (const item of rosterFiltered) {{
        const nodeId = normalizeNodeId(item && item.id);
        if (!usePrioritySections) {{
          regularRows.push(item);
          continue;
        }}
        if (chatNodeNavigatorUnreadDirectCount(unreadDirectByPeer, nodeId) > 0) {{
          pinnedUnreadRows.push(item);
        }} else if (meshtasticFavoriteIds.has(nodeId)) {{
          meshtasticRows.push(item);
        }} else if ((typeof isPinnedNode === "function") && isPinnedNode(nodeId)) {{
          pinnedManualRows.push(item);
        }} else if (pinDirectHistory && directHistoryPeerIds.has(nodeId)) {{
          historyPriorityRows.push(item);
        }} else {{
          regularRows.push(item);
        }}
      }}
      const rowRenderContext = {{
        state: safeState,
        nowUnix,
        nodesById,
        historyCapsById,
        packetTickerByNode: packetMaps.packetTickerByNode,
        packetSparklineByNode: packetMaps.packetSparklineByNode,
        malformedTextByNode,
        unreadDirectByPeer,
        directHistoryPeerIds,
        linkQualityByNode,
        visibleMetaFieldIds,
        resolveChatNodeFreshnessFn,
      }};
      if (unreadShell instanceof HTMLElement && unreadList instanceof HTMLElement) {{
        const nextUnreadHtml = usePrioritySections && pinnedUnreadRows.length > 0
          ? pinnedUnreadRows.map((item) => buildChatNodeNavigatorMemberHtml(item, rowRenderContext)).join("")
          : "";
        const previousUnreadHtml = !forceRosterSectionRender && (typeof unreadList.__meshLastInnerHtml_chat_room_unread_list === "string")
          ? unreadList.__meshLastInnerHtml_chat_room_unread_list
          : null;
        if (previousUnreadHtml !== nextUnreadHtml) {{
          unreadList.innerHTML = nextUnreadHtml;
          unreadList.__meshLastInnerHtml_chat_room_unread_list = nextUnreadHtml;
        }}
        if (usePrioritySections) {{
          unreadShell.hidden = pinnedUnreadRows.length <= 0;
        }} else {{
          unreadShell.hidden = true;
        }}
        if (unreadCountEl instanceof HTMLElement) {{
          unreadCountEl.textContent = String(usePrioritySections ? pinnedUnreadRows.length : 0);
        }}
      }}
      if (meshtasticShell instanceof HTMLElement && meshtasticList instanceof HTMLElement) {{
        const nextMeshtasticHtml = usePrioritySections
          ? (
              meshtasticRows.length > 0
                ? meshtasticRows.map((item) => buildChatNodeNavigatorMemberHtml(item, rowRenderContext)).join("")
                : '<div class="chat-member-empty">No Meshtastic favorites yet.</div>'
            )
          : "";
        const previousMeshtasticHtml = !forceRosterSectionRender && (typeof meshtasticList.__meshLastInnerHtml_chat_room_meshtastic_list === "string")
          ? meshtasticList.__meshLastInnerHtml_chat_room_meshtastic_list
          : null;
        if (previousMeshtasticHtml !== nextMeshtasticHtml) {{
          meshtasticList.innerHTML = nextMeshtasticHtml;
          meshtasticList.__meshLastInnerHtml_chat_room_meshtastic_list = nextMeshtasticHtml;
        }}
        if (usePrioritySections) {{
          meshtasticShell.hidden = false;
        }} else {{
          meshtasticShell.hidden = true;
        }}
        if (meshtasticCountEl instanceof HTMLElement) {{
          meshtasticCountEl.textContent = String(usePrioritySections ? meshtasticRows.length : 0);
        }}
      }}
      if (pinnedShell instanceof HTMLElement && pinnedList instanceof HTMLElement) {{
        const nextPinnedHtml = usePrioritySections && pinnedManualRows.length > 0
          ? pinnedManualRows.map((item) => buildChatNodeNavigatorMemberHtml(item, rowRenderContext)).join("")
          : "";
        const previousPinnedHtml = !forceRosterSectionRender && (typeof pinnedList.__meshLastInnerHtml_chat_room_pinned_list === "string")
          ? pinnedList.__meshLastInnerHtml_chat_room_pinned_list
          : null;
        if (previousPinnedHtml !== nextPinnedHtml) {{
          pinnedList.innerHTML = nextPinnedHtml;
          pinnedList.__meshLastInnerHtml_chat_room_pinned_list = nextPinnedHtml;
        }}
        if (usePrioritySections) {{
          pinnedShell.hidden = pinnedManualRows.length <= 0;
        }} else {{
          pinnedShell.hidden = true;
        }}
        if (pinnedCountEl instanceof HTMLElement) {{
          pinnedCountEl.textContent = String(usePrioritySections ? pinnedManualRows.length : 0);
        }}
      }}
      const orderedRoomRows = historyPriorityRows.concat(regularRows);
      const pinnedSectionCount = usePrioritySections
        ? (pinnedUnreadRows.length + meshtasticRows.length + pinnedManualRows.length)
        : 0;
      const rosterBaseLimit = Math.max(1, Math.trunc(Number(chatRosterMaxEntries) || 180));
      const currentRosterLimit = Math.max(
        rosterBaseLimit,
        Math.trunc(Number(chatRosterVisibleLimit) || rosterBaseLimit)
      );
      const hasRosterQuery = String(rosterQuery || "").trim().length > 0;
      const selectedRoomRowIndex = (() => {{
        const selectedId = normalizeNodeId(selectedNodeId || "");
        if (!isSelectableNodeId(selectedId)) return -1;
        return orderedRoomRows.findIndex((item) => normalizeNodeId(item && item.id) === selectedId);
      }})();
      const traceRoomRowIndex = (() => {{
        if (typeof syncChatNodeNavigatorTraceVisibilityState !== "function") return -1;
        const traceState = syncChatNodeNavigatorTraceVisibilityState();
        const traceTargetId = normalizeNodeId(traceState && traceState.targetId);
        if (!(traceState && traceState.active && isSelectableNodeId(traceTargetId))) return -1;
        return orderedRoomRows.findIndex((item) => normalizeNodeId(item && item.id) === traceTargetId);
      }})();
      const shouldWindowRoomRows = !hasRosterQuery && orderedRoomRows.length > 0;
      let roomRowRenderLimit = shouldWindowRoomRows
        ? Math.max(0, currentRosterLimit - pinnedSectionCount)
        : orderedRoomRows.length;
      if (selectedRoomRowIndex >= 0) {{
        roomRowRenderLimit = Math.max(roomRowRenderLimit, selectedRoomRowIndex + 1);
      }}
      if (traceRoomRowIndex >= 0) {{
        roomRowRenderLimit = Math.max(roomRowRenderLimit, traceRoomRowIndex + 1);
      }}
      roomRowRenderLimit = Math.max(0, Math.min(orderedRoomRows.length, Math.trunc(Number(roomRowRenderLimit) || 0)));
      const visibleRoomRows = shouldWindowRoomRows
        ? orderedRoomRows.slice(0, roomRowRenderLimit)
        : orderedRoomRows;
      const hiddenRoomRowCount = Math.max(0, orderedRoomRows.length - visibleRoomRows.length);
      const renderedRoomRowsHtml = visibleRoomRows.length > 0
        ? visibleRoomRows.map((item) => buildChatNodeNavigatorMemberHtml(item, {{
            nowUnix,
            nodesById,
            historyCapsById,
            packetTickerByNode: packetMaps.packetTickerByNode,
            packetSparklineByNode: packetMaps.packetSparklineByNode,
            malformedTextByNode,
            unreadDirectByPeer,
            directHistoryPeerIds,
            linkQualityByNode,
            resolveChatNodeFreshnessFn,
          }})).join("")
        : "";
      const rosterLoadControlHtml = hiddenRoomRowCount > 0
        ? `<div class="chat-roster-load-row">
            <button type="button" class="chat-roster-load-btn" data-roster-hidden-count="${{escAttr(String(hiddenRoomRowCount))}}" title="Show more users">Show more users</button>
            <span class="chat-roster-load-detail">${{escAttr(String(Math.min(rosterFiltered.length, pinnedSectionCount + visibleRoomRows.length)))}} of ${{escAttr(String(rosterFiltered.length))}} shown</span>
          </div>`
        : "";
      const nextRoomListHtml = orderedRoomRows.length > 0
        ? `${{renderedRoomRowsHtml}}${{rosterLoadControlHtml}}`
        : ((pinnedSectionCount <= 0 && rosterQuery)
            ? '<div class="chat-member-empty">No users match this search.</div>'
            : (pinnedSectionCount <= 0
                ? '<div class="chat-member-empty">No users discovered yet.</div>'
                : ""));
      const nextMarkup = String(nextRoomListHtml == null ? "" : nextRoomListHtml);
      const previousMarkup = !forceRosterSectionRender && (typeof roomList.__meshLastInnerHtml_chat_room_list === "string")
        ? roomList.__meshLastInnerHtml_chat_room_list
        : null;
      if (previousMarkup !== nextMarkup) {{
        roomList.innerHTML = nextMarkup;
        roomList.__meshLastInnerHtml_chat_room_list = nextMarkup;
      }}
      hydrateChatNodeNavigatorCities(unreadList);
      hydrateChatNodeNavigatorCities(meshtasticList);
      hydrateChatNodeNavigatorCities(pinnedList);
      hydrateChatNodeNavigatorCities(roomList);
      bindChatNodeNavigatorListInteractions(roomList);
      bindChatNodeNavigatorListInteractions(unreadList);
      bindChatNodeNavigatorListInteractions(meshtasticList);
      bindChatNodeNavigatorListInteractions(pinnedList);
      scheduleChatNodeNavigatorSearchBoundsSync();
      if (chatNodeNavigatorSelectionScrollLocked) {{
        resetChatNodeNavigatorViewport();
      }}
      keepTraceTargetNodeVisibleInNavigator();
      if (
        typeof syncChatNodeDetailsDrawer === "function"
        && typeof isChatNodeDetailsDrawerExpanded === "function"
        && isChatNodeDetailsDrawerExpanded()
      ) {{
        syncChatNodeDetailsDrawer(safeState, {{
          fetchHistory: false,
        }});
      }}

      const onlineCount = rosterAll.filter((item) => normalizeFreshnessKey(item && item.status) === "online").length;
      const warnCount = rosterAll.filter((item) => normalizeFreshnessKey(item && item.status) === "warn").length;
      const staleCount = rosterAll.filter((item) => normalizeFreshnessKey(item && item.status) === "stale").length;
      const leftSub = document.getElementById("chat-left-sub");
      if (leftSub) {{
        leftSub.textContent = `Scope: ${{channelLabel(activeChatChannel)}} • View Ch: ${{currentMeshChannelViewLabel()}} • Send Ch: ${{currentMeshChannelSendLabel()}} • ${{onlineCount}} online, ${{warnCount}} aging, ${{staleCount}} stale`;
      }}
      return {{
        rosterAll,
        rosterFiltered,
        nodesById,
        historyCapsById,
        packetTickerByNode: packetMaps.packetTickerByNode,
        packetSparklineByNode: packetMaps.packetSparklineByNode,
        linkQualityByNode,
        resolveChatNodeFreshnessFn,
      }};
    }}

    function renderChatNodeNavigatorMenuControls() {{
      const menuBtn = document.getElementById("chat-node-navigator-menu-btn");
      const menu = document.getElementById("chat-node-navigator-menu");
      const sortSelect = document.getElementById("chat-node-navigator-sort-select");
      const dirBtn = document.getElementById("chat-node-navigator-sort-dir-btn");
      const fieldsHost = document.getElementById("chat-node-navigator-fields");

      if (menuBtn instanceof HTMLButtonElement) {{
        menuBtn.setAttribute("aria-expanded", chatNodeNavigatorMenuOpen ? "true" : "false");
      }}
      if (menu instanceof HTMLElement) {{
        menu.hidden = !chatNodeNavigatorMenuOpen;
        if (!chatNodeNavigatorMenuOpen) {{
          menu.style.removeProperty("position");
          menu.style.removeProperty("top");
          menu.style.removeProperty("left");
          menu.style.removeProperty("right");
          menu.style.removeProperty("bottom");
          menu.style.removeProperty("max-height");
          menu.style.removeProperty("z-index");
          menu.style.removeProperty("visibility");
          menu.style.removeProperty("width");
        }} else if (menuBtn instanceof HTMLElement && typeof positionFloatingPanelNearAnchor === "function") {{
          positionFloatingPanelNearAnchor(menu, menuBtn, {{
            alignX: "right",
            preferY: "above",
            gap: 8,
            margin: 8,
            zIndex: 1360,
            minWidth: Math.max(220, menuBtn.getBoundingClientRect().width + 180),
          }});
        }}
      }}

      if (sortSelect instanceof HTMLSelectElement) {{
        const optionsHtml = chatNodeNavigatorSortDefs.map((def) => (
          `<option value="${{escAttr(def.id)}}">${{escAttr(def.label)}}</option>`
        )).join("");
        if (sortSelect.__meshOptionsHtml !== optionsHtml) {{
          sortSelect.innerHTML = optionsHtml;
          sortSelect.__meshOptionsHtml = optionsHtml;
        }}
        const sortKey = normalizeChatNodeNavigatorSortKeyPref(chatNodeNavigatorSortKey);
        if (sortSelect.value !== sortKey) {{
          sortSelect.value = sortKey;
        }}
      }}

      if (dirBtn instanceof HTMLButtonElement) {{
        const dir = normalizeChatNodeNavigatorSortDirPref(chatNodeNavigatorSortDir);
        dirBtn.textContent = dir === "desc" ? "Desc" : "Asc";
        dirBtn.title = dir === "desc"
          ? "Sorting descending. Click to sort ascending."
          : "Sorting ascending. Click to sort descending.";
        dirBtn.setAttribute("aria-label", dirBtn.title);
      }}

      if (fieldsHost instanceof HTMLElement) {{
        const selected = new Set(
          normalizeChatNodeNavigatorMetaFieldIdsPref(chatNodeNavigatorMetaFieldIds, {{
            fallbackToDefaults: false,
          }})
        );
        const pinDirectHistory = normalizeChatNodeNavigatorPinDirectHistoryPref(
          chatNodeNavigatorPinDirectHistory
        );
        const showCity = normalizeChatNodeNavigatorShowCityPref(
          chatNodeNavigatorShowCity
        );
        const showIdle = normalizeChatNodeNavigatorShowIdlePref(
          chatNodeNavigatorShowIdle
        );
        const showStatusDots = normalizeChatNodeNavigatorShowStatusDotsPref(
          chatNodeNavigatorShowStatusDots
        );
        const showPacketDirection = normalizeChatNodeNavigatorShowPacketDirectionPref(
          chatNodeNavigatorShowPacketDirection
        );
        const fieldsHtml = nodeExplorerRosterMetadataFieldDefs().map((def) => {{
          const fieldId = normalizeNodeExplorerFieldId(def && def.id);
          if (!fieldId) return "";
          const checked = selected.has(fieldId) ? " checked" : "";
          return `<label class="chat-node-navigator-field-option">
            <input type="checkbox" data-meta-field-id="${{escAttr(fieldId)}}"${{checked}} />
            <span>${{escAttr(def.label || fieldId)}}</span>
          </label>`;
        }}).join("")
          + `<label class="chat-node-navigator-field-option">
            <input type="checkbox" data-nav-toggle-id="direct-history"${{pinDirectHistory ? " checked" : ""}} />
            <span>DM history first</span>
          </label>`
          + `<label class="chat-node-navigator-field-option">
            <input type="checkbox" data-nav-toggle-id="city"${{showCity ? " checked" : ""}} />
            <span>City</span>
          </label>`
          + `<label class="chat-node-navigator-field-option">
            <input type="checkbox" data-nav-toggle-id="idle"${{showIdle ? " checked" : ""}} />
            <span>Idle / Last Heard</span>
          </label>`
          + `<label class="chat-node-navigator-field-option">
            <input type="checkbox" data-nav-toggle-id="status-dots"${{showStatusDots ? " checked" : ""}} />
            <span>Status</span>
          </label>`
          + `<label class="chat-node-navigator-field-option">
            <input type="checkbox" data-nav-toggle-id="packet-direction"${{showPacketDirection ? " checked" : ""}} />
            <span>Packet plot</span>
          </label>`;
        if (fieldsHost.__meshFieldsHtml !== fieldsHtml) {{
          fieldsHost.innerHTML = fieldsHtml;
          fieldsHost.__meshFieldsHtml = fieldsHtml;
        }} else {{
          for (const input of fieldsHost.querySelectorAll('input[type="checkbox"][data-meta-field-id]')) {{
            if (!(input instanceof HTMLInputElement)) continue;
            const fieldId = normalizeNodeExplorerFieldId(input.dataset.metaFieldId || "");
            input.checked = selected.has(fieldId);
          }}
          for (const input of fieldsHost.querySelectorAll('input[type="checkbox"][data-nav-toggle-id]')) {{
            if (!(input instanceof HTMLInputElement)) continue;
            const toggleId = String(input.dataset.navToggleId || "").trim().toLowerCase();
            if (toggleId === "direct-history") {{
              input.checked = pinDirectHistory;
            }}
            if (toggleId === "city") {{
              input.checked = showCity;
            }}
            if (toggleId === "idle") {{
              input.checked = showIdle;
            }}
            if (toggleId === "status-dots") {{
              input.checked = showStatusDots;
            }}
            if (toggleId === "packet-direction") {{
              input.checked = showPacketDirection;
            }}
          }}
        }}
      }}
    }}

    function bindChatNodeNavigatorMenuControls() {{
      const menuBtn = document.getElementById("chat-node-navigator-menu-btn");
      const sortSelect = document.getElementById("chat-node-navigator-sort-select");
      const dirBtn = document.getElementById("chat-node-navigator-sort-dir-btn");
      const fieldsHost = document.getElementById("chat-node-navigator-fields");

      if (menuBtn instanceof HTMLButtonElement && menuBtn.dataset.bound !== "1") {{
        menuBtn.dataset.bound = "1";
        menuBtn.addEventListener("click", (ev) => {{
          ev.preventDefault();
          chatNodeNavigatorMenuOpen = !chatNodeNavigatorMenuOpen;
          renderChatNodeNavigatorMenuControls();
        }});
      }}

      if (sortSelect instanceof HTMLSelectElement && sortSelect.dataset.bound !== "1") {{
        sortSelect.dataset.bound = "1";
        sortSelect.addEventListener("change", () => {{
          applyChatNodeNavigatorPreferences({{
            sortKey: sortSelect.value,
          }}, {{
            persist: true,
            rerender: true,
          }});
        }});
      }}

      if (dirBtn instanceof HTMLButtonElement && dirBtn.dataset.bound !== "1") {{
        dirBtn.dataset.bound = "1";
        dirBtn.addEventListener("click", (ev) => {{
          ev.preventDefault();
          const currentDir = normalizeChatNodeNavigatorSortDirPref(chatNodeNavigatorSortDir);
          const nextDir = currentDir === "desc" ? "asc" : "desc";
          applyChatNodeNavigatorPreferences({{
            sortDir: nextDir,
          }}, {{
            persist: true,
            rerender: true,
          }});
        }});
      }}

      if (fieldsHost instanceof HTMLElement && fieldsHost.dataset.bound !== "1") {{
        fieldsHost.dataset.bound = "1";
        fieldsHost.addEventListener("change", (ev) => {{
          const target = ev.target;
          if (!(target instanceof HTMLInputElement)) return;
          if (target.type !== "checkbox") return;
          const toggleId = String(target.dataset.navToggleId || "").trim().toLowerCase();
          if (toggleId === "direct-history") {{
            applyChatNodeNavigatorPreferences({{
              pinDirectHistory: !!target.checked,
            }}, {{
              persist: true,
              rerender: true,
            }});
            return;
          }}
          if (toggleId === "city") {{
            applyChatNodeNavigatorPreferences({{
              showCity: !!target.checked,
            }}, {{
              persist: true,
              rerender: true,
            }});
            return;
          }}
          if (toggleId === "idle") {{
            applyChatNodeNavigatorPreferences({{
              showIdle: !!target.checked,
            }}, {{
              persist: true,
              rerender: true,
            }});
            return;
          }}
          if (toggleId === "status-dots") {{
            applyChatNodeNavigatorPreferences({{
              showStatusDots: !!target.checked,
            }}, {{
              persist: true,
              rerender: true,
            }});
            return;
          }}
          if (toggleId === "packet-direction") {{
            applyChatNodeNavigatorPreferences({{
              showPacketDirection: !!target.checked,
            }}, {{
              persist: true,
              rerender: true,
            }});
            return;
          }}
          const nextFields = [];
          for (const input of fieldsHost.querySelectorAll('input[type="checkbox"][data-meta-field-id]')) {{
            if (!(input instanceof HTMLInputElement) || !input.checked) continue;
            nextFields.push(input.dataset.metaFieldId || "");
          }}
          applyChatNodeNavigatorPreferences({{
            metaFields: nextFields,
          }}, {{
            persist: true,
            rerender: true,
          }});
        }});
      }}

      if (document.body.dataset.chatNodeNavigatorMenuOutsideBound !== "1") {{
        document.body.dataset.chatNodeNavigatorMenuOutsideBound = "1";
        document.addEventListener("pointerdown", (ev) => {{
          if (!chatNodeNavigatorMenuOpen) return;
          const target = ev.target;
          if (!(target instanceof Node)) return;
          const btn = document.getElementById("chat-node-navigator-menu-btn");
          const panel = document.getElementById("chat-node-navigator-menu");
          if ((btn instanceof HTMLElement) && btn.contains(target)) return;
          if ((panel instanceof HTMLElement) && panel.contains(target)) return;
          chatNodeNavigatorMenuOpen = false;
          renderChatNodeNavigatorMenuControls();
        }});
      }}

      if (document.body.dataset.chatNodeNavigatorMenuViewportBound !== "1") {{
        document.body.dataset.chatNodeNavigatorMenuViewportBound = "1";
        window.addEventListener("resize", () => {{
          if (!chatNodeNavigatorMenuOpen) return;
          renderChatNodeNavigatorMenuControls();
        }});
        window.addEventListener("scroll", () => {{
          if (!chatNodeNavigatorMenuOpen) return;
          renderChatNodeNavigatorMenuControls();
        }}, true);
      }}

      renderChatNodeNavigatorMenuControls();
    }}

