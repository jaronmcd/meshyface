        if (targetHeap[parent].distance <= targetHeap[index].distance) break;
        const swap = targetHeap[parent];
        targetHeap[parent] = targetHeap[index];
        targetHeap[index] = swap;
        index = parent;
      }}
      return targetHeap;
    }}

    function chatNodeNavigatorMinHeapPop(heap) {{
