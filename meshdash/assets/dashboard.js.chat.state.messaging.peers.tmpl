      const changed = (
        nextSortKey !== chatNodeNavigatorSortKey
        || nextSortDir !== chatNodeNavigatorSortDir
        || nextPinDirectHistory !== chatNodeNavigatorPinDirectHistory
        || nextShowCity !== chatNodeNavigatorShowCity
        || nextShowIdle !== chatNodeNavigatorShowIdle
