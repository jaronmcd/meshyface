    function chatNodeNavigatorCompareSortValues(left, right) {{
      const leftNum = Number(left);
      const rightNum = Number(right);
      const leftHasNum = Number.isFinite(leftNum);
      const rightHasNum = Number.isFinite(rightNum);
      if (leftHasNum && rightHasNum) {{
        return leftNum - rightNum;
      }}
      if (typeof normalizeSortValue === "function" && typeof compareSortValues === "function") {{
        return compareSortValues(normalizeSortValue(left), normalizeSortValue(right));
      }}
      return String(left == null ? "" : left).localeCompare(String(right == null ? "" : right));
    }}

    function normalizeChatNodeNavigatorUnreadDirectByPeer(source = null) {{
      const unreadByPeer = new Map();
      if (source instanceof Map) {{
        for (const [rawPeerId, rawCount] of source.entries()) {{
          const peerId = normalizeNodeId(rawPeerId || "");
          if (!isSelectableNodeId(peerId)) continue;
          const count = Math.max(0, Math.trunc(Number(rawCount) || 0));
          if (count <= 0) continue;
          unreadByPeer.set(peerId, count);
        }}
        return unreadByPeer;
      }}
      const directAckSet = (typeof chatChangeAcknowledgedKeySetForChannel === "function")
        ? chatChangeAcknowledgedKeySetForChannel("direct")
        : null;
      const notices = (typeof chatChangeNoticesForChannel === "function")
        ? chatChangeNoticesForChannel("direct")
        : [];
      for (const notice of notices) {{
        const noticeKey = String((notice && notice.key) || "").trim();
        if (directAckSet instanceof Set && noticeKey && directAckSet.has(noticeKey)) continue;
        const peerId = normalizeNodeId(notice && notice.peerNodeId);
        if (!isSelectableNodeId(peerId)) continue;
        unreadByPeer.set(peerId, (unreadByPeer.get(peerId) || 0) + 1);
      }}
      return unreadByPeer;
    }}

    function chatNodeNavigatorDirectHistoryPeerIds(state = latestState) {{
      const safeState = state && typeof state === "object" ? state : (latestState || {{}});
      const traffic = (safeState.traffic && typeof safeState.traffic === "object")
        ? safeState.traffic
        : {{}};
      const recentChat = Array.isArray(traffic.recent_chat) ? traffic.recent_chat : [];
      const localNodeId = normalizeNodeId(
        typeof resolveLocalNodeId === "function" ? resolveLocalNodeId(safeState) : ""
      );
      const peerIds = new Set();
      for (const msg of recentChat) {{
        if (!msg || typeof msg !== "object") continue;
        if (typeof classifyMessageChannel === "function" && classifyMessageChannel(msg) !== "direct") continue;
        const endpoints = (typeof endpointsForMessage === "function")
          ? endpointsForMessage(msg)
          : {{
              fromId: normalizeNodeId(msg && (msg.from || msg.sender || "")),
              toId: normalizeNodeId(msg && (msg.to || msg.destination || "")),
            }};
        const fromId = normalizeNodeId(endpoints && endpoints.fromId);
        const toId = normalizeNodeId(endpoints && endpoints.toId);
        const candidates = [];
        if (isCanonicalNodeId(localNodeId)) {{
          if (fromId === localNodeId && isSelectableNodeId(toId) && !isSelfNodeId(toId)) {{
            candidates.push(toId);
          }}
          if (toId === localNodeId && isSelectableNodeId(fromId) && !isSelfNodeId(fromId)) {{
            candidates.push(fromId);
          }}
        }}
        if (candidates.length <= 0) {{
          if (isSelectableNodeId(fromId) && !isSelfNodeId(fromId)) {{
            candidates.push(fromId);
          }}
          if (isSelectableNodeId(toId) && toId !== fromId && !isSelfNodeId(toId)) {{
            candidates.push(toId);
          }}
        }}
        for (const peerId of candidates) {{
          if (!isNodeVisibleByLists(peerId)) continue;
          peerIds.add(peerId);
        }}
      }}
      return peerIds;
    }}

    function chatNodeNavigatorUnreadDirectCount(unreadDirectByPeer, rawPeerId) {{
      const unreadByPeer = unreadDirectByPeer instanceof Map
        ? unreadDirectByPeer
        : normalizeChatNodeNavigatorUnreadDirectByPeer(unreadDirectByPeer);
      const peerId = normalizeNodeId(rawPeerId || "");
      if (!peerId) return 0;
      return Math.max(0, Math.trunc(Number(unreadByPeer.get(peerId) || 0)));
    }}

    function noteChatNodeNavigatorProgrammaticScrollReset(durationMs = 700) {{
      const duration = Number.isFinite(Number(durationMs))
        ? Math.max(120, Math.trunc(Number(durationMs)))
        : 700;
      chatNodeNavigatorProgrammaticScrollResetUntilMs = Date.now() + duration;
    }}

    function clearChatNodeNavigatorSelectionScrollLock() {{
      chatNodeNavigatorSelectionScrollLocked = false;
