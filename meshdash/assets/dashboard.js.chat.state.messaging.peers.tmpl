          if (!isCanonicalNodeId(nodeId) || isSelfNodeId(nodeId)) return;
          peerDmActivePeerId = nodeId;
          setPeerDmMenuOpen(false);
          if (latestState) {{
            renderChat(latestState);
          }}
        }});
