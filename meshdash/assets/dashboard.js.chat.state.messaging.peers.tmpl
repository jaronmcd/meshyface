    const chatNodeTelemetryStateByNode = new Map();

    function chatNodeTelemetryToolById(rawToolId) {{
      const cleanToolId = String(rawToolId || "").trim().toLowerCase();
      if (!cleanToolId) return null;
      for (const tool of chatNodeTelemetryToolDefinitions) {{
        if (String(tool && tool.id || "").trim().toLowerCase() === cleanToolId) {{
          return tool;
        }}
      }}
      return null;
    }}

    function chatNodeTelemetryStateForNode(rawNodeId, create = false) {{
      const nodeId = normalizeNodeId(rawNodeId || "");
      if (!isSelectableNodeId(nodeId)) return null;
      let nodeState = chatNodeTelemetryStateByNode.get(nodeId);
      if (!nodeState && create) {{
        nodeState = {{
          tools: new Map(),
          summaryMessage: "",
          summaryError: false,
          summaryUpdatedMs: 0,
        }};
        chatNodeTelemetryStateByNode.set(nodeId, nodeState);
      }}
      return nodeState;
    }}

    function chatNodeTelemetryToolStateForNode(rawNodeId, rawToolId, create = false) {{
      const nodeState = chatNodeTelemetryStateForNode(rawNodeId, create);
      if (!nodeState) return null;
      const toolId = String(rawToolId || "").trim().toLowerCase();
      if (!toolId) return null;
      let toolState = nodeState.tools.get(toolId);
      if (!toolState && create) {{
        toolState = {{
          running: false,
          ok: null,
          updatedMs: 0,
          statusText: "",
          lines: [],
        }};
        nodeState.tools.set(toolId, toolState);
      }}
      return toolState;
    }}

    function chatNodeTelemetryExtractConsoleLines(payload) {{
      if (typeof extractConsoleNetworkToolLines === "function") {{
        return extractConsoleNetworkToolLines(payload);
      }}
      return Array.isArray(payload && payload.console_lines)
        ? payload.console_lines
            .map((line) => String(line == null ? "" : line).trimEnd())
            .filter((line) => !!line)
        : [];
    }}

    function chatNodeTelemetryStatusLabel(toolState) {{
      const state = (toolState && typeof toolState === "object") ? toolState : null;
      if (!state) return "Not run yet.";
      if (state.running) return "Request in progress...";
      const lastUnix = Math.floor((Number(state.updatedMs) || 0) / 1000);
      if (lastUnix <= 0) return "Not run yet.";
      const stamp = formatLocalChatTime(lastUnix, "n/a");
      if (state.ok === false) return `Last error: ${{stamp}}`;
      if (state.ok === true) return `Last success: ${{stamp}}`;
      return `Last run: ${{stamp}}`;
    }}

    function runChatNodeTelemetryShortcut(rawShortcutId, rawNodeId = selectedNodeId) {{
      const shortcutId = String(rawShortcutId || "").trim().toLowerCase();
      if (!shortcutId) return false;
      const nodeId = chatNodeDetailsDrawerTargetNodeId(rawNodeId);
      const targetNodeId = isSelectableNodeId(nodeId) ? nodeId : normalizeNodeId(selectedNodeId || "");

      if (shortcutId === "routes") {{
        if (typeof openNetworkRoutesLiveTrace === "function") {{
          openNetworkRoutesLiveTrace(targetNodeId, {{ autoRun: false }});
          return true;
        }}
        if (typeof applyLayoutView === "function") {{
          applyLayoutView("network", true);
        }}
        if (typeof setActiveNetworkSubview === "function") {{
          setActiveNetworkSubview("routes", {{ persist: true }});
        }}
        return true;
      }}

      if (shortcutId === "map") {{
        if (isSelectableNodeId(targetNodeId) && typeof selectNode === "function") {{
          selectNode(targetNodeId, true, false);
        }}
        if (typeof applyLayoutView === "function") {{
          applyLayoutView("network", true);
        }}
        if (typeof setActiveNetworkSubview === "function") {{
          setActiveNetworkSubview("map", {{ persist: true }});
        }}
        return true;
      }}

      if (shortcutId === "sensors") {{
        if (typeof applyLayoutView === "function") {{
          applyLayoutView("network", true);
        }}
        if (typeof setActiveNetworkSubview === "function") {{
          setActiveNetworkSubview("sensors", {{ persist: true }});
        }}
        return true;
      }}

      return false;
    }}

    function syncChatNodeTelemetryTracerouteFromPayload(rawNodeId, payload, options = null) {{
      const nodeId = normalizeNodeId(rawNodeId || "");
      if (!isSelectableNodeId(nodeId)) return false;
      const opts = (options && typeof options === "object") ? options : {{}};
      const safePayload = (payload && typeof payload === "object") ? payload : {{}};
      const lines = chatNodeTelemetryExtractConsoleLines(safePayload);
      const hasOk = Object.prototype.hasOwnProperty.call(opts, "ok");
      const ok = hasOk ? (opts.ok === true) : (safePayload.ok === true);
      const fallbackError = String(opts.error || safePayload.error || "request failed").trim();
      const summaryLine = lines[0]
        || (ok
          ? `[traceroute] ${{nodeId}} | request completed`
          : `[traceroute] ${{nodeId}} | ${{fallbackError || "request failed"}}`);

      const nodeState = chatNodeTelemetryStateForNode(nodeId, true);
      if (!nodeState) return false;
      nodeState.tools.set("traceroute", {{
        running: false,
        ok: ok ? true : false,
        updatedMs: Date.now(),
        statusText: summaryLine,
        lines,
      }});
      if (opts.updateSummary !== false) {{
        nodeState.summaryMessage = summaryLine;
        nodeState.summaryError = !ok;
        nodeState.summaryUpdatedMs = Date.now();
      }}

      const shouldRender = (
        opts.renderPanel !== false
        && isChatNodeDetailsDrawerExpanded()
        && normalizeChatNodeDetailsDrawerTab(chatNodeDetailsDrawerTab) === "telemetry"
        && chatNodeDetailsDrawerTargetNodeId(selectedNodeId) === nodeId
      );
      if (shouldRender) {{
        renderChatNodeTelemetryPanel(nodeId, latestState);
      }}
      return true;
    }}

    function renderChatNodeTelemetryPanel(rawNodeId = selectedNodeId, state = latestState) {{
      const host = document.getElementById("chat-node-details-telemetry-host");
      if (!(host instanceof HTMLElement)) return;
      const nodeId = chatNodeDetailsDrawerTargetNodeId(rawNodeId);
      if (!isSelectableNodeId(nodeId)) {{
        host.dataset.nodeId = "";
        setDrawerElementHtmlIfChanged(
          host,
          '<div class="chat-node-telemetry-empty">Select a node to run telemetry tools.</div>',
          "telemetry"
        );
        return;
      }}

      const safeState = (state && typeof state === "object") ? state : (latestState || {{}});
      const nodes = Array.isArray(safeState.nodes) ? safeState.nodes : [];
      const selectedNode = nodes.find((entry) => normalizeNodeId(entry && entry.id) === nodeId) || null;
      const resolvedName = preferredNodeName(selectedNode) || nodeNameCache.get(nodeId) || nodeId;
      const nodeState = chatNodeTelemetryStateForNode(nodeId, true);
      if (!nodeState) return;
      host.dataset.nodeId = nodeId;

      const summaryText = String(nodeState.summaryMessage || "").trim()
        || "Run a tool to request live data from this node.";
      const summaryClass = nodeState.summaryError ? " is-error" : "";
      const rowsHtml = chatNodeTelemetryToolDefinitions.map((tool) => {{
        const toolState = chatNodeTelemetryToolStateForNode(nodeId, tool.id, true) || {{}};
        const liveTraceState = (tool.id === "traceroute" && typeof normalizedNetworkRoutesLiveTraceState === "function")
          ? normalizedNetworkRoutesLiveTraceState(networkRoutesLiveTraceState)
          : null;
        const liveTraceRunningForNode = !!(liveTraceState && liveTraceState.running
          && normalizeNodeId(liveTraceState.targetId || "") === nodeId);
        const running = !!toolState.running || liveTraceRunningForNode;
        const liveTraceProgressPct = (tool.id === "traceroute" && running && liveTraceRunningForNode)
          ? (
              typeof networkRoutesLiveTraceProgressPct === "function"
                ? networkRoutesLiveTraceProgressPct(liveTraceState)
                : 1
            )
          : 0;
        const showTraceProgress = tool.id === "traceroute" && running && liveTraceProgressPct > 0;
        const effectiveToolState = (!toolState.running && liveTraceRunningForNode)
          ? {{
              ...toolState,
              running: true,
              ok: null,
              statusText: "Request in progress...",
            }}
          : toolState;
        const rowClass = running
          ? " is-running"
          : (effectiveToolState.ok === false ? " is-error" : (effectiveToolState.ok === true ? " is-success" : ""));
        const status = chatNodeTelemetryStatusLabel(effectiveToolState);
        const statusDetail = String(effectiveToolState.statusText || "").trim();
        const lines = Array.isArray(effectiveToolState.lines)
          ? effectiveToolState.lines
              .map((line) => String(line == null ? "" : line).trim())
              .filter((line) => !!line)
              .slice(0, 2)
          : [];
        const detailHtml = statusDetail
          ? `<div class="chat-node-telemetry-tool-detail">${{escAttr(statusDetail)}}</div>`
          : "";
        const linesHtml = lines.length
          ? `<div class="chat-node-telemetry-tool-lines">${{lines.map((line) => `<div class="chat-node-telemetry-tool-line">${{escAttr(line)}}</div>`).join("")}}</div>`
          : "";
        const shortcut = (tool && tool.shortcut && typeof tool.shortcut === "object") ? tool.shortcut : null;
        const shortcutId = shortcut ? String(shortcut.id || "").trim().toLowerCase() : "";
        const shortcutLabel = shortcut ? String(shortcut.label || "View").trim() : "";
        const shortcutTitle = shortcut ? String(shortcut.title || "").trim() : "";
        const shortcutBtnHtml = (shortcutId && shortcutLabel)
          ? `<button
              class="chat-node-telemetry-tool-shortcut-btn"
              type="button"
              data-drawer-telemetry-shortcut-id="${{escAttr(shortcutId)}}"
              title="${{escAttr(shortcutTitle || shortcutLabel)}}"
            >${{escAttr(shortcutLabel)}}</button>`
          : "";
        const runBtnClass = `chat-node-telemetry-tool-run-btn${{showTraceProgress ? " is-running-trace" : ""}}`;
        const runBtnProgressStyle = showTraceProgress
          ? ` style="--chat-node-telemetry-tool-progress:${{escAttr(String(liveTraceProgressPct))}}%;"`
          : "";
        const runBtnProgressAttrs = showTraceProgress
          ? ` aria-busy="true" aria-label="${{escAttr(`Traceroute running ${{liveTraceProgressPct}}%`)}}" title="${{escAttr(`Traceroute in progress (${{liveTraceProgressPct}}%)`)}}"`
          : "";
        const runBtnContent = showTraceProgress
          ? `<span class="chat-node-telemetry-tool-progress-fill" aria-hidden="true"></span><span class="chat-node-telemetry-tool-progress-text">Tracing ${{escAttr(String(liveTraceProgressPct))}}%</span>`
          : escAttr(running ? "Running..." : "Run");
        return `<article class="chat-node-telemetry-tool-row${{rowClass}}">
          <div class="chat-node-telemetry-tool-main">
            <div class="chat-node-telemetry-tool-label">${{escAttr(tool.label)}}</div>
            <div class="chat-node-telemetry-tool-copy">${{escAttr(tool.description)}}</div>
          </div>
          <div class="chat-node-telemetry-tool-actions">
            ${{shortcutBtnHtml}}
            <button
              class="${{escAttr(runBtnClass)}}"
              type="button"
              data-drawer-telemetry-tool-id="${{escAttr(tool.id)}}"
              ${{running ? "disabled" : ""}}
              ${{runBtnProgressAttrs}}${{runBtnProgressStyle}}
            >${{runBtnContent}}</button>
          </div>
          <div class="chat-node-telemetry-tool-status">${{escAttr(status)}}</div>
          ${{detailHtml}}
          ${{linesHtml}}
        </article>`;
      }}).join("");

      const panelHtml = `<div class="chat-node-telemetry-head">
        <div class="chat-node-telemetry-title">Telemetry Tools</div>
        <div class="chat-node-telemetry-subtitle">${{escAttr(resolvedName)}} (${{escAttr(nodeId)}})</div>
      </div>
      <div class="chat-node-telemetry-summary${{summaryClass}}">${{escAttr(summaryText)}}</div>
      <div class="chat-node-telemetry-tools">${{rowsHtml}}</div>`;
      setDrawerElementHtmlIfChanged(host, panelHtml, "telemetry");
      if (host.dataset.telemetryBound !== "1") {{
        host.dataset.telemetryBound = "1";
        host.addEventListener("click", (event) => {{
          const target = event.target;
          if (!(target instanceof Element)) return;
          const shortcutBtn = target.closest("button[data-drawer-telemetry-shortcut-id]");
          if (shortcutBtn instanceof HTMLButtonElement && !shortcutBtn.disabled) {{
            const shortcutId = String(shortcutBtn.dataset.drawerTelemetryShortcutId || "").trim().toLowerCase();
            if (!shortcutId) return;
            const hostNodeId = normalizeNodeId(host.dataset.nodeId || "");
            runChatNodeTelemetryShortcut(shortcutId, hostNodeId || selectedNodeId);
            return;
          }}
          const runBtn = target.closest("button[data-drawer-telemetry-tool-id]");
          if (!(runBtn instanceof HTMLButtonElement) || runBtn.disabled) return;
          const toolId = String(runBtn.dataset.drawerTelemetryToolId || "").trim().toLowerCase();
          if (!toolId) return;
          const hostNodeId = normalizeNodeId(host.dataset.nodeId || "");
          void runChatNodeTelemetryTool(toolId, hostNodeId || selectedNodeId);
        }});
      }}
    }}

    async function runChatNodeTelemetryTool(rawToolId, rawNodeId = selectedNodeId) {{
      const tool = chatNodeTelemetryToolById(rawToolId);
      if (!tool) return;
      const nodeId = chatNodeDetailsDrawerTargetNodeId(rawNodeId);
      if (!isSelectableNodeId(nodeId)) {{
        const host = document.getElementById("chat-node-details-telemetry-host");
        if (host instanceof HTMLElement) {{
          setDrawerElementHtmlIfChanged(
            host,
            '<div class="chat-node-telemetry-empty">Select a node to run telemetry tools.</div>',
            "telemetry"
          );
        }}
        return;
      }}
      const nodeState = chatNodeTelemetryStateForNode(nodeId, true);
      if (!nodeState) return;
      const existingState = chatNodeTelemetryToolStateForNode(nodeId, tool.id, true);
      if (existingState && existingState.running) return;

      nodeState.tools.set(tool.id, {{
        running: true,
        ok: null,
        updatedMs: Date.now(),
        statusText: "Request in progress...",
        lines: [],
      }});
      nodeState.summaryMessage = `Running ${{tool.label}} for ${{nodeId}}...`;
      nodeState.summaryError = false;
      nodeState.summaryUpdatedMs = Date.now();
      if (tool.id === "traceroute" && typeof setNetworkRoutesLiveTraceState === "function") {{
        const safeState = (latestState && typeof latestState === "object") ? latestState : {{}};
        const preferredSourceId = normalizeNodeId(resolveNetworkRoutesSourceNodeId(safeState) || "");
        const localSourceId = normalizeNodeId(resolveLocalNodeId(safeState) || "");
        const sourceId = isSelectableNodeId(preferredSourceId) ? preferredSourceId : localSourceId;
        if (typeof setNetworkRoutesPinnedTargetId === "function") {{
          setNetworkRoutesPinnedTargetId(nodeId);
        }}
        setNetworkRoutesLiveTraceState({{
          running: true,
          ok: null,
          updatedMs: Date.now(),
          sourceId,
          targetId: nodeId,
          error: "",
          lines: [],
          result: null,
        }});
        if (
          typeof renderNetworkRoutes === "function"
          && normalizeLayoutView(activeLayoutView) === "network"
          && normalizeNetworkSubview(activeNetworkSubview) === "routes"
        ) {{
          renderNetworkRoutes(latestState);
        }}
      }}
      if (
        isChatNodeDetailsDrawerExpanded()
        && normalizeChatNodeDetailsDrawerTab(chatNodeDetailsDrawerTab) === "telemetry"
      ) {{
        renderChatNodeTelemetryPanel(nodeId, latestState);
      }}

      const body = Object.assign({{ destination: nodeId }}, tool.requestBody || {{}});
      try {{
        const payload = await postNetworkToolCommand(body);
        const lines = chatNodeTelemetryExtractConsoleLines(payload);
        const summaryLine = lines[0] || `[${{tool.consoleLabel}}] ${{nodeId}} | request completed`;
        nodeState.tools.set(tool.id, {{
          running: false,
          ok: true,
          updatedMs: Date.now(),
          statusText: summaryLine,
          lines,
        }});
        nodeState.summaryMessage = summaryLine;
        nodeState.summaryError = false;
        nodeState.summaryUpdatedMs = Date.now();
        if (typeof appendConsoleLine === "function" && lines.length) {{
          const baseKey = `telemetry_tool|${{Date.now()}}|${{tool.id}}|${{nodeId}}`;
          lines.forEach((line, idx) => appendConsoleLine(`${{baseKey}}|${{idx}}`, line));
        }}
        if (tool.id === "traceroute" && typeof syncNetworkRoutesLiveTraceFromPayload === "function") {{
          syncNetworkRoutesLiveTraceFromPayload(nodeId, payload, {{
            ok: true,
            renderIfVisible: true,
          }});
        }}
      }} catch (err) {{
        const payload = (err && typeof err === "object") ? err.payload : null;
        const lines = chatNodeTelemetryExtractConsoleLines(payload);
        const fallbackMessage = err instanceof Error
          ? (err.message || String(err))
          : String(err || "request failed");
        const summaryLine = lines[0] || fallbackMessage;
        nodeState.tools.set(tool.id, {{
          running: false,
          ok: false,
          updatedMs: Date.now(),
          statusText: summaryLine,
          lines,
        }});
        nodeState.summaryMessage = summaryLine;
        nodeState.summaryError = true;
        nodeState.summaryUpdatedMs = Date.now();
        if (typeof appendConsoleLine === "function" && lines.length) {{
          const baseKey = `telemetry_tool|${{Date.now()}}|${{tool.id}}|${{nodeId}}|error`;
          lines.forEach((line, idx) => appendConsoleLine(`${{baseKey}}|${{idx}}`, line));
        }}
        if (tool.id === "traceroute" && typeof syncNetworkRoutesLiveTraceFromPayload === "function") {{
          const tracePayload = (payload && typeof payload === "object")
            ? payload
            : {{
                ok: false,
                destination: nodeId,
                error: fallbackMessage,
                console_lines: lines,
              }};
          syncNetworkRoutesLiveTraceFromPayload(nodeId, tracePayload, {{
            ok: false,
            error: fallbackMessage,
            renderIfVisible: true,
          }});
        }}
      }} finally {{
        if (
          isChatNodeDetailsDrawerExpanded()
          && normalizeChatNodeDetailsDrawerTab(chatNodeDetailsDrawerTab) === "telemetry"
          && chatNodeDetailsDrawerTargetNodeId(selectedNodeId) === nodeId
        ) {{
          renderChatNodeTelemetryPanel(nodeId, latestState);
        }}
        if (typeof requestImmediatePoll === "function") {{
          requestImmediatePoll(120);
        }}
      }}
    }}

    function normalizeChatNodeDetailsDrawerTab(value) {{
      const clean = String(value || "").trim().toLowerCase();
      if (clean === "history") return "history";
      if (clean === "location") return "location";
      if (clean === "chat") return "chat";
      if (clean === "links") return "links";
      if (clean === "telemetry") return "telemetry";
      if (clean === "notes") return "notes";
      if (clean === "messages") return "messages";
      if (clean === "tag") return "tag";
      return "details";
    }}

    function chatNodeDetailsDrawerTargetNodeId(rawNodeId = selectedNodeId) {{
      const clean = normalizeNodeId(rawNodeId || "");
      return isSelectableNodeId(clean) ? clean : "";
    }}

    function chatNodeDetailsDrawerExpandedForNode(rawNodeId = selectedNodeId) {{
      const nodeId = chatNodeDetailsDrawerTargetNodeId(rawNodeId);
      return !!chatNodeDetailsDrawerExpanded && isSelectableNodeId(nodeId);
    }}

    function isChatNodeDetailsDrawerExpanded() {{
      return chatNodeDetailsDrawerExpandedForNode(selectedNodeId);
    }}

    function isChatNodeDetailsHistoryActive() {{
      return isChatNodeDetailsDrawerExpanded()
        && normalizeChatNodeDetailsDrawerTab(chatNodeDetailsDrawerTab) === "history";
    }}

    function isChatNodeDetailsPromotedActive() {{
      return !!chatNodeDetailsPromoted && isChatNodeDetailsDrawerExpanded();
    }}

    function syncChatNodeDetailsInlineDockState(activeList = null) {{
      const activeListEl = activeList instanceof HTMLElement ? activeList : null;
      for (const listId of [
        "chat-room-unread-list",
        "chat-room-meshtastic-list",
        "chat-room-pinned-list",
        "chat-room-list",
      ]) {{
        const listEl = document.getElementById(listId);
        if (listEl instanceof HTMLElement) {{
          listEl.classList.toggle("has-node-details-inline", listEl === activeListEl);
        }}
      }}
      for (const shellId of [
        "chat-room-unread-shell",
        "chat-room-meshtastic-shell",
        "chat-room-pinned-shell",
      ]) {{
        const shellEl = document.getElementById(shellId);
        shellEl?.classList?.toggle(
          "has-node-details-inline",
          !!activeListEl && shellEl instanceof HTMLElement && shellEl.contains(activeListEl)
        );
      }}
    }}

    function resetChatNodeDetailsInlineHost(inlineHost) {{
      if (!(inlineHost instanceof HTMLElement)) return;
      delete inlineHost.dataset.dock;
      const section = document.querySelector(".chat-left-section.chat-users-section");
      if (!(section instanceof HTMLElement)) return;
      const splitter = document.getElementById("chat-node-details-splitter");
      const anchor = splitter instanceof HTMLElement && splitter.parentElement === section
        ? splitter.nextSibling
        : null;
      if (inlineHost.parentElement !== section || inlineHost.previousElementSibling !== splitter) {{
        section.insertBefore(inlineHost, anchor);
      }}
    }}

    function ensureChatNodeDetailsDrawer() {{
      const existing = document.getElementById("chat-node-details-drawer");
      if (existing instanceof HTMLElement) return existing;
      const inlineHost = document.getElementById("chat-node-details-inline-host");
      if (!(inlineHost instanceof HTMLElement)) return null;
      const drawer = document.createElement("section");
      drawer.id = "chat-node-details-drawer";
      drawer.className = "chat-node-details-drawer";
