    function resolveChatNodeNavigatorCityHint(lat, lon, key) {{
      const cleanKey = String(key || "").trim();
      if (!cleanKey || !chatNodeNavigatorLocationIsValid(lat, lon)) return Promise.resolve("");
      if (nodeCityHintCache instanceof Map && nodeCityHintCache.has(cleanKey)) {{
        return Promise.resolve(String(nodeCityHintCache.get(cleanKey) || "").trim());
      }}
      if (nodeCityHintPending instanceof Map && nodeCityHintPending.has(cleanKey)) {{
