    function resetChatNodeNavigatorViewport() {{
      const scrollLists = [
        document.getElementById("chat-room-unread-list"),
        document.getElementById("chat-room-pinned-list"),
        document.getElementById("chat-room-list"),
      ].filter((listEl) => listEl instanceof HTMLElement);
      if (scrollLists.length <= 0) return;
      const roomList = document.getElementById("chat-room-list");
      const applyReset = () => {{
