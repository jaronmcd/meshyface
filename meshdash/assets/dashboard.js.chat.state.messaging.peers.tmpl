    let chatNodeNavigatorSearchBoundsResizeBound = false;

    function syncChatNodeNavigatorSearchBounds() {{
      const panel = document.getElementById("chat-left-panel");
      const unreadList = document.getElementById("chat-room-unread-list");
      const pinnedList = document.getElementById("chat-room-pinned-list");
      const roomList = document.getElementById("chat-room-list");
      const bottomBar = document.querySelector(".chat-left-bottom-bar");
      const anchor = (
        unreadList instanceof HTMLElement
          ? unreadList.querySelector(".chat-member-item, .chat-member-empty")
          : null
      ) || (
        pinnedList instanceof HTMLElement
          ? pinnedList.querySelector(".chat-member-item, .chat-member-empty")
          : null
      ) || (
        roomList instanceof HTMLElement
          ? roomList.querySelector(".chat-member-item, .chat-member-empty")
          : null
      );
      if (!(panel instanceof HTMLElement) || !(bottomBar instanceof HTMLElement)) return;

      const defaultInset = "6px";
      if (!(anchor instanceof HTMLElement)) {{
        bottomBar.style.setProperty("--chat-user-search-inline-start", defaultInset);
        bottomBar.style.setProperty("--chat-user-search-inline-end", defaultInset);
        return;
      }}

      const panelRect = panel.getBoundingClientRect();
      const anchorRect = anchor.getBoundingClientRect();
      const leftInset = Math.max(0, Math.round((anchorRect.left - panelRect.left) * 100) / 100);
      const rightInset = Math.max(0, Math.round((panelRect.right - anchorRect.right) * 100) / 100);
      bottomBar.style.setProperty("--chat-user-search-inline-start", `${leftInset}px`);
      bottomBar.style.setProperty("--chat-user-search-inline-end", `${rightInset}px`);
    }}

    function scheduleChatNodeNavigatorSearchBoundsSync() {{
      if (typeof requestAnimationFrame === "function") {{
        requestAnimationFrame(() => {{
          syncChatNodeNavigatorSearchBounds();
        }});
      }} else {{
        syncChatNodeNavigatorSearchBounds();
      }}
    }}

