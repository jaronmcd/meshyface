    function chatNodeNavigatorStatusSortValue(item, projection) {{
      const statusKey = normalizeFreshnessKey(item && item.status);
      if (statusKey && statusKey !== "unknown") {{
        return (typeof statusRank === "function") ? statusRank(statusKey) : 99;
      }}
      return Number.isFinite(Number(projection && projection.statusSort))
        ? Number(projection.statusSort)
        : 99;
    }}

    function chatNodeNavigatorSortValue(item, projection, sortKeyRaw, nowUnixRaw = null) {{
      const sortKey = normalizeChatNodeNavigatorSortKeyPref(sortKeyRaw);
      const safeItem = item && typeof item === "object" ? item : {{}};
      const safeProjection = projection && typeof projection === "object"
        ? projection
        : nodeExplorerBuildProjection(null);
      const nowUnix = Number.isFinite(Number(nowUnixRaw))
        ? Math.trunc(Number(nowUnixRaw))
        : Math.floor(Date.now() / 1000);
      if (sortKey === "status") {{
        return chatNodeNavigatorStatusSortValue(safeItem, safeProjection);
      }}
      if (sortKey === "activity") {{
        return Number(safeItem.lastMessageUnix) || 0;
      }}
      if (sortKey === "idle") {{
        const lastSeenFromRoster = Number(safeItem && safeItem.lastSeenUnix);
        const lastSeenFromProjection = Number(
          safeProjection
          && safeProjection.fields
          && safeProjection.fields.last_heard
          && safeProjection.fields.last_heard.sort
        );
        const lastSeenUnix = Number.isFinite(lastSeenFromRoster) && lastSeenFromRoster > 0
          ? Math.trunc(lastSeenFromRoster)
          : (Number.isFinite(lastSeenFromProjection) && lastSeenFromProjection > 0
            ? Math.trunc(lastSeenFromProjection)
            : 0);
        if (!Number.isFinite(lastSeenUnix) || lastSeenUnix <= 0) {{
          return Number.MAX_SAFE_INTEGER;
        }}
        return Math.max(0, nowUnix - lastSeenUnix);
      }}
      const fieldId = normalizeNodeExplorerFieldId(sortKey);
      const field = fieldId && safeProjection.fields
        ? safeProjection.fields[fieldId]
        : null;
      return field ? field.sort : "";
    }}

    function sortChatNodeNavigatorParticipants(
      participantsList,
      nodesById,
      nowUnix = Math.floor(Date.now() / 1000),
      historyCapsById = null,
      unreadDirectByPeer = null
    ) {{
      const rows = Array.isArray(participantsList) ? participantsList : [];
      const sourceNodes = nodesById instanceof Map ? nodesById : new Map();
      const sourceHistoryCaps = historyCapsById instanceof Map ? historyCapsById : new Map();
      const sourceUnreadDirectByPeer = normalizeChatNodeNavigatorUnreadDirectByPeer(unreadDirectByPeer);
      const sortKey = normalizeChatNodeNavigatorSortKeyPref(chatNodeNavigatorSortKey);
      const sortDir = normalizeChatNodeNavigatorSortDirPref(chatNodeNavigatorSortDir);
      const projectionById = new Map();
      const projectionFor = (entry) => {{
        const nodeId = normalizeNodeId(entry && entry.id);
        if (projectionById.has(nodeId)) {{
          return projectionById.get(nodeId);
        }}
        const node = sourceNodes.get(nodeId) || null;
        const projection = nodeExplorerBuildProjection(
          node || {{ id: nodeId, long_name: (entry && entry.name) || nodeId }},
          {{
            nowUnix,
            historyCaps: sourceHistoryCaps.get(nodeId) || null,
          }}
        );
        projectionById.set(nodeId, projection);
        return projection;
      }};
      rows.sort((a, b) => {{
        const unreadDiff = (
          chatNodeNavigatorUnreadDirectCount(sourceUnreadDirectByPeer, b && b.id)
          - chatNodeNavigatorUnreadDirectCount(sourceUnreadDirectByPeer, a && a.id)
        );
        if (unreadDiff !== 0) return unreadDiff;

        const pinDiff = activeChatChannel === "direct"
          ? (Number(!!(b && b.p2pPinned)) - Number(!!(a && a.p2pPinned)))
          : 0;
        if (pinDiff !== 0) return pinDiff;

        const aProjection = projectionFor(a);
        const bProjection = projectionFor(b);
        const aValue = chatNodeNavigatorSortValue(a, aProjection, sortKey, nowUnix);
        const bValue = chatNodeNavigatorSortValue(b, bProjection, sortKey, nowUnix);
        const cmp = chatNodeNavigatorCompareSortValues(aValue, bValue);
        if (cmp !== 0) {{
          return sortDir === "desc" ? -cmp : cmp;
        }}

        const statusCmp = chatNodeNavigatorCompareSortValues(
          chatNodeNavigatorStatusSortValue(a, aProjection),
          chatNodeNavigatorStatusSortValue(b, bProjection)
        );
        if (statusCmp !== 0) return statusCmp;

        const activityCmp = chatNodeNavigatorCompareSortValues(
          Number(b && b.lastMessageUnix) || 0,
          Number(a && a.lastMessageUnix) || 0
        );
        if (activityCmp !== 0) return activityCmp;

        const nameCmp = String((a && (a.name || a.id)) || "").localeCompare(String((b && (b.name || b.id)) || ""));
        if (nameCmp !== 0) return nameCmp;
        return String((a && a.id) || "").localeCompare(String((b && b.id) || ""));
      }});
      return rows;
    }}

    function buildChatNodeNavigatorPacketSparklinePath(bucketValuesRaw, width = 56, height = 12) {{
      const buckets = Array.isArray(bucketValuesRaw)
        ? bucketValuesRaw.map((value) => Math.max(0, Number(value) || 0))
        : [];
      const plotWidth = Math.max(12, Number(width) || 56);
      const plotHeight = Math.max(8, Number(height) || 12);
      const baselineY = Math.max(1, plotHeight - 1);
      if (buckets.length <= 0) {{
        return `M 0 ${{baselineY.toFixed(2)}} L ${{plotWidth.toFixed(2)}} ${{baselineY.toFixed(2)}}`;
      }}
      const maxValue = Math.max(0, ...buckets);
      const padY = 1;
      const usableHeight = Math.max(2, plotHeight - (padY * 2));
      const points = buckets.map((value, idx) => {{
        const x = buckets.length <= 1
          ? (plotWidth / 2)
          : ((idx / Math.max(1, buckets.length - 1)) * plotWidth);
        const y = maxValue > 0
          ? (padY + ((maxValue - value) / maxValue) * usableHeight)
          : baselineY;
        return {{ x, y }};
      }});
      if (typeof buildSmoothSvgPath === "function") {{
        const smoothPath = buildSmoothSvgPath(points, 0.2);
        if (smoothPath) {{
          return smoothPath;
        }}
      }}
      return points.map((point, idx) => (
        `${{idx === 0 ? "M" : "L"}} ${{point.x.toFixed(2)}} ${{point.y.toFixed(2)}}`
      )).join(" ");
    }}

    function classifyChatNodeNavigatorPacketSparklineTrend(bucketValuesRaw) {{
      const buckets = Array.isArray(bucketValuesRaw)
        ? bucketValuesRaw.map((value) => Math.max(0, Number(value) || 0))
        : [];
      if (buckets.length <= 1) return "trend-flat";
      const segmentSize = Math.max(1, Math.trunc(buckets.length / 3));
      const startSlice = buckets.slice(0, segmentSize);
      const endSlice = buckets.slice(-segmentSize);
      const avg = (rows) => {{
        const list = Array.isArray(rows) ? rows : [];
        if (list.length === 0) return 0;
        const total = list.reduce((sum, value) => sum + (Number(value) || 0), 0);
        return total / Math.max(1, list.length);
      }};
      const startAvg = avg(startSlice);
      const endAvg = avg(endSlice);
      const delta = endAvg - startAvg;
      const threshold = Math.max(0.5, Math.max(...buckets, 0) * 0.15);
      if (delta > threshold) return "trend-up";
      if (delta < -threshold) return "trend-down";
      return "trend-flat";
    }}

    function buildChatNodeNavigatorPacketTrendMapsFromPayload(trendPayload) {{
      const payload = (trendPayload && typeof trendPayload === "object") ? trendPayload : null;
      const packetTickerByNode = new Map();
      const packetSparklineByNode = new Map();
      const nodesPayload = payload && payload.nodes && typeof payload.nodes === "object"
        ? payload.nodes
        : null;
      if (!nodesPayload) {{
        return null;
      }}
      const windowSec = Math.max(
        60,
        Math.trunc(Number(payload.window_seconds ?? payload.windowSeconds ?? 3600) || 3600)
      );
      const bucketCount = Math.max(
        1,
        Math.trunc(Number(payload.bucket_count ?? payload.bucketCount ?? 24) || 24)
      );
      for (const [rawNodeId, rawNodeTrend] of Object.entries(nodesPayload)) {{
        const nodeId = normalizeNodeId(rawNodeId);
        if (!isSelectableNodeId(nodeId)) continue;
        const trend = rawNodeTrend && typeof rawNodeTrend === "object" ? rawNodeTrend : {{}};
        const buckets = Array.isArray(trend.buckets)
          ? trend.buckets.slice(0, bucketCount).map((value) => Math.max(0, Math.trunc(Number(value) || 0)))
          : [];
        while (buckets.length < bucketCount) {{
          buckets.push(0);
        }}
        const txTotal = Math.max(0, Math.trunc(Number(trend.txTotal ?? trend.tx_total ?? 0) || 0));
        const txRecent5m = Math.max(0, Math.trunc(Number(trend.txRecent5m ?? trend.tx_recent_5m ?? 0) || 0));
        const rxTotal = Math.max(0, Math.trunc(Number(trend.rxTotal ?? trend.rx_total ?? 0) || 0));
        const rxRecent5m = Math.max(0, Math.trunc(Number(trend.rxRecent5m ?? trend.rx_recent_5m ?? 0) || 0));
        const lastTxUnix = Number(trend.lastTxUnix ?? trend.last_tx_unix);
        const lastRxUnix = Number(trend.lastRxUnix ?? trend.last_rx_unix);
        const lastPacketUnix = Number(trend.lastPacketUnix ?? trend.last_packet_unix);
        packetTickerByNode.set(nodeId, {{
          total: Math.max(0, Math.trunc(Number(trend.total) || (txTotal + rxTotal))),
          recent5m: Math.max(0, Math.trunc(Number(trend.recent5m ?? trend.recent_5m) || (txRecent5m + rxRecent5m))),
          txTotal,
          txRecent5m,
          rxTotal,
          rxRecent5m,
          lastPacketUnix: Number.isFinite(lastPacketUnix) && lastPacketUnix > 0
            ? lastPacketUnix
            : latestUnixTimestamp(lastTxUnix, lastRxUnix),
          lastTxUnix: Number.isFinite(lastTxUnix) && lastTxUnix > 0 ? lastTxUnix : null,
          lastRxUnix: Number.isFinite(lastRxUnix) && lastRxUnix > 0 ? lastRxUnix : null,
        }});
        packetSparklineByNode.set(nodeId, {{
          buckets,
          windowSec,
          bucketCount,
        }});
      }}
      return {{ packetTickerByNode, packetSparklineByNode }};
    }}

    function buildChatNodeNavigatorPacketTrendMaps(
      rawPackets = [],
      localNodeId = "",
      nowUnix = Math.floor(Date.now() / 1000),
      trendPayload = null
    ) {{
      const packetTickerByNode = new Map();
      const packetSparklineByNode = new Map();
      if (!nodeNavigatorPacketTrendEnabled()) {{
        return {{ packetTickerByNode, packetSparklineByNode }};
      }}
      const persistedMaps = buildChatNodeNavigatorPacketTrendMapsFromPayload(trendPayload);
      if (persistedMaps) {{
        return persistedMaps;
      }}

      const packetSparklineWindowSec = 60 * 60;
      const packetSparklineBucketCount = 24;
      const packetSparklineBucketSpanSec = packetSparklineWindowSec / packetSparklineBucketCount;

      const ensurePacketBucket = (nodeId) => {{
        if (!isSelectableNodeId(nodeId)) return null;
        let bucket = packetTickerByNode.get(nodeId);
        if (!bucket) {{
          bucket = {{
            total: 0,
            recent5m: 0,
            txTotal: 0,
            txRecent5m: 0,
            rxTotal: 0,
            rxRecent5m: 0,
            lastPacketUnix: null,
            lastTxUnix: null,
            lastRxUnix: null,
          }};
          packetTickerByNode.set(nodeId, bucket);
        }}
        return bucket;
      }};

      const ensureSparklineBucket = (nodeId) => {{
        if (!isSelectableNodeId(nodeId)) return null;
        let spark = packetSparklineByNode.get(nodeId);
        if (!spark) {{
          spark = {{
            buckets: new Array(packetSparklineBucketCount).fill(0),
            windowSec: packetSparklineWindowSec,
            bucketCount: packetSparklineBucketCount,
          }};
          packetSparklineByNode.set(nodeId, spark);
        }}
        return spark;
      }};

      const touchPacketDirection = (nodeId, direction, packetUnix, inRecent5m) => {{
        const bucket = ensurePacketBucket(nodeId);
        if (!bucket) return;
        if (direction === "tx") {{
          bucket.txTotal += 1;
          bucket.lastTxUnix = latestUnixTimestamp(bucket.lastTxUnix, packetUnix);
          if (inRecent5m) bucket.txRecent5m += 1;
        }} else if (direction === "rx") {{
          bucket.rxTotal += 1;
          bucket.lastRxUnix = latestUnixTimestamp(bucket.lastRxUnix, packetUnix);
          if (inRecent5m) bucket.rxRecent5m += 1;
        }}
        bucket.total = Math.max(
          0,
          Math.trunc(Number(bucket.txTotal) || 0) + Math.trunc(Number(bucket.rxTotal) || 0)
        );
        bucket.recent5m = Math.max(
          0,
          Math.trunc(Number(bucket.txRecent5m) || 0) + Math.trunc(Number(bucket.rxRecent5m) || 0)
        );
        bucket.lastPacketUnix = latestUnixTimestamp(bucket.lastTxUnix, bucket.lastRxUnix, packetUnix);
      }};

      const touchSparkline = (nodeId, packetUnix) => {{
        if (!Number.isFinite(packetUnix) || packetUnix <= 0) return;
        const spark = ensureSparklineBucket(nodeId);
        if (!spark) return;
        const ageSec = nowUnix - packetUnix;
        if (ageSec < 0 || ageSec > packetSparklineWindowSec) return;
        let bucketIndex = Math.floor((packetSparklineWindowSec - ageSec) / packetSparklineBucketSpanSec);
        if (!Number.isFinite(bucketIndex)) {{
          bucketIndex = packetSparklineBucketCount - 1;
        }}
        bucketIndex = Math.max(0, Math.min(packetSparklineBucketCount - 1, Math.trunc(bucketIndex)));
        spark.buckets[bucketIndex] = Math.max(
          0,
          Math.trunc(Number(spark.buckets[bucketIndex]) || 0) + 1
        );
      }};

      for (const packetEntry of (Array.isArray(rawPackets) ? rawPackets : [])) {{
        const summary = (packetEntry && packetEntry.summary && typeof packetEntry.summary === "object")
          ? packetEntry.summary
          : {{}};
        const packet = (packetEntry && packetEntry.packet && typeof packetEntry.packet === "object")
          ? packetEntry.packet
          : {{}};
        const isRadioPacket = (typeof isMeshRadioActivityPacket === "function")
          ? isMeshRadioActivityPacket(packetEntry, localNodeId)
          : true;
        if (!isRadioPacket) continue;
        const fromId = normalizeNodeId(
          summary.from_id
          ?? summary.fromId
          ?? summary.from
          ?? packet.from_id
          ?? packet.fromId
          ?? packet.from
        );
        const toId = normalizeNodeId(
          summary.to_id
          ?? summary.toId
          ?? summary.to
          ?? packet.to_id
          ?? packet.toId
          ?? packet.to
          ?? packet.destination
        );
        const packetUnix = latestUnixTimestamp(
          summary.rx_time_unix,
          summary.captured_at,
          summary.rx_time,
          summary.time,
          packetEntry && (packetEntry.captured_at || packetEntry.rx_time || packetEntry.time),
          packet.rxTime,
        );
        const inRecent5m = (
          Number.isFinite(packetUnix)
          && packetUnix > 0
          && (nowUnix - packetUnix) <= 300
        );
        touchPacketDirection(fromId, "tx", packetUnix, inRecent5m);
        touchPacketDirection(toId, "rx", packetUnix, inRecent5m);
        touchSparkline(fromId, packetUnix);
        touchSparkline(toId, packetUnix);
      }}

      return {{ packetTickerByNode, packetSparklineByNode }};
    }}

    function bindChatNodeNavigatorListInteractions(roomList = null) {{
      const targetList = roomList instanceof HTMLElement
        ? roomList
        : document.getElementById("chat-room-list");
      if (!(targetList instanceof HTMLElement) || targetList.dataset.memberClickBound === "1") return;
      targetList.dataset.memberClickBound = "1";
      targetList.addEventListener("scroll", () => {{
        if (!chatNodeNavigatorSelectionScrollLocked) return;
        if (Date.now() <= Number(chatNodeNavigatorProgrammaticScrollResetUntilMs || 0)) return;
        clearChatNodeNavigatorSelectionScrollLock();
      }}, {{ passive: true }});
      targetList.addEventListener("click", (ev) => {{
        const target = ev.target;
        if (!(target instanceof Element)) return;
        const removeBtn = target.closest(".chat-peer-remove-btn");
        if (removeBtn instanceof HTMLButtonElement) {{
          ev.preventDefault();
          ev.stopPropagation();
          const nodeId = normalizeNodeId(removeBtn.dataset.nodeId || "");
          if (!isCanonicalNodeId(nodeId)) return;
          const removed = removeManualDirectPeer(nodeId);
          if (!removed) return;
          setChatSendStatus(`Peer ${{nodeId}} removed from peer-to-peer list.`);
          renderChatPeerAddPanel(latestState);
          if (typeof renderChatNodeNavigatorList === "function" && latestState) {{
            renderChatNodeNavigatorList(latestState);
          }}
          return;
        }}
        if (target.closest("button")) return;
        const member = target.closest(".chat-member-item");
        if (!(member instanceof HTMLElement) || !targetList.contains(member)) return;
        const nodeId = normalizeNodeId(member.dataset.nodeId || "");
        const unreadDirectCount = Math.max(0, Math.trunc(Number(member.dataset.unreadDirectCount) || 0));
        if (!isSelectableNodeId(nodeId)) return;
        selectNode(nodeId, true, true);
        const selectedAfterClick = normalizeNodeId(selectedNodeId || "");
        if (
          unreadDirectCount > 0
          && selectedAfterClick === nodeId
          && typeof setChatNodeDetailsDrawerTab === "function"
        ) {{
          setChatNodeDetailsDrawerTab("messages", {{
            fetchHistory: false,
          }});
        }}
      }});
    }}

    function buildChatNodeNavigatorDefaultRoster(
      state,
      nodesById,
      historyCapsById,
      resolveChatNodeFreshnessFn,
      nowUnix = Math.floor(Date.now() / 1000)
    ) {{
      const safeState = state && typeof state === "object" ? state : {{}};
      const traffic = (safeState.traffic && typeof safeState.traffic === "object")
        ? safeState.traffic
        : {{}};
      const recentChat = Array.isArray(traffic.recent_chat) ? traffic.recent_chat : [];
      const latestChatTouchByNode = (typeof mapLatestChatTouchInfo === "function")
        ? mapLatestChatTouchInfo(recentChat)
        : new Map();
      const participants = new Map();

      const touchNodeById = (rawNodeId, options = null) => {{
        const nodeId = normalizeNodeId(rawNodeId || "");
        if (!isSelectableNodeId(nodeId)) return;
        if (!isNodeVisibleByLists(nodeId)) return;
        const opts = options && typeof options === "object" ? options : {{}};
        const node = nodesById instanceof Map ? (nodesById.get(nodeId) || null) : null;
        const snapshot = (typeof resolveChatNodeFreshnessFn === "function")
          ? resolveChatNodeFreshnessFn(nodeId)
          : {{
              id: nodeId,
              node,
              historyCaps: historyCapsById instanceof Map ? (historyCapsById.get(nodeId) || null) : null,
              lastSeenUnix: null,
              status: "unknown",
            }};
        const chatTouch = latestChatTouchByNode instanceof Map
          ? (latestChatTouchByNode.get(nodeId) || null)
          : null;
        const name = String(
          opts.name
          || preferredNodeName(node)
          || nodeNameCache.get(nodeId)
          || nodeId
        ).trim() || nodeId;
        const messageUnix = Number.isFinite(Number(opts.lastMessageUnix))
          ? Math.trunc(Number(opts.lastMessageUnix))
          : (Number(chatTouch && chatTouch.unix) || 0);
        const existing = participants.get(nodeId);
        if (!existing) {{
          participants.set(nodeId, {{
            id: nodeId,
            name,
            status: normalizeFreshnessKey(snapshot && snapshot.status),
            lastSeenUnix: Number.isFinite(Number(snapshot && snapshot.lastSeenUnix))
              ? Math.trunc(Number(snapshot.lastSeenUnix))
              : null,
            lastMessageUnix: messageUnix > 0 ? messageUnix : null,
            p2pPinned: !!opts.p2pPinned,
          }});
          return;
        }}
        if (name && name !== "Unknown node") {{
          existing.name = name;
        }}
        existing.status = normalizeFreshnessKey(snapshot && snapshot.status);
        existing.lastSeenUnix = latestUnixTimestamp(existing.lastSeenUnix, snapshot && snapshot.lastSeenUnix);
        if (messageUnix > 0) {{
          existing.lastMessageUnix = latestUnixTimestamp(existing.lastMessageUnix, messageUnix);
        }}
        if (opts.p2pPinned) {{
          existing.p2pPinned = true;
        }}
      }};

      if (activeChatChannel === "direct") {{
        for (const peerId of manualDirectPeerIds) {{
          if (!isCanonicalNodeId(peerId)) continue;
          touchNodeById(peerId, {{ p2pPinned: true }});
        }}
        if (isCanonicalNodeId(chatDirectActivePeerId)) {{
          touchNodeById(chatDirectActivePeerId, {{
            p2pPinned: manualDirectPeerIds.has(normalizeNodeId(chatDirectActivePeerId)),
          }});
        }}
      }}
      if (activeChatChannel === "direct" && isCanonicalNodeId(selectedNodeId)) {{
        touchNodeById(selectedNodeId, {{
          p2pPinned: manualDirectPeerIds.has(normalizeNodeId(selectedNodeId)),
        }});
      }}

      if (nodesById instanceof Map) {{
        for (const nodeId of nodesById.keys()) {{
          touchNodeById(nodeId, {{
            p2pPinned: manualDirectPeerIds.has(normalizeNodeId(nodeId)),
          }});
        }}
      }}
      if (activeChatChannel === "direct" && historyCapsById instanceof Map) {{
        for (const nodeId of historyCapsById.keys()) {{
          touchNodeById(nodeId, {{
            p2pPinned: manualDirectPeerIds.has(normalizeNodeId(nodeId)),
          }});
        }}
      }}
      if (favoriteNodeIds && typeof favoriteNodeIds.forEach === "function") {{
        favoriteNodeIds.forEach((nodeId) => {{
          touchNodeById(nodeId, {{
            p2pPinned: manualDirectPeerIds.has(normalizeNodeId(nodeId)),
          }});
        }});
      }}
      if (pinnedNodeIds && typeof pinnedNodeIds.forEach === "function") {{
        pinnedNodeIds.forEach((nodeId) => {{
          touchNodeById(nodeId, {{
            p2pPinned: manualDirectPeerIds.has(normalizeNodeId(nodeId)),
          }});
        }});
      }}
      if (nodeNotesById && typeof nodeNotesById.forEach === "function") {{
        nodeNotesById.forEach((_entry, nodeId) => {{
          touchNodeById(nodeId, {{
            p2pPinned: manualDirectPeerIds.has(normalizeNodeId(nodeId)),
          }});
        }});
      }}

      const rows = Array.from(participants.values());
      if (typeof sortChatNodeNavigatorParticipants === "function") {{
        return sortChatNodeNavigatorParticipants(rows, nodesById, nowUnix, historyCapsById);
      }}
      return rows.sort((a, b) => String((a && (a.name || a.id)) || "").localeCompare(String((b && (b.name || b.id)) || "")));
    }}

    function malformedTextPayloadRecord(packetEntry) {{
      const entry = packetEntry && typeof packetEntry === "object" ? packetEntry : null;
      if (!entry) return null;
      const summary = entry.summary && typeof entry.summary === "object" ? entry.summary : {{}};
      const packet = entry.packet && typeof entry.packet === "object" ? entry.packet : {{}};
      const decoded = packet.decoded && typeof packet.decoded === "object" ? packet.decoded : {{}};
      const rawPacket = packet.raw && typeof packet.raw === "object" ? packet.raw : {{}};
      const rawDecoded = rawPacket.decoded && typeof rawPacket.decoded === "object" ? rawPacket.decoded : {{}};
      const portnum = String(summary.portnum ?? decoded.portnum ?? packet.portnum ?? "").trim().toUpperCase();
      if (portnum !== "TEXT_MESSAGE_APP") return null;
      if (summary.is_reaction === true) return null;
      const decodedText = String(summary.decoded_text ?? decoded.text ?? rawDecoded.text ?? packet.text ?? "").trim();
      if (decodedText) return null;
      const payloadText = String(decoded.payload ?? rawDecoded.payload ?? "").trim();
      if (!payloadText) return null;
      const nodeId = normalizeNodeId(summary.from || packet.fromId || packet.from || "");
      if (!isSelectableNodeId(nodeId)) return null;
      const latestUnix = latestUnixTimestamp(
        summary.rx_time_unix,
        packet.rxTime,
        rawPacket.rx_time,
        summary.rx_time,
        summary.captured_at
      );
      const packetIdRaw = Number(summary.packet_id ?? packet.id);
      const packetId = Number.isFinite(packetIdRaw) && packetIdRaw > 0
        ? Math.trunc(packetIdRaw)
        : null;
      return {{
        nodeId,
        latestUnix: Number.isFinite(Number(latestUnix)) && Number(latestUnix) > 0
          ? Math.trunc(Number(latestUnix))
          : 0,
        latestPacketId: packetId,
        payloadPreview: payloadText.length > 28 ? `${{payloadText.slice(0, 28)}}...` : payloadText,
      }};
    }}

    function mapMalformedTextPayloadByNode(recentPackets) {{
      const packets = Array.isArray(recentPackets) ? recentPackets : [];
      const byNode = new Map();
      for (const entry of packets) {{
        const record = malformedTextPayloadRecord(entry);
        if (!record) continue;
        const existing = byNode.get(record.nodeId);
        if (!existing) {{
          byNode.set(record.nodeId, {{
            count: 1,
            latestUnix: record.latestUnix,
            latestPacketId: record.latestPacketId,
            payloadPreview: record.payloadPreview,
          }});
          continue;
        }}
        existing.count = Math.max(0, Math.trunc(Number(existing.count) || 0)) + 1;
        const existingLatestUnix = Number(existing.latestUnix) || 0;
        if ((Number(record.latestUnix) || 0) >= existingLatestUnix) {{
          existing.latestUnix = record.latestUnix;
          existing.latestPacketId = record.latestPacketId;
          existing.payloadPreview = record.payloadPreview;
        }} else if (!existing.payloadPreview && record.payloadPreview) {{
          existing.payloadPreview = record.payloadPreview;
        }}
      }}
      return byNode;
    }}

    function buildChatNodeNavigatorMemberHtml(item, context) {{
      try {{
        const ctx = context && typeof context === "object" ? context : {{}};
        const nowUnix = Number.isFinite(Number(ctx.nowUnix))
          ? Math.trunc(Number(ctx.nowUnix))
          : Math.floor(Date.now() / 1000);
        const nodesById = ctx.nodesById instanceof Map ? ctx.nodesById : new Map();
        const historyCapsById = ctx.historyCapsById instanceof Map ? ctx.historyCapsById : new Map();
        const packetTickerByNode = ctx.packetTickerByNode instanceof Map ? ctx.packetTickerByNode : new Map();
        const packetSparklineByNode = ctx.packetSparklineByNode instanceof Map ? ctx.packetSparklineByNode : new Map();
        const malformedTextByNode = ctx.malformedTextByNode instanceof Map ? ctx.malformedTextByNode : new Map();
        const unreadDirectByPeer = ctx.unreadDirectByPeer instanceof Map ? ctx.unreadDirectByPeer : new Map();
        const directHistoryPeerIds = ctx.directHistoryPeerIds instanceof Set ? ctx.directHistoryPeerIds : new Set();
        const resolveChatNodeFreshnessFn = (typeof ctx.resolveChatNodeFreshnessFn === "function")
          ? ctx.resolveChatNodeFreshnessFn
          : (() => ({{ id: normalizeNodeId(item && item.id), lastSeenUnix: null, status: "unknown" }}));
        const nodeId = normalizeNodeId(item && item.id);
        const snapshot = resolveChatNodeFreshnessFn(nodeId);
        const node = nodesById.get(nodeId) || null;
        const nodeProjection = nodeExplorerBuildProjection(
          node || {{ id: nodeId, long_name: (item && item.name) || nodeId }},
          {{
            nowUnix,
            historyCaps: historyCapsById.get(nodeId) || null,
          }}
        );
        const caps = historyCapsById.get(nodeId) || null;
        const statusKey = normalizeFreshnessKey(item && item.status);
        const statusLabel = statusKey === "online"
          ? "Online"
          : (statusKey === "warn" ? "Aging" : (statusKey === "stale" ? "Stale" : "Unknown"));
        const lastSeenText = Number.isFinite(Number(snapshot && snapshot.lastSeenUnix))
          ? `${{formatLocalChatTime(snapshot.lastSeenUnix, "n/a", nowUnix)}} (${{formatIdleAge(snapshot.lastSeenUnix, nowUnix)}})`
          : "n/a";
        const roleText = String((node && node.role) || "").trim() || "n/a";
        const hardwareText = String((node && (node.hardware_model || node.hardware)) || "").trim() || "n/a";
        const batteryRaw = Number(
          (node && node.battery_level != null)
            ? node.battery_level
            : (caps && caps.battery_level)
        );
        const batteryText = Number.isFinite(batteryRaw)
          ? `${{Math.max(0, Math.min(100, Math.round(batteryRaw)))}}%`
          : "n/a";
        const hopsRaw = Number(
          (node && node.hops_away != null)
            ? node.hops_away
            : (caps && caps.last_hops)
        );
        const hopsText = Number.isFinite(hopsRaw) && hopsRaw >= 0
          ? String(Math.trunc(hopsRaw))
          : "n/a";
        const hasLivePosition = (
          node
          && Number.isFinite(Number(node.lat))
          && Number.isFinite(Number(node.lon))
        );
        const gpsText = hasLivePosition
          ? `${{Number(node.lat).toFixed(5)}}, ${{Number(node.lon).toFixed(5)}}`
          : ((caps && caps.has_position === true) ? "history only" : "n/a");
        const noteEntry = (typeof nodeNoteEntry === "function") ? nodeNoteEntry(nodeId) : null;
        const noteText = String((noteEntry && noteEntry.note) || "").trim();
        const muted = (typeof isMutedNode === "function") && isMutedNode(nodeId);
        const unreadDirectCount = Math.max(0, Math.trunc(Number(unreadDirectByPeer.get(nodeId) || 0)));
        const hasDirectHistory = directHistoryPeerIds.has(nodeId);
        const idleText = Number.isFinite(Number(snapshot && snapshot.lastSeenUnix))
          ? formatIdleAge(snapshot.lastSeenUnix, nowUnix)
          : "n/a";
        const showIdle = (typeof normalizeChatNodeNavigatorShowIdlePref === "function")
          ? normalizeChatNodeNavigatorShowIdlePref(chatNodeNavigatorShowIdle)
          : !!chatNodeNavigatorShowIdle;
        const showCity = (typeof normalizeChatNodeNavigatorShowCityPref === "function")
          ? normalizeChatNodeNavigatorShowCityPref(chatNodeNavigatorShowCity)
          : !!chatNodeNavigatorShowCity;
        const showPacketTrend = nodeNavigatorPacketTrendEnabled();
        const showPacketDirection = (typeof normalizeChatNodeNavigatorShowPacketDirectionPref === "function")
          ? normalizeChatNodeNavigatorShowPacketDirectionPref(chatNodeNavigatorShowPacketDirection)
          : !!chatNodeNavigatorShowPacketDirection;
        const showPacketTrendRow = showPacketTrend && showPacketDirection;
        const packetTicker = packetTickerByNode.get(nodeId) || null;
        const packetSparkline = packetSparklineByNode.get(nodeId) || null;
        const packetSparklineBuckets = Array.isArray(packetSparkline && packetSparkline.buckets)
          ? packetSparkline.buckets
          : [];
        const packetSparklineWindowSec = Math.max(
          60,
          Math.trunc(Number(packetSparkline && packetSparkline.windowSec) || 3600)
        );
        const packetSparklineWindowMin = Math.max(1, Math.round(packetSparklineWindowSec / 60));
        const packetTotal = Math.max(0, Math.trunc(Number(packetTicker && packetTicker.total) || 0));
        const packetTxTotal = Math.max(0, Math.trunc(Number(packetTicker && packetTicker.txTotal) || 0));
        const packetTxRecent5m = Math.max(0, Math.trunc(Number(packetTicker && packetTicker.txRecent5m) || 0));
        const packetRxTotal = Math.max(0, Math.trunc(Number(packetTicker && packetTicker.rxTotal) || 0));
        const packetRxRecent5m = Math.max(0, Math.trunc(Number(packetTicker && packetTicker.rxRecent5m) || 0));
        const packetLastUnix = Number(packetTicker && packetTicker.lastPacketUnix);
        const packetLastTxUnix = Number(packetTicker && packetTicker.lastTxUnix);
        const packetLastRxUnix = Number(packetTicker && packetTicker.lastRxUnix);
        const packetLastText = (
          Number.isFinite(packetLastUnix) && packetLastUnix > 0
            ? `${{formatLocalChatTime(packetLastUnix, "n/a", nowUnix)}} (${{formatIdleAge(packetLastUnix, nowUnix)}})`
            : "n/a"
        );
        const packetLastTxText = (
          Number.isFinite(packetLastTxUnix) && packetLastTxUnix > 0
            ? `${{formatLocalChatTime(packetLastTxUnix, "n/a", nowUnix)}} (${{formatIdleAge(packetLastTxUnix, nowUnix)}})`
            : "n/a"
        );
        const packetLastRxText = (
          Number.isFinite(packetLastRxUnix) && packetLastRxUnix > 0
            ? `${{formatLocalChatTime(packetLastRxUnix, "n/a", nowUnix)}} (${{formatIdleAge(packetLastRxUnix, nowUnix)}})`
            : "n/a"
        );
        const malformedTextEntry = malformedTextByNode.get(nodeId) || null;
        const malformedTextCount = Math.max(0, Math.trunc(Number(malformedTextEntry && malformedTextEntry.count) || 0));
        const malformedTextLatestUnix = Number(malformedTextEntry && malformedTextEntry.latestUnix);
        const malformedTextLatestText = (
          Number.isFinite(malformedTextLatestUnix) && malformedTextLatestUnix > 0
            ? `${{formatLocalChatTime(malformedTextLatestUnix, "n/a", nowUnix)}} (${{formatIdleAge(malformedTextLatestUnix, nowUnix)}})`
            : "n/a"
        );
        const malformedTextPayloadPreview = String((malformedTextEntry && malformedTextEntry.payloadPreview) || "").trim();
        const packetTickerDetail = packetTotal > 0
          ? `Observed packet activity: ${{packetRxRecent5m + packetTxRecent5m}} in 5m, ${{packetTotal}} total, last observed ${{packetLastText}}. Trend window: ${{packetSparklineWindowMin}}m`
          : "Observed packet activity: none in current packet buffer";
        const tooltipLines = [
          `${{(item && item.name) || nodeId}} (${{(item && item.id) || nodeId}})`,
          `Status: ${{statusLabel}}`,
          `Last seen: ${{lastSeenText}}`,
          `Idle: ${{idleText}}`,
          `Role: ${{roleText}}`,
          `Hardware: ${{hardwareText}}`,
          `Battery: ${{batteryText}}`,
