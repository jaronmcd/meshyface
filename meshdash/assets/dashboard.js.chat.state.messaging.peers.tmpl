    function setChatNodeDetailsDrawerExpanded(expanded, options = null) {{
      const opts = options && typeof options === "object" ? options : {{}};
      const nextExpanded = !!expanded;
      const nextTab = normalizeChatNodeDetailsDrawerTab(
        opts.tab != null ? opts.tab : chatNodeDetailsDrawerTab
      );
      const currentExpanded = !!chatNodeDetailsDrawerExpanded;
      const currentTab = normalizeChatNodeDetailsDrawerTab(chatNodeDetailsDrawerTab);
      if (nextExpanded && !isSelectableNodeId(chatNodeDetailsDrawerTargetNodeId(selectedNodeId))) {{
        chatNodeDetailsDrawerExpanded = false;
        chatNodeDetailsDrawerTab = nextTab;
        syncChatNodeDetailsDrawer(latestState, {{
          fetchHistory: false,
        }});
        return false;
      }}
      const changed = currentExpanded !== nextExpanded || currentTab !== nextTab;
      chatNodeDetailsDrawerExpanded = nextExpanded;
      chatNodeDetailsDrawerTab = nextTab;
      if (activeLayoutView === "network") {{
        const selectedId = chatNodeDetailsDrawerTargetNodeId(selectedNodeId);
        if (isSelectableNodeId(selectedId)) {{
          if (nextExpanded) {{
            networkNodeInfoCollapsedNodeId = "";
          }} else {{
            networkNodeInfoCollapsedNodeId = selectedId;
          }}
        }}
      }}
      const shouldRerender = opts.rerender === true;
      if (shouldRerender && latestState) {{
        renderChat(latestState);
      }} else {{
        syncChatNodeDetailsDrawer(latestState, {{
          fetchHistory: opts.fetchHistory !== false,
        }});
      }}
      return changed;
    }}

    function setChatNodeDetailsDrawerTab(tab, options = null) {{
      const nextTab = normalizeChatNodeDetailsDrawerTab(tab);
      const opts = options && typeof options === "object" ? options : {{}};
      chatNodeDetailsDrawerTab = nextTab;
