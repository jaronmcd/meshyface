    function syncChatNodeDetailsDrawerPlacement(drawer, promotedVisible) {{
      if (!(drawer instanceof HTMLElement)) return false;
      const inlineHost = document.getElementById("chat-node-details-inline-host");
      const promotedShell = document.getElementById("chat-node-details-promoted-shell");
      const promotedHost = document.getElementById("chat-node-details-promoted-host");
      const usePromoted = !!promotedVisible && promotedHost instanceof HTMLElement;
      if (inlineHost instanceof HTMLElement) {{
        if (usePromoted) {{
          resetChatNodeDetailsInlineHost(inlineHost);
        }} else {{
          const section = document.querySelector(".chat-left-section.chat-users-section");
          const roomList = document.getElementById("chat-room-list");
          if (section instanceof HTMLElement && roomList instanceof HTMLElement && roomList.parentElement === section) {{
            if (inlineHost.parentElement !== section || inlineHost.nextElementSibling !== roomList) {{
              section.insertBefore(inlineHost, roomList);
            }}
            inlineHost.dataset.dock = "shared";
          }} else {{
            resetChatNodeDetailsInlineHost(inlineHost);
          }}
        }}
      }}
      syncChatNodeDetailsInlineDockState(null);
      const target = usePromoted && promotedHost instanceof HTMLElement
        ? promotedHost
        : inlineHost;
      if (target instanceof HTMLElement && drawer.parentElement !== target) {{
        target.appendChild(drawer);
      }}
      drawer.dataset.promoted = usePromoted ? "true" : "false";
      if (promotedShell instanceof HTMLElement) {{
        promotedShell.hidden = !usePromoted;
      }}
      const workspaceShell = document.querySelector(".workspace-shell");
      if (workspaceShell instanceof HTMLElement) {{
        workspaceShell.classList.toggle("has-promoted-node-details", usePromoted);
      }}
      return usePromoted;
    }}

    function syncSavedNodeDetailsDock(forceToSaved = false) {{
      const detailsHost = document.getElementById("saved-node-details");
      if (!(detailsHost instanceof HTMLElement)) return;
      const savedPane = document.querySelector(".saved-node-pane");
      const drawerHost = document.getElementById("chat-node-details-content-host");
      const useDrawerHost = !forceToSaved
        && isChatNodeDetailsDrawerExpanded()
        && (drawerHost instanceof HTMLElement);
      const target = useDrawerHost ? drawerHost : savedPane;
      if (!(target instanceof HTMLElement)) return;
      if (detailsHost.parentElement !== target) {{
        target.appendChild(detailsHost);
      }}
    }}

    function setDrawerElementTextIfChanged(element, nextText) {{
      if (!(element instanceof HTMLElement)) return false;
      const normalized = String(nextText == null ? "" : nextText);
      if (element.textContent === normalized) return false;
      element.textContent = normalized;
      return true;
    }}

    function setDrawerElementHtmlIfChanged(element, nextHtml, cacheKey = "default") {{
      if (!(element instanceof HTMLElement)) return false;
      const normalized = String(nextHtml == null ? "" : nextHtml);
      const propName = `__meshDrawerLastHtml_${{cacheKey}}`;
      const previousMarkup = (typeof element[propName] === "string") ? element[propName] : null;
      if (previousMarkup === normalized) return false;
      element.innerHTML = normalized;
      element[propName] = normalized;
      return true;
    }}

    function syncDrawerTabButtonState(button, isActive) {{
      if (!(button instanceof HTMLButtonElement)) return;
      const nextActive = !!isActive;
      button.classList.toggle("is-active", nextActive);
      button.setAttribute("aria-selected", nextActive ? "true" : "false");
    }}

    function syncDrawerPanelHiddenState(panel, isActive) {{
      if (!(panel instanceof HTMLElement)) return;
      panel.hidden = !isActive;
    }}

