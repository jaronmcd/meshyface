        const buildRef = String(revision.build_ref || "").trim();
        const fallbackLabel = String(revision.label || "").trim();
        const cleanFallbackLabel = fallbackLabel.replace(/^Rev:\s*/i, "").trim();
        const commit = String(revision.commit || "").trim();
        const prNumber = String(revision.pr_number || "").replace(/[^0-9]/g, "").slice(0, 12);
        const title = String(revision.title || "").trim();
        const shortCommit = commit && commit.toLowerCase() !== "nogit" ? commit.slice(0, 12) : commit;
        const derivedRef = shortCommit ? `${{shortCommit}}${{prNumber ? ` · PR #${{prNumber}}` : ""}}` : "";
        const revisionText = buildRef || derivedRef || cleanFallbackLabel || "n/a";
        settingsSoftwareRevision.textContent = revisionText;
        settingsSoftwareRevision.title = title || `Dashboard revision ${{revisionText}}`;
