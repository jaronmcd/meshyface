    function syncTopbarUpdateTickerEvents(state, _context = null) {{
      if (!topbarUpdateTickerBootstrapped) {{
        topbarUpdateTickerBootstrapped = true;
        return;
      }}
      pruneTopbarUpdateTickerEvents();
      // Keep ticker scoped to public chat updates only.
      clearTopbarUpdateTickerEventsByPrefix("direct:");
      for (const entry of [...topbarUpdateTickerEvents]) {{
        const key = String(entry && entry.key ? entry.key : "").trim();
        if (!key) continue;
        if (key.startsWith("oneshot:") && !key.startsWith("oneshot:public:")) {{
          removeTopbarUpdateTickerEventByKey(key);
        }}
      }}
    }}

    function topbarUpdateTickerRows(state, context = null) {{
      syncTopbarUpdateTickerEvents(state, context);
      const normalizeTickerSortMs = (rawValue) => {{
        const value = Number(rawValue);
        if (!Number.isFinite(value) || value <= 0) return 0;
        if (value > 1e12) return value;
        if (value > 1e9) return value * 1000;
        return value;
      }};
      const unseenNoticeRows = [];
      const seenNoticeKeys = new Set();
      const appendChannelNotices = (channelKey) => {{
        if (typeof chatChangeNoticesForChannel !== "function") return;
        const notices = chatChangeNoticesForChannel(channelKey);
        if (!Array.isArray(notices) || !notices.length) return;
        const ackSet = typeof chatChangeAcknowledgedKeySetForChannel === "function"
          ? chatChangeAcknowledgedKeySetForChannel(channelKey)
          : null;
        for (const notice of notices) {{
          const noticeKey = String(notice && notice.key ? notice.key : "").trim();
          if (ackSet instanceof Set && noticeKey && ackSet.has(noticeKey)) {{
            continue;
          }}
          const dedupeKey = `${{normalizeChatChannel(channelKey)}}:${{noticeKey}}`;
          if (noticeKey && seenNoticeKeys.has(dedupeKey)) {{
            continue;
          }}
          if (noticeKey) {{
            seenNoticeKeys.add(dedupeKey);
          }}
          const sender = String(notice && notice.sender ? notice.sender : "").trim() || "Unknown node";
          const preview = compactTopbarTickerText(notice && notice.preview ? notice.preview : "", 96);
          const unix = Number(notice && notice.unix);
          const rowKey = noticeKey
            ? `notice:${{normalizeChatChannel(channelKey)}}:${{noticeKey}}`
            : `notice:${{normalizeChatChannel(channelKey)}}:${{sender.toLowerCase()}}:${{Math.trunc(Number.isFinite(unix) ? unix : 0)}}:${{unseenNoticeRows.length}}`;
          unseenNoticeRows.push({{
            key: rowKey,
            text: preview
              ? `${{sender}}: ${{preview}}`
              : `${{sender}}`,
            mode: "oneshot",
            sortMs: normalizeTickerSortMs(unix),
          }});
        }}
      }};
      appendChannelNotices("all");
      const oneShotRows = topbarUpdateTickerEvents
        .filter((entry) => String(entry && entry.key ? entry.key : "").trim().startsWith("oneshot:public:"))
        .map((entry) => ({{
          key: String(entry && entry.key ? entry.key : "").trim(),
          text: compactTopbarTickerText(entry && entry.text ? entry.text : "", 160),
          mode: "oneshot",
          sortMs: normalizeTickerSortMs((entry && entry.updatedAtMs) || (entry && entry.createdAtMs) || 0),
        }}))
        .filter((entry) => String(entry && entry.text ? entry.text : "").trim().length > 0);
      const allRows = unseenNoticeRows.concat(oneShotRows);
      if (!allRows.length) return [];
      allRows.sort((a, b) => Number(a && a.sortMs ? a.sortMs : 0) - Number(b && b.sortMs ? b.sortMs : 0));
      const dedupedRows = [];
      const seenRowKeys = new Set();
      for (const row of allRows) {{
        const key = String(row && row.key ? row.key : "").trim() || `row:${{dedupedRows.length}}`;
        if (seenRowKeys.has(key)) continue;
        const text = compactTopbarTickerText(row && row.text ? row.text : "", 160);
        if (!text) continue;
        seenRowKeys.add(key);
        dedupedRows.push({{
          key,
          text,
          mode: String(row && row.mode ? row.mode : "sticky").trim().toLowerCase() === "oneshot" ? "oneshot" : "sticky",
          sortMs: Number(row && row.sortMs),
        }});
        if (dedupedRows.length >= topbarUpdateTickerQueueMax) break;
      }}
      return dedupedRows;
    }}

    function renderTopbarUpdateTicker(state, context = null) {{
      const tickerEl = document.getElementById("topbar-update-ticker");
      const viewportEl = document.getElementById("topbar-update-viewport");
      const trackEl = document.getElementById("topbar-update-track");
      const primaryEl = document.getElementById("topbar-update-text-primary");
      const secondaryEl = document.getElementById("topbar-update-text-secondary");
      if (!(tickerEl instanceof HTMLElement)) return;
      if (!(viewportEl instanceof HTMLElement)) return;
      if (!(trackEl instanceof HTMLElement)) return;
      if (!(primaryEl instanceof HTMLElement)) return;
      if (!(secondaryEl instanceof HTMLElement)) return;
      if (!topbarUpdateTickerEnabled()) {{
        cancelTopbarTickerClearTimers(tickerEl);
        hideTopbarUpdateTickerNow(tickerEl, trackEl, primaryEl, secondaryEl);
        return;
      }}
      const rows = topbarUpdateTickerRows(state, context);
      primaryEl.textContent = "";
      primaryEl.hidden = true;
      secondaryEl.textContent = "";
      secondaryEl.hidden = true;
      tickerEl.classList.remove("is-static");
      syncTopbarUpdateTickerActiveRows(rows);
      updateTopbarTickerTitleFromActiveRows(tickerEl);
      if (
        topbarUpdateTickerActiveRowByKey.size <= 0
        && topbarUpdateTickerPendingSpawnKeys.length <= 0
        && topbarUpdateTickerVisibleItemCount <= 0
      ) {{
        scheduleTopbarTickerHideWhenIdle(tickerEl, trackEl, primaryEl, secondaryEl);
        return;
      }}
      cancelTopbarTickerClearTimers(tickerEl);
      setTopbarUpdateTickerVisibility(tickerEl, true);
      topbarUpdateTickerScheduleSpawnPump(tickerEl, viewportEl, trackEl, primaryEl, secondaryEl);
    }}

    function summaryMiniPanelHashMixInt(hash, value) {{
      const v = (Number.isFinite(Number(value)) ? Math.trunc(Number(value)) : 0) | 0;
      hash ^= v;
      hash = Math.imul(hash, 16777619);
      return hash >>> 0;
    }}

    function summaryMiniPanelHashMixStr(hash, value) {{
      const text = String(value == null ? "" : value);
      for (let i = 0; i < text.length; i += 1) {{
        hash ^= text.charCodeAt(i);
        hash = Math.imul(hash, 16777619);
      }}
      return hash >>> 0;
    }}

    function updateSummaryMiniPanel(panelKey, element, options = null) {{
      if (!(element instanceof HTMLElement)) return false;
      const opts = (options && typeof options === "object") ? options : {{}};
      const mode = String(opts.mode || "text").toLowerCase() === "html" ? "html" : "text";
      const body = mode === "html"
        ? String(opts.html == null ? "" : opts.html)
        : String(opts.text == null ? "" : opts.text);
      const title = String(opts.title == null ? "" : opts.title);
      let hash = 2166136261;
      hash = summaryMiniPanelHashMixStr(hash, panelKey);
      hash = summaryMiniPanelHashMixStr(hash, mode);
      hash = summaryMiniPanelHashMixInt(hash, body.length);
      hash = summaryMiniPanelHashMixStr(hash, body);
      hash = summaryMiniPanelHashMixInt(hash, title.length);
      hash = summaryMiniPanelHashMixStr(hash, title);
      const normalizedHash = hash >>> 0;
      if (summaryMiniPanelHashById.get(panelKey) === normalizedHash) {{
        return false;
      }}
      if (mode === "html") {{
        if (element.innerHTML !== body) {{
          element.innerHTML = body;
        }}
      }} else {{
        if (element.textContent !== body) {{
          element.textContent = body;
        }}
      }}
      if (element.title !== title) {{
        element.title = title;
      }}
      summaryMiniPanelHashById.set(panelKey, normalizedHash);
      return true;
    }}

    function selfNodeCityCoordinateIsValid(latRaw, lonRaw) {{
      const lat = Number(latRaw);
      const lon = Number(lonRaw);
      if (typeof isValidMapCoord === "function") {{
        return isValidMapCoord(lat, lon);
      }}
      if (typeof isValidLatLonRange === "function") {{
        return isValidLatLonRange(lat, lon) && !(Math.abs(lat) < 1e-9 && Math.abs(lon) < 1e-9);
      }}
      return Number.isFinite(lat) && Number.isFinite(lon)
        && lat >= -90 && lat <= 90
        && lon >= -180 && lon <= 180
        && !(Math.abs(lat) < 1e-9 && Math.abs(lon) < 1e-9);
    }}

    function selfNodeGpsLocationFromEntries(...entries) {{
      for (const entry of entries) {{
        if (!entry || typeof entry !== "object") continue;
        const coords = (typeof nodeCoordsFromStateEntry === "function")
          ? nodeCoordsFromStateEntry(entry)
          : null;
        if (coords && selfNodeCityCoordinateIsValid(coords.lat, coords.lon)) {{
          return {{
            lat: Number(coords.lat),
            lon: Number(coords.lon),
            source: "gps",
          }};
        }}
        const lat = Number(entry.lat ?? entry.latitude);
        const lon = Number(entry.lon ?? entry.lng ?? entry.longitude);
        if (selfNodeCityCoordinateIsValid(lat, lon)) {{
          return {{
            lat,
            lon,
            source: "gps",
          }};
        }}
      }}
      return null;
    }}

    function selfNodeLinkedLocationGraphKey(nodes, edges, nodeId) {{
      if (typeof buildMapGraphSignature === "function") {{
        try {{
          return `${{nodeId}}:${{buildMapGraphSignature(nodes, edges, {{ includeTemporalEdgeFade: false }})}}`;
        }} catch (_err) {{
          // Fall through to the lightweight key below.
        }}
      }}
      return `${{nodeId}}:${{Array.isArray(nodes) ? nodes.length : 0}}:${{Array.isArray(edges) ? edges.length : 0}}`;
    }}

    function selfNodeLinkedLocationFromState(state, nodeId) {{
      const safeState = (state && typeof state === "object") ? state : {{}};
      const nodes = Array.isArray(safeState.nodes) ? safeState.nodes : [];
      const traffic = (safeState.traffic && typeof safeState.traffic === "object") ? safeState.traffic : {{}};
      const edges = Array.isArray(traffic.edges) ? traffic.edges : [];
      if (!isSelectableNodeId(nodeId) || nodes.length === 0 || edges.length === 0) {{
        return null;
      }}
      if (typeof buildMapLinkLayerOverlay !== "function") {{
        return null;
      }}
      const cacheKey = selfNodeLinkedLocationGraphKey(nodes, edges, nodeId);
      if (cacheKey && cacheKey === selfNodeLinkedLocationCacheKey) {{
        return selfNodeLinkedLocationCacheValue;
      }}

      let linkedLocation = null;
      try {{
        const overlay = buildMapLinkLayerOverlay(nodes, edges, {{
          mode: "live",
          minEstimateAnchors: mapLinkMinCityEstimateAnchors,
          minEstimateConfidence: mapLinkMinCityEstimateConfidence,
        }});
        const estimates = overlay && overlay.estimates instanceof Map ? overlay.estimates : null;
        const estimate = estimates ? estimates.get(nodeId) : null;
        const lat = Number(estimate && estimate.lat);
        const lon = Number(estimate && estimate.lon);
        const confidence = Number(estimate && estimate.confidence);
        const anchorCount = Math.max(0, Math.trunc(Number(estimate && estimate.anchorCount) || 0));
        const fitScore = Number(estimate && estimate.fitScore);
        if (
          selfNodeCityCoordinateIsValid(lat, lon)
          && anchorCount >= mapLinkMinCityEstimateAnchors
          && Number.isFinite(confidence)
          && confidence >= mapLinkMinCityEstimateConfidence
          && Number.isFinite(fitScore)
          && fitScore >= mapLinkMinCityEstimateFit
        ) {{
          // Legacy guard for compatibility tests: source: "linked",
          linkedLocation = {{
            lat,
            lon,
            source: "estimated",
            confidence,
            anchorCount,
            fitScore,
          }};
        }}
      }} catch (_err) {{
        linkedLocation = null;
      }}

      selfNodeLinkedLocationCacheKey = cacheKey;
      selfNodeLinkedLocationCacheValue = linkedLocation;
      return linkedLocation;
    }}

    function resolveSelfNodeCityLocation(state, node, owner, nodeId) {{
      const safeState = (state && typeof state === "object") ? state : {{}};
      const cleanNodeId = normalizeNodeId(nodeId || "");
      const localId = normalizeNodeId(resolveLocalNodeId(safeState) || "");
      const canUseLocalState = isCanonicalNodeId(localId) && cleanNodeId === localId;
      if (typeof resolveNodeCityLocationMeta === "function") {{
        const locationMeta = resolveNodeCityLocationMeta(cleanNodeId, safeState, node, {{
          allowEstimate: true,
          estimateMode: "live",
          minEstimateAnchors: mapLinkMinCityEstimateAnchors,
          minEstimateConfidence: mapLinkMinCityEstimateConfidence,
          minEstimateFit: mapLinkMinCityEstimateFit,
          extraSources: canUseLocalState ? [safeState.local_state, safeState.localState] : [],
        }});
        if (locationMeta && typeof locationMeta === "object" && locationMeta.location) {{
          return {{
            lat: Number(locationMeta.location.lat),
            lon: Number(locationMeta.location.lon),
            source: locationMeta.source === "estimated" ? "estimated" : "gps",
            confidence: Number(locationMeta && locationMeta.estimate && locationMeta.estimate.confidence),
          }};
        }}
      }}
      const gpsLocation = selfNodeGpsLocationFromEntries(
        node,
        owner,
        ...(canUseLocalState ? [safeState.local_state, safeState.localState] : [])
      );
      if (gpsLocation) {{
        return gpsLocation;
      }}
      return selfNodeLinkedLocationFromState(safeState, cleanNodeId);
    }}

    function selfNodeNearestCityCacheKey(location) {{
      if (!location || typeof location !== "object") return "";
      const lat = Number(location.lat);
      const lon = Number(location.lon);
      if (!selfNodeCityCoordinateIsValid(lat, lon)) return "";
      const source = location.source === "estimated" ? "estimated" : "gps";
      return `${{source}}:${{Math.round(lat * 1000)}}:${{Math.round(lon * 1000)}}`;
    }}

    function formatSelfNodeNearestCityLabel(place, location) {{
      const cleanPlace = String(place == null ? "" : place).replace(/\\s+/g, " ").trim();
      if (!cleanPlace) return "";
      return location && location.source === "estimated" ? `~ ${{cleanPlace}}` : cleanPlace;
    }}

    async function resolveSelfNodeNearestCityLabel(location) {{
      const cacheKey = selfNodeNearestCityCacheKey(location);
      if (!cacheKey) return "";
      if (selfNodeNearestCityCache.has(cacheKey)) {{
        return selfNodeNearestCityCache.get(cacheKey) || "";
      }}
      let label = "";
      if (typeof nearestOfflineCityHintFromCoords === "function") {{
        try {{
          const place = await nearestOfflineCityHintFromCoords(
            Number(location.lat),
            Number(location.lon),
            botCityHintMaxDistanceKm
          );
          label = formatSelfNodeNearestCityLabel(place, location);
        }} catch (_err) {{
          label = "";
        }}
      }}
      selfNodeNearestCityCache.set(cacheKey, label);
      while (selfNodeNearestCityCache.size > selfNodeNearestCityCacheMaxEntries) {{
        const oldestKey = selfNodeNearestCityCache.keys().next().value;
        selfNodeNearestCityCache.delete(oldestKey);
      }}
      return label;
    }}

