      const chatRosterTickerEl = document.getElementById("m-chat-roster");
      if (chatRosterTickerEl instanceof HTMLElement) {{
        const totalCount = Math.max(0, Math.trunc(Number(s.node_count) || 0));
        const onlineCount = Math.max(
          0,
          Math.min(totalCount, Math.trunc(Number(s.online_node_count) || 0))
        );
        const offlineCount = Math.max(0, totalCount - onlineCount);
        const rows = [
          {{ key: "Online", value: String(onlineCount) }},
          {{ key: "Offline", value: String(offlineCount) }},
          {{ key: "Total", value: String(totalCount) }},
