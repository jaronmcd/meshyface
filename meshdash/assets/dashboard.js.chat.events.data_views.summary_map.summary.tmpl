        const rowsHtml = rows
          .map((row) => `<div class="node-ticker-row"><span class="node-ticker-key">${{escAttr(row.key)}}:</span><span class="node-ticker-val">${{escAttr(row.value)}}</span></div>`)
          .join("");
        const rowsTitle = `Online uses Meshtastic LocalStats semantics (heard in the past 2 hours). | ${
          rows.map((row) => `${row.key}: ${row.value}`).join(" | ")
        }`;
        updateSummaryMiniPanel("m-chat-roster", chatRosterTickerEl, {{
          mode: "html",
          html: rowsHtml,
          title: rowsTitle,
