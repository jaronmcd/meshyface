    const envAggregateTickerWindowHours = 24;
    const envAggregateTickerWindowMs = envAggregateTickerWindowHours * 60 * 60 * 1000;
    const envAggregateTickerRefreshMs = Math.max(120000, refreshMs * 40);
    const envAggregateTickerMaxPoints = (envAggregateTickerWindowHours * 60) + 8;
    const envAggregateTickerStaleSeconds = 30 * 60;
    const envAggregateTickerSnapshotLookbackMinutes = 12;
    const envAggregateTickerSnapshotLookbackMs = envAggregateTickerSnapshotLookbackMinutes * 60 * 1000;
    const envAggregateTickerSnapshotMaxBucketWeight = 8;
    const envAggregateTickerNodeConsensusLookbackMinutes = 30;
    const envAggregateTickerNodeConsensusLookbackSeconds = envAggregateTickerNodeConsensusLookbackMinutes * 60;
    let envAggregateTickerSnapshots = new Map();
    let envAggregateTickerHydrated = false;
    let envAggregateTickerLastHydratedMs = 0;
    let envAggregateTickerHydrateInFlight = null;
    const selfNodeNearestCityCache = new Map();
    const selfNodeNearestCityCacheMaxEntries = 96;
    let selfNodeNearestCityRenderSeq = 0;
    let selfNodeLinkedLocationCacheKey = "";
    let selfNodeLinkedLocationCacheValue = null;
    const envAggregateTickerMetricDefs = Object.freeze([
      {{
        id: "temperature",
        label: "Temp",
        metricKeys: ["temperature", "temp"],
        valueId: "m-temperature",
        containerId: "ticker-temperature",
        deltaId: "ticker-delta-temperature",
