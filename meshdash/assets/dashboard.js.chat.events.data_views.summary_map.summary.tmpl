    function renderSummary(state) {{
      syncTopbarChatContext(state);
      const s = state.summary || {{}};
      let targetValue = s.target || "n/a";
      let updatedValue = state.generated_at || "n/a";
      let updatedFreshnessStatus = "";
      let updatedFreshnessLabel = "";
      if (activeLayoutView === "saved") {{
        const selectedId = normalizeNodeId(selectedNodeId || "");
        if (isSelectableNodeId(selectedId)) {{
          const nodes = Array.isArray(state.nodes) ? state.nodes : [];
          const node = nodes.find((entry) => normalizeNodeId(entry && entry.id) === selectedId) || null;
          const historyCapsById = new Map(
            Object.entries((state.history_caps && typeof state.history_caps === "object") ? state.history_caps : {{}})
              .map(([rawNodeId, caps]) => [normalizeNodeId(rawNodeId), caps])
              .filter(([nodeId, caps]) => isSelectableNodeId(nodeId) && caps && typeof caps === "object")
          );
          const caps = historyCapsById.get(selectedId) || null;
          const traffic = (state.traffic && typeof state.traffic === "object") ? state.traffic : {{}};
          const chatMessages = Array.isArray(traffic.recent_chat) ? traffic.recent_chat : [];
          const latestChatTouchByNode = mapLatestChatTouchInfo(chatMessages);
          const freshness = resolveNodeFreshness(node, caps, null, latestChatTouchByNode.get(selectedId) || null);
          const status = freshnessStatus(freshness.unix, Math.floor(Date.now() / 1000));
          updatedValue = savedDetailText(freshness.text, state.generated_at || "n/a");
          updatedFreshnessStatus = status;
          updatedFreshnessLabel = status === "online"
            ? "Fresh"
            : (status === "warn" ? "Aging" : (status === "stale" ? "Stale" : "Unknown"));
        }}
      }}
      const targetDisplay = compactTargetMetric(targetValue);
      setText("m-target", targetDisplay);
      const targetMetric = document.getElementById("m-target");
      if (targetMetric instanceof HTMLElement) {{
        const fullTarget = String(targetValue == null ? "" : targetValue).trim();
        targetMetric.title = fullTarget || "n/a";
      }}
      renderTargetRadioStatus(state);
      setText("m-nodes", s.node_count ?? 0);
      setText("m-online-nodes", s.online_node_count ?? 0);
      const rawLivePacketTotal = Number(s.live_packet_count);
      const livePacketTotal = Number.isFinite(rawLivePacketTotal) ? rawLivePacketTotal : 0;
      if (resetTickerScaleOnRestart) {{
        maybeResetMetricTickerSeries(livePacketTotal);
      }}
      const localTelemetry = resolveLocalNodeTelemetry(state);
      const batteryPct = Number(localTelemetry && localTelemetry.batteryPct);
      const voltage = Number(localTelemetry && localTelemetry.voltage);
      const batteryPctText = Number.isFinite(batteryPct)
        ? `${{Number.isInteger(batteryPct) ? batteryPct.toFixed(0) : batteryPct.toFixed(1)}}%`
        : null;
      const batteryVoltText = Number.isFinite(voltage) ? `${{voltage.toFixed(2)}}V` : null;
      const batteryDisplayText = [batteryPctText, batteryVoltText].filter(Boolean).join(" · ") || "n/a";
      const showKnownNodesTrend = tickerTrendEnabled("known_nodes");
      const showOnlineNodesTrend = tickerTrendEnabled("online_nodes");
      const showPacketsTrend = tickerTrendEnabled("packets_per_min");
      const showChannelUtilTrend = tickerTrendEnabled("channel_util");
      const showBatteryTrend = tickerTrendEnabled("battery");
      const showWifiTrend = tickerTrendEnabled("wifi");
      const showNodeTrend = tickerTrendEnabled("node");
      const batteryTrendWindowMs = batteryTrendWindowHours() * 60 * 60 * 1000;
      setText("m-battery", batteryDisplayText);
      const batteryMetricValueEl = document.getElementById("m-battery");
      if (batteryMetricValueEl instanceof HTMLElement) {{
        batteryMetricValueEl.title = Number.isFinite(batteryPct)
          ? `Battery ${{batteryPctText || "n/a"}} | Voltage ${{batteryVoltText || "n/a"}} | Local node ${{localTelemetry.nodeName || "n/a"}}`
          : `Battery n/a | Voltage ${{batteryVoltText || "n/a"}}`;
      }}
      updateMetricTicker("nodes", s.node_count ?? 0, {{
        containerId: "ticker-nodes",
        deltaId: "ticker-delta-nodes",
        rateId: "ticker-rate-nodes",
        chartId: "ticker-chart-nodes",
        digits: 0,
      }});
      const nodesTicker = document.getElementById("ticker-nodes");
      if (nodesTicker instanceof HTMLElement && !showKnownNodesTrend) {{
        nodesTicker.hidden = true;
      }}
      updateMetricTicker("online_nodes", s.online_node_count ?? 0, {{
        containerId: "ticker-online-nodes",
        deltaId: "ticker-delta-online-nodes",
        rateId: "ticker-rate-online-nodes",
        chartId: "ticker-chart-online-nodes",
        digits: 0,
      }});
      const onlineNodesTicker = document.getElementById("ticker-online-nodes");
      if (onlineNodesTicker instanceof HTMLElement && !showOnlineNodesTrend) {{
        onlineNodesTicker.hidden = true;
      }}
      appendMetricTickerPoint("live_packets", livePacketTotal);
      const livePacketSeries = metricTickerSeries.get("live_packets") || [];
      const packetsPerMinuteSeries = derivePacketsPerMinuteSeriesFromTotals(livePacketSeries);
      const latestPacketsPerMinute = packetsPerMinuteSeries.length
        ? Number(packetsPerMinuteSeries[packetsPerMinuteSeries.length - 1].value)
        : 0;
      updateMetricTicker("live_packets_per_min", latestPacketsPerMinute, {{
        containerId: "ticker-live-packets",
        deltaId: "ticker-delta-live-packets",
        rateId: "ticker-rate-live-packets",
        chartId: "ticker-chart-live-packets",
        digits: 1,
      }});
      const packetsTicker = document.getElementById("ticker-live-packets");
      if (packetsTicker instanceof HTMLElement && !showPacketsTrend) {{
        packetsTicker.hidden = true;
      }}
      const packetsPerMinute = derivePacketsPerMinuteFromTotals(livePacketSeries);
      setText("m-live-packets", formatTickerNumber(packetsPerMinute, 1));
      const livePacketsMetric = document.getElementById("m-live-packets");
      if (livePacketsMetric instanceof HTMLElement) {{
        livePacketsMetric.title = `Packets per minute (derived). Total packets in background: ${{formatTickerNumber(livePacketTotal, 0)}}`;
      }}
      const channelUtilTicker = buildChannelUtilTickerSummary(state);
      setText("m-channel-util", channelUtilTicker && channelUtilTicker.text ? String(channelUtilTicker.text) : "n/a");
      const channelUtilMetric = document.getElementById("m-channel-util");
      if (channelUtilMetric instanceof HTMLElement) {{
        channelUtilMetric.title = channelUtilTicker && channelUtilTicker.title
          ? String(channelUtilTicker.title)
          : "Channel utilization unavailable";
      }}
      const channelUtilValue = Number(channelUtilTicker && channelUtilTicker.channel_util);
      if (Number.isFinite(channelUtilValue)) {{
        updateMetricTicker("channel_utilization_pct", channelUtilValue, {{
          containerId: "ticker-channel-util",
          deltaId: "ticker-delta-channel-util",
          rateId: "ticker-rate-channel-util",
          chartId: "ticker-chart-channel-util",
          digits: 1,
          rateDigits: 1,
          flatThreshold: 0.3,
          valueUnit: "%",
          windowMs: 2 * 60 * 60 * 1000,
          maxPoints: 240,
        }});
        const channelUtilMetricTicker = document.getElementById("ticker-channel-util");
        if (channelUtilMetricTicker instanceof HTMLElement && !showChannelUtilTrend) {{
          channelUtilMetricTicker.hidden = true;
        }}
      }} else {{
        const channelUtilMetricTicker = document.getElementById("ticker-channel-util");
        if (channelUtilMetricTicker instanceof HTMLElement) {{
          channelUtilMetricTicker.hidden = true;
        }}
      }}
      if (Number.isFinite(batteryPct)) {{
        updateMetricTicker("battery_pct", batteryPct, {{
          containerId: "ticker-battery",
          deltaId: "ticker-delta-battery",
          rateId: "ticker-rate-battery",
          chartId: "ticker-chart-battery",
          digits: 1,
          rateDigits: 2,
          flatThreshold: 0.15,
          valueUnit: "%",
          windowMs: batteryTrendWindowMs,
          maxPoints: 480,
        }});
        const batteryTicker = document.getElementById("ticker-battery");
        if (batteryTicker instanceof HTMLElement && !showBatteryTrend) {{
          batteryTicker.hidden = true;
        }}
      }} else {{
        const batteryTicker = document.getElementById("ticker-battery");
        if (batteryTicker instanceof HTMLElement) {{
          batteryTicker.hidden = true;
        }}
      }}
      const nodeTicker = buildNodeTickerSummary(state);
      const nodeTickerEl = document.getElementById("m-node-ticker");
      const nodeTickerItem = document.getElementById("summary-ticker-node");
      if (nodeTickerEl instanceof HTMLElement) {{
        const rowsHtml = String(nodeTicker && nodeTicker.rows_html ? nodeTicker.rows_html : "");
        const hasRows = !!(nodeTicker && nodeTicker.has_rows && rowsHtml);
        nodeTickerEl.classList.toggle("is-compact", !hasRows);
        if (nodeTickerItem instanceof HTMLElement) {{
          nodeTickerItem.classList.toggle("has-extra-rows", hasRows);
        }}
        if (rowsHtml) {{
          nodeTickerEl.innerHTML = rowsHtml;
        }} else {{
          nodeTickerEl.textContent = nodeTicker && nodeTicker.text ? String(nodeTicker.text) : "n/a";
        }}
        nodeTickerEl.title = nodeTicker.title || "Node summary unavailable";
      }} else if (nodeTickerItem instanceof HTMLElement) {{
        nodeTickerItem.classList.remove("has-extra-rows");
      }}
      const nodeRssi = Number(nodeTicker && nodeTicker.rssi_dbm);
      const nodeSnr = Number(nodeTicker && nodeTicker.snr_db);
      const nodeSignalValue = Number.isFinite(nodeRssi) ? nodeRssi : nodeSnr;
      const nodeSignalMetricKey = Number.isFinite(nodeRssi) ? "node_rssi_dbm" : "node_snr_db";
      const nodeSignalUnit = Number.isFinite(nodeRssi) ? "dBm" : "dB";
      const nodeSignalDigits = Number.isFinite(nodeRssi) ? 0 : 1;
      if (Number.isFinite(nodeSignalValue)) {{
        updateMetricTicker(nodeSignalMetricKey, nodeSignalValue, {{
          containerId: "ticker-node-signal",
          deltaId: "ticker-delta-node-signal",
          rateId: "ticker-rate-node-signal",
          chartId: "ticker-chart-node-signal",
          digits: nodeSignalDigits,
          rateDigits: 1,
          flatThreshold: 0.4,
          valueUnit: nodeSignalUnit,
          windowMs: 2 * 60 * 60 * 1000,
          maxPoints: 240,
        }});
        const nodeMetricTicker = document.getElementById("ticker-node-signal");
        if (nodeMetricTicker instanceof HTMLElement && !showNodeTrend) {{
          nodeMetricTicker.hidden = true;
        }}
      }} else {{
        const nodeMetricTicker = document.getElementById("ticker-node-signal");
        if (nodeMetricTicker instanceof HTMLElement) {{
          nodeMetricTicker.hidden = true;
        }}
      }}
      const gpsTicker = buildGpsTickerSummary(state);
      const gpsTickerEl = document.getElementById("m-gps-ticker");
      if (gpsTickerEl instanceof HTMLElement) {{
        const rowsHtml = String(gpsTicker && gpsTicker.rows_html ? gpsTicker.rows_html : "");
        if (rowsHtml) {{
          gpsTickerEl.innerHTML = rowsHtml;
        }} else {{
          gpsTickerEl.textContent = gpsTicker && gpsTicker.text ? String(gpsTicker.text) : "n/a";
        }}
        gpsTickerEl.title = gpsTicker && gpsTicker.title ? String(gpsTicker.title) : "GPS summary unavailable";
      }}
      const systemTicker = buildSystemTickerSummary(state);
      const systemTickerEl = document.getElementById("m-system-ticker");
      if (systemTickerEl instanceof HTMLElement) {{
        const rowsHtml = String(systemTicker && systemTicker.rows_html ? systemTicker.rows_html : "");
        if (rowsHtml) {{
          systemTickerEl.innerHTML = rowsHtml;
        }} else {{
          systemTickerEl.textContent = systemTicker && systemTicker.text ? String(systemTicker.text) : "n/a";
        }}
        systemTickerEl.title = systemTicker && systemTicker.title ? String(systemTicker.title) : "System summary unavailable";
      }}
      const wifiTicker = buildWifiTickerSummary(state);
      const wifiTickerEl = document.getElementById("m-wifi-ticker");
      if (wifiTickerEl instanceof HTMLElement) {{
        const rowsHtml = String(wifiTicker && wifiTicker.rows_html ? wifiTicker.rows_html : "");
        if (rowsHtml) {{
          wifiTickerEl.innerHTML = rowsHtml;
        }} else {{
          wifiTickerEl.textContent = wifiTicker && wifiTicker.text ? String(wifiTicker.text) : "n/a";
        }}
        wifiTickerEl.title = wifiTicker && wifiTicker.title ? String(wifiTicker.title) : "Wi-Fi summary unavailable";
      }}
      const wifiRssi = Number(wifiTicker && wifiTicker.rssi_dbm);
      if (Number.isFinite(wifiRssi)) {{
        updateMetricTicker("wifi_rssi_dbm", wifiRssi, {{
          containerId: "ticker-wifi",
          deltaId: "ticker-delta-wifi",
          rateId: "ticker-rate-wifi",
          chartId: "ticker-chart-wifi",
          digits: 0,
          rateDigits: 1,
          flatThreshold: 1,
          valueUnit: "dBm",
          windowMs: 2 * 60 * 60 * 1000,
          maxPoints: 240,
        }});
        const wifiMetricTicker = document.getElementById("ticker-wifi");
        if (wifiMetricTicker instanceof HTMLElement && !showWifiTrend) {{
          wifiMetricTicker.hidden = true;
        }}
      }} else {{
        const wifiMetricTicker = document.getElementById("ticker-wifi");
        if (wifiMetricTicker instanceof HTMLElement) {{
          wifiMetricTicker.hidden = true;
        }}
      }}
      const radioReportedTime = resolveRadioReportedTime(state);
      syncRadioTimeBase(radioReportedTime.unix, radioReportedTime.source);
      syncUptimeBase(s.uptime_seconds);
      updateUptimeDisplay();
      setText("updated-at", updatedValue);
      const updatedFreshness = document.getElementById("updated-freshness");
      if (updatedFreshness instanceof HTMLElement) {{
        updatedFreshness.classList.remove("status-online", "status-warn", "status-stale", "status-unknown");
        if (activeLayoutView === "saved" && updatedFreshnessLabel) {{
          updatedFreshness.hidden = false;
          updatedFreshness.textContent = updatedFreshnessLabel;
          updatedFreshness.classList.add(`status-${{updatedFreshnessStatus || "unknown"}}`);
        }} else {{
          updatedFreshness.hidden = true;
          updatedFreshness.textContent = "";
        }}
      }}
      const err = document.getElementById("local-state-error");
      if (err) {{
        const parts = [];
        if (state.local_state_error) {{
          parts.push(`Local state error: ${{trimInlineError(state.local_state_error)}}`);
        }}
        if (state.tracker_error) {{
          parts.push(`Tracker error: ${{trimInlineError(state.tracker_error)}}`);
        }}
        err.textContent = parts.length > 0 ? `  ${{parts.join(" | ")}}` : "";
      }}

      const revision = s.revision || {{}};
      const revisionText = document.getElementById("revision-text");
      if (revisionText) {{
        const fallbackLabel = String(revision.label || "").trim();
        const version = String(revision.version || "").trim();
        const commit = String(revision.commit || "").trim();
        if (fallbackLabel) {{
          revisionText.textContent = fallbackLabel;
        }} else if (version || commit) {{
          const versionText = version ? `v${{version}}` : "unknown";
          const commitText = commit || "nogit";
          revisionText.textContent = `Rev: ${{versionText}} (${{commitText}})`;
        }}
        const title = String(revision.title || "").trim();
        if (title) {{
          revisionText.title = title;
        }}
      }}

      const disk = s.disk || {{}};
      const diskLabel = document.getElementById("disk-label");
      const diskFill = document.getElementById("disk-fill");
      const diskMeter = document.getElementById("disk-meter");
      const freePctRaw = Number(disk.free_pct);
      if (!Number.isFinite(freePctRaw)) {{
        if (diskLabel) {{
          diskLabel.textContent = "Disk free: n/a";
        }}
        if (diskFill) {{
          diskFill.style.width = "0%";
          diskFill.classList.remove("warn", "danger");
        }}
        if (diskMeter) {{
          const detail = disk.error ? ` (${{disk.error}})` : "";
          diskMeter.title = `Disk free on dashboard host${{detail}}`;
        }}
        requestTopbarLayoutMetricsSync();
        return;
      }}

      const freePct = Math.max(0, Math.min(100, freePctRaw));
      if (diskLabel) {{
        diskLabel.textContent = `Disk free: ${{freePct.toFixed(1)}}%`;
      }}
      if (diskFill) {{
        diskFill.style.width = `${{freePct.toFixed(1)}}%`;
        diskFill.classList.remove("warn", "danger");
        if (freePct < 15) {{
          diskFill.classList.add("danger");
        }} else if (freePct < 30) {{
          diskFill.classList.add("warn");
        }}
      }}
      if (diskMeter) {{
        const freeGiB = bytesToGiB(disk.free_bytes);
        const totalGiB = bytesToGiB(disk.total_bytes);
        const freeText = freeGiB == null ? "n/a" : freeGiB.toFixed(1);
        const totalText = totalGiB == null ? "n/a" : totalGiB.toFixed(1);
        diskMeter.title = `Disk free on dashboard host (${{freeText}} GiB / ${{totalText}} GiB, path: ${{disk.path || "n/a"}})`;
      }}
      requestTopbarLayoutMetricsSync();
    }}

