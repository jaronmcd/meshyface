    function favoriteMenuTagChipHtml(nodeId, extraClass = "") {{
      const tagEntry = nodeTagEntryForNode(nodeId);
      const styleVars = tagEntry ? nodeTagStyleVars(tagEntry) : "";
      const styleAttr = styleVars ? ` style="${{escAttr(styleVars)}}"` : "";
      const title = tagEntry && tagEntry.preset
        ? `Tag: ${{nodeTagDisplayLabel(tagEntry, "Tagged")}}`
        : "No tag";
      const emojiHtml = nodeTagChipEmojiHtml(tagEntry, nodeId);
      const iconClass = tagEntry && typeof nodeTagIconPathForEntry === "function" && nodeTagIconPathForEntry(tagEntry)
        ? " has-icon"
        : "";
      return `<span class="favorite-menu-tag-chip ${{extraClass}}${{tagEntry ? " is-tagged" : ""}}${{emojiHtml ? " has-emoji" : ""}}${{iconClass}}"${{styleAttr}} title="${{escAttr(title)}}" aria-hidden="true">${{emojiHtml}}</span>`;
    }}

    function favoriteMenuTagEditorHtml(nodeId) {{
      const cleanNodeId = normalizeNodeId(nodeId);
      if (!isSelectableNodeId(cleanNodeId)) return "";
      const currentTag = typeof manualNodeTagEntryForNode === "function"
        ? manualNodeTagEntryForNode(cleanNodeId)
        : nodeTagEntryForNode(cleanNodeId);
      const currentPreset = currentTag && currentTag.preset
        ? currentTag.preset
        : nodeTagPresetForId(activeNodeTagPresetId) || defaultNodeTagPreset();
      const selectedPresetId = currentTag && currentTag.presetId
        ? currentTag.presetId
        : normalizeNodeTagPresetId(activeNodeTagPresetId || currentPreset.id || "tag-default", "tag-default");
      const selectedPresetLocked = favoriteMenuTagPresetFieldsLocked(selectedPresetId);
      const presets = nodeTagPresetEntries();
      const optionsHtml = presets.map((preset) => {{
        const presetId = normalizeNodeTagPresetId(preset.id, "tag-default");
        const selectedAttr = presetId === selectedPresetId ? " selected" : "";
        return `<option value="${{escAttr(presetId)}}"${{selectedAttr}}>${{escAttr(preset.name)}}</option>`;
      }}).join("");
      return `<div id="favorite-menu-tag-editor" class="favorite-menu-tag-editor" data-node-id="${{escAttr(cleanNodeId)}}">
        <div class="favorite-menu-tag-editor-row">
          <label for="favorite-menu-tag-preset-select" class="favorite-menu-tag-editor-label">Preset</label>
          <select id="favorite-menu-tag-preset-select" class="favorite-menu-tag-preset-select">
            ${{optionsHtml}}
          </select>
        </div>
        <div class="favorite-menu-tag-editor-row">
          <label for="favorite-menu-tag-name-input" class="favorite-menu-tag-editor-label">Name</label>
          <input id="favorite-menu-tag-name-input" class="favorite-menu-tag-editor-input" type="text" maxlength="40" value="${{escAttr(normalizeNodeTagPresetName(currentPreset.name, "Tagged"))}}" placeholder="Tag name"${{selectedPresetLocked ? " disabled" : ""}} />
        </div>
        <div class="favorite-menu-tag-editor-row">
          <label for="favorite-menu-tag-emoji-input" class="favorite-menu-tag-editor-label">Tag Emoji</label>
          <input id="favorite-menu-tag-emoji-input" class="favorite-menu-tag-editor-input favorite-menu-tag-emoji-input" type="text" maxlength="8" value="${{escAttr(normalizeNodeTagEmoji(currentPreset.emoji, ""))}}" placeholder="Optional emoji"${{selectedPresetLocked ? " disabled" : ""}} />
        </div>
        <div class="favorite-menu-tag-editor-row">
          <label for="favorite-menu-node-emoji-input" class="favorite-menu-tag-editor-label">Node Icon</label>
          <input id="favorite-menu-node-emoji-input" class="favorite-menu-tag-editor-input favorite-menu-tag-emoji-input" type="text" maxlength="8" value="${{escAttr(nodeEmojiOverrideForNode(cleanNodeId))}}" placeholder="Optional node-specific emoji" />
        </div>
        <div class="favorite-menu-tag-editor-row favorite-menu-tag-editor-row-inline">
          <label for="favorite-menu-tag-color-input" class="favorite-menu-tag-editor-label">Color</label>
          <input id="favorite-menu-tag-color-input" class="favorite-menu-tag-color-input" type="color" value="${{escAttr(normalizeNodeTagColor(currentPreset.color, "#2aa85a"))}}"${{selectedPresetLocked ? " disabled" : ""}} />
          <label for="favorite-menu-tag-vibrance-input" class="favorite-menu-tag-editor-label">Vibrance</label>
          <input id="favorite-menu-tag-vibrance-input" class="favorite-menu-tag-vibrance-input" type="range" min="0" max="100" step="1" value="${{escAttr(clampNodeTagVibrance(currentPreset.vibrance, 70))}}"${{selectedPresetLocked ? " disabled" : ""}} />
          <span id="favorite-menu-tag-vibrance-value" class="favorite-menu-tag-vibrance-value">${{escAttr(clampNodeTagVibrance(currentPreset.vibrance, 70))}}%</span>
          <span id="favorite-menu-tag-preview" class="favorite-menu-tag-chip favorite-menu-tag-chip-preview" style="${{escAttr(nodeTagStyleVars({{ preset: currentPreset }}))}}" aria-hidden="true"></span>
        </div>
        <div class="favorite-menu-tag-editor-actions">
          <button id="favorite-menu-tag-save-preset-btn" class="btn btn-secondary" type="button"${{selectedPresetLocked ? " disabled" : ""}}>Save Preset</button>
          <button id="favorite-menu-tag-assign-btn" class="btn btn-secondary" type="button">Assign</button>
          <button id="favorite-menu-node-emoji-save-btn" class="btn btn-secondary" type="button">Save Icon</button>
          <button id="favorite-menu-node-emoji-clear-btn" class="btn btn-secondary" type="button">Clear Icon</button>
          <button id="favorite-menu-tag-clear-btn" class="btn btn-secondary" type="button">Clear Tag</button>
        </div>
        <div id="favorite-menu-tag-status" class="favorite-menu-tag-status"></div>
      </div>`;
    }}

    function favoriteMenuTagPresetFieldsLocked(presetId) {{
      return (typeof isMeshtasticFavoritePresetId === "function")
        ? isMeshtasticFavoritePresetId(presetId)
        : false;
    }}

    function bindFavoriteMenuTagEditorControls(nodeId) {{
      const cleanNodeId = normalizeNodeId(nodeId);
      const host = document.getElementById("favorite-menu-tag-editor");
      if (!(host instanceof HTMLElement)) return;
      if (normalizeNodeId(host.dataset.nodeId || "") !== cleanNodeId) return;
      const presetSelect = document.getElementById("favorite-menu-tag-preset-select");
      const nameInput = document.getElementById("favorite-menu-tag-name-input");
      const emojiInput = document.getElementById("favorite-menu-tag-emoji-input");
      const nodeEmojiInput = document.getElementById("favorite-menu-node-emoji-input");
      const colorInput = document.getElementById("favorite-menu-tag-color-input");
      const vibranceInput = document.getElementById("favorite-menu-tag-vibrance-input");
      const vibranceValue = document.getElementById("favorite-menu-tag-vibrance-value");
      const preview = document.getElementById("favorite-menu-tag-preview");
      const statusEl = document.getElementById("favorite-menu-tag-status");
      const savePresetBtn = document.getElementById("favorite-menu-tag-save-preset-btn");
      const assignBtn = document.getElementById("favorite-menu-tag-assign-btn");
      const saveNodeEmojiBtn = document.getElementById("favorite-menu-node-emoji-save-btn");
      const clearNodeEmojiBtn = document.getElementById("favorite-menu-node-emoji-clear-btn");
      const clearBtn = document.getElementById("favorite-menu-tag-clear-btn");
      if (!(presetSelect instanceof HTMLSelectElement)) return;
      if (!(nameInput instanceof HTMLInputElement)) return;
      if (!(emojiInput instanceof HTMLInputElement)) return;
      if (!(nodeEmojiInput instanceof HTMLInputElement)) return;
      if (!(colorInput instanceof HTMLInputElement)) return;
      if (!(vibranceInput instanceof HTMLInputElement)) return;
      if (!(vibranceValue instanceof HTMLElement)) return;
      if (!(preview instanceof HTMLElement)) return;
      if (!(statusEl instanceof HTMLElement)) return;
      if (!(savePresetBtn instanceof HTMLButtonElement)) return;
      if (!(assignBtn instanceof HTMLButtonElement)) return;
      if (!(saveNodeEmojiBtn instanceof HTMLButtonElement)) return;
      if (!(clearNodeEmojiBtn instanceof HTMLButtonElement)) return;
      if (!(clearBtn instanceof HTMLButtonElement)) return;

      const setStatus = (text) => {{
        statusEl.textContent = String(text == null ? "" : text);
      }};

      const applyPreview = () => {{
        const color = normalizeNodeTagColor(colorInput.value, "#2aa85a");
        const vibrance = clampNodeTagVibrance(vibranceInput.value, 70);
        const emoji = normalizeNodeTagEmoji(emojiInput.value, "");
        const nodeEmoji = normalizeNodeTagEmoji(nodeEmojiInput.value, "");
        emojiInput.value = emoji;
        nodeEmojiInput.value = nodeEmoji;
        vibranceValue.textContent = `${{vibrance}}%`;
        const styleVars = nodeTagStyleVars({{
          preset: {{
            color,
            vibrance,
          }},
        }});
        preview.setAttribute("style", styleVars);
        preview.classList.toggle("has-emoji", !!(nodeEmoji || emoji));
        preview.innerHTML = (nodeEmoji || emoji) ? `<span class="favorite-menu-tag-chip-emoji" aria-hidden="true">${{escAttr(nodeEmoji || emoji)}}</span>` : "";
      }};

      const applyPresetLockState = (presetId) => {{
        const locked = favoriteMenuTagPresetFieldsLocked(presetId);
        nameInput.disabled = locked;
        emojiInput.disabled = locked;
        colorInput.disabled = locked;
        vibranceInput.disabled = locked;
        savePresetBtn.disabled = locked;
      }};

      const loadPresetIntoEditor = (presetId) => {{
        const preset = nodeTagPresetForId(presetId);
        if (!preset) return;
        nameInput.value = normalizeNodeTagPresetName(preset.name, "Tagged");
        emojiInput.value = normalizeNodeTagEmoji(preset.emoji, "");
        nodeEmojiInput.value = nodeEmojiOverrideForNode(cleanNodeId);
        colorInput.value = normalizeNodeTagColor(preset.color, "#2aa85a");
        vibranceInput.value = String(clampNodeTagVibrance(preset.vibrance, 70));
        applyPresetLockState(preset.id);
        applyPreview();
      }};

      const persistPresetFromEditor = (preferredId = "") => {{
        const preferredPresetId = normalizeNodeTagPresetId(preferredId || "", "");
        const effectivePreferredId = (
          preferredPresetId
          && typeof isNodeTagPresetIdLocked === "function"
          && isNodeTagPresetIdLocked(preferredPresetId)
        )
          ? ""
          : preferredPresetId;
        const preset = upsertNodeTagPreset(
          nameInput.value,
          colorInput.value,
          vibranceInput.value,
          {{
            preferredId: effectivePreferredId,
            emoji: emojiInput.value,
          }}
        );
        setActiveNodeTagPreset(preset.id, true);
        renderStarredNodeSelect(latestState || {{}});
        setStatus(`Preset saved: ${{preset.name}}`);
        return preset;
      }};

      if (presetSelect.dataset.bound !== "1") {{
        presetSelect.dataset.bound = "1";
        presetSelect.addEventListener("change", () => {{
          const presetId = normalizeNodeTagPresetId(presetSelect.value || "", "");
          setActiveNodeTagPreset(presetId, true);
          loadPresetIntoEditor(presetId);
          setStatus("");
        }});
      }}
      if (nameInput.dataset.bound !== "1") {{
        nameInput.dataset.bound = "1";
        nameInput.addEventListener("input", () => {{
          applyPreview();
          setStatus("");
        }});
      }}
      if (emojiInput.dataset.bound !== "1") {{
        emojiInput.dataset.bound = "1";
        emojiInput.addEventListener("input", () => {{
          applyPreview();
          setStatus("");
        }});
        emojiInput.addEventListener("blur", () => {{
          emojiInput.value = normalizeNodeTagEmoji(emojiInput.value, "");
          applyPreview();
        }});
        const openEmojiPicker = () => {{
          if (typeof openChatEmojiPanel !== "function") return;
          openChatEmojiPanel("tag", null, emojiInput);
        }};
        emojiInput.addEventListener("click", () => {{
          openEmojiPicker();
        }});
        emojiInput.addEventListener("focus", () => {{
          openEmojiPicker();
        }});
        emojiInput.addEventListener("keydown", (ev) => {{
          const key = String(ev.key || "");
          if (key === "Enter" || key === "ArrowDown" || key === " ") {{
            ev.preventDefault();
            openEmojiPicker();
          }}
        }});
      }}
      if (nodeEmojiInput.dataset.bound !== "1") {{
        nodeEmojiInput.dataset.bound = "1";
        nodeEmojiInput.addEventListener("input", () => {{
          applyPreview();
          setStatus("");
        }});
        nodeEmojiInput.addEventListener("blur", () => {{
          nodeEmojiInput.value = normalizeNodeTagEmoji(nodeEmojiInput.value, "");
          applyPreview();
        }});
        const openNodeEmojiPicker = () => {{
          if (typeof openChatEmojiPanel !== "function") return;
          openChatEmojiPanel("tag", null, nodeEmojiInput);
        }};
        nodeEmojiInput.addEventListener("click", () => {{
          openNodeEmojiPicker();
        }});
        nodeEmojiInput.addEventListener("focus", () => {{
          openNodeEmojiPicker();
        }});
        nodeEmojiInput.addEventListener("keydown", (ev) => {{
          const key = String(ev.key || "");
          if (key === "Enter" || key === "ArrowDown" || key === " ") {{
            ev.preventDefault();
            openNodeEmojiPicker();
          }}
        }});
      }}
      if (colorInput.dataset.bound !== "1") {{
        colorInput.dataset.bound = "1";
        const syncColorPreview = () => {{
          applyPreview();
          setStatus("");
        }};
        colorInput.addEventListener("input", syncColorPreview);
        colorInput.addEventListener("change", syncColorPreview);
      }}
      if (vibranceInput.dataset.bound !== "1") {{
        vibranceInput.dataset.bound = "1";
        const syncVibrancePreview = () => {{
          applyPreview();
          setStatus("");
        }};
        vibranceInput.addEventListener("input", syncVibrancePreview);
        vibranceInput.addEventListener("change", syncVibrancePreview);
      }}
      if (savePresetBtn.dataset.bound !== "1") {{
        savePresetBtn.dataset.bound = "1";
        savePresetBtn.addEventListener("click", () => {{
          const preferredId = normalizeNodeTagPresetId(presetSelect.value || "", "");
          persistPresetFromEditor(preferredId);
        }});
      }}
      if (assignBtn.dataset.bound !== "1") {{
        assignBtn.dataset.bound = "1";
        assignBtn.addEventListener("click", () => {{
          const preferredId = normalizeNodeTagPresetId(presetSelect.value || "", "");
          const preset = persistPresetFromEditor(preferredId);
          const presetId = normalizeNodeTagPresetId(preset && preset.id, "");
          if (!presetId || !nodeTagPresetsById.has(presetId)) return;
          assignNodeTagPresetToNode(cleanNodeId, presetId, {{ persist: false }});
          saveNodeEmojiOverride(cleanNodeId, "", {{ persist: false }});
          nodeEmojiInput.value = "";
          persistFavoriteNodes();
          refreshFavoriteToggleButtons();
          if (latestState) {{
            renderFavorites(latestState);
          }} else {{
            renderStarredNodeSelect({{}});
          }}
          if (typeof syncChatNodeDetailsDrawer === "function") {{
            syncChatNodeDetailsDrawer(latestState, {{
              fetchHistory: false,
            }});
          }}
        }});
      }}
      if (saveNodeEmojiBtn.dataset.bound !== "1") {{
        saveNodeEmojiBtn.dataset.bound = "1";
        saveNodeEmojiBtn.addEventListener("click", () => {{
          const emoji = saveNodeEmojiOverride(cleanNodeId, nodeEmojiInput.value, {{ persist: true }});
          nodeEmojiInput.value = emoji;
          applyPreview();
          refreshFavoriteToggleButtons();
          if (latestState) {{
            renderFavorites(latestState);
          }} else {{
            renderStarredNodeSelect({{}});
          }}
          if (typeof syncChatNodeDetailsDrawer === "function") {{
            syncChatNodeDetailsDrawer(latestState, {{ fetchHistory: false }});
          }}
          setStatus(emoji ? "Node icon saved." : "Node icon cleared.");
        }});
      }}
      if (clearNodeEmojiBtn.dataset.bound !== "1") {{
        clearNodeEmojiBtn.dataset.bound = "1";
        clearNodeEmojiBtn.addEventListener("click", () => {{
          saveNodeEmojiOverride(cleanNodeId, "", {{ persist: true }});
          nodeEmojiInput.value = "";
          applyPreview();
          refreshFavoriteToggleButtons();
          if (latestState) {{
            renderFavorites(latestState);
          }} else {{
            renderStarredNodeSelect({{}});
          }}
          if (typeof syncChatNodeDetailsDrawer === "function") {{
            syncChatNodeDetailsDrawer(latestState, {{ fetchHistory: false }});
          }}
          setStatus("Node icon cleared.");
        }});
      }}
      if (clearBtn.dataset.bound !== "1") {{
        clearBtn.dataset.bound = "1";
        clearBtn.addEventListener("click", () => {{
          clearNodeTagForNode(cleanNodeId);
          refreshFavoriteToggleButtons();
          if (latestState) {{
            renderFavorites(latestState);
          }} else {{
            renderStarredNodeSelect({{}});
          }}
          if (typeof syncChatNodeDetailsDrawer === "function") {{
            syncChatNodeDetailsDrawer(latestState, {{
              fetchHistory: false,
            }});
          }}
        }});
      }}

      applyPreview();
    }}

    function renderStarredNodeSelect(state) {{
      const selectedList = document.getElementById("favorite-menu-selected-list");
      const list = document.getElementById("favorite-menu-saved-list");
      if (!(list instanceof HTMLElement)) return;

      const safeState = (state && typeof state === "object") ? state : {{}};
      const nodes = Array.isArray(safeState.nodes) ? safeState.nodes : [];
      const nodesById = new Map(nodes.map((node) => [normalizeNodeId(node.id || ""), node]));
      const resolveEntryName = (nodeId) => {{
        const normalized = normalizeNodeId(nodeId);
        const node = nodesById.get(normalized);
        return preferredNodeName(node) || nodeNameCache.get(normalized) || `Node ${{normalized}}`;
      }};
      const entries = visibleFavoriteNodeIds()
        .map((nodeId) => {{
          const name = resolveEntryName(nodeId);
          const tagEntry = nodeTagEntryForNode(nodeId);
          const tagName = tagEntry && tagEntry.preset
            ? nodeTagDisplayLabel(tagEntry, "Tagged")
            : "Tagged";
          return {{ id: nodeId, name, tagName, tagEntry }};
        }})
        .sort((a, b) => {{
          const tagDiff = String(a.tagName || "").localeCompare(String(b.tagName || ""));
          if (tagDiff !== 0) return tagDiff;
          const nameDiff = String(a.name || "").localeCompare(String(b.name || ""));
          if (nameDiff !== 0) return nameDiff;
          return String(a.id || "").localeCompare(String(b.id || ""));
        }});
      const selectedNodeValue = isSelectableNodeId(selectedNodeId) ? normalizeNodeId(selectedNodeId) : "";
      const showSelectedTopRow = !!selectedNodeValue;

      if (selectedList instanceof HTMLElement) {{
        if (showSelectedTopRow) {{
          closeFavoriteMenuNodeSearchDropdown();
          const selectedName = resolveEntryName(selectedNodeValue);
          const selectedTagChip = favoriteMenuTagChipHtml(selectedNodeValue, "favorite-menu-selected-chip");
          const title = `Selected: ${{selectedName}} (${{selectedNodeValue}}). Click to clear selection.`;
          selectedList.innerHTML = `<div class="favorite-menu-selected-stack">
            <button type="button" role="listitem" class="favorite-menu-saved-item favorite-menu-selected-item active" data-node-id="${{escAttr(selectedNodeValue)}}" title="${{escAttr(title)}}" aria-label="${{escAttr(title)}}">
              <span class="favorite-menu-saved-main">
                <span class="favorite-menu-selected-prefix">Selected</span>
                ${{selectedTagChip}}
                <span class="favorite-menu-saved-name">${{escAttr(selectedName)}}</span>
              </span>
              <span class="favorite-menu-saved-id">${{escAttr(selectedNodeValue)}}</span>
            </button>
          </div>`;
        }} else {{
          let searchInput = document.getElementById("favorite-menu-node-search-input");
          let searchDropdown = document.getElementById("favorite-menu-node-search-dropdown");
          const hasSearchControls = (
            searchInput instanceof HTMLInputElement
            && searchDropdown instanceof HTMLElement
            && selectedList.contains(searchInput)
            && selectedList.contains(searchDropdown)
          );
          if (!hasSearchControls) {{
            selectedList.innerHTML = `<div class="favorite-menu-node-search-wrap">
              <input
                id="favorite-menu-node-search-input"
                class="list-search-input"
                type="search"
                placeholder="Search by ID, name, or notes"
                autocomplete="off"
              />
              <div id="favorite-menu-node-search-dropdown" class="node-search-dropdown favorite-menu-node-search-dropdown" hidden></div>
            </div>`;
            searchInput = document.getElementById("favorite-menu-node-search-input");
            searchDropdown = document.getElementById("favorite-menu-node-search-dropdown");
          }}
          if (searchInput instanceof HTMLInputElement) {{
            searchInput.value = globalNodeSearchQuery();
          }}
          bindFavoriteMenuNodeSearchControls();
          renderFavoriteMenuNodeSearchDropdown(safeState);
        }}
      }}
      if (!entries.length) {{
        list.innerHTML = '<div class="favorite-menu-saved-empty">No tagged nodes yet.</div>';
        return;
      }}
      list.innerHTML = entries.map((entry) => {{
        const title = `${{entry.name}} (${{entry.id}})`;
        const tagChip = favoriteMenuTagChipHtml(entry.id);
        return `<button type="button" role="listitem" class="favorite-menu-saved-item" data-node-id="${{escAttr(entry.id)}}" title="${{escAttr(title)}}" aria-label="${{escAttr(title)}}">
          <span class="favorite-menu-saved-main">
            ${{tagChip}}
            <span class="favorite-menu-saved-name">${{escAttr(entry.name)}}</span>
          </span>
          <span class="favorite-menu-saved-id">${{escAttr(entry.id)}}</span>
        </button>`;
      }}).join("");
    }}

    function refreshFavoriteToggleButtons() {{
      const activePreset = nodeTagPresetForId(activeNodeTagPresetId) || nodeTagPresetForId("tag-default");
      const activePresetLabel = activePreset
        ? normalizeNodeTagPresetName(activePreset.name, "Tagged")
        : "tag";
      for (const btn of document.querySelectorAll(".favorite-toggle-btn")) {{
        if (!(btn instanceof HTMLButtonElement)) continue;
        const nodeId = normalizeNodeId(btn.dataset.nodeId || "");
        const tagEntry = typeof manualNodeTagEntryForNode === "function"
          ? manualNodeTagEntryForNode(nodeId)
          : nodeTagEntryForNode(nodeId);
        const active = !!tagEntry;
        btn.classList.toggle("active", active);
        btn.setAttribute("aria-pressed", active ? "true" : "false");
        const title = active
          ? `Clear tag (${{nodeTagDisplayLabel(tagEntry, "Tagged")}})`
          : `Tag node with ${{activePresetLabel}}`;
        btn.title = title;
        btn.setAttribute("aria-label", title);
        const styleVars = active ? nodeTagStyleVars(tagEntry) : "";
        if (styleVars) {{
          btn.setAttribute("style", styleVars);
        }} else {{
          btn.removeAttribute("style");
        }}
        const icon = btn.querySelector(".favorite-toggle-icon");
        if (icon) {{
          icon.textContent = active ? nodeTagEmojiForEntry(tagEntry) : "";
        }}
        const cell = btn.closest && btn.closest("td");
        if (cell instanceof HTMLElement) {{
          cell.setAttribute("data-sort", active ? "1" : "0");
        }}
      }}
      const visibleMetaFieldIds = (typeof normalizeChatNodeNavigatorMetaFieldIdsPref === "function")
        ? normalizeChatNodeNavigatorMetaFieldIdsPref(chatNodeNavigatorMetaFieldIds, {{ fallbackToDefaults: false }})
        : [];
      const showTagBadge = Array.isArray(visibleMetaFieldIds)
        && visibleMetaFieldIds.includes("favorite");
      const nodeSurfaceTintSuffixes = [
        "hue",
        "tint-start-hue",
        "tint-end-hue",
        "sat-mult",
        "light-shift",
        "dark-sat-mult",
        "dark-light-shift",
        "outline-hue",
        "outline-sat-mult",
        "outline-light-shift",
        "outline-dark-sat-mult",
        "outline-dark-light-shift",
      ];
      function nodeSurfaceTintScope(scope = "member") {{
        return String(scope || "member").trim().toLowerCase() === "feed" ? "feed" : "member";
      }}
      function clearNodeSurfaceTintStyle(target, scope = "member") {{
        if (!(target instanceof HTMLElement)) return;
        const cleanScope = nodeSurfaceTintScope(scope);
        const prefix = cleanScope === "feed" ? "--chat-feed-node-" : "--chat-member-node-";
        for (const suffix of nodeSurfaceTintSuffixes) {{
          target.style.removeProperty(`${{prefix}}${{suffix}}`);
        }}
        target.style.removeProperty("--node-tag-color");
        target.style.removeProperty("--node-tag-vibrance");
        target.style.removeProperty("--node-profile-border");
        target.style.removeProperty("--node-profile-bg");
        if (typeof clearMeshyfaceProfileThemeElementStyle === "function") {{
          clearMeshyfaceProfileThemeElementStyle(target);
        }}
      }}
      function applyNodeAppearanceSurfaceStyle(target, appearanceEntry, scope = "member", fallbackHue = 145) {{
        if (!(target instanceof HTMLElement)) return false;
        const entry = appearanceEntry && typeof appearanceEntry === "object" && appearanceEntry.preset
          ? appearanceEntry
          : null;
        const cleanScope = nodeSurfaceTintScope(scope);
        clearNodeSurfaceTintStyle(target, cleanScope);
        if (!entry) return false;
        const prefix = cleanScope === "feed" ? "--chat-feed-node-" : "--chat-member-node-";
        const hueRaw = typeof nodeTagTintHue === "function"
          ? nodeTagTintHue(entry, fallbackHue)
          : fallbackHue;
        const hue = Math.max(0, Math.min(359, Math.trunc(Number(hueRaw) || fallbackHue)));
        target.style.setProperty(`${{prefix}}hue`, String(hue));
        target.style.setProperty(`${{prefix}}tint-start-hue`, String(hue));
        target.style.setProperty(`${{prefix}}tint-end-hue`, String(hue));
        target.style.setProperty(`${{prefix}}outline-hue`, String(hue));
        const color = normalizeNodeTagColor(entry.preset.color, "#2aa85a");
        target.style.setProperty("--node-tag-color", color);
        target.style.setProperty("--node-tag-vibrance", (clampNodeTagVibrance(entry.preset.vibrance, 70) / 100).toFixed(3));
        target.style.setProperty("--node-profile-border", color);
        target.style.setProperty(
          "--node-profile-bg",
          `color-mix(in srgb, ${{color}} 15%, var(--surface-tint-bg-soft) 85%)`
        );
        if (typeof applyMeshyfaceProfileThemeElementStyle === "function") {{
          applyMeshyfaceProfileThemeElementStyle(target, entry.theme);
        }}
        return true;
      }}
      for (const member of document.querySelectorAll("#chat-room-unread-list .chat-member-item, #chat-room-meshtastic-list .chat-member-item, #chat-room-pinned-list .chat-member-item, #chat-room-list .chat-member-item")) {{
        if (!(member instanceof HTMLElement)) continue;
        const nodeId = normalizeNodeId(member.dataset.nodeId || "");
        const tagEntry = nodeTagEntryForNode(nodeId);
        const tagActive = !!(tagEntry && tagEntry.preset);
        const appearanceEntry = (typeof effectiveNodeAppearanceForNode === "function")
          ? effectiveNodeAppearanceForNode(nodeId)
          : tagEntry;
        const appearanceActive = !!(appearanceEntry && appearanceEntry.preset);
        member.classList.toggle("tagged-node", tagActive);
        member.classList.toggle("profiled-node", appearanceActive && !tagActive);
        const nameLeft = member.querySelector(".chat-member-name-left");
        const existingChip = nameLeft instanceof HTMLElement
          ? nameLeft.querySelector(".chat-member-tag-chip")
          : null;
        if (appearanceActive) {{
          applyNodeAppearanceSurfaceStyle(member, appearanceEntry, "member", 145);
        }} else {{
          clearNodeSurfaceTintStyle(member, "member");
        }}
        if (tagActive) {{
          const tagLabel = normalizeNodeTagPresetName(tagEntry.preset.name, "Tagged");
          const tagDisplayLabel = nodeTagDisplayLabel(tagEntry, "Tagged");
          const tagStyleVars = nodeTagStyleVars(tagEntry);
          if (showTagBadge) {{
            if (existingChip instanceof HTMLElement) {{
              existingChip.textContent = tagDisplayLabel;
              existingChip.title = `Tag: ${{tagDisplayLabel}}`;
              if (tagStyleVars) {{
                existingChip.setAttribute("style", tagStyleVars);
              }} else {{
                existingChip.removeAttribute("style");
              }}
            }} else if (nameLeft instanceof HTMLElement) {{
              const chip = document.createElement("span");
              chip.className = "chat-member-tag-chip";
              chip.textContent = tagDisplayLabel;
              chip.title = `Tag: ${{tagDisplayLabel}}`;
              if (tagStyleVars) {{
                chip.setAttribute("style", tagStyleVars);
              }}
              nameLeft.appendChild(chip);
            }}
          }} else if (existingChip instanceof HTMLElement) {{
            existingChip.remove();
          }}
        }} else {{
          if (existingChip instanceof HTMLElement) {{
            existingChip.remove();
          }}
        }}
      }}
      for (const row of document.querySelectorAll("#chat-feed .chat-feed-item")) {{
        if (!(row instanceof HTMLElement)) continue;
        const rowCandidates = [
          row.dataset.fromNodeId,
          row.dataset.nodeId,
          row.dataset.replyName,
        ];
        let rowNodeId = "";
        let tagEntry = null;
        for (const candidate of rowCandidates) {{
          const clean = normalizeNodeId(candidate || "");
          if (!isSelectableNodeId(clean)) continue;
          const entry = nodeTagEntryForNode(clean);
          if (entry && entry.preset) {{
            rowNodeId = clean;
            tagEntry = entry;
            break;
          }}
          if (!rowNodeId) {{
            rowNodeId = clean;
          }}
        }}
        if (!isSelectableNodeId(rowNodeId)) continue;
        const tagActive = !!(tagEntry && tagEntry.preset);
        const appearanceEntry = (typeof effectiveNodeAppearanceForNode === "function")
          ? effectiveNodeAppearanceForNode(rowNodeId)
          : tagEntry;
        const appearanceActive = !!(appearanceEntry && appearanceEntry.preset);
        row.classList.toggle("tagged-node", tagActive);
        row.classList.toggle("profiled-node", appearanceActive && !tagActive);
        if (appearanceActive) {{
          applyNodeAppearanceSurfaceStyle(row, appearanceEntry, "feed", 210);
        }} else {{
          clearNodeSurfaceTintStyle(row, "feed");
        }}
      }}
      syncMapTitleFavoriteToggle();
      renderSavedRailStatus();

      const nodesSort = tableSortState["nodes-table"];
      if (nodesSort && Number(nodesSort.index) === 9) {{
        sortTableRows("nodes-table");
      }}
    }}

    function refreshMuteToggleButtons() {{
      for (const btn of document.querySelectorAll(".mute-toggle-btn")) {{
        if (!(btn instanceof HTMLButtonElement)) continue;
        const nodeId = normalizeNodeId(btn.dataset.nodeId || "");
        const active = isMutedNode(nodeId);
        btn.classList.toggle("active", active);
        btn.setAttribute("aria-pressed", active ? "true" : "false");
        const title = active ? "Unmute this user in chat feed" : "Mute this user in chat feed";
        btn.title = title;
        btn.setAttribute("aria-label", title);
        const icon = btn.querySelector(".mute-toggle-icon");
        if (icon) {{
          icon.textContent = active ? "🔇" : "🔊";
        }}
        const label = btn.querySelector(".chat-node-details-mute-label");
        if (label) {{
          label.textContent = active ? "Muted" : "Mute";
        }}
      }}
    }}

    function refreshPinToggleButtons() {{
      for (const btn of document.querySelectorAll(".pin-toggle-btn")) {{
        if (!(btn instanceof HTMLButtonElement)) continue;
        const nodeId = normalizeNodeId(btn.dataset.nodeId || "");
        const active = isPinnedNode(nodeId);
        btn.classList.toggle("active", active);
        btn.setAttribute("aria-pressed", active ? "true" : "false");
        const title = active
          ? "Unpin this node from the top of the chat list"
          : "Pin this node to the top of the chat list";
        btn.title = title;
        btn.setAttribute("aria-label", title);
        const label = btn.querySelector(".chat-node-details-pin-label");
        if (label) {{
          label.textContent = active ? "Pinned" : "Pin";
        }}
      }}
    }}

    function toggleFavoriteNode(nodeId, forceActive = null) {{
      const normalized = normalizeNodeId(nodeId);
      if (!isSelectableNodeId(normalized)) return;
      const currentManualTag = typeof manualNodeTagEntryForNode === "function"
        ? manualNodeTagEntryForNode(normalized)
        : nodeTagEntryForNode(normalized);
      const targetActive = forceActive == null ? !currentManualTag : !!forceActive;
      if (targetActive) {{
        const preferredPresetId = normalizeNodeTagPresetId(activeNodeTagPresetId || "tag-default", "tag-default");
        const fallbackPreset = nodeTagPresetForId(preferredPresetId) || nodeTagPresetForId("tag-default") || defaultNodeTagPreset();
        const ensurePreset = nodeTagPresetsById.has(fallbackPreset.id)
          ? fallbackPreset
          : upsertNodeTagPreset(fallbackPreset.name, fallbackPreset.color, fallbackPreset.vibrance, {{ preferredId: fallbackPreset.id }});
        assignNodeTagPresetToNode(normalized, ensurePreset.id, {{ persist: false }});
      }} else {{
        clearNodeTagForNode(normalized, {{ persist: false }});
      }}
      persistFavoriteNodes();
      refreshFavoriteToggleButtons();
      if (latestState) {{
        renderFavorites(latestState);
      }} else {{
        renderStarredNodeSelect({{}});
      }}
      if (typeof syncChatNodeDetailsDrawer === "function") {{
        syncChatNodeDetailsDrawer(latestState, {{
          fetchHistory: false,
        }});
      }}
      if (typeof setChatSendStatus === "function") {{
        const statusText = targetActive
          ? `Tagged node ${{normalized}}.`
          : `Cleared tag for node ${{normalized}}.`;
        setChatSendStatus(statusText);
      }}
    }}

    function toggleMutedNode(nodeId, forceActive = null) {{
      const normalized = normalizeNodeId(nodeId);
      if (!isSelectableNodeId(normalized) || isSelfNodeId(normalized)) return;
      const targetActive = forceActive == null ? !mutedNodeIds.has(normalized) : !!forceActive;
      if (targetActive) {{
        mutedNodeIds.add(normalized);
      }} else {{
        mutedNodeIds.delete(normalized);
      }}
      persistMutedNodes();
      if (latestState) {{
        renderChat(latestState);
      }} else {{
        refreshMuteToggleButtons();
      }}
      setChatSendStatus(
        targetActive
          ? `Muted ${{normalized}} in chat feed.`
          : `Unmuted ${{normalized}} in chat feed.`
      );
    }}

    function applyPinnedNodeState(nodeId, active) {{
      const normalized = normalizeNodeId(nodeId);
      if (!isSelectableNodeId(normalized)) return;
      if (active) {{
        pinnedNodeIds.add(normalized);
      }} else {{
        pinnedNodeIds.delete(normalized);
      }}
      persistPinnedNodes();
      if (latestState) {{
        renderChat(latestState);
      }} else {{
        refreshPinToggleButtons();
      }}
    }}

    function connectedDeviceRoleForFavoriteSync(state = latestState) {{
      const safeState = state && typeof state === "object" ? state : {{}};
      const localState = safeState.local_state && typeof safeState.local_state === "object"
        ? safeState.local_state
        : null;
      const localConfig = localState && typeof localState.local_config === "object"
        ? localState.local_config
        : null;
      const deviceConfig = localConfig && typeof localConfig.device === "object"
        ? localConfig.device
        : null;
      const rawRole = deviceConfig ? deviceConfig.role : null;
      if (typeof normalizeDeviceRole === "function") {{
        return normalizeDeviceRole(rawRole);
      }}
      const text = String(rawRole == null ? "" : rawRole).trim().toUpperCase();
      if (text) return text;
      return "CLIENT";
    }}

    async function requestMeshtasticFavoriteTagSync(nodeId, targetActive) {{
      const normalized = normalizeNodeId(nodeId);
      if (!isCanonicalNodeId(normalized)) return false;
      if (
        typeof shouldIgnoreMeshtasticFavoriteNodeId === "function"
        && shouldIgnoreMeshtasticFavoriteNodeId(normalized, latestState)
      ) {{
        setChatSendStatus("Self node is not managed as a Meshtastic favorite.");
        return false;
      }}
      if (meshtasticFavoriteSyncInFlightNodeIds.has(normalized)) {{
        setChatSendStatus(`Favorite sync already in progress for ${{normalized}}.`);
        return false;
      }}
      if (targetActive) {{
        const role = connectedDeviceRoleForFavoriteSync(latestState);
        if (role === "CLIENT_BASE" && typeof window !== "undefined" && typeof window.confirm === "function") {{
          const approved = window.confirm(
            "CLIENT_BASE should only favorite nodes you control. Continue?"
          );
          if (!approved) {{
            setChatSendStatus(
              `Canceled Meshtastic favorite sync for ${{normalized}} (CLIENT_BASE safeguard).`,
              true
            );
            return false;
          }}
        }}
      }}
      if (typeof postNetworkToolCommand !== "function") {{
        setChatSendStatus(
          `Favorite sync unavailable for ${{normalized}}.`,
          true
        );
        return false;
      }}

      meshtasticFavoriteSyncInFlightNodeIds.add(normalized);
      meshtasticFavoritePendingDesiredByNodeId.set(normalized, {{
        active: !!targetActive,
        sinceMs: Date.now(),
      }});
      const command = targetActive ? "set-favorite" : "remove-favorite";
      try {{
        await postNetworkToolCommand({{
          command,
          destination: normalized,
        }});
        if (typeof requestImmediatePoll === "function") {{
          requestImmediatePoll(0);
        }}
        setChatSendStatus(
          targetActive
            ? `Tagged ${{normalized}} as Meshtastic favorite.`
            : `Removed Meshtastic favorite for ${{normalized}}.`
        );
        return true;
      }} catch (err) {{
        const reason = (err && typeof err === "object" && "message" in err)
          ? String(err.message || "").trim()
          : "";
        const message = reason || "favorite sync failed";
        meshtasticFavoritePendingDesiredByNodeId.delete(normalized);
        setChatSendStatus(
          `Meshtastic favorite sync failed for ${{normalized}}: ${{message}}.`,
          true
        );
        if (typeof requestImmediatePoll === "function") {{
          requestImmediatePoll(0);
        }}
        return false;
      }} finally {{
        meshtasticFavoriteSyncInFlightNodeIds.delete(normalized);
        if (typeof renderNodeVisibilityListsUi === "function") {{
          renderNodeVisibilityListsUi(latestRawState || latestState || {{}});
        }}
      }}
    }}

    function toggleMeshtasticFavoriteNode(nodeId, forceActive = null) {{
      const normalized = normalizeNodeId(nodeId);
      if (!isSelectableNodeId(normalized) || !isCanonicalNodeId(normalized)) return;
      if (
        typeof shouldIgnoreMeshtasticFavoriteNodeId === "function"
        && shouldIgnoreMeshtasticFavoriteNodeId(normalized, latestState)
      ) {{
        setChatSendStatus("Self node is not managed as a Meshtastic favorite.");
        return;
      }}
      if (meshtasticFavoriteSyncInFlightNodeIds.has(normalized)) {{
        setChatSendStatus(`Favorite sync already in progress for ${{normalized}}.`);
        return;
      }}
      const previousPresetId = normalizeNodeTagPresetId(nodeTagByNodeId.get(normalized), "");
      const previousActive = (typeof isMeshtasticFavoritePresetId === "function")
        ? isMeshtasticFavoritePresetId(previousPresetId)
        : false;
      const targetActive = forceActive == null ? !previousActive : !!forceActive;
      if (targetActive === previousActive) return;
      if (targetActive) {{
        const meshtasticPreset = (typeof ensureMeshtasticFavoriteTagPreset === "function")
          ? ensureMeshtasticFavoriteTagPreset()
          : null;
        const presetId = normalizeNodeTagPresetId(
          meshtasticPreset && meshtasticPreset.id,
          "meshtastic-favorite"
        );
        if (!presetId || !nodeTagPresetsById.has(presetId)) return;
        assignNodeTagPresetToNode(normalized, presetId, {{ persist: true }});
      }} else {{
        clearNodeTagForNode(normalized, {{ persist: true }});
      }}
      refreshFavoriteToggleButtons();
      if (latestState) {{
        renderFavorites(latestState);
      }} else {{
        renderStarredNodeSelect({{}});
      }}
      if (typeof syncChatNodeDetailsDrawer === "function") {{
        syncChatNodeDetailsDrawer(latestState, {{ fetchHistory: false }});
      }}
    }}

    function togglePinnedNode(nodeId, forceActive = null) {{
      const normalized = normalizeNodeId(nodeId);
      if (!isSelectableNodeId(normalized)) return;
      const previousActive = pinnedNodeIds.has(normalized);
      const targetActive = forceActive == null ? !previousActive : !!forceActive;
      applyPinnedNodeState(normalized, targetActive);
      setChatSendStatus(
        targetActive
          ? `Pinned ${{normalized}} to the top of the chat list.`
          : `Unpinned ${{normalized}} from the top of the chat list.`
      );
    }}
