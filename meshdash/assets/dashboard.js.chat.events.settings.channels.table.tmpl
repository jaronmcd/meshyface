        "settings-ticker-move-down",
        "settings-ticker-label",
        "settings-ticker-show-trend",
        "settings-ticker-battery-window-hours",
        "settings-ticker-node-row-snr",
        "settings-ticker-node-row-rssi",
        "settings-ticker-node-row-route",
