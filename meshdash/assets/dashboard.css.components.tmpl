    .console-filter-input {{
      border: 1px solid #c2d8c7;
      background: #f0f8f2;
      color: #1e5e40;
      border-radius: 6px;
      font-size: 11px;
      padding: 4px 8px;
      font-family: inherit;
      min-width: 140px;
      width: min(34vw, 260px);
    }}
    .console-terminal-screen {{
      position: relative;
      display: flex;
      flex-direction: column;
      flex: 1 1 auto;
      min-height: 0;
      border: 1px solid #7ab18a;
      border-radius: 8px;
      background:
        radial-gradient(circle at top, rgba(255, 255, 255, 0.58), transparent 40%),
        radial-gradient(circle at 50% 120%, rgba(138, 194, 156, 0.18), transparent 46%),
        linear-gradient(180deg, #eef8f1 0%, #dceddf 58%, #d1e6d8 100%);
      box-shadow:
        inset 0 0 0 1px rgba(255, 255, 255, 0.5),
        inset 0 0 28px rgba(95, 152, 114, 0.12),
        0 10px 20px rgba(49, 86, 60, 0.08);
      overflow: hidden;
    }}
    .console-terminal-screen::before {{
      content: "";
      position: absolute;
      inset: 0;
      background:
        linear-gradient(
          180deg,
          rgba(56, 97, 68, 0.035) 0,
          rgba(56, 97, 68, 0.035) 1px,
          transparent 1px,
          transparent 4px
        );
      opacity: 0.45;
      pointer-events: none;
    }}
    .console-command-input-proxy {{
      position: absolute;
      top: 0;
      left: 0;
      width: 1px;
      height: 1px;
      opacity: 0;
      border: 0;
      padding: 0;
      margin: 0;
      pointer-events: none;
    }}
    #live-console {{
      margin: 0;
      background: transparent;
      border: none;
      color: #17482d;
      border-radius: 0;
      padding: 12px;
      min-height: 0;
      max-height: none;
      flex: 1 1 auto;
      overflow-y: auto;
      overflow-x: auto;
      font-size: 10px;
      line-height: 1.3;
      white-space: pre;
      overflow-wrap: normal;
      word-break: normal;
      cursor: text;
      text-shadow: 0 0 4px rgba(123, 180, 141, 0.08);
    }}
    .console-caret {{
      display: inline-block;
      width: 0;
      height: 1em;
      border-left: 1px solid currentColor;
      margin-left: -0.5px;
      vertical-align: -0.12em;
      pointer-events: none;
    }}
    details {{
      border: 1px solid #d7e5d2;
      border-radius: 6px;
      padding: 6px 8px;
      margin-bottom: 6px;
      background: #fcfffc;
    }}
    summary {{ cursor: pointer; font-weight: 600; }}
    pre {{
      margin: 10px 0 0 0;
      background: #0e1f16;
      color: #cbffde;
      border-radius: 6px;
      padding: 8px;
      max-height: 200px;
      overflow: auto;
      font-size: 10px;
      line-height: 1.35;
      white-space: pre-wrap;
      word-break: break-word;
    }}
