    @media (max-width: 1100px) {{
      html, body {{
        height: auto;
        overflow: auto;
      }}
      .workspace-shell {{
        grid-template-columns: 1fr;
        grid-template-rows: auto auto auto;
        gap: 6px;
        padding: 6px;
        height: auto;
        min-height: 0;
        overflow: visible;
      }}
      .workspace-main {{
        min-height: 0;
        height: auto;
        overflow: visible;
      }}
      .teams-rail {{
        position: static;
        height: auto;
        min-height: 0;
        flex-direction: row;
        align-items: center;
        overflow-x: auto;
        overflow-y: hidden;
        padding: 6px;
      }}
      .teams-rail-title {{
        display: none;
      }}
      .rail-btn {{
        min-width: 74px;
      }}
      .workspace-shell.chat-panel-open {{
        grid-template-columns: 1fr;
      }}
      .chat-left-panel {{
        position: static;
        height: auto;
        min-height: 0;
        max-height: 220px;
      }}
      .layout {{
        grid-template-columns: 1fr;
        grid-template-rows: auto;
      }}
      .layout.view-network {{
        height: auto;
        min-height: 0;
      }}
      .layout.view-history {{
        height: auto;
        min-height: 0;
      }}
      .layout.view-saved {{
        height: auto;
        min-height: 0;
      }}
      .layout.view-saved .map-card-head {{
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 8px;
        border-bottom: 1px solid #d2e1d0;
        background: #edf6ec;
        padding: 8px 10px 7px 10px;
      }}
      .layout.view-saved .map-card-head::before {{
        content: none;
      }}
      .layout.view-saved .map-card-head .pane-head-title,
      .layout.view-saved .map-card-head .pane-head-actions {{
        border: 0;
        border-radius: 0;
        background: transparent;
        min-height: 0;
        padding: 0;
      }}
      [data-theme="dark"] .layout.view-saved .map-card-head {{
        background: #070d07;
        border-bottom-color: #236744;
      }}
      .layout.view-saved .map .body {{
        display: flex;
        flex-direction: column;
      }}
      .layout.view-saved .map-frame,
      .layout.view-saved .saved-node-details {{
        border-top: 1px solid var(--saved-pane-head-border);
        border-radius: 8px;
      }}
      .saved-map-splitter,
      .saved-map-splitter-head {{
        display: none !important;
      }}
      .saved-node-history-splitter {{
        display: none !important;
      }}
      .history-activity-splitter {{
        display: none !important;
      }}
      .history-chat-splitter {{
        display: none !important;
      }}
      .layout.view-history .history-activity-main-scroll {{
        flex: 1 1 auto;
      }}
      .layout.view-history .history-chat-main-scroll {{
        flex: 1 1 auto;
      }}
      .layout.view-saved .saved-node-main-scroll {{
        flex: 1 1 auto;
      }}
