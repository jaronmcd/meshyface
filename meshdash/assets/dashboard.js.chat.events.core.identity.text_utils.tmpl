    function escAttr(value) {{
      return String(value)
        .replace(/&/g, "&amp;")
        .replace(/"/g, "&quot;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;");
    }}

    function splitTrailingUrlPunctuation(urlText) {{
      let url = String(urlText || "");
      let trailing = "";
      const trimSimple = new Set([".", ",", "!", "?", ";", ":"]);
      const maybeUnbalancedPairs = [
        [")", "("],
        ["]", "["],
        ["}", "{"],
      ];
      while (url) {{
        const last = url.slice(-1);
        if (trimSimple.has(last)) {{
          trailing = `${{last}}${{trailing}}`;
          url = url.slice(0, -1);
          continue;
        }}
        let trimmed = false;
        for (const [closeChar, openChar] of maybeUnbalancedPairs) {{
          if (last !== closeChar) continue;
          const opens = url.split(openChar).length - 1;
          const closes = url.split(closeChar).length - 1;
          if (closes > opens) {{
            trailing = `${{last}}${{trailing}}`;
            url = url.slice(0, -1);
            trimmed = true;
          }}
          break;
        }}
        if (trimmed) continue;
        break;
      }}
      return {{ url, trailing }};
    }}

    const chatEmojiSegmenter = (
      typeof Intl !== "undefined" && typeof Intl.Segmenter === "function"
    )
      ? new Intl.Segmenter(undefined, {{ granularity: "grapheme" }})
      : null;
    const chatInlineEmojiTokenRe = /(?:\p{Extended_Pictographic}|\p{Regional_Indicator}|\u20E3)/u;

    function chatSplitGraphemes(textValue) {{
      const raw = String(textValue == null ? "" : textValue);
      if (!raw) return [];
      return chatEmojiSegmenter
        ? Array.from(chatEmojiSegmenter.segment(raw), (segment) => String(segment.segment || ""))
        : Array.from(raw);
    }}

    function chatIsEmojiOnlyText(textValue) {{
      const raw = String(textValue == null ? "" : textValue).trim();
      if (!raw) return false;

      let sawEmoji = false;
      for (const grapheme of chatSplitGraphemes(raw)) {{
        if (!grapheme || !grapheme.trim()) continue;
        if (chatInlineEmojiTokenRe.test(grapheme)) {{
          sawEmoji = true;
          continue;
        }}
        return false;
      }}
      return sawEmoji;
    }}

    function chatEscapeTextWithBreaksAndEmoji(textValue) {{
      const raw = String(textValue == null ? "" : textValue);
      if (!raw) return "";

      const parts = [];
      const chunks = raw.split(/(\\n|\n)/);
      for (const chunk of chunks) {{
        if (!chunk) continue;
        if (chunk === "\\n" || chunk === "\n") {{
          parts.push("<br/>");
          continue;
        }}
        for (const grapheme of chatSplitGraphemes(chunk)) {{
          const escaped = escAttr(grapheme);
          if (chatInlineEmojiTokenRe.test(grapheme)) {{
            parts.push(`<span class="chat-inline-emoji">${{escaped}}</span>`);
          }} else {{
            parts.push(escaped);
          }}
        }}
      }}
      return parts.join("");
    }}

    function chatPlainTextToHtml(value, linkify = false) {{
      const raw = String(value == null ? "" : value);
      if (!raw) return "";

      if (!linkify) {{
        return chatEscapeTextWithBreaksAndEmoji(raw);
      }}

      const parts = [];
      const urlRe = /https?:\/\/[^\x00-\x20<>"'`]+/gi;
      let start = 0;
      for (const match of raw.matchAll(urlRe)) {{
        const index = Number(match.index);
        if (!Number.isFinite(index) || index < start) continue;
        const token = String(match[0] || "");
        if (!token) continue;
        if (index > start) {{
          parts.push(chatEscapeTextWithBreaksAndEmoji(raw.slice(start, index)));
        }}
        const split = splitTrailingUrlPunctuation(token);
        const href = String(split.url || "");
        const suffix = String(split.trailing || "");
        const hrefLower = href.toLowerCase();
        if (href && (hrefLower.startsWith("http://") || hrefLower.startsWith("https://"))) {{
          parts.push(`<a class="chat-link" href="${{escAttr(href)}}" target="_blank" rel="noopener noreferrer">${{escAttr(href)}}</a>`);
          if (suffix) parts.push(chatEscapeTextWithBreaksAndEmoji(suffix));
        }} else {{
          parts.push(chatEscapeTextWithBreaksAndEmoji(token));
        }}
        start = index + token.length;
      }}
      if (start < raw.length) {{
        parts.push(chatEscapeTextWithBreaksAndEmoji(raw.slice(start)));
      }}
      return parts.join("");
    }}
