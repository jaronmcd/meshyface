    function scheduleFileTransferMaintenance(state = latestState) {{
      if (fileTransferMaintenanceInFlight) {{
        fileTransferMaintenanceQueued = true;
        return;
      }}
      fileTransferMaintenanceInFlight = true;
      void (async () => {{
        try {{
          await runFileTransferMaintenance(state);
        }} finally {{
          fileTransferMaintenanceInFlight = false;
          if (fileTransferMaintenanceQueued) {{
            fileTransferMaintenanceQueued = false;
            scheduleFileTransferMaintenance(latestState);
          }}
        }}
      }})();
    }}

    function hasActiveFileTransferSessions() {{
      for (const session of fileTransferOutgoingByToken.values()) {{
        if (!session || typeof session !== "object") continue;
        if (!session.delivered && !session.failed) {{
          return true;
        }}
      }}
      return false;
    }}

    function syncFileTransferBlobs(rows) {{
      const activeKeys = new Set();
      const list = Array.isArray(rows) ? rows : [];
      for (const row of list) {{
        const key = String(row && row.key ? row.key : "").trim();
        if (!key) continue;
        activeKeys.add(key);
        if (!(row && row.canDownload)) {{
          clearFileTransferMaterializedStateForKey(key);
        }}
      }}

      const materializedKeys = new Set([
        ...fileTransferBlobByKey.keys(),
        ...fileTransferDecodedBytesByKey.keys(),
      ]);
      for (const key of materializedKeys) {{
        if (activeKeys.has(key)) continue;
        clearFileTransferMaterializedStateForKey(key);
      }}
      enforceFileTransferMaterializedCacheLimits();
    }}

    function fileTransferRowMaterializeSignature(row) {{
      if (!(row && typeof row === "object")) return "";
      return [
        String(row.key || "").trim(),
        Math.max(0, Math.trunc(Number(row.expectedChunks) || 0)),
        Math.max(0, Math.trunc(Number(row.wireDeclaredBytes) || 0)),
        Math.max(0, Math.trunc(Number(row.originalDeclaredBytes) || 0)),
        normalizeFileTransferCompressionCodec(row.payloadCodec || fileTransferCompressionCodecRaw),
        Math.max(0, Math.trunc(Number(row.observedBytes) || 0)),
      ].join("|");
    }}

    function materializeFileTransferRowBytes(row) {{
      if (!(row && typeof row === "object") || !row.canDownload) return null;
      const key = String(row.key || "").trim();
      if (!key) return null;
      const signature = fileTransferRowMaterializeSignature(row);
      const priorFailure = fileTransferMaterializeFailureByKey.get(key);
      if (priorFailure && String(priorFailure.signature || "") === signature) return null;
      const cached = fileTransferDecodedBytesByKey.get(key);
      const expectedDecodedBytes = Math.max(
        0,
        Math.trunc(Number(row.originalDeclaredBytes) || 0)
      );
      if (
        cached instanceof Uint8Array
        && cached.length > 0
        && cached.length === expectedDecodedBytes
      ) {{
        touchFileTransferMaterializedState(key);
        return cached;
      }}
      clearFileTransferMaterializedStateForKey(key);
      const chunks = row.wireChunks instanceof Map ? row.wireChunks : null;
      const expectedChunks = Math.max(0, Math.trunc(Number(row.expectedChunks) || 0));
      const wireDeclaredBytes = Math.max(0, Math.trunc(Number(row.wireDeclaredBytes) || 0));
      if (!chunks || expectedChunks <= 0 || wireDeclaredBytes <= 0 || expectedDecodedBytes <= 0) {{
        setBoundedFileTransferMapEntry(
          fileTransferMaterializeFailureByKey,
          key,
          {{ signature, failedAtMs: Date.now() }},
          fileTransferMaterializeFailureMaxEntries
        );
        return null;
      }}
      let mergedLength = 0;
      for (let idx = 0; idx < expectedChunks; idx += 1) {{
        const part = chunks.get(idx);
        if (!(part instanceof Uint8Array)) {{
          mergedLength = -1;
          break;
        }}
        mergedLength += part.length;
        if (mergedLength > fileTransferMaxFileBytes + fileTransferChunkBytes) {{
          mergedLength = -1;
          break;
        }}
      }}
      if (mergedLength < wireDeclaredBytes || mergedLength <= 0) {{
        setBoundedFileTransferMapEntry(
          fileTransferMaterializeFailureByKey,
          key,
          {{ signature, failedAtMs: Date.now() }},
          fileTransferMaterializeFailureMaxEntries
        );
        return null;
      }}
      const merged = new Uint8Array(mergedLength);
      let cursor = 0;
      for (let idx = 0; idx < expectedChunks; idx += 1) {{
        const part = chunks.get(idx);
        merged.set(part, cursor);
        cursor += part.length;
      }}
      const decoded = decodeFileTransferPayloadBytes(
        merged.subarray(0, wireDeclaredBytes),
        row.payloadCodec,
        expectedDecodedBytes
      );
      if (!(decoded instanceof Uint8Array) || decoded.length !== expectedDecodedBytes) {{
        setBoundedFileTransferMapEntry(
          fileTransferMaterializeFailureByKey,
          key,
          {{ signature, failedAtMs: Date.now() }},
          fileTransferMaterializeFailureMaxEntries
        );
        return null;
      }}
      fileTransferDecodedBytesByKey.delete(key);
      fileTransferDecodedBytesByKey.set(key, decoded);
      fileTransferMaterializeFailureByKey.delete(key);
      touchFileTransferMaterializedState(key);
      enforceFileTransferMaterializedCacheLimits(key);
      return decoded;
    }}

    function fileTransferDownloadUrlForKey(transferKey) {{
      const key = String(transferKey || "").trim();
      if (!key) return "";
      const existing = fileTransferDownloadUrlByKey.get(key);
      if (existing) return existing;
      const blob = fileTransferBlobByKey.get(key);
      if (!(blob instanceof Blob)) return "";
      let created = "";
      try {{
        created = URL.createObjectURL(blob);
      }} catch (_err) {{
        created = "";
      }}
      if (created) {{
        fileTransferDownloadUrlByKey.set(key, created);
      }}
      return created;
    }}

    function downloadFileTransferByKey(transferKey) {{
      const key = String(transferKey || "").trim();
      if (!key) return;
      const row = fileTransferRows.find((entry) => entry && entry.key === key) || null;
      if (!row || !row.canDownload) {{
        setFileTransferStatus("This transfer is not complete yet.", true);
        appendFileTransferConsole("Download blocked: transfer is not complete yet.", {{ level: "warn" }});
        return;
      }}
      const bytes = materializeFileTransferRowBytes(row);
      if (!(bytes instanceof Uint8Array) || bytes.length <= 0) {{
        setFileTransferStatus("Could not validate or decode this transfer.", true);
        appendFileTransferConsole("Download blocked: transfer payload failed validation.", {{ level: "error" }});
        return;
      }}
      const priorBlob = fileTransferBlobByKey.get(key);
      if (!(priorBlob instanceof Blob) || Number(priorBlob.size) !== bytes.length) {{
        fileTransferBlobByKey.set(key, new Blob([bytes], {{ type: "application/octet-stream" }}));
        const staleUrl = fileTransferDownloadUrlByKey.get(key);
        if (staleUrl) {{
          try {{
            URL.revokeObjectURL(staleUrl);
          }} catch (_err) {{
          }}
          fileTransferDownloadUrlByKey.delete(key);
        }}
      }}
      touchFileTransferMaterializedState(key);
      enforceFileTransferMaterializedCacheLimits(key);
      const url = fileTransferDownloadUrlForKey(key);
      if (!url) {{
        setFileTransferStatus("Could not prepare file download.", true);
        appendFileTransferConsole("Download failed: could not prepare transfer blob.", {{ level: "error" }});
        return;
      }}
      const anchor = document.createElement("a");
      anchor.href = url;
      anchor.download = row.downloadName || "mesh-file.bin";
      anchor.rel = "noopener";
      anchor.style.display = "none";
      document.body.appendChild(anchor);
      anchor.click();
      anchor.remove();
      setFileTransferStatus(`Download ready: ${{row.downloadName || row.fileName}}`);
      appendFileTransferConsole(
        `Download ready for ${{row.downloadName || row.fileName}} (transfer ${{fileTransferShortTransferId(row.transferId)}}).`
      );
    }}

    function fileTransferRowByKey(transferKey) {{
      const key = String(transferKey || "").trim();
      if (!key) return null;
      return fileTransferRows.find((entry) => entry && entry.key === key) || null;
    }}

    function clearFileTransferBlobStateForKey(transferKey) {{
      const key = String(transferKey || "").trim();
      if (!key) return;
      clearFileTransferMaterializedStateForKey(key);
    }}

    function setFileTransferInboundDecisionAction(transferKey, decisionRaw, options = null) {{
      const key = String(transferKey || "").trim();
      if (!key) return;
      const decision = normalizeFileTransferInboundDecision(decisionRaw);
      if (!decision) return;
      const opts = (options && typeof options === "object") ? options : {{}};
      const mode = String(opts.mode || "").trim().toLowerCase();
      const asCancel = mode === "cancel";
      const row = fileTransferRowByKey(key);
      if (!(row && typeof row === "object")) {{
        setFileTransferStatus("Transfer row is no longer available.", true);
        return;
      }}
      if (!row.requiresInboundAccept) {{
        setFileTransferStatus("This transfer does not require receiver acceptance.", true);
        return;
      }}
      if (decision === "declined" && asCancel) {{
        const fileName = normalizeFileTransferName(row.fileName || "mesh-file.bin");
        const shortId = fileTransferShortTransferId(row.transferId);
        const confirmText = `Cancel inbound transfer "${{fileName}}" (${{shortId}})?\n\nThis stops local ACKs and halts receive progress.`;
        if (typeof window.confirm === "function" && !window.confirm(confirmText)) {{
          return;
        }}
      }}
      setFileTransferInboundDecisionByKey(key, decision, {{
        transferId: row.transferId,
        senderId: row.fromId,
        receiverId: row.toId,
        fileName: row.fileName,
      }});
      if (decision === "declined") {{
        setFileTransferInboundFlowStateByKey(key, asCancel ? "canceled-by-receiver" : "", {{
          transferId: row.transferId,
          senderId: row.fromId,
          receiverId: row.toId,
        }});
        fileTransferChunkCacheByKey.delete(key);
        clearFileTransferBlobStateForKey(key);
        fileTransferAckSentState.delete(key);
        fileTransferAckObservedChunksByKey.delete(key);
        fileTransferAckProbeCursorByKey.delete(key);
        fileTransferAckProbeStateByKey.delete(key);
        fileTransferAckMissingChannelWarnByKey.delete(key);
        fileTransferFlowSignalSentByKey.delete(key);
        const actionLabel = asCancel ? "Canceled" : "Declined";
        setFileTransferStatus(`${{actionLabel}} inbound transfer "${{row.fileName || "mesh-file.bin"}}".`);
        appendFileTransferConsole(
          `${{actionLabel}} inbound transfer ${{fileTransferShortTransferId(row.transferId)}} from ${{row.peerId || "unknown sender"}}.`,
          {{ level: "warn" }}
        );
      }} else {{
        setFileTransferStatus(`Accepted inbound transfer "${{row.fileName || "mesh-file.bin"}}".`);
        appendFileTransferConsole(
          `Accepted inbound transfer ${{fileTransferShortTransferId(row.transferId)}} from ${{row.peerId || "unknown sender"}}.`
        );
      }}
      renderFilesView(latestState);
      scheduleFileTransferMaintenance(latestState);
      requestImmediatePoll(40);
      void poll();
    }}

    function setInboundFileTransferPausedAction(transferKey, pausedRaw) {{
      const key = String(transferKey || "").trim();
      if (!key) return;
      const paused = !!pausedRaw;
      const row = fileTransferRowByKey(key);
      if (!(row && typeof row === "object")) {{
        setFileTransferStatus("Transfer row is no longer available.", true);
        return;
      }}
      if (String(row.directionClass || "").trim().toLowerCase() !== "inbound") {{
        setFileTransferStatus("Only inbound transfers can be paused or resumed.", true);
        return;
      }}
      if (!row.requiresInboundAccept || !row.inboundAccepted || row.inboundDeclined || row.delivered) {{
        setFileTransferStatus("This inbound transfer cannot be paused.", true);
        return;
      }}
      setFileTransferInboundFlowStateByKey(
        key,
        paused ? "paused" : "",
        {{
          transferId: row.transferId,
          senderId: row.fromId,
          receiverId: row.toId,
        }}
      );
      if (paused) {{
        fileTransferFlowSignalSentByKey.delete(key);
      }} else {{
        // Force one explicit resume signal on the next maintenance tick.
        fileTransferFlowSignalSentByKey.set(key, {{
          action: "pause",
          lastSentAtMs: 0,
          updatedAtMs: Date.now(),
          lastErrorAtMs: 0,
        }});
      }}
      const fileName = normalizeFileTransferName(row.fileName || "mesh-file.bin");
      if (paused) {{
        setFileTransferStatus(`Paused inbound transfer "${{fileName}}".`);
        appendFileTransferConsole(
          `Paused inbound transfer ${{fileTransferShortTransferId(row.transferId)}} from ${{row.peerId || "unknown sender"}}.`,
          {{ level: "warn" }}
        );
      }} else {{
        setFileTransferStatus(`Resumed inbound transfer "${{fileName}}".`);
        appendFileTransferConsole(
          `Resumed inbound transfer ${{fileTransferShortTransferId(row.transferId)}} from ${{row.peerId || "unknown sender"}}.`,
          {{ level: "warn" }}
        );
      }}
      renderFilesView(latestState);
      scheduleFileTransferMaintenance(latestState);
      requestImmediatePoll(40);
      void poll();
    }}

    function setOutgoingFileTransferPausedAction(transferKey, paused) {{
      const key = String(transferKey || "").trim();
      if (!key) return;
      const row = fileTransferRowByKey(key);
      if (!(row && typeof row === "object")) {{
        setFileTransferStatus("Transfer row is no longer available.", true);
        return;
      }}
      if (String(row.directionClass || "").trim().toLowerCase() !== "outbound") {{
        setFileTransferStatus("Only outbound transfers can be paused or resumed.", true);
        return;
      }}
      const transferId = String(row.transferId || "").trim().toLowerCase();
      const destination = normalizeNodeId(row.toId || row.peerId || "");
      if (!transferId || !isCanonicalNodeId(destination)) {{
        setFileTransferStatus("Cannot resolve transfer destination.", true);
        return;
      }}
      const session = findOutgoingFileTransferSession(transferId, destination, row.channelIndex);
      if (!(session && typeof session === "object")) {{
        setFileTransferStatus("This outbound session is no longer in memory.", true);
        appendFileTransferConsole(
          `Pause/resume skipped for ${{fileTransferShortTransferId(transferId)}}: local session is unavailable.`,
          {{ level: "warn" }}
        );
        return;
      }}
      const updated = setOutgoingFileTransferPaused(session, !!paused);
      if (!(updated && typeof updated === "object")) {{
        setFileTransferStatus("Could not update transfer pause state.", true);
        return;
      }}
      const fileName = normalizeFileTransferName(row.fileName || session.fileName || "mesh-file.bin");
      if (paused) {{
        setFileTransferStatus(`Paused transfer "${{fileName}}" to ${{destination}}.`);
        appendFileTransferConsole(
          `Paused outbound transfer ${{fileTransferShortTransferId(transferId)}} to ${{destination}}.`,
          {{ level: "warn" }}
        );
      }} else {{
        setFileTransferStatus(`Resumed transfer "${{fileName}}" to ${{destination}}.`);
        appendFileTransferConsole(
          `Resumed outbound transfer ${{fileTransferShortTransferId(transferId)}} to ${{destination}}.`,
          {{ level: "warn" }}
        );
      }}
      renderFilesView(latestState);
      scheduleFileTransferMaintenance(latestState);
      requestImmediatePoll(40);
      void poll();
    }}

    function cancelOutgoingFileTransferAction(transferKey) {{
      const key = String(transferKey || "").trim();
      if (!key) return;
      const row = fileTransferRowByKey(key);
      if (!(row && typeof row === "object")) {{
        setFileTransferStatus("Transfer row is no longer available.", true);
        return;
      }}
      if (String(row.directionClass || "").trim().toLowerCase() !== "outbound") {{
        setFileTransferStatus("Only outbound transfers can be canceled.", true);
        return;
      }}
      const transferId = String(row.transferId || "").trim().toLowerCase();
      const destination = normalizeNodeId(row.toId || row.peerId || "");
      if (!transferId || !isCanonicalNodeId(destination)) {{
        setFileTransferStatus("Cannot resolve transfer destination for cancel.", true);
        return;
      }}
      const session = findOutgoingFileTransferSession(transferId, destination, row.channelIndex);
      if (!(session && typeof session === "object")) {{
        setFileTransferStatus("This outbound session is no longer in memory.", true);
        appendFileTransferConsole(
          `Cancel skipped for ${{fileTransferShortTransferId(transferId)}}: local session is unavailable.`,
          {{ level: "warn" }}
        );
        return;
      }}
      const fileName = normalizeFileTransferName(row.fileName || session.fileName || "mesh-file.bin");
      const shortId = fileTransferShortTransferId(transferId);
      const confirmText = `Cancel transfer "${{fileName}}" (${{shortId}}) to ${{destination}}?\n\nThis stops retries and marks the outbound session canceled.`;
      if (typeof window.confirm === "function" && !window.confirm(confirmText)) {{
        return;
      }}
      const canceled = cancelOutgoingFileTransferSession(session, {{ clearAckState: false }});
      if (!(canceled && typeof canceled === "object")) {{
        setFileTransferStatus("Could not cancel this transfer.", true);
        return;
      }}
      setFileTransferStatus(`Canceled transfer "${{fileName}}" to ${{destination}}.`);
      appendFileTransferConsole(
        `Canceled outbound transfer ${{shortId}} to ${{destination}}.`,
        {{ level: "warn" }}
      );
      renderFilesView(latestState);
      scheduleFileTransferMaintenance(latestState);
      requestImmediatePoll(40);
      void poll();
    }}

    function cancelAllFileTransfersAction() {{
      const activeOutgoing = Array.from(fileTransferOutgoingByToken.values()).filter((session) => (
        session && typeof session === "object" && !session.delivered && !session.failed && !session.canceled
      ));
      const activeInbound = (Array.isArray(fileTransferRows) ? fileTransferRows : []).filter((row) => (
        row
        && typeof row === "object"
        && String(row.directionClass || "").trim().toLowerCase() === "inbound"
        && !row.delivered
        && !row.inboundDeclined
        && !row.inboundCanceled
      ));
      const total = activeOutgoing.length + activeInbound.length;
      if (total <= 0) {{
        setFileTransferStatus("No active file transfers to cancel.");
        return 0;
      }}
      const confirmText = `Cancel all ${{total}} active file transfer${{total === 1 ? "" : "s"}}?\n\nThis stops retries, declines inbound transfers, and queues cancel signals to peers.`;
      if (typeof window.confirm === "function" && !window.confirm(confirmText)) return 0;
      let canceled = 0;
      for (const session of activeOutgoing) {{
        if (cancelOutgoingFileTransferSession(session, {{ clearAckState: false }})) canceled += 1;
      }}
      for (const row of activeInbound) {{
        const key = String(row.key || "").trim();
        if (!key) continue;
        setFileTransferInboundDecisionByKey(key, "declined", {{
          transferId: row.transferId,
          senderId: row.fromId,
          receiverId: row.toId,
          fileName: row.fileName,
        }});
        setFileTransferInboundFlowStateByKey(key, "canceled-by-receiver", {{
          transferId: row.transferId,
          senderId: row.fromId,
          receiverId: row.toId,
        }});
        deleteFileTransferChunkCacheEntry(key);
        clearFileTransferBlobStateForKey(key);
        fileTransferAckSentState.delete(key);
        fileTransferAckObservedChunksByKey.delete(key);
        fileTransferAckProbeCursorByKey.delete(key);
        fileTransferAckProbeStateByKey.delete(key);
        fileTransferAckMissingChannelWarnByKey.delete(key);
        fileTransferFlowSignalSentByKey.delete(key);
        canceled += 1;
      }}
      const suffix = canceled === 1 ? "" : "s";
      setFileTransferStatus(`Canceled ${{canceled}} active file transfer${{suffix}}.`);
      appendFileTransferConsole(
        `Canceled all ${{canceled}} active file transfer${{suffix}}. Cancel signals queued for peers.`,
        {{ level: "warn" }}
      );
      renderFilesView(latestState);
      scheduleFileTransferMaintenance(latestState);
      requestImmediatePoll(40);
      void poll();
      return canceled;
    }}

    function clearAllFileTransferRowsAction() {{
      const activeOutgoing = Array.from(fileTransferOutgoingByToken.values()).some((session) => (
        session && typeof session === "object" && !session.delivered && !session.failed && !session.canceled
      ));
      const activeInbound = (Array.isArray(fileTransferRows) ? fileTransferRows : []).some((row) => (
        row
        && typeof row === "object"
        && String(row.directionClass || "").trim().toLowerCase() === "inbound"
        && !row.delivered
        && !row.inboundDeclined
        && !row.inboundCanceled
      ));
      if (activeOutgoing || activeInbound) {{
        setFileTransferStatus("Cancel active transfers before clearing the list.", true);
        return 0;
      }}
      const keys = (Array.isArray(fileTransferRows) ? fileTransferRows : [])
        .map((row) => String(row && row.key || "").trim())
        .filter((key, index, list) => !!key && list.indexOf(key) === index);
      if (!keys.length) {{
        setFileTransferStatus("The transfer list is already empty.");
        return 0;
      }}
      const confirmText = `Clear all ${{keys.length}} transfer row${{keys.length === 1 ? "" : "s"}} and cached received files from this browser?`;
      if (typeof window.confirm === "function" && !window.confirm(confirmText)) return 0;
      let cleared = 0;
      for (const key of keys) {{
        if (dismissFileTransferRowByKey(key)) cleared += 1;
      }}
      renderFilesView(latestState);
      const suffix = cleared === 1 ? "" : "s";
      setFileTransferStatus(`Cleared ${{cleared}} transfer row${{suffix}}.`);
      appendFileTransferConsole(`Cleared the Files list (${{cleared}} row${{suffix}}).`);
      return cleared;
    }}

    function restartOutgoingFileTransferAction(transferKey) {{
      const key = String(transferKey || "").trim();
      if (!key) return;
      const row = fileTransferRowByKey(key);
      if (!(row && typeof row === "object")) {{
        setFileTransferStatus("Transfer row is no longer available.", true);
        return;
      }}
      if (String(row.directionClass || "").trim().toLowerCase() !== "outbound") {{
        setFileTransferStatus("Only outbound transfers can be restarted.", true);
        return;
      }}
      const transferId = String(row.transferId || "").trim().toLowerCase();
      const destination = normalizeNodeId(row.toId || row.peerId || "");
      if (!transferId || !isCanonicalNodeId(destination)) {{
        setFileTransferStatus("Cannot resolve transfer destination for restart.", true);
        return;
      }}
      const session = findOutgoingFileTransferSession(transferId, destination, row.channelIndex);
      if (!(session && typeof session === "object")) {{
        setFileTransferStatus("This outbound session is no longer in memory.", true);
        appendFileTransferConsole(
          `Restart skipped for ${{fileTransferShortTransferId(transferId)}}: local session is unavailable.`,
          {{ level: "warn" }}
        );
        return;
      }}
      if (
        !String(session.metaFrame || "").trim()
        || !(Array.isArray(session.chunkFrames))
        || session.chunkFrames.length <= 0
      ) {{
        setFileTransferStatus("Cannot restart: local transfer frames are unavailable.", true);
        appendFileTransferConsole(
          `Restart skipped for ${{fileTransferShortTransferId(transferId)}}: missing local frames.`,
          {{ level: "warn" }}
        );
        return;
      }}
      const fileName = normalizeFileTransferName(row.fileName || session.fileName || "mesh-file.bin");
      const shortId = fileTransferShortTransferId(transferId);
      const confirmText = `Restart transfer "${{fileName}}" (${{shortId}}) to ${{destination}}?\n\nThis resets local ACK progress and resends metadata/chunks.`;
      if (typeof window.confirm === "function" && !window.confirm(confirmText)) {{
        return;
      }}
      const restarted = restartOutgoingFileTransferSession(session, {{ forceWaitForAccept: true }});
      if (!(restarted && typeof restarted === "object")) {{
        setFileTransferStatus("Could not restart this transfer.", true);
        return;
      }}
      setFileTransferStatus(`Restarted transfer "${{fileName}}" to ${{destination}}.`);
      appendFileTransferConsole(
        `Manual restart for ${{shortId}} to ${{destination}}: progress reset, awaiting receiver accept.`,
        {{ level: "warn" }}
      );
      renderFilesView(latestState);
      scheduleFileTransferMaintenance(latestState);
      requestImmediatePoll(40);
      void poll();
    }}

    function bindFilesTransferTableControls() {{
      const table = document.getElementById("files-transfer-table");
      if (!(table instanceof HTMLTableElement) || table.dataset.bound === "1") {{
        return;
      }}
      table.dataset.bound = "1";
      table.addEventListener("click", (event) => {{
        const target = event.target;
        if (!(target instanceof Element)) return;
        const button = target.closest("button.files-transfer-action");
        if (!(button instanceof HTMLButtonElement)) return;
        const transferKey = String(button.dataset.transferKey || "").trim();
        if (!transferKey) return;
        const action = String(button.dataset.action || "download").trim().toLowerCase();
        if (action === "accept" || action === "decline") {{
          setFileTransferInboundDecisionAction(transferKey, action === "accept" ? "accepted" : "declined");
          return;
        }}
        if (action === "cancel-inbound") {{
          setFileTransferInboundDecisionAction(transferKey, "declined", {{ mode: "cancel" }});
          return;
        }}
        if (action === "pause-inbound") {{
          setInboundFileTransferPausedAction(transferKey, true);
          return;
        }}
        if (action === "resume-inbound") {{
          setInboundFileTransferPausedAction(transferKey, false);
          return;
        }}
        if (action === "restart") {{
          restartOutgoingFileTransferAction(transferKey);
          return;
        }}
        if (action === "pause") {{
          setOutgoingFileTransferPausedAction(transferKey, true);
          return;
        }}
        if (action === "resume") {{
          setOutgoingFileTransferPausedAction(transferKey, false);
          return;
        }}
        if (action === "cancel") {{
          cancelOutgoingFileTransferAction(transferKey);
          return;
        }}
        if (action === "clear") {{
          if (!dismissFileTransferRowByKey(transferKey)) {{
            setFileTransferStatus("Transfer row could not be cleared.", true);
            return;
          }}
          setFileTransferStatus("Cleared transfer row.");
          appendFileTransferConsole("Cleared 1 transfer row from the Files table.");
          renderFilesView(latestState);
          return;
        }}
        downloadFileTransferByKey(transferKey);
      }});
    }}

    function renderFilesView(state = latestState) {{
      const selectedSeed = syncFileTransferDestinationFromSelectedNode(state, {{ persist: true }});
      renderFileTransferHopLimitPreview(state);

      const useSelectedBtn = document.getElementById("files-use-selected-btn");
      if (useSelectedBtn instanceof HTMLButtonElement) {{
        const hasSelectedSeed = isCanonicalNodeId(selectedSeed);
        useSelectedBtn.disabled = !!fileTransferSendInFlight || !hasSelectedSeed;
        useSelectedBtn.title = hasSelectedSeed
          ? `Use selected node ${{selectedSeed}} as destination.`
          : "Select a node in the list to choose a destination.";
      }}

      bindFilesTransferTableControls();
      bindFilesConsoleControls();
      bindFileTransferAutoAcceptToggle();
      syncFileTransferAutoAcceptToggle();
      renderFileTransferConsole();
      const rows = buildFileTransferRows(state);
      fileTransferRows = rows;
      syncFileTransferBlobs(rows);

      const caption = document.getElementById("files-caption");
      if (caption instanceof HTMLElement) {{
        const total = rows.length;
        const complete = rows.filter((row) => row && row.delivered).length;
        const pending = Math.max(0, total - complete);
        const channelLabel = currentMeshChannelViewLabel();
        const sendCtx = meshChannelSendContext({{ appId: "files" }});
        const sendLabel = sendCtx.sendLabel;
        const sendModeLabel = sendCtx.sendMode === "fixed" ? "Fixed" : "Global";
        if (!total) {{
          caption.textContent = `No file transfers detected yet. View channel: ${{channelLabel}}. Send channel: ${{sendLabel}} (${{sendModeLabel}}).`;
        }} else {{
          caption.textContent = `Showing ${{total}} transfer${{total === 1 ? "" : "s"}}. ${{complete}} complete, ${{pending}} pending. View channel: ${{channelLabel}}. Send channel: ${{sendLabel}} (${{sendModeLabel}}).`;
        }}
      }}

      const table = document.getElementById("files-transfer-table");
      if (!(table instanceof HTMLTableElement)) return;
      const tbody = table.querySelector("tbody");
      if (!(tbody instanceof HTMLElement)) return;
      if (!rows.length) {{
        tbody.innerHTML = '<tr><td colspan="8">No file transfers yet.</td></tr>';
        return;
      }}

      tbody.innerHTML = rows.map((row) => {{
        const unix = Number(row && row.unix);
        const when = Number.isFinite(unix) && unix > 0 ? formatLocalChatTime(unix, "n/a") : "n/a";
        const peerText = row && row.peerLabel ? row.peerLabel : (row && row.peerId ? row.peerId : "n/a");
        const peerTitle = row && row.peerTitle ? row.peerTitle : peerText;
        const nameMain = compactInlineMessage(row && row.fileName ? row.fileName : "mesh-file.bin", 52);
        const nameSub = `id:${{compactInlineMessage(String((row && row.transferId) || ""), 24)}}`;
        const directionClass = String(row && row.directionClass ? row.directionClass : "other");
        const directionLabel = String(row && row.directionLabel ? row.directionLabel : "Seen");
        const channelLabel = String(row && row.channelLabel ? row.channelLabel : "Unknown");
        const requiresInboundAccept = !!(row && row.requiresInboundAccept);
        const inboundAccepted = !!(row && row.inboundAccepted);
        const inboundPending = !!(row && row.inboundPending);
        const inboundDeclined = !!(row && row.inboundDeclined);
        const progressPctRaw = Number(row && row.progressPercent);
        const progressPct = Number.isFinite(progressPctRaw)
          ? Math.max(0, Math.min(100, Math.round(progressPctRaw)))
          : 0;
        const progressStateRaw = String(row && row.progressState ? row.progressState : "active").trim().toLowerCase();
        const progressState = (
          progressStateRaw === "success"
          || progressStateRaw === "error"
          || progressStateRaw === "pending"
        ) ? progressStateRaw : "active";
        const progressClass = progressState === "success"
          ? "files-transfer-progress is-success"
          : (
            progressState === "error"
              ? "files-transfer-progress is-error"
              : (
                progressState === "pending"
                  ? "files-transfer-progress is-pending"
                  : "files-transfer-progress"
              )
          );
        const progressLabelText = String(row && row.progressLabel ? row.progressLabel : "n/a");
        const progressHtml = `<span class="${{escAttr(progressClass)}}">
            <span class="files-transfer-progress-head">
              <span class="files-transfer-progress-text">${{escAttr(progressLabelText)}}</span>
              <span class="files-transfer-progress-pct">${{escAttr(`${{progressPct}}%`)}}</span>
            </span>
            <span class="files-transfer-progress-meter">
              <span style="width:${{escAttr(String(progressPct))}}%;"></span>
            </span>
          </span>`;
        const channelIndexRaw = Number(row && row.channelIndex);
        const hasChannelIndex = Number.isInteger(channelIndexRaw) && channelIndexRaw >= 0;
        const channelBadge = hasChannelIndex
          ? meshChannelBadgeHtml(
            channelIndexRaw,
            channelLabel,
            {{
              allowAll: false,
              extraClass: "compact",
              title: channelLabel,
            }}
          )
          : `<span class="mesh-channel-badge compact" style="${{escAttr(meshChannelBadgeStyle(meshChannelAllIndex, {{ allowAll: true }}))}}" title="Channel unavailable from packet metadata">Unknown</span>`;
        let actionSort = 0;
        let actionHtml = "";
        const inboundCanceled = !!(row && row.inboundCanceled);
        const inboundCanceledBySender = !!(row && row.inboundCanceledBySender);
        const inboundCanceledByReceiver = !!(row && row.inboundCanceledByReceiver);
        if (inboundCanceled) {{
          const cancelActorLabel = inboundCanceledBySender ? "sender" : (inboundCanceledByReceiver ? "receiver" : "peer");
          actionSort = 1;
          actionHtml = `<button
              type="button"
              class="files-transfer-action"
              data-action="clear"
              data-transfer-key="${{escAttr(row.key || "")}}"
              title="${{escAttr(`Remove this canceled transfer row (canceled by ${{cancelActorLabel}}).`)}}"
            >Clear</button>`;
        }} else if (requiresInboundAccept && !inboundAccepted) {{
          const acceptTitle = `Accept inbound transfer ${{row.fileName || "file"}}`;
          const declineTitle = inboundDeclined
            ? "Transfer is declined"
            : `Decline inbound transfer ${{row.fileName || "file"}}`;
          const declineDisabled = inboundDeclined ? " disabled" : "";
          const declineLabel = inboundDeclined ? "Declined" : "Decline";
          actionSort = inboundPending ? 2 : 1;
          actionHtml = `<span class="files-transfer-action-group">
              <button
                type="button"
                class="files-transfer-action accept"
                data-action="accept"
                data-transfer-key="${{escAttr(row.key || "")}}"
                title="${{escAttr(acceptTitle)}}"
              >Accept</button>
              <button
                type="button"
                class="files-transfer-action decline"
                data-action="decline"
                data-transfer-key="${{escAttr(row.key || "")}}"
                title="${{escAttr(declineTitle)}}"
                ${{declineDisabled}}
              >${{escAttr(declineLabel)}}</button>
            </span>`;
        }} else {{
          const inboundCanPauseResume = !!(
            row
            && String(row.directionClass || "").trim().toLowerCase() === "inbound"
            && row.requiresInboundAccept
            && row.inboundAccepted
            && !row.inboundDeclined
            && !row.inboundCanceled
            && !row.canDownload
            && !row.delivered
          );
          const inboundPausedBySender = !!(row && row.inboundPausedBySender);
          const inboundPausedByReceiver = !!(row && row.inboundPausedByReceiver);
          const inboundPauseAction = inboundPausedByReceiver ? "resume-inbound" : "pause-inbound";
          const inboundPauseLabel = inboundPausedBySender
            ? "Paused by TX"
            : (inboundPausedByReceiver ? "Resume" : "Pause");
          const inboundPauseTitle = inboundPausedBySender
            ? "Sender paused this transfer; waiting for sender resume."
            : (
              inboundPausedByReceiver
                ? "Resume inbound transfer and continue ACK updates."
                : "Pause inbound transfer and notify sender."
            );
          const inboundPauseDisabled = inboundPausedBySender ? " disabled" : "";
          const outgoingCanRestart = !!(row && row.outgoingCanRestart);
          const outgoingCanceled = !!(row && row.outgoingCanceled);
          const outgoingPausedRemote = !!(row && row.outgoingPausedRemote);
          const outgoingCanPause = !!(row && row.outgoingCanPause);
          const outgoingCanResume = !!(row && row.outgoingCanResume);
          const outgoingCanCancel = !!(row && row.outgoingCanCancel);
          if (inboundCanPauseResume) {{
            actionSort = 2;
            actionHtml = `<span class="files-transfer-action-group">
                <button
                  type="button"
                  class="files-transfer-action"
                  data-action="${{escAttr(inboundPauseAction)}}"
                  data-transfer-key="${{escAttr(row.key || "")}}"
                  title="${{escAttr(inboundPauseTitle)}}"
                  ${{inboundPauseDisabled}}
                >${{escAttr(inboundPauseLabel)}}</button>
                <button
                  type="button"
                  class="files-transfer-action decline"
                  data-action="cancel-inbound"
                  data-transfer-key="${{escAttr(row.key || "")}}"
                  title="Cancel inbound transfer and stop local ACKs."
                >Cancel</button>
              </span>`;
          }} else if (outgoingCanceled && !(row && row.canDownload)) {{
            actionSort = 1;
            actionHtml = `<button
                type="button"
                class="files-transfer-action"
                data-action="clear"
                data-transfer-key="${{escAttr(row.key || "")}}"
                title="Remove this canceled transfer row."
              >Clear</button>`;
          }} else if ((outgoingCanPause || outgoingCanResume || outgoingCanCancel) && !(row && row.canDownload)) {{
            actionSort = 2;
            const pauseAction = outgoingCanResume ? "resume" : "pause";
            const pauseLabel = outgoingPausedRemote
              ? "Paused by RX"
              : (outgoingCanResume ? "Resume" : "Pause");
            const pauseTitle = outgoingPausedRemote
              ? "Receiver paused this transfer; waiting for receiver resume."
              : (
                outgoingCanResume
                  ? "Resume outbound transfer."
                  : "Pause outbound transfer without resetting progress."
              );
            const pauseDisabled = outgoingPausedRemote
              ? " disabled"
              : ((outgoingCanPause || outgoingCanResume) ? "" : " disabled");
            const cancelDisabled = outgoingCanCancel ? "" : " disabled";
            actionHtml = `<span class="files-transfer-action-group">
                <button
                  type="button"
                  class="files-transfer-action"
                  data-action="${{escAttr(pauseAction)}}"
                  data-transfer-key="${{escAttr(row.key || "")}}"
                  title="${{escAttr(pauseTitle)}}"
                  ${{pauseDisabled}}
                >${{escAttr(pauseLabel)}}</button>
                <button
                  type="button"
                  class="files-transfer-action decline"
                  data-action="cancel"
                  data-transfer-key="${{escAttr(row.key || "")}}"
                  title="Cancel outbound transfer and stop retries."
                  ${{cancelDisabled}}
                >Cancel</button>
              </span>`;
          }} else if (outgoingCanRestart && !(row && row.canDownload)) {{
            const restartTitle = outgoingCanceled
              ? "Restart canceled outbound transfer from metadata/chunk 0."
              : (row && row.outgoingFailed
              ? "Restart failed outbound transfer from metadata/chunk 0."
              : (
                row && row.outgoingWaitingForAccept
                  ? "Restart outbound transfer and request receiver acceptance again."
                  : "Restart outbound transfer from metadata/chunk 0."
              ));
            actionSort = 2;
            actionHtml = `<button
                type="button"
                class="files-transfer-action restart"
                data-action="restart"
                data-transfer-key="${{escAttr(row.key || "")}}"
                title="${{escAttr(restartTitle)}}"
              >Restart</button>`;
          }} else if (row && row.outgoingSessionMissing && !(row && row.canDownload)) {{
            actionSort = 1;
            actionHtml = `<button
                type="button"
                class="files-transfer-action"
                data-action="clear"
                data-transfer-key="${{escAttr(row.key || "")}}"
                title="Remove this stale transfer row (sender session state is unavailable)."
              >Clear</button>`;
          }} else {{
            const backendAuthoritative = !!(row && row.backendAuthoritative);
            const backendInbound = !!(
              backendAuthoritative
              && String(row.directionClass || "").trim().toLowerCase() === "inbound"
            );
            const serverComplete = !!(row && row.serverComplete);
            const actionLabel = row && row.canDownload
              ? "Download"
              : (
                backendInbound
                  ? (serverComplete ? "Received" : "Receiving")
                  : (
                    row && row.outgoingPausedOffline
                      ? "Paused"
                      : (row && row.outgoingRetrying ? "Retrying" : "Waiting")
                  )
              );
            const actionDisabled = row && row.canDownload ? "" : " disabled";
            const actionTitle = row && row.canDownload
              ? `Download ${{row.downloadName || row.fileName || "file"}}`
              : (
                backendInbound
                  ? (
                    serverComplete
                      ? "Backend receiver has the complete transfer; this browser does not have download bytes."
                      : "Backend receiver is tracking this transfer."
                  )
                  : (
                    row && row.outgoingPausedOffline
                      ? "Transfer is auto-paused while peer appears offline."
                      : (row && row.outgoingWaitingForAccept ? "Waiting for receiver accept" : "Waiting for all chunks")
                  )
              );
            actionSort = row && row.canDownload ? 3 : 0;
            actionHtml = `<button
                type="button"
                class="files-transfer-action"
                data-action="download"
                data-transfer-key="${{escAttr(row.key || "")}}"
                title="${{escAttr(actionTitle)}}"
                ${{actionDisabled}}
              >${{escAttr(actionLabel)}}</button>`;
          }}
        }}
        const rowDirection = String(row && row.directionClass || "").trim().toLowerCase();
        const activeInboundRow = !!(
          rowDirection === "inbound"
          && !row.delivered
          && !row.inboundDeclined
          && !row.inboundCanceled
        );
        const activeOutboundRow = !!(
          rowDirection === "outbound"
          && !row.delivered
          && !row.outgoingFailed
          && !row.outgoingCanceled
          && !row.outgoingSessionMissing
        );
        const closeAction = activeInboundRow
          ? "cancel-inbound"
          : (activeOutboundRow ? "cancel" : "clear");
        const closeTitle = activeInboundRow
          ? "Cancel this inbound transfer and stop receiving."
          : (
            activeOutboundRow
              ? "Cancel this outbound transfer and stop retries."
              : "Remove this transfer row and cached file data."
          );
        const closeButton = `<button
            type="button"
            class="files-transfer-action decline files-transfer-row-close"
            data-action="${{escAttr(closeAction)}}"
            data-transfer-key="${{escAttr(row.key || "")}}"
            title="${{escAttr(closeTitle)}}"
            aria-label="${{escAttr(closeTitle)}}"
          >&times;</button>`;
        actionHtml = `<span class="files-transfer-action-group files-transfer-row-actions">${{actionHtml}}${{closeButton}}</span>`;
        const peerNodeId = normalizeNodeId(row && row.peerId || "");
        const appearanceEntry = peerNodeId && typeof effectiveNodeAppearanceForNode === "function"
          ? effectiveNodeAppearanceForNode(peerNodeId, state)
          : null;
        const hasProfileTheme = !!(
          appearanceEntry
          && appearanceEntry.profileAppearance
          && appearanceEntry.preset
        );
        const appearanceStyleVars = hasProfileTheme && typeof nodeAppearanceStyleVars === "function"
          ? nodeAppearanceStyleVars(appearanceEntry)
          : "";
        const appearanceStyleAttr = appearanceStyleVars
          ? ` style="${{escAttr(appearanceStyleVars)}}"`
          : "";
        const appearanceClass = hasProfileTheme ? " profiled-node files-transfer-profiled-row" : "";
        return `<tr class="files-transfer-row${{appearanceClass}}" data-peer-node-id="${{escAttr(peerNodeId)}}"${{appearanceStyleAttr}}>
          <td data-sort="${{escAttr(unix)}}">${{escAttr(when)}}</td>
          <td data-sort="${{escAttr(directionLabel)}}"><span class="files-transfer-dir ${{escAttr(directionClass)}}">${{escAttr(directionLabel)}}</span></td>
          <td data-sort="${{escAttr(peerText)}}" title="${{escAttr(peerTitle)}}">${{escAttr(peerText)}}</td>
          <td data-sort="${{escAttr(row.fileName || "")}}">
            <span class="files-transfer-name">
              <span class="files-transfer-name-main" title="${{escAttr(row.fileName || "")}}">${{escAttr(nameMain)}}</span>
              <span class="files-transfer-name-sub" title="${{escAttr(row.transferId || "")}}">${{escAttr(nameSub)}}</span>
            </span>
          </td>
          <td data-sort="${{escAttr(row.progressSort ?? 0)}}">${{progressHtml}}</td>
          <td data-sort="${{escAttr(row.sizeSort ?? 0)}}">${{escAttr(row.sizeLabel || "n/a")}}</td>
          <td data-sort="${{escAttr(hasChannelIndex ? channelIndexRaw : -1)}}">${{channelBadge}}</td>
          <td data-sort="${{escAttr(actionSort)}}">${{actionHtml}}</td>
        </tr>`;
      }}).join("");
    }}
