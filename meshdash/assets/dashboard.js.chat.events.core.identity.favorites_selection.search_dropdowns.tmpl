    function normalizeSearchQuery(value) {{
      return String(value == null ? "" : value).trim().toLowerCase();
    }}

    function globalNodeSearchQuery() {{
      return normalizeSearchQuery(chatUserSearchQuery);
    }}

    function syncGlobalNodeSearchInputs(query, options = null) {{
      const opts = options && typeof options === "object" ? options : {{}};
      const valueText = normalizeSearchQuery(query);
      const sourceInputId = String(opts.sourceInputId || "").trim();
      const skipSourceInput = opts.skipSourceInput === true;
      const inputIds = [
        "chat-user-search-input",
        "nodes-search-input",
        "favorite-menu-node-search-input",
      ];
      for (const inputId of inputIds) {{
        if (!inputId) continue;
        if (skipSourceInput && sourceInputId && inputId === sourceInputId) continue;
        const input = document.getElementById(inputId);
        if (!(input instanceof HTMLInputElement)) continue;
        if (input.value !== valueText) {{
          input.value = valueText;
        }}
        if (typeof syncSearchTextInputClearButton === "function") {{
          syncSearchTextInputClearButton(input);
        }}
      }}
    }}

    function setGlobalNodeSearchQuery(value, options = null) {{
      const opts = options && typeof options === "object" ? options : {{}};
      const query = normalizeSearchQuery(value);
      const changed = query !== globalNodeSearchQuery();
      chatUserSearchQuery = query;
      nodesSearchQuery = query;
      favoriteMenuNodeSearchQuery = query;
      if (opts.syncInputs !== false) {{
        syncGlobalNodeSearchInputs(query, opts);
      }}
      return changed;
    }}

    function nodeSearchKeywordText(nodeId, nodeName, options = null) {{
      const opts = options && typeof options === "object" ? options : {{}};
      const terms = [];
      const pushTerm = (value) => {{
        const normalized = normalizeSearchQuery(
          value == null ? "" : String(value).replace(/\s+/g, " ")
        );
        if (!normalized || terms.includes(normalized)) return;
        terms.push(normalized);
      }};

      pushTerm(nodeId);
      pushTerm(nodeName);

      const node = opts.node && typeof opts.node === "object" ? opts.node : null;
      if (node) {{
        pushTerm(node.short_name);
        pushTerm(node.long_name);
        pushTerm(node.role);
        pushTerm(node.hardware);
        pushTerm(node.hardware_model);
        pushTerm(node.num);
      }}

      const extras = Array.isArray(opts.extraValues)
        ? opts.extraValues
        : (opts.extraValues == null ? [] : [opts.extraValues]);
      for (const extra of extras) {{
        pushTerm(extra);
      }}

      if (typeof nodeTagEntryForNode === "function") {{
        const tagEntry = nodeTagEntryForNode(nodeId);
        if (tagEntry && tagEntry.preset) {{
          pushTerm(tagEntry.preset.name);
          pushTerm(tagEntry.preset.id);
        }}
      }}

      const includeNotes = opts.includeNotes !== false;
      if (includeNotes) {{
        const noteEntry = (typeof nodeNoteEntry === "function")
          ? nodeNoteEntry(nodeId)
          : null;
        const noteText = noteEntry && noteEntry.note != null
          ? noteEntry.note
          : "";
        pushTerm(noteText);
      }}

      return terms.join(" ");
    }}

    function matchesIdOrNameQuery(nodeId, nodeName, query, options = null) {{
      if (!query) return true;
      return nodeSearchKeywordText(nodeId, nodeName, options).includes(query);
    }}

    function closeFavoriteMenuNodeSearchDropdown() {{
      if (favoriteMenuNodeSearchBlurTimer !== null) {{
        clearTimeout(favoriteMenuNodeSearchBlurTimer);
        favoriteMenuNodeSearchBlurTimer = null;
      }}
      favoriteMenuNodeSearchOpen = false;
      const dropdown = document.getElementById("favorite-menu-node-search-dropdown");
      if (dropdown instanceof HTMLElement) {{
        dropdown.hidden = true;
      }}
    }}

    function buildNodeSearchResults(state, query, limit = 250, options = null) {{
      const safeState = state && typeof state === "object" ? state : {{}};
      const opts = options && typeof options === "object" ? options : {{}};
      const includeHiddenNodes = opts.includeHiddenNodes === true;
      const normalizedQuery = normalizeSearchQuery(query);
      const nodes = Array.isArray(safeState.nodes) ? safeState.nodes : [];
      const historyCapsById = new Map(
        Object.entries((safeState.history_caps && typeof safeState.history_caps === "object") ? safeState.history_caps : {{}})
          .map(([rawNodeId, caps]) => [normalizeNodeId(rawNodeId), caps])
          .filter(([nodeId, caps]) => isSelectableNodeId(nodeId) && caps && typeof caps === "object")
      );
      const nodeById = new Map();
      for (const node of nodes) {{
        const nodeId = normalizeNodeId(node && node.id);
        if (!isSelectableNodeId(nodeId)) continue;
        nodeById.set(nodeId, node);
      }}

      const orderedNodeIds = [];
      const seenNodeIds = new Set();
      const pushNodeId = (nodeId) => {{
        const cleanNodeId = normalizeNodeId(nodeId);
        if (!isSelectableNodeId(cleanNodeId) || seenNodeIds.has(cleanNodeId)) return;
        if (!includeHiddenNodes && !isNodeVisibleByLists(cleanNodeId)) return;
        seenNodeIds.add(cleanNodeId);
        orderedNodeIds.push(cleanNodeId);
      }};

      for (const node of nodes) {{
        pushNodeId(node && node.id);
      }}
      if (typeof favoriteNodeIds !== "undefined" && favoriteNodeIds && typeof favoriteNodeIds.forEach === "function") {{
        favoriteNodeIds.forEach((nodeId) => {{
          pushNodeId(nodeId);
        }});
      }}
      if (typeof nodeNotesById !== "undefined" && nodeNotesById && typeof nodeNotesById.forEach === "function") {{
        nodeNotesById.forEach((_entry, nodeId) => {{
          pushNodeId(nodeId);
        }});
      }}
      pushNodeId(selectedNodeId || "");
      if (normalizedQuery) {{
        const layout = String(activeLayoutView || "").trim().toLowerCase();
        const subview = (typeof normalizeNetworkSubview === "function")
          ? normalizeNetworkSubview(activeNetworkSubview)
          : String(activeNetworkSubview || "").trim().toLowerCase();
        const historyMode = layout === "network"
          ? (
              subview === "routes"
                ? ((typeof normalizeNetworkGraphEdgeMode === "function") ? normalizeNetworkGraphEdgeMode(networkRoutesWindow) : String(networkRoutesWindow || "7d"))
                : (subview === "graph"
                  ? ((typeof normalizeNetworkGraphEdgeMode === "function") ? normalizeNetworkGraphEdgeMode(networkGraphEdgeMode) : String(networkGraphEdgeMode || "7d"))
                  : "max")
            )
          : "max";
        const historySearchNodeIds = (typeof networkGraphHistorySearchNodeIds === "function")
          ? networkGraphHistorySearchNodeIds(historyCapsById, normalizedQuery, historyMode)
          : [];
        for (const nodeId of historySearchNodeIds) {{
          pushNodeId(nodeId);
        }}
      }}

      const maxRows = Math.max(1, Number(limit) || 250);
      const results = [];
      for (const nodeId of orderedNodeIds) {{
        const node = nodeById.get(nodeId);
        const caps = historyCapsById.get(nodeId) || null;
        const capsLongName = String(caps && caps.last_long_name || "").trim();
        const capsShortName = String(caps && caps.last_short_name || "").trim();
        const historyName = capsLongName || capsShortName;
        const name = preferredNodeName(node) || nodeNameCache.get(nodeId) || historyName || `Node ${{nodeId}}`;
        if (!matchesIdOrNameQuery(nodeId, name, normalizedQuery, {{
          node,
          extraValues: [capsLongName, capsShortName],
          includeNotes: false,
        }})) continue;
        results.push({{
          nodeId,
          name: String(name || nodeId),
        }});
        if (results.length >= maxRows) break;
      }}
      return results;
    }}

    function renderFavoriteMenuNodeSearchDropdown(state = latestState) {{
      const input = document.getElementById("favorite-menu-node-search-input");
      const dropdown = document.getElementById("favorite-menu-node-search-dropdown");
      const selectedHost = document.getElementById("favorite-menu-selected-list");
      if (
        !(input instanceof HTMLInputElement)
        || !(dropdown instanceof HTMLElement)
        || !(selectedHost instanceof HTMLElement)
      ) {{
        return;
      }}

      if (!favoriteMenuOpen) {{
        dropdown.hidden = true;
        return;
      }}

      const hasFocus = document.activeElement === input || dropdown.contains(document.activeElement);
      if (!favoriteMenuNodeSearchOpen || !hasFocus) {{
        dropdown.hidden = true;
        return;
      }}

      const query = globalNodeSearchQuery();
      const rows = buildNodeSearchResults(state, query, 250);
      if (!rows.length) {{
        dropdown.innerHTML = '<div class="node-search-empty">No nodes match this search.</div>';
        dropdown.hidden = false;
        return;
      }}

      const selectedId = normalizeNodeId(selectedNodeId || "");
      dropdown.innerHTML = rows.map((row) => {{
        const selectedClass = row.nodeId === selectedId ? " selected-node" : "";
        return `<button type="button" class="node-search-item${{selectedClass}}" data-node-id="${{escAttr(row.nodeId)}}" role="option" aria-selected="${{row.nodeId === selectedId ? "true" : "false"}}"><span class="node-search-name">${{escAttr(row.name)}}</span><span class="node-search-id">${{escAttr(row.nodeId)}}</span></button>`;
      }}).join("");
      dropdown.hidden = false;
    }}
