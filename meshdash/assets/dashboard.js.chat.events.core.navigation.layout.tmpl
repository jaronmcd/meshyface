      finishNetworkGraphRenderStats("complete", {{
        action: graphSceneAction,
        edgeMode,
        layoutMode,
        reusedData: !!canReuseGraphData,
        reusedLayout: !!canReuseGraphLayout,
        skippedSceneDataSync: !!canSkipSceneDataSync,
        nodes: nodes.length,
        edges: combinedEdges.length,
        renderedItems: layout.items.length,
      }});
