    function buildNetworkGraphSourceSignature(nodes, historyCapsRaw, rawEdges, state, edgeMode) {{
      let hash = 2166136261;
      hash = hashMixStr(hash, normalizeNetworkGraphEdgeMode(edgeMode));
      hash = hashMixStr(hash, normalizeNetworkGraphLayoutMode(networkGraphLayoutMode));
      hash = hashMixStr(hash, normalizeNodeId(networkGraphRootNodeId || ""));
      hash = hashMixStr(hash, normalizeNodeId(selectedNodeId || ""));
      hash = hashMixStr(hash, normalizeNodeId(resolveLocalNodeId(state || latestState || {{}}) || ""));

      const safeNodes = Array.isArray(nodes) ? nodes : [];
      hash = hashMixInt(hash, safeNodes.length);
      for (const node of safeNodes) {{
        hash = hashMixStr(hash, normalizeNodeId(node && node.id));
        hash = hashMixStr(hash, String(node && (node.short_name || "")));
        hash = hashMixStr(hash, String(node && (node.long_name || "")));
        hash = hashMixInt(hash, Math.round(Number(node && node.lat) * 100000) || 0);
        hash = hashMixInt(hash, Math.round(Number(node && node.lon) * 100000) || 0);
        hash = hashMixInt(hash, Math.trunc(Number(node && node.last_heard_unix) || 0));
        hash = hashMixInt(hash, Math.trunc(Number(node && node.saved_packets) || 0));
        hash = hashMixInt(hash, Math.trunc(Number(node && node.saved_points) || 0));
        hash = hashMixInt(hash, Math.round(Number(node && node.snr) * 100) || 0);
      }}

      const capsEntries = Object.entries((historyCapsRaw && typeof historyCapsRaw === "object") ? historyCapsRaw : {{}})
        .sort((a, b) => String(a[0]).localeCompare(String(b[0])));
      hash = hashMixInt(hash, capsEntries.length);
      for (const [nodeId, caps] of capsEntries) {{
        hash = hashMixStr(hash, normalizeNodeId(nodeId));
        hash = hashMixInt(hash, Math.trunc(Number(caps && caps.last_seen_unix) || 0));
        hash = hashMixInt(hash, Math.trunc(Number(caps && caps.last_position_unix) || 0));
        hash = hashMixInt(hash, Math.trunc(Number(caps && caps.last_hops) || 0));
        hash = hashMixInt(hash, caps && caps.has_position ? 1 : 0);
      }}

      const safeEdges = Array.isArray(rawEdges) ? rawEdges : [];
      hash = hashMixInt(hash, safeEdges.length);
      for (const edge of safeEdges) {{
        hash = hashMixStr(hash, normalizeNodeId(edge && edge.from));
        hash = hashMixStr(hash, normalizeNodeId(edge && edge.to));
        hash = hashMixInt(hash, Math.trunc(Number(edge && (edge.session_count ?? edge.count)) || 0));
        hash = hashMixInt(hash, Math.trunc(Number(edge && (edge.lifetime_count ?? edge.count)) || 0));
        hash = hashMixInt(hash, edge && edge.is_real ? 1 : 0);
        hash = hashMixInt(hash, Math.trunc(Number(edge && (edge.last_rx_unix ?? edge.last_seen_unix ?? edge.last_unix)) || 0));
        hash = hashMixInt(hash, Math.round(Number(edge && edge.avg_hops) * 100) || 0);
        hash = hashMixInt(hash, Math.round(Number(edge && edge.avg_snr) * 100) || 0);
        hash = hashMixInt(hash, Math.round(Number(edge && edge.avg_rssi) * 100) || 0);
      }}

      return `network-graph:${{(hash >>> 0).toString(16)}}`;
    }}

    function renderNetworkGraphView(state = latestState) {{
