      return {{
        ...base,
        adjacency,
        degreeMeta,
        items,
        positions,
        layers,
        rings: Array.isArray(base.rings) ? base.rings.slice() : [],
        regions: Array.isArray(base.regions) ? base.regions.slice() : [],
