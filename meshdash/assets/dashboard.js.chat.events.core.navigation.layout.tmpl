    const networkTopNodesCategoryDefs = Object.freeze([
      {{ id: "all", label: "All Categories", unit: "" }},
      {{ id: "saved_packets", label: "Saved Packets", unit: "packets" }},
      {{ id: "active_hours", label: "Active Hours", unit: "hours" }},
      {{ id: "chat_packets", label: "Chats", unit: "chats" }},
      {{ id: "gps_positions", label: "GPS Positions", unit: "positions" }},
      {{ id: "environment_metrics", label: "Metrics", unit: "samples" }},
      {{ id: "links", label: "Links", unit: "links" }},
      {{ id: "link_packets", label: "Link Packets", unit: "packets" }},
      {{ id: "telemetry_packets", label: "Telemetry", unit: "packets" }},
      {{ id: "position_packets", label: "Position Packets", unit: "packets" }},
      {{ id: "routing_packets", label: "Routing", unit: "packets" }},
      {{ id: "nodeinfo_packets", label: "Node Info", unit: "packets" }},
      {{ id: "direct_packets", label: "Direct Sends", unit: "packets" }},
      {{ id: "storeforward_packets", label: "Store/Fwd", unit: "packets" }},
      {{ id: "admin_packets", label: "Admin", unit: "packets" }},
      {{ id: "encrypted_packets", label: "Encrypted", unit: "packets" }},
      {{ id: "other_packets", label: "Other Packets", unit: "packets" }},
    ]);
    const networkTopNodesCategoryById = new Map(
      networkTopNodesCategoryDefs.map((entry) => [entry.id, entry])
    );

    function normalizeNetworkTopNodesCategory(raw) {{
      const clean = String(raw || "").trim().toLowerCase().replace(/[-\s]+/g, "_");
      const aliases = {{
        everything: "all",
        all_categories: "all",
        all_lists: "all",
        packets: "saved_packets",
        stored_packets: "saved_packets",
        saved: "saved_packets",
        uptime: "active_hours",
        active: "active_hours",
        chat: "chat_packets",
        chats: "chat_packets",
        gps: "gps_positions",
        positions: "gps_positions",
        position: "position_packets",
        metrics: "environment_metrics",
        metric: "environment_metrics",
        telemetry: "telemetry_packets",
        link: "links",
        routing: "routing_packets",
        nodeinfo: "nodeinfo_packets",
        node_info: "nodeinfo_packets",
        direct: "direct_packets",
        store_forward: "storeforward_packets",
        storefwd: "storeforward_packets",
        encrypted: "encrypted_packets",
        other: "other_packets",
      }};
      const normalized = aliases[clean] || clean;
      return networkTopNodesCategoryById.has(normalized) ? normalized : "saved_packets";
    }}

    function networkTopNodesCategoryDef(category) {{
      const clean = normalizeNetworkTopNodesCategory(category);
      return networkTopNodesCategoryById.get(clean) || networkTopNodesCategoryDefs[0];
    }}

