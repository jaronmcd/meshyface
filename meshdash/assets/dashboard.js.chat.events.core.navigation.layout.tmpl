    function renderChatLabsView(state = latestState) {{
      const terminal = document.getElementById("chat-labs-terminal");
      const feed = document.getElementById("chat-labs-feed");
      const countEl = document.getElementById("chat-labs-count");
      if (!(terminal instanceof HTMLElement) || !(feed instanceof HTMLElement)) return;

      const safeState = (state && typeof state === "object") ? state : null;
      const traffic = (safeState && safeState.traffic && typeof safeState.traffic === "object")
        ? safeState.traffic
        : {{}};
      const rows = Array.isArray(traffic.recent_chat) ? traffic.recent_chat : [];
      const nodes = Array.isArray(safeState && safeState.nodes) ? safeState.nodes : [];
      const nowUnix = Math.floor(Date.now() / 1000);
      const localNodeId = normalizeNodeId(resolveLocalNodeId(safeState || latestState || {{}}));
      const nodesById = new Map();
      const nodeIdByNum = new Map();
      for (const node of nodes) {{
        const nodeId = normalizeNodeId(node && node.id);
        if (isCanonicalNodeId(nodeId) && !nodesById.has(nodeId)) {{
          nodesById.set(nodeId, node);
        }}
        const nodeNum = parseNodeNum(node && node.num);
        if (Number.isInteger(nodeNum) && nodeNum >= 0 && isCanonicalNodeId(nodeId) && !nodeIdByNum.has(nodeNum)) {{
          nodeIdByNum.set(nodeNum, nodeId);
        }}
      }}

      const wasNearBottom = (terminal.scrollHeight - terminal.scrollTop - terminal.clientHeight) <= 28;
      const maxLines = 260;
      const resolveNodeIdFromMessage = (msg, keys) => {{
        for (const key of keys) {{
          const rawValue = msg && msg[key];
          const clean = normalizeNodeId(rawValue);
          if (isCanonicalNodeId(clean) || clean === "^all" || clean === "local") {{
            return clean;
          }}
          const nodeNum = parseNodeNum(rawValue);
          if (Number.isInteger(nodeNum) && nodeIdByNum.has(nodeNum)) {{
            return nodeIdByNum.get(nodeNum) || clean;
          }}
        }}
        return "";
      }};
      const nodeLabel = (nodeId, fallbackText = "unknown") => {{
        const clean = normalizeNodeId(nodeId);
        if (!clean || clean === "^all") return "all";
        if (clean === "local") return "local";
        if (!isCanonicalNodeId(clean)) return String(fallbackText || "unknown");
        const node = nodesById.get(clean) || null;
        const preferred = preferredNodeName(node) || nodeNameCache.get(clean) || clean;
        return String(preferred || clean);
      }};
      const emojiFromCodepoint = (rawValue) => {{
        const codepoint = Number(rawValue);
        if (!Number.isInteger(codepoint) || codepoint <= 0) return "";
        try {{
          return String.fromCodePoint(codepoint);
        }} catch (_err) {{
          return "";
        }}
      }};
      const messageText = (msg) => {{
        const candidates = [
          msg && msg.decoded_text,
          msg && msg.payload_text,
          msg && msg.text,
          msg && msg.message,
          msg && msg.body,
        ];
        for (const candidate of candidates) {{
          const text = String(candidate == null ? "" : candidate).trim();
          if (text) return text;
        }}
        const emoji = String(msg && msg.emoji ? msg.emoji : "").trim() || emojiFromCodepoint(msg && (msg.emoji_codepoint ?? msg.emojiCodepoint));
        if (emoji) {{
          return `reaction ${{emoji}}`;
        }}
        if (msg && msg.is_reaction === true) {{
          return "reaction";
        }}
        return "";
      }};

      const timeline = rows
        .map((msg, index) => {{
          const unix = latestUnixTimestamp(
            msg && msg.rx_time,
            msg && msg.captured_at,
            msg && msg.time,
            msg && msg.rxTime,
            msg && msg.timestamp,
          );
          return {{
            msg,
            index,
            unix: Number.isFinite(unix) ? Math.floor(unix) : null,
          }};
        }})
        .filter((row) => row && row.msg && typeof row.msg === "object")
        .sort((a, b) => {{
          const aUnix = Number.isFinite(a.unix) ? a.unix : null;
          const bUnix = Number.isFinite(b.unix) ? b.unix : null;
          if (aUnix == null && bUnix != null) return -1;
          if (aUnix != null && bUnix == null) return 1;
          if (aUnix != null && bUnix != null && aUnix !== bUnix) {{
            return aUnix - bUnix;
          }}
          return a.index - b.index;
        }})
        .slice(-maxLines);

      if (!timeline.length) {{
        feed.innerHTML = '<div class="chatlabs-empty">No chat traffic yet. Incoming messages will appear here.</div>';
        if (countEl instanceof HTMLElement) {{
          countEl.textContent = "0 lines";
        }}
        return;
      }}

      const lineHtml = [];
      for (const row of timeline) {{
        const msg = row.msg;
        const fromId = resolveNodeIdFromMessage(msg, ["from_id", "fromId", "from", "source_id", "sourceId", "source", "from_num", "fromNum"]);
        const toId = resolveNodeIdFromMessage(msg, ["to_id", "toId", "to", "dest_id", "destId", "destination", "dest", "to_num", "toNum"]);
        const fromLabel = nodeLabel(fromId, "unknown");
        const toLabel = nodeLabel(toId || "^all", "all");
        const isDirect = !!(toId && toId !== "^all" && toId !== "all" && toId !== "local");
        const text = messageText(msg);
        const isReaction = !!(
          msg && (
            msg.is_reaction === true
            || msg.emoji != null
            || msg.emoji_codepoint != null
            || msg.emojiCodepoint != null
          )
        );
        const rawTime = msg && (msg.rx_time || msg.captured_at || msg.time || msg.rxTime || msg.timestamp || "");
        const timeLabel = Number.isFinite(row.unix) && row.unix > 0
          ? formatLocalChatTime(row.unix, rawTime || "n/a", nowUnix)
          : String(rawTime || "n/a");
        const classes = ["chatlabs-line"];
        if (isCanonicalNodeId(fromId) && isCanonicalNodeId(localNodeId) && fromId === localNodeId) {{
          classes.push("chatlabs-line-self");
        }}
        if (isReaction) {{
          classes.push("chatlabs-line-reaction");
        }}
        const directionLabel = isDirect ? `-> ${{toLabel}}` : "-> all";
        const bodyHtml = chatPlainTextToHtml(text || "(no text)", true);
        lineHtml.push(
          `<div class="${{escAttr(classes.join(" "))}}"><span class="chatlabs-ts">[${{escAttr(timeLabel)}}]</span> <span class="chatlabs-node">${{escAttr(fromLabel)}}</span> <span class="chatlabs-route">${{escAttr(directionLabel)}}</span> <span class="chatlabs-body">${{bodyHtml || "&nbsp;"}}</span></div>`
        );
      }}

      feed.innerHTML = lineHtml.join("");
      if (countEl instanceof HTMLElement) {{
        countEl.textContent = `${{timeline.length}} lines`;
      }}
      if (wasNearBottom) {{
        window.requestAnimationFrame(() => {{
          terminal.scrollTop = terminal.scrollHeight;
        }});
      }}
    }}

    function normalizeAppsLayoutView(raw) {{
      const clean = String(raw || "").trim().toLowerCase();
      if (
        clean === "macros"
        || clean === "games"
        || clean === "files"
        || clean === "bbs"
        || clean === "bots"
        || clean === "remote"
      ) {{
        return clean;
      }}
      return "macros";
    }}

    function isAppsLayoutView(viewName) {{
      const clean = String(viewName || "").trim().toLowerCase();
      return (
        clean === "macros"
        || clean === "games"
        || clean === "files"
        || clean === "bbs"
        || clean === "bots"
        || clean === "remote"
      );
    }}

    function loadPreferredAppsLayoutView() {{
      try {{
        const raw = window.localStorage.getItem("meshDashboardAppsLayoutViewV1") || "macros";
        return normalizeAppsLayoutView(raw);
      }} catch (_err) {{
        return "macros";
      }}
    }}

    function persistPreferredAppsLayoutView(viewName) {{
      if (!isAppsLayoutView(viewName)) return;
      try {{
        window.localStorage.setItem("meshDashboardAppsLayoutViewV1", normalizeAppsLayoutView(viewName));
      }} catch (_err) {{
      }}
    }}

    function normalizeLayoutView(raw) {{
      const clean = String(raw || "").trim().toLowerCase();
      if (clean === "data") return "settings";
      if (clean === "apps") return loadPreferredAppsLayoutView();
      if (isAppsLayoutView(clean)) return clean;
      return knownLayoutViews.has(clean) ? clean : "chat";
    }}

    function isMapVisibleLayoutView(viewName) {{
      const view = normalizeLayoutView(viewName);
      return view === "network" || view === "saved";
    }}

    function syncNodeHistoryDock() {{
      const nodeHistoryPanel = document.getElementById("map-data-node");
      const mapDataBody = document.getElementById("map-data-body");
      const networkHost = document.getElementById("network-node-history-host");
      const savedHost = document.getElementById("saved-node-history-host");
      const nodesTitle = document.getElementById("nodes-card-title");
      if (!(nodeHistoryPanel instanceof HTMLElement)) return;
      if (!(mapDataBody instanceof HTMLElement)) return;
      if (!(networkHost instanceof HTMLElement)) return;

      const dockInSaved = activeLayoutView === "saved" && (savedHost instanceof HTMLElement);
      const target = dockInSaved ? savedHost : mapDataBody;
      if (nodeHistoryPanel.parentElement !== target) {{
        target.appendChild(nodeHistoryPanel);
      }}

      networkHost.hidden = true;
      networkHost.classList.remove("empty");
      if (nodesTitle instanceof HTMLElement) {{
        nodesTitle.textContent = activeLayoutView === "network" ? "Network Explorer" : "Nodes";
      }}
    }}

    function syncAppsTabBar(viewName = activeLayoutView) {{
      const normalized = normalizeLayoutView(viewName);
      for (const btn of document.querySelectorAll(".apps-tab-btn")) {{
        if (!(btn instanceof HTMLButtonElement)) continue;
        const rawTarget = String(btn.dataset.appView || "").trim().toLowerCase();
        const btnView = normalizeLayoutView(rawTarget);
        const isActive = btnView === normalized;
        btn.classList.toggle("is-active", isActive);
        btn.setAttribute("aria-pressed", isActive ? "true" : "false");
      }}
    }}

    function syncAppsTabBarVisibility(viewName = activeLayoutView) {{
      const tabsBar = document.getElementById("apps-tabs-bar");
      if (!(tabsBar instanceof HTMLElement)) return;
      const next = normalizeLayoutView(viewName);
      const showTabs = isAppsLayoutView(next);
      tabsBar.hidden = !showTabs;
      tabsBar.setAttribute("aria-hidden", showTabs ? "false" : "true");
    }}

    function resolveLayoutViewTargetFromEvent(ev) {{
      const rawTarget = ev && ev.target;
      const target = rawTarget instanceof Element
        ? rawTarget
        : ((rawTarget instanceof Node) ? rawTarget.parentElement : null);
      if (!(target instanceof Element)) return "";

      const railBtn = target.closest(".teams-rail .rail-btn");
      if (railBtn instanceof HTMLButtonElement) {{
        if (railBtn.disabled) return "";
        return String(railBtn.dataset.view || "chat");
      }}

      const appsBtn = target.closest(".apps-tab-btn");
      if (appsBtn instanceof HTMLButtonElement) {{
        if (appsBtn.disabled) return "";
        return String(appsBtn.dataset.appView || "chat");
      }}

      return "";
    }}

    function applyLayoutView(viewName, persist = true) {{
      const layout = document.getElementById("dashboard-layout");
      if (!(layout instanceof HTMLElement)) return;
      const shell = document.querySelector(".workspace-shell");
      const chatLeftPanel = document.getElementById("chat-left-panel");
      const next = normalizeLayoutView(viewName);
      activeLayoutView = next;
      persistPreferredAppsLayoutView(next);
      for (const name of knownLayoutViews) {{
        layout.classList.remove(`view-${{name}}`);
      }}
      layout.classList.add(`view-${{next}}`);

      // Keep rail selection in sync even if any later view-specific setup throws.
      for (const btn of document.querySelectorAll(".teams-rail .rail-btn")) {{
        if (!(btn instanceof HTMLButtonElement)) continue;
        const railView = String(btn.dataset.view || "").trim().toLowerCase();
        const isActive = railView === "apps"
          ? isAppsLayoutView(next)
          : normalizeLayoutView(railView) === next;
        btn.classList.toggle("active", isActive);
        btn.setAttribute("aria-current", isActive ? "page" : "false");
      }}
      const chatRailBtn = document.querySelector('.teams-rail .rail-btn[data-view="chat"]');
      if (chatRailBtn instanceof HTMLButtonElement) {{
        chatRailBtn.hidden = false;
        chatRailBtn.disabled = false;
      }}
      syncAppsTabBarVisibility(next);
      syncAppsTabBar(next);

      const chatViewActive = isChatWorkspaceLayoutView(next);
      if (shell instanceof HTMLElement) {{
        shell.classList.add("chat-panel-open");
      }}
      if (chatLeftPanel instanceof HTMLElement) {{
        chatLeftPanel.hidden = false;
      }}
      if (typeof applyChatPanelSplitState === "function") {{
        applyChatPanelSplitState();
      }}
      refreshMapCardTitle();
      const mapResetBtn = document.getElementById("map-reset-view-btn");
      if (mapResetBtn instanceof HTMLButtonElement) {{
        mapResetBtn.hidden = next === "saved" || next === "history";
      }}
      updateMapPacketLinesControl();

      const mapNodes = latestState && Array.isArray(latestState.nodes) ? latestState.nodes : [];
      try {{
        syncSignalHeatmapLayer(mapNodes, next === "saved");
      }} catch (_err) {{
      }}
      try {{
        setMapWheelZoomActive(next === "network" || next === "saved");
      }} catch (_err) {{
      }}
      if (isMapVisibleLayoutView(next)) {{
        requestMapResizeNow();
      }}
      if (chatViewActive) {{
        if (activeWheelPane instanceof HTMLElement) {{
          activeWheelPane.classList.remove("wheel-scroll-active");
        }}
        activeWheelPane = null;
        if (activeWheelPaneLease !== null) {{
          clearTimeout(activeWheelPaneLease);
          activeWheelPaneLease = null;
        }}
        // Entering Chat should clear any stale rail badge regardless of which
        // sub-channel (Everyone vs Peer-to-peer) previously accumulated it.
        clearChatUnread();
      }} else {{
        clearAllChatChangeAutoDismissTimers();
      }}
      syncChatRailUnread();
      if (typeof window.meshRefreshWheelHints === "function") {{
        try {{
          window.meshRefreshWheelHints();
        }} catch (_err) {{
        }}
      }}

      if (persist) {{
        try {{
          window.localStorage.setItem(layoutViewStorageKey, next);
        }} catch (_err) {{
        }}
      }}
      applyChatViewMode(next === "macros" ? "monitor" : "default", false);
      if (next === "macros" && typeof applyMacrosPanelSplitState === "function") {{
        applyMacrosPanelSplitState();
      }}

      if (next === "history") {{
        mapDataFocus = "activity";
      }}
      if (next === "network" && mapDataFocus === "activity") {{
        mapDataFocus = "auto";
      }}
      if (next === "network") {{
        fitDone = false;
      }}
      if (next === "network" && isSelectableNodeId(selectedNodeId)) {{
        pendingSelectionScroll = true;
        highlightNodeSelection();
        window.requestAnimationFrame(() => {{
          scrollSelectionIntoView();
        }});
      }}
      syncNodeHistoryDock();
      if (latestState) {{
        let cachedNodeHistory = null;
        const viewHistoryNodeId = next === "saved"
          ? resolveSavedViewNodeId(latestState)
          : (next === "network" ? normalizeNodeId(selectedNodeId || "") : "");
        if ((next === "saved" || next === "network") && isSelectableNodeId(viewHistoryNodeId)) {{
          const cached = nodeHistoryCache.get(viewHistoryNodeId);
          if (cached && cached.data) {{
            cachedNodeHistory = cached.data;
          }}
        }}
        // Render visible UI from cached state immediately on view switches.
        // This prevents "blank" panes when the server legitimately returns 304s.
        renderSummary(latestState);
        if (next === "saved" || next === "network") {{
          renderMap(latestState.nodes || [], (latestState.traffic || {{}}).edges || [], cachedNodeHistory);
        }}
        if (next === "network") {{
          renderNodes(latestState.nodes || []);
        }}
        renderTraffic(latestState.traffic || {{}}, latestState.nodes || [], cachedNodeHistory);
        if (isChatWorkspaceLayoutView(next)) {{
          renderChat(latestState);
          if (next === "chatlabs") {{
            renderChatLabsView(latestState);
          }}
        }}
        if (next === "files") {{
          renderFilesView(latestState);
        }}
        if (next === "bbs") {{
          renderBbsView(latestState);
        }}
        if (next === "bots") {{
          renderBotsView(latestState);
        }}
        if (next === "games") {{
          renderGamesView(latestState);
        }}
        if (next === "remote") {{
          renderRemoteView(latestState);
        }}
        if (next === "history") {{
          renderHistoryChat(latestState.traffic || {{}});
          setMapDataMode("activity");
          void refreshHistoryPanels(false);
        }}
        if (next === "saved") {{
          renderFavorites(latestState, cachedNodeHistory);
        }} else {{
          renderSavedNodeDetails(latestState, cachedNodeHistory);
        }}
        if (next === "settings") {{
          renderSettings(latestState);
          syncSettingsPositionSourceUi({{
            source: settingsPositionSourcePref,
            recenter: true,
          }});
        }}
        if (next === "packets") {{
          renderPackets(latestState);
        }}
        if (next === "channels") {{
          renderChannelsView(latestState);
          void ensureChannelsViewLocalStateHydrated(false);
        }}
        if (next === "encription") {{
          renderEncription(latestState.traffic || {{}});
        }}
        if (next === "environment") {{
          void renderEnvironmentMetricsView(false);
        }}
        if (next === "console") {{
          renderConsole(latestState.traffic || {{}});
        }}
      }} else if (next === "network") {{
        renderNodesPlaceholder("Syncing nodes...");
      }} else if (next === "history") {{
        setMapDataMode("activity");
        renderWeeklySummaryLoading();
        renderHistoryChat({{}});
      }} else if (next === "chatlabs") {{
        renderChatLabsView(latestState);
      }} else if (next === "files") {{
        renderFilesView(latestState);
      }} else if (next === "bbs") {{
        renderBbsView(latestState);
      }} else if (next === "channels") {{
        renderChannelsView(latestState);
        void ensureChannelsViewLocalStateHydrated(false);
      }} else if (next === "bots") {{
        renderBotsView(latestState);
      }} else if (next === "games") {{
        renderGamesView(latestState);
      }} else if (next === "remote") {{
        renderRemoteView(latestState);
      }} else if (next === "encription") {{
        renderEncription({{}});
      }} else if (next === "environment") {{
        void renderEnvironmentMetricsView(false);
      }}
      if (next === "console") {{
        window.requestAnimationFrame(() => {{
          focusConsoleCommandInput(false);
        }});
      }}
      if (next !== "saved") {{
        closeSavedNodeSearchDropdown();
      }}
      renderSavedNodeSearchDropdown(latestState);
      renderFavoriteMenuNodeSearchDropdown(latestState);
      // Ensure node history loads immediately when switching into the map views.
      void refreshSelectedNodeHistory(false);
      if (next === "chat" || next === "macros" || next === "chatlabs" || next === "files" || next === "bbs" || next === "bots" || next === "games" || next === "remote" || next === "history" || next === "network" || next === "saved" || next === "channels" || next === "environment") {{
        requestImmediatePoll(0);
      }}
      if (isMapVisibleLayoutView(next)) {{
        requestMapResizeStabilized();
      }} else {{
        clearMapResizeStabilizeTimers();
      }}
      if (next === "settings") {{
        if (ensureSettingsFixedMap()) {{
          const shouldRecenterSettingsMap = (
            activeSettingsTab === "core"
            && normalizeSettingsPositionSource(readSettingsPositionSourceSelection()) === "fixed"
          );
          syncSettingsFixedMapFromInputs({{ recenter: shouldRecenterSettingsMap }});
          requestSettingsFixedMapResizeStabilized();
        }}
      }} else {{
        clearSettingsFixedMapResizeTimers();
      }}
    }}

    function meshSelectLayoutView(viewName) {{
      const next = normalizeLayoutView(viewName);
      try {{
        window.localStorage.setItem(layoutViewStorageKey, next);
      }} catch (_err) {{
      }}
      try {{
        applyLayoutView(next, true);
        const layout = document.getElementById("dashboard-layout");
        if (layout instanceof HTMLElement && layout.classList.contains(`view-${{next}}`)) {{
          return false;
        }}
      }} catch (_err) {{
      }}
      try {{
        window.location.reload();
      }} catch (_err) {{
      }}
      return false;
    }}

    // Expose view switching globally so inline fallback handlers in HTML can
    // always route navigation clicks even if delegated binding is interrupted.
    if (typeof window !== "undefined") {{
      window.applyLayoutView = applyLayoutView;
      window.meshSelectLayoutView = meshSelectLayoutView;
    }}

    function loadLayoutView() {{
      let rawPreferred = "chat";
      try {{
        rawPreferred = String(window.localStorage.getItem(layoutViewStorageKey) || "chat");
      }} catch (_err) {{
      }}
      const preferred = normalizeLayoutView(rawPreferred);
      const migratedDataView = String(rawPreferred || "").trim().toLowerCase() === "data";
      applyLayoutView(preferred, false);
      if (migratedDataView) {{
        setActiveSettingsTab("data", true);
      }}
    }}

    function bindLayoutNav() {{
      if (window.__meshLayoutNavDelegatedBound === true) return;
      window.__meshLayoutNavDelegatedBound = true;
      document.addEventListener("click", (ev) => {{
        const targetView = resolveLayoutViewTargetFromEvent(ev);
        if (!targetView) return;
        applyLayoutView(targetView, true);
      }}, true);
    }}

    // Install layout navigation delegation as soon as this template loads so
    // view switching still works even if later boot/setup code short-circuits.
    bindLayoutNav();
