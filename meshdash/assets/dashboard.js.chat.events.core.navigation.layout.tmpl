          ? (denseRoute ? 12 : 14)
          : (showMeta ? 10 : 9);
        const label = showLabel
          ? String(
              labelPlan && labelPlan.nameLabel
                ? labelPlan.nameLabel
                : truncateNetworkGraphLabel(name, labelMax)
            )
          : "";
        const radius = isFrom || isTo ? 18 : (isRoute ? 15 : 10);
        const locationMeta = (labelPlan && labelPlan.locationMeta)
          ? labelPlan.locationMeta
          : (showCity
            ? networkRoutesScopeNodeLocation(clean, node, latestState, routeLocationEstimates)
            : null);
        const location = locationMeta ? locationMeta.location : null;
        const citySource = locationMeta ? String(locationMeta.source || "gps") : "";
        const cityKey = networkTopNodesCityCacheKey(location);
        const cityTextRaw = String(networkTopNodesCityText(location) || "").trim();
        const cityMaxChars = Math.max(0, Math.trunc(Number(labelPlan && labelPlan.cityMaxChars) || 0));
        const cityText = cityMaxChars > 0
          ? truncateNetworkGraphLabel(cityTextRaw, Math.max(6, cityMaxChars))
          : cityTextRaw;
        const cityLabel = (labelPlan && showCity && labelPlan.cityLabel)
          ? String(labelPlan.cityLabel || "")
          : (cityText && citySource === "estimated" ? `~ ${{cityText}}` : cityText);
        const cityY = radius + 26;
        const classes = [
          "network-route-scope-node",
          isRoute ? "is-route" : "is-context",
          resolvedNodeEmoji ? "has-emoji-glyph" : "",
          isFrom ? "is-from" : "",
          isTo ? "is-to" : "",
          isLocal ? "is-local" : "",
          isFocused ? "is-focused" : "",
        ].filter(Boolean).join(" ");
        const title = `${{name}} (${{clean}})`;
        const emojiBoxSize = Math.max(22, Math.round(radius * 2.15));
        const emojiBoxOffset = -(emojiBoxSize / 2);
        return `<g class="${{escAttr(classes)}}"
          data-route-node-id="${{escAttr(clean)}}"
          tabindex="0"
          role="button"
          aria-label="${{escAttr(`Explore ${{title}}`)}}"
          transform="translate(${{point.x.toFixed(1)}} ${{point.y.toFixed(1)}})"
        >
          <title>${{escAttr(title)}}</title>
          <circle class="network-route-scope-node-hit" r="${{escAttr(String(radius + 10))}}"></circle>
          <circle class="network-route-scope-node-core" r="${{escAttr(String(radius))}}"></circle>
          ${{resolvedNodeEmoji ? `<foreignObject class="network-route-scope-node-emoji-fo" x="${{emojiBoxOffset.toFixed(1)}}" y="${{emojiBoxOffset.toFixed(1)}}" width="${{emojiBoxSize.toFixed(1)}}" height="${{emojiBoxSize.toFixed(1)}}" aria-hidden="true">
            <div xmlns="http://www.w3.org/1999/xhtml" class="network-route-scope-node-emoji">${{escAttr(resolvedNodeEmoji)}}</div>
          </foreignObject>` : ""}}
          ${{isRoute && !resolvedNodeEmoji ? `<text class="network-route-scope-node-index" y="4">${{escAttr(String(index + 1))}}</text>` : ""}}
          ${{showLabel ? `<text class="network-route-scope-node-label" y="${{escAttr(String(radius + 14))}}">${{escAttr(label)}}</text>` : ""}}
          ${{showCity && cityKey ? `<text class="network-route-scope-node-city${{citySource === "estimated" ? " is-estimated" : ""}}" y="${{escAttr(String(cityY))}}" data-route-node-city-key="${{escAttr(cityKey)}}" data-route-node-city-lat="${{escAttr(location.lat.toFixed(6))}}" data-route-node-city-lon="${{escAttr(location.lon.toFixed(6))}}" data-route-node-city-source="${{escAttr(citySource || "gps")}}" data-route-node-city-max-chars="${{escAttr(String(cityMaxChars))}}"${{cityLabel ? "" : ' visibility="hidden"'}}>${{escAttr(cityLabel || " ")}}</text>` : ""}}
        </g>`;
      }}).join("");
      const contextCount = scoped.contextEdges.length;
      const clusterCount = Array.isArray(scoped && scoped.clusterEdges) ? scoped.clusterEdges.length : 0;
      const routeEdgeCount = scoped.routeEdges.length;
      const nodeCount = scoped.nodeIds.length;
      return `<section class="network-route-scope" data-route-scope-signature="${{escAttr(scopeSignature)}}" aria-label="Route scoped links">
        <div class="network-route-scope-head">
          <span>Route scope</span>
          <span>${{escAttr(String(nodeCount))}} nodes &middot; ${{escAttr(String(routeEdgeCount))}} route links &middot; ${{escAttr(String(contextCount))}} side links &middot; ${{escAttr(String(clusterCount))}} cluster links</span>
          <button class="network-route-scope-reset-btn" type="button" data-route-scope-reset="1" title="Reset route scope view">Reset</button>
        </div>
        <svg class="network-route-scope-svg"
          viewBox="${{escAttr(networkRoutesScopeViewBoxText(viewBox))}}"
          data-route-scope-default-viewbox="${{escAttr(networkRoutesScopeViewBoxText(defaultViewBox))}}"
          role="img"
          aria-label="Route scoped links from selected endpoints"
        >
          ${{markerDefsHtml}}
          <g class="network-route-scope-links">${{edgeHtml}}</g>
          <g class="network-route-scope-nodes">${{nodeHtml}}</g>
        </svg>
      </section>`;
    }}

    function applyNetworkRoutesScopeNodeCityText(el, text) {{
      if (!(el instanceof Element)) return;
      const raw = String(text || "").trim();
      const maxChars = Math.max(0, Math.trunc(Number(el.getAttribute("data-route-node-city-max-chars")) || 0));
      const clean = maxChars > 0
        ? truncateNetworkGraphLabel(raw, Math.max(6, maxChars))
        : raw;
      const source = String(el.getAttribute("data-route-node-city-source") || "").trim().toLowerCase();
      const display = clean && source === "estimated" ? `~ ${{clean}}` : clean;
      el.textContent = display || " ";
      if (clean) {{
        el.removeAttribute("visibility");
      }} else {{
        el.setAttribute("visibility", "hidden");
      }}
    }}

    function hydrateNetworkRoutesScopeNodeCities(root) {{
      if (!(root instanceof HTMLElement)) return;
      const nodes = Array.from(root.querySelectorAll("[data-route-node-city-key]"));
      if (!nodes.length) return;
      for (const node of nodes) {{
        if (!(node instanceof Element)) continue;
        const key = String(node.getAttribute("data-route-node-city-key") || "").trim();
        if (!key) continue;
        if (nodeCityHintCache instanceof Map && nodeCityHintCache.has(key)) {{
          applyNetworkRoutesScopeNodeCityText(node, nodeCityHintCache.get(key));
          continue;
        }}
        const lat = Number(node.getAttribute("data-route-node-city-lat"));
        const lon = Number(node.getAttribute("data-route-node-city-lon"));
        if (!networkTopNodesLocationIsValid(lat, lon) || typeof nearestOfflineCityHintFromCoords !== "function") {{
          if (nodeCityHintCache instanceof Map) nodeCityHintCache.set(key, "");
          applyNetworkRoutesScopeNodeCityText(node, "");
          continue;
        }}
        nearestOfflineCityHintFromCoords(lat, lon)
          .then((city) => {{
            const text = String(city || "").trim();
            if (nodeCityHintCache instanceof Map) nodeCityHintCache.set(key, text);
            if (node.isConnected && String(node.getAttribute("data-route-node-city-key") || "").trim() === key) {{
              applyNetworkRoutesScopeNodeCityText(node, text);
            }}
          }})
          .catch(() => {{
            if (nodeCityHintCache instanceof Map) nodeCityHintCache.set(key, "");
            if (node.isConnected && String(node.getAttribute("data-route-node-city-key") || "").trim() === key) {{
              applyNetworkRoutesScopeNodeCityText(node, "");
            }}
          }});
      }}
    }}

    function networkRoutesSplitLayoutHtml(topHtml, bottomHtml, options = {{}}) {{
      const top = String(topHtml == null ? "" : topHtml).trim();
      const bottom = String(bottomHtml == null ? "" : bottomHtml).trim();
      if (!top || !bottom) return `${{top}}${{bottom}}`;
      const opts = (options && typeof options === "object") ? options : {{}};
      const ratio = normalizeNetworkRoutesSplitRatio(
        Object.prototype.hasOwnProperty.call(opts, "ratio")
          ? opts.ratio
          : networkRoutesSplitRatio
      );
      const minPct = Math.round(networkRoutesSplitRatioMin * 100);
      const maxPct = Math.round(networkRoutesSplitRatioMax * 100);
      const nowPct = Math.round(ratio * 100);
      return `<div class="network-routes-split-layout" data-routes-split-layout style="--network-routes-split:${{ratio.toFixed(4)}};">
        <div class="network-routes-split-pane is-top">${{top}}</div>
        <div
          class="network-routes-split-divider"
          data-routes-split-divider
          role="separator"
          aria-orientation="horizontal"
          aria-label="Resize route graph and list"
          aria-valuemin="${{escAttr(String(minPct))}}"
          aria-valuemax="${{escAttr(String(maxPct))}}"
          aria-valuenow="${{escAttr(String(nowPct))}}"
          tabindex="0"
          title="Drag to resize graph and list"
        ></div>
        <div class="network-routes-split-pane is-bottom">${{bottom}}</div>
      </div>`;
    }}

    function applyNetworkRoutesSplitLayoutRatio(layout, rawRatio, persist = false) {{
      if (!(layout instanceof HTMLElement)) return networkRoutesSplitRatio;
      const clean = normalizeNetworkRoutesSplitRatio(rawRatio);
      const divider = layout.querySelector("[data-routes-split-divider]");
      if (divider instanceof HTMLElement) {{
        divider.setAttribute("aria-valuenow", String(Math.round(clean * 100)));
      }}
      layout.style.setProperty("--network-routes-split", clean.toFixed(4));
      networkRoutesSplitRatio = clean;
      if (persist) {{
        networkRoutesSplitRatio = persistPreferredNetworkRoutesSplitRatio(clean);
        layout.style.setProperty("--network-routes-split", networkRoutesSplitRatio.toFixed(4));
        if (divider instanceof HTMLElement) {{
          divider.setAttribute("aria-valuenow", String(Math.round(networkRoutesSplitRatio * 100)));
        }}
      }}
      return networkRoutesSplitRatio;
    }}

    function bindNetworkRoutesSplitLayout(root) {{
      if (!(root instanceof HTMLElement)) return;
      const layout = root.querySelector("[data-routes-split-layout]");
      if (!(layout instanceof HTMLElement)) return;
      const divider = layout.querySelector("[data-routes-split-divider]");
      if (!(divider instanceof HTMLElement)) return;

      applyNetworkRoutesSplitLayoutRatio(layout, networkRoutesSplitRatio, false);
      if (divider.dataset.bound === "1") return;
      divider.dataset.bound = "1";

      const applyFromPointer = (clientY, persist = false) => {{
        const rect = layout.getBoundingClientRect();
        if (!Number.isFinite(rect.height) || rect.height <= 12) return;
        const dividerRect = divider.getBoundingClientRect();
        const dividerHeight = Number.isFinite(dividerRect.height) && dividerRect.height > 0
          ? dividerRect.height
          : 10;
        const usableHeight = Math.max(32, rect.height - dividerHeight);
        const pointerOffset = clientY - rect.top - (dividerHeight * 0.5);
        const ratio = pointerOffset / usableHeight;
        applyNetworkRoutesSplitLayoutRatio(layout, ratio, persist);
      }};

      divider.addEventListener("pointerdown", (event) => {{
        if (!(event instanceof PointerEvent) || event.button !== 0) return;
        if (typeof window.matchMedia === "function" && window.matchMedia("(max-width: 1100px)").matches) return;
        networkRoutesSplitPointerDrag = {{
          pointerId: event.pointerId,
          layout,
          divider,
        }};
        divider.classList.add("active");
        layout.classList.add("is-dragging");
        document.body.classList.add("resizing-panels-y");
        try {{
          divider.setPointerCapture(event.pointerId);
        }} catch (_err) {{
        }}
        applyFromPointer(event.clientY, false);
        event.preventDefault();
      }});

      divider.addEventListener("pointermove", (event) => {{
        if (!(event instanceof PointerEvent)) return;
        const drag = networkRoutesSplitPointerDrag;
        if (!drag || drag.layout !== layout || drag.divider !== divider) return;
        if (Number(event.pointerId) !== Number(drag.pointerId)) return;
        applyFromPointer(event.clientY, false);
      }});

      const finishDrag = (event) => {{
        const drag = networkRoutesSplitPointerDrag;
        if (!drag || drag.layout !== layout || drag.divider !== divider) return;
        if (event && Number(event.pointerId) !== Number(drag.pointerId)) return;
        networkRoutesSplitPointerDrag = null;
        divider.classList.remove("active");
        layout.classList.remove("is-dragging");
        document.body.classList.remove("resizing-panels-y");
        try {{
          divider.releasePointerCapture(drag.pointerId);
        }} catch (_err) {{
        }}
        if (event && Number.isFinite(Number(event.clientY))) {{
          applyFromPointer(event.clientY, true);
        }} else {{
          applyNetworkRoutesSplitLayoutRatio(layout, networkRoutesSplitRatio, true);
        }}
      }};
      divider.addEventListener("pointerup", finishDrag);
      divider.addEventListener("pointercancel", finishDrag);
      divider.addEventListener("lostpointercapture", finishDrag);

      divider.addEventListener("keydown", (event) => {{
        if (!(event instanceof KeyboardEvent)) return;
        const step = event.shiftKey ? 0.08 : 0.04;
        if (event.key === "ArrowUp") {{
          event.preventDefault();
          applyNetworkRoutesSplitLayoutRatio(layout, networkRoutesSplitRatio - step, true);
          return;
        }}
        if (event.key === "ArrowDown") {{
          event.preventDefault();
          applyNetworkRoutesSplitLayoutRatio(layout, networkRoutesSplitRatio + step, true);
          return;
        }}
        if (event.key === "Home") {{
          event.preventDefault();
          applyNetworkRoutesSplitLayoutRatio(layout, networkRoutesSplitRatioMin, true);
          return;
        }}
        if (event.key === "End") {{
          event.preventDefault();
          applyNetworkRoutesSplitLayoutRatio(layout, networkRoutesSplitRatioMax, true);
        }}
      }});
    }}

    function renderNetworkRoutes(state = latestState, options = {{}}) {{
      bindNetworkRoutesControls();
      networkRoutesMode = normalizeNetworkRoutesMode(networkRoutesMode);
      networkRoutesWindow = normalizeNetworkGraphEdgeMode(networkRoutesWindow);
      ensureNetworkRoutesWindowOptions();
      syncNetworkRoutesModeControls();

      const summary = document.getElementById("network-routes-summary");
      const result = document.getElementById("network-routes-result");
      const status = document.getElementById("network-routes-status");
      const fromSelect = document.getElementById("network-routes-from");
      const toSelect = document.getElementById("network-routes-to");
      const sourceChip = document.getElementById("network-routes-source-chip");
      const windowSelect = document.getElementById("network-routes-window");
      const swapBtn = document.getElementById("network-routes-swap-btn");
      const runBtn = document.getElementById("network-routes-run-live-btn");
      if (!(summary instanceof HTMLElement) || !(result instanceof HTMLElement)) return;
      summary.hidden = false;
      summary.setAttribute("aria-hidden", "false");

      const data = buildNetworkRoutesData(state);
      const nodeIds = networkRoutesSortedNodeIds(data.nodeMap);
      const mode = normalizeNetworkRoutesMode(networkRoutesMode);
      const pinnedTargetId = getNetworkRoutesPinnedTargetId(data.nodeMap);
      if (mode === "live") {{
        const resolvedSourceId = resolveNetworkRoutesSourceNodeId(state, data.nodeMap, nodeIds);
        if (isSelectableNodeId(resolvedSourceId)) {{
          networkRoutesFromNodeId = resolvedSourceId;
        }}
        if (isSelectableNodeId(pinnedTargetId) && pinnedTargetId !== networkRoutesFromNodeId) {{
          networkRoutesToNodeId = pinnedTargetId;
        }} else {{
          const selectedId = normalizeNodeId(selectedNodeId || "");
          if (
            isSelectableNodeId(selectedId)
            && selectedId !== networkRoutesFromNodeId
            && data.nodeMap.has(selectedId)
          ) {{
            networkRoutesToNodeId = selectedId;
          }}
        }}
      }}
      const selections = resolveNetworkRoutesSelections(data, nodeIds);
      networkRoutesFromNodeId = selections.fromId;
      networkRoutesToNodeId = selections.toId;
      renderNetworkRoutesNodeOptions(fromSelect, nodeIds, networkRoutesFromNodeId, data.nodeMap, data.localNodeId);
      renderNetworkRoutesNodeOptions(toSelect, nodeIds, networkRoutesToNodeId, data.nodeMap, data.localNodeId);
      const fromName = networkGraphNodeDisplayName(networkRoutesFromNodeId, data.nodeMap);
      if (sourceChip instanceof HTMLElement) {{
        sourceChip.textContent = `From: ${{fromName}} (self)`;
      }}
      const liveState = normalizedNetworkRoutesLiveTraceState(networkRoutesLiveTraceState);
      const endpointsReady = (
        isSelectableNodeId(networkRoutesFromNodeId)
        && isSelectableNodeId(networkRoutesToNodeId)
        && networkRoutesFromNodeId !== networkRoutesToNodeId
      );

      if (windowSelect instanceof HTMLSelectElement) {{
        windowSelect.disabled = mode === "live";
      }}
      if (swapBtn instanceof HTMLButtonElement) {{
        swapBtn.disabled = mode === "live" || !endpointsReady;
      }}
      if (runBtn instanceof HTMLButtonElement) {{
        runBtn.hidden = false;
        runBtn.disabled = !endpointsReady || !!liveState.running;
        runBtn.classList.toggle("is-running-trace", !!liveState.running);
        if (liveState.running) {{
          const progressPct = networkRoutesLiveTraceProgressPct(liveState);
          runBtn.style.setProperty("--network-routes-run-progress", `${{progressPct}}%`);
          runBtn.setAttribute("aria-busy", "true");
          runBtn.setAttribute("aria-label", `Traceroute running ${{progressPct}}%`);
          runBtn.title = `Traceroute in progress (${{progressPct}}%)`;
          runBtn.innerHTML = `<span class="network-routes-run-progress-fill" aria-hidden="true"></span><span class="network-routes-run-progress-text">Tracing ${{escAttr(String(progressPct))}}%</span>`;
        }} else {{
          runBtn.style.removeProperty("--network-routes-run-progress");
          runBtn.removeAttribute("aria-busy");
          runBtn.removeAttribute("aria-label");
          runBtn.title = "Run live traceroute from self to selected destination";
          runBtn.textContent = "Run trace";
        }}
      }}

      if (status instanceof HTMLElement) {{
        if (mode === "live") {{
          if (liveState.running) {{
            status.textContent = "Running live traceroute...";
          }} else if (liveState.ok === false && liveState.error) {{
            status.textContent = liveState.error;
          }} else if (liveState.ok === true && liveState.updatedMs > 0) {{
            status.textContent = `Trace updated ${{formatLocalChatTime(Math.floor(liveState.updatedMs / 1000), "n/a")}}`;
          }} else {{
            status.textContent = "";
          }}
        }} else {{
          status.textContent = data.historyLoading
            ? `Loading ${{networkGraphEdgeModeLabel(data.edgeMode)}} links...`
            : "";
        }}
      }}

      if (!nodeIds.length) {{
        if (sourceChip instanceof HTMLElement) {{
          sourceChip.textContent = "From: self";
        }}
        summary.innerHTML = `<span><strong>Routes</strong> - no selectable nodes yet</span><span>0 nodes</span>`;
        result.innerHTML = `<div class="network-routes-empty">No route endpoints are available yet.</div>`;
        return;
      }}

      const toName = networkGraphNodeDisplayName(networkRoutesToNodeId, data.nodeMap);
      if (mode === "live") {{
        if (!endpointsReady) {{
          summary.innerHTML = `<span><strong>Live trace</strong> - choose a destination</span><span>source: self</span>`;
          result.innerHTML = `<div class="network-routes-empty">Choose a destination node, then run a live traceroute.</div>`;
          return;
        }}
        const liveSourceId = normalizeNodeId(liveState.sourceId || "");
        const liveTargetId = normalizeNodeId(liveState.targetId || "");
        const runningFromId = (
          liveState.running
          && isSelectableNodeId(liveSourceId)
        ) ? liveSourceId : networkRoutesFromNodeId;
        const runningToId = (
          liveState.running
          && isSelectableNodeId(liveTargetId)
        ) ? liveTargetId : networkRoutesToNodeId;
        const runningFromName = networkGraphNodeDisplayName(runningFromId, data.nodeMap);
        const runningToName = networkGraphNodeDisplayName(runningToId, data.nodeMap);
        const liveMatchesSelection = networkRoutesLiveTraceMatchesSelection(
          liveState,
          networkRoutesFromNodeId,
          networkRoutesToNodeId
        );
        summary.innerHTML = `<span><strong>Live trace</strong> - ${{escAttr(runningFromName)}} to ${{escAttr(runningToName)}}</span><span>${{liveState.running ? "running" : "ready"}}</span>`;
        if (liveState.running && !liveMatchesSelection) {{
          result.innerHTML = `<div class="network-routes-empty">Running traceroute from ${{escAttr(runningFromName)}} to ${{escAttr(runningToName)}}...</div>`;
          return;
        }}
        if (liveMatchesSelection && liveState.ok === true && liveState.result && typeof liveState.result === "object") {{
          result.innerHTML = networkRoutesLiveTraceResultHtml(
            liveState,
            data,
            networkRoutesFromNodeId,
            networkRoutesToNodeId
          );
          bindNetworkRoutesScopeInteractions(result);
          hydrateNetworkRoutesScopeNodeCities(result);
          return;
        }}
        if (liveMatchesSelection && liveState.ok === false) {{
          const detail = String(liveState.error || "").trim() || "Traceroute request failed.";
          const lines = Array.isArray(liveState.lines) ? liveState.lines : [];
          const linesHtml = lines.length
            ? `<div class="chat-node-telemetry-tool-lines">${{lines.slice(0, 3).map((line) => `<div class="chat-node-telemetry-tool-line">${{escAttr(line)}}</div>`).join("")}}</div>`
            : "";
          result.innerHTML = `<div class="network-routes-empty">${{escAttr(detail)}}</div>${{linesHtml}}`;
          return;
        }}
        result.innerHTML = `<div class="network-routes-empty">Run trace to capture the live hop path from self to ${{escAttr(toName)}}.</div>`;
        return;
      }}

      if (!isSelectableNodeId(networkRoutesFromNodeId) || !isSelectableNodeId(networkRoutesToNodeId)) {{
        summary.innerHTML = `<span><strong>Inferred route</strong> - choose two nodes</span><span>${{escAttr(networkGraphEdgeModeLabel(data.edgeMode))}}</span>`;
        result.innerHTML = `<div class="network-routes-empty">Choose a source and target node.</div>`;
        return;
      }}

      const route = networkRoutesFindInferredPath(networkRoutesFromNodeId, networkRoutesToNodeId, data.adjacency);
      if (!route.path.length) {{
        summary.innerHTML = `<span><strong>Inferred route</strong> - no path found</span><span>${{escAttr(networkGraphEdgeModeLabel(data.edgeMode))}} links</span>`;
        result.innerHTML = `<div class="network-routes-empty">No observed link path connects ${{escAttr(fromName)}} and ${{escAttr(toName)}} in the selected link window.</div>`;
        return;
      }}

      summary.innerHTML = "";
      summary.hidden = true;
      summary.setAttribute("aria-hidden", "true");
      const routeLocationEstimates = networkRoutesBuildLocationEstimates(data);
      const scopeHtml = networkRoutesScopeHtml(route, data, networkRoutesFromNodeId, networkRoutesToNodeId, {{ routeLocationEstimates }});
      const pathHtml = networkRoutesPathHtml(route, data.nodeMap, data.localNodeId);
      result.innerHTML = networkRoutesSplitLayoutHtml(scopeHtml, pathHtml, {{
        ratio: networkRoutesSplitRatio,
      }});
      bindNetworkRoutesSplitLayout(result);
      bindNetworkRoutesScopeInteractions(result);
      hydrateNetworkRoutesScopeNodeCities(result);
    }}

    function formatMalformedDiagnosticsTimestamp(unixValue) {{
      const parsed = Number(unixValue);
      if (!Number.isFinite(parsed) || parsed <= 0) return "n/a";
      try {{
        return new Date(Math.floor(parsed) * 1000).toLocaleString();
      }} catch (_err) {{
        return "n/a";
      }}
    }}

    function previewMalformedDiagnosticsPayload(value, maxLength = 64) {{
      const text = String(value == null ? "" : value).trim();
      if (!text) return "n/a";
      if (text.length <= maxLength) return text;
      return `${{text.slice(0, Math.max(12, maxLength - 3))}}...`;
    }}

    function resolveMalformedDiagnosticsSenderLabel(sender, state = latestState) {{
      const safeSender = (sender && typeof sender === "object") ? sender : {{}};
      const cleanId = normalizeNodeId(safeSender.from_id || safeSender.fromId || "");
      const safeState = (state && typeof state === "object") ? state : {{}};
      const nodes = Array.isArray(safeState.nodes) ? safeState.nodes : [];
      let node = null;
      for (const entry of nodes) {{
        if (!entry || typeof entry !== "object") continue;
        if (normalizeNodeId(entry.id || entry.node_id || entry.nodeId || "") === cleanId) {{
          node = entry;
          break;
        }}
      }}
      const preferred = node ? String(preferredNodeName(node) || "").trim() : "";
      const cached = (nodeNameCache instanceof Map)
        ? String(nodeNameCache.get(cleanId) || "").trim()
        : "";
      const fallback = String(safeSender.from_label || safeSender.fromLabel || cleanId || "Unknown node").trim();
      return preferred || cached || fallback || "Unknown node";
    }}

    function renderNetworkDiagnosticsLoading() {{
      const overviewHost = document.getElementById("network-diagnostics-overview");
      const emptyHost = document.getElementById("network-diagnostics-empty");
      const sendersHost = document.getElementById("network-diagnostics-senders");
      const entriesHost = document.getElementById("network-diagnostics-entries");
      const titleHost = document.getElementById("network-diagnostics-entries-title");
      const noteHost = document.getElementById("network-diagnostics-summary-note");
      const layoutHost = document.querySelector("#network-map-panel-diagnostics .network-diagnostics-layout");
      if (overviewHost instanceof HTMLElement) {{
        overviewHost.innerHTML = "";
      }}
      if (sendersHost instanceof HTMLElement) {{
        sendersHost.innerHTML = "";
      }}
      if (entriesHost instanceof HTMLElement) {{
        entriesHost.innerHTML = "";
      }}
      if (titleHost instanceof HTMLElement) {{
        titleHost.textContent = "Recent Payloads";
      }}
      if (noteHost instanceof HTMLElement) {{
        noteHost.innerHTML = `Reviewing persisted malformed <code>TEXT_MESSAGE_APP</code> payloads...`;
      }}
      if (layoutHost instanceof HTMLElement) {{
        layoutHost.hidden = true;
      }}
