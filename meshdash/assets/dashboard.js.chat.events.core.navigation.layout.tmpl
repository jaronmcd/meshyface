      if (next === "settings") {{
        if (ensureSettingsFixedMap()) {{
          const shouldRecenterSettingsMap = (
            activeSettingsTab === "core"
            && normalizeSettingsPositionSource(readSettingsPositionSourceSelection()) === "fixed"
          );
          syncSettingsFixedMapFromInputs({{ recenter: shouldRecenterSettingsMap }});
          requestSettingsFixedMapResizeStabilized();
        }}
      }} else {{
        clearSettingsFixedMapResizeTimers();
