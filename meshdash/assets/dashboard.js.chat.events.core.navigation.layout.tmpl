        if (!payload) {{
          throw (lastError || new Error("traceroute failed"));
        }}
        if (requestNonce !== networkRoutesLiveTraceRequestNonce) return payload;
        syncNetworkRoutesLiveTraceFromPayload(targetId, payload, {{
          sourceId,
          ok: true,
          renderIfVisible: true,
        }});
        if (typeof syncChatNodeTelemetryTracerouteFromPayload === "function") {{
          syncChatNodeTelemetryTracerouteFromPayload(targetId, payload, {{
            ok: true,
            updateSummary: true,
            renderPanel: true,
          }});
        }}
        if (typeof requestImmediatePoll === "function") {{
          requestImmediatePoll(120);
        }}
        return payload;
      }} catch (err) {{
        if (requestNonce !== networkRoutesLiveTraceRequestNonce) throw err;
        const payload = (err && typeof err === "object") ? err.payload : null;
        const message = err instanceof Error
          ? String(err.message || "traceroute failed")
          : String(err || "traceroute failed");
        const tracePayload = (payload && typeof payload === "object")
          ? payload
          : {{
              ok: false,
              destination: targetId,
              error: message,
              console_lines: [],
            }};
        syncNetworkRoutesLiveTraceFromPayload(targetId, tracePayload, {{
          sourceId,
          ok: false,
          error: message,
          renderIfVisible: true,
        }});
        if (typeof syncChatNodeTelemetryTracerouteFromPayload === "function") {{
          syncChatNodeTelemetryTracerouteFromPayload(targetId, tracePayload, {{
            ok: false,
            error: message,
            updateSummary: true,
            renderPanel: true,
          }});
        }}
        return null;
      }}
    }}

    function openNetworkRoutesLiveTrace(rawTargetNodeId = selectedNodeId, options = {{}}) {{
      const opts = (options && typeof options === "object") ? options : {{}};
      const targetId = normalizeNodeId(rawTargetNodeId || selectedNodeId || "");
      const sourceId = resolveNetworkRoutesSourceNodeId(latestState);
      networkRoutesMode = "live";
      persistPreferredNetworkRoutesMode(networkRoutesMode);
      if (isSelectableNodeId(sourceId)) {{
        networkRoutesFromNodeId = sourceId;
      }}
      if (isSelectableNodeId(targetId)) {{
        networkRoutesToNodeId = targetId;
        setNetworkRoutesPinnedTargetId(targetId);
      }}
      persistPreferredNetworkRoutesNodeId(networkRoutesFromStorageKey, networkRoutesFromNodeId);
      persistPreferredNetworkRoutesNodeId(networkRoutesToStorageKey, networkRoutesToNodeId);

      if (opts.tracePayload && typeof opts.tracePayload === "object") {{
        setNetworkRoutesLiveTraceState({{
          running: false,
          ok: true,
          updatedMs: Date.now(),
          sourceId: normalizeNodeId(networkRoutesFromNodeId || sourceId),
          targetId: normalizeNodeId(networkRoutesToNodeId || targetId),
          error: "",
          lines: networkRoutesExtractConsoleLines(opts.tracePayload),
          result: (opts.tracePayload.result && typeof opts.tracePayload.result === "object")
            ? opts.tracePayload.result
