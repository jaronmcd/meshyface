        // Render visible UI from cached state immediately on view switches.
        // This prevents "blank" panes when the server legitimately returns 304s.
        renderSummary(latestState);
        if (next === "saved" || next === "network") {{
          renderMap(latestState.nodes || [], (latestState.traffic || {{}}).edges || [], cachedNodeHistory);
