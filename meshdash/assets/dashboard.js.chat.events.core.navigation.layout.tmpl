    function resolveNetworkGraphPointerPosition(svg, clientX, clientY) {{
      if (!(svg instanceof SVGElement)) return null;
      const rect = svg.getBoundingClientRect();
      if (!(rect.width > 0) || !(rect.height > 0)) return null;
      const viewBox = cloneNetworkGraphViewBox(networkGraphViewState.viewBox);
      const viewAspect = viewBox.width / viewBox.height;
      const rectAspect = rect.width / rect.height;
      let renderWidth = rect.width;
      let renderHeight = rect.height;
      let offsetX = 0;
      let offsetY = 0;
      if (rectAspect > viewAspect) {{
        renderWidth = rect.height * viewAspect;
        offsetX = (rect.width - renderWidth) / 2;
      }} else if (rectAspect < viewAspect) {{
        renderHeight = rect.width / viewAspect;
        offsetY = (rect.height - renderHeight) / 2;
      }}
      if (!(renderWidth > 0) || !(renderHeight > 0)) return null;
      const unitX = Math.min(1, Math.max(0, (clientX - rect.left - offsetX) / renderWidth));
      const unitY = Math.min(1, Math.max(0, (clientY - rect.top - offsetY) / renderHeight));
      return {{
        x: viewBox.x + (unitX * viewBox.width),
        y: viewBox.y + (unitY * viewBox.height),
      }};
    }}

    function getNetworkGraphActivePointers() {{
      if (!(networkGraphViewState.activePointers instanceof Map)) {{
        networkGraphViewState.activePointers = new Map();
      }}
      return networkGraphViewState.activePointers;
    }}

    function firstTwoNetworkGraphPointers() {{
      return Array.from(getNetworkGraphActivePointers().values()).slice(0, 2);
    }}

    function networkGraphPointerDistance(a, b) {{
      if (!a || !b) return 0;
      return Math.hypot(
        Number(b.clientX) - Number(a.clientX),
        Number(b.clientY) - Number(a.clientY)
      );
    }}

    function networkGraphPointerCenter(a, b) {{
      if (!a || !b) return null;
      return {{
        clientX: (Number(a.clientX) + Number(b.clientX)) / 2,
        clientY: (Number(a.clientY) + Number(b.clientY)) / 2,
      }};
    }}

    function beginNetworkGraphPinch(svg) {{
      if (!(svg instanceof SVGElement)) return false;
      const [firstPointer, secondPointer] = firstTwoNetworkGraphPointers();
      const startDistance = networkGraphPointerDistance(firstPointer, secondPointer);
      const center = networkGraphPointerCenter(firstPointer, secondPointer);
      if (!(startDistance > 6) || !center) return false;
      const graphPoint = resolveNetworkGraphPointerPosition(svg, center.clientX, center.clientY);
      if (!graphPoint) return false;
      cancelNetworkGraphViewAnimation();
      cancelNetworkGraphSceneAnimation();
      networkGraphViewState.pendingFocusTransition = null;
      networkGraphViewState.pointerId = null;
      networkGraphViewState.pointerViewBox = null;
      networkGraphViewState.pointerDownNodeId = "";
      networkGraphViewState.pinchStartDistance = startDistance;
      networkGraphViewState.pinchStartCenterClientX = center.clientX;
      networkGraphViewState.pinchStartCenterClientY = center.clientY;
      networkGraphViewState.pinchStartViewBox = cloneNetworkGraphViewBox(networkGraphViewState.viewBox);
      networkGraphViewState.pinchStartGraphPoint = graphPoint;
      networkGraphViewState.pinching = true;
      networkGraphViewState.dragging = true;
      networkGraphViewState.captureActive = true;
      if (svg.parentElement instanceof HTMLElement) {{
        svg.parentElement.classList.add("is-panning");
      }}
      if (typeof svg.setPointerCapture === "function") {{
        getNetworkGraphActivePointers().forEach((_pointer, pointerId) => {{
          try {{
            svg.setPointerCapture(pointerId);
          }} catch (_err) {{
          }}
        }});
      }}
      return true;
    }}

    function updateNetworkGraphPinch(svg) {{
      if (!(svg instanceof SVGElement) || !networkGraphViewState.pinching) return false;
      const [firstPointer, secondPointer] = firstTwoNetworkGraphPointers();
      const currentDistance = networkGraphPointerDistance(firstPointer, secondPointer);
      const currentCenter = networkGraphPointerCenter(firstPointer, secondPointer);
      const startDistance = Number(networkGraphViewState.pinchStartDistance);
      const startViewBox = cloneNetworkGraphViewBox(networkGraphViewState.pinchStartViewBox);
      const startPoint = networkGraphViewState.pinchStartGraphPoint;
      if (!(currentDistance > 6) || !(startDistance > 6) || !currentCenter || !startPoint) return false;
      const rect = svg.getBoundingClientRect();
      if (!(rect.width > 0) || !(rect.height > 0)) return false;
