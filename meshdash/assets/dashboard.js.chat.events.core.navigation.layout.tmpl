    function syncNetworkGraphTextZoom(svg, rawViewBox) {{
      if (!(svg instanceof SVGElement)) return;
      const viewBox = cloneNetworkGraphViewBox(rawViewBox);
      const zoomRatio = networkGraphViewportBase.width / Math.max(1, Number(viewBox.width) || networkGraphViewportBase.width);
      const zoomFactor = Math.max(1, zoomRatio);
      const labelDensity = zoomRatio >= 2.6
        ? "full"
        : zoomRatio >= 1.55
        ? "medium"
        : "overview";
      const compensation = Math.max(0.22, Math.min(1, 1 / zoomFactor));
      const labelSizePx = 9.4 * compensation;
      const secondaryLabelSizePx = 8.3 * compensation;
      const ringLabelSizePx = 9.2 * compensation;
      const regionLabelSizePx = 9.2 * compensation;
      const emojiCompensation = Math.max(0.52, Math.min(1, 0.84 / Math.sqrt(zoomFactor)));
      const emojiSizePx = 18 * emojiCompensation;
      const localEmojiSizePx = 20 * emojiCompensation;
      const labelStrokePx = Math.max(0.95, 2.15 * compensation);
      svg.style.setProperty("--network-graph-label-font-size", `${{labelSizePx.toFixed(2)}}px`);
      svg.style.setProperty("--network-graph-secondary-label-font-size", `${{secondaryLabelSizePx.toFixed(2)}}px`);
      svg.style.setProperty("--network-graph-ring-label-font-size", `${{ringLabelSizePx.toFixed(2)}}px`);
      svg.style.setProperty("--network-graph-region-label-font-size", `${{regionLabelSizePx.toFixed(2)}}px`);
      svg.style.setProperty("--network-graph-emoji-font-size", `${{emojiSizePx.toFixed(2)}}px`);
      svg.style.setProperty("--network-graph-local-emoji-font-size", `${{localEmojiSizePx.toFixed(2)}}px`);
      svg.style.setProperty("--network-graph-label-stroke-width", `${{labelStrokePx.toFixed(2)}}px`);
      const labelEls = svg.querySelectorAll(".network-graph-node-label");
      labelEls.forEach((labelEl) => {{
        if (!(labelEl instanceof SVGTextElement)) return;
        const baseRadius = Math.max(0, Number(labelEl.getAttribute("data-network-graph-node-radius") || 0));
        const rawBaseOffset = Number(
          labelEl.getAttribute("data-network-graph-label-offset-y")
          || labelEl.getAttribute("y")
          || 0
        );
        if (!Number.isFinite(rawBaseOffset) || rawBaseOffset === 0) return;
        const direction = rawBaseOffset < 0 ? -1 : 1;
        const baseMagnitude = Math.abs(rawBaseOffset);
        const baseGap = Math.max(0, baseMagnitude - baseRadius);
        const nodeGroup = labelEl.closest(".network-graph-node");
        const ridesUnderEmoji = !!(nodeGroup && nodeGroup.classList.contains("has-emoji-glyph"));
        const radiusFactor = ridesUnderEmoji ? 0.58 : 0.72;
        const pinnedGapPx = Math.max(
          ridesUnderEmoji ? 1.8 : 2.6,
          Math.min(ridesUnderEmoji ? 4.2 : 5.4, baseGap * 0.55)
        );
        const adjustedMagnitude = Math.max(
          1.2,
          (baseRadius * radiusFactor) + (pinnedGapPx / zoomFactor)
        );
        labelEl.setAttribute("y", `${{(adjustedMagnitude * direction).toFixed(2)}}`);
      }});
      svg.dataset.labelDensity = labelDensity;
    }}

    function applyNetworkGraphViewBox(svg, rawViewBox, options = {{}}) {{
