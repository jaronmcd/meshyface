    function combineNetworkGraphEdges(rawEdges, nodeMap) {{
      const buckets = new Map();
      for (const edge of (rawEdges || [])) {{
        const fromId = normalizeNodeId(edge && edge.from);
        const toId = normalizeNodeId(edge && edge.to);
        if (!isSelectableNodeId(fromId) || !isSelectableNodeId(toId) || fromId === toId) continue;
        if (!(nodeMap instanceof Map) || !nodeMap.has(fromId) || !nodeMap.has(toId)) continue;
        const a = fromId < toId ? fromId : toId;
        const b = fromId < toId ? toId : fromId;
        const key = `${{a}}::${{b}}`;
        if (!buckets.has(key)) {{
          buckets.set(key, {{
            key,
            a,
            b,
            weight: 0,
            sessionWeight: 0,
            isReal: false,
            lastSeenUnix: 0,
            lastSeenLabel: "",
            lastHops: null,
            avgHopsWeight: 0,
            avgHopsSamples: 0,
            directionCount: 0,
          }});
        }}
        const bucket = buckets.get(key);
        if (!bucket) continue;
        const lifetimeCount = Number(edge && (edge.lifetime_count ?? edge.count ?? 0));
        const sessionCount = Number(edge && (edge.session_count ?? edge.count ?? 0));
        const parsedLifetime = Number.isFinite(lifetimeCount) ? Math.max(0, lifetimeCount) : 0;
        const parsedSession = Number.isFinite(sessionCount) ? Math.max(0, sessionCount) : 0;
        bucket.weight += parsedLifetime;
        bucket.sessionWeight += parsedSession;
        bucket.isReal = bucket.isReal || !!(edge && edge.is_real);
        bucket.directionCount += 1;
        const lastSeenUnix = (typeof parseEdgeLastSeenUnix === "function")
          ? parseEdgeLastSeenUnix(edge)
          : NaN;
        if (Number.isFinite(lastSeenUnix) && lastSeenUnix > bucket.lastSeenUnix) {{
          bucket.lastSeenUnix = lastSeenUnix;
          bucket.lastSeenLabel = String((edge && edge.last_rx_time) || "");
          const lastHops = Number(edge && edge.last_hops);
          bucket.lastHops = Number.isFinite(lastHops) ? lastHops : bucket.lastHops;
        }}
        const avgHops = Number(edge && edge.avg_hops);
        const hopsSamples = Number(edge && edge.hops_samples);
        if (Number.isFinite(avgHops)) {{
          const sampleWeight = (Number.isFinite(hopsSamples) && hopsSamples > 0) ? hopsSamples : 1;
          bucket.avgHopsWeight += avgHops * sampleWeight;
          bucket.avgHopsSamples += sampleWeight;
        }}
      }}
      const combined = Array.from(buckets.values()).map((bucket) => ({{
        ...bucket,
        avgHops: bucket.avgHopsSamples > 0
          ? Math.round((bucket.avgHopsWeight / bucket.avgHopsSamples) * 100) / 100
          : null,
      }}));
      combined.sort((a, b) => (
        (b.weight - a.weight)
        || (b.directionCount - a.directionCount)
        || (a.a < b.a ? -1 : (a.a > b.a ? 1 : 0))
        || (a.b < b.b ? -1 : (a.b > b.b ? 1 : 0))
      ));
      return combined;
    }}

    function buildNetworkGraphAdjacency(nodeMap, edges) {{
      const adjacency = new Map();
      for (const nodeId of (nodeMap instanceof Map ? nodeMap.keys() : [])) {{
        adjacency.set(nodeId, new Map());
      }}
      for (const edge of (edges || [])) {{
        if (!edge || !adjacency.has(edge.a) || !adjacency.has(edge.b)) continue;
        adjacency.get(edge.a).set(edge.b, edge);
        adjacency.get(edge.b).set(edge.a, edge);
      }}
      return adjacency;
    }}

    function resolveNetworkGraphRootId(nodeMap, adjacency, degreeMeta, state) {{
      const graphRootId = normalizeNodeId(networkGraphRootNodeId || "");
      if (graphRootId && nodeMap.has(graphRootId)) return graphRootId;
      const selectedId = normalizeNodeId(selectedNodeId || "");
      if (selectedId && nodeMap.has(selectedId)) return selectedId;
      const localNodeId = normalizeNodeId(resolveLocalNodeId(state || latestState || {{}}) || "");
      if (localNodeId && nodeMap.has(localNodeId)) return localNodeId;
      let bestId = "";
      let bestDegree = -1;
      let bestWeight = -1;
      for (const nodeId of nodeMap.keys()) {{
        const peers = adjacency.get(nodeId) || new Map();
        const meta = degreeMeta.get(nodeId) || {{ degree: peers.size, weight: 0 }};
        if (meta.degree > bestDegree || (meta.degree === bestDegree && meta.weight > bestWeight)) {{
          bestId = nodeId;
          bestDegree = meta.degree;
          bestWeight = meta.weight;
        }}
      }}
      if (bestId) return bestId;
      for (const nodeId of nodeMap.keys()) {{
        return nodeId;
      }}
      return "";
    }}

    function buildNetworkGraphLayout(nodeMap, combinedEdges, state) {{
      const adjacency = buildNetworkGraphAdjacency(nodeMap, combinedEdges);
      const safeState = (state && typeof state === "object") ? state : {{}};
      const safeTraffic = (safeState.traffic && typeof safeState.traffic === "object") ? safeState.traffic : {{}};
      const recentPackets = Array.isArray(safeTraffic.recent_packets) ? safeTraffic.recent_packets : [];
      const degreeMeta = new Map();
      for (const nodeId of nodeMap.keys()) {{
        const peers = adjacency.get(nodeId) || new Map();
        let totalWeight = 0;
        for (const edge of peers.values()) {{
          totalWeight += Number(edge && edge.weight) || 0;
        }}
        degreeMeta.set(nodeId, {{
          degree: peers.size,
          weight: totalWeight,
        }});
      }}
      const signalMetaByNodeId = buildNetworkGraphNodeSignalMeta(nodeMap, recentPackets);

      const rootId = resolveNetworkGraphRootId(nodeMap, adjacency, degreeMeta, state);
      if (!rootId) {{
        return {{
          rootId: "",
          adjacency,
          degreeMeta,
          items: [],
          positions: new Map(),
          layers: new Map(),
          rings: [],
          edges: combinedEdges,
          signalMetaByNodeId,
          connectedCount: 0,
          broadcastOnlyCount: 0,
          disconnectedCount: 0,
        }};
      }}

      const layerByNodeId = new Map([[rootId, 0]]);
      const visitQueue = [rootId];
      for (let cursor = 0; cursor < visitQueue.length; cursor += 1) {{
        const currentId = visitQueue[cursor];
        const currentLayer = Number(layerByNodeId.get(currentId) || 0);
        const neighbors = Array.from((adjacency.get(currentId) || new Map()).keys())
          .filter((peerId) => nodeMap.has(peerId))
          .sort((a, b) => compareNetworkGraphNodeIds(a, b, degreeMeta, nodeMap));
        for (const peerId of neighbors) {{
          if (layerByNodeId.has(peerId)) continue;
          layerByNodeId.set(peerId, currentLayer + 1);
          visitQueue.push(peerId);
        }}
      }}

      const layers = new Map();
      for (const [nodeId, layer] of layerByNodeId.entries()) {{
        if (!layers.has(layer)) {{
          layers.set(layer, []);
        }}
        layers.get(layer).push(nodeId);
      }}
      for (const ids of layers.values()) {{
        ids.sort((a, b) => compareNetworkGraphNodeIds(a, b, degreeMeta, nodeMap));
      }}

      const disconnectedCandidates = Array.from(nodeMap.keys())
        .filter((nodeId) => !layerByNodeId.has(nodeId))
        .sort((a, b) => compareNetworkGraphNodeIds(a, b, degreeMeta, nodeMap));
      const broadcastOnlyDisconnected = [];
      const disconnected = [];
      for (const nodeId of disconnectedCandidates) {{
        const meta = degreeMeta.get(nodeId) || {{ degree: 0, weight: 0 }};
        const signalMeta = signalMetaByNodeId.get(nodeId) || null;
        const isBroadcastOnly = !!(
          Number(meta.degree || 0) <= 0
          && signalMeta
          && (signalMeta.hasBroadcastOnlyEvidence || signalMeta.hasNodeStateBroadcastHint)
        );
        if (isBroadcastOnly) {{
          broadcastOnlyDisconnected.push(nodeId);
        }} else {{
          disconnected.push(nodeId);
        }}
      }}

      const centerX = 480;
      const centerY = 310;
      const positions = new Map();
      const polarAngleByNodeId = new Map();
      positions.set(rootId, {{
        x: centerX,
        y: centerY,
        layer: 0,
        disconnected: false,
        broadcastOnly: !!(
          (degreeMeta.get(rootId) || {{ degree: 0 }}).degree <= 0
          && (
            (signalMetaByNodeId.get(rootId) || {{}}).hasBroadcastOnlyEvidence
            || (signalMetaByNodeId.get(rootId) || {{}}).hasNodeStateBroadcastHint
          )
        ),
      }});
      polarAngleByNodeId.set(rootId, -Math.PI / 2);

      const connectedLayers = Array.from(layers.keys()).filter((layer) => layer > 0).sort((a, b) => a - b);
      const maxConnectedLayer = connectedLayers.length ? connectedLayers[connectedLayers.length - 1] : 0;
      const firstRingRadius = maxConnectedLayer <= 0 ? 0 : (maxConnectedLayer === 1 ? 180 : 116);
      const disconnectedRingCount = (broadcastOnlyDisconnected.length ? 1 : 0) + (disconnected.length ? 1 : 0);
      const outerConnectedRadius = disconnectedRingCount ? 228 : 262;
      const ringStep = maxConnectedLayer > 1
        ? Math.max(46, Math.min(88, (outerConnectedRadius - firstRingRadius) / Math.max(1, maxConnectedLayer - 1)))
        : 0;

      for (const layer of connectedLayers) {{
        const rawIds = Array.isArray(layers.get(layer)) ? Array.from(layers.get(layer)) : [];
        const ordered = rawIds.map((nodeId) => {{
          const parentAngles = Array.from((adjacency.get(nodeId) || new Map()).keys())
            .filter((peerId) => Number(layerByNodeId.get(peerId)) === (layer - 1))
            .map((peerId) => Number(polarAngleByNodeId.get(peerId)))
            .filter((angle) => Number.isFinite(angle));
          if (!parentAngles.length) {{
            return {{ nodeId, anchor: null }};
          }}
          let sinTotal = 0;
          let cosTotal = 0;
          for (const angle of parentAngles) {{
            sinTotal += Math.sin(angle);
            cosTotal += Math.cos(angle);
          }}
          return {{
            nodeId,
            anchor: Math.atan2(sinTotal / parentAngles.length, cosTotal / parentAngles.length),
          }};
        }}).sort((a, b) => {{
          const aAnchor = a.anchor;
          const bAnchor = b.anchor;
          if (Number.isFinite(aAnchor) && Number.isFinite(bAnchor) && aAnchor !== bAnchor) {{
            return aAnchor - bAnchor;
          }}
          if (Number.isFinite(aAnchor)) return -1;
          if (Number.isFinite(bAnchor)) return 1;
          return compareNetworkGraphNodeIds(a.nodeId, b.nodeId, degreeMeta, nodeMap);
        }});

        const ids = ordered.map((entry) => entry.nodeId);
        const radius = maxConnectedLayer === 1
          ? firstRingRadius
          : (firstRingRadius + ((layer - 1) * ringStep));
        const step = ids.length > 0 ? ((Math.PI * 2) / ids.length) : 0;
        const anchored = ordered.find((entry) => Number.isFinite(entry.anchor));
        const startAngle = anchored ? (Number(anchored.anchor) - (step / 2)) : (-Math.PI / 2);
        ids.forEach((nodeId, index) => {{
          const angle = ids.length === 1 ? (-Math.PI / 2) : (startAngle + (step * index));
          polarAngleByNodeId.set(nodeId, angle);
          positions.set(nodeId, {{
            x: centerX + (Math.cos(angle) * radius),
            y: centerY + (Math.sin(angle) * radius),
            layer,
            disconnected: false,
          }});
        }});
      }}

      const disconnectedGroups = [];
      if (broadcastOnlyDisconnected.length) {{
        disconnectedGroups.push({{
          nodeIds: broadcastOnlyDisconnected,
          label: "broadcast-only",
          detached: false,
          broadcastOnly: true,
        }});
      }}
      if (disconnected.length) {{
        disconnectedGroups.push({{
          nodeIds: disconnected,
          label: "detached",
          detached: true,
          broadcastOnly: false,
        }});
      }}

      if (disconnectedGroups.length) {{
        const firstDetachedRadius = Math.min(296, Math.max(206, outerConnectedRadius + 42));
        const detachedRingStep = disconnectedGroups.length > 1 ? 34 : 0;
        const span = Math.PI * 1.84;
        const startAngle = Math.PI * 0.08;
        disconnectedGroups.forEach((group, groupIndex) => {{
          const radius = Math.min(328, firstDetachedRadius + (groupIndex * detachedRingStep));
          const step = group.nodeIds.length > 1 ? (span / Math.max(1, group.nodeIds.length - 1)) : 0;
          group.nodeIds.forEach((nodeId, index) => {{
            const angle = group.nodeIds.length === 1 ? (Math.PI / 2) : (startAngle + (step * index));
            polarAngleByNodeId.set(nodeId, angle);
            positions.set(nodeId, {{
              x: centerX + (Math.cos(angle) * radius),
              y: centerY + (Math.sin(angle) * radius),
              layer: maxConnectedLayer + 1 + groupIndex,
              disconnected: true,
              broadcastOnly: !!group.broadcastOnly,
            }});
          }});
        }});
      }}

      const rings = connectedLayers.map((layer) => {{
        const radius = maxConnectedLayer === 1
          ? firstRingRadius
          : (firstRingRadius + ((layer - 1) * ringStep));
        return {{
          radius,
          label: `${{layer}} hop${{layer === 1 ? "" : "s"}}`,
          detached: false,
        }};
      }});
      disconnectedGroups.forEach((group, groupIndex) => {{
        const radius = Math.min(
          328,
          Math.min(296, Math.max(206, outerConnectedRadius + 42)) + (groupIndex * (disconnectedGroups.length > 1 ? 34 : 0))
        );
        rings.push({{
          radius,
          label: group.label,
          detached: !!group.detached,
          broadcastOnly: !!group.broadcastOnly,
        }});
      }});

      const selectedId = normalizeNodeId(selectedNodeId || "");
      const firstLayerCount = Array.isArray(layers.get(1)) ? layers.get(1).length : 0;
      const items = Array.from(positions.entries()).map(([nodeId, position]) => {{
        const node = nodeMap.get(nodeId) || null;
        const meta = degreeMeta.get(nodeId) || {{ degree: 0, weight: 0 }};
        const signalMeta = signalMetaByNodeId.get(nodeId) || null;
        const baseRadius = position.layer === 0
          ? 13
          : Math.max(5.5, Math.min(10.5, 5.4 + (Math.log2(Math.max(1, meta.weight) + 1) * 0.9) + Math.min(2.6, meta.degree * 0.2)));
        return {{
          nodeId,
          node,
          x: Number(position.x),
          y: Number(position.y),
          layer: Number(position.layer || 0),
          disconnected: !!position.disconnected,
          detached: !!position.disconnected && !position.broadcastOnly,
          broadcastOnly: !!position.broadcastOnly,
          degree: meta.degree,
          weight: meta.weight,
          signalMeta,
          radius: position.disconnected ? Math.max(5, baseRadius - 0.7) : baseRadius,
          showLabel: (
            nodeId === rootId
            || nodeId === selectedId
            || nodeMap.size <= 18
            || (!position.disconnected && position.layer === 1 && firstLayerCount <= 14)
            || (!position.disconnected && meta.degree >= 6 && position.layer <= 2)
          ),
        }};
      }});

      return {{
        rootId,
        adjacency,
        degreeMeta,
        items,
        positions,
        layers,
        rings,
        edges: combinedEdges,
        signalMetaByNodeId,
        connectedCount: layerByNodeId.size,
        broadcastOnlyCount: broadcastOnlyDisconnected.length
          + (
            positions.get(rootId) && positions.get(rootId).broadcastOnly
              ? 1
              : 0
          ),
        disconnectedCount: disconnected.length,
      }};
    }}

    function renderNetworkGraphView(state = latestState) {{
      const svg = document.getElementById("network-graph-svg");
      const empty = document.getElementById("network-graph-empty");
      const summary = document.getElementById("network-graph-summary");
      const legend = document.getElementById("network-graph-legend");
      if (!(svg instanceof SVGElement)) return;
      if (!(empty instanceof HTMLElement) || !(summary instanceof HTMLElement) || !(legend instanceof HTMLElement)) return;
      bindNetworkGraphInteractions(svg);

      const safeState = (state && typeof state === "object") ? state : {{}};
      const nodes = Array.isArray(safeState.nodes) ? safeState.nodes : [];
      const traffic = (safeState.traffic && typeof safeState.traffic === "object") ? safeState.traffic : {{}};
      const rawEdges = Array.isArray(traffic.edges) ? traffic.edges : [];
      const nodeMap = new Map();
      for (const node of nodes) {{
        const nodeId = normalizeNodeId(node && node.id);
        if (!isSelectableNodeId(nodeId) || nodeMap.has(nodeId)) continue;
        nodeMap.set(nodeId, node);
      }}

      const combinedEdges = combineNetworkGraphEdges(rawEdges, nodeMap);
      const layout = buildNetworkGraphLayout(nodeMap, combinedEdges, safeState);
      const rootId = layout.rootId;
      if (!rootId || !layout.items.length) {{
        cancelNetworkGraphSceneAnimation();
        svg.innerHTML = "";
        renderNetworkGraphNavigationControls(safeState, nodeMap, "");
        networkGraphViewState.bounds = defaultNetworkGraphBounds();
        networkGraphViewState.lastRootId = "";
        networkGraphViewState.initialized = false;
        networkGraphViewState.pendingEntryViewportSync = false;
        networkGraphViewState.renderedPositions = new Map();
        networkGraphViewState.renderedLayoutSnapshot = null;
        networkGraphViewState.pendingFocusTransition = null;
        stopNetworkGraphPan(svg);
        applyNetworkGraphViewBox(svg, networkGraphViewportBase);
        summary.innerHTML = "";
        legend.innerHTML = "";
        empty.hidden = false;
        scheduleNetworkGraphEmptyRetry();
        return;
      }}

      clearNetworkGraphEmptyRetry();
      empty.hidden = true;
      const selectedId = normalizeNodeId(selectedNodeId || "");
      const rootLabel = networkGraphNodeDisplayName(rootId, nodeMap);
      const firstHopCount = Array.isArray(layout.layers.get(1)) ? layout.layers.get(1).length : 0;
      const realLinkCount = combinedEdges.filter((edge) => !!(edge && edge.isReal)).length;
      const rootItem = layout.items.find((item) => item && item.nodeId === rootId) || null;
      const summaryParts = [
        `<span class="network-graph-chip"><span class="network-graph-chip-label">Root</span><strong>${{escAttr(truncateNetworkGraphLabel(rootLabel, 28))}}</strong></span>`,
        `<span class="network-graph-chip"><span class="network-graph-chip-label">Nodes</span><strong>${{layout.items.length}}</strong></span>`,
        `<span class="network-graph-chip"><span class="network-graph-chip-label">Links</span><strong>${{combinedEdges.length}}</strong></span>`,
        `<span class="network-graph-chip"><span class="network-graph-chip-label">Reach</span><strong>${{layout.connectedCount}}/${{layout.items.length}}</strong></span>`,
      ];
      if (rootItem && rootItem.broadcastOnly) {{
        summaryParts.push(
          `<span class="network-graph-chip"><span class="network-graph-chip-label">Root signal</span><strong>Broadcast only</strong></span>`
        );
      }}
      if (firstHopCount > 0) {{
        summaryParts.push(
          `<span class="network-graph-chip"><span class="network-graph-chip-label">1 Hop</span><strong>${{firstHopCount}}</strong></span>`
        );
      }}
      if (layout.broadcastOnlyCount > 0) {{
        summaryParts.push(
          `<span class="network-graph-chip"><span class="network-graph-chip-label">Broadcast only</span><strong>${{layout.broadcastOnlyCount}}</strong></span>`
        );
      }}
      if (layout.disconnectedCount > 0) {{
        summaryParts.push(
          `<span class="network-graph-chip"><span class="network-graph-chip-label">Detached</span><strong>${{layout.disconnectedCount}}</strong></span>`
        );
      }}
      summary.innerHTML = summaryParts.join("");
      networkGraphViewState.bounds = computeNetworkGraphBounds(layout);
      networkGraphRootNodeId = rootId;
      const rootPosition = layout.positions.get(rootId) || null;
      const shouldRecenterForEntry = !!(
        networkGraphViewState.pendingEntryViewportSync
        && rootPosition
        && !isNetworkGraphPointVisible(
          networkGraphViewState.viewBox,
          Number(rootPosition.x),
          Number(rootPosition.y),
          0.12
        )
      );
      renderNetworkGraphNavigationControls(safeState, nodeMap, rootId);
      const previousLayoutSnapshot = networkGraphViewState.renderedLayoutSnapshot;
      const shouldAnimateSceneChange = !!(
        previousLayoutSnapshot
        && networkGraphViewState.lastRootId
        && networkGraphViewState.lastRootId !== rootId
      );
      if (!networkGraphViewState.initialized) {{
        stopNetworkGraphPan(svg);
        resetNetworkGraphView(svg, {{ animate: false }});
      }} else if (networkGraphViewState.lastRootId !== rootId) {{
        stopNetworkGraphPan(svg);
        recenterNetworkGraphView(svg, {{ preserveScale: true }});
      }} else if (shouldRecenterForEntry) {{
        stopNetworkGraphPan(svg);
        recenterNetworkGraphView(svg, {{ preserveScale: true, animate: false }});
      }} else {{
        applyNetworkGraphViewBox(svg, networkGraphViewState.viewBox);
      }}
      networkGraphViewState.pendingEntryViewportSync = false;
      networkGraphViewState.pendingFocusTransition = null;
      networkGraphViewState.lastRootId = rootId;
      networkGraphViewState.renderedPositions = new Map(layout.positions);
      networkGraphViewState.renderedLayoutSnapshot = cloneNetworkGraphLayoutSnapshot(layout);

      legend.innerHTML = [
        `<span class="network-graph-legend-item"><span class="network-graph-swatch is-root"></span>Root / selected node</span>`,
        `<span class="network-graph-legend-item"><span class="network-graph-swatch is-real"></span>${{realLinkCount}} confirmed links</span>`,
        `<span class="network-graph-legend-item"><span class="network-graph-swatch is-observed"></span>${{Math.max(0, combinedEdges.length - realLinkCount)}} observed links</span>`,
        `<span class="network-graph-legend-item"><span class="network-graph-swatch is-broadcast-only"></span>Nodes heard recently, but only via broadcast</span>`,
        `<span class="network-graph-legend-item"><span class="network-graph-swatch is-detached"></span>Nodes with no current path or recent broadcast evidence</span>`,
        `<span class="network-graph-legend-item hint">Click to refocus, scroll to zoom, and use Back, Home, or Reset view from inside the graph.</span>`,
      ].join("");
      const scene = {{
        ...layout,
        rootId,
        selectedId,
        nodeMap,
        edges: combinedEdges,
      }};
      if (shouldAnimateSceneChange) {{
        animateNetworkGraphScene(svg, previousLayoutSnapshot, scene);
      }} else {{
        cancelNetworkGraphSceneAnimation();
        svg.innerHTML = buildNetworkGraphSceneMarkup(scene);
      }}
    }}

    function syncNodeHistoryDock() {{
      const nodeHistoryPanel = document.getElementById("map-data-node");
      const mapDataBody = document.getElementById("map-data-body");
      const networkHost = document.getElementById("network-node-history-host");
      const savedHost = document.getElementById("saved-node-history-host");
      const drawerHistoryHost = document.getElementById("chat-node-details-history-host");
      const nodesTitle = document.getElementById("nodes-card-title");
      if (!(nodeHistoryPanel instanceof HTMLElement)) return;
      if (!(mapDataBody instanceof HTMLElement)) return;
      if (!(networkHost instanceof HTMLElement)) return;

      const dockInDrawer = (
        typeof isChatNodeDetailsHistoryActive === "function"
        && isChatNodeDetailsHistoryActive()
        && (drawerHistoryHost instanceof HTMLElement)
      );
      const dockInSaved = !dockInDrawer && activeLayoutView === "saved" && (savedHost instanceof HTMLElement);
      const target = dockInDrawer
        ? drawerHistoryHost
        : (dockInSaved ? savedHost : mapDataBody);
      if (nodeHistoryPanel.parentElement !== target) {{
        target.appendChild(nodeHistoryPanel);
      }}

      networkHost.hidden = true;
      networkHost.classList.remove("empty");
      if (nodesTitle instanceof HTMLElement) {{
        nodesTitle.textContent = activeLayoutView === "network" ? "Network Explorer" : "Nodes";
      }}
    }}

    function syncAppsTabBar(viewName = activeLayoutView) {{
      const normalized = normalizeLayoutView(viewName);
      for (const btn of document.querySelectorAll(".apps-tab-btn")) {{
        if (!(btn instanceof HTMLButtonElement)) continue;
        const rawTarget = String(btn.dataset.appView || "").trim().toLowerCase();
        const btnView = normalizeLayoutView(rawTarget);
        const isActive = btnView === normalized;
        btn.classList.toggle("is-active", isActive);
        btn.setAttribute("aria-pressed", isActive ? "true" : "false");
      }}
    }}

    function syncFileTransferFeatureVisibility() {{
      const enabled = !!fileTransferFeatureEnabled;
      const filesTabBtn = document.querySelector('.apps-tab-btn[data-app-view="files"]');
      if (filesTabBtn instanceof HTMLButtonElement) {{
        filesTabBtn.hidden = !enabled;
        filesTabBtn.disabled = !enabled;
        filesTabBtn.setAttribute("aria-hidden", enabled ? "false" : "true");
      }}
      const filesCard = document.querySelector("#dashboard-layout .card.files");
      if (filesCard instanceof HTMLElement) {{
        filesCard.hidden = !enabled;
        filesCard.setAttribute("aria-hidden", enabled ? "false" : "true");
      }}
    }}

    function syncAppsTabBarVisibility(viewName = activeLayoutView) {{
      const tabsBar = document.getElementById("apps-tabs-bar");
      if (!(tabsBar instanceof HTMLElement)) return;
      const next = normalizeLayoutView(viewName);
      const showTabs = isAppsLayoutView(next);
      tabsBar.hidden = !showTabs;
      tabsBar.setAttribute("aria-hidden", showTabs ? "false" : "true");
    }}

    function resolveLayoutViewTargetFromEvent(ev) {{
      const rawTarget = ev && ev.target;
      const target = rawTarget instanceof Element
        ? rawTarget
        : ((rawTarget instanceof Node) ? rawTarget.parentElement : null);
      if (!(target instanceof Element)) return "";

      const railBtn = target.closest(".teams-rail .rail-btn");
      if (railBtn instanceof HTMLButtonElement) {{
        if (railBtn.disabled) return "";
        return String(railBtn.dataset.view || "chat");
      }}

      const appsBtn = target.closest(".apps-tab-btn");
      if (appsBtn instanceof HTMLButtonElement) {{
        if (appsBtn.disabled) return "";
        return String(appsBtn.dataset.appView || "chat");
      }}

      return "";
    }}

    function applyLayoutView(viewName, persist = true) {{
      const layout = document.getElementById("dashboard-layout");
      if (!(layout instanceof HTMLElement)) return;
      const shell = document.querySelector(".workspace-shell");
