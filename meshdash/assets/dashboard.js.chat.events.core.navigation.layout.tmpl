      const centerY = (Number(safeBounds.minY) + Number(safeBounds.maxY)) / 2;
      const rawWidth = Math.max(220, Number(safeBounds.maxX) - Number(safeBounds.minX));
      const rawHeight = Math.max(160, Number(safeBounds.maxY) - Number(safeBounds.minY));
