      const spanHeight = Math.max(1, Number(bounds.maxY) - Number(bounds.minY));
      const padX = Math.max(42, next.width * 0.14);
      const padY = Math.max(34, next.height * 0.14);
      const minX = Number(bounds.minX) - padX;
      const maxX = Number(bounds.maxX) + padX - next.width;
      const minY = Number(bounds.minY) - padY;
      const maxY = Number(bounds.maxY) + padY - next.height;
