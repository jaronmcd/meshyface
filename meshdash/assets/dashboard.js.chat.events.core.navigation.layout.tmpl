      const nextWidth = startViewBox.width * zoomFactor;
      const nextHeight = startViewBox.height * zoomFactor;
      const centerDx = currentCenter.clientX - networkGraphViewState.pinchStartCenterClientX;
      const centerDy = currentCenter.clientY - networkGraphViewState.pinchStartCenterClientY;
      applyNetworkGraphViewBox(svg, {{
        x: Number(startPoint.x) - (ratioX * nextWidth) - ((centerDx / rect.width) * nextWidth),
        y: Number(startPoint.y) - (ratioY * nextHeight) - ((centerDy / rect.height) * nextHeight),
        width: nextWidth,
        height: nextHeight,
      }});
      return true;
    }}

    function pushNetworkGraphRootHistory(nodeId) {{
      const clean = normalizeNodeId(nodeId || "");
      if (!isSelectableNodeId(clean)) return;
      const lastEntry = normalizeNodeId(networkGraphRootHistory[networkGraphRootHistory.length - 1] || "");
      if (lastEntry === clean) return;
      networkGraphRootHistory.push(clean);
      while (networkGraphRootHistory.length > networkGraphRootHistoryLimit) {{
        networkGraphRootHistory.shift();
      }}
    }}

    function resolveNetworkGraphHomeNodeId(state = latestState, nodeMap = null) {{
      const clean = normalizeNodeId(resolveLocalNodeId(state || latestState || {{}}) || "");
      if (!isSelectableNodeId(clean)) return "";
      if (nodeMap instanceof Map && nodeMap.size && !nodeMap.has(clean)) return "";
      return clean;
    }}

    function renderNetworkGraphNavigationControls(state = latestState, nodeMap = null, rootId = "") {{
      const backBtn = document.getElementById("network-graph-back-btn");
      const homeBtn = document.getElementById("network-graph-home-btn");
      const safeMap = nodeMap instanceof Map ? nodeMap : new Map();

      if (backBtn instanceof HTMLButtonElement) {{
        let previousId = "";
        for (let index = networkGraphRootHistory.length - 1; index >= 0; index -= 1) {{
          const candidateId = normalizeNodeId(networkGraphRootHistory[index] || "");
          if (!isSelectableNodeId(candidateId)) continue;
          if (safeMap.size && !safeMap.has(candidateId)) continue;
          previousId = candidateId;
          break;
        }}
        backBtn.disabled = !previousId;
        backBtn.setAttribute("aria-disabled", previousId ? "false" : "true");
        backBtn.title = previousId
          ? `Go back to ${{networkGraphNodeDisplayName(previousId, safeMap)}}`
          : "No earlier links focus yet";
