            </article>`;
          }}).join("")
          : `<div class="network-diagnostics-empty-copy">No malformed payloads to show for this sender.</div>`;
      }}

      if (layoutHost instanceof HTMLElement) {{
        layoutHost.hidden = totalPackets < 1;
      }}
      if (emptyHost instanceof HTMLElement) {{
        emptyHost.hidden = totalPackets > 0;
        emptyHost.textContent = "No malformed text payloads recorded in this window.";
