      if (changed) {{
        // Node-list root changes should rebuild from scratch so we do not keep
        // stale scene/layout state from the previous root.
        networkGraphViewState.renderSourceSignature = "";
        networkGraphViewState.layoutSourceSignature = "";
        networkGraphViewState.cachedNodeMap = null;
        networkGraphViewState.cachedCombinedEdges = null;
        networkGraphViewState.cachedLayout = null;
        networkGraphViewState.lastSceneStructureSignature = "";
        networkGraphViewState.renderedPositions = new Map();
        networkGraphViewState.renderedLayoutSnapshot = null;
        networkGraphViewState.forceCenteredFitOnce = true;
        networkGraphViewState.skipSceneAnimationOnce = true;
        networkGraphViewState.pendingEntryViewportSync = true;
      }}
      return true;
    }}

    function navigateNetworkGraphBack() {{
      const liveNodes = (latestState && Array.isArray(latestState.nodes)) ? latestState.nodes : [];
      const historyCapsRaw = (latestState && latestState.history_caps && typeof latestState.history_caps === "object")
        ? latestState.history_caps
        : {{}};
      const historyCaps = networkGraphHistoryCapsForMode(historyCapsRaw, networkGraphEdgeMode);
      const traffic = (latestState && latestState.traffic && typeof latestState.traffic === "object")
        ? latestState.traffic
        : {{}};
      const rawEdges = networkGraphRawEdgesForMode(
        Array.isArray(traffic.edges) ? traffic.edges : [],
        networkGraphEdgeMode
      );
      const filteredRawEdges = filterNetworkGraphRawEdgesByMode(rawEdges, networkGraphEdgeMode);
      const searchQuery = (typeof globalNodeSearchQuery === "function")
        ? globalNodeSearchQuery()
        : "";
      const nodeMap = buildNetworkGraphNodeMap(liveNodes, historyCaps, filteredRawEdges, {{
        includeAllLiveNodes: normalizeNetworkGraphEdgeMode(networkGraphEdgeMode) !== "live",
        pinnedNodeIds: [
          networkGraphRootNodeId,
          selectedNodeId,
          resolveLocalNodeId(latestState),
        ],
        historyMode: networkGraphEdgeMode,
        searchQuery,
      }});
      while (networkGraphRootHistory.length) {{
        const previousId = normalizeNodeId(networkGraphRootHistory.pop() || "");
        if (!isSelectableNodeId(previousId)) continue;
        if (nodeMap.size && !nodeMap.has(previousId)) continue;
        focusNetworkGraphNode(previousId, {{ pushHistory: false, focusSelection: true }});
        return true;
      }}
      renderNetworkGraphNavigationControls(latestState, nodeMap, networkGraphRootNodeId);
      return false;
    }}

    function resolveNetworkGraphNodeIdFromTarget(target) {{
      if (!(target instanceof Element)) return "";
      const nodeGroup = target.closest("[data-network-graph-node-id]");
      if (!(nodeGroup instanceof Element)) return "";
      return normalizeNodeId(nodeGroup.getAttribute("data-network-graph-node-id") || "");
    }}

    function resolveNetworkGraphTagRouteKeyFromTarget(target) {{
      if (!(target instanceof Element)) return "";
      const routeEl = target.closest("[data-network-graph-tag-route-key]");
      if (!(routeEl instanceof Element)) return "";
      return String(routeEl.getAttribute("data-network-graph-tag-route-key") || "");
    }}

    function bindNetworkGraphInteractions(svg) {{
      if (!(svg instanceof SVGElement) || svg.dataset.bound === "1") return;
      svg.dataset.bound = "1";

      svg.addEventListener("pointerdown", (event) => {{
        if (event.pointerType === "mouse" && event.button !== 0) return;
        const activePointers = getNetworkGraphActivePointers();
        activePointers.set(event.pointerId, {{
          clientX: event.clientX,
          clientY: event.clientY,
        }});
        if (event.pointerType !== "mouse" && activePointers.size >= 2) {{
          beginNetworkGraphPinch(svg);
          event.preventDefault();
          return;
        }}
        if (networkGraphViewState.pointerId !== null) return;
        cancelNetworkGraphViewAnimation();
        cancelNetworkGraphSceneAnimation();
        networkGraphViewState.pendingFocusTransition = null;
        networkGraphViewState.pointerId = event.pointerId;
        networkGraphViewState.pointerClientX = event.clientX;
        networkGraphViewState.pointerClientY = event.clientY;
        networkGraphViewState.pointerViewBox = cloneNetworkGraphViewBox(networkGraphViewState.viewBox);
        networkGraphViewState.pointerDownNodeId = resolveNetworkGraphNodeIdFromTarget(event.target);
        networkGraphViewState.captureActive = false;
        networkGraphViewState.dragging = false;
      }});

      svg.addEventListener("pointermove", (event) => {{
        const activePointers = getNetworkGraphActivePointers();
        if (activePointers.has(event.pointerId)) {{
          activePointers.set(event.pointerId, {{
            clientX: event.clientX,
            clientY: event.clientY,
          }});
        }}
        if (networkGraphViewState.pinching) {{
          if (updateNetworkGraphPinch(svg)) {{
            event.preventDefault();
          }}
          return;
        }}
        if (networkGraphViewState.pointerId !== event.pointerId) return;
        const startViewBox = networkGraphViewState.pointerViewBox;
        if (!startViewBox) return;
        const rect = svg.getBoundingClientRect();
        if (!(rect.width > 0) || !(rect.height > 0)) return;
        const dx = event.clientX - networkGraphViewState.pointerClientX;
        const dy = event.clientY - networkGraphViewState.pointerClientY;
        if (!networkGraphViewState.dragging && Math.hypot(dx, dy) < 5) {{
          return;
        }}
        if (!networkGraphViewState.dragging) {{
          networkGraphViewState.dragging = true;
          if (!networkGraphViewState.captureActive) {{
            try {{
              svg.setPointerCapture(event.pointerId);
              networkGraphViewState.captureActive = true;
            }} catch (_err) {{
            }}
          }}
        }}
        if (svg.parentElement instanceof HTMLElement) {{
          svg.parentElement.classList.add("is-panning");
        }}
        applyNetworkGraphViewBox(svg, {{
          x: startViewBox.x - ((dx / rect.width) * startViewBox.width),
          y: startViewBox.y - ((dy / rect.height) * startViewBox.height),
          width: startViewBox.width,
          height: startViewBox.height,
        }});
        event.preventDefault();
      }}, {{ passive: false }});

      const finishPan = (event) => {{
        const activePointers = getNetworkGraphActivePointers();
        const wasPinching = !!networkGraphViewState.pinching;
        if (activePointers.has(event.pointerId)) {{
          activePointers.delete(event.pointerId);
        }}
        if (wasPinching) {{
          if (activePointers.size >= 2) {{
            beginNetworkGraphPinch(svg);
          }} else {{
            stopNetworkGraphPan(svg);
          }}
          suppressNextNetworkGraphClick();
          event.preventDefault();
          return;
        }}
        if (networkGraphViewState.pointerId !== event.pointerId) return;
        const wasDragging = networkGraphViewState.dragging;
        const releasedNodeId = resolveNetworkGraphNodeIdFromTarget(event.target);
        const nodeId = wasDragging
          ? ""
          : (releasedNodeId || networkGraphViewState.pointerDownNodeId || "");
        stopNetworkGraphPan(svg);
        if (wasDragging) {{
          suppressNextNetworkGraphClick();
          return;
        }}
        if (isSelectableNodeId(nodeId)) {{
          suppressNextNetworkGraphClick();
          if (
            typeof selectNode === "function"
            && normalizeNodeId(selectedNodeId || "") === nodeId
          ) {{
            selectNode(nodeId, true, false);
            return;
          }}
          focusNetworkGraphNode(nodeId, {{ pushHistory: true, focusSelection: true }});
        }}
      }};
      svg.addEventListener("pointerup", finishPan);
      svg.addEventListener("pointercancel", finishPan);
      svg.addEventListener("lostpointercapture", () => {{
        stopNetworkGraphPan(svg);
      }});

      svg.addEventListener("click", (event) => {{
        if (networkGraphViewState.suppressClick) return;
        const routeKey = resolveNetworkGraphTagRouteKeyFromTarget(event.target);
        if (!routeKey) return;
        event.preventDefault();
        event.stopPropagation();
        networkGraphViewState.selectedTagRouteKey = networkGraphViewState.selectedTagRouteKey === routeKey
          ? ""
          : routeKey;
        syncNetworkGraphSelectedTagRoute(svg);
      }});

      svg.addEventListener("pointerover", (event) => {{
        hydrateNetworkGraphLazyTitle(event.target);
      }});

      svg.addEventListener("focusin", (event) => {{
        hydrateNetworkGraphLazyTitle(event.target);
      }});

      svg.addEventListener("wheel", (event) => {{
        const pointer = resolveNetworkGraphPointerPosition(svg, event.clientX, event.clientY);
        if (!pointer) return;
        cancelNetworkGraphViewAnimation();
        cancelNetworkGraphSceneAnimation();
        networkGraphViewState.pendingFocusTransition = null;
        const current = cloneNetworkGraphViewBox(networkGraphViewState.viewBox);
        const delta = Number(event.deltaY) || 0;
        if (!Number.isFinite(delta) || delta === 0) return;
        const stepCount = Math.max(1, Math.min(4, Math.round(Math.abs(delta) / 120) || 1));
        const zoomFactor = Math.pow(delta > 0 ? 1.12 : 0.88, stepCount);
        const ratioX = (pointer.x - current.x) / current.width;
        const ratioY = (pointer.y - current.y) / current.height;
        applyNetworkGraphViewBox(svg, {{
          x: pointer.x - (ratioX * current.width * zoomFactor),
          y: pointer.y - (ratioY * current.height * zoomFactor),
          width: current.width * zoomFactor,
          height: current.height * zoomFactor,
        }});
        event.preventDefault();
      }}, {{ passive: false }});

    }}

    function networkGraphNodeHasTag(nodeId) {{
      const clean = normalizeNodeId(nodeId || "");
      if (!clean) return false;
      try {{
        const tagEntry = networkGraphVisibleTagEntryForNode(clean);
        return !!(tagEntry && tagEntry.preset);
      }} catch (_err) {{
        return false;
      }}
    }}

    function networkGraphNodeHasVisualIcon(nodeId, nodeMap) {{
      const clean = normalizeNodeId(nodeId || "");
      if (!clean || typeof nodeVisualEmojiForNode !== "function") return false;
      const node = nodeMap instanceof Map ? (nodeMap.get(clean) || null) : null;
      try {{
        return !!networkGraphVisibleNodeEmojiForNode(clean, node);
      }} catch (_err) {{
        return false;
      }}
    }}

    function networkGraphNodeDisplayPriority(nodeId, nodeMap) {{
      if (networkGraphNodeHasTag(nodeId)) return 2;
      return networkGraphNodeHasVisualIcon(nodeId, nodeMap) ? 1 : 0;
    }}

    function networkGraphNodeGroupDisplayPriority(nodeIds, nodeMap) {{
      const values = Array.isArray(nodeIds) ? nodeIds : [];
      let best = 0;
      for (const nodeId of values) {{
        best = Math.max(best, networkGraphNodeDisplayPriority(nodeId, nodeMap));
        if (best >= 2) break;
      }}
      return best;
    }}

    function compareNetworkGraphNodeIds(a, b, degreeMeta, nodeMap) {{
      const priorityDelta = networkGraphNodeDisplayPriority(b, nodeMap) - networkGraphNodeDisplayPriority(a, nodeMap);
      if (priorityDelta !== 0) return priorityDelta;
      const aMeta = degreeMeta.get(a) || {{ degree: 0, weight: 0 }};
      const bMeta = degreeMeta.get(b) || {{ degree: 0, weight: 0 }};
      if (bMeta.degree !== aMeta.degree) return bMeta.degree - aMeta.degree;
      if (bMeta.weight !== aMeta.weight) return bMeta.weight - aMeta.weight;
      const aName = networkGraphNodeDisplayName(a, nodeMap).toLowerCase();
      const bName = networkGraphNodeDisplayName(b, nodeMap).toLowerCase();
      if (aName !== bName) return aName < bName ? -1 : 1;
      return a < b ? -1 : (a > b ? 1 : 0);
    }}

    function networkGraphAverageParentOrder(nodeId, parentHintsByNodeId, layerOrderIndexByNodeId) {{
      const parents = Array.isArray(parentHintsByNodeId && parentHintsByNodeId.get(nodeId))
        ? parentHintsByNodeId.get(nodeId)
        : [];
      if (!parents.length) return Number.POSITIVE_INFINITY;
      let total = 0;
      let count = 0;
      for (const parentId of parents) {{
        const order = Number(layerOrderIndexByNodeId && layerOrderIndexByNodeId.get(parentId));
        if (!Number.isFinite(order)) continue;
        total += order;
        count += 1;
      }}
      return count > 0 ? (total / count) : Number.POSITIVE_INFINITY;
    }}

    function compareNetworkGraphLayerIds(
      a,
      b,
      layer,
      parentHintsByNodeId,
      layerOrderIndexByNodeId,
      degreeMeta,
      nodeMap
    ) {{
      const safeLayer = Math.max(0, Math.trunc(Number(layer) || 0));
      if (safeLayer > 1) {{
        const aParentOrder = networkGraphAverageParentOrder(a, parentHintsByNodeId, layerOrderIndexByNodeId);
        const bParentOrder = networkGraphAverageParentOrder(b, parentHintsByNodeId, layerOrderIndexByNodeId);
        if (Number.isFinite(aParentOrder) || Number.isFinite(bParentOrder)) {{
          if (!Number.isFinite(aParentOrder)) return 1;
          if (!Number.isFinite(bParentOrder)) return -1;
          if (Math.abs(aParentOrder - bParentOrder) > 0.0001) return aParentOrder - bParentOrder;
        }}
      }}
      return compareNetworkGraphNodeIds(a, b, degreeMeta, nodeMap);
    }}

    function buildNetworkGraphPlaceholderNode(nodeId, caps = null) {{
      const clean = normalizeNodeId(nodeId || "");
      const safeCaps = (caps && typeof caps === "object") ? caps : null;
      const lastSeenRaw = Number(safeCaps && safeCaps.last_seen_unix);
      const lastSeenUnix = Number.isFinite(lastSeenRaw) && lastSeenRaw > 0
        ? Math.trunc(lastSeenRaw)
        : 0;
      const lastPositionRaw = Number(safeCaps && safeCaps.last_position_unix);
      const lastPositionUnix = Number.isFinite(lastPositionRaw) && lastPositionRaw > 0
        ? Math.trunc(lastPositionRaw)
        : null;
      const lastHopsRaw = Number(safeCaps && safeCaps.last_hops);
      const lastHops = Number.isFinite(lastHopsRaw)
        ? Math.max(0, Math.trunc(lastHopsRaw))
        : null;
      return {{
        id: clean,
        last_heard_unix: lastSeenUnix,
        last_heard: formatLocalChatTime(lastSeenUnix, String((safeCaps && safeCaps.last_seen) || ""), Math.floor(Date.now() / 1000)),
        has_position: !!(safeCaps && safeCaps.has_position),
        last_position_unix: lastPositionUnix,
        last_position_time: formatLocalChatTime(lastPositionUnix, String((safeCaps && safeCaps.last_position_time) || ""), Math.floor(Date.now() / 1000)),
        hops_away: lastHops,
        short_name: String((safeCaps && safeCaps.last_short_name) || "").trim() || undefined,
        long_name: String((safeCaps && safeCaps.last_long_name) || "").trim() || undefined,
        is_graph_placeholder: true,
      }};
    }}

    function buildNetworkGraphNodeMap(nodes, historyCapsRaw, rawEdges, options = {{}}) {{
      const liveNodeById = new Map();
      for (const node of (Array.isArray(nodes) ? nodes : [])) {{
        const nodeId = normalizeNodeId(node && node.id);
        if (!isSelectableNodeId(nodeId) || liveNodeById.has(nodeId)) continue;
        liveNodeById.set(nodeId, node);
      }}
      const nodeMap = new Map();
      const includeAllLiveNodes = !(options && options.includeAllLiveNodes === false);
      if (includeAllLiveNodes) {{
        for (const [nodeId, node] of liveNodeById.entries()) {{
          nodeMap.set(nodeId, node);
        }}
      }}
      const pinnedNodeIds = Array.isArray(options && options.pinnedNodeIds)
        ? options.pinnedNodeIds
          .map((nodeId) => normalizeNodeId(nodeId))
          .filter((nodeId) => isSelectableNodeId(nodeId))
        : [];
      const requestedNodeIds = Array.isArray(options && options.requestedNodeIds)
        ? options.requestedNodeIds
          .map((nodeId) => normalizeNodeId(nodeId))
          .filter((nodeId) => isSelectableNodeId(nodeId))
        : [];

      const historyCapsById = new Map(
        Object.entries((historyCapsRaw && typeof historyCapsRaw === "object") ? historyCapsRaw : {{}})
          .map(([rawNodeId, caps]) => [normalizeNodeId(rawNodeId), caps])
          .filter(([nodeId, caps]) => isSelectableNodeId(nodeId) && caps && typeof caps === "object")
      );
      const searchQuery = normalizeSearchQuery(
        options && typeof options === "object" ? (options.searchQuery || "") : ""
      );
      const historyMode = (
        options
        && typeof options === "object"
        && Object.prototype.hasOwnProperty.call(options, "historyMode")
      )
        ? options.historyMode
        : networkGraphEdgeMode;

      const ensureNode = (nodeId) => {{
        const clean = normalizeNodeId(nodeId || "");
        if (!isSelectableNodeId(clean) || nodeMap.has(clean)) return;
        if (liveNodeById.has(clean)) {{
          nodeMap.set(clean, liveNodeById.get(clean));
          return;
        }}
        nodeMap.set(clean, buildNetworkGraphPlaceholderNode(clean, historyCapsById.get(clean) || null));
      }};

      for (const nodeId of pinnedNodeIds) {{
        ensureNode(nodeId);
      }}
      for (const nodeId of requestedNodeIds) {{
        ensureNode(nodeId);
      }}
      if (searchQuery) {{
        const queryMatches = networkGraphHistorySearchNodeIds(historyCapsById, searchQuery, historyMode);
        for (const nodeId of queryMatches) {{
          ensureNode(nodeId);
        }}
      }}

      for (const edge of (Array.isArray(rawEdges) ? rawEdges : [])) {{
        const fromId = normalizeNodeId(edge && edge.from);
        const toId = normalizeNodeId(edge && edge.to);
        ensureNode(fromId);
        ensureNode(toId);
      }}

      return nodeMap;
    }}

    function networkGraphHistoryEdgeLimit(modeName) {{
      const mode = normalizeNetworkGraphEdgeMode(modeName);
      if (mode === "max") return 10000;
      if (mode === "30d" || mode === "14d") return 1800;
      return 1200;
    }}

    function networkGraphHistoryEdgeCacheTtlMs() {{
      const pollMs = Number(refreshMs) || 0;
      return Math.max(15000, pollMs * 4);
    }}

    function networkGraphHistoryEdgeCacheIsFresh(modeName) {{
      const mode = normalizeNetworkGraphEdgeMode(modeName);
      if (!networkGraphHistoryEdgeCache.has(mode)) return false;
      const fetchedAtMs = Number(networkGraphHistoryEdgeFetchedAtMs.get(mode) || 0);
      if (!Number.isFinite(fetchedAtMs) || fetchedAtMs <= 0) return false;
      return (Date.now() - fetchedAtMs) < networkGraphHistoryEdgeCacheTtlMs();
    }}

    function invalidateNetworkGraphRenderCache() {{
      networkGraphViewState.renderSourceSignature = "";
      networkGraphViewState.layoutSourceSignature = "";
      networkGraphViewState.cachedNodeMap = null;
      networkGraphViewState.cachedCombinedEdges = null;
      networkGraphViewState.cachedLayout = null;
      networkGraphViewState.lastSceneStructureSignature = "";
      networkGraphViewState.lastSceneDataSignature = "";
      networkGraphViewState.renderedPositions = new Map();
      networkGraphViewState.renderedLayoutSnapshot = null;
    }}

    function ensureNetworkGraphHistoryEdges(modeName, options = {{}}) {{
      const mode = normalizeNetworkGraphEdgeMode(modeName);
      const force = !!(options && options.force);
      if (!networkGraphEdgeModeUsesHistoryFetch(mode)) return;
      if (networkGraphHistoryEdgeRequests.has(mode)) return;
      if (!force && networkGraphHistoryEdgeCacheIsFresh(mode)) return;

      const params = new URLSearchParams();
      params.set("window", mode);
      params.set("limit", String(networkGraphHistoryEdgeLimit(mode)));
      const request = fetch(`/api/history/links?${{params.toString()}}`, {{ cache: "no-store" }})
        .then((resp) => resp.ok ? resp.json() : Promise.reject(new Error(`HTTP ${{resp.status}}`)))
        .then((payload) => {{
          const edges = (payload && Array.isArray(payload.edges)) ? payload.edges : [];
          const historyCaps = (payload && payload.history_caps && typeof payload.history_caps === "object")
            ? payload.history_caps
            : {{}};
          networkGraphHistoryEdgeCache.set(mode, edges);
          networkGraphHistoryCapsCache.set(mode, historyCaps);
          networkGraphHistoryEdgeFetchedAtMs.set(mode, Date.now());
          invalidateNetworkGraphRenderCache();
          if (
            activeLayoutView === "network"
            && activeNetworkSubview === "graph"
            && normalizeNetworkGraphEdgeMode(networkGraphEdgeMode) === mode
          ) {{
            if (networkSubviewUsesMap(activeNetworkSubview)) {{
              lastMapSignature = "";
              lastMapGraphSignature = "";
              lastMapRenderMode = "";
              if (latestState && typeof renderMap === "function") {{
                renderMap(latestState.nodes || [], ((latestState.traffic || {{}}).edges || []), null);
              }}
            }} else if (typeof renderNetworkGraphView === "function") {{
              renderNetworkGraphView(latestState);
            }}
          }}
          if (
            activeLayoutView === "network"
            && activeNetworkSubview === "routes"
            && normalizeNetworkGraphEdgeMode(networkRoutesWindow) === mode
            && typeof renderNetworkRoutes === "function"
          ) {{
            renderNetworkRoutes(latestState);
          }}
        }})
        .catch((_err) => {{
          networkGraphHistoryEdgeCache.set(mode, []);
          networkGraphHistoryCapsCache.set(mode, {{}});
          networkGraphHistoryEdgeFetchedAtMs.set(mode, Date.now());
          invalidateNetworkGraphRenderCache();
          if (
            activeLayoutView === "network"
            && activeNetworkSubview === "graph"
            && normalizeNetworkGraphEdgeMode(networkGraphEdgeMode) === mode
          ) {{
            if (networkSubviewUsesMap(activeNetworkSubview)) {{
              lastMapSignature = "";
              lastMapGraphSignature = "";
              lastMapRenderMode = "";
              if (latestState && typeof renderMap === "function") {{
                renderMap(latestState.nodes || [], ((latestState.traffic || {{}}).edges || []), null);
              }}
            }} else if (typeof renderNetworkGraphView === "function") {{
              renderNetworkGraphView(latestState);
            }}
          }}
          if (
            activeLayoutView === "network"
            && activeNetworkSubview === "routes"
            && normalizeNetworkGraphEdgeMode(networkRoutesWindow) === mode
            && typeof renderNetworkRoutes === "function"
          ) {{
            renderNetworkRoutes(latestState);
          }}
        }})
        .finally(() => {{
          networkGraphHistoryEdgeRequests.delete(mode);
        }});
      networkGraphHistoryEdgeRequests.set(mode, request);
    }}

    function networkGraphRawEdgesForMode(rawEdges, modeName = networkGraphEdgeMode) {{
      const mode = normalizeNetworkGraphEdgeMode(modeName);
      const safeEdges = Array.isArray(rawEdges) ? rawEdges : [];
      if (!networkGraphEdgeModeUsesHistoryFetch(mode)) return safeEdges;
      ensureNetworkGraphHistoryEdges(mode);
      return networkGraphHistoryEdgeCache.has(mode)
        ? (networkGraphHistoryEdgeCache.get(mode) || [])
        : safeEdges;
    }}

    function networkGraphHistoryEdgesLoading(modeName = networkGraphEdgeMode) {{
      const mode = normalizeNetworkGraphEdgeMode(modeName);
      return !!(
        networkGraphEdgeModeUsesHistoryFetch(mode)
        && networkGraphHistoryEdgeRequests.has(mode)
        && !networkGraphHistoryEdgeCache.has(mode)
      );
    }}

    function networkGraphHistoryCapsForMode(historyCapsRaw, modeName = networkGraphEdgeMode) {{
      const mode = normalizeNetworkGraphEdgeMode(modeName);
      const baseCaps = (historyCapsRaw && typeof historyCapsRaw === "object") ? historyCapsRaw : {{}};
      if (!networkGraphEdgeModeUsesHistoryFetch(mode) || !networkGraphHistoryCapsCache.has(mode)) {{
        return baseCaps;
      }}
      const extraCaps = networkGraphHistoryCapsCache.get(mode);
      if (!extraCaps || typeof extraCaps !== "object") return baseCaps;
      return Object.assign({{}}, extraCaps, baseCaps);
    }}

    function networkGraphHistoryModeMaxAgeSeconds(modeName = networkGraphEdgeMode) {{
      const mode = normalizeNetworkGraphEdgeMode(modeName);
      if (mode === "live") return 2 * 60 * 60;
      if (mode === "6h") return 6 * 60 * 60;
      if (mode === "12h") return 12 * 60 * 60;
      if (mode === "24h") return 24 * 60 * 60;
      if (mode === "72h") return 72 * 60 * 60;
      if (mode === "7d") return 7 * 24 * 60 * 60;
      if (mode === "14d") return 14 * 24 * 60 * 60;
      if (mode === "30d") return 30 * 24 * 60 * 60;
      return Number.POSITIVE_INFINITY;
    }}

    function networkGraphHistorySearchNodeIds(historyCapsRaw, searchQuery, modeName = networkGraphEdgeMode, options = {{}}) {{
      const query = normalizeSearchQuery(searchQuery);
      if (!query) return [];
      const opts = (options && typeof options === "object") ? options : {{}};
      const nowUnix = Number.isFinite(Number(opts.nowUnix))
        ? Math.trunc(Number(opts.nowUnix))
        : Math.floor(Date.now() / 1000);
      const maxAgeSeconds = networkGraphHistoryModeMaxAgeSeconds(modeName);
      const entries = historyCapsRaw instanceof Map
        ? Array.from(historyCapsRaw.entries())
        : Object.entries((historyCapsRaw && typeof historyCapsRaw === "object") ? historyCapsRaw : {{}});
      const out = [];
      for (const [rawNodeId, rawCaps] of entries) {{
        const nodeId = normalizeNodeId(rawNodeId || "");
        if (!isSelectableNodeId(nodeId)) continue;
        const caps = (rawCaps && typeof rawCaps === "object") ? rawCaps : null;
        const lastSeenUnixRaw = Number(caps && caps.last_seen_unix);
        const lastSeenUnix = Number.isFinite(lastSeenUnixRaw) && lastSeenUnixRaw > 0
          ? Math.trunc(lastSeenUnixRaw)
          : 0;
        if (Number.isFinite(maxAgeSeconds)) {{
          if (lastSeenUnix <= 0) continue;
          if ((nowUnix - lastSeenUnix) > maxAgeSeconds) continue;
        }}
        const longName = String(caps && caps.last_long_name || "").trim();
        const shortName = String(caps && caps.last_short_name || "").trim();
        const displayName = longName || shortName || nodeId;
        const matched = (typeof matchesIdOrNameQuery === "function")
          ? matchesIdOrNameQuery(nodeId, displayName, query, {{
              node: null,
              extraValues: [longName, shortName],
              includeNotes: false,
            }})
          : (`${{nodeId}} ${{displayName}} ${{longName}} ${{shortName}}`).toLowerCase().includes(query);
        if (!matched) continue;
        out.push(nodeId);
      }}
      out.sort((left, right) => left.localeCompare(right));
      return out;
    }}

    function filterNetworkGraphRawEdgesByMode(rawEdges, mode = networkGraphEdgeMode) {{
      const safeEdges = Array.isArray(rawEdges) ? rawEdges : [];
      const edgeMode = normalizeNetworkGraphEdgeMode(mode);
      if (edgeMode !== "live") return safeEdges;
      return safeEdges.filter((edge) => {{
        const sessionCount = Number(edge && (edge.session_count ?? edge.count ?? 0));
        return Number.isFinite(sessionCount) && sessionCount > 0;
      }});
    }}

    function combineNetworkGraphEdges(rawEdges, nodeMap, options = {{}}) {{
      const edgeMode = normalizeNetworkGraphEdgeMode(options && options.mode);
      const useSessionWeight = edgeMode === "live";
      const buckets = new Map();
      for (const edge of (rawEdges || [])) {{
        const fromId = normalizeNodeId(edge && edge.from);
        const toId = normalizeNodeId(edge && edge.to);
        if (!isSelectableNodeId(fromId) || !isSelectableNodeId(toId) || fromId === toId) continue;
        if (!(nodeMap instanceof Map) || !nodeMap.has(fromId) || !nodeMap.has(toId)) continue;
        const lifetimeCount = Number(edge && (edge.lifetime_count ?? edge.count ?? 0));
        const sessionCount = Number(edge && (edge.session_count ?? edge.count ?? 0));
        const parsedLifetime = Number.isFinite(lifetimeCount) ? Math.max(0, lifetimeCount) : 0;
        const parsedSession = Number.isFinite(sessionCount) ? Math.max(0, sessionCount) : 0;
        const parsedWeight = useSessionWeight ? parsedSession : parsedLifetime;
        if (parsedWeight <= 0) continue;
        const a = fromId < toId ? fromId : toId;
        const b = fromId < toId ? toId : fromId;
        const key = `${{a}}::${{b}}`;
        if (!buckets.has(key)) {{
          buckets.set(key, {{
            key,
            a,
            b,
            weight: 0,
            sessionWeight: 0,
            isReal: false,
            lastSeenUnix: 0,
            lastSeenLabel: "",
            lastHops: null,
            avgHopsWeight: 0,
            avgHopsSamples: 0,
            avgSnrWeight: 0,
            avgSnrSamples: 0,
            snrMin: null,
            snrMax: null,
            avgRssiWeight: 0,
            avgRssiSamples: 0,
            rssiMin: null,
            rssiMax: null,
            directionCount: 0,
          }});
        }}
        const bucket = buckets.get(key);
        if (!bucket) continue;
        bucket.weight += parsedWeight;
        bucket.sessionWeight += parsedSession;
        bucket.isReal = bucket.isReal || !!(edge && edge.is_real);
        bucket.directionCount += 1;
        const lastSeenUnix = (typeof parseEdgeLastSeenUnix === "function")
          ? parseEdgeLastSeenUnix(edge)
          : NaN;
        if (Number.isFinite(lastSeenUnix) && lastSeenUnix > bucket.lastSeenUnix) {{
          bucket.lastSeenUnix = lastSeenUnix;
          bucket.lastSeenLabel = (typeof edgeRxLabel === "function")
            ? String(edgeRxLabel(edge, "last", "") || "")
            : String((edge && edge.last_rx_time) || "");
          const lastHops = Number(edge && edge.last_hops);
          bucket.lastHops = Number.isFinite(lastHops) ? lastHops : bucket.lastHops;
        }}
        const avgHops = Number(edge && edge.avg_hops);
        const hopsSamples = Number(edge && edge.hops_samples);
        if (Number.isFinite(avgHops)) {{
          const sampleWeight = (Number.isFinite(hopsSamples) && hopsSamples > 0) ? hopsSamples : 1;
          bucket.avgHopsWeight += avgHops * sampleWeight;
          bucket.avgHopsSamples += sampleWeight;
        }}
        const avgSnr = Number(edge && edge.avg_snr);
        const snrSamples = Number(edge && edge.snr_samples);
        if (Number.isFinite(avgSnr)) {{
          const sampleWeight = (Number.isFinite(snrSamples) && snrSamples > 0) ? snrSamples : 1;
          bucket.avgSnrWeight += avgSnr * sampleWeight;
          bucket.avgSnrSamples += sampleWeight;
        }}
        const snrMin = Number(edge && edge.snr_min);
        const snrMax = Number(edge && edge.snr_max);
        if (Number.isFinite(snrMin)) {{
          bucket.snrMin = Number.isFinite(bucket.snrMin) ? Math.min(bucket.snrMin, snrMin) : snrMin;
        }}
        if (Number.isFinite(snrMax)) {{
          bucket.snrMax = Number.isFinite(bucket.snrMax) ? Math.max(bucket.snrMax, snrMax) : snrMax;
        }}
        const avgRssi = Number(edge && edge.avg_rssi);
        const rssiSamples = Number(edge && edge.rssi_samples);
        if (Number.isFinite(avgRssi)) {{
          const sampleWeight = (Number.isFinite(rssiSamples) && rssiSamples > 0) ? rssiSamples : 1;
          bucket.avgRssiWeight += avgRssi * sampleWeight;
          bucket.avgRssiSamples += sampleWeight;
        }}
        const rssiMin = Number(edge && edge.rssi_min);
        const rssiMax = Number(edge && edge.rssi_max);
        if (Number.isFinite(rssiMin)) {{
          bucket.rssiMin = Number.isFinite(bucket.rssiMin) ? Math.min(bucket.rssiMin, rssiMin) : rssiMin;
        }}
        if (Number.isFinite(rssiMax)) {{
          bucket.rssiMax = Number.isFinite(bucket.rssiMax) ? Math.max(bucket.rssiMax, rssiMax) : rssiMax;
        }}
      }}
      const combined = Array.from(buckets.values()).map((bucket) => ({{
        ...bucket,
        avgHops: bucket.avgHopsSamples > 0
          ? Math.round((bucket.avgHopsWeight / bucket.avgHopsSamples) * 100) / 100
          : null,
        avgSnr: bucket.avgSnrSamples > 0
          ? Math.round((bucket.avgSnrWeight / bucket.avgSnrSamples) * 100) / 100
          : null,
        snrSamples: bucket.avgSnrSamples,
        avgRssi: bucket.avgRssiSamples > 0
          ? Math.round((bucket.avgRssiWeight / bucket.avgRssiSamples) * 100) / 100
          : null,
        rssiSamples: bucket.avgRssiSamples,
      }}));
      combined.sort((a, b) => (
        (b.weight - a.weight)
        || (b.directionCount - a.directionCount)
        || (a.a < b.a ? -1 : (a.a > b.a ? 1 : 0))
        || (a.b < b.b ? -1 : (a.b > b.b ? 1 : 0))
      ));
      return combined;
    }}

    function buildNetworkGraphAdjacency(nodeMap, edges) {{
      const adjacency = new Map();
      for (const nodeId of (nodeMap instanceof Map ? nodeMap.keys() : [])) {{
        adjacency.set(nodeId, new Map());
      }}
      for (const edge of (edges || [])) {{
        if (!edge || !adjacency.has(edge.a) || !adjacency.has(edge.b)) continue;
        adjacency.get(edge.a).set(edge.b, edge);
        adjacency.get(edge.b).set(edge.a, edge);
      }}
      return adjacency;
    }}

    function compareNetworkGraphComponents(componentA, componentB, degreeMeta, nodeMap) {{
      const a = (componentA && typeof componentA === "object") ? componentA : null;
      const b = (componentB && typeof componentB === "object") ? componentB : null;
      if (!a && !b) return 0;
      if (!a) return 1;
      if (!b) return -1;
      const edgePresenceDelta = Number((b.edgeCount || 0) > 0) - Number((a.edgeCount || 0) > 0);
      if (edgePresenceDelta !== 0) return edgePresenceDelta;
      const nodeDelta = Math.max(0, Number(b.nodeCount) || 0) - Math.max(0, Number(a.nodeCount) || 0);
      if (nodeDelta !== 0) return nodeDelta;
      const edgeDelta = Math.max(0, Number(b.edgeCount) || 0) - Math.max(0, Number(a.edgeCount) || 0);
      if (edgeDelta !== 0) return edgeDelta;
      const realDelta = Math.max(0, Number(b.realEdgeCount) || 0) - Math.max(0, Number(a.realEdgeCount) || 0);
      if (realDelta !== 0) return realDelta;
      const weightDelta = Math.max(0, Number(b.weight) || 0) - Math.max(0, Number(a.weight) || 0);
      if (weightDelta !== 0) return weightDelta;
      return compareNetworkGraphNodeIds(a.rootId || "", b.rootId || "", degreeMeta, nodeMap);
    }}

    function buildNetworkGraphComponentMeta(nodeMap, adjacency, degreeMeta) {{
      const safeMap = nodeMap instanceof Map ? nodeMap : new Map();
      const componentByNodeId = new Map();
      const seen = new Set();
      let bestComponent = null;

      const chooseComponentRoot = (nodeIds) => {{
        const ids = Array.isArray(nodeIds) ? nodeIds.slice() : [];
        ids.sort((a, b) => compareNetworkGraphNodeIds(a, b, degreeMeta, safeMap));
        return ids[0] || "";
      }};

      for (const startId of safeMap.keys()) {{
        const cleanStart = normalizeNodeId(startId || "");
        if (!cleanStart || seen.has(cleanStart)) continue;
        const queue = [cleanStart];
        const nodeIds = [];
        seen.add(cleanStart);
        let edgeCount = 0;
        let realEdgeCount = 0;
        let weight = 0;
        while (queue.length) {{
          const nodeId = queue.shift();
          if (!nodeId) continue;
          nodeIds.push(nodeId);
          const peers = adjacency instanceof Map ? (adjacency.get(nodeId) || new Map()) : new Map();
          for (const [peerIdRaw, edge] of peers.entries()) {{
            const peerId = normalizeNodeId(peerIdRaw || "");
            if (!peerId || !safeMap.has(peerId)) continue;
            if (String(nodeId) < String(peerId)) {{
              edgeCount += 1;
              weight += Math.max(0, Number(edge && edge.weight) || 0);
              if (edge && edge.isReal) {{
                realEdgeCount += 1;
              }}
            }}
            if (!seen.has(peerId)) {{
              seen.add(peerId);
              queue.push(peerId);
            }}
          }}
        }}
        const rootId = chooseComponentRoot(nodeIds) || cleanStart;
        const component = {{
          rootId,
          nodeCount: nodeIds.length,
          edgeCount,
          realEdgeCount,
          weight,
          nodeIds: new Set(nodeIds),
        }};
        nodeIds.forEach((nodeId) => componentByNodeId.set(nodeId, component));
        if (!bestComponent || compareNetworkGraphComponents(component, bestComponent, degreeMeta, safeMap) < 0) {{
          bestComponent = component;
        }}
      }}

      return {{
        componentByNodeId,
        bestComponent,
      }};
    }}

    function networkGraphNodeHasLinkPeers(nodeId, adjacency, nodeMap = null) {{
      const clean = normalizeNodeId(nodeId || "");
      if (!clean || !(adjacency instanceof Map) || !adjacency.has(clean)) return false;
      const peers = adjacency.get(clean);
      if (!(peers instanceof Map) || peers.size <= 0) return false;
      if (!(nodeMap instanceof Map) || nodeMap.size <= 0) return peers.size > 0;
      for (const peerId of peers.keys()) {{
        if (nodeMap.has(peerId)) return true;
      }}
      return false;
    }}

    function networkGraphRootCandidate(nodeId, componentMeta, degreeMeta) {{
      const clean = normalizeNodeId(nodeId || "");
      const components = componentMeta && componentMeta.componentByNodeId instanceof Map
        ? componentMeta.componentByNodeId
        : new Map();
      if (!clean || !components.has(clean)) return null;
      const component = components.get(clean);
      const meta = degreeMeta instanceof Map ? (degreeMeta.get(clean) || {{ degree: 0, weight: 0 }}) : {{ degree: 0, weight: 0 }};
      return {{
        nodeId: clean,
        component,
        degree: Math.max(0, Number(meta.degree) || 0),
        weight: Math.max(0, Number(meta.weight) || 0),
        hasLinks: Math.max(0, Number(meta.degree) || 0) > 0,
      }};
    }}

    function networkGraphComponentIsRelationshipAnchor(candidate, bestComponent) {{
      if (!(candidate && candidate.component && candidate.hasLinks)) return false;
      const component = candidate.component;
      if (Math.max(0, Number(component.edgeCount) || 0) <= 0) return false;
      if (!(bestComponent && typeof bestComponent === "object")) return true;
      if (component === bestComponent) return true;
      const bestNodes = Math.max(1, Number(bestComponent.nodeCount) || 0);
      const bestEdges = Math.max(1, Number(bestComponent.edgeCount) || 0);
      const bestWeight = Math.max(1, Number(bestComponent.weight) || 0);
      const nodeCount = Math.max(0, Number(component.nodeCount) || 0);
      const edgeCount = Math.max(0, Number(component.edgeCount) || 0);
      const weight = Math.max(0, Number(component.weight) || 0);
      return (
        nodeCount >= 12
        || edgeCount >= 12
        || (nodeCount / bestNodes) >= 0.34
        || (edgeCount / bestEdges) >= 0.34
        || (weight / bestWeight) >= 0.34
      );
    }}

    function resolveNetworkGraphRootId(nodeMap, adjacency, degreeMeta, state) {{
      const componentMeta = buildNetworkGraphComponentMeta(nodeMap, adjacency, degreeMeta);
      const bestComponent = componentMeta.bestComponent;
      const selectedId = normalizeNodeId(selectedNodeId || "");
      const selectedNodeAvailable = !!(selectedId && nodeMap.has(selectedId));
      const graphRootId = normalizeNodeId(networkGraphRootNodeId || "");
      const graphRootAvailable = !!(graphRootId && nodeMap.has(graphRootId));
      const graphRootCandidate = graphRootAvailable
        ? networkGraphRootCandidate(graphRootId, componentMeta, degreeMeta)
        : null;
      const manualRootId = normalizeNodeId(networkGraphViewState.manualRootNodeId || "");
      const manualRootAvailable = !!(manualRootId && nodeMap.has(manualRootId));
      const manualRootCandidate = manualRootAvailable
        ? networkGraphRootCandidate(manualRootId, componentMeta, degreeMeta)
        : null;
      const localNodeId = normalizeNodeId(resolveLocalNodeId(state || latestState || {{}}) || "");
      const localNodeAvailable = !!(localNodeId && nodeMap.has(localNodeId));
      const localCandidate = localNodeAvailable
        ? networkGraphRootCandidate(localNodeId, componentMeta, degreeMeta)
        : null;
      let bestId = bestComponent && bestComponent.rootId ? normalizeNodeId(bestComponent.rootId) : "";
      let strongestId = "";
      let bestDegree = -1;
      let bestWeight = -1;
      for (const nodeId of nodeMap.keys()) {{
        const peers = adjacency.get(nodeId) || new Map();
        const meta = degreeMeta.get(nodeId) || {{ degree: peers.size, weight: 0 }};
        if (meta.degree > bestDegree || (meta.degree === bestDegree && meta.weight > bestWeight)) {{
          strongestId = nodeId;
          bestDegree = meta.degree;
          bestWeight = meta.weight;
        }}
      }}
      if (selectedNodeAvailable) return selectedId;
      if (manualRootCandidate && manualRootCandidate.hasLinks) return manualRootCandidate.nodeId;
      if (graphRootCandidate && networkGraphComponentIsRelationshipAnchor(graphRootCandidate, bestComponent)) {{
        return graphRootCandidate.nodeId;
      }}
      if (
        localCandidate
        && (
          networkGraphComponentIsRelationshipAnchor(localCandidate, bestComponent)
          || bestDegree <= 0
        )
      ) {{
        return localNodeId;
      }}
      if (bestId) return bestId;
      if (strongestId) return strongestId;
      if (selectedNodeAvailable) return selectedId;
      if (graphRootAvailable) return graphRootId;
      for (const nodeId of nodeMap.keys()) {{
        return nodeId;
      }}
      return "";
    }}

    function detectNetworkGraphCommunities(adjacency, degreeMeta, eligibleNodeIds) {{
      const nodeIds = Array.isArray(eligibleNodeIds)
        ? Array.from(new Set(eligibleNodeIds.map((nodeId) => normalizeNodeId(nodeId)).filter(Boolean)))
        : [];
      const labels = new Map(nodeIds.map((nodeId) => [nodeId, nodeId]));
      const iterations = 8;
      for (let step = 0; step < iterations; step += 1) {{
        let changed = false;
        const orderedNodeIds = nodeIds.slice().sort((a, b) => compareNetworkGraphNodeIds(a, b, degreeMeta, new Map()));
        for (const nodeId of orderedNodeIds) {{
          const peers = adjacency.get(nodeId);
          if (!(peers instanceof Map) || peers.size <= 0) continue;
          const scores = new Map();
          for (const [peerId, edge] of peers.entries()) {{
            if (!labels.has(peerId)) continue;
            const peerLabel = normalizeNodeId(labels.get(peerId) || peerId);
            const weight = Math.max(1, Number(edge && edge.weight) || 0);
            scores.set(peerLabel, (scores.get(peerLabel) || 0) + weight);
          }}
          if (!scores.size) continue;
          let bestLabel = normalizeNodeId(labels.get(nodeId) || nodeId);
          let bestScore = -1;
          for (const [label, score] of scores.entries()) {{
            if (
              score > bestScore
              || (score === bestScore && String(label) < String(bestLabel))
            ) {{
              bestLabel = label;
              bestScore = score;
            }}
          }}
          if (bestLabel && labels.get(nodeId) !== bestLabel) {{
            labels.set(nodeId, bestLabel);
            changed = true;
          }}
        }}
        if (!changed) break;
      }}
      const communities = new Map();
      nodeIds.forEach((nodeId) => {{
        const label = normalizeNodeId(labels.get(nodeId) || nodeId);
        if (!communities.has(label)) {{
          communities.set(label, []);
        }}
        communities.get(label).push(nodeId);
      }});
      return Array.from(communities.values()).map((members) => members.slice().sort()).sort((a, b) => b.length - a.length);
    }}

    function collectNetworkGraphAncestorScores(nodeId, targetLayer, layerByNodeId, parentHintsByNodeId, memo = new Map()) {{
      const cleanNodeId = normalizeNodeId(nodeId || "");
      const desiredLayer = Math.max(0, Number(targetLayer) || 0);
      if (!cleanNodeId || !(layerByNodeId instanceof Map) || !(parentHintsByNodeId instanceof Map)) {{
        return new Map();
      }}
      const cacheKey = `${{desiredLayer}}:${{cleanNodeId}}`;
      if (memo instanceof Map && memo.has(cacheKey)) {{
        return new Map(memo.get(cacheKey) || []);
      }}
      const scores = new Map();
      const nodeLayer = Number(layerByNodeId.get(cleanNodeId));
      if (!Number.isFinite(nodeLayer) || nodeLayer < desiredLayer) {{
        if (memo instanceof Map) memo.set(cacheKey, new Map(scores));
        return new Map(scores);
      }}
      if (nodeLayer === desiredLayer) {{
        scores.set(cleanNodeId, 1);
        if (memo instanceof Map) memo.set(cacheKey, new Map(scores));
        return new Map(scores);
      }}
      const parents = Array.isArray(parentHintsByNodeId.get(cleanNodeId))
        ? parentHintsByNodeId.get(cleanNodeId)
        : [];
      parents.forEach((parentId) => {{
        const parentScores = collectNetworkGraphAncestorScores(
          parentId,
          desiredLayer,
          layerByNodeId,
          parentHintsByNodeId,
          memo
        );
        parentScores.forEach((score, ancestorId) => {{
          const cleanAncestorId = normalizeNodeId(ancestorId || "");
          if (!cleanAncestorId) return;
          scores.set(cleanAncestorId, (scores.get(cleanAncestorId) || 0) + Math.max(1, Number(score) || 0));
        }});
      }});
      if (memo instanceof Map) memo.set(cacheKey, new Map(scores));
      return new Map(scores);
    }}

    function resolveNetworkGraphBestClusterCandidate(candidateScores, degreeMeta, fallbackId = "") {{
      const fallback = normalizeNodeId(fallbackId || "");
      let bestId = fallback;
      let bestScore = -1;
      let bestDegree = -1;
      let bestWeight = -1;
      for (const [candidateIdRaw, scoreRaw] of (candidateScores instanceof Map ? candidateScores.entries() : [])) {{
        const candidateId = normalizeNodeId(candidateIdRaw || "");
        if (!candidateId) continue;
        const score = Math.max(0, Number(scoreRaw) || 0);
        const meta = degreeMeta instanceof Map
          ? (degreeMeta.get(candidateId) || {{ degree: 0, weight: 0 }})
          : {{ degree: 0, weight: 0 }};
        const degree = Math.max(0, Number(meta.degree) || 0);
        const weight = Math.max(0, Number(meta.weight) || 0);
        if (
          score > bestScore
          || (score === bestScore && degree > bestDegree)
          || (score === bestScore && degree === bestDegree && weight > bestWeight)
          || (score === bestScore && degree === bestDegree && weight === bestWeight && (!bestId || String(candidateId) < String(bestId)))
        ) {{
          bestId = candidateId;
          bestScore = score;
          bestDegree = degree;
          bestWeight = weight;
        }}
      }}
      return bestId;
    }}

    function collectNetworkGraphDisconnectedComponentDescriptors(nodeMap, adjacency, layerByNodeId, degreeMeta) {{
      const safeMap = nodeMap instanceof Map ? nodeMap : new Map();
      const safeAdjacency = adjacency instanceof Map ? adjacency : new Map();
      const rootLayerMap = layerByNodeId instanceof Map ? layerByNodeId : new Map();
      const seen = new Set();
      const descriptors = [];

      for (const startIdRaw of safeMap.keys()) {{
        const startId = normalizeNodeId(startIdRaw || "");
        if (!startId || rootLayerMap.has(startId) || seen.has(startId)) continue;
        const queue = [startId];
        const nodeIds = [];
        seen.add(startId);
        let edgeCount = 0;
        let realEdgeCount = 0;
        let weight = 0;

        for (let cursor = 0; cursor < queue.length; cursor += 1) {{
          const nodeId = normalizeNodeId(queue[cursor] || "");
          if (!nodeId || !safeMap.has(nodeId) || rootLayerMap.has(nodeId)) continue;
          nodeIds.push(nodeId);
          const peers = safeAdjacency.get(nodeId) || new Map();
          for (const [peerIdRaw, edge] of peers.entries()) {{
            const peerId = normalizeNodeId(peerIdRaw || "");
            if (!peerId || !safeMap.has(peerId) || rootLayerMap.has(peerId)) continue;
            if (String(nodeId) < String(peerId)) {{
              edgeCount += 1;
              weight += Math.max(0, Number(edge && edge.weight) || 0);
              if (edge && edge.isReal) {{
                realEdgeCount += 1;
              }}
            }}
            if (!seen.has(peerId)) {{
              seen.add(peerId);
              queue.push(peerId);
            }}
          }}
        }}

        if (edgeCount <= 0 || nodeIds.length <= 1) continue;
        const sortedNodeIds = nodeIds.slice().sort((a, b) => (
          compareNetworkGraphNodeIds(a, b, degreeMeta, safeMap)
        ));
        const rootId = sortedNodeIds[0] || startId;
        descriptors.push({{
          rootId,
          nodeIds: sortedNodeIds,
          nodeCount: sortedNodeIds.length,
          edgeCount,
          realEdgeCount,
          weight,
        }});
      }}

      return descriptors.sort((componentA, componentB) => (
        compareNetworkGraphComponents(componentA, componentB, degreeMeta, safeMap)
      ));
    }}

    function chunkNetworkGraphNodeIds(nodeIds, chunkSize = 1) {{
      const safeNodeIds = Array.isArray(nodeIds)
        ? nodeIds.map((nodeId) => normalizeNodeId(nodeId)).filter(Boolean)
        : [];
      const safeChunkSize = Math.max(1, Math.trunc(Number(chunkSize) || 1));
      const chunks = [];
      for (let index = 0; index < safeNodeIds.length; index += safeChunkSize) {{
        chunks.push(safeNodeIds.slice(index, index + safeChunkSize));
      }}
      return chunks;
    }}

    function compareNetworkGraphDisconnectedCandidates(candidateA, candidateB, degreeMeta, nodeMap) {{
      const safeCandidateA = (candidateA && typeof candidateA === "object") ? candidateA : {{}};
      const safeCandidateB = (candidateB && typeof candidateB === "object") ? candidateB : {{}};
      const preserveDelta = Number(!!safeCandidateB.preserve) - Number(!!safeCandidateA.preserve);
      if (preserveDelta !== 0) return preserveDelta;
      const broadcastDelta = Number(!!safeCandidateB.broadcastOnly) - Number(!!safeCandidateA.broadcastOnly);
      if (broadcastDelta !== 0) return broadcastDelta;
      const priorityDelta = networkGraphNodeDisplayPriority(safeCandidateB.nodeId, nodeMap) - networkGraphNodeDisplayPriority(safeCandidateA.nodeId, nodeMap);
      if (priorityDelta !== 0) return priorityDelta;
      const signalMetaA = (safeCandidateA.signalMeta && typeof safeCandidateA.signalMeta === "object") ? safeCandidateA.signalMeta : {{}};
      const signalMetaB = (safeCandidateB.signalMeta && typeof safeCandidateB.signalMeta === "object") ? safeCandidateB.signalMeta : {{}};
      const livePacketDelta = Math.max(0, Number(signalMetaB.packetCount) || 0) - Math.max(0, Number(signalMetaA.packetCount) || 0);
      if (livePacketDelta !== 0) return livePacketDelta;
      const broadcastPacketDelta = Math.max(0, Number(signalMetaB.broadcastPacketCount) || 0) - Math.max(0, Number(signalMetaA.broadcastPacketCount) || 0);
      if (broadcastPacketDelta !== 0) return broadcastPacketDelta;
      const savedPacketDelta = Math.max(0, Number(signalMetaB.savedPackets) || 0) - Math.max(0, Number(signalMetaA.savedPackets) || 0);
      if (savedPacketDelta !== 0) return savedPacketDelta;
      const nodeA = (safeCandidateA.node && typeof safeCandidateA.node === "object") ? safeCandidateA.node : null;
      const nodeB = (safeCandidateB.node && typeof safeCandidateB.node === "object") ? safeCandidateB.node : null;
      const positionHintDelta = Number(!!(nodeB && nodeB.has_position)) - Number(!!(nodeA && nodeA.has_position));
      if (positionHintDelta !== 0) return positionHintDelta;
      const lastPositionDelta = Math.max(0, Number(nodeB && nodeB.last_position_unix) || 0) - Math.max(0, Number(nodeA && nodeA.last_position_unix) || 0);
      if (lastPositionDelta !== 0) return lastPositionDelta;
      const lastHeardDelta = Math.max(0, Number(signalMetaB.lastHeardUnix) || 0) - Math.max(0, Number(signalMetaA.lastHeardUnix) || 0);
      if (lastHeardDelta !== 0) return lastHeardDelta;
      const placeholderDelta = Number(!!(nodeA && nodeA.is_graph_placeholder)) - Number(!!(nodeB && nodeB.is_graph_placeholder));
      if (placeholderDelta !== 0) return placeholderDelta;
      const hopsA = Number(signalMetaA.hopsAway);
      const hopsB = Number(signalMetaB.hopsAway);
      const safeHopsA = Number.isFinite(hopsA) ? hopsA : Number.POSITIVE_INFINITY;
      const safeHopsB = Number.isFinite(hopsB) ? hopsB : Number.POSITIVE_INFINITY;
      if (safeHopsA !== safeHopsB) return safeHopsA - safeHopsB;
      return compareNetworkGraphNodeIds(
        normalizeNodeId(safeCandidateA.nodeId || ""),
        normalizeNodeId(safeCandidateB.nodeId || ""),
        degreeMeta,
        nodeMap
      );
    }}

    function limitNetworkGraphDisconnectedNodeIds(
      broadcastOnlyNodeIds,
      detachedNodeIds,
      connectedCount,
      nodeMap,
      signalMetaByNodeId,
      degreeMeta,
      options = {{}}
    ) {{
      const broadcastCandidates = Array.isArray(broadcastOnlyNodeIds)
        ? broadcastOnlyNodeIds.map((nodeId) => normalizeNodeId(nodeId)).filter(Boolean)
