        const retargetNetworkRoutesScopeNode = (rawNodeId) => {{
          const targetNodeId = normalizeNodeId(rawNodeId || "");
          if (!isSelectableNodeId(targetNodeId)) return false;
          const localSourceId = normalizeNodeId(
            resolveNetworkRoutesSourceNodeId(latestState) || networkRoutesFromNodeId || ""
          );
          if (isSelectableNodeId(localSourceId)) {{
            networkRoutesFromNodeId = localSourceId;
