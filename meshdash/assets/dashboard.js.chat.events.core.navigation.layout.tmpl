    function resolveNetworkGraphShortestPathSegments(edges, fromNodeId, toNodeId) {{
      const startId = normalizeNodeId(fromNodeId || "");
      const targetId = normalizeNodeId(toNodeId || "");
      if (!isSelectableNodeId(startId) || !isSelectableNodeId(targetId) || startId === targetId) {{
        return [];
      }}
      const adjacency = new Map();
      for (const edge of (Array.isArray(edges) ? edges : [])) {{
        const a = normalizeNodeId(edge && edge.a);
        const b = normalizeNodeId(edge && edge.b);
        const edgeKey = networkGraphEdgeKeyBetween(a, b);
        if (!edgeKey) continue;
        if (!adjacency.has(a)) adjacency.set(a, []);
        if (!adjacency.has(b)) adjacency.set(b, []);
        adjacency.get(a).push({{ peerId: b, edgeKey }});
        adjacency.get(b).push({{ peerId: a, edgeKey }});
      }}
      if (!adjacency.has(startId) || !adjacency.has(targetId)) return [];

      const parents = new Map([[startId, null]]);
      const queue = [startId];
      for (let cursor = 0; cursor < queue.length && !parents.has(targetId); cursor += 1) {{
        const currentId = queue[cursor];
        const neighbors = adjacency.get(currentId) || [];
        for (const neighbor of neighbors) {{
          const peerId = normalizeNodeId(neighbor && neighbor.peerId);
          if (!peerId || parents.has(peerId)) continue;
          parents.set(peerId, {{
            nodeId: currentId,
            edgeKey: neighbor.edgeKey,
          }});
          if (peerId === targetId) break;
          queue.push(peerId);
        }}
      }}
      if (!parents.has(targetId)) return [];

      let currentId = targetId;
      const pathSegments = [];
      while (currentId && currentId !== startId) {{
        const parent = parents.get(currentId);
        if (!parent || !parent.nodeId || !parent.edgeKey) break;
        pathSegments.unshift({{
          edgeKey: parent.edgeKey,
          fromNodeId: parent.nodeId,
          toNodeId: currentId,
        }});
        currentId = parent.nodeId;
      }}
      return pathSegments;
    }}

    function resolveNetworkGraphShortestPathEdgeKeys(edges, fromNodeId, toNodeId) {{
