    function renderChatLabsView(state = latestState) {{
      const terminal = document.getElementById("chat-labs-terminal");
      const feed = document.getElementById("chat-labs-feed");
      const countEl = document.getElementById("chat-labs-count");
      if (!(terminal instanceof HTMLElement) || !(feed instanceof HTMLElement)) return;
      if (typeof renderMeshChannelPills === "function") {{
        renderMeshChannelPills(meshChannelOptions);
      }}

      const safeState = (state && typeof state === "object") ? state : null;
      const traffic = (safeState && safeState.traffic && typeof safeState.traffic === "object")
        ? safeState.traffic
        : {{}};
      const liveRows = Array.isArray(traffic.recent_chat) ? traffic.recent_chat : [];
      const nodes = Array.isArray(safeState && safeState.nodes) ? safeState.nodes : [];
      const nowUnix = Math.floor(Date.now() / 1000);
      const localNodeId = normalizeNodeId(resolveLocalNodeId(safeState || latestState || {{}}));
      const nodesById = new Map();
      const nodeIdByNum = new Map();
      for (const node of nodes) {{
        const nodeId = normalizeNodeId(node && node.id);
        if (isCanonicalNodeId(nodeId) && !nodesById.has(nodeId)) {{
          nodesById.set(nodeId, node);
        }}
        const nodeNum = parseNodeNum(node && node.num);
        if (Number.isInteger(nodeNum) && nodeNum >= 0 && isCanonicalNodeId(nodeId) && !nodeIdByNum.has(nodeNum)) {{
          nodeIdByNum.set(nodeNum, nodeId);
        }}
      }}

      const wasNearBottom = (terminal.scrollHeight - terminal.scrollTop - terminal.clientHeight) <= 28;
      const setElementHtmlIfChanged = (element, markup, cacheKey = "default") => {{
        if (!(element instanceof HTMLElement)) return false;
        const nextMarkup = String(markup == null ? "" : markup);
        const propName = `__meshLastInnerHtml_${{cacheKey}}`;
        const previousMarkup = (typeof element[propName] === "string") ? element[propName] : null;
        if (previousMarkup === nextMarkup) return false;
        element.innerHTML = nextMarkup;
        element[propName] = nextMarkup;
        return true;
      }};
      const maxLines = 260;
      const historyBackfillLimit = Math.max(320, maxLines * 2);
      const fromIdKeys = ["from_id", "fromId", "from", "source_id", "sourceId", "source", "from_num", "fromNum"];
      const toIdKeys = ["to_id", "toId", "to", "dest_id", "destId", "destination", "dest", "to_num", "toNum"];
      const resolveNodeIdFromMessage = (msg, keys) => {{
        for (const key of keys) {{
          const rawValue = msg && msg[key];
          const clean = normalizeNodeId(rawValue);
          if (isCanonicalNodeId(clean) || clean === "^all" || clean === "local") {{
            return clean;
          }}
          const nodeNum = parseNodeNum(rawValue);
          if (Number.isInteger(nodeNum) && nodeIdByNum.has(nodeNum)) {{
            return nodeIdByNum.get(nodeNum) || clean;
          }}
        }}
        return "";
      }};
      const nodeLabel = (nodeId, fallbackText = "unknown") => {{
        const clean = normalizeNodeId(nodeId);
        if (!clean || clean === "^all") return "all";
        if (clean === "local") return "local";
        if (!isCanonicalNodeId(clean)) return String(fallbackText || "unknown");
        const node = nodesById.get(clean) || null;
        const preferred = preferredNodeName(node) || nodeNameCache.get(clean) || clean;
        return String(preferred || clean);
      }};
      const emojiFromCodepoint = (rawValue) => {{
        const codepoint = Number(rawValue);
        if (!Number.isInteger(codepoint) || codepoint <= 0) return "";
        try {{
          return String.fromCodePoint(codepoint);
        }} catch (_err) {{
          return "";
        }}
      }};
      const squeezeChatLabsWhitespace = (rawValue) => {{
        const raw = String(rawValue == null ? "" : rawValue).replace(/\r\n?/g, "\n");
        let normalized = raw;
        try {{
          normalized = normalized.replace(/\p{{Z}}+/gu, " ");
        }} catch (_err) {{
          normalized = normalized.replace(/[\u00A0\u1680\u180E\u2000-\u200A\u2028\u2029\u202F\u205F\u3000]+/g, " ");
        }}
        normalized = normalized
          .replace(/[\u2800\u3164\u115F\u1160]+/g, " ")
          .replace(/[\u200B-\u200D\u2060\uFEFF]+/g, " ")
          .replace(/[\u0000-\u001F\u007F-\u009F]+/g, " ");
        normalized = normalized
          .replace(/[\t\f\v]+/g, " ")
          .split("\n")
          .map((line) => line.replace(/ +/g, " ").trim())
          .join("\n")
          .trim();
        return normalized;
      }};
      const normalizeChatLabsText = (rawValue) => squeezeChatLabsWhitespace(rawValue).replace(/\s+/g, " ").trim();
      const normalizeChatLabsLabel = (rawValue) => squeezeChatLabsWhitespace(rawValue).replace(/\n+/g, " ");
      const historyBridge = (() => {{
        if (typeof window === "undefined") return {{ loaded: false, loading: false, rows: [] }};
        const existing = window.__meshChatLabsHistoryBridge;
        if (existing && typeof existing === "object") return existing;
        const created = {{
          loaded: false,
          loading: false,
          rows: [],
          loadedAtMs: 0,
        }};
        window.__meshChatLabsHistoryBridge = created;
        return created;
      }})();
      const historyRows = Array.isArray(historyBridge.rows) ? historyBridge.rows : [];
      const activeMeshFilterIndex = (typeof activeMeshChannelFilterIndex === "function")
        ? activeMeshChannelFilterIndex()
        : meshChannelAllIndex;
      const renderMinuteBucket = Math.floor(nowUnix / 60);
      const cachedRender = (chatLabsRenderCache && typeof chatLabsRenderCache === "object")
        ? chatLabsRenderCache
        : null;
      if (
        cachedRender
        && cachedRender.liveRowsRef === liveRows
        && cachedRender.nodesRef === nodes
        && cachedRender.historyRowsRef === historyRows
        && cachedRender.meshFilterIndex === activeMeshFilterIndex
        && cachedRender.minuteBucket === renderMinuteBucket
        && cachedRender.historyLoaded === !!historyBridge.loaded
        && cachedRender.historyLoading === !!historyBridge.loading
      ) {{
        if (typeof cachedRender.feedHtml === "string") {{
          setElementHtmlIfChanged(feed, cachedRender.feedHtml, "chat-labs-feed");
        }}
        if (countEl instanceof HTMLElement) {{
          const countText = String(cachedRender.countText || "");
          if (countEl.textContent !== countText) {{
            countEl.textContent = countText;
          }}
        }}
        if (typeof bindChatReactionControls === "function") {{
          bindChatReactionControls();
        }}
        if (wasNearBottom) {{
          window.requestAnimationFrame(() => {{
            terminal.scrollTop = terminal.scrollHeight;
          }});
        }}
        return;
      }}
      const mergedRows = [];
      const seenMergedKeys = new Set();
      const mergedCandidates = liveRows.concat(historyRows);
      const dedupeChatLabsRowKey = (msg) => {{
        const packetId = messageIdOfChatPacket(msg);
        if (Number.isInteger(packetId) && packetId > 0) {{
          return `id:${{packetId}}`;
        }}
        const fromNode = normalizeNodeId(
          (msg && (msg.from_id ?? msg.fromId ?? msg.from ?? msg.source_id ?? msg.sourceId ?? msg.source)) || ""
        );
        const toNode = normalizeNodeId(
          (msg && (msg.to_id ?? msg.toId ?? msg.to ?? msg.dest_id ?? msg.destId ?? msg.destination ?? msg.dest)) || ""
        );
        const whenLabel = String(
          (msg && (msg.rx_time || msg.captured_at || msg.time || msg.rxTime || msg.timestamp || "")) || ""
        ).trim();
        const textLabel = normalizeChatLabsText(
          msg && (msg.decoded_text ?? msg.payload_text ?? msg.text ?? msg.message ?? msg.body ?? "")
        );
        return `row:${{fromNode}}|${{toNode}}|${{whenLabel}}|${{textLabel}}`;
      }};
      for (const msg of mergedCandidates) {{
        if (!(msg && typeof msg === "object")) continue;
        const dedupeKey = dedupeChatLabsRowKey(msg);
        if (seenMergedKeys.has(dedupeKey)) continue;
        seenMergedKeys.add(dedupeKey);
        mergedRows.push(msg);
      }}
      const filteredRows = (typeof messageMatchesActiveMeshChannel === "function")
        ? mergedRows.filter((msg) => messageMatchesActiveMeshChannel(msg))
        : mergedRows;
      if (
        typeof fetchConsoleHistorySearch === "function"
        && !historyBridge.loaded
        && !historyBridge.loading
      ) {{
        historyBridge.loading = true;
        void fetchConsoleHistorySearch({{
          queryText: "from",
          limit: historyBackfillLimit,
          source: "chat",
          scope: "summary",
          scanLimit: Math.max(3000, historyBackfillLimit * 6),
        }})
          .then((payload) => {{
            const entries = Array.isArray(payload && payload.entries) ? payload.entries : [];
            const historyMessages = [];
            for (const entry of entries) {{
              if (!(entry && typeof entry === "object")) continue;
              if (entry.separator === true) continue;
              if (String(entry.source || "").trim().toLowerCase() !== "chat") continue;
              const chat = (entry.chat && typeof entry.chat === "object") ? entry.chat : null;
              if (!chat) continue;
              historyMessages.push({{
                from_id: chat.from,
                from: chat.from,
                to_id: chat.to,
                to: chat.to,
                channel: chat.channel,
                channel_index: chat.channel,
                decoded_text: chat.text,
                text: chat.text,
                message: chat.text,
                body: chat.text,
                rx_time: chat.rx_time || chat.captured_at || "",
                captured_at: chat.captured_at || chat.rx_time || "",
                time: chat.captured_at || chat.rx_time || "",
                timestamp: chat.captured_at || chat.rx_time || "",
                message_id: chat.message_id,
                packet_id: chat.message_id,
                reply_id: chat.reply_id ?? chat.replyId,
                replyId: chat.reply_id ?? chat.replyId,
                emoji: chat.emoji,
                emoji_codepoint: chat.emoji_codepoint ?? chat.emojiCodepoint,
                emojiCodepoint: chat.emoji_codepoint ?? chat.emojiCodepoint,
                is_reaction: chat.is_reaction === true || chat.isReaction === true,
                portnum: chat.portnum,
                rx_snr: chat.rx_snr,
                rx_rssi: chat.rx_rssi,
                hop_start: chat.hop_start,
                hop_limit: chat.hop_limit,
                hops: chat.hops,
              }});
            }}
            historyBridge.rows = historyMessages.slice(-historyBackfillLimit);
            historyBridge.loaded = true;
            historyBridge.loadedAtMs = Date.now();
          }})
          .catch(() => {{
            historyBridge.rows = [];
            historyBridge.loaded = true;
            historyBridge.loadedAtMs = Date.now();
          }})
          .finally(() => {{
            historyBridge.loading = false;
            if (activeLayoutView === "chatlabs") {{
              renderChatLabsView(latestState);
            }}
          }});
      }}
      const messageText = (msg) => {{
        const candidates = [
          msg && msg.decoded_text,
          msg && msg.payload_text,
          msg && msg.text,
          msg && msg.message,
          msg && msg.body,
        ];
        for (const candidate of candidates) {{
          const text = normalizeChatLabsText(candidate);
          if (text) return text;
        }}
        const emoji = String(msg && msg.emoji ? msg.emoji : "").trim() || emojiFromCodepoint(msg && (msg.emoji_codepoint ?? msg.emojiCodepoint));
        if (emoji) {{
          return emoji;
        }}
        if (msg && msg.is_reaction === true) {{
          return "Reaction";
        }}
        return "";
      }};
      const reactionEmojiForMessage = (msg) => {{
        const isEmojiCodePointLocal = (cp) => {{
          if (!Number.isInteger(cp)) return false;
          return (
            (cp >= 0x1F000 && cp <= 0x1FAFF)
            || (cp >= 0x2600 && cp <= 0x27BF)
            || (cp >= 0x1F1E6 && cp <= 0x1F1FF)
          );
        }};
        const emojiFromTextPayloadLocal = (rawValue) => {{
          const text = String(rawValue == null ? "" : rawValue).trim();
          if (!text) return "";
          const keycapMatch = text.match(/^([0-9#*])(?:\uFE0F)?\u20E3$/u);
          if (keycapMatch) {{
            return `${{keycapMatch[1]}}\uFE0F\u20E3`;
          }}
          if (text.length > 8 || /\\s/.test(text)) return "";
          if (/^[0-9A-Za-z.,;:!?'"`~_\\-]+$/.test(text)) return "";
          let sawEmoji = false;
          for (const ch of text) {{
            const cp = ch.codePointAt(0);
            if (!Number.isInteger(cp)) return "";
            if (cp === 0x200D || cp === 0xFE0F || cp === 0x20E3) continue;
            if (isEmojiCodePointLocal(cp)) {{
              sawEmoji = true;
              continue;
            }}
            return "";
          }}
          if (!sawEmoji) return "";
          const clusters = Array.from(text);
          if (clusters.length > 4) return "";
          return text;
        }};
        if (typeof emojiOf === "function") {{
          const parsed = String(emojiOf(msg) || "").trim();
          if (parsed) return parsed;
        }}
        const inline = String(msg && msg.emoji ? msg.emoji : "").trim();
        if (inline) return inline;
        const fromCodepoint = emojiFromCodepoint(msg && (msg.emoji_codepoint ?? msg.emojiCodepoint));
        if (fromCodepoint) return fromCodepoint;
        const fromText = emojiFromTextPayloadLocal(msg && (msg.text ?? msg.decoded_text ?? msg.payload_text));
        if (fromText) return fromText;
        return "";
      }};
      const avatarTokenFromLabel = (label) => {{
        const raw = String(label == null ? "" : label).trim();
        if (!raw) return "?";
        const cleaned = raw.replace(/[^A-Za-z0-9 ]+/g, " ").trim();
        if (cleaned) {{
          const words = cleaned.split(/\s+/).filter(Boolean);
          if (words.length >= 2) {{
            return `${{words[0][0] || ""}}${{words[1][0] || ""}}`.toUpperCase();
          }}
          return words[0].slice(0, 2).toUpperCase();
        }}
        const first = Array.from(raw).slice(0, 1).join("");
        return first ? first.toUpperCase() : "?";
      }};
      const isEmojiCodePoint = (cp) => {{
        if (!Number.isInteger(cp)) return false;
        return (
          (cp >= 0x1F000 && cp <= 0x1FAFF)
          || (cp >= 0x2600 && cp <= 0x27BF)
          || (cp >= 0x1F1E6 && cp <= 0x1F1FF)
        );
      }};
      const isEmojiOnlyText = (rawText) => {{
        const text = String(rawText == null ? "" : rawText).trim();
        if (!text) return false;
        const compact = text.replace(/\s+/g, "");
        if (!compact) return false;
        let sawEmoji = false;
        for (const ch of compact) {{
          const cp = ch.codePointAt(0);
          if (!Number.isInteger(cp)) return false;
          if (cp === 0x200D || cp === 0xFE0F || cp === 0x20E3) continue;
          if (isEmojiCodePoint(cp)) {{
            sawEmoji = true;
            continue;
          }}
          return false;
        }}
        return sawEmoji;
      }};
      const reactionBucketsByMessage = new Map();
      const baseRows = [];
      for (const msg of filteredRows) {{
        if (!(msg && typeof msg === "object")) continue;
        const replyId = replyIdOfChatPacket(msg);
        const reactionEmoji = reactionEmojiForMessage(msg);
        const isReactionPacket = !!(
          msg.is_reaction === true
          || (Number.isInteger(replyId) && replyId > 0 && !!reactionEmoji)
        );
        if (isReactionPacket) {{
          if (!Number.isInteger(replyId) || replyId <= 0 || !reactionEmoji) {{
            continue;
          }}
          const messageKey = String(replyId);
          let perMessage = reactionBucketsByMessage.get(messageKey);
          if (!(perMessage instanceof Map)) {{
            perMessage = new Map();
            reactionBucketsByMessage.set(messageKey, perMessage);
          }}
          let bucket = perMessage.get(reactionEmoji);
          if (!bucket) {{
            bucket = {{
              emoji: reactionEmoji,
              count: 0,
              reactors: new Set(),
              names: [],
            }};
            perMessage.set(reactionEmoji, bucket);
          }}
          const reactorId = resolveNodeIdFromMessage(msg, fromIdKeys);
          const reactorName = nodeLabel(reactorId, "Unknown node");
          const dedupeKey = reactorId || `${{reactorName}}:${{msg.rx_time || msg.captured_at || bucket.count}}`;
          if (!bucket.reactors.has(dedupeKey)) {{
            bucket.reactors.add(dedupeKey);
            bucket.count += 1;
            bucket.names.push(reactorName);
          }}
          continue;
        }}
        baseRows.push(msg);
      }}

      const timeline = baseRows
        .map((msg, index) => {{
          const unix = latestUnixTimestamp(
            msg && msg.rx_time,
            msg && msg.captured_at,
            msg && msg.time,
            msg && msg.rxTime,
            msg && msg.timestamp,
          );
          return {{
            msg,
            index,
            unix: Number.isFinite(unix) ? Math.floor(unix) : null,
          }};
        }})
        .filter((row) => row && row.msg && typeof row.msg === "object")
        .sort((a, b) => {{
          const aUnix = Number.isFinite(a.unix) ? a.unix : null;
          const bUnix = Number.isFinite(b.unix) ? b.unix : null;
          if (aUnix == null && bUnix != null) return -1;
          if (aUnix != null && bUnix == null) return 1;
          if (aUnix != null && bUnix != null && aUnix !== bUnix) {{
            return aUnix - bUnix;
          }}
          return a.index - b.index;
        }})
        .slice(-maxLines);

      if (!timeline.length) {{
        const loadingHistory = !!(historyBridge && historyBridge.loading);
        const nextFeedHtml = loadingHistory
          ? '<div class="chatlabs-empty">Loading saved chat history...</div>'
          : '<div class="chatlabs-empty">No chat traffic yet. Incoming messages will appear here.</div>';
        setElementHtmlIfChanged(feed, nextFeedHtml, "chat-labs-feed");
        const countText = loadingHistory ? "loading..." : "0 msgs";
        if (countEl instanceof HTMLElement) {{
          if (countEl.textContent !== countText) {{
            countEl.textContent = countText;
          }}
        }}
        chatLabsRenderCache = {{
          liveRowsRef: liveRows,
          nodesRef: nodes,
          historyRowsRef: historyRows,
          meshFilterIndex: activeMeshFilterIndex,
          minuteBucket: renderMinuteBucket,
          historyLoaded: !!historyBridge.loaded,
          historyLoading: !!historyBridge.loading,
          feedHtml: nextFeedHtml,
          countText,
        }};
        if (typeof bindChatReactionControls === "function") {{
          bindChatReactionControls();
        }}
        return;
      }}

      const lineHtml = [];
      for (let rowIndex = 0; rowIndex < timeline.length; rowIndex += 1) {{
        const row = timeline[rowIndex];
        const msg = row.msg;
        const fromId = resolveNodeIdFromMessage(msg, fromIdKeys);
        const toId = resolveNodeIdFromMessage(msg, toIdKeys);
        const messageId = messageIdOfChatPacket(msg);
        const fromLabel = normalizeChatLabsLabel(nodeLabel(fromId, "unknown")) || "unknown";
        const toLabel = normalizeChatLabsLabel(nodeLabel(toId || "^all", "all")) || "all";
        const isDirect = !!(toId && toId !== "^all" && toId !== "all" && toId !== "local");
        const text = messageText(msg);
        const isReaction = !!(
          msg && (
            msg.is_reaction === true
            || msg.emoji != null
            || msg.emoji_codepoint != null
            || msg.emojiCodepoint != null
          )
        );
        const rawTime = msg && (msg.rx_time || msg.captured_at || msg.time || msg.rxTime || msg.timestamp || "");
        const timeLabel = Number.isFinite(row.unix) && row.unix > 0
          ? formatLocalChatTime(row.unix, rawTime || "n/a", nowUnix)
          : String(rawTime || "n/a");
        const isSelf = isCanonicalNodeId(fromId) && isCanonicalNodeId(localNodeId) && fromId === localNodeId;
        let continuation = false;
        if (rowIndex > 0) {{
          const previous = timeline[rowIndex - 1];
          const previousMsg = previous && previous.msg && typeof previous.msg === "object"
            ? previous.msg
            : null;
          if (previousMsg) {{
            const previousFromId = resolveNodeIdFromMessage(previousMsg, fromIdKeys);
            const previousIsSelf = isCanonicalNodeId(previousFromId) && isCanonicalNodeId(localNodeId) && previousFromId === localNodeId;
            const previousUnix = Number.isFinite(previous.unix) ? Math.floor(previous.unix) : null;
            const maxGapSec = 5 * 60;
            const withinWindow = (
              Number.isFinite(row.unix)
              && Number.isFinite(previousUnix)
              && (Math.floor(row.unix) - previousUnix) >= 0
              && (Math.floor(row.unix) - previousUnix) <= maxGapSec
            );
            continuation = previousFromId === fromId && previousIsSelf === isSelf && withinWindow;
          }}
        }}
        const isEmojiOnly = isEmojiOnlyText(text);
        const rowClasses = ["chatlabs-message-row"];
        if (isSelf) {{
          rowClasses.push("is-self");
        }}
        if (continuation) {{
          rowClasses.push("is-continuation");
        }}
        if (isReaction) {{
          rowClasses.push("is-reaction");
        }}
        const bubbleClasses = ["chatlabs-bubble"];
        if (isSelf) {{
          bubbleClasses.push("is-self");
        }}
        if (isReaction) {{
          bubbleClasses.push("is-reaction");
        }}
        if (isEmojiOnly) {{
          bubbleClasses.push("is-emoji-only");
        }}
        const directionLabel = isDirect ? `to ${{toLabel}}` : "to all";
        const bodyHtml = chatPlainTextToHtml(text || "(no text)", true);
        const fromMeta = (typeof chatEndpointParts === "function")
          ? chatEndpointParts(fromId, row.unix)
          : null;
        const senderBaseLabel = fromMeta && fromMeta.label
          ? String(fromMeta.label || "")
          : fromLabel;
        const senderLabel = isSelf ? "You" : (normalizeChatLabsLabel(senderBaseLabel) || "unknown");
        const rawSenderStatusKey = String((fromMeta && fromMeta.status) || "").trim().toLowerCase();
        const senderStatusKey = (
          rawSenderStatusKey === "online"
          || rawSenderStatusKey === "warn"
          || rawSenderStatusKey === "stale"
        ) ? rawSenderStatusKey : "unknown";
        const senderStatusLabel = senderStatusKey === "online"
          ? "Online"
          : (senderStatusKey === "warn" ? "Aging" : (senderStatusKey === "stale" ? "Stale" : "Unknown"));
        const messageReactions = messageId ? reactionBucketsByMessage.get(String(messageId)) : null;
        const reactionGroups = messageReactions
          ? Array.from(messageReactions.values())
              .map((bucket) => ({{
                emoji: String(bucket.emoji || "").trim(),
                count: Math.max(0, Number(bucket.count || 0)),
                names: Array.isArray(bucket.names)
                  ? Array.from(new Set(bucket.names.map((name) => String(name || "").trim()).filter(Boolean))).slice(0, 40)
                  : [],
              }}))
              .filter((bucket) => !!bucket.emoji && Number.isFinite(bucket.count) && bucket.count > 0)
              .sort((a, b) => (b.count - a.count) || String(a.emoji).localeCompare(String(b.emoji)))
          : [];
        const reactionTotal = reactionGroups.reduce((sum, bucket) => sum + Math.max(0, Number(bucket.count || 0)), 0);
        const reactionSummaryTitle = reactionGroups.map((bucket) => `${{bucket.emoji}} ${{bucket.count}}`).join(" • ");
        const reactionSummaryIcons = reactionGroups
          .slice(0, 4)
          .map((bucket) => `<span class="chat-reaction-summary-emoji">${{escAttr(bucket.emoji)}}</span>`)
          .join("");
        const reactionSummary = reactionGroups.length > 0
          ? `<button type="button" class="chat-reaction-summary" data-reaction-summary="${{escAttr(JSON.stringify(reactionGroups))}}" data-reply-id="${{escAttr(messageId)}}" aria-label="${{escAttr(`Reactions: ${{reactionSummaryTitle}}`)}}" title="${{escAttr(`${{reactionSummaryTitle}} • React to this message`)}}">
              <span class="chat-reaction-summary-icons">${{reactionSummaryIcons}}</span>
              <span class="chat-reaction-summary-total">${{reactionTotal}}</span>
            </button>`
          : "";
        const reactButton = messageId
          ? `<button type="button" class="chat-react-btn chatlabs-react-meta${{reactionGroups.length > 0 ? " has-reactions" : ""}}" data-reply-id="${{escAttr(messageId)}}" title="Add reaction" aria-label="Add reaction">+</button>`
          : "";
        const tools = (reactionSummary || reactButton)
          ? `<div class="chatlabs-message-tools">${{reactionSummary}}${{reactButton}}</div>`
          : "";
        const statusChip = `<span class="chatlabs-meta-status status-${{escAttr(senderStatusKey)}}" title="Sender status: ${{escAttr(senderStatusLabel)}}">${{escAttr(senderStatusLabel)}}</span>`;
        const routeChip = isDirect
          ? `<span class="chatlabs-meta-route" title="${{escAttr(directionLabel)}}">Direct</span>`
          : "";
        const inlinePrefix = `<span class="chatlabs-inline-header">
              <span class="chatlabs-inline-name">${{escAttr(senderLabel)}}</span>
              ${{statusChip}}
              ${{routeChip}}
              <span class="chatlabs-inline-time">${{escAttr(timeLabel)}}</span>
            </span>`;
        const bubbleBodyHtml = `${{inlinePrefix}}<span class="chatlabs-inline-sep">:</span> <span class="chatlabs-inline-body">${{bodyHtml || "&nbsp;"}}</span>`;
        lineHtml.push(
          `<article class="${{escAttr(rowClasses.join(" "))}}">
            <div class="chatlabs-message-main">
              <div class="${{escAttr(bubbleClasses.join(" "))}}"><span class="chatlabs-bubble-text">${{bubbleBodyHtml}}</span></div>
              ${{tools}}
            </div>
          </article>`
        );
      }}

      const nextFeedHtml = lineHtml.join("");
      setElementHtmlIfChanged(feed, nextFeedHtml, "chat-labs-feed");
      if (typeof bindChatReactionControls === "function") {{
        bindChatReactionControls();
      }}
      const countText = `${{timeline.length}} msgs`;
      if (countEl instanceof HTMLElement) {{
        if (countEl.textContent !== countText) {{
          countEl.textContent = countText;
        }}
      }}
      chatLabsRenderCache = {{
        liveRowsRef: liveRows,
        nodesRef: nodes,
        historyRowsRef: historyRows,
        meshFilterIndex: activeMeshFilterIndex,
        minuteBucket: renderMinuteBucket,
        historyLoaded: !!historyBridge.loaded,
        historyLoading: !!historyBridge.loading,
        feedHtml: nextFeedHtml,
        countText,
      }};
      if (wasNearBottom) {{
        window.requestAnimationFrame(() => {{
          terminal.scrollTop = terminal.scrollHeight;
        }});
      }}
    }}

    function normalizeAppsLayoutView(raw) {{
      const clean = String(raw || "").trim().toLowerCase();
      if (clean === "games") {{
        return clean;
      }}
      if (clean === "files" && fileTransferFeatureEnabled) {{
        return clean;
      }}
      return "games";
    }}

    function isAppsLayoutView(viewName) {{
      const clean = String(viewName || "").trim().toLowerCase();
      return clean === "games" || (clean === "files" && fileTransferFeatureEnabled);
    }}

    function loadPreferredAppsLayoutView() {{
      try {{
        const raw = window.localStorage.getItem("meshDashboardAppsLayoutViewV1") || "games";
        return normalizeAppsLayoutView(raw);
      }} catch (_err) {{
        return "games";
      }}
    }}

    function persistPreferredAppsLayoutView(viewName) {{
      if (!isAppsLayoutView(viewName)) return;
      try {{
        window.localStorage.setItem("meshDashboardAppsLayoutViewV1", normalizeAppsLayoutView(viewName));
      }} catch (_err) {{
      }}
    }}

    function normalizeLayoutView(raw) {{
      const clean = String(raw || "").trim().toLowerCase();
      let resolved = clean;
      if (clean === "data" || clean === "packets" || clean === "channels") {{
        resolved = "settings";
      }} else if (clean === "encription" || clean === "saved") {{
        resolved = "network";
      }} else if (clean === "apps") {{
        resolved = loadPreferredAppsLayoutView();
      }} else if (isAppsLayoutView(clean)) {{
        resolved = clean;
      }} else if (!knownLayoutViews.has(clean)) {{
        resolved = "chat";
      }}
      if (resolved === "files" && !fileTransferFeatureEnabled) {{
        resolved = "games";
      }}

      // Public v0 rail: expose only Chat/Network/Console/Games/Files/Settings.
      return (
        resolved === "chat"
        || resolved === "network"
        || resolved === "console"
        || resolved === "games"
        || (resolved === "files" && fileTransferFeatureEnabled)
        || resolved === "settings"
      )
        ? resolved
        : "chat";
    }}

    function isMapVisibleLayoutView(viewName) {{
      const view = normalizeLayoutView(viewName);
      return view === "saved" || (view === "network" && activeNetworkSubview === "map");
    }}

    function normalizeNetworkSubview(raw) {{
      const clean = String(raw || "").trim().toLowerCase();
      if (clean === "details") return "sensors";
      return clean === "overview" || clean === "graph" || clean === "sensors" ? clean : "map";
    }}

    function loadPreferredNetworkSubview() {{
      try {{
        const raw = window.localStorage.getItem(networkSubviewStorageKey) || "map";
        return normalizeNetworkSubview(raw);
      }} catch (_err) {{
        return "map";
      }}
    }}

    function persistPreferredNetworkSubview(subviewName) {{
      const next = normalizeNetworkSubview(subviewName);
      try {{
        window.localStorage.setItem(networkSubviewStorageKey, next);
      }} catch (_err) {{
      }}
    }}

    function syncMapControlsDock(viewName = activeLayoutView, subviewName = activeNetworkSubview) {{
      const dock = document.getElementById("map-controls-dock");
      const headerHost = document.getElementById("map-card-actions-host");
      const overlayHost = document.getElementById("network-map-controls-host");
      if (!(dock instanceof HTMLElement)) return;
      if (!(headerHost instanceof HTMLElement)) return;
      if (!(overlayHost instanceof HTMLElement)) return;

      const normalizedView = normalizeLayoutView(viewName);
      const normalizedSubview = normalizeNetworkSubview(subviewName);
      const useOverlayDock = normalizedView === "network";
      const targetHost = useOverlayDock ? overlayHost : headerHost;
      if (dock.parentElement !== targetHost) {{
        targetHost.appendChild(dock);
      }}

      headerHost.hidden = useOverlayDock;
      headerHost.setAttribute("aria-hidden", useOverlayDock ? "true" : "false");
      overlayHost.classList.toggle("is-hidden", !useOverlayDock || normalizedSubview !== "map");
      overlayHost.setAttribute(
        "aria-hidden",
        (!useOverlayDock || normalizedSubview !== "map") ? "true" : "false"
      );
    }}

    function syncEnvironmentMetricsDock(viewName = activeLayoutView, subviewName = activeNetworkSubview) {{
      const explorer = document.querySelector(".env-metrics-explorer");
      const homeHost = document.getElementById("environment-metrics-home");
      const networkHost = document.getElementById("network-sensors-host");
      if (!(explorer instanceof HTMLElement)) return;
      if (!(homeHost instanceof HTMLElement)) return;
      if (!(networkHost instanceof HTMLElement)) return;

      const normalizedView = normalizeLayoutView(viewName);
      const normalizedSubview = normalizeNetworkSubview(subviewName);
      const dockInNetwork = normalizedView === "network" && normalizedSubview === "sensors";
      const targetHost = dockInNetwork ? networkHost : homeHost;
      if (explorer.parentElement !== targetHost) {{
        targetHost.appendChild(explorer);
      }}
    }}

    function setActiveNetworkSubview(subviewName, options = {{}}) {{
      const next = normalizeNetworkSubview(subviewName);
      const persist = options && options.persist !== false;
      if (normalizeLayoutView(activeLayoutView) === "network" && next === "graph") {{
        networkGraphViewState.pendingEntryViewportSync = true;
      }} else {{
        clearNetworkGraphEmptyRetry();
      }}
      activeNetworkSubview = next;

      const normalizedView = normalizeLayoutView(activeLayoutView);
      const showTabbedSubview = normalizedView === "network";
      const showMapPanel = !showTabbedSubview || next === "map";
      const root = document.getElementById("network-map-subviews");
      if (root instanceof HTMLElement) {{
        root.dataset.activeSubview = next;
      }}

      for (const btn of document.querySelectorAll(".network-map-subview-tab")) {{
        if (!(btn instanceof HTMLButtonElement)) continue;
        const tabName = normalizeNetworkSubview(btn.dataset.networkSubview || "map");
        const isActive = tabName === next;
        btn.classList.toggle("is-active", isActive);
        btn.setAttribute("aria-selected", isActive ? "true" : "false");
        btn.tabIndex = isActive ? 0 : -1;
      }}

      for (const panel of document.querySelectorAll(".network-map-subview-panel")) {{
        if (!(panel instanceof HTMLElement)) continue;
        const panelName = normalizeNetworkSubview(panel.dataset.networkSubviewPanel || "map");
        const isActive = showTabbedSubview ? panelName === next : panelName === "map";
        panel.hidden = !isActive;
        panel.classList.toggle("is-active", isActive);
      }}

      syncMapControlsDock(activeLayoutView, next);
      syncEnvironmentMetricsDock(activeLayoutView, next);

      try {{
        if (typeof setMapWheelZoomActive === "function") {{
          setMapWheelZoomActive(isMapVisibleLayoutView(activeLayoutView));
        }}
      }} catch (_err) {{
      }}

      if (persist) {{
        persistPreferredNetworkSubview(next);
      }}

      if (
        normalizedView === "network"
        && next !== "map"
        && latestState
        && typeof renderChatNodeNavigatorList === "function"
      ) {{
        renderChatNodeNavigatorList(latestState);
      }}

      if (normalizedView === "network" && next === "overview") {{
        if (typeof refreshNetworkOverviewPanels === "function") {{
          void refreshNetworkOverviewPanels(false);
        }}
      }}
      if (normalizedView === "network" && next === "graph") {{
        if (typeof renderNetworkGraphView === "function") {{
          renderNetworkGraphView(latestState);
        }}
      }}
      if (normalizedView === "network" && next === "sensors") {{
        if (typeof renderEnvironmentMetricsView === "function") {{
          void renderEnvironmentMetricsView(false);
        }}
      }}

      if (showMapPanel && (normalizedView === "network" || normalizedView === "saved")) {{
        if (typeof requestMapResizeNow === "function") {{
          requestMapResizeNow();
        }}
        if (typeof requestMapResizeStabilized === "function") {{
          requestMapResizeStabilized();
        }} else if (typeof requestMapResize === "function") {{
          requestMapResize();
        }}
      }}
    }}

    function bindNetworkSubviewTabs() {{
      for (const btn of document.querySelectorAll(".network-map-subview-tab")) {{
        if (!(btn instanceof HTMLButtonElement) || btn.dataset.bound === "1") continue;
        btn.dataset.bound = "1";
        btn.addEventListener("click", () => {{
          setActiveNetworkSubview(btn.dataset.networkSubview || "map", {{ persist: true }});
        }});
      }}
    }}

    function networkGraphNodeDisplayName(nodeId, nodeMap) {{
      const clean = normalizeNodeId(nodeId || "");
      const node = nodeMap instanceof Map ? (nodeMap.get(clean) || null) : null;
      const cachedName = (typeof nodeNameCache !== "undefined" && nodeNameCache instanceof Map)
        ? nodeNameCache.get(clean)
        : "";
      return String(preferredNodeName(node) || cachedName || clean || "Unknown node");
    }}

    function truncateNetworkGraphLabel(rawValue, maxLength = 18) {{
      const text = String(rawValue == null ? "" : rawValue).trim();
      if (!text) return "";
      if (text.length <= maxLength) return text;
      return `${{text.slice(0, Math.max(1, maxLength - 3)).trimEnd()}}...`;
    }}

    const networkGraphPacketFromIdKeys = ["from_id", "fromId", "from", "source_id", "sourceId", "source", "from_num", "fromNum"];
    const networkGraphPacketToIdKeys = ["to_id", "toId", "to", "dest_id", "destId", "destination", "dest", "to_num", "toNum"];

    function resolveNetworkGraphPacketNodeId(packet, keys, nodeIdByNum) {{
      const safePacket = (packet && typeof packet === "object") ? packet : null;
      const safeKeys = Array.isArray(keys) ? keys : [];
      const numericLookup = nodeIdByNum instanceof Map ? nodeIdByNum : new Map();
      for (const key of safeKeys) {{
        const rawValue = safePacket ? safePacket[key] : null;
        const clean = normalizeNodeId(rawValue);
        if (isCanonicalNodeId(clean) || clean === "^all" || clean === "local") {{
          return clean;
        }}
        const nodeNum = parseNodeNum(rawValue);
        if (Number.isInteger(nodeNum) && numericLookup.has(nodeNum)) {{
          return normalizeNodeId(numericLookup.get(nodeNum) || "");
        }}
      }}
      return "";
    }}

    function buildNetworkGraphNodeSignalMeta(nodeMap, recentPackets) {{
      const signalMeta = new Map();
      const nodeIdByNum = new Map();
      for (const [nodeId, node] of (nodeMap instanceof Map ? nodeMap.entries() : [])) {{
        const nodeNum = parseNodeNum(node && node.num);
        if (Number.isInteger(nodeNum) && nodeNum >= 0 && !nodeIdByNum.has(nodeNum)) {{
          nodeIdByNum.set(nodeNum, nodeId);
        }}
        const lastHeardRaw = Number(node && (node.last_heard_unix ?? node.last_heard_epoch ?? 0));
        const lastHeardUnix = Number.isFinite(lastHeardRaw) && lastHeardRaw > 0
          ? Math.trunc(lastHeardRaw)
          : 0;
        const savedPacketsRaw = Number(node && node.saved_packets);
        const savedPackets = Number.isFinite(savedPacketsRaw)
          ? Math.max(0, Math.trunc(savedPacketsRaw))
          : 0;
        const hopsRaw = Number(node && node.hops_away);
        const hopsAway = Number.isFinite(hopsRaw) ? Math.trunc(hopsRaw) : null;
        signalMeta.set(nodeId, {{
          packetCount: 0,
          broadcastPacketCount: 0,
          directTargetCount: 0,
          incomingDirectCount: 0,
          lastPortnum: "",
          lastHeardUnix,
          savedPackets,
          hopsAway,
        }});
      }}

      const ensureSignal = (nodeId) => {{
        const clean = normalizeNodeId(nodeId || "");
        if (!isCanonicalNodeId(clean) || !(nodeMap instanceof Map) || !nodeMap.has(clean)) return null;
        if (!signalMeta.has(clean)) {{
          signalMeta.set(clean, {{
            packetCount: 0,
            broadcastPacketCount: 0,
            directTargetCount: 0,
            incomingDirectCount: 0,
            lastPortnum: "",
            lastHeardUnix: 0,
            savedPackets: 0,
            hopsAway: null,
          }});
        }}
        return signalMeta.get(clean) || null;
      }};

      for (const packet of (Array.isArray(recentPackets) ? recentPackets : [])) {{
        if (!(packet && typeof packet === "object")) continue;
        const fromId = resolveNetworkGraphPacketNodeId(packet, networkGraphPacketFromIdKeys, nodeIdByNum);
        const toId = resolveNetworkGraphPacketNodeId(packet, networkGraphPacketToIdKeys, nodeIdByNum);
        const portnum = String((packet.portnum ?? packet.portNum ?? "") || "").trim();
        const fromSignal = ensureSignal(fromId);
        if (fromSignal) {{
          fromSignal.packetCount += 1;
          if (portnum) {{
            fromSignal.lastPortnum = portnum;
          }}
          if (isCanonicalNodeId(toId) && toId !== fromId) {{
            fromSignal.directTargetCount += 1;
          }} else {{
            fromSignal.broadcastPacketCount += 1;
          }}
        }}
        if (isCanonicalNodeId(toId) && toId !== fromId) {{
          const toSignal = ensureSignal(toId);
          if (toSignal) {{
            toSignal.incomingDirectCount += 1;
          }}
        }}
      }}

      const nowUnix = Math.floor(Date.now() / 1000);
      for (const [nodeId, meta] of signalMeta.entries()) {{
        const lastHeardUnix = Number(meta.lastHeardUnix || 0);
        const isFreshByNodeState = !!(
          Number.isFinite(lastHeardUnix)
          && lastHeardUnix > 0
          && Math.max(0, nowUnix - lastHeardUnix) <= networkGraphBroadcastOnlyFreshnessSeconds
        );
        meta.hasBroadcastOnlyEvidence = !!(
          meta.broadcastPacketCount > 0
          && meta.directTargetCount <= 0
          && meta.incomingDirectCount <= 0
        );
        meta.hasNodeStateBroadcastHint = !!(
          isFreshByNodeState
          && Number(meta.savedPackets || 0) > 0
          && Number.isFinite(Number(meta.hopsAway))
          && Number(meta.hopsAway) >= 0
        );
        signalMeta.set(nodeId, meta);
      }}
      return signalMeta;
    }}

    const networkGraphViewportBase = Object.freeze({{ x: 0, y: 0, width: 960, height: 620 }});
    const networkGraphZoomBounds = Object.freeze({{ minScale: 0.62, maxScale: 5.5 }});
    const networkGraphFocusAnimationDurationMs = 680;
    const networkGraphRootHistoryLimit = 48;
    const networkGraphBroadcastOnlyFreshnessSeconds = 2 * 60 * 60;
    const networkGraphViewState = {{
      initialized: false,
      lastRootId: "",
      pendingEntryViewportSync: false,
      bounds: {{
        minX: networkGraphViewportBase.x,
        minY: networkGraphViewportBase.y,
        maxX: networkGraphViewportBase.x + networkGraphViewportBase.width,
        maxY: networkGraphViewportBase.y + networkGraphViewportBase.height,
      }},
      viewBox: {{ ...networkGraphViewportBase }},
      pointerId: null,
      pointerClientX: 0,
      pointerClientY: 0,
      pointerViewBox: null,
      pointerDownNodeId: "",
      captureActive: false,
      dragging: false,
      suppressClick: false,
      suppressClickTimer: null,
      animationFrame: null,
      sceneAnimationFrame: null,
      emptyRetryTimer: null,
      emptyRetryCount: 0,
      renderedPositions: new Map(),
      renderedLayoutSnapshot: null,
      pendingFocusTransition: null,
    }};

    function cloneNetworkGraphViewBox(rawViewBox = networkGraphViewportBase) {{
      const fallback = networkGraphViewportBase;
      const source = (rawViewBox && typeof rawViewBox === "object") ? rawViewBox : fallback;
      const x = Number(source.x);
      const y = Number(source.y);
      const width = Number(source.width);
      const height = Number(source.height);
      return {{
        x: Number.isFinite(x) ? x : fallback.x,
        y: Number.isFinite(y) ? y : fallback.y,
        width: Number.isFinite(width) && width > 0 ? width : fallback.width,
        height: Number.isFinite(height) && height > 0 ? height : fallback.height,
      }};
    }}

    function isNetworkGraphPointVisible(viewBox, x, y, paddingRatio = 0.08) {{
      const safeViewBox = cloneNetworkGraphViewBox(viewBox);
      const padX = safeViewBox.width * Math.max(0, Number(paddingRatio) || 0);
      const padY = safeViewBox.height * Math.max(0, Number(paddingRatio) || 0);
      return (
        Number.isFinite(Number(x))
        && Number.isFinite(Number(y))
        && Number(x) >= (safeViewBox.x + padX)
        && Number(x) <= ((safeViewBox.x + safeViewBox.width) - padX)
        && Number(y) >= (safeViewBox.y + padY)
        && Number(y) <= ((safeViewBox.y + safeViewBox.height) - padY)
      );
    }}

    function defaultNetworkGraphBounds() {{
      return {{
        minX: networkGraphViewportBase.x,
        minY: networkGraphViewportBase.y,
        maxX: networkGraphViewportBase.x + networkGraphViewportBase.width,
        maxY: networkGraphViewportBase.y + networkGraphViewportBase.height,
      }};
    }}

    function getNetworkGraphStageAspectRatio(svg = null) {{
      if (svg instanceof SVGElement) {{
        const rect = svg.getBoundingClientRect();
        if (rect.width > 0 && rect.height > 0) {{
          return rect.width / rect.height;
        }}
      }}
      const current = cloneNetworkGraphViewBox(networkGraphViewState.viewBox);
      if (current.width > 0 && current.height > 0) {{
        return current.width / current.height;
      }}
      return networkGraphViewportBase.width / networkGraphViewportBase.height;
    }}

    function prefersReducedMotion() {{
      return !!(
        typeof window !== "undefined"
        && typeof window.matchMedia === "function"
        && window.matchMedia("(prefers-reduced-motion: reduce)").matches
      );
    }}

    function cancelNetworkGraphViewAnimation() {{
      if (networkGraphViewState.animationFrame !== null) {{
        window.cancelAnimationFrame(networkGraphViewState.animationFrame);
      }}
      networkGraphViewState.animationFrame = null;
    }}

    function cancelNetworkGraphSceneAnimation() {{
      if (networkGraphViewState.sceneAnimationFrame !== null) {{
        window.cancelAnimationFrame(networkGraphViewState.sceneAnimationFrame);
      }}
      networkGraphViewState.sceneAnimationFrame = null;
    }}

    function clearNetworkGraphEmptyRetry() {{
      if (networkGraphViewState.emptyRetryTimer !== null) {{
        clearTimeout(networkGraphViewState.emptyRetryTimer);
      }}
      networkGraphViewState.emptyRetryTimer = null;
      networkGraphViewState.emptyRetryCount = 0;
    }}

    function scheduleNetworkGraphEmptyRetry() {{
      if (
        networkGraphViewState.emptyRetryTimer !== null
        || networkGraphViewState.emptyRetryCount >= 4
      ) {{
        return;
      }}
      const retryDelayMs = 140 + (networkGraphViewState.emptyRetryCount * 180);
      networkGraphViewState.emptyRetryCount += 1;
      networkGraphViewState.emptyRetryTimer = window.setTimeout(() => {{
        networkGraphViewState.emptyRetryTimer = null;
        if (
          activeLayoutView === "network"
          && activeNetworkSubview === "graph"
          && typeof renderNetworkGraphView === "function"
        ) {{
          renderNetworkGraphView(latestState);
        }}
      }}, retryDelayMs);
    }}

    function easeNetworkGraphAnimationProgress(progress) {{
      const safeProgress = Math.min(1, Math.max(0, Number(progress) || 0));
      return 1 - Math.pow(1 - safeProgress, 3);
    }}

    function interpolateNetworkGraphViewBox(fromViewBox, toViewBox, progress) {{
      const from = cloneNetworkGraphViewBox(fromViewBox);
      const to = cloneNetworkGraphViewBox(toViewBox);
      const ratio = Math.min(1, Math.max(0, Number(progress) || 0));
      return {{
        x: from.x + ((to.x - from.x) * ratio),
        y: from.y + ((to.y - from.y) * ratio),
        width: from.width + ((to.width - from.width) * ratio),
        height: from.height + ((to.height - from.height) * ratio),
      }};
    }}

    function buildNetworkGraphSceneMarkup(scene) {{
      const safeScene = (scene && typeof scene === "object") ? scene : {{}};
      const rootId = normalizeNodeId(safeScene.rootId || "");
      const selectedId = normalizeNodeId(safeScene.selectedId || "");
      const nodeMap = safeScene.nodeMap instanceof Map ? safeScene.nodeMap : new Map();
      const positions = safeScene.positions instanceof Map ? safeScene.positions : new Map();
      const rings = Array.isArray(safeScene.rings) ? safeScene.rings : [];
      const edges = Array.isArray(safeScene.edges) ? safeScene.edges : [];
      const items = Array.isArray(safeScene.items) ? safeScene.items : [];

      const ringMarkup = rings.map((ring) => `
        <g class="network-graph-ring-wrap">
          <circle class="network-graph-ring${{ring.detached ? " is-detached" : ""}}${{ring.broadcastOnly ? " is-broadcast-only" : ""}}" cx="480" cy="310" r="${{Number(ring.radius).toFixed(1)}}"></circle>
          <text class="network-graph-ring-label" x="480" y="${{(310 - Number(ring.radius) - 8).toFixed(1)}}" text-anchor="middle">${{escAttr(ring.label)}}</text>
        </g>
      `).join("");

      const edgeMarkup = edges.map((edge) => {{
        const fromPos = positions.get(edge.a);
        const toPos = positions.get(edge.b);
        if (!fromPos || !toPos) return "";
        const classes = [
          "network-graph-edge",
          edge.isReal ? "is-real" : "is-observed",
          (edge.a === rootId || edge.b === rootId) ? "is-root-link" : "",
        ].filter(Boolean).join(" ");
        const width = Math.max(1.1, Math.min(5.2, 1.2 + (Math.log2(Math.max(1, edge.weight) + 1) * 0.85) + (edge.isReal ? 0.35 : 0)));
        const fromLabel = networkGraphNodeDisplayName(edge.a, nodeMap);
        const toLabel = networkGraphNodeDisplayName(edge.b, nodeMap);
        const lastAgeLabel = Number.isFinite(edge.lastSeenUnix) && edge.lastSeenUnix > 0
          ? (
            typeof formatIdleAge === "function"
              ? formatIdleAge(edge.lastSeenUnix, Math.floor(Date.now() / 1000))
              : `${{Math.max(0, Math.floor((Date.now() / 1000) - edge.lastSeenUnix))}}s ago`
          )
          : (edge.lastSeenLabel || "n/a");
        const edgeTitle = [
          `${{fromLabel}} <-> ${{toLabel}}`,
          `Packets: ${{Math.round(edge.weight)}}`,
          `Directions observed: ${{edge.directionCount}}`,
          `Last seen: ${{lastAgeLabel}}`,
          `Avg hops: ${{edge.avgHops == null ? "n/a" : edge.avgHops}}`,
        ].join("\n");
        return `
          <line
            class="${{classes}}"
            x1="${{Number(fromPos.x).toFixed(1)}}"
            y1="${{Number(fromPos.y).toFixed(1)}}"
            x2="${{Number(toPos.x).toFixed(1)}}"
            y2="${{Number(toPos.y).toFixed(1)}}"
            style="stroke-width:${{width.toFixed(2)}}"
          >
            <title>${{escAttr(edgeTitle)}}</title>
          </line>
        `;
      }}).join("");

      const nodeMarkup = items.map((item) => {{
        const classes = [
          "network-graph-node",
          item.nodeId === rootId ? "is-root" : "",
          item.nodeId === selectedId ? "is-selected" : "",
          item.detached ? "is-detached" : "",
          item.broadcastOnly ? "is-broadcast-only" : "",
        ].filter(Boolean).join(" ");
        const displayName = networkGraphNodeDisplayName(item.nodeId, nodeMap);
        const label = truncateNetworkGraphLabel(displayName, item.layer === 0 ? 28 : 16);
        const statusLine = item.broadcastOnly
          ? (
            item.nodeId === rootId
              ? "Heard recently via broadcast only"
              : "No explicit node link, only recent broadcast evidence"
          )
          : item.detached
          ? "No current path from the root"
          : (item.layer === 0 ? "Root node" : `${{item.layer}} hop${{item.layer === 1 ? "" : "s"}} away`);
        const title = [
          displayName,
          item.nodeId,
          statusLine,
          `Visible links: ${{item.degree}}`,
          `Observed packets on links: ${{Math.round(item.weight)}}`,
          item.signalMeta && item.broadcastOnly
            ? (
              Number(item.signalMeta.broadcastPacketCount || 0) > 0
                ? `Recent broadcast packets: ${{item.signalMeta.broadcastPacketCount}}${{item.signalMeta.lastPortnum ? ` (${{item.signalMeta.lastPortnum}})` : ""}}`
                : `Saved heard packets: ${{Math.max(0, Math.trunc(Number(item.signalMeta.savedPackets) || 0))}}, hops away: ${{Number.isFinite(Number(item.signalMeta.hopsAway)) ? Math.trunc(Number(item.signalMeta.hopsAway)) : "n/a"}}`
            )
            : "",
          `Last heard: ${{(item.node && item.node.last_heard) || "n/a"}}`,
        ].filter(Boolean).join("\n");
        return `
          <g
            class="${{classes}}"
            data-network-graph-node-id="${{escAttr(item.nodeId)}}"
            transform="translate(${{Number(item.x).toFixed(1)}} ${{Number(item.y).toFixed(1)}})"
          >
            <circle class="network-graph-node-core" r="${{Number(item.radius).toFixed(1)}}"></circle>
            ${{
              item.showLabel
