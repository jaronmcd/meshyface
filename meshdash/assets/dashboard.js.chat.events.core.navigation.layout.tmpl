      networkGraphViewState.pointerClientY = 0;
      networkGraphViewState.pointerViewBox = null;
      networkGraphViewState.pinchStartDistance = 0;
      networkGraphViewState.pinchStartCenterClientX = 0;
      networkGraphViewState.pinchStartCenterClientY = 0;
