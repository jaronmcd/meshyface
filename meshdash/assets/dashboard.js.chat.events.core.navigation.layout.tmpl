      const localNodeId = normalizeNodeId(options && options.localNodeId || "");
      const rootId = normalizeNodeId(options && options.rootId || "");
      const seenNodeIds = new Set();
      const candidates = [];
      const appendCandidate = (nodeId, broadcastOnly) => {{
        const cleanNodeId = normalizeNodeId(nodeId || "");
        if (!cleanNodeId || seenNodeIds.has(cleanNodeId)) return;
        seenNodeIds.add(cleanNodeId);
        candidates.push({{
          nodeId: cleanNodeId,
          broadcastOnly: !!broadcastOnly,
          preserve: !!(
            cleanNodeId === selectedId
            || cleanNodeId === localNodeId
            || cleanNodeId === rootId
