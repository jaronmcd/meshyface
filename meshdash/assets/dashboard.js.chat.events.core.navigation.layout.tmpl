          layer: Number(position.layer || 0),
          disconnected: !!position.disconnected,
          detached: !!position.disconnected && !position.broadcastOnly,
          broadcastOnly: !!position.broadcastOnly,
          degree: meta.degree,
          weight: meta.weight,
          signalMeta,
          radius: position.disconnected ? Math.max(5, baseRadius - 0.7) : baseRadius,
          labelOffsetY: (
            position.labelOffsetY == null
            || position.labelOffsetY === ""
            || !Number.isFinite(Number(position.labelOffsetY))
          )
            ? null
            : Number(position.labelOffsetY),
          showLabel: visibleLabelNodeIds.has(nodeId),
        }};
      }});

      return {{
        rootId,
        layoutMode,
        adjacency,
        degreeMeta,
        items,
        positions,
        layers,
        rings,
        regions,
        edges: combinedEdges,
        signalMetaByNodeId,
        connectedCount,
        broadcastOnlyCount: visibleBroadcastOnlyDisconnected.length
          + (
            positions.get(rootId) && positions.get(rootId).broadcastOnly
