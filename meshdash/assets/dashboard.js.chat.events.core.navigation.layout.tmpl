      const shouldAnimate = !(
        options
        && options.animate === false
      ) && networkGraphViewState.initialized && durationMs >= 32 && !prefersReducedMotion();
      if (
        current.x === target.x
        && current.y === target.y
        && current.width === target.width
        && current.height === target.height
      ) {{
        const applied = applyNetworkGraphViewBox(svg, target);
        if (onComplete) {{
          onComplete(cloneNetworkGraphViewBox(applied));
        }}
        return applied;
      }}
      if (!shouldAnimate) {{
        const applied = applyNetworkGraphViewBox(svg, target);
        if (onComplete) {{
          onComplete(cloneNetworkGraphViewBox(applied));
        }}
        return applied;
      }}
      cancelNetworkGraphViewAnimation();
      const startViewBox = cloneNetworkGraphViewBox(current);
      const startTime = performance.now();
      const step = (now) => {{
        const progress = durationMs <= 0 ? 1 : Math.min(1, (now - startTime) / durationMs);
        const nextViewBox = interpolateNetworkGraphViewBox(
          startViewBox,
          target,
          easeNetworkGraphAnimationProgress(progress)
