        if (!routeKey) continue;
        for (const segment of pathSegments) {{
          if (!segment || !segment.edgeKey) continue;
          if (!segmentsByEdgeKey.has(segment.edgeKey)) {{
            segmentsByEdgeKey.set(segment.edgeKey, []);
          }}
          segmentsByEdgeKey.get(segment.edgeKey).push({{
            ...segment,
            sourceId: routeStartId,
            targetId: taggedItem.nodeId,
            routeKey,
            hopCount,
            presetId: taggedItem.presetId,
            color: taggedItem.color,
            label: taggedItem.label,
          }});
        }}
      }}
      const routeSegments = [];
      for (const stack of segmentsByEdgeKey.values()) {{
        const stackCount = stack.length;
        stack.forEach((segment, stackIndex) => {{
          routeSegments.push({{
            ...segment,
            stackCount,
            stackIndex,
          }});
        }});
      }}
      return routeSegments;
    }}

    function networkGraphTagRoutePresetIsVisible(presetId) {{
      const cleanPresetId = normalizeNetworkGraphTagRoutePresetId(presetId);
      if (!cleanPresetId) return true;
      const hiddenIds = networkGraphViewState.hiddenTagRoutePresetIds instanceof Set
        ? networkGraphViewState.hiddenTagRoutePresetIds
        : new Set();
      return !hiddenIds.has(cleanPresetId);
