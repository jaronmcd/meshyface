    function positionFloatingPanelNearAnchor(panel, anchor, options = {{}}) {{
      if (!(panel instanceof HTMLElement) || !(anchor instanceof HTMLElement)) return false;
      const viewportWidth = Math.max(0, window.innerWidth || document.documentElement.clientWidth || 0);
      const viewportHeight = Math.max(0, window.innerHeight || document.documentElement.clientHeight || 0);
      if (viewportWidth <= 0 || viewportHeight <= 0) return false;

      const margin = Math.max(0, Number(options.margin) || 8);
      const gap = Math.max(0, Number(options.gap) || 8);
      const alignX = String(options.alignX || "left").trim().toLowerCase();
      const preferY = String(options.preferY || "below").trim().toLowerCase();
      const minWidth = Number(options.minWidth);
      const zIndex = Number(options.zIndex);

      panel.hidden = false;
      panel.style.position = "fixed";
      panel.style.left = `${{margin}}px`;
      panel.style.top = `${{margin}}px`;
      panel.style.right = "auto";
      panel.style.bottom = "auto";
      panel.style.visibility = "hidden";
      panel.style.maxHeight = `${{Math.max(80, viewportHeight - (margin * 2))}}px`;
      if (Number.isFinite(minWidth) && minWidth > 0) {{
        panel.style.minWidth = `${{Math.round(minWidth)}}px`;
      }}
      if (Number.isFinite(zIndex) && zIndex > 0) {{
        panel.style.zIndex = String(Math.round(zIndex));
      }}

      const anchorRect = anchor.getBoundingClientRect();
      const panelRect = panel.getBoundingClientRect();
      const width = Math.max(0, Math.ceil(panelRect.width));
      const height = Math.max(0, Math.ceil(panelRect.height));
      const maxLeft = Math.max(margin, viewportWidth - width - margin);
      const maxTop = Math.max(margin, viewportHeight - height - margin);

      let left = anchorRect.left;
      if (alignX === "right") {{
        left = anchorRect.right - width;
      }} else if (alignX === "center") {{
        left = anchorRect.left + ((anchorRect.width - width) / 2);
      }} else if (alignX === "after") {{
        const preferred = anchorRect.right + gap;
        const fallback = anchorRect.left - width - gap;
        left = preferred;
        if ((preferred + width + margin) > viewportWidth && fallback >= margin) {{
          left = fallback;
        }}
      }} else if (alignX === "before") {{
        const preferred = anchorRect.left - width - gap;
        const fallback = anchorRect.right + gap;
        left = preferred;
        if (preferred < margin && (fallback + width + margin) <= viewportWidth) {{
          left = fallback;
        }}
      }}

      let top = preferY === "above"
        ? (anchorRect.top - height - gap)
        : (anchorRect.bottom + gap);
      if (preferY === "above") {{
        if (top < margin && (anchorRect.bottom + gap + height + margin) <= viewportHeight) {{
          top = anchorRect.bottom + gap;
        }}
      }} else if ((top + height + margin) > viewportHeight && (anchorRect.top - gap - height) >= margin) {{
        top = anchorRect.top - height - gap;
      }}

      left = Math.min(Math.max(margin, Math.round(left)), maxLeft);
      top = Math.min(Math.max(margin, Math.round(top)), maxTop);

      panel.style.left = `${{left}}px`;
      panel.style.top = `${{top}}px`;
      panel.style.visibility = "";
      return true;
    }}

