    function networkTopNodesPacketType(portnumRaw) {{
      const portnum = String(portnumRaw || "").trim().toUpperCase();
      if (!portnum) return "encrypted";
      if (portnum === "TEXT_MESSAGE_APP") return "chat";
      if (portnum === "TELEMETRY_APP") return "telemetry";
      if (portnum === "POSITION_APP") return "position";
      if (portnum === "ROUTING_APP") return "routing";
      if (portnum === "STORE_FORWARD_APP") return "storeforward";
      if (portnum === "NODEINFO_APP") return "nodeinfo";
      if (portnum === "ADMIN_APP") return "admin";
      return "other";
    }}

    function networkTopNodesPacketSummary(entry) {{
      const safeEntry = (entry && typeof entry === "object") ? entry : {{}};
      const summary = (safeEntry.summary && typeof safeEntry.summary === "object") ? safeEntry.summary : {{}};
      const packet = (safeEntry.packet && typeof safeEntry.packet === "object") ? safeEntry.packet : safeEntry;
      const decoded = (packet.decoded && typeof packet.decoded === "object") ? packet.decoded : {{}};
      const fromId = normalizeNodeId(
        summary.from
        ?? summary.from_id
        ?? summary.fromId
        ?? packet.fromId
        ?? packet.from_id
        ?? packet.from
        ?? ""
      );
      const toId = normalizeNodeId(
        summary.to
        ?? summary.to_id
        ?? summary.toId
        ?? packet.toId
        ?? packet.to_id
        ?? packet.to
        ?? packet.destination
        ?? ""
      );
      const portnum = String(
        summary.portnum
        ?? decoded.portnum
        ?? packet.portnum
        ?? ""
      ).trim();
      const unixRaw = Number(
        summary.rx_time_unix
        ?? summary.time_unix
        ?? packet.rxTime
        ?? packet.rx_time
        ?? 0
      );
      const lastSeenUnix = Number.isFinite(unixRaw) && unixRaw > 0 ? Math.trunc(unixRaw) : 0;
      return {{
        fromId,
        toId,
        portnum,
        packetType: networkTopNodesPacketType(portnum),
        lastSeenUnix,
      }};
    }}

    function networkTopNodesAddCount(map, nodeId, amount = 1, options = {{}}) {{
      const clean = normalizeNodeId(nodeId || "");
      if (!isSelectableNodeId(clean)) return null;
      const increment = Math.max(0, Math.trunc(Number(amount) || 0));
      if (increment <= 0) return null;
      let item = map.get(clean);
      if (!item) {{
        item = {{
          node_id: clean,
          value: 0,
          secondary_value: 0,
          last_seen_unix: 0,
        }};
        map.set(clean, item);
      }}
      item.value += increment;
      const secondary = Math.max(0, Math.trunc(Number(options.secondaryValue) || 0));
      if (secondary > 0) {{
        item.secondary_value = Math.max(Math.trunc(Number(item.secondary_value) || 0), secondary);
      }}
      const lastSeen = Math.trunc(Number(options.lastSeenUnix) || 0);
      if (lastSeen > 0) {{
        item.last_seen_unix = Math.max(Math.trunc(Number(item.last_seen_unix) || 0), lastSeen);
      }}
      return item;
    }}

    function networkTopNodesItemsFromMap(map, limit = 10) {{
      return Array.from(map.values())
        .filter((item) => Number(item && item.value) > 0)
        .sort((a, b) => {{
          const valueDiff = (Number(b.value) || 0) - (Number(a.value) || 0);
          if (Math.abs(valueDiff) > 1e-9) return valueDiff;
          const timeDiff = (Number(b.last_seen_unix) || 0) - (Number(a.last_seen_unix) || 0);
          if (timeDiff) return timeDiff;
          return String(a.node_id || "").localeCompare(String(b.node_id || ""));
        }})
        .slice(0, Math.max(1, Math.trunc(Number(limit) || 10)))
        .map((item, idx) => ({{
          ...item,
          rank: idx + 1,
        }}));
    }}

    function buildLocalNetworkTopNodesPayload(category, state = latestState) {{
      const cleanCategory = normalizeNetworkTopNodesCategory(category);
      const def = networkTopNodesCategoryDef(cleanCategory);
      const safeState = (state && typeof state === "object") ? state : {{}};
      if (cleanCategory === "all") {{
        const groups = networkTopNodesCategoryDefs
          .filter((entry) => entry && entry.id && entry.id !== "all")
          .map((entry) => buildLocalNetworkTopNodesPayload(entry.id, safeState));
        const itemCount = groups.reduce((sum, group) => {{
          const items = Array.isArray(group && group.items) ? group.items : [];
          return sum + items.length;
        }}, 0);
        return {{
          ok: true,
          category: cleanCategory,
          category_label: def.label,
          unit: def.unit,
          source: "current state",
          limit: 10,
          groups,
          item_count: itemCount,
          items: [],
          fallback: true,
        }};
      }}
      const nodes = Array.isArray(safeState.nodes) ? safeState.nodes : [];
      const traffic = (safeState.traffic && typeof safeState.traffic === "object") ? safeState.traffic : {{}};
      const edges = Array.isArray(traffic.edges) ? traffic.edges : [];
      const packets = Array.isArray(traffic.recent_packets) ? traffic.recent_packets : [];
      const counts = new Map();

      if (cleanCategory === "saved_packets") {{
        for (const node of nodes) {{
          networkTopNodesAddCount(counts, node && node.id, node && node.saved_packets, {{
            secondaryValue: node && node.saved_points,
            lastSeenUnix: node && node.last_heard_unix,
          }});
        }}
      }} else if (cleanCategory === "gps_positions") {{
        for (const node of nodes) {{
          const hasPosition = Number.isFinite(Number(node && node.lat)) && Number.isFinite(Number(node && node.lon));
          if (!hasPosition) continue;
          networkTopNodesAddCount(counts, node && node.id, 1, {{
            lastSeenUnix: node && node.last_heard_unix,
          }});
        }}
      }} else if (cleanCategory === "links" || cleanCategory === "link_packets") {{
        const peersByNode = new Map();
        const linkPacketsByNode = new Map();
        const lastSeenByNode = new Map();
        const addPeer = (nodeId, peerId, packetCount, lastSeenUnix) => {{
          const cleanNode = normalizeNodeId(nodeId || "");
          const cleanPeer = normalizeNodeId(peerId || "");
          if (!isSelectableNodeId(cleanNode) || !isSelectableNodeId(cleanPeer)) return;
          if (!peersByNode.has(cleanNode)) peersByNode.set(cleanNode, new Set());
          peersByNode.get(cleanNode).add(cleanPeer);
          linkPacketsByNode.set(
            cleanNode,
            Math.max(0, Math.trunc(Number(linkPacketsByNode.get(cleanNode)) || 0)) + Math.max(0, Math.trunc(Number(packetCount) || 0))
          );
          const lastSeen = Math.trunc(Number(lastSeenUnix) || 0);
          if (lastSeen > 0) {{
            lastSeenByNode.set(cleanNode, Math.max(Math.trunc(Number(lastSeenByNode.get(cleanNode)) || 0), lastSeen));
          }}
        }};
        for (const edge of edges) {{
          const fromId = edge && edge.from;
          const toId = edge && edge.to;
          const packetCount = edge && (edge.lifetime_count ?? edge.count ?? edge.session_count);
          const lastSeen = edge && (edge.last_rx_unix ?? edge.last_seen_unix ?? edge.last_unix);
          addPeer(fromId, toId, packetCount, lastSeen);
          addPeer(toId, fromId, packetCount, lastSeen);
        }}
        for (const [nodeId, peers] of peersByNode.entries()) {{
          const packetCount = Math.max(0, Math.trunc(Number(linkPacketsByNode.get(nodeId)) || 0));
          networkTopNodesAddCount(
            counts,
            nodeId,
            cleanCategory === "links" ? peers.size : packetCount,
            {{
              secondaryValue: cleanCategory === "links" ? packetCount : peers.size,
              lastSeenUnix: lastSeenByNode.get(nodeId),
            }}
          );
        }}
      }} else {{
        const categoryTypeById = {{
          chat_packets: "chat",
          telemetry_packets: "telemetry",
          position_packets: "position",
          routing_packets: "routing",
          nodeinfo_packets: "nodeinfo",
          storeforward_packets: "storeforward",
          admin_packets: "admin",
          encrypted_packets: "encrypted",
          other_packets: "other",
          environment_metrics: "telemetry",
        }};
        const targetType = categoryTypeById[cleanCategory] || "";
        for (const entry of packets) {{
          const summary = networkTopNodesPacketSummary(entry);
          if (!isSelectableNodeId(summary.fromId)) continue;
          if (cleanCategory === "direct_packets") {{
            if (!isSelectableNodeId(summary.toId) || summary.toId === summary.fromId) continue;
            networkTopNodesAddCount(counts, summary.fromId, 1, {{
              secondaryValue: 1,
              lastSeenUnix: summary.lastSeenUnix,
            }});
            continue;
          }}
          if (targetType && summary.packetType !== targetType) continue;
          networkTopNodesAddCount(counts, summary.fromId, 1, {{
            lastSeenUnix: summary.lastSeenUnix,
          }});
        }}
      }}

      return {{
        ok: true,
        category: cleanCategory,
        category_label: def.label,
        unit: def.unit,
        source: "current state",
        limit: 10,
        items: networkTopNodesItemsFromMap(counts, 10),
        fallback: true,
      }};
    }}

    function networkTopNodesNodeMap(state = latestState) {{
      const safeState = (state && typeof state === "object") ? state : {{}};
      const nodes = Array.isArray(safeState.nodes) ? safeState.nodes : [];
      const out = new Map();
      for (const node of nodes) {{
        const nodeId = normalizeNodeId(node && node.id);
        if (isSelectableNodeId(nodeId) && !out.has(nodeId)) {{
          out.set(nodeId, node);
        }}
      }}
      return out;
    }}

    function networkTopNodesDisplayName(nodeId, state = latestState) {{
      const clean = normalizeNodeId(nodeId || "");
      const node = networkTopNodesNodeMap(state).get(clean) || null;
      const cached = (nodeNameCache instanceof Map) ? String(nodeNameCache.get(clean) || "").trim() : "";
      return String(preferredNodeName(node) || cached || clean || "Unknown node");
    }}

    function networkTopNodesTimeText(unixValue) {{
      const parsed = Math.trunc(Number(unixValue) || 0);
      if (parsed <= 0) return "";
      if (typeof formatLocalChatTime === "function") {{
        return formatLocalChatTime(parsed, "n/a");
      }}
      try {{
        return new Date(parsed * 1000).toLocaleString();
      }} catch (_err) {{
        return "";
      }}
    }}

    function networkTopNodesNumberText(value) {{
      const parsed = Number(value);
      if (!Number.isFinite(parsed)) return "0";
      try {{
        return Math.trunc(parsed).toLocaleString();
      }} catch (_err) {{
        return String(Math.trunc(parsed));
      }}
    }}

    function networkTopNodesUnitText(unit, value) {{
      const clean = String(unit || "").trim();
      if (!clean) return "";
      const count = Math.trunc(Number(value) || 0);
      if (count === 1) {{
        if (clean === "hours") return "hour";
        if (clean === "packets") return "packet";
        if (clean === "chats") return "chat";
        if (clean === "positions") return "position";
        if (clean === "samples") return "sample";
        if (clean === "links") return "link";
      }}
      return clean;
    }}

    function networkTopNodesMetaText(item, payload) {{
      const pieces = [];
      const secondary = Math.trunc(Number(item && item.secondary_value) || 0);
      const category = normalizeNetworkTopNodesCategory(payload && payload.category);
      if (secondary > 0) {{
        if (category === "saved_packets") {{
          pieces.push(`${{networkTopNodesNumberText(secondary)}} metric points`);
        }} else if (category === "links") {{
          pieces.push(`${{networkTopNodesNumberText(secondary)}} link packets`);
        }} else if (category === "link_packets") {{
          pieces.push(`${{networkTopNodesNumberText(secondary)}} linked nodes`);
        }} else if (category === "environment_metrics") {{
          pieces.push(`${{networkTopNodesNumberText(secondary)}} metric types`);
        }} else if (category === "direct_packets") {{
          pieces.push(`${{networkTopNodesNumberText(secondary)}} targets`);
        }}
      }}
      const seenText = networkTopNodesTimeText(item && item.last_seen_unix);
      if (seenText) {{
        pieces.push(`last ${{seenText}}`);
      }}
      return pieces.join(" - ");
    }}

    function networkTopNodesPayloadHasItems(payload) {{
      const safePayload = (payload && typeof payload === "object") ? payload : {{}};
      const items = Array.isArray(safePayload.items) ? safePayload.items : [];
      if (items.length > 0) return true;
      const groups = Array.isArray(safePayload.groups) ? safePayload.groups : [];
      return groups.some((group) => Array.isArray(group && group.items) && group.items.length > 0);
    }}

    function networkTopNodesRowsHtml(items, payload, state = latestState) {{
      const safeItems = Array.isArray(items) ? items : [];
      const safePayload = (payload && typeof payload === "object") ? payload : {{}};
      const category = normalizeNetworkTopNodesCategory(safePayload.category || networkTopNodesCategory);
      const def = networkTopNodesCategoryDef(category);
      const unit = String(safePayload.unit || def.unit || "");
      const maxValue = safeItems.reduce((max, item) => Math.max(max, Number(item && item.value) || 0), 0);
      return safeItems.map((item, index) => {{
        const nodeId = normalizeNodeId(item && item.node_id);
        const rank = Math.max(1, Math.trunc(Number(item && item.rank) || (index + 1)));
        const value = Math.max(0, Math.trunc(Number(item && item.value) || 0));
        const pct = maxValue > 0 ? Math.max(3, Math.min(100, (value / maxValue) * 100)) : 0;
        const name = networkTopNodesDisplayName(nodeId, state);
        const meta = networkTopNodesMetaText(item, safePayload);
        const unitText = networkTopNodesUnitText(unit, value);
        return `<button class="network-top-node-row" type="button" data-top-node-id="${{escAttr(nodeId)}}" title="${{escAttr(`${{name}} (${{nodeId}})`)}}">
          <span class="network-top-node-rank">#${{escAttr(rank)}}</span>
          <span class="network-top-node-main">
            <span class="network-top-node-name">${{escAttr(name)}}</span>
            <span class="network-top-node-id">${{escAttr(nodeId)}}</span>
            ${{meta ? `<span class="network-top-node-meta">${{escAttr(meta)}}</span>` : ""}}
            <span class="network-top-node-bar" aria-hidden="true"><span style="--top-node-bar:${{pct.toFixed(1)}}%;"></span></span>
          </span>
          <span class="network-top-node-value">
            <strong>${{escAttr(networkTopNodesNumberText(value))}}</strong>
            <span class="network-top-node-unit">${{escAttr(unitText)}}</span>
          </span>
        </button>`;
      }}).join("");
    }}

    function networkTopNodesGroupHtml(group, state = latestState, options = {{}}) {{
      const safeGroup = (group && typeof group === "object") ? group : {{}};
      const safeOptions = (options && typeof options === "object") ? options : {{}};
      const category = normalizeNetworkTopNodesCategory(safeGroup.category || "saved_packets");
      const def = networkTopNodesCategoryDef(category);
      const label = String(safeGroup.category_label || def.label || "Top Nodes");
      const source = String(safeGroup.source || "").trim();
      const limit = Math.max(1, Math.trunc(Number(safeGroup.limit) || 10));
      const items = Array.isArray(safeGroup.items) ? safeGroup.items : [];
      const showHeader = safeOptions.showHeader !== false;
      if (!items.length) return "";
      return `<section class="network-top-nodes-group" data-top-node-category="${{escAttr(category)}}">
        ${{showHeader ? `<div class="network-top-nodes-group-head">
          <span class="network-top-nodes-group-title">
            <strong>${{escAttr(label)}}</strong>
            ${{source ? `<span class="network-top-nodes-group-source">${{escAttr(source)}}</span>` : ""}}
          </span>
          <span class="network-top-nodes-group-count">${{escAttr(String(items.length))}} / ${{escAttr(String(limit))}}</span>
        </div>` : ""}}
        <div class="network-top-nodes-group-list">${{networkTopNodesRowsHtml(items, safeGroup, state)}}</div>
      </section>`;
    }}

    function renderNetworkTopNodesPayload(payload, state = latestState, options = {{}}) {{
      const safePayload = (payload && typeof payload === "object") ? payload : buildLocalNetworkTopNodesPayload(networkTopNodesCategory, state);
      const summary = document.getElementById("network-top-nodes-summary");
      const list = document.getElementById("network-top-nodes-list");
      const status = document.getElementById("network-top-nodes-status");
      if (!(summary instanceof HTMLElement) || !(list instanceof HTMLElement)) return;
      const category = normalizeNetworkTopNodesCategory(safePayload.category || networkTopNodesCategory);
      const def = networkTopNodesCategoryDef(category);
      const label = String(safePayload.category_label || def.label || "Top Nodes");
      const items = Array.isArray(safePayload.items) ? safePayload.items : [];
      const groups = Array.isArray(safePayload.groups)
        ? safePayload.groups.filter((group) => Array.isArray(group && group.items) && group.items.length > 0)
        : [];
      const displayGroups = groups.length > 0
        ? groups
        : (items.length > 0 ? [safePayload] : []);
      const source = String(safePayload.source || (safePayload.fallback ? "current state" : "history")).trim();
      const errorText = String(options.error || safePayload.error || "").trim();
      const loading = !!options.loading;

      if (status instanceof HTMLElement) {{
        status.textContent = loading ? "Loading..." : (errorText ? "Current state fallback" : "");
      }}

      if (category === "all" || displayGroups.length > 0) {{
        const itemCount = displayGroups.reduce((sum, group) => {{
          const groupItems = Array.isArray(group && group.items) ? group.items : [];
          return sum + groupItems.length;
        }}, 0);
        const groupLabel = displayGroups.length === 1 ? "list" : "lists";
        summary.innerHTML = `<span><strong>${{escAttr(label)}}</strong> - ${{escAttr(source)}}${{errorText ? ` - ${{escAttr(errorText)}}` : ""}}</span><span>${{escAttr(String(displayGroups.length))}} ${{escAttr(groupLabel)}} - ${{escAttr(String(itemCount))}} entries</span>`;
        if (!displayGroups.length) {{
          list.innerHTML = `<div class="network-top-nodes-empty">No top node activity yet.</div>`;
          return;
        }}
        const showGroupHeaders = category === "all" || displayGroups.length > 1;
        list.innerHTML = displayGroups
          .map((group) => networkTopNodesGroupHtml(group, state, {{ showHeader: showGroupHeaders }}))
          .join("");
        return;
      }}

      summary.innerHTML = `<span><strong>${{escAttr(label)}}</strong> - ${{escAttr(source)}}${{errorText ? ` - ${{escAttr(errorText)}}` : ""}}</span><span>${{escAttr(String(items.length))}} / 10</span>`;

      if (!items.length) {{
        list.innerHTML = `<div class="network-top-nodes-empty">No ${{escAttr(label.toLowerCase())}} activity yet.</div>`;
        return;
      }}

      list.innerHTML = networkTopNodesRowsHtml(items, safePayload, state);
    }}

    async function fetchNetworkTopNodesPayload(category, force = false) {{
      const clean = normalizeNetworkTopNodesCategory(category);
      const cached = networkTopNodesCache instanceof Map ? networkTopNodesCache.get(clean) : null;
      const now = Date.now();
      if (
        !force
        && cached
        && cached.payload
        && (now - Number(cached.fetchedAtMs || 0)) < Math.max(30000, refreshMs * 10)
      ) {{
        return cached.payload;
      }}
      const resp = await fetch(`/api/history/top_nodes?category=${{encodeURIComponent(clean)}}&limit=10`, {{ cache: "no-store" }});
      const payload = await resp.json();
      if (!resp.ok || !payload || payload.ok === false) {{
        const message = payload && payload.error ? String(payload.error) : `HTTP ${{resp.status}}`;
        throw new Error(message);
      }}
      if (networkTopNodesCache instanceof Map) {{
        networkTopNodesCache.set(clean, {{
          payload,
          fetchedAtMs: now,
        }});
      }}
      return payload;
    }}

    function renderNetworkTopNodes(state = latestState, options = {{}}) {{
      bindNetworkTopNodesControls();
      networkTopNodesCategory = normalizeNetworkTopNodesCategory(networkTopNodesCategory);
      ensureNetworkTopNodesCategoryOptions();
      const select = document.getElementById("network-top-nodes-category");
      if (select instanceof HTMLSelectElement && select.value !== networkTopNodesCategory) {{
        select.value = networkTopNodesCategory;
      }}
      const localPayload = buildLocalNetworkTopNodesPayload(networkTopNodesCategory, state);
      renderNetworkTopNodesPayload(localPayload, state, {{
        loading: true,
      }});
      const force = !!(options && options.force);
      const requestCategory = networkTopNodesCategory;
      if (
        networkTopNodesHydrateInFlight
        && normalizeNetworkTopNodesCategory(networkTopNodesHydrateInFlight.category) === requestCategory
      ) {{
        return;
      }}
      const requestToken = {{
        category: requestCategory,
      }};
      networkTopNodesHydrateInFlight = requestToken;
      requestToken.promise = fetchNetworkTopNodesPayload(requestCategory, force)
        .then((payload) => {{
          if (activeLayoutView !== "network" || activeNetworkSubview !== "top10") return;
          if (normalizeNetworkTopNodesCategory(networkTopNodesCategory) !== normalizeNetworkTopNodesCategory(payload && payload.category)) return;
          if (!networkTopNodesPayloadHasItems(payload) && networkTopNodesPayloadHasItems(localPayload)) {{
            renderNetworkTopNodesPayload(localPayload, latestState || state);
            return;
          }}
          renderNetworkTopNodesPayload(payload, latestState || state);
        }})
        .catch((err) => {{
          if (activeLayoutView !== "network" || activeNetworkSubview !== "top10") return;
          const message = err instanceof Error ? err.message : String(err || "history unavailable");
          renderNetworkTopNodesPayload(localPayload, latestState || state, {{
            error: message,
          }});
        }})
        .finally(() => {{
          if (networkTopNodesHydrateInFlight === requestToken) {{
            networkTopNodesHydrateInFlight = null;
          }}
        }});
    }}

    function formatMalformedDiagnosticsTimestamp(unixValue) {{
      const parsed = Number(unixValue);
      if (!Number.isFinite(parsed) || parsed <= 0) return "n/a";
      try {{
        return new Date(Math.floor(parsed) * 1000).toLocaleString();
      }} catch (_err) {{
        return "n/a";
      }}
    }}

    function previewMalformedDiagnosticsPayload(value, maxLength = 64) {{
      const text = String(value == null ? "" : value).trim();
      if (!text) return "n/a";
      if (text.length <= maxLength) return text;
      return `${{text.slice(0, Math.max(12, maxLength - 3))}}...`;
    }}

    function resolveMalformedDiagnosticsSenderLabel(sender, state = latestState) {{
      const safeSender = (sender && typeof sender === "object") ? sender : {{}};
      const cleanId = normalizeNodeId(safeSender.from_id || safeSender.fromId || "");
      const safeState = (state && typeof state === "object") ? state : {{}};
      const nodes = Array.isArray(safeState.nodes) ? safeState.nodes : [];
      let node = null;
      for (const entry of nodes) {{
        if (!entry || typeof entry !== "object") continue;
        if (normalizeNodeId(entry.id || entry.node_id || entry.nodeId || "") === cleanId) {{
          node = entry;
          break;
        }}
      }}
      const preferred = node ? String(preferredNodeName(node) || "").trim() : "";
      const cached = (nodeNameCache instanceof Map)
        ? String(nodeNameCache.get(cleanId) || "").trim()
        : "";
      const fallback = String(safeSender.from_label || safeSender.fromLabel || cleanId || "Unknown node").trim();
      return preferred || cached || fallback || "Unknown node";
    }}

    function renderNetworkDiagnosticsLoading() {{
      const overviewHost = document.getElementById("network-diagnostics-overview");
      const emptyHost = document.getElementById("network-diagnostics-empty");
      const sendersHost = document.getElementById("network-diagnostics-senders");
      const entriesHost = document.getElementById("network-diagnostics-entries");
      const titleHost = document.getElementById("network-diagnostics-entries-title");
      const noteHost = document.getElementById("network-diagnostics-summary-note");
      const layoutHost = document.querySelector("#network-map-panel-diagnostics .network-diagnostics-layout");
      if (overviewHost instanceof HTMLElement) {{
        overviewHost.innerHTML = "";
      }}
      if (sendersHost instanceof HTMLElement) {{
        sendersHost.innerHTML = "";
      }}
      if (entriesHost instanceof HTMLElement) {{
        entriesHost.innerHTML = "";
      }}
      if (titleHost instanceof HTMLElement) {{
        titleHost.textContent = "Recent Payloads";
      }}
      if (noteHost instanceof HTMLElement) {{
        noteHost.innerHTML = `Reviewing persisted malformed <code>TEXT_MESSAGE_APP</code> payloads...`;
      }}
      if (layoutHost instanceof HTMLElement) {{
        layoutHost.hidden = true;
      }}
      if (emptyHost instanceof HTMLElement) {{
        emptyHost.hidden = false;
        emptyHost.textContent = "Loading malformed text diagnostics...";
      }}
    }}

    function renderNetworkDiagnosticsError(message) {{
      const emptyHost = document.getElementById("network-diagnostics-empty");
      const layoutHost = document.querySelector("#network-map-panel-diagnostics .network-diagnostics-layout");
      const noteHost = document.getElementById("network-diagnostics-summary-note");
      if (layoutHost instanceof HTMLElement) {{
        layoutHost.hidden = true;
      }}
      if (noteHost instanceof HTMLElement) {{
        noteHost.innerHTML = `Malformed text diagnostics are unavailable right now.`;
      }}
      if (emptyHost instanceof HTMLElement) {{
        emptyHost.hidden = false;
        emptyHost.textContent = `Could not load malformed text diagnostics: ${{String(message || "unknown error")}}`;
      }}
    }}

    function bindNetworkDiagnosticsControls() {{
      const windowSelect = document.getElementById("network-diagnostics-window");
      if (windowSelect instanceof HTMLSelectElement) {{
        const desiredValue = String(Math.max(1, Math.round(Number(networkDiagnosticsWindowHours) || 72)));
        if (windowSelect.value !== desiredValue) {{
          windowSelect.value = desiredValue;
        }}
        if (windowSelect.dataset.bound !== "1") {{
          windowSelect.dataset.bound = "1";
          windowSelect.addEventListener("change", () => {{
            networkDiagnosticsWindowHours = Math.max(1, Math.round(Number(windowSelect.value) || 72));
            networkDiagnosticsSelectedSenderId = "";
            malformedTextHistoryCache.clear();
            void refreshNetworkDiagnosticsPanel(true);
          }});
        }}
      }}

      const refreshBtn = document.getElementById("network-diagnostics-refresh-btn");
      if (refreshBtn instanceof HTMLButtonElement && refreshBtn.dataset.bound !== "1") {{
        refreshBtn.dataset.bound = "1";
        refreshBtn.addEventListener("click", () => {{
          malformedTextHistoryCache.clear();
          void refreshNetworkDiagnosticsPanel(true);
        }});
      }}

      const clearBtn = document.getElementById("network-diagnostics-clear-sender-btn");
      if (clearBtn instanceof HTMLButtonElement && clearBtn.dataset.bound !== "1") {{
        clearBtn.dataset.bound = "1";
        clearBtn.addEventListener("click", () => {{
          networkDiagnosticsSelectedSenderId = "";
          void refreshNetworkDiagnosticsPanel(false);
        }});
      }}

      const sendersHost = document.getElementById("network-diagnostics-senders");
      if (sendersHost instanceof HTMLElement && sendersHost.dataset.bound !== "1") {{
        sendersHost.dataset.bound = "1";
        sendersHost.addEventListener("click", (ev) => {{
          const trigger = ev.target instanceof Element
            ? ev.target.closest("[data-malformed-sender-id]")
            : null;
          if (!(trigger instanceof HTMLElement)) return;
          const nextId = normalizeNodeId(trigger.dataset.malformedSenderId || "");
          if (!nextId) return;
          networkDiagnosticsSelectedSenderId = (networkDiagnosticsSelectedSenderId === nextId) ? "" : nextId;
          void refreshNetworkDiagnosticsPanel(false);
        }});
      }}
    }}

    function renderNetworkDiagnosticsPayload(payload, detailPayload = null) {{
      const safePayload = (payload && typeof payload === "object") ? payload : {{}};
      const safeDetailPayload = (detailPayload && typeof detailPayload === "object") ? detailPayload : null;
      const summary = (safePayload.summary && typeof safePayload.summary === "object") ? safePayload.summary : {{}};
      const senders = Array.isArray(safePayload.senders) ? safePayload.senders : [];
      const selectedSenderId = normalizeNodeId(networkDiagnosticsSelectedSenderId || "");
      const detailEntries = Array.isArray(safeDetailPayload && safeDetailPayload.entries)
        ? safeDetailPayload.entries
        : (Array.isArray(safePayload.entries) ? safePayload.entries : []);
      const overviewHost = document.getElementById("network-diagnostics-overview");
      const emptyHost = document.getElementById("network-diagnostics-empty");
      const sendersHost = document.getElementById("network-diagnostics-senders");
      const entriesHost = document.getElementById("network-diagnostics-entries");
      const titleHost = document.getElementById("network-diagnostics-entries-title");
      const noteHost = document.getElementById("network-diagnostics-summary-note");
      const clearBtn = document.getElementById("network-diagnostics-clear-sender-btn");
      const layoutHost = document.querySelector("#network-map-panel-diagnostics .network-diagnostics-layout");

      const totalPackets = Math.max(0, Math.trunc(Number(summary.total_packets) || 0));
      const distinctSenders = Math.max(0, Math.trunc(Number(summary.distinct_senders) || 0));
      const firstSeenText = formatMalformedDiagnosticsTimestamp(summary.first_seen_unix);
      const lastSeenText = formatMalformedDiagnosticsTimestamp(summary.last_seen_unix);
      const selectedSender = selectedSenderId
        ? senders.find((entry) => normalizeNodeId(entry && (entry.from_id || entry.fromId) || "") === selectedSenderId) || null
        : null;
      const selectedSenderLabel = selectedSender
        ? resolveMalformedDiagnosticsSenderLabel(selectedSender)
        : "";

      if (overviewHost instanceof HTMLElement) {{
        overviewHost.innerHTML = [
          ["Malformed packets", String(totalPackets)],
          ["Distinct senders", String(distinctSenders)],
          ["First seen", firstSeenText],
          ["Last seen", lastSeenText],
        ].map(([label, value]) => `<div class="overview-item"><div class="k">${{escAttr(label)}}</div><div class="v">${{escAttr(value)}}</div></div>`).join("");
      }}

      if (noteHost instanceof HTMLElement) {{
        if (selectedSender && selectedSenderLabel) {{
          noteHost.innerHTML = `Showing persisted malformed <code>TEXT_MESSAGE_APP</code> payloads for <strong>${{escAttr(selectedSenderLabel)}}</strong>.`;
        }} else {{
          noteHost.innerHTML = `Review persisted malformed <code>TEXT_MESSAGE_APP</code> payloads, grouped by sender.`;
        }}
      }}

      if (clearBtn instanceof HTMLButtonElement) {{
        clearBtn.hidden = !selectedSenderId;
      }}

      if (titleHost instanceof HTMLElement) {{
        titleHost.textContent = selectedSender && selectedSenderLabel
          ? `Recent Payloads • ${{selectedSenderLabel}}`
          : "Recent Payloads";
      }}

      if (sendersHost instanceof HTMLElement) {{
        sendersHost.innerHTML = senders.length > 0
          ? senders.map((sender) => {{
            const senderId = normalizeNodeId(sender && (sender.from_id || sender.fromId) || "");
            const senderLabel = resolveMalformedDiagnosticsSenderLabel(sender);
            const senderCount = Math.max(0, Math.trunc(Number(sender && sender.count) || 0));
            const isActive = !!selectedSenderId && senderId === selectedSenderId;
            const senderLastSeen = formatMalformedDiagnosticsTimestamp(sender && sender.last_seen_unix);
            const senderPreview = previewMalformedDiagnosticsPayload(sender && sender.last_payload_preview, 68);
            return `<button class="network-diagnostics-sender${{isActive ? " is-active" : ""}}" type="button" data-malformed-sender-id="${{escAttr(senderId)}}">
              <span class="network-diagnostics-sender-line">
                <span class="network-diagnostics-sender-name">${{escAttr(senderLabel)}}</span>
                <span class="network-diagnostics-count-chip">${{escAttr(String(senderCount))}}</span>
              </span>
              <span class="network-diagnostics-sender-meta">${{escAttr(senderId || "unknown")}} · last ${{escAttr(senderLastSeen)}}</span>
              <span class="network-diagnostics-sender-preview">${{escAttr(senderPreview)}}</span>
            </button>`;
          }}).join("")
          : `<div class="network-diagnostics-empty-copy">No flagged senders in this window.</div>`;
      }}

      if (entriesHost instanceof HTMLElement) {{
        entriesHost.innerHTML = detailEntries.length > 0
          ? detailEntries.map((entry) => {{
            const entrySenderLabel = resolveMalformedDiagnosticsSenderLabel(entry);
            const entrySenderId = normalizeNodeId(entry && (entry.from_id || entry.fromId) || "");
            const entryUnix = Number(entry && (entry.rx_time_unix ?? entry.created_unix));
            const packetId = Number(entry && entry.packet_id);
            const packetLabel = Number.isFinite(packetId) && packetId > 0
              ? `packet #${{Math.trunc(packetId)}}`
              : "packet n/a";
            return `<article class="network-diagnostics-entry">
              <div class="network-diagnostics-entry-meta">
                <span class="network-diagnostics-entry-chip">${{escAttr(entrySenderLabel)}}</span>
                <span>${{escAttr(entrySenderId || "unknown")}}</span>
                <span>${{escAttr(packetLabel)}}</span>
                <span>${{escAttr(formatMalformedDiagnosticsTimestamp(entryUnix))}}</span>
              </div>
              <code class="network-diagnostics-entry-payload">${{escAttr(String(entry && entry.payload_text || ""))}}</code>
            </article>`;
          }}).join("")
          : `<div class="network-diagnostics-empty-copy">No malformed payloads to show for this sender.</div>`;
      }}

      if (layoutHost instanceof HTMLElement) {{
        layoutHost.hidden = totalPackets < 1;
      }}
      if (emptyHost instanceof HTMLElement) {{
        emptyHost.hidden = totalPackets > 0;
        emptyHost.textContent = "No malformed text payloads recorded in this window.";
      }}
    }}

    async function refreshNetworkDiagnosticsPanel(force = false) {{
      if (activeLayoutView !== "network" || activeNetworkSubview !== "diagnostics") return;
      bindNetworkDiagnosticsControls();
      const windowHours = Math.max(1, Math.round(Number(networkDiagnosticsWindowHours) || 72));
      if (force) {{
        malformedTextHistoryCache.clear();
      }}
      renderNetworkDiagnosticsLoading();
      try {{
        const payload = await fetchMalformedTextHistory({{
          windowHours,
          limit: 120,
        }});
        if (activeLayoutView !== "network" || activeNetworkSubview !== "diagnostics") return;
        const senders = Array.isArray(payload && payload.senders) ? payload.senders : [];
        const selectedSenderId = normalizeNodeId(networkDiagnosticsSelectedSenderId || "");
        if (
          selectedSenderId
          && !senders.some((sender) => normalizeNodeId(sender && (sender.from_id || sender.fromId) || "") === selectedSenderId)
        ) {{
          networkDiagnosticsSelectedSenderId = "";
        }}
        const detailPayload = networkDiagnosticsSelectedSenderId
          ? await fetchMalformedTextHistory({{
            windowHours,
            limit: 120,
            nodeId: networkDiagnosticsSelectedSenderId,
          }})
          : null;
        if (activeLayoutView !== "network" || activeNetworkSubview !== "diagnostics") return;
        renderNetworkDiagnosticsPayload(payload, detailPayload);
