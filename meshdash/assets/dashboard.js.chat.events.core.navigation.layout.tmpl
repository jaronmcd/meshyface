    function resolveNetworkGraphTagRouteLegendItems(edges, items, rootId, routeAnchorId = "") {{
      const byPresetId = new Map();
      for (const taggedItem of resolveNetworkGraphTaggedItems(items)) {{
        const presetId = normalizeNetworkGraphTagRoutePresetId(taggedItem && taggedItem.presetId);
        if (!presetId) continue;
        if (!byPresetId.has(presetId)) {{
