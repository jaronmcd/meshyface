      summary.innerHTML = `<span><strong>${{escAttr(label)}}</strong> - ${{escAttr(source)}}${{errorText ? ` - ${{escAttr(errorText)}}` : ""}}</span><span>${{escAttr(String(items.length))}} / 10</span>`;

