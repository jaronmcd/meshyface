    function renderNetworkTopNodesPayload(payload, state = latestState, options = {{}}) {{
      const safePayload = (payload && typeof payload === "object") ? payload : buildLocalNetworkTopNodesPayload(networkTopNodesCategory, state);
      const summary = document.getElementById("network-top-nodes-summary");
