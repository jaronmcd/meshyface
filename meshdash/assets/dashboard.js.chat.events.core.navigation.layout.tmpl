      syncNetworkGraphTextZoom(svg, networkGraphViewState.viewBox);
      markNetworkGraphRenderPhase("post_sync", {{
        action: graphSceneAction,
      }});
      networkGraphViewState.lastSceneStructureSignature = sceneStructureSignature;
      networkGraphViewState.lastSceneDataSignature = sceneDataSignature;
      if (perfToken > 0 && typeof markNodeSelectionPerf === "function") {{
        markNodeSelectionPerf(perfToken, "selection.graph_render", perfStartMs, {{
          nodes: layout.items.length,
          edges: combinedEdges.length,
        }});
