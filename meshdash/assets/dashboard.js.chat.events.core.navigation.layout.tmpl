      const preservedNodeIds = new Set(
        rankedCandidates.filter((candidate) => !!candidate.preserve).map((candidate) => candidate.nodeId)
      );
      let preferredVisibleCount = Math.max(0, (totalDisconnectedCount * 2) - safeConnectedCount);
      if (totalDisconnectedCount > 24 && safeConnectedCount <= 3) {{
