        nodeinfo: "nodeinfo_packets",
        node_info: "nodeinfo_packets",
        direct: "direct_packets",
        store_forward: "storeforward_packets",
        storefwd: "storeforward_packets",
        encrypted: "encrypted_packets",
        other: "other_packets",
      }};
      const normalized = aliases[clean] || clean;
      return networkTopNodesCategoryById.has(normalized) ? normalized : "saved_packets";
    }}

    function networkTopNodesCategoryDef(category) {{
      const clean = normalizeNetworkTopNodesCategory(category);
      return networkTopNodesCategoryById.get(clean) || networkTopNodesCategoryDefs[0];
    }}

    function loadPreferredNetworkTopNodesCategory() {{
      try {{
        const stored = window.localStorage.getItem(networkTopNodesCategoryStorageKey);
        return stored ? normalizeNetworkTopNodesCategory(stored) : "all";
      }} catch (_err) {{
        return "all";
      }}
    }}

    function persistPreferredNetworkTopNodesCategory(category) {{
      const clean = normalizeNetworkTopNodesCategory(category);
      try {{
        window.localStorage.setItem(networkTopNodesCategoryStorageKey, clean);
      }} catch (_err) {{
      }}
    }}

    function ensureNetworkTopNodesCategoryOptions() {{
      const select = document.getElementById("network-top-nodes-category");
      if (!(select instanceof HTMLSelectElement)) return;
      const optionsSignature = networkTopNodesCategoryDefs.map((entry) => entry.id).join("|");
      if (select.dataset.optionsSignature !== optionsSignature) {{
        select.innerHTML = networkTopNodesCategoryDefs
          .map((entry) => `<option value="${{escAttr(entry.id)}}">${{escAttr(entry.label)}}</option>`)
          .join("");
        select.dataset.optionsSignature = optionsSignature;
      }}
      const clean = normalizeNetworkTopNodesCategory(networkTopNodesCategory);
      if (select.value !== clean) {{
        select.value = clean;
      }}
    }}

    function bindNetworkTopNodesControls() {{
      ensureNetworkTopNodesCategoryOptions();
      const select = document.getElementById("network-top-nodes-category");
      if (select instanceof HTMLSelectElement && select.dataset.bound !== "1") {{
        select.dataset.bound = "1";
        select.addEventListener("change", () => {{
          networkTopNodesCategory = normalizeNetworkTopNodesCategory(select.value);
          persistPreferredNetworkTopNodesCategory(networkTopNodesCategory);
          renderNetworkTopNodes(latestState, {{ force: false }});
        }});
      }}
      const refreshBtn = document.getElementById("network-top-nodes-refresh-btn");
      if (refreshBtn instanceof HTMLButtonElement && refreshBtn.dataset.bound !== "1") {{
        refreshBtn.dataset.bound = "1";
        refreshBtn.addEventListener("click", () => {{
          renderNetworkTopNodes(latestState, {{ force: true }});
        }});
      }}
      const list = document.getElementById("network-top-nodes-list");
      if (list instanceof HTMLElement && list.dataset.bound !== "1") {{
        list.dataset.bound = "1";
        list.addEventListener("click", (event) => {{
          const target = event.target instanceof Element ? event.target : null;
          const row = target ? target.closest("[data-top-node-id]") : null;
          if (!(row instanceof HTMLElement)) return;
          const nodeId = normalizeNodeId(row.dataset.topNodeId || "");
          if (!isSelectableNodeId(nodeId)) return;
          selectNode(nodeId, true, false);
        }});
      }}
    }}

    function networkTopNodesPacketType(portnumRaw) {{
      const portnum = String(portnumRaw || "").trim().toUpperCase();
      if (!portnum) return "encrypted";
      if (portnum === "TEXT_MESSAGE_APP") return "chat";
      if (portnum === "TELEMETRY_APP") return "telemetry";
      if (portnum === "POSITION_APP") return "position";
      if (portnum === "ROUTING_APP") return "routing";
      if (portnum === "STORE_FORWARD_APP") return "storeforward";
      if (portnum === "NODEINFO_APP") return "nodeinfo";
      if (portnum === "ADMIN_APP") return "admin";
      return "other";
    }}

    function networkTopNodesPacketSummary(entry) {{
      const safeEntry = (entry && typeof entry === "object") ? entry : {{}};
      const summary = (safeEntry.summary && typeof safeEntry.summary === "object") ? safeEntry.summary : {{}};
      const packet = (safeEntry.packet && typeof safeEntry.packet === "object") ? safeEntry.packet : safeEntry;
      const decoded = (packet.decoded && typeof packet.decoded === "object") ? packet.decoded : {{}};
      const fromId = normalizeNodeId(
        summary.from
        ?? summary.from_id
        ?? summary.fromId
        ?? packet.fromId
        ?? packet.from_id
        ?? packet.from
        ?? ""
      );
      const toId = normalizeNodeId(
        summary.to
        ?? summary.to_id
        ?? summary.toId
        ?? packet.toId
        ?? packet.to_id
        ?? packet.to
        ?? packet.destination
        ?? ""
      );
      const portnum = String(
        summary.portnum
        ?? decoded.portnum
        ?? packet.portnum
        ?? ""
      ).trim();
      const unixRaw = Number(
        summary.rx_time_unix
        ?? summary.time_unix
        ?? packet.rxTime
        ?? packet.rx_time
        ?? 0
      );
      const lastSeenUnix = Number.isFinite(unixRaw) && unixRaw > 0 ? Math.trunc(unixRaw) : 0;
      return {{
        fromId,
        toId,
        portnum,
        packetType: networkTopNodesPacketType(portnum),
        lastSeenUnix,
      }};
    }}

    function networkTopNodesAddCount(map, nodeId, amount = 1, options = {{}}) {{
      const clean = normalizeNodeId(nodeId || "");
      if (!isSelectableNodeId(clean)) return null;
      const increment = Math.max(0, Math.trunc(Number(amount) || 0));
      if (increment <= 0) return null;
      let item = map.get(clean);
      if (!item) {{
        item = {{
          node_id: clean,
          value: 0,
          secondary_value: 0,
          last_seen_unix: 0,
        }};
        map.set(clean, item);
      }}
      item.value += increment;
      const secondary = Math.max(0, Math.trunc(Number(options.secondaryValue) || 0));
      if (secondary > 0) {{
        item.secondary_value = Math.max(Math.trunc(Number(item.secondary_value) || 0), secondary);
      }}
      const lastSeen = Math.trunc(Number(options.lastSeenUnix) || 0);
      if (lastSeen > 0) {{
        item.last_seen_unix = Math.max(Math.trunc(Number(item.last_seen_unix) || 0), lastSeen);
      }}
      return item;
    }}

    function networkTopNodesExcludedLocalIds(state = latestState) {{
      const localId = normalizeNodeId(resolveLocalNodeId(state) || "");
      return isCanonicalNodeId(localId) ? new Set([localId]) : new Set();
    }}

    function networkTopNodesItemsFromMap(map, limit = 10, excludedNodeIds = null) {{
      const excluded = excludedNodeIds instanceof Set ? excludedNodeIds : new Set();
      return Array.from(map.values())
        .filter((item) => {{
          const nodeId = normalizeNodeId(item && item.node_id);
          return Number(item && item.value) > 0 && !excluded.has(nodeId);
        }})
        .sort((a, b) => {{
          const valueDiff = (Number(b.value) || 0) - (Number(a.value) || 0);
          if (Math.abs(valueDiff) > 1e-9) return valueDiff;
          const timeDiff = (Number(b.last_seen_unix) || 0) - (Number(a.last_seen_unix) || 0);
          if (timeDiff) return timeDiff;
          return String(a.node_id || "").localeCompare(String(b.node_id || ""));
        }})
        .slice(0, Math.max(1, Math.trunc(Number(limit) || 10)))
        .map((item, idx) => ({{
          ...item,
          rank: idx + 1,
        }}));
    }}

    function buildLocalNetworkTopNodesPayload(category, state = latestState) {{
      const cleanCategory = normalizeNetworkTopNodesCategory(category);
      const def = networkTopNodesCategoryDef(cleanCategory);
      const safeState = (state && typeof state === "object") ? state : {{}};
      if (cleanCategory === "all") {{
        const groups = networkTopNodesCategoryDefs
          .filter((entry) => entry && entry.id && entry.id !== "all")
          .map((entry) => buildLocalNetworkTopNodesPayload(entry.id, safeState));
        const itemCount = groups.reduce((sum, group) => {{
          const items = Array.isArray(group && group.items) ? group.items : [];
          return sum + items.length;
        }}, 0);
        return {{
          ok: true,
          category: cleanCategory,
          category_label: def.label,
          unit: def.unit,
          source: "current state",
          limit: 10,
          groups,
          item_count: itemCount,
          items: [],
          fallback: true,
        }};
      }}
      const nodes = Array.isArray(safeState.nodes) ? safeState.nodes : [];
      const traffic = (safeState.traffic && typeof safeState.traffic === "object") ? safeState.traffic : {{}};
      const edges = Array.isArray(traffic.edges) ? traffic.edges : [];
      const packets = Array.isArray(traffic.recent_packets) ? traffic.recent_packets : [];
      const counts = new Map();
      const excludedNodeIds = networkTopNodesExcludedLocalIds(safeState);

      if (cleanCategory === "saved_packets") {{
        for (const node of nodes) {{
          networkTopNodesAddCount(counts, node && node.id, node && node.saved_packets, {{
            secondaryValue: node && node.saved_points,
            lastSeenUnix: node && node.last_heard_unix,
          }});
        }}
      }} else if (cleanCategory === "gps_positions") {{
        for (const node of nodes) {{
          const hasPosition = Number.isFinite(Number(node && node.lat)) && Number.isFinite(Number(node && node.lon));
          if (!hasPosition) continue;
          networkTopNodesAddCount(counts, node && node.id, 1, {{
            lastSeenUnix: node && node.last_heard_unix,
          }});
        }}
      }} else if (cleanCategory === "links" || cleanCategory === "link_packets") {{
        const peersByNode = new Map();
        const linkPacketsByNode = new Map();
        const lastSeenByNode = new Map();
        const addPeer = (nodeId, peerId, packetCount, lastSeenUnix) => {{
          const cleanNode = normalizeNodeId(nodeId || "");
          const cleanPeer = normalizeNodeId(peerId || "");
          if (!isSelectableNodeId(cleanNode) || !isSelectableNodeId(cleanPeer)) return;
          if (!peersByNode.has(cleanNode)) peersByNode.set(cleanNode, new Set());
          peersByNode.get(cleanNode).add(cleanPeer);
          linkPacketsByNode.set(
            cleanNode,
            Math.max(0, Math.trunc(Number(linkPacketsByNode.get(cleanNode)) || 0)) + Math.max(0, Math.trunc(Number(packetCount) || 0))
          );
          const lastSeen = Math.trunc(Number(lastSeenUnix) || 0);
          if (lastSeen > 0) {{
            lastSeenByNode.set(cleanNode, Math.max(Math.trunc(Number(lastSeenByNode.get(cleanNode)) || 0), lastSeen));
          }}
        }};
        for (const edge of edges) {{
          const fromId = edge && edge.from;
          const toId = edge && edge.to;
          const packetCount = edge && (edge.lifetime_count ?? edge.count ?? edge.session_count);
          const lastSeen = edge && (edge.last_rx_unix ?? edge.last_seen_unix ?? edge.last_unix);
          addPeer(fromId, toId, packetCount, lastSeen);
          addPeer(toId, fromId, packetCount, lastSeen);
        }}
        for (const [nodeId, peers] of peersByNode.entries()) {{
          const packetCount = Math.max(0, Math.trunc(Number(linkPacketsByNode.get(nodeId)) || 0));
          networkTopNodesAddCount(
            counts,
            nodeId,
            cleanCategory === "links" ? peers.size : packetCount,
            {{
              secondaryValue: cleanCategory === "links" ? packetCount : peers.size,
              lastSeenUnix: lastSeenByNode.get(nodeId),
            }}
          );
        }}
      }} else {{
        const categoryTypeById = {{
          chat_packets: "chat",
          telemetry_packets: "telemetry",
          position_packets: "position",
          routing_packets: "routing",
          nodeinfo_packets: "nodeinfo",
          storeforward_packets: "storeforward",
          admin_packets: "admin",
          encrypted_packets: "encrypted",
          other_packets: "other",
          environment_metrics: "telemetry",
        }};
        const targetType = categoryTypeById[cleanCategory] || "";
        for (const entry of packets) {{
          const summary = networkTopNodesPacketSummary(entry);
          if (!isSelectableNodeId(summary.fromId)) continue;
          if (cleanCategory === "direct_packets") {{
            if (!isSelectableNodeId(summary.toId) || summary.toId === summary.fromId) continue;
            networkTopNodesAddCount(counts, summary.fromId, 1, {{
              secondaryValue: 1,
              lastSeenUnix: summary.lastSeenUnix,
            }});
            continue;
          }}
          if (targetType && summary.packetType !== targetType) continue;
          networkTopNodesAddCount(counts, summary.fromId, 1, {{
            lastSeenUnix: summary.lastSeenUnix,
          }});
        }}
      }}

      return {{
        ok: true,
        category: cleanCategory,
        category_label: def.label,
        unit: def.unit,
        source: "current state",
        limit: 10,
        items: networkTopNodesItemsFromMap(counts, 10, excludedNodeIds),
        fallback: true,
      }};
    }}

    function networkTopNodesNodeMap(state = latestState) {{
      const safeState = (state && typeof state === "object") ? state : {{}};
      const nodes = Array.isArray(safeState.nodes) ? safeState.nodes : [];
      const out = new Map();
      for (const node of nodes) {{
        const nodeId = normalizeNodeId(node && node.id);
        if (isSelectableNodeId(nodeId) && !out.has(nodeId)) {{
          out.set(nodeId, node);
        }}
      }}
      return out;
    }}

    function networkTopNodesDisplayName(nodeId, state = latestState) {{
      const clean = normalizeNodeId(nodeId || "");
      const node = networkTopNodesNodeMap(state).get(clean) || null;
      const cached = (nodeNameCache instanceof Map) ? String(nodeNameCache.get(clean) || "").trim() : "";
      return String(preferredNodeName(node) || cached || clean || "Unknown node");
    }}

    function networkTopNodesPathValue(source, path) {{
      if (!source || typeof source !== "object") return null;
      const parts = String(path || "").split(".").filter(Boolean);
      let current = source;
      for (const part of parts) {{
        if (!current || typeof current !== "object") return null;
        current = current[part];
      }}
      return current;
    }}

    function networkTopNodesCoordValue(source, paths) {{
      const safePaths = Array.isArray(paths) ? paths : [];
      for (const path of safePaths) {{
        const parsed = Number(networkTopNodesPathValue(source, path));
        if (Number.isFinite(parsed)) return parsed;
      }}
      return null;
    }}

    function networkTopNodesLocationIsValid(lat, lon) {{
      if (typeof isValidLatLonRange === "function" && !isValidLatLonRange(lat, lon)) return false;
      if (!Number.isFinite(lat) || !Number.isFinite(lon)) return false;
      if (lat < -90 || lat > 90 || lon < -180 || lon > 180) return false;
      if (Math.abs(lat) < 1e-9 && Math.abs(lon) < 1e-9) return false;
      return true;
    }}

    function networkTopNodesNodeLocation(nodeId, state = latestState, item = null) {{
      const clean = normalizeNodeId(nodeId || "");
      const node = networkTopNodesNodeMap(state).get(clean) || null;
      const sources = [item, node].filter((source) => source && typeof source === "object");
      const latPaths = ["lat", "latitude", "position.lat", "position.latitude", "location.lat", "location.latitude"];
      const lonPaths = ["lon", "lng", "longitude", "position.lon", "position.lng", "position.longitude", "location.lon", "location.lng", "location.longitude"];
      for (const source of sources) {{
        const lat = networkTopNodesCoordValue(source, latPaths);
        const lon = networkTopNodesCoordValue(source, lonPaths);
        if (networkTopNodesLocationIsValid(lat, lon)) {{
          return {{ lat: Number(lat), lon: Number(lon) }};
        }}
      }}
      return null;
    }}

    function networkTopNodesNodeLocationMeta(nodeId, state = latestState, item = null) {{
      const safeState = (state && typeof state === "object") ? state : latestState;
      if (typeof resolveNodeCityLocationMeta === "function") {{
        const meta = resolveNodeCityLocationMeta(nodeId, safeState, item, {{
          allowEstimate: true,
          estimateMode: "both",
        }});
        if (meta && typeof meta === "object") return meta;
      }}
      const gpsLocation = networkTopNodesNodeLocation(nodeId, safeState, item);
      if (gpsLocation && typeof gpsLocation === "object") {{
        return {{
          source: "gps",
          location: gpsLocation,
          nodeId: normalizeNodeId(nodeId || ""),
        }};
      }}
      return null;
    }}

    function networkTopNodesCityCacheKey(location) {{
      if (!location || typeof location !== "object") return "";
      const lat = Number(location.lat);
      const lon = Number(location.lon);
      if (!networkTopNodesLocationIsValid(lat, lon)) return "";
      return `${{lat.toFixed(4)}},${{lon.toFixed(4)}}`;
    }}

    function networkTopNodesCityText(location) {{
      const key = networkTopNodesCityCacheKey(location);
      if (!key || !(nodeCityHintCache instanceof Map)) return "";
      return String(nodeCityHintCache.get(key) || "").trim();
    }}

    function applyNetworkTopNodeCitySpan(span, text) {{
      if (!(span instanceof HTMLElement)) return;
      const clean = String(text || "").trim();
      const source = String(span.dataset.topNodeCitySource || "").trim().toLowerCase();
      const display = clean && source === "estimated" ? `~ ${{clean}}` : clean;
      span.textContent = display;
      span.classList.toggle("is-estimated", source === "estimated");
      span.hidden = !clean;
    }}

    function hydrateNetworkTopNodeCities(root) {{
      if (!(root instanceof HTMLElement)) return;
      const spans = Array.from(root.querySelectorAll("[data-top-node-city-key]"));
      if (!spans.length) return;
      for (const span of spans) {{
        if (!(span instanceof HTMLElement)) continue;
        const key = String(span.dataset.topNodeCityKey || "").trim();
        if (!key) continue;
        if (nodeCityHintCache instanceof Map && nodeCityHintCache.has(key)) {{
          applyNetworkTopNodeCitySpan(span, nodeCityHintCache.get(key));
          continue;
        }}
        const lat = Number(span.dataset.topNodeCityLat);
        const lon = Number(span.dataset.topNodeCityLon);
        if (!networkTopNodesLocationIsValid(lat, lon) || typeof nearestOfflineCityHintFromCoords !== "function") {{
          if (nodeCityHintCache instanceof Map) nodeCityHintCache.set(key, "");
          applyNetworkTopNodeCitySpan(span, "");
          continue;
        }}
        nearestOfflineCityHintFromCoords(lat, lon)
          .then((city) => {{
            const text = String(city || "").trim();
            if (nodeCityHintCache instanceof Map) nodeCityHintCache.set(key, text);
            if (span.isConnected && String(span.dataset.topNodeCityKey || "").trim() === key) {{
              applyNetworkTopNodeCitySpan(span, text);
            }}
          }})
          .catch(() => {{
            if (nodeCityHintCache instanceof Map) nodeCityHintCache.set(key, "");
            if (span.isConnected && String(span.dataset.topNodeCityKey || "").trim() === key) {{
              applyNetworkTopNodeCitySpan(span, "");
            }}
          }});
      }}
    }}

    function networkTopNodesTimeText(unixValue) {{
      const parsed = Math.trunc(Number(unixValue) || 0);
      if (parsed <= 0) return "";
      if (typeof formatLocalChatTime === "function") {{
        return formatLocalChatTime(parsed, "n/a");
      }}
      try {{
        return new Date(parsed * 1000).toLocaleString();
      }} catch (_err) {{
        return "";
      }}
    }}

    function networkTopNodesNumberText(value) {{
      const parsed = Number(value);
      if (!Number.isFinite(parsed)) return "0";
      try {{
        return Math.trunc(parsed).toLocaleString();
      }} catch (_err) {{
        return String(Math.trunc(parsed));
      }}
    }}

    function networkTopNodesUnitText(unit, value) {{
      const clean = String(unit || "").trim();
      if (!clean) return "";
      const count = Math.trunc(Number(value) || 0);
      if (count === 1) {{
        if (clean === "hours") return "hour";
        if (clean === "packets") return "packet";
        if (clean === "chats") return "chat";
        if (clean === "positions") return "position";
        if (clean === "samples") return "sample";
        if (clean === "links") return "link";
      }}
      return clean;
    }}

    function networkTopNodesMetaText(item, payload) {{
      const pieces = [];
      const secondary = Math.trunc(Number(item && item.secondary_value) || 0);
      const category = normalizeNetworkTopNodesCategory(payload && payload.category);
      if (secondary > 0) {{
        if (category === "saved_packets") {{
          pieces.push(`${{networkTopNodesNumberText(secondary)}} metric points`);
        }} else if (category === "links") {{
          pieces.push(`${{networkTopNodesNumberText(secondary)}} link packets`);
        }} else if (category === "link_packets") {{
          pieces.push(`${{networkTopNodesNumberText(secondary)}} linked nodes`);
        }} else if (category === "environment_metrics") {{
          pieces.push(`${{networkTopNodesNumberText(secondary)}} metric types`);
        }} else if (category === "direct_packets") {{
          pieces.push(`${{networkTopNodesNumberText(secondary)}} targets`);
        }}
      }}
      const seenText = networkTopNodesTimeText(item && item.last_seen_unix);
      if (seenText) {{
        pieces.push(`last ${{seenText}}`);
      }}
      return pieces.join(" - ");
    }}

    function networkTopNodesPayloadHasItems(payload) {{
      const safePayload = (payload && typeof payload === "object") ? payload : {{}};
      const items = Array.isArray(safePayload.items) ? safePayload.items : [];
      if (items.length > 0) return true;
      const groups = Array.isArray(safePayload.groups) ? safePayload.groups : [];
      return groups.some((group) => Array.isArray(group && group.items) && group.items.length > 0);
    }}

    function networkTopNodesVisualEmoji(nodeId, state = latestState) {{
      const clean = normalizeNodeId(nodeId || "");
      if (!clean) return "";
      const node = networkTopNodesNodeMap(state).get(clean) || null;
      try {{
        if (typeof nodeVisualWatermarkForNode === "function") {{
          return String(nodeVisualWatermarkForNode(clean, null, node) || "").trim();
        }}
        if (typeof nodeVisualEmojiForNode === "function") {{
          return String(nodeVisualEmojiForNode(clean, null, node) || "").trim();
        }}
        return "";
      }} catch (_err) {{
        return "";
      }}
    }}

    function networkTopNodesRowsHtml(items, payload, state = latestState) {{
      const safeItems = Array.isArray(items) ? items : [];
      const safePayload = (payload && typeof payload === "object") ? payload : {{}};
      const category = normalizeNetworkTopNodesCategory(safePayload.category || networkTopNodesCategory);
      const def = networkTopNodesCategoryDef(category);
      const unit = String(safePayload.unit || def.unit || "");
      const maxValue = safeItems.reduce((max, item) => Math.max(max, Number(item && item.value) || 0), 0);
      return safeItems.map((item, index) => {{
        const nodeId = normalizeNodeId(item && item.node_id);
        const rank = Math.max(1, Math.trunc(Number(item && item.rank) || (index + 1)));
        const value = Math.max(0, Math.trunc(Number(item && item.value) || 0));
        const pct = maxValue > 0 ? Math.max(3, Math.min(100, (value / maxValue) * 100)) : 0;
        const name = networkTopNodesDisplayName(nodeId, state);
        const meta = networkTopNodesMetaText(item, safePayload);
        const unitText = networkTopNodesUnitText(unit, value);
        const locationMeta = networkTopNodesNodeLocationMeta(nodeId, state, item);
        const location = locationMeta ? locationMeta.location : null;
        const citySource = String(locationMeta && locationMeta.source || "gps").trim().toLowerCase() === "estimated"
          ? "estimated"
          : "gps";
        const cityKey = networkTopNodesCityCacheKey(location);
        const cityTextRaw = networkTopNodesCityText(location);
        const cityText = cityTextRaw && citySource === "estimated"
          ? `~ ${{cityTextRaw}}`
          : cityTextRaw;
        const cityHtml = cityKey
          ? `<span class="network-top-node-city${{citySource === "estimated" ? " is-estimated" : ""}}" data-top-node-city-key="${{escAttr(cityKey)}}" data-top-node-city-lat="${{escAttr(location.lat.toFixed(6))}}" data-top-node-city-lon="${{escAttr(location.lon.toFixed(6))}}" data-top-node-city-source="${{escAttr(citySource)}}"${{cityText ? "" : " hidden"}}>${{escAttr(cityText)}}</span>`
          : "";
        const nodeEmoji = networkTopNodesVisualEmoji(nodeId, state);
        const nodeWatermarkTextClass = (
          nodeEmoji
          && typeof nodeVisualWatermarkIsText === "function"
          && nodeVisualWatermarkIsText(nodeEmoji)
        )
          ? " has-node-watermark-text"
          : "";
        const nodeEmojiClass = nodeEmoji ? ` has-node-emoji${{nodeWatermarkTextClass}}` : "";
        return `<button class="network-top-node-row${{nodeEmojiClass}}" type="button" data-top-node-id="${{escAttr(nodeId)}}"${{nodeEmoji ? ` data-node-emoji="${{escAttr(nodeEmoji)}}"` : ""}} title="${{escAttr(`${{name}} (${{nodeId}})`)}}">
          <span class="network-top-node-rank">#${{escAttr(rank)}}</span>
          <span class="network-top-node-main">
            <span class="network-top-node-name">${{escAttr(name)}}</span>
            <span class="network-top-node-id">${{escAttr(nodeId)}}</span>
            ${{cityHtml}}
            ${{meta ? `<span class="network-top-node-meta">${{escAttr(meta)}}</span>` : ""}}
            <span class="network-top-node-bar" aria-hidden="true"><span style="--top-node-bar:${{pct.toFixed(1)}}%;"></span></span>
          </span>
          <span class="network-top-node-value">
            <strong>${{escAttr(networkTopNodesNumberText(value))}}</strong>
            <span class="network-top-node-unit">${{escAttr(unitText)}}</span>
          </span>
        </button>`;
      }}).join("");
    }}

