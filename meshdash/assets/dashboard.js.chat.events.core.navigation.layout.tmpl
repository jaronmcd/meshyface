      }}
      if (resolved === "files" && !fileTransferFeatureEnabled) {{
        resolved = "games";
      }}

      // Public v0 rail: expose only Chat/Network/Console/Games/BBS/Files/Settings.
      return (
        resolved === "chat"
        || resolved === "network"
        || resolved === "console"
        || resolved === "games"
        || (resolved === "bbs" && bbsFeatureEnabled)
        || (resolved === "files" && fileTransferFeatureEnabled)
