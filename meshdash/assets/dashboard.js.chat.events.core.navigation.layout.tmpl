      const safeTraffic = (safeState.traffic && typeof safeState.traffic === "object") ? safeState.traffic : {{}};
      const recentPackets = Array.isArray(safeTraffic.recent_packets) ? safeTraffic.recent_packets : [];
      const degreeMeta = new Map();
      for (const nodeId of nodeMap.keys()) {{
        const peers = adjacency.get(nodeId) || new Map();
        let totalWeight = 0;
