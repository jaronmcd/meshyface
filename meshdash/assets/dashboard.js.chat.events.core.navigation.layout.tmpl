        }});
      }}

      applyLayoutView("network", true);
      setActiveNetworkSubview("routes", {{ persist: true }});
      syncNetworkRoutesFromSelectedNode(latestState);
      renderNetworkRoutes(latestState);

      const shouldAutoRun = opts.autoRun !== false && !(opts.tracePayload && typeof opts.tracePayload === "object");
      if (shouldAutoRun) {{
        void runNetworkRoutesLiveTrace(latestState, {{ force: true }});
      }}
    }}

    function buildNetworkRoutesScopedLinks(route, data) {{
      const nodeMap = data && data.nodeMap instanceof Map ? data.nodeMap : new Map();
      const adjacency = data && data.adjacency instanceof Map ? data.adjacency : new Map();
      const path = (Array.isArray(route && route.path) ? route.path : [])
        .map((nodeId) => normalizeNodeId(nodeId || ""))
        .filter((nodeId) => isSelectableNodeId(nodeId) && nodeMap.has(nodeId));
      const returnPath = (Array.isArray(route && route.returnPath) ? route.returnPath : [])
        .map((nodeId) => normalizeNodeId(nodeId || ""))
        .filter((nodeId) => isSelectableNodeId(nodeId) && nodeMap.has(nodeId));
      const routeEdgesRaw = Array.isArray(route && route.edges) ? route.edges : [];
      const returnEdgesRaw = Array.isArray(route && route.returnEdges) ? route.returnEdges : [];
      const pathIndex = new Map(path.map((nodeId, index) => [nodeId, index]));
      const scopedPathNodeIds = new Set(path.concat(returnPath));
      const routeEdgeKeys = new Set();
      const routeEdges = [];
      const maxSideLinks = Math.max(6, Math.min(14, path.length * 2));
      const maxSideLinksPerRouteNode = 2;
      const maxClusterLinks = 8;
      const maxClusterNewNodes = 5;
      const appendPathEdges = (pathNodes, rawEdges, kind = "route") => {{
        for (let index = 0; index < Math.max(0, pathNodes.length - 1); index += 1) {{
          const a = pathNodes[index];
          const b = pathNodes[index + 1];
          const edge = rawEdges[index] || ((adjacency.get(a) || new Map()).get(b)) || null;
          const key = networkGraphEdgeKeyBetween(a, b);
          if (!key) continue;
          const keyAlreadyPresent = routeEdgeKeys.has(key);
          if (!keyAlreadyPresent) routeEdgeKeys.add(key);
          if (keyAlreadyPresent && kind !== "return") continue;
          routeEdges.push({{
            key,
            a,
            b,
            edge,
            kind,
            routeIndex: index,
          }});
        }}
      }};
      appendPathEdges(path, routeEdgesRaw, "route");
      appendPathEdges(returnPath, returnEdgesRaw, "return");

      const candidateKeys = new Set();
      const contextCandidates = [];
      for (const nodeId of scopedPathNodeIds) {{
        const peers = adjacency.get(nodeId);
        if (!(peers instanceof Map)) continue;
        for (const [peerIdRaw, edge] of peers.entries()) {{
          const peerId = normalizeNodeId(peerIdRaw || "");
          if (!isSelectableNodeId(peerId) || !nodeMap.has(peerId)) continue;
          const key = networkGraphEdgeKeyBetween(nodeId, peerId);
          if (!key || routeEdgeKeys.has(key) || candidateKeys.has(key)) continue;
          candidateKeys.add(key);
          contextCandidates.push({{
            key,
            a: nodeId,
            b: peerId,
            edge,
            kind: pathIndex.has(peerId) ? "alternate" : "context",
            routeIndex: pathIndex.has(nodeId) ? pathIndex.get(nodeId) : 0,
          }});
        }}
      }}
      contextCandidates.sort((left, right) => {{
        const leftWeight = Math.max(0, Number(left && left.edge && left.edge.weight) || 0);
        const rightWeight = Math.max(0, Number(right && right.edge && right.edge.weight) || 0);
        return (rightWeight - leftWeight) || String(left && left.key || "").localeCompare(String(right && right.key || ""));
      }});

      const sideLinkCountByRouteNode = new Map();
      const contextEdges = [];
      for (const item of contextCandidates) {{
        if (contextEdges.length >= maxSideLinks) break;
        const routeAnchor = pathIndex.has(item.a) ? item.a : (pathIndex.has(item.b) ? item.b : "");
        if (routeAnchor) {{
          const count = Number(sideLinkCountByRouteNode.get(routeAnchor) || 0);
          if (count >= maxSideLinksPerRouteNode) continue;
          sideLinkCountByRouteNode.set(routeAnchor, count + 1);
        }}
        contextEdges.push(item);
      }}

      const nodeIds = new Set(scopedPathNodeIds);
      const ringOneContextIds = new Set();
      for (const item of contextEdges) {{
        const a = normalizeNodeId(item && item.a || "");
        const b = normalizeNodeId(item && item.b || "");
        if (isSelectableNodeId(a) && nodeMap.has(a)) nodeIds.add(a);
        if (isSelectableNodeId(b) && nodeMap.has(b)) nodeIds.add(b);
        if (isSelectableNodeId(a) && !pathIndex.has(a)) ringOneContextIds.add(a);
        if (isSelectableNodeId(b) && !pathIndex.has(b)) ringOneContextIds.add(b);
      }}

      const scopedEdgeKeys = new Set(routeEdges.map((item) => String(item && item.key || "")));
      for (const item of contextEdges) {{
        const key = String(item && item.key || "").trim();
        if (key) scopedEdgeKeys.add(key);
      }}

      const clusterCandidates = [];
      for (const contextNodeId of ringOneContextIds) {{
        const peers = adjacency.get(contextNodeId);
        if (!(peers instanceof Map)) continue;
        for (const [peerIdRaw, edge] of peers.entries()) {{
          const peerId = normalizeNodeId(peerIdRaw || "");
          if (!isSelectableNodeId(peerId) || !nodeMap.has(peerId) || peerId === contextNodeId) continue;
          const key = networkGraphEdgeKeyBetween(contextNodeId, peerId);
          if (!key || scopedEdgeKeys.has(key)) continue;
          const peerOnRoute = pathIndex.has(peerId);
          const peerInRingOne = ringOneContextIds.has(peerId);
          const clusterPriority = peerInRingOne ? 0 : (peerOnRoute ? 1 : 2);
          clusterCandidates.push({{
            key,
            a: contextNodeId,
            b: peerId,
            edge,
            kind: peerOnRoute ? "alternate" : "cluster",
            clusterPriority,
          }});
        }}
      }}

      clusterCandidates.sort((left, right) => {{
        const leftPriority = Number(left && left.clusterPriority);
        const rightPriority = Number(right && right.clusterPriority);
        if (leftPriority !== rightPriority) return leftPriority - rightPriority;
        const leftWeight = Math.max(0, Number(left && left.edge && left.edge.weight) || 0);
        const rightWeight = Math.max(0, Number(right && right.edge && right.edge.weight) || 0);
        return (rightWeight - leftWeight) || String(left && left.key || "").localeCompare(String(right && right.key || ""));
      }});

      const clusterEdges = [];
      let clusterNewNodeCount = 0;
      for (const item of clusterCandidates) {{
        if (clusterEdges.length >= maxClusterLinks) break;
        const a = normalizeNodeId(item && item.a || "");
        const b = normalizeNodeId(item && item.b || "");
        const aKnown = nodeIds.has(a);
        const bKnown = nodeIds.has(b);
        if (!aKnown && !bKnown) continue;
        const newNodes = (aKnown ? 0 : 1) + (bKnown ? 0 : 1);
        if (newNodes > 0 && clusterNewNodeCount >= maxClusterNewNodes) continue;
        if (newNodes > 0) clusterNewNodeCount += newNodes;
        nodeIds.add(a);
        nodeIds.add(b);
        scopedEdgeKeys.add(item.key);
        clusterEdges.push(item);
      }}

      const scopedEdges = routeEdges.concat(contextEdges, clusterEdges);
      const routeDistanceByNodeId = new Map();
      const queue = [];
      for (const nodeId of path) {{
        routeDistanceByNodeId.set(nodeId, 0);
        queue.push(nodeId);
      }}
      for (let cursor = 0; cursor < queue.length; cursor += 1) {{
        const nodeId = normalizeNodeId(queue[cursor] || "");
        const depth = Number(routeDistanceByNodeId.get(nodeId));
        const peers = adjacency.get(nodeId);
        if (!(peers instanceof Map)) continue;
        for (const [peerIdRaw] of peers.entries()) {{
          const peerId = normalizeNodeId(peerIdRaw || "");
          if (!nodeIds.has(peerId)) continue;
          const nextDepth = depth + 1;
          const previous = routeDistanceByNodeId.get(peerId);
          if (previous == null || nextDepth < previous) {{
            routeDistanceByNodeId.set(peerId, nextDepth);
            queue.push(peerId);
          }}
        }}
      }}

      return {{
        path,
        pathIndex,
        routeEdgeKeys,
        routeEdges,
        contextEdges,
        clusterEdges,
        edges: scopedEdges,
        routeDistanceByNodeId,
        nodeIds: Array.from(nodeIds),
      }};
    }}

    function networkRoutesScopeLabeledNodeIds(scoped, fromNodeId = "", toNodeId = "", localNodeId = "") {{
      const path = Array.isArray(scoped && scoped.path) ? scoped.path : [];
      const nodeIds = Array.isArray(scoped && scoped.nodeIds) ? scoped.nodeIds : [];
      const fromId = normalizeNodeId(fromNodeId || "");
      const toId = normalizeNodeId(toNodeId || "");
      const localId = normalizeNodeId(localNodeId || "");
      const labeledNodeIds = new Set();
      for (const rawNodeId of nodeIds) {{
        const clean = normalizeNodeId(rawNodeId || "");
        if (isSelectableNodeId(clean)) labeledNodeIds.add(clean);
      }}
      for (const routeNodeId of path) {{
        const clean = normalizeNodeId(routeNodeId || "");
        if (isSelectableNodeId(clean)) labeledNodeIds.add(clean);
      }}
      if (isSelectableNodeId(fromId)) labeledNodeIds.add(fromId);
      if (isSelectableNodeId(toId)) labeledNodeIds.add(toId);
      if (isSelectableNodeId(localId)) labeledNodeIds.add(localId);
      return labeledNodeIds;
    }}

    function networkRoutesScopeDefaultViewBox(layout, scoped, nodeMap, options = {{}}) {{
      const safeLayout = (layout && typeof layout === "object") ? layout : {{}};
      const width = Math.max(240, Number(safeLayout.width) || 920);
      const height = Math.max(180, Number(safeLayout.height) || 270);
      const positions = safeLayout.positions instanceof Map ? safeLayout.positions : new Map();
      const safeScoped = (scoped && typeof scoped === "object") ? scoped : {{}};
      const pathIndex = safeScoped.pathIndex instanceof Map ? safeScoped.pathIndex : new Map();
      const nodeIds = Array.isArray(safeScoped.nodeIds) ? safeScoped.nodeIds : [];
      const opts = (options && typeof options === "object") ? options : {{}};
      const fromId = normalizeNodeId(opts.fromId || "");
      const toId = normalizeNodeId(opts.toId || "");
      const localId = normalizeNodeId(opts.localNodeId || "");
      const labeledNodeIds = opts.labeledNodeIds instanceof Set ? opts.labeledNodeIds : new Set();
      const labelPlans = opts.labelPlans instanceof Map ? opts.labelPlans : new Map();
      const dense = pathIndex.size > 6 || nodeIds.length > 14;
      let minX = Infinity;
      let maxX = -Infinity;
      let minY = Infinity;
      let maxY = -Infinity;
      for (const rawNodeId of nodeIds) {{
        const clean = normalizeNodeId(rawNodeId || "");
        const point = positions.get(clean);
        if (!point) continue;
        const x = Number(point.x);
        const y = Number(point.y);
        if (!Number.isFinite(x) || !Number.isFinite(y)) continue;
        const isRoute = pathIndex.has(clean);
        const isFrom = clean && clean === fromId;
        const isTo = clean && clean === toId;
        const isLocal = clean && clean === localId;
        const radius = isFrom || isTo ? 18 : (isRoute ? 15 : 10);
        const labelPlan = labelPlans.get(clean) || null;
        const showLabel = labelPlan
          ? !!labelPlan.showName
          : labeledNodeIds.has(clean);
        const showMeta = labelPlan
          ? !!labelPlan.showMeta
          : (showLabel && (isRoute || isFrom || isTo || isLocal));
        const showCity = labelPlan
          ? !!labelPlan.showCity
          : showMeta;
        const name = networkGraphNodeDisplayName(clean, nodeMap);
        const labelMax = isRoute
          ? (dense ? 12 : 14)
          : (showMeta ? 10 : 9);
        const label = showLabel
          ? String(
              labelPlan && labelPlan.nameLabel
                ? labelPlan.nameLabel
                : truncateNetworkGraphLabel(name, labelMax)
            )
          : "";
        const nameHalfWidth = showLabel
          ? Math.max(22, (label.length * (isRoute ? 4.4 : 3.8)) + 10)
          : 0;
        const idHalfWidth = showMeta ? 28 : 0;
        const cityLabel = (showCity && labelPlan && labelPlan.cityLabel)
          ? String(labelPlan.cityLabel || "")
          : "";
        const cityHalfWidth = showCity
          ? Math.max(26, (cityLabel.length * 3.1) + 8)
          : 0;
        const nodeHalfWidth = Math.max(radius + 12, nameHalfWidth, idHalfWidth, cityHalfWidth);
        const top = y - radius - 16;
        const bottom = y + radius + (showCity ? 52 : (showMeta ? 40 : (showLabel ? 28 : 16)));
        minX = Math.min(minX, x - nodeHalfWidth);
        maxX = Math.max(maxX, x + nodeHalfWidth);
        minY = Math.min(minY, top);
        maxY = Math.max(maxY, bottom);
      }}
      if (![minX, maxX, minY, maxY].every((value) => Number.isFinite(value))) {{
        return {{ x: 0, y: 0, width, height }};
      }}
      const paddingX = 22;
      const paddingY = 14;
      const nextX = minX - paddingX;
      const nextY = minY - paddingY;
      const nextWidth = Math.max(width, (maxX - minX) + (paddingX * 2));
      const nextHeight = Math.max(height, (maxY - minY) + (paddingY * 2));
      return {{
        x: Math.floor(nextX),
        y: Math.floor(nextY),
        width: Math.ceil(nextWidth),
        height: Math.ceil(nextHeight),
      }};
    }}

    function networkRoutesScopeRectsIntersect(left, right) {{
      const a = (left && typeof left === "object") ? left : null;
      const b = (right && typeof right === "object") ? right : null;
      if (!a || !b) return false;
      return !(
        Number(a.maxX) <= Number(b.minX)
        || Number(a.minX) >= Number(b.maxX)
        || Number(a.maxY) <= Number(b.minY)
        || Number(a.minY) >= Number(b.maxY)
      );
    }}

    function networkRoutesScopeApproxTextHalfWidth(text, unitsPerChar = 3.8, minWidth = 0) {{
      const clean = String(text || "").trim();
      if (!clean) return Math.max(0, Number(minWidth) || 0);
      const chars = clean.length;
      const width = (chars * Math.max(2.4, Number(unitsPerChar) || 3.8)) + 6;
      return Math.max(Math.max(0, Number(minWidth) || 0), width);
    }}

    function networkRoutesScopeLabelBox(point, radius, plan) {{
      if (!point || typeof point !== "object" || !plan || !plan.showName) return null;
      const centerX = Number(point.x);
      const centerY = Number(point.y);
      if (!Number.isFinite(centerX) || !Number.isFinite(centerY)) return null;
      const safeRadius = Math.max(0, Number(radius) || 0);
      const nameHalf = networkRoutesScopeApproxTextHalfWidth(plan.nameLabel, plan.nameUnitsPerChar, 20);
      const cityHalf = plan.showCity
        ? networkRoutesScopeApproxTextHalfWidth(plan.cityLabel, plan.cityUnitsPerChar, 18)
        : 0;
      const halfWidth = Math.max(nameHalf, cityHalf, safeRadius + 10);
      const top = centerY + safeRadius + 4;
      const bottom = centerY + safeRadius + (plan.showCity ? 30 : 18);
      return {{
        minX: centerX - halfWidth,
        maxX: centerX + halfWidth,
        minY: top,
        maxY: bottom,
      }};
    }}

    function networkRoutesScopeLabelVariants(candidate) {{
      const safe = (candidate && typeof candidate === "object") ? candidate : {{}};
      const fullName = String(safe.nameFull || "").trim();
      if (!fullName) {{
        return [{{
          showName: false,
          showMeta: false,
          showCity: false,
          nameLabel: "",
          cityLabel: "",
          allowOverlap: false,
        }}];
      }}
      const cityFull = String(safe.cityLabelFull || "").trim();
      const showMetaBase = !!safe.showMetaBase;
      const isFocused = !!safe.isFocused;
      const isPriority = isFocused || !!safe.isRoute || !!safe.isFrom || !!safe.isTo || !!safe.isLocal;
      const variants = [];
      const seen = new Set();
      const pushVariant = (nameMax, metaEnabled, cityEnabled, cityMax = 0, allowOverlap = false, cityUnitsPerChar = 2.55) => {{
        const rawName = truncateNetworkGraphLabel(fullName, Math.max(4, Math.trunc(Number(nameMax) || fullName.length)));
        const nameLabel = String(rawName || "").trim();
        if (!nameLabel) return;
        const showMeta = !!(metaEnabled && showMetaBase);
        const showCity = !!(showMeta && cityEnabled && cityFull);
        const maxCityChars = Math.max(0, Math.trunc(Number(cityMax) || 0));
        const cityLabel = showCity
          ? String((maxCityChars > 0 ? truncateNetworkGraphLabel(cityFull, Math.max(6, maxCityChars)) : cityFull) || "").trim()
          : "";
        const key = `${{nameLabel}}|${{showMeta ? 1 : 0}}|${{showCity ? cityLabel : ""}}|${{allowOverlap ? 1 : 0}}`;
        if (seen.has(key)) return;
        seen.add(key);
        variants.push({{
          showName: true,
          showMeta,
          showCity: !!(showCity && cityLabel),
          nameLabel,
          cityLabel: showCity ? cityLabel : "",
          cityMaxChars: showCity ? maxCityChars : 0,
          cityUnitsPerChar: Math.max(2.1, Number(cityUnitsPerChar) || 2.55),
          allowOverlap: !!allowOverlap,
        }});
      }};
      if (isPriority) {{
        if (isFocused) {{
          pushVariant(160, true, true, 120, false, 2.55);
          pushVariant(160, true, true, 96, false, 2.55);
          pushVariant(160, true, false, 0, false, 2.55);
          pushVariant(120, true, false, 0, false, 2.55);
        }}
        pushVariant(120, true, true, 96, false, 2.55);
        pushVariant(120, true, true, 72, false, 2.55);
        pushVariant(120, true, true, 56, false, 2.55);
        pushVariant(120, true, true, 42, false, 2.55);
        pushVariant(120, true, true, 32, false, 2.55);
        pushVariant(120, true, false, 0, false, 2.55);
        pushVariant(36, true, false, 0, false);
        pushVariant(26, true, false, 0, false);
        pushVariant(20, true, false, 0, false);
        pushVariant(15, false, false, 0, false);
        pushVariant(11, false, false, 0, true);
      }} else {{
        pushVariant(96, false, false, 0, false);
        pushVariant(34, false, false, 0, false);
        pushVariant(24, false, false, 0, false);
        pushVariant(18, false, false, 0, false);
        pushVariant(14, false, false, 0, false);
        pushVariant(10, false, false, 0, false);
        pushVariant(8, false, false, 0, false);
        variants.push({{
          showName: false,
          showMeta: false,
          showCity: false,
          nameLabel: "",
          cityLabel: "",
          cityMaxChars: 0,
          cityUnitsPerChar: 2.55,
          allowOverlap: false,
        }});
      }}
      return variants;
