      const def = networkTopNodesCategoryDef(category);
      const label = String(safePayload.category_label || def.label || "Top Nodes");
      const items = Array.isArray(safePayload.items) ? safePayload.items : [];
      const groups = Array.isArray(safePayload.groups)
        ? safePayload.groups.filter((group) => Array.isArray(group && group.items) && group.items.length > 0)
        : [];
      const displayGroups = groups.length > 0
        ? groups
        : (items.length > 0 ? [safePayload] : []);
      const source = String(safePayload.source || (safePayload.fallback ? "current state" : "history")).trim();
      const errorText = String(options.error || safePayload.error || "").trim();
      const loading = !!options.loading;

      if (status instanceof HTMLElement) {{
        status.textContent = loading ? "Loading..." : (errorText ? "Current state fallback" : "");
      }}

      if (category === "all" || displayGroups.length > 0) {{
        const itemCount = displayGroups.reduce((sum, group) => {{
          const groupItems = Array.isArray(group && group.items) ? group.items : [];
          return sum + groupItems.length;
        }}, 0);
        const groupLabel = displayGroups.length === 1 ? "list" : "lists";
        summary.innerHTML = `<span><strong>${{escAttr(label)}}</strong> - ${{escAttr(source)}}${{errorText ? ` - ${{escAttr(errorText)}}` : ""}}</span><span>${{escAttr(String(displayGroups.length))}} ${{escAttr(groupLabel)}} - ${{escAttr(String(itemCount))}} entries</span>`;
