      const localId = normalizeNodeId(resolveLocalNodeId(safeState) || "");
      summary.innerHTML = `<div class="network-graph-summary-main"><label class="network-graph-layout-control history-metric-wrap history-select-chip-hide-label" for="network-graph-layout-select"><span class="network-graph-chip-label history-metric-label">View</span><select id="network-graph-layout-select" class="network-graph-layout-select history-metric-select" aria-label="Network links layout"><option value="radial"${{layoutMode === "radial" ? " selected" : ""}}>Radial</option><option value="tree"${{layoutMode === "tree" ? " selected" : ""}}>Tree</option><option value="cluster"${{layoutMode === "cluster" ? " selected" : ""}}>Cluster</option><option value="community"${{layoutMode === "community" ? " selected" : ""}}>Community</option></select></label><button id="network-graph-reset-view-btn" class="network-graph-chip network-graph-action-chip" type="button" title="Reset links view" aria-controls="network-graph-svg"><span class="network-graph-chip-label">View</span><strong>Reset</strong></button></div><div class="network-graph-summary-side"><label class="network-graph-mode-control history-metric-wrap history-select-chip-hide-label" for="network-graph-mode-select" title="Switch Links view between stored history topology and the current session topology"><span class="network-graph-chip-label history-metric-label">Mode</span><select id="network-graph-mode-select" class="network-graph-mode-select history-metric-select" aria-label="Network links source"><option value="history"${{edgeMode === "history" ? " selected" : ""}}>History</option><option value="live"${{edgeMode === "live" ? " selected" : ""}}>Live</option></select></label></div>`;
      bindNetworkGraphLayoutSelector();
