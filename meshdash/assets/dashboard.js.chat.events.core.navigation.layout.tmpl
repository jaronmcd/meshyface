      const launcherBtn = target.closest("#layout-view-menu .topbar-view-menu-item");
      if (launcherBtn instanceof HTMLButtonElement) {{
        if (launcherBtn.disabled) return "";
        if (String(launcherBtn.dataset.submenu || "").trim()) return "";
        return String(launcherBtn.dataset.view || "chat");
      }}

      return "";
    }}

    function applyLayoutView(viewName, persist = true) {{
      const layout = document.getElementById("dashboard-layout");
      if (!(layout instanceof HTMLElement)) return;
      const shell = document.querySelector(".workspace-shell");
      const chatLeftPanel = document.getElementById("chat-left-panel");
      const requested = String(viewName || "").trim().toLowerCase();
      const requestedSavedAlias = requested === "saved";
      const next = normalizeLayoutView(viewName);
      const previous = normalizeLayoutView(activeLayoutView);
      const leavingNetworkGraphLayout = !!(
        previous === "network"
        && next !== "network"
        && normalizeNetworkSubview(activeNetworkSubview) === "graph"
      );
      if (next === "console") {{
        if (previous !== "console") {{
          consoleHotkeyReturnLayoutView = previous;
        }}
      }} else {{
        consoleHotkeyReturnLayoutView = next;
      }}
      if (leavingNetworkGraphLayout) {{
        clearNetworkGraphDom();
      }}
      activeLayoutView = next;
      if (resolveTopbarLauncherLayoutView(next) === "apps") {{
        acknowledgeAppsLauncherNotifications(latestState, {{ sync: false }});
      }}
      persistPreferredAppsLayoutView(next);
      for (const name of knownLayoutViews) {{
