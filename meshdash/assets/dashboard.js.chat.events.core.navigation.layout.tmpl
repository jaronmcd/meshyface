    function animateNetworkGraphViewBox(svg, rawViewBox, options = {{}}) {{
      if (!(svg instanceof SVGElement)) return cloneNetworkGraphViewBox();
      const aspectRatio = getNetworkGraphStageAspectRatio(svg);
      const target = clampNetworkGraphViewBox(rawViewBox, {{
        aspectRatio,
        preserveRequestedCenter: !!(options && options.preserveRequestedCenter),
      }});
      const current = cloneNetworkGraphViewBox(networkGraphViewState.viewBox);
      const onComplete = (options && typeof options.onComplete === "function")
        ? options.onComplete
        : null;
      const durationMs = Math.max(
        0,
        Number.isFinite(Number(options && options.durationMs))
          ? Number(options && options.durationMs)
          : networkGraphFocusAnimationDurationMs
