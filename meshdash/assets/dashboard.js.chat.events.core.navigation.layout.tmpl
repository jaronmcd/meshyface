    async function fetchNetworkTopNodesPayload(category, force = false) {{
      const clean = normalizeNetworkTopNodesCategory(category);
      const cached = networkTopNodesCache instanceof Map ? networkTopNodesCache.get(clean) : null;
      const now = Date.now();
      if (
        !force
        && cached
        && cached.payload
        && (now - Number(cached.fetchedAtMs || 0)) < Math.max(30000, refreshMs * 10)
      ) {{
        return cached.payload;
      }}
      const resp = await fetch(`/api/history/top_nodes?category=${{encodeURIComponent(clean)}}&limit=10`, {{ cache: "no-store" }});
      const payload = await resp.json();
      if (!resp.ok || !payload || payload.ok === false) {{
        const message = payload && payload.error ? String(payload.error) : `HTTP ${{resp.status}}`;
        throw new Error(message);
      }}
      if (networkTopNodesCache instanceof Map) {{
        networkTopNodesCache.set(clean, {{
          payload,
          fetchedAtMs: now,
        }});
      }}
      return payload;
    }}

    function renderNetworkTopNodes(state = latestState, options = {{}}) {{
      bindNetworkTopNodesControls();
      networkTopNodesCategory = normalizeNetworkTopNodesCategory(networkTopNodesCategory);
      ensureNetworkTopNodesCategoryOptions();
      const select = document.getElementById("network-top-nodes-category");
      if (select instanceof HTMLSelectElement && select.value !== networkTopNodesCategory) {{
        select.value = networkTopNodesCategory;
      }}
      const localPayload = buildLocalNetworkTopNodesPayload(networkTopNodesCategory, state);
      renderNetworkTopNodesPayload(localPayload, state, {{
        loading: true,
      }});
      const force = !!(options && options.force);
      const requestCategory = networkTopNodesCategory;
      if (
        networkTopNodesHydrateInFlight
        && normalizeNetworkTopNodesCategory(networkTopNodesHydrateInFlight.category) === requestCategory
      ) {{
        return;
      }}
      const requestToken = {{
        category: requestCategory,
      }};
      networkTopNodesHydrateInFlight = requestToken;
      requestToken.promise = fetchNetworkTopNodesPayload(requestCategory, force)
        .then((payload) => {{
          if (activeLayoutView !== "network" || activeNetworkSubview !== "top10") return;
          if (normalizeNetworkTopNodesCategory(networkTopNodesCategory) !== normalizeNetworkTopNodesCategory(payload && payload.category)) return;
          if (!networkTopNodesPayloadHasItems(payload) && networkTopNodesPayloadHasItems(localPayload)) {{
            renderNetworkTopNodesPayload(localPayload, latestState || state);
            return;
          }}
          renderNetworkTopNodesPayload(payload, latestState || state);
        }})
        .catch((err) => {{
          if (activeLayoutView !== "network" || activeNetworkSubview !== "top10") return;
          const message = err instanceof Error ? err.message : String(err || "history unavailable");
          renderNetworkTopNodesPayload(localPayload, latestState || state, {{
            error: message,
          }});
        }})
        .finally(() => {{
          if (networkTopNodesHydrateInFlight === requestToken) {{
            networkTopNodesHydrateInFlight = null;
          }}
        }});
    }}

