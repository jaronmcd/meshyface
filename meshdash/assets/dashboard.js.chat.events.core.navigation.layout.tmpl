        bbsTabBtn.setAttribute("aria-hidden", enabled ? "false" : "true");
      }}
      const bbsCard = document.querySelector("#dashboard-layout .card.bbs");
      if (bbsCard instanceof HTMLElement) {{
        bbsCard.hidden = !enabled;
        bbsCard.setAttribute("aria-hidden", enabled ? "false" : "true");
      }}
    }}

    function syncAppsTabBarVisibility(viewName = activeLayoutView) {{
      syncAppsTabBar(viewName);
    }}

    function resolveTopbarLauncherLayoutView(viewName) {{
      const normalized = normalizeLayoutView(viewName);
      return isAppsLayoutView(normalized) ? "apps" : normalized;
    }}

    function currentWorkspaceLauncherLabel(viewName = activeLayoutView) {{
      const normalized = resolveTopbarLauncherLayoutView(viewName);
      if (normalized === "apps") {{
        return `Apps · ${{currentAppsLauncherLabel(viewName)}}`;
      }}
      return topbarLauncherLayoutLabel(viewName);
    }}

    function topbarLauncherLayoutLabel(viewName) {{
      const normalized = resolveTopbarLauncherLayoutView(viewName);
      if (normalized === "network") return "Network";
      if (normalized === "console") return "Console";
      if (normalized === "apps") return "Apps";
      if (normalized === "settings") return "Settings";
      return "Chat";
    }}

    function workspaceLauncherViewNotificationCount(viewName) {{
      const key = resolveTopbarLauncherLayoutView(viewName);
      return Math.max(0, Math.trunc(Number(workspaceLauncherNotificationCounts[key] || 0) || 0));
    }}

    function totalWorkspaceLauncherNotificationCount() {{
      let total = 0;
      for (const viewName of ["chat", "network", "console", "apps", "settings"]) {{
        total += workspaceLauncherViewNotificationCount(viewName);
      }}
      return total;
    }}

    function workspaceLauncherNotificationLabel(count) {{
      const safeCount = Math.max(0, Math.trunc(Number(count) || 0));
      return safeCount > 99 ? "99+" : String(safeCount);
    }}

    function setWorkspaceLauncherViewNotificationCount(viewName, count, options = {{}}) {{
      const key = resolveTopbarLauncherLayoutView(viewName);
      if (!Object.prototype.hasOwnProperty.call(workspaceLauncherNotificationCounts, key)) {{
        return 0;
      }}
      const safeCount = Math.max(0, Math.min(999, Math.trunc(Number(count) || 0)));
      if (workspaceLauncherNotificationCounts[key] === safeCount) {{
        return safeCount;
      }}
      workspaceLauncherNotificationCounts[key] = safeCount;
      if (!(options && options.sync === false)) {{
        syncLayoutViewMenu(activeLayoutView);
      }}
      return safeCount;
    }}

    function incrementWorkspaceLauncherViewNotificationCount(viewName, delta = 1) {{
      const key = resolveTopbarLauncherLayoutView(viewName);
      const safeDelta = Math.max(0, Math.trunc(Number(delta) || 0));
      return setWorkspaceLauncherViewNotificationCount(
        key,
        workspaceLauncherViewNotificationCount(key) + safeDelta
      );
    }}

    function rememberAppsLauncherNotificationKey(rawKey) {{
      const key = String(rawKey || "").trim();
      if (!key || appsLauncherSeenKeys.has(key)) return false;
      appsLauncherSeenKeys.add(key);
      appsLauncherSeenOrder.push(key);
      if (appsLauncherSeenOrder.length > 2200) {{
        while (appsLauncherSeenOrder.length > 1600) {{
          const stale = appsLauncherSeenOrder.shift();
          if (stale) appsLauncherSeenKeys.delete(stale);
        }}
      }}
      return true;
    }}

    function collectAppsLauncherNotificationKeys(state = latestState) {{
      const keys = [];
      const keySet = new Set();
      const safeState = (state && typeof state === "object") ? state : latestState;
      const pushKey = (rawKey) => {{
        const key = String(rawKey || "").trim();
        if (!key || keySet.has(key)) return;
        keySet.add(key);
        keys.push(key);
      }};

      if (fileTransferFeatureEnabled) {{
        const fileRows = buildFileTransferRows(safeState);
        for (const row of fileRows) {{
          if (!row || typeof row !== "object") continue;
          const rowKey = String(row.key || "").trim();
          if (!rowKey) continue;
          if (String(row.directionClass || "").trim().toLowerCase() !== "inbound") continue;
          if (row.delivered || row.inboundDeclined) continue;
          const progressState = String(row.progressState || "").trim().toLowerCase();
          if (progressState === "success") continue;
          pushKey(`files:${{rowKey}}`);
        }}
      }}

      for (const row of (Array.isArray(reversiPendingInvites) ? reversiPendingInvites : [])) {{
        const inviteKey = reversiInviteKey(
          row && (row.from_id ?? row.fromId),
          row && (row.session_id ?? row.sessionId)
        );
        if (inviteKey) {{
          pushKey(`games:reversi:${{inviteKey}}`);
        }}
      }}

      for (const gameId of ["checkers", "chess"]) {{
        const refs = boardGameRefs(gameId);
        for (const row of refs.getPendingInvites()) {{
          const inviteKey = boardGameInviteKey(
            row && (row.from_id ?? row.fromId),
            row && (row.session_id ?? row.sessionId)
          );
          if (inviteKey) {{
            pushKey(`games:${{gameId}}:${{inviteKey}}`);
          }}
        }}
      }}

      return keys;
    }}

    function acknowledgeAppsLauncherNotifications(state = latestState, options = {{}}) {{
      for (const key of collectAppsLauncherNotificationKeys(state)) {{
        rememberAppsLauncherNotificationKey(key);
      }}
      return setWorkspaceLauncherViewNotificationCount("apps", 0, options);
    }}

    function syncAppsLauncherNotifications(state = latestState) {{
      const appsViewVisible = (
        resolveTopbarLauncherLayoutView(activeLayoutView) === "apps"
        && !(typeof document !== "undefined" && document.hidden)
        && !!tabHasFocus
      );
      if (appsViewVisible) {{
        acknowledgeAppsLauncherNotifications(state);
        return 0;
      }}
      let freshCount = 0;
      for (const key of collectAppsLauncherNotificationKeys(state)) {{
        if (rememberAppsLauncherNotificationKey(key)) {{
          freshCount += 1;
        }}
      }}
      if (freshCount > 0) {{
        incrementWorkspaceLauncherViewNotificationCount("apps", freshCount);
      }}
      return freshCount;
    }}

    function syncLayoutViewLauncherButtonState(viewName = activeLayoutView) {{
      const launcherBtn = document.getElementById("layout-view-menu-btn");
      const launcherLabel = document.getElementById("layout-view-menu-btn-label");
      const launcherLabelText = document.getElementById("layout-view-menu-btn-label-text");
      const launcherBadge = document.getElementById("layout-view-menu-btn-badge");
      const attentionIndicator = document.getElementById("layout-view-menu-attention-indicator");
      if (!(launcherBtn instanceof HTMLButtonElement)) return;

      const activeLabel = currentWorkspaceLauncherLabel(viewName);
      const launcherLabelTarget = (launcherLabelText instanceof HTMLElement) ? launcherLabelText : launcherLabel;
      if (launcherLabelTarget instanceof HTMLElement && launcherLabelTarget.textContent !== activeLabel) {{
        launcherLabelTarget.textContent = activeLabel;
      }}

      const totalCount = totalWorkspaceLauncherNotificationCount();
      const totalLabel = workspaceLauncherNotificationLabel(totalCount);
      if (launcherBadge instanceof HTMLElement) {{
        launcherBadge.hidden = totalCount <= 0;
        if (totalCount > 0 && launcherBadge.textContent !== totalLabel) {{
          launcherBadge.textContent = totalLabel;
        }}
      }}
      if (attentionIndicator instanceof HTMLElement) {{
        attentionIndicator.hidden = true;
      }}
      launcherBtn.classList.toggle("has-unread", totalCount > 0);

      const titleParts = ["Open workspace view menu.", `Current view: ${{activeLabel}}.`];
      if (totalCount > 0) {{
        titleParts.push(`Total notifications: ${{totalLabel}}.`);
      }}
      const summaryParts = [];
      for (const launcherView of ["chat", "network", "console", "apps", "settings"]) {{
        const count = workspaceLauncherViewNotificationCount(launcherView);
        if (count <= 0) continue;
        const countLabel = workspaceLauncherNotificationLabel(count);
        summaryParts.push(`${{topbarLauncherLayoutLabel(launcherView)}} ${{countLabel}}`);
      }}
      if (summaryParts.length > 0) {{
        titleParts.push(`New activity: ${{summaryParts.join(", ")}}.`);
      }}
      const nextTitle = titleParts.join(" ");
      launcherBtn.title = nextTitle;
      launcherBtn.setAttribute("aria-label", nextTitle);
    }}

    function syncLayoutViewMenu(viewName = activeLayoutView) {{
      const launcherView = resolveTopbarLauncherLayoutView(viewName);
      for (const btn of document.querySelectorAll("#layout-view-menu .topbar-view-menu-item")) {{
        if (!(btn instanceof HTMLButtonElement)) continue;
        const btnView = String(btn.dataset.view || "").trim().toLowerCase();
        const isActive = btnView === launcherView;
        const hasSubmenu = String(btn.dataset.submenu || "").trim().length > 0;
        const notificationCount = workspaceLauncherViewNotificationCount(btnView);
        const notificationLabel = workspaceLauncherNotificationLabel(notificationCount);
        const notificationText = notificationCount > 0
          ? `${{notificationLabel}} new notification${{notificationCount === 1 ? "" : "s"}}`
          : "";
        const badge = btn.querySelector(".topbar-view-menu-item-badge");
        if (badge instanceof HTMLElement) {{
          badge.hidden = notificationCount <= 0;
          if (notificationCount > 0 && badge.textContent !== notificationLabel) {{
            badge.textContent = notificationLabel;
          }}
        }}
        const baseTitle = String(btn.dataset.baseTitle || btn.title || "").trim();
        if (!btn.dataset.baseTitle) {{
          btn.dataset.baseTitle = baseTitle;
        }}
        btn.classList.toggle("is-active", isActive);
        btn.classList.toggle("has-notifications", notificationCount > 0);
        if (hasSubmenu) {{
          btn.removeAttribute("aria-checked");
        }} else {{
          btn.setAttribute("aria-checked", isActive ? "true" : "false");
        }}
        btn.setAttribute("aria-current", isActive ? "page" : "false");
        const label = topbarLauncherLayoutLabel(btnView);
        const spokenLabel = hasSubmenu ? `${{label}}. Current app: ${{currentAppsLauncherLabel(viewName)}}.` : label;
        if (notificationText) {{
          btn.title = baseTitle
            ? `${{baseTitle}} • ${{notificationText}}`
            : `${{spokenLabel}} • ${{notificationText}}`;
          btn.setAttribute(
            "aria-label",
            isActive
              ? `${{spokenLabel}} ${{notificationText}}. Current view.`
              : `${{spokenLabel}} ${{notificationText}}.`
          );
        }} else {{
          btn.title = baseTitle;
          btn.setAttribute(
            "aria-label",
            isActive
              ? `${{spokenLabel}} Current view.`
              : spokenLabel
          );
        }}
      }}
      syncAppsTabBar(viewName);
      syncLayoutViewLauncherButtonState(viewName);
    }}

    function closeLayoutViewMenu(options = {{}}) {{
      const restoreFocus = !!(options && options.restoreFocus);
      const launcherBtn = document.getElementById("layout-view-menu-btn");
      const menu = document.getElementById("layout-view-menu");
      if (menu instanceof HTMLElement) {{
        menu.hidden = true;
        menu.style.removeProperty("left");
        menu.style.removeProperty("top");
        menu.style.removeProperty("min-width");
        menu.style.removeProperty("visibility");
      }}
      closeLayoutViewSubmenus();
      if (launcherBtn instanceof HTMLButtonElement) {{
        launcherBtn.setAttribute("aria-expanded", "false");
        if (restoreFocus) {{
          launcherBtn.focus();
        }}
      }}
    }}

    function openLayoutViewMenu() {{
      const launcherBtn = document.getElementById("layout-view-menu-btn");
      const menu = document.getElementById("layout-view-menu");
      if (!(launcherBtn instanceof HTMLButtonElement) || !(menu instanceof HTMLElement)) return;

      syncLayoutViewMenu(activeLayoutView);
      closeLayoutViewSubmenus();
      menu.hidden = false;
      menu.style.visibility = "hidden";
      launcherBtn.setAttribute("aria-expanded", "true");

      const btnRect = launcherBtn.getBoundingClientRect();
      menu.style.minWidth = `${{Math.max(260, Math.ceil(btnRect.width))}}px`;
      menu.style.left = "8px";
      menu.style.top = "8px";

      const menuRect = menu.getBoundingClientRect();
      const viewportWidth = Math.max(0, window.innerWidth || document.documentElement.clientWidth || 0);
      const viewportHeight = Math.max(0, window.innerHeight || document.documentElement.clientHeight || 0);
      let left = Math.max(8, Math.round(btnRect.left));
      if (viewportWidth > 0) {{
        left = Math.min(left, Math.max(8, viewportWidth - Math.ceil(menuRect.width) - 8));
      }}
      let top = Math.round(btnRect.bottom + 8);
      if (viewportHeight > 0 && (top + menuRect.height) > (viewportHeight - 8)) {{
        top = Math.max(8, Math.round(btnRect.top - menuRect.height - 8));
      }}
      menu.style.left = `${{left}}px`;
      menu.style.top = `${{top}}px`;
      menu.style.visibility = "";
    }}

    function toggleLayoutViewMenu() {{
      const launcherBtn = document.getElementById("layout-view-menu-btn");
      if (!(launcherBtn instanceof HTMLButtonElement)) return false;
      const expanded = launcherBtn.getAttribute("aria-expanded") === "true";
      if (expanded) {{
        closeLayoutViewMenu();
      }} else {{
        openLayoutViewMenu();
      }}
      return false;
    }}

    function shouldCloseLayoutViewMenuForScrollTarget(target = null) {{
      if (target === window || target === document) {{
        return true;
      }}
      if (target instanceof Document) {{
        return true;
      }}
      if (target instanceof HTMLElement) {{
        return target === document.body || target === document.documentElement;
      }}
      return false;
    }}

    function resolveLayoutViewTargetFromEvent(ev) {{
      const rawTarget = ev && ev.target;
      const target = rawTarget instanceof Element
        ? rawTarget
        : ((rawTarget instanceof Node) ? rawTarget.parentElement : null);
      if (!(target instanceof Element)) return "";

      const appsSubmenuBtn = target.closest("#layout-view-menu .topbar-view-submenu-item");
      if (appsSubmenuBtn instanceof HTMLButtonElement) {{
        if (appsSubmenuBtn.disabled) return "";
        return String(appsSubmenuBtn.dataset.view || appsSubmenuBtn.dataset.appView || "chat");
      }}

      const launcherBtn = target.closest("#layout-view-menu .topbar-view-menu-item");
      if (launcherBtn instanceof HTMLButtonElement) {{
        if (launcherBtn.disabled) return "";
        if (String(launcherBtn.dataset.submenu || "").trim()) return "";
        return String(launcherBtn.dataset.view || "chat");
      }}

      return "";
    }}

