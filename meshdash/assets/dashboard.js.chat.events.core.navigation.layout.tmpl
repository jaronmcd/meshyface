    function workspaceLauncherViewNotificationCount(viewName) {{
      const key = resolveTopbarLauncherLayoutView(viewName);
      return Math.max(0, Math.trunc(Number(workspaceLauncherNotificationCounts[key] || 0) || 0));
    }}

    function totalWorkspaceLauncherNotificationCount() {{
      let total = 0;
      for (const viewName of ["chat", "network", "console", "apps", "settings"]) {{
        total += workspaceLauncherViewNotificationCount(viewName);
      }}
      return total;
    }}

    function workspaceLauncherNotificationLabel(count) {{
      const safeCount = Math.max(0, Math.trunc(Number(count) || 0));
      return safeCount > 99 ? "99+" : String(safeCount);
    }}

    function setWorkspaceLauncherViewNotificationCount(viewName, count, options = {{}}) {{
      const key = resolveTopbarLauncherLayoutView(viewName);
      if (!Object.prototype.hasOwnProperty.call(workspaceLauncherNotificationCounts, key)) {{
        return 0;
      }}
      const safeCount = Math.max(0, Math.min(999, Math.trunc(Number(count) || 0)));
      if (workspaceLauncherNotificationCounts[key] === safeCount) {{
        return safeCount;
      }}
      workspaceLauncherNotificationCounts[key] = safeCount;
      if (!(options && options.sync === false)) {{
        syncLayoutViewMenu(activeLayoutView);
      }}
      return safeCount;
    }}

    function incrementWorkspaceLauncherViewNotificationCount(viewName, delta = 1) {{
      const key = resolveTopbarLauncherLayoutView(viewName);
      const safeDelta = Math.max(0, Math.trunc(Number(delta) || 0));
      return setWorkspaceLauncherViewNotificationCount(
        key,
        workspaceLauncherViewNotificationCount(key) + safeDelta
      );
    }}

    function rememberAppsLauncherNotificationKey(rawKey) {{
      const key = String(rawKey || "").trim();
      if (!key || appsLauncherSeenKeys.has(key)) return false;
      appsLauncherSeenKeys.add(key);
      appsLauncherSeenOrder.push(key);
      if (appsLauncherSeenOrder.length > 2200) {{
        while (appsLauncherSeenOrder.length > 1600) {{
          const stale = appsLauncherSeenOrder.shift();
          if (stale) appsLauncherSeenKeys.delete(stale);
        }}
      }}
      return true;
    }}

    function collectAppsLauncherNotificationKeys(state = latestState) {{
      const keys = [];
      const keySet = new Set();
      const safeState = (state && typeof state === "object") ? state : latestState;
      const pushKey = (rawKey) => {{
        const key = String(rawKey || "").trim();
        if (!key || keySet.has(key)) return;
        keySet.add(key);
        keys.push(key);
      }};

      if (fileTransferFeatureEnabled) {{
        const fileRows = buildFileTransferRows(safeState);
        for (const row of fileRows) {{
          if (!row || typeof row !== "object") continue;
          const rowKey = String(row.key || "").trim();
          if (!rowKey) continue;
          if (String(row.directionClass || "").trim().toLowerCase() !== "inbound") continue;
          if (row.delivered || row.inboundDeclined) continue;
          const progressState = String(row.progressState || "").trim().toLowerCase();
          if (progressState === "success") continue;
          pushKey(`files:${{rowKey}}`);
        }}
      }}

      for (const row of (Array.isArray(reversiPendingInvites) ? reversiPendingInvites : [])) {{
        const inviteKey = reversiInviteKey(
          row && (row.from_id ?? row.fromId),
          row && (row.session_id ?? row.sessionId)
        );
        if (inviteKey) {{
          pushKey(`games:reversi:${{inviteKey}}`);
        }}
      }}

      for (const gameId of ["checkers", "chess"]) {{
        const refs = boardGameRefs(gameId);
        for (const row of refs.getPendingInvites()) {{
          const inviteKey = boardGameInviteKey(
            row && (row.from_id ?? row.fromId),
            row && (row.session_id ?? row.sessionId)
          );
          if (inviteKey) {{
            pushKey(`games:${{gameId}}:${{inviteKey}}`);
          }}
        }}
      }}

      return keys;
    }}

    function acknowledgeAppsLauncherNotifications(state = latestState, options = {{}}) {{
      for (const key of collectAppsLauncherNotificationKeys(state)) {{
        rememberAppsLauncherNotificationKey(key);
      }}
      return setWorkspaceLauncherViewNotificationCount("apps", 0, options);
    }}

    function syncAppsLauncherNotifications(state = latestState) {{
      const appsViewVisible = (
        resolveTopbarLauncherLayoutView(activeLayoutView) === "apps"
        && !(typeof document !== "undefined" && document.hidden)
        && !!tabHasFocus
      );
      if (appsViewVisible) {{
        acknowledgeAppsLauncherNotifications(state);
        return 0;
      }}
      let freshCount = 0;
      for (const key of collectAppsLauncherNotificationKeys(state)) {{
        if (rememberAppsLauncherNotificationKey(key)) {{
          freshCount += 1;
        }}
      }}
      if (freshCount > 0) {{
        incrementWorkspaceLauncherViewNotificationCount("apps", freshCount);
      }}
      return freshCount;
    }}

    function syncLayoutViewLauncherButtonState(viewName = activeLayoutView) {{
      const launcherBtn = document.getElementById("layout-view-menu-btn");
      const launcherLabel = document.getElementById("layout-view-menu-btn-label");
