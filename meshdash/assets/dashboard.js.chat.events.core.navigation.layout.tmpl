    function buildNetworkRoutesData(state = latestState) {{
      const safeState = (state && typeof state === "object") ? state : {{}};
      const nodes = Array.isArray(safeState.nodes) ? safeState.nodes : [];
      const historyCapsRaw = (safeState.history_caps && typeof safeState.history_caps === "object")
        ? safeState.history_caps
        : {{}};
      const traffic = (safeState.traffic && typeof safeState.traffic === "object") ? safeState.traffic : {{}};
      const edgeMode = normalizeNetworkGraphEdgeMode(networkRoutesWindow);
      const historyCaps = networkGraphHistoryCapsForMode(historyCapsRaw, edgeMode);
      const rawEdges = networkGraphRawEdgesForMode(
        Array.isArray(traffic.edges) ? traffic.edges : [],
        edgeMode
      );
      const historyLoading = !!(
        networkGraphEdgeModeUsesHistoryFetch(edgeMode)
        && networkGraphHistoryEdgeRequests.has(edgeMode)
        && !networkGraphHistoryEdgeCache.has(edgeMode)
      );
      const filteredRawEdges = filterNetworkGraphRawEdgesByMode(rawEdges, edgeMode);
      const localNodeId = normalizeNodeId(resolveLocalNodeId(safeState) || "");
      const searchQuery = (typeof globalNodeSearchQuery === "function")
        ? globalNodeSearchQuery()
        : "";
      const nodeMap = buildNetworkGraphNodeMap(nodes, historyCaps, filteredRawEdges, {{
        includeAllLiveNodes: true,
        pinnedNodeIds: [
          localNodeId,
          selectedNodeId,
          networkRoutesFromNodeId,
          networkRoutesToNodeId,
        ],
        historyMode: edgeMode,
        searchQuery,
      }});
      const combinedEdges = combineNetworkGraphEdges(filteredRawEdges, nodeMap, {{ mode: edgeMode }});
      const adjacency = buildNetworkGraphAdjacency(nodeMap, combinedEdges);
      return {{
        safeState,
        nodes,
        historyCaps,
        rawEdges,
        filteredRawEdges,
        nodeMap,
        combinedEdges,
        adjacency,
        edgeMode,
        localNodeId,
        historyLoading,
      }};
    }}

    function networkRoutesSortedNodeIds(nodeMap) {{
      const ids = Array.from(nodeMap instanceof Map ? nodeMap.keys() : [])
        .map((nodeId) => normalizeNodeId(nodeId || ""))
        .filter((nodeId) => isSelectableNodeId(nodeId));
      ids.sort((a, b) => {{
        const nameA = networkGraphNodeDisplayName(a, nodeMap).toLowerCase();
        const nameB = networkGraphNodeDisplayName(b, nodeMap).toLowerCase();
        return nameA.localeCompare(nameB) || a.localeCompare(b);
      }});
      return ids;
    }}

    function resolveNetworkRoutesSelections(data, nodeIds) {{
      const safeIds = Array.isArray(nodeIds) ? nodeIds : [];
      if (!safeIds.length) return {{ fromId: "", toId: "" }};
      const nodeMap = data && data.nodeMap instanceof Map ? data.nodeMap : new Map();
      const localNodeId = normalizeNodeId(data && data.localNodeId || "");
      const selectedId = normalizeNodeId(selectedNodeId || "");
      let fromId = normalizeNodeId(networkRoutesFromNodeId || "");
      if (localNodeId && nodeMap.has(localNodeId)) {{
        fromId = localNodeId;
      }} else if (!fromId || !nodeMap.has(fromId)) {{
        fromId = (localNodeId && nodeMap.has(localNodeId)) ? localNodeId : safeIds[0];
      }}
      let toId = normalizeNodeId(networkRoutesToNodeId || "");
      if (!toId || !nodeMap.has(toId) || (safeIds.length > 1 && toId === fromId)) {{
        if (selectedId && selectedId !== fromId && nodeMap.has(selectedId)) {{
          toId = selectedId;
        }} else {{
          toId = safeIds.find((nodeId) => nodeId !== fromId) || fromId;
        }}
      }}
      return {{ fromId, toId }};
    }}

    function syncNetworkRoutesFromSelectedNode() {{
      const inputState = arguments.length > 0 ? arguments[0] : latestState;
      const rawOptions = arguments.length > 1 ? arguments[1] : null;
      const safeState = (inputState && typeof inputState === "object") ? inputState : (latestState || {{}});
      const opts = (rawOptions && typeof rawOptions === "object") ? rawOptions : {{}};
      const preferSelectedTarget = opts.preferSelectedTarget === true;
      const localNodeId = normalizeNodeId(resolveLocalNodeId(safeState) || "");
      const selectedId = normalizeNodeId(selectedNodeId || "");
      if (!isSelectableNodeId(selectedId) && !isSelectableNodeId(localNodeId)) return false;
      const previousFrom = normalizeNodeId(networkRoutesFromNodeId || "");
      const previousTo = normalizeNodeId(networkRoutesToNodeId || "");
      const nextFrom = isSelectableNodeId(localNodeId) ? localNodeId : selectedId;
      const mode = normalizeNetworkRoutesMode(networkRoutesMode);
      const pinnedTargetId = getNetworkRoutesPinnedTargetId();
      const lockLiveTarget = (
        mode === "live"
        && isSelectableNodeId(pinnedTargetId)
        && !preferSelectedTarget
      );
      let changed = previousFrom !== nextFrom;
      networkRoutesFromNodeId = selectedId;
      networkRoutesFromNodeId = nextFrom;
      if (lockLiveTarget && pinnedTargetId !== nextFrom) {{
        networkRoutesToNodeId = pinnedTargetId;
        changed = changed || previousTo !== pinnedTargetId;
      }} else if (isSelectableNodeId(selectedId) && selectedId !== nextFrom) {{
        networkRoutesToNodeId = selectedId;
        if (mode === "live" && preferSelectedTarget) {{
          setNetworkRoutesPinnedTargetId(selectedId);
        }}
        changed = changed || previousTo !== selectedId;
      }} else if (!previousTo || previousTo === nextFrom) {{
        const nextTo = previousFrom && previousFrom !== selectedId ? previousFrom : "";
        const fallbackTo = previousFrom && previousFrom !== nextFrom ? previousFrom : "";
        if (nextTo) {{
          networkRoutesToNodeId = nextTo;
          changed = changed || previousTo !== nextTo;
        }} else if (fallbackTo) {{
          networkRoutesToNodeId = fallbackTo;
          changed = changed || previousTo !== fallbackTo;
        }}
      }}
      if (mode === "live" && preferSelectedTarget) {{
        const nextPinnedTargetId = normalizeNodeId(networkRoutesToNodeId || "");
        if (isSelectableNodeId(nextPinnedTargetId) && nextPinnedTargetId !== nextFrom) {{
          setNetworkRoutesPinnedTargetId(nextPinnedTargetId);
        }}
      }}
      return changed;
    }}

    function networkRoutesOptionLabel(nodeId, nodeMap, localNodeId = "") {{
      const clean = normalizeNodeId(nodeId || "");
      const name = networkGraphNodeDisplayName(clean, nodeMap);
      const selfSuffix = clean && clean === normalizeNodeId(localNodeId || "") ? " (self)" : "";
      return `${{name}}${{selfSuffix}} ${{clean}}`;
    }}

    function renderNetworkRoutesNodeOptions(select, nodeIds, selectedId, nodeMap, localNodeId = "") {{
      if (!(select instanceof HTMLSelectElement)) return;
      const safeIds = Array.isArray(nodeIds) ? nodeIds : [];
      const signature = safeIds
        .map((nodeId) => `${{nodeId}}:${{networkGraphNodeDisplayName(nodeId, nodeMap)}}`)
        .join("|");
      if (select.dataset.optionsSignature !== signature) {{
        select.innerHTML = safeIds
          .map((nodeId) => `<option value="${{escAttr(nodeId)}}">${{escAttr(networkRoutesOptionLabel(nodeId, nodeMap, localNodeId))}}</option>`)
          .join("");
        select.dataset.optionsSignature = signature;
      }}
      if (select.value !== selectedId) {{
        select.value = selectedId;
      }}
    }}

    function networkRoutesEdgeCost(edge) {{
      const weight = Math.max(1, Number(edge && edge.weight) || 0);
      const avgHops = Number(edge && edge.avgHops);
      const hopPenalty = Number.isFinite(avgHops) && avgHops > 0 ? Math.min(3, avgHops * 0.08) : 0;
      const unseenPenalty = Number(edge && edge.lastSeenUnix) > 0 ? 0 : 0.25;
      return 1 + (1 / Math.log2(weight + 2)) + hopPenalty + unseenPenalty;
    }}

    function networkRoutesFindInferredPath(fromNodeId, toNodeId, adjacency) {{
      const source = normalizeNodeId(fromNodeId || "");
      const target = normalizeNodeId(toNodeId || "");
      if (!source || !target || !(adjacency instanceof Map) || !adjacency.has(source) || !adjacency.has(target)) {{
        return {{ path: [], edges: [], cost: Infinity }};
      }}
      if (source === target) {{
        return {{ path: [source], edges: [], cost: 0 }};
      }}
      const distances = new Map([[source, 0]]);
      const previous = new Map();
      const remaining = new Set(adjacency.keys());
      while (remaining.size > 0) {{
        let currentId = "";
        let currentDistance = Infinity;
        for (const nodeId of remaining) {{
          const distance = distances.has(nodeId) ? distances.get(nodeId) : Infinity;
          if (distance < currentDistance) {{
            currentDistance = distance;
            currentId = nodeId;
          }}
        }}
        if (!currentId || currentDistance === Infinity) break;
        remaining.delete(currentId);
        if (currentId === target) break;
        const peers = adjacency.get(currentId);
        if (!(peers instanceof Map)) continue;
        for (const [peerId, edge] of peers.entries()) {{
          if (!remaining.has(peerId)) continue;
          const candidate = currentDistance + networkRoutesEdgeCost(edge);
          const existing = distances.has(peerId) ? distances.get(peerId) : Infinity;
          if (candidate < existing) {{
            distances.set(peerId, candidate);
            previous.set(peerId, {{ nodeId: currentId, edge }});
          }}
        }}
      }}
      if (!previous.has(target)) {{
        return {{ path: [], edges: [], cost: Infinity }};
      }}
      const path = [target];
      const edges = [];
      let cursor = target;
      while (cursor !== source) {{
        const step = previous.get(cursor);
        if (!step || !step.nodeId) {{
          return {{ path: [], edges: [], cost: Infinity }};
        }}
        edges.unshift(step.edge);
        cursor = step.nodeId;
        path.unshift(cursor);
      }}
      return {{ path, edges, cost: distances.get(target) || 0 }};
    }}

    function networkRoutesEdgeMetaParts(edge) {{
      const meta = {{
        packetText: "",
        hopsText: "",
        snrText: "",
        lastSeenText: "",
      }};
      const weight = Math.max(0, Math.round(Number(edge && edge.weight) || 0));
      if (weight > 0) {{
        meta.packetText = `${{networkTopNodesNumberText(weight)}} packet${{weight === 1 ? "" : "s"}}`;
      }}
      const avgHops = Number(edge && edge.avgHops);
      if (Number.isFinite(avgHops) && avgHops > 0) {{
        meta.hopsText = `${{avgHops.toFixed(avgHops >= 10 ? 0 : 1)}} avg hops`;
      }}
      const avgSnr = Number(edge && edge.avgSnr);
      if (Number.isFinite(avgSnr)) {{
        meta.snrText = `${{avgSnr.toFixed(1)}} dB SNR`;
      }}
      const lastSeen = String(edge && edge.lastSeenLabel || "").trim();
      if (lastSeen) {{
        meta.lastSeenText = lastSeen;
      }}
      return meta;
    }}

    function networkRoutesEdgeMetaText(edge) {{
      const pieces = [];
      const meta = networkRoutesEdgeMetaParts(edge);
      if (meta.packetText) pieces.push(meta.packetText);
      if (meta.hopsText) pieces.push(meta.hopsText);
      if (meta.snrText) pieces.push(meta.snrText);
      if (meta.lastSeenText) pieces.push(`last ${{meta.lastSeenText}}`);
      return pieces.join(" - ");
    }}

    function networkRoutesEdgeSnrStrengthPct(edge, fallbackWeightPct = 0) {{
      const avgSnr = Number(edge && edge.avgSnr);
      if (Number.isFinite(avgSnr)) {{
        // Typical mesh SNR spans roughly -18dB (poor) to +12dB (strong).
        const normalized = Math.max(0, Math.min(1, (avgSnr + 18) / 30));
        const scaled = Math.round(normalized * 1000) / 10;
        return Math.max(4, Math.min(100, scaled));
      }}
      const fallbackPct = Number(fallbackWeightPct);
      if (Number.isFinite(fallbackPct) && fallbackPct > 0) {{
        return Math.max(4, Math.min(100, fallbackPct));
      }}
      return 0;
    }}

    function networkRoutesEdgeSnrBarsFromPct(rawPct) {{
      const pct = Number(rawPct);
      const bounded = Number.isFinite(pct) ? Math.max(0, Math.min(100, pct)) : 0;
      const bars = bounded >= 82
        ? 4
        : (bounded >= 58 ? 3 : (bounded >= 34 ? 2 : (bounded >= 12 ? 1 : 0)));
      const level = bars >= 4
        ? "excellent"
        : (bars === 3 ? "good" : (bars === 2 ? "fair" : (bars === 1 ? "weak" : "none")));
      return {{
        pct: bounded,
        bars,
        level,
      }};
    }}

    function networkRoutesConfidenceText(route) {{
      const edges = Array.isArray(route && route.edges) ? route.edges : [];
      if (!edges.length) return "Direct";
      const weakest = edges.reduce((min, edge) => Math.min(min, Math.max(0, Number(edge && edge.weight) || 0)), Infinity);
      if (weakest >= 100) return "Strong";
      if (weakest >= 10) return "Moderate";
      return "Sparse";
    }}

    function networkRoutesPathHtml(route, nodeMap, localNodeId = "") {{
      const path = Array.isArray(route && route.path) ? route.path : [];
      const edges = Array.isArray(route && route.edges) ? route.edges : [];
      const maxWeight = edges.reduce((max, edge) => Math.max(max, Number(edge && edge.weight) || 0), 0);
      return `<ol class="network-route-hop-list">${{path.map((nodeId, index) => {{
        const clean = normalizeNodeId(nodeId || "");
        const edge = index < edges.length ? edges[index] : null;
        const isLocal = clean && clean === normalizeNodeId(localNodeId || "");
        const name = networkGraphNodeDisplayName(clean, nodeMap);
        const edgeWeight = Math.max(0, Number(edge && edge.weight) || 0);
        const edgeWeightPct = maxWeight > 0 ? Math.max(4, Math.min(100, (edgeWeight / maxWeight) * 100)) : 0;
        const edgePct = networkRoutesEdgeSnrStrengthPct(edge, edgeWeightPct);
        const edgeSignal = networkRoutesEdgeSnrBarsFromPct(edgePct);
        const edgeMeta = edge ? networkRoutesEdgeMetaParts(edge) : null;
        const inlineBarHtml = edge
          ? `<span class="network-route-edge-bars is-${{escAttr(edgeSignal.level)}}" title="${{escAttr(`Link signal strength ${{edgeSignal.bars}} of 4 bars`)}}" aria-hidden="true">
              <span class="network-route-edge-cell level-1${{edgeSignal.bars >= 1 ? " is-on" : ""}}"></span>
              <span class="network-route-edge-cell level-2${{edgeSignal.bars >= 2 ? " is-on" : ""}}"></span>
              <span class="network-route-edge-cell level-3${{edgeSignal.bars >= 3 ? " is-on" : ""}}"></span>
              <span class="network-route-edge-cell level-4${{edgeSignal.bars >= 4 ? " is-on" : ""}}"></span>
            </span>`
          : "";
        const linkMetaHtml = edge
          ? `<span class="network-route-hop-link-meta">
              ${{edgeMeta && edgeMeta.packetText ? `<span class="network-route-hop-meta-item">${{escAttr(edgeMeta.packetText)}}</span>` : ""}}
              ${{edgeMeta && edgeMeta.hopsText ? `<span class="network-route-hop-meta-item">${{escAttr(edgeMeta.hopsText)}}</span>` : ""}}
              ${{edgeMeta && edgeMeta.snrText ? `<span class="network-route-hop-meta-item is-snr">${{escAttr(edgeMeta.snrText)}}</span>` : ""}}
              ${{inlineBarHtml}}
              ${{edgeMeta && edgeMeta.lastSeenText ? `<span class="network-route-hop-meta-item is-last">last ${{escAttr(edgeMeta.lastSeenText)}}</span>` : ""}}
            </span>`
          : `<span class="network-route-hop-link-meta"><span class="network-route-hop-meta-item is-last">Destination</span></span>`;
        return `<li class="network-route-hop${{isLocal ? " is-local" : ""}}" data-route-node-id="${{escAttr(clean)}}">
          <button class="network-route-hop-node" type="button" data-route-node-id="${{escAttr(clean)}}" title="${{escAttr(`${{name}} (${{clean}})`)}}">
            <span class="network-route-hop-index">${{escAttr(String(index + 1))}}</span>
            <span class="network-route-hop-main">
              <strong>${{escAttr(name)}}</strong>
              ${{linkMetaHtml}}
            </span>
          </button>
        </li>`;
      }}).join("")}}</ol>`;
    }}

    function networkRoutesCompactPathHtml(route, nodeMap, localNodeId = "", options = {{}}) {{
      const safeRoute = (route && typeof route === "object") ? route : {{}};
      const path = Array.isArray(safeRoute.path) ? safeRoute.path : [];
      const edges = Array.isArray(safeRoute.edges) ? safeRoute.edges : [];
      if (!path.length) return "";
      const opts = (options && typeof options === "object") ? options : {{}};
      const label = String(opts.label || "Path").trim() || "Path";
      const kind = String(opts.kind || "").trim().toLowerCase();
      const kindClass = kind === "return"
        ? " is-return"
        : (kind === "route" ? " is-route" : "");
      const hopCount = Math.max(0, path.length - 1);
      const hopLabel = hopCount === 1 ? "1 hop" : `${{hopCount}} hops`;
      const snrParts = [];
      for (const edge of edges) {{
        const avgSnr = Number(edge && edge.avgSnr);
        if (Number.isFinite(avgSnr)) {{
          snrParts.push(`${{avgSnr >= 0 ? "+" : ""}}${{avgSnr.toFixed(1)}}dB`);
        }}
      }}
      const snrText = snrParts.length ? `SNR ${{snrParts.join(" · ")}}` : "";
      const sepHtml = `<span class="network-route-pill-sep${{kindClass}}" aria-hidden="true">→</span>`;
      const nodeHtml = path.map((nodeId, index) => {{
        const clean = normalizeNodeId(nodeId || "");
        const isLocal = clean && clean === normalizeNodeId(localNodeId || "");
        const name = networkGraphNodeDisplayName(clean, nodeMap);
        const displayName = isLocal ? `${{name}} (self)` : name;
        return `<button class="network-route-pill${{isLocal ? " is-local" : ""}}" type="button" data-route-node-id="${{escAttr(clean)}}" title="${{escAttr(`${{displayName}} (${{clean}})`)}}">
          <span class="network-route-pill-index">${{escAttr(String(index + 1))}}</span>
          <span class="network-route-pill-name">${{escAttr(displayName)}}</span>
        </button>`;
      }}).join(sepHtml);
      return `<section class="network-route-compact${{kindClass}}">
        <div class="network-route-compact-head">
          <span>${{escAttr(label)}}</span>
          <span>${{escAttr(hopLabel)}}</span>
        </div>
        <div class="network-route-pill-row">${{nodeHtml}}</div>
        ${{snrText ? `<div class="network-route-pill-meta">${{escAttr(snrText)}}</div>` : ""}}
      </section>`;
    }}

    function resolveNetworkRoutesSourceNodeId(state = latestState, nodeMap = null, fallbackNodeIds = []) {{
      const safeState = (state && typeof state === "object") ? state : (latestState || {{}});
      const map = nodeMap instanceof Map ? nodeMap : null;
      const localNodeId = normalizeNodeId(resolveLocalNodeId(safeState) || "");
      if (isSelectableNodeId(localNodeId) && (!map || map.has(localNodeId))) {{
        return localNodeId;
      }}
      const currentFrom = normalizeNodeId(networkRoutesFromNodeId || "");
      if (isSelectableNodeId(currentFrom) && (!map || map.has(currentFrom))) {{
        return currentFrom;
      }}
      const fallbackIds = Array.isArray(fallbackNodeIds) ? fallbackNodeIds : [];
      for (const candidateRaw of fallbackIds) {{
        const candidate = normalizeNodeId(candidateRaw || "");
        if (isSelectableNodeId(candidate) && (!map || map.has(candidate))) {{
          return candidate;
        }}
      }}
      return "";
    }}

    function networkRoutesBuildLiveTracePath(startNodeId, hops, options = {{}}) {{
      const startId = normalizeNodeId(startNodeId || "");
      const opts = (options && typeof options === "object") ? options : {{}};
      const localAliasNodeId = normalizeNodeId(opts.localAliasNodeId || "");
      const fallbackEndNodeId = normalizeNodeId(opts.fallbackEndNodeId || "");
      const updatedMs = Math.max(0, Number(opts.updatedMs) || 0);
      const path = [];
      const edges = [];
      const appendNode = (nodeId) => {{
        const clean = normalizeNodeId(nodeId || "");
        if (!isSelectableNodeId(clean)) return false;
        if (!path.length || path[path.length - 1] !== clean) {{
          path.push(clean);
        }}
        return true;
      }};

      appendNode(startId);
      const hopList = Array.isArray(hops) ? hops : [];
      for (let index = 0; index < hopList.length; index += 1) {{
        const hop = (hopList[index] && typeof hopList[index] === "object") ? hopList[index] : {{}};
        let hopNodeId = normalizeNodeId(hop.node || "");
        if (
          (!hopNodeId || hopNodeId === "local" || hopNodeId === "!local")
          && isSelectableNodeId(localAliasNodeId)
        ) {{
          hopNodeId = localAliasNodeId;
        }}
        if (!isSelectableNodeId(hopNodeId)) continue;
        const previousNodeId = path.length ? path[path.length - 1] : "";
        if (!appendNode(hopNodeId) || !previousNodeId || previousNodeId === hopNodeId) {{
          continue;
        }}
        const edgeKey = networkGraphEdgeKeyBetween(previousNodeId, hopNodeId) || `trace:${{index}}:${{previousNodeId}}:${{hopNodeId}}`;
        const snrRaw = Number(hop.snr_db);
        edges.push({{
          key: edgeKey,
          a: previousNodeId,
          b: hopNodeId,
          weight: 0,
          sessionWeight: 0,
          isReal: true,
          lastSeenUnix: updatedMs > 0 ? Math.floor(updatedMs / 1000) : 0,
          lastSeenLabel: "live traceroute",
          lastHops: null,
          avgHops: null,
          avgSnr: Number.isFinite(snrRaw) ? snrRaw : null,
          avgRssi: null,
          directionCount: 1,
        }});
      }}

      if (
        path.length <= 1
        && isSelectableNodeId(fallbackEndNodeId)
        && fallbackEndNodeId !== (path[0] || "")
      ) {{
        const previousNodeId = path[0] || startId;
        if (appendNode(fallbackEndNodeId) && previousNodeId && previousNodeId !== fallbackEndNodeId) {{
          const edgeKey = networkGraphEdgeKeyBetween(previousNodeId, fallbackEndNodeId)
            || `trace:fallback:${{previousNodeId}}:${{fallbackEndNodeId}}`;
          edges.push({{
            key: edgeKey,
            a: previousNodeId,
            b: fallbackEndNodeId,
            weight: 0,
            sessionWeight: 0,
            isReal: true,
            lastSeenUnix: updatedMs > 0 ? Math.floor(updatedMs / 1000) : 0,
            lastSeenLabel: "live traceroute",
            lastHops: null,
            avgHops: null,
            avgSnr: null,
            avgRssi: null,
            directionCount: 1,
          }});
        }}
      }}

      return {{ path, edges }};
    }}

    function networkRoutesBuildLiveTraceRenderData(baseData, towardsRoute, backRoute, sourceId, targetId) {{
      const safeBase = (baseData && typeof baseData === "object") ? baseData : {{}};
      const nodeIdSet = new Set();
      const addNodeId = (rawNodeId) => {{
        const clean = normalizeNodeId(rawNodeId || "");
        if (isSelectableNodeId(clean)) {{
          nodeIdSet.add(clean);
        }}
      }};
      addNodeId(sourceId);
      addNodeId(targetId);
      for (const nodeId of (Array.isArray(towardsRoute && towardsRoute.path) ? towardsRoute.path : [])) {{
        addNodeId(nodeId);
      }}
      for (const nodeId of (Array.isArray(backRoute && backRoute.path) ? backRoute.path : [])) {{
        addNodeId(nodeId);
      }}

      const rawEdgeByKey = new Map();
      const addRouteEdges = (route) => {{
        const edges = Array.isArray(route && route.edges) ? route.edges : [];
        for (const edge of edges) {{
          const a = normalizeNodeId(edge && edge.a || "");
          const b = normalizeNodeId(edge && edge.b || "");
          if (!isSelectableNodeId(a) || !isSelectableNodeId(b) || a === b) continue;
          addNodeId(a);
          addNodeId(b);
          const key = networkGraphEdgeKeyBetween(a, b);
          if (!key) continue;
          const previous = rawEdgeByKey.get(key) || {{
            from: a,
            to: b,
            count: 1,
            session_count: 1,
            lifetime_count: 1,
            is_real: true,
            confidence: "confirmed",
            first_rx_unix: 0,
            last_rx_unix: 0,
            snr_samples: 0,
          }};
          const avgSnr = Number(edge && edge.avgSnr);
          if (Number.isFinite(avgSnr)) {{
            previous.avg_snr = avgSnr;
            previous.snr_samples = Math.max(1, Number(previous.snr_samples) || 0);
          }}
          rawEdgeByKey.set(key, previous);
        }}
      }};
      addRouteEdges(towardsRoute);
      addRouteEdges(backRoute);
      const rawEdges = Array.from(rawEdgeByKey.values());
      const nodeMap = buildNetworkGraphNodeMap(
        safeBase.nodes,
        safeBase.historyCaps,
        rawEdges,
        {{
          includeAllLiveNodes: true,
          pinnedNodeIds: Array.from(nodeIdSet),
        }}
      );
      const combinedEdges = combineNetworkGraphEdges(rawEdges, nodeMap, {{ mode: "live" }});
      const adjacency = buildNetworkGraphAdjacency(nodeMap, combinedEdges);
      return {{
        nodeMap,
        adjacency,
        combinedEdges,
        rawEdges,
        filteredRawEdges: rawEdges,
        edgeMode: "live",
        localNodeId: normalizeNodeId(sourceId || safeBase.localNodeId || ""),
      }};
    }}

    function networkRoutesBuildLocationEstimates(data) {{
      const safeData = (data && typeof data === "object") ? data : {{}};
      if (typeof buildMapLinkLayerOverlay !== "function") return new Map();
      const nodeMap = safeData.nodeMap instanceof Map ? safeData.nodeMap : new Map();
      if (!nodeMap.size) return new Map();
      const rawEdges = Array.isArray(safeData.filteredRawEdges)
        ? safeData.filteredRawEdges
        : (Array.isArray(safeData.rawEdges) ? safeData.rawEdges : []);
      if (!rawEdges.length) return new Map();
      const nodes = Array.from(nodeMap.values()).filter((node) => node && typeof node === "object");
      if (!nodes.length) return new Map();
      const modeRaw = String(safeData.edgeMode || "").trim().toLowerCase();
      const mapMode = modeRaw === "live" ? "live" : "history";
      try {{
        const overlay = buildMapLinkLayerOverlay(nodes, rawEdges, {{ mode: mapMode }});
        return (overlay && overlay.estimates instanceof Map) ? overlay.estimates : new Map();
      }} catch (_err) {{
        return new Map();
      }}
    }}

    function networkRoutesLiveTraceMatchesSelection(liveState, fromId, toId) {{
      const safe = normalizedNetworkRoutesLiveTraceState(liveState);
      return (
        normalizeNodeId(safe.sourceId || "") === normalizeNodeId(fromId || "")
        && normalizeNodeId(safe.targetId || "") === normalizeNodeId(toId || "")
      );
    }}

    function resolveLiveTracerouteHopLimit(rawTargetNodeId, options = {{}}) {{
      const opts = (options && typeof options === "object") ? options : {{}};
      const safeState = (opts.state && typeof opts.state === "object") ? opts.state : (latestState || {{}});
      const targetId = normalizeNodeId(rawTargetNodeId || "");
      if (!isSelectableNodeId(targetId)) return 7;

      const baseData = (opts.data && typeof opts.data === "object")
        ? opts.data
        : buildNetworkRoutesData(safeState);
      const nodeMap = baseData && baseData.nodeMap instanceof Map ? baseData.nodeMap : new Map();
      const adjacency = baseData && baseData.adjacency instanceof Map ? baseData.adjacency : new Map();
      const historyCaps = (baseData && baseData.historyCaps && typeof baseData.historyCaps === "object")
        ? baseData.historyCaps
        : {{}};
      const preferredSourceId = normalizeNodeId(opts.sourceId || "");
      const resolvedSourceId = normalizeNodeId(
        preferredSourceId
        || resolveNetworkRoutesSourceNodeId(safeState, nodeMap)
        || resolveLocalNodeId(safeState)
        || ""
      );

      const node = nodeMap.get(targetId) || null;
      const safeCaps = (historyCaps[targetId] && typeof historyCaps[targetId] === "object")
        ? historyCaps[targetId]
        : null;
      const hopCandidates = [];
      const liveHopsRaw = Number(node && (node.hops_away ?? node.hopsAway));
      if (Number.isFinite(liveHopsRaw) && liveHopsRaw >= 0) {{
        hopCandidates.push(Math.max(0, Math.trunc(liveHopsRaw)));
      }}
      const capsHopsRaw = Number(safeCaps && safeCaps.last_hops);
      if (Number.isFinite(capsHopsRaw) && capsHopsRaw >= 0) {{
        hopCandidates.push(Math.max(0, Math.trunc(capsHopsRaw)));
      }}
      if (
        isSelectableNodeId(resolvedSourceId)
        && resolvedSourceId !== targetId
        && adjacency instanceof Map
      ) {{
        const inferred = networkRoutesFindInferredPath(resolvedSourceId, targetId, adjacency);
        const inferredPath = Array.isArray(inferred && inferred.path) ? inferred.path : [];
        const inferredHops = Math.max(0, inferredPath.length - 1);
        if (inferredHops > 0) {{
          hopCandidates.push(inferredHops);
        }}
      }}

      const baseHops = hopCandidates.length > 0
        ? Math.max(...hopCandidates)
        : 6;
      return Math.max(3, Math.min(7, Math.trunc(baseHops) + 1));
    }}

    function networkRoutesLiveTraceIsTimeoutError(err) {{
      if (!err) return false;
      const payload = (err && typeof err === "object" && err.payload && typeof err.payload === "object")
        ? err.payload
        : null;
      const messageParts = [];
      const errMessage = (err && typeof err === "object" && "message" in err) ? err.message : "";
      if (errMessage != null) messageParts.push(String(errMessage));
      if (payload && payload.error != null) messageParts.push(String(payload.error));
      const consoleLines = payload && Array.isArray(payload.console_lines) ? payload.console_lines : [];
      if (consoleLines.length) {{
        messageParts.push(consoleLines.join(" | "));
      }}
      const text = messageParts.join(" ").toLowerCase();
      return text.includes("timed out waiting for traceroute response")
        || text.includes("timed out waiting for response")
        || text.includes("destination did not respond")
        || text.includes("error=no_response")
        || text.includes("invalid traceroute response payload")
        || text.includes("traceroute response payload missing")
        || text.includes("malformed traceroute response");
    }}

    function networkRoutesLiveTraceDelay(delayMs) {{
      const waitMs = Math.max(0, Number(delayMs) || 0);
      if (waitMs <= 0) return Promise.resolve();
      return new Promise((resolve) => {{
        window.setTimeout(resolve, waitMs);
      }});
    }}

    function networkRoutesLiveTraceResultHtml(liveState, baseData, fromId, toId) {{
      const safeState = normalizedNetworkRoutesLiveTraceState(liveState);
      const sourceId = normalizeNodeId(fromId || safeState.sourceId || "");
      const targetId = normalizeNodeId(toId || safeState.targetId || "");
      const result = (safeState.result && typeof safeState.result === "object") ? safeState.result : {{}};
      const towardsHops = Array.isArray(result.towards) ? result.towards : [];
      const backHops = Array.isArray(result.back) ? result.back : [];

      const towardsRoute = networkRoutesBuildLiveTracePath(sourceId, towardsHops, {{
        localAliasNodeId: sourceId,
        fallbackEndNodeId: targetId,
        updatedMs: safeState.updatedMs,
      }});
      const backRouteStart = (towardsRoute.path.length > 1)
        ? towardsRoute.path[towardsRoute.path.length - 1]
        : targetId;
      const backRoute = networkRoutesBuildLiveTracePath(backRouteStart, backHops, {{
        localAliasNodeId: sourceId,
        fallbackEndNodeId: sourceId,
        updatedMs: safeState.updatedMs,
      }});

      const renderData = networkRoutesBuildLiveTraceRenderData(baseData, towardsRoute, backRoute, sourceId, targetId);
      const routeLocationEstimates = networkRoutesBuildLocationEstimates(renderData);
      const towardsHopCount = Math.max(0, towardsRoute.path.length - 1);
      const updatedUnix = safeState.updatedMs > 0 ? Math.floor(safeState.updatedMs / 1000) : 0;
      const updatedLabel = updatedUnix > 0 ? formatLocalChatTime(updatedUnix, "n/a") : "n/a";
      const scopeRoute = {{
        path: towardsRoute.path,
        edges: towardsRoute.edges,
        returnPath: backRoute.path,
        returnEdges: backRoute.edges,
      }};
      const towardScopeHtml = towardsRoute.path.length > 1
        ? networkRoutesScopeHtml(scopeRoute, renderData, sourceId, targetId, {{
            allowNodeEmoji: false,
            routeLocationEstimates,
          }})
        : "";
      const towardPathHtml = networkRoutesCompactPathHtml(
        towardsRoute,
        renderData.nodeMap,
        renderData.localNodeId,
        {{
          label: "Towards destination",
          kind: "route",
        }}
      );
      const backPathHtml = backRoute.path.length > 1
        ? networkRoutesCompactPathHtml(
            backRoute,
            renderData.nodeMap,
            renderData.localNodeId,
            {{
              label: "Return path",
              kind: "return",
            }}
          )
        : "";
      const consoleLines = Array.isArray(safeState.lines) ? safeState.lines.slice(0, 2) : [];
      const consoleHtml = consoleLines.length
        ? `<details class="network-route-console">
            <summary>Trace output · ${{escAttr(updatedLabel)}}</summary>
            <div class="chat-node-telemetry-tool-lines">${{consoleLines.map((line) => `<div class="chat-node-telemetry-tool-line">${{escAttr(line)}}</div>`).join("")}}</div>
          </details>`
        : "";
      return `${{towardScopeHtml}}
        <div class="network-route-result-head">
          <span>Live route</span>
          <span>${{escAttr(towardsHopCount === 1 ? "1 hop" : `${{towardsHopCount}} hops`)}} · updated ${{escAttr(updatedLabel)}}</span>
        </div>
        ${{towardPathHtml}}
        ${{backPathHtml}}
        ${{consoleHtml}}`;
    }}

    async function runNetworkRoutesLiveTrace(state = latestState, options = {{}}) {{
      const opts = (options && typeof options === "object") ? options : {{}};
      const safeState = (state && typeof state === "object") ? state : (latestState || {{}});
      const data = buildNetworkRoutesData(safeState);
      const nodeIds = networkRoutesSortedNodeIds(data.nodeMap);
      const sourceId = normalizeNodeId(
        opts.sourceId
        || resolveNetworkRoutesSourceNodeId(safeState, data.nodeMap, nodeIds)
      );
      let targetId = normalizeNodeId(opts.targetId || networkRoutesToNodeId || selectedNodeId || "");
      if (!isSelectableNodeId(targetId) || targetId === sourceId || !data.nodeMap.has(targetId)) {{
        const selectedId = normalizeNodeId(selectedNodeId || "");
        if (isSelectableNodeId(selectedId) && selectedId !== sourceId && data.nodeMap.has(selectedId)) {{
          targetId = selectedId;
        }} else {{
          targetId = nodeIds.find((nodeId) => nodeId !== sourceId) || "";
        }}
      }}

      networkRoutesFromNodeId = sourceId;
      networkRoutesToNodeId = targetId;
      setNetworkRoutesPinnedTargetId(targetId, data.nodeMap);
      persistPreferredNetworkRoutesNodeId(networkRoutesFromStorageKey, networkRoutesFromNodeId);
      persistPreferredNetworkRoutesNodeId(networkRoutesToStorageKey, networkRoutesToNodeId);
      const hopLimit = resolveLiveTracerouteHopLimit(targetId, {{
        state: safeState,
        sourceId,
        data,
      }});

      if (!isSelectableNodeId(sourceId) || !isSelectableNodeId(targetId) || sourceId === targetId) {{
        setNetworkRoutesLiveTraceState({{
          running: false,
          ok: false,
          updatedMs: Date.now(),
          sourceId,
          targetId,
          error: "Choose two different nodes before running a live trace.",
          lines: [],
          result: null,
        }});
        renderNetworkRoutes(latestState);
        if (typeof renderChatNodeNavigatorList === "function" && latestState) {{
          renderChatNodeNavigatorList(latestState);
        }}
        return null;
      }}

      const current = normalizedNetworkRoutesLiveTraceState(networkRoutesLiveTraceState);
      if (current.running && opts.force !== true) {{
        return null;
      }}

      networkRoutesLiveTraceRequestNonce = Math.max(0, Number(networkRoutesLiveTraceRequestNonce) || 0) + 1;
      const requestNonce = networkRoutesLiveTraceRequestNonce;
      setNetworkRoutesPinnedTargetId(targetId, data.nodeMap);
      setNetworkRoutesLiveTraceState({{
        running: true,
        ok: null,
        updatedMs: Date.now(),
        sourceId,
        targetId,
        error: "",
        lines: [],
      }});
      if (
        typeof chatNodeTelemetryStateForNode === "function"
        && typeof chatNodeTelemetryToolStateForNode === "function"
      ) {{
        const telemetryNodeState = chatNodeTelemetryStateForNode(targetId, true);
        if (telemetryNodeState && telemetryNodeState.tools instanceof Map) {{
          const tracerouteState = chatNodeTelemetryToolStateForNode(targetId, "traceroute", true) || {{}};
          telemetryNodeState.tools.set("traceroute", {{
            ...tracerouteState,
            running: true,
            ok: null,
            updatedMs: Date.now(),
            statusText: "Request in progress...",
            lines: [],
          }});
          telemetryNodeState.summaryMessage = `Running Traceroute for ${{targetId}}...`;
          telemetryNodeState.summaryError = false;
          telemetryNodeState.summaryUpdatedMs = Date.now();
          if (
            isChatNodeDetailsDrawerExpanded()
            && normalizeChatNodeDetailsDrawerTab(chatNodeDetailsDrawerTab) === "telemetry"
            && chatNodeDetailsDrawerTargetNodeId(selectedNodeId) === targetId
          ) {{
            renderChatNodeTelemetryPanel(targetId, latestState);
          }}
        }}
      }}
      renderNetworkRoutes(latestState);
      if (typeof renderChatNodeNavigatorList === "function" && latestState) {{
        renderChatNodeNavigatorList(latestState);
      }}

      try {{
        let payload = null;
        let lastError = null;
        const attempts = Math.max(1, Number(networkRoutesLiveTraceMaxAttempts) || 1);
        for (let attempt = 1; attempt <= attempts; attempt += 1) {{
          try {{
            const requestBody = {{
              command: "traceroute",
              destination: targetId,
              timeout_ms: networkRoutesLiveTraceTimeoutMs,
            }};
            if (Number.isFinite(Number(hopLimit)) && Number(hopLimit) > 0) {{
