          node,
          x: Number(position.x),
          y: Number(position.y),
          layer: Number(position.layer || 0),
          disconnected: !!position.disconnected,
          detached: !!position.disconnected && !position.broadcastOnly,
          broadcastOnly: !!position.broadcastOnly,
          degree: meta.degree,
          weight: meta.weight,
          signalMeta,
          radius: Number.isFinite(cachedRadius) && cachedRadius > 0
            ? cachedRadius
