              const hasRoutes = Number(item.routeCount || 0) > 0;
              const checkedAttr = item.visible ? " checked" : "";
              const disabledAttr = hasRoutes ? "" : " disabled";
              const countLabel = item.count > 1 ? ` <span class="network-graph-tag-filter-count">${{item.count}}</span>` : "";
              const title = hasRoutes
                ? `Toggle ${{item.label}} tag routes`
                : `No current ${{item.label}} routes from this view`;
              return `<label class="network-graph-tag-filter${{item.visible ? "" : " is-muted"}}${{hasRoutes ? "" : " is-empty"}}" style="--network-graph-tag-route-color:${{escAttr(item.color)}};" title="${{escAttr(title)}}">
                <input
                  class="network-graph-tag-filter-input"
                  type="checkbox"
                  data-network-graph-tag-filter-id="${{escAttr(item.presetId)}}"
