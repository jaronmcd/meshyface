      const launcherBadge = document.getElementById("layout-view-menu-btn-badge");
      const attentionIndicator = document.getElementById("layout-view-menu-attention-indicator");
      if (!(launcherBtn instanceof HTMLButtonElement)) return;

      const activeLabel = currentWorkspaceLauncherLabel(viewName);
      const launcherLabelTarget = (launcherLabelText instanceof HTMLElement) ? launcherLabelText : launcherLabel;
      if (launcherLabelTarget instanceof HTMLElement && launcherLabelTarget.textContent !== activeLabel) {{
        launcherLabelTarget.textContent = activeLabel;
      }}

      const totalCount = totalWorkspaceLauncherNotificationCount();
      const totalLabel = workspaceLauncherNotificationLabel(totalCount);
      if (launcherBadge instanceof HTMLElement) {{
        launcherBadge.hidden = totalCount <= 0;
        if (totalCount > 0 && launcherBadge.textContent !== totalLabel) {{
          launcherBadge.textContent = totalLabel;
        }}
      }}
      if (attentionIndicator instanceof HTMLElement) {{
        attentionIndicator.hidden = true;
      }}
      launcherBtn.classList.toggle("has-unread", totalCount > 0);

      const titleParts = ["Open workspace view menu.", `Current view: ${{activeLabel}}.`];
      if (totalCount > 0) {{
        titleParts.push(`Total notifications: ${{totalLabel}}.`);
      }}
      const summaryParts = [];
      for (const launcherView of ["chat", "network", "console", "apps", "settings"]) {{
        const count = workspaceLauncherViewNotificationCount(launcherView);
        if (count <= 0) continue;
        const countLabel = workspaceLauncherNotificationLabel(count);
        summaryParts.push(`${{topbarLauncherLayoutLabel(launcherView)}} ${{countLabel}}`);
      }}
      if (summaryParts.length > 0) {{
        titleParts.push(`New activity: ${{summaryParts.join(", ")}}.`);
      }}
      const nextTitle = titleParts.join(" ");
      launcherBtn.title = nextTitle;
      launcherBtn.setAttribute("aria-label", nextTitle);
    }}

    function syncLayoutViewMenu(viewName = activeLayoutView) {{
      const launcherView = resolveTopbarLauncherLayoutView(viewName);
      for (const btn of document.querySelectorAll("#layout-view-menu .topbar-view-menu-item")) {{
        if (!(btn instanceof HTMLButtonElement)) continue;
        const btnView = String(btn.dataset.view || "").trim().toLowerCase();
        const isActive = btnView === launcherView;
        const hasSubmenu = String(btn.dataset.submenu || "").trim().length > 0;
        const notificationCount = workspaceLauncherViewNotificationCount(btnView);
        const notificationLabel = workspaceLauncherNotificationLabel(notificationCount);
        const notificationText = notificationCount > 0
          ? `${{notificationLabel}} new notification${{notificationCount === 1 ? "" : "s"}}`
          : "";
        const badge = btn.querySelector(".topbar-view-menu-item-badge");
        if (badge instanceof HTMLElement) {{
          badge.hidden = notificationCount <= 0;
          if (notificationCount > 0 && badge.textContent !== notificationLabel) {{
            badge.textContent = notificationLabel;
          }}
        }}
        const baseTitle = String(btn.dataset.baseTitle || btn.title || "").trim();
        if (!btn.dataset.baseTitle) {{
          btn.dataset.baseTitle = baseTitle;
        }}
        btn.classList.toggle("is-active", isActive);
        btn.classList.toggle("has-notifications", notificationCount > 0);
        if (hasSubmenu) {{
          btn.removeAttribute("aria-checked");
        }} else {{
          btn.setAttribute("aria-checked", isActive ? "true" : "false");
        }}
        btn.setAttribute("aria-current", isActive ? "page" : "false");
        const label = topbarLauncherLayoutLabel(btnView);
        const spokenLabel = hasSubmenu ? `${{label}}. Current app: ${{currentAppsLauncherLabel(viewName)}}.` : label;
        if (notificationText) {{
          btn.title = baseTitle
            ? `${{baseTitle}} • ${{notificationText}}`
            : `${{spokenLabel}} • ${{notificationText}}`;
          btn.setAttribute(
            "aria-label",
            isActive
              ? `${{spokenLabel}} ${{notificationText}}. Current view.`
              : `${{spokenLabel}} ${{notificationText}}.`
          );
        }} else {{
          btn.title = baseTitle;
          btn.setAttribute(
            "aria-label",
            isActive
              ? `${{spokenLabel}} Current view.`
              : spokenLabel
          );
        }}
      }}
      syncAppsTabBar(viewName);
      syncLayoutViewLauncherButtonState(viewName);
    }}

