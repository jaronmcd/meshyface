    function networkGraphEdgeKeyBetween(fromNodeId, toNodeId) {{
      const a = normalizeNodeId(fromNodeId || "");
      const b = normalizeNodeId(toNodeId || "");
      if (!isSelectableNodeId(a) || !isSelectableNodeId(b) || a === b) return "";
      return a < b ? `${{a}}::${{b}}` : `${{b}}::${{a}}`;
    }}

    function buildNetworkGraphEdgeDomKey(edge) {{
      return networkGraphEdgeKeyBetween(edge && edge.a, edge && edge.b);
