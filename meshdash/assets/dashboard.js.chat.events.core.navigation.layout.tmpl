        const homeNodeId = resolveNetworkGraphHomeNodeId(state, safeMap);
        const canGoHome = !!homeNodeId && homeNodeId !== normalizeNodeId(rootId || "");
        homeBtn.disabled = !canGoHome;
        homeBtn.setAttribute("aria-disabled", canGoHome ? "false" : "true");
        homeBtn.title = canGoHome
          ? `Center links view on ${{networkGraphNodeDisplayName(homeNodeId, safeMap)}}`
          : "Links view is already centered on the local node";
