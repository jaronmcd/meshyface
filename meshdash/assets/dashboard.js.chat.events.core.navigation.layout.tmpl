        : resolveNetworkGraphResetViewBox(svg, options);
      return clampNetworkGraphViewBox({{
        x: focusX - (sourceViewBox.width / 2),
        y: focusY - (sourceViewBox.height / 2),
        width: sourceViewBox.width,
        height: sourceViewBox.height,
      }}, {{
        aspectRatio: getNetworkGraphStageAspectRatio(svg),
        preserveRequestedCenter: true,
      }});
