      const safeStats = {{
        ...stats,
        totalMs: networkGraphRoundMs(stats.totalMs),
        phases: Array.isArray(stats.phases)
          ? stats.phases.map((phase) => (phase && typeof phase === "object" ? {{ ...phase }} : phase))
          : [],
      }};
      const existing = window.__meshNetworkGraphRenderStats;
      const store = existing && typeof existing === "object" ? existing : {{ runs: [] }};
      const runs = Array.isArray(store.runs) ? store.runs : [];
      runs.push(safeStats);
      if (runs.length > 40) {{
        runs.splice(0, runs.length - 40);
      }}
      store.runs = runs;
      store.last = safeStats;
      window.__meshNetworkGraphRenderStats = store;
    }}

    function cloneNetworkGraphViewBox(rawViewBox = networkGraphViewportBase) {{
      const fallback = networkGraphViewportBase;
      const source = (rawViewBox && typeof rawViewBox === "object") ? rawViewBox : fallback;
      const x = Number(source.x);
      const y = Number(source.y);
      const width = Number(source.width);
      const height = Number(source.height);
      return {{
        x: Number.isFinite(x) ? x : fallback.x,
        y: Number.isFinite(y) ? y : fallback.y,
        width: Number.isFinite(width) && width > 0 ? width : fallback.width,
        height: Number.isFinite(height) && height > 0 ? height : fallback.height,
      }};
    }}

    function isNetworkGraphPointVisible(viewBox, x, y, paddingRatio = 0.08) {{
      const safeViewBox = cloneNetworkGraphViewBox(viewBox);
      const padX = safeViewBox.width * Math.max(0, Number(paddingRatio) || 0);
      const padY = safeViewBox.height * Math.max(0, Number(paddingRatio) || 0);
      return (
        Number.isFinite(Number(x))
        && Number.isFinite(Number(y))
        && Number(x) >= (safeViewBox.x + padX)
        && Number(x) <= ((safeViewBox.x + safeViewBox.width) - padX)
        && Number(y) >= (safeViewBox.y + padY)
        && Number(y) <= ((safeViewBox.y + safeViewBox.height) - padY)
      );
    }}

    function defaultNetworkGraphBounds() {{
      return {{
        minX: networkGraphViewportBase.x,
        minY: networkGraphViewportBase.y,
        maxX: networkGraphViewportBase.x + networkGraphViewportBase.width,
        maxY: networkGraphViewportBase.y + networkGraphViewportBase.height,
      }};
    }}

    function resolveNetworkGraphStage(svg = null) {{
      if (svg instanceof SVGElement) {{
        const stage = svg.closest(".network-graph-stage");
        if (stage instanceof HTMLElement) return stage;
      }}
      const stage = document.querySelector(".network-graph-stage");
      return stage instanceof HTMLElement ? stage : null;
    }}

    function isNetworkGraphOverlayDocked(svg = null) {{
      const stage = resolveNetworkGraphStage(svg);
      return !!(stage && stage.classList.contains("is-overlay-docked"));
    }}

    function resolveNetworkGraphFitZoomOutScale(svg = null) {{
      const baseScale = Number.isFinite(networkGraphFitZoomOutScale) && networkGraphFitZoomOutScale > 1
        ? networkGraphFitZoomOutScale
        : 1;
      const overlayScale = Number.isFinite(networkGraphOverlayFitZoomOutScale) && networkGraphOverlayFitZoomOutScale > 1
        ? networkGraphOverlayFitZoomOutScale
        : baseScale;
      return isNetworkGraphOverlayDocked(svg) ? overlayScale : baseScale;
    }}

    function resolveNetworkGraphTopSafeInset(svg = null) {{
      const overlayInset = Number.isFinite(networkGraphOverlaySafeInsetTop) && networkGraphOverlaySafeInsetTop >= 0
        ? networkGraphOverlaySafeInsetTop
        : 0;
      const defaultInset = Number.isFinite(networkGraphToolbarSafeInsetTop) && networkGraphToolbarSafeInsetTop >= 0
        ? networkGraphToolbarSafeInsetTop
        : overlayInset;
      return isNetworkGraphOverlayDocked(svg) ? overlayInset : defaultInset;
    }}

    function getNetworkGraphStageAspectRatio(svg = null) {{
      if (svg instanceof SVGElement) {{
        const rect = svg.getBoundingClientRect();
        if (rect.width > 0 && rect.height > 0) {{
          return rect.width / rect.height;
        }}
      }}
      const current = cloneNetworkGraphViewBox(networkGraphViewState.viewBox);
      if (current.width > 0 && current.height > 0) {{
        return current.width / current.height;
      }}
      return networkGraphViewportBase.width / networkGraphViewportBase.height;
    }}

    function prefersReducedMotion() {{
      return !!(
        typeof window !== "undefined"
        && typeof window.matchMedia === "function"
        && window.matchMedia("(prefers-reduced-motion: reduce)").matches
      );
    }}

    function cancelNetworkGraphViewAnimation() {{
      if (networkGraphViewState.animationFrame !== null) {{
        window.cancelAnimationFrame(networkGraphViewState.animationFrame);
      }}
      networkGraphViewState.animationFrame = null;
    }}

    function cancelNetworkGraphSceneAnimation() {{
      if (networkGraphViewState.sceneAnimationFrame !== null) {{
        window.cancelAnimationFrame(networkGraphViewState.sceneAnimationFrame);
      }}
      networkGraphViewState.sceneAnimationFrame = null;
    }}

    function clearNetworkGraphEmptyRetry() {{
      if (networkGraphViewState.emptyRetryTimer !== null) {{
        clearTimeout(networkGraphViewState.emptyRetryTimer);
      }}
      networkGraphViewState.emptyRetryTimer = null;
      networkGraphViewState.emptyRetryCount = 0;
    }}

    function clearNetworkGraphDom() {{
      const svg = document.getElementById("network-graph-svg");
      const summary = document.getElementById("network-graph-summary");
      const legend = document.getElementById("network-graph-legend");
      const empty = document.getElementById("network-graph-empty");
      cancelNetworkGraphViewAnimation();
      cancelNetworkGraphSceneAnimation();
      clearNetworkGraphEmptyRetry();
      if (networkGraphViewState.suppressClickTimer !== null) {{
        clearTimeout(networkGraphViewState.suppressClickTimer);
      }}
      networkGraphViewState.suppressClick = false;
      networkGraphViewState.suppressClickTimer = null;
      if (svg instanceof SVGElement) {{
        stopNetworkGraphPan(svg);
        svg.innerHTML = "";
      }}
      if (summary instanceof HTMLElement) {{
        summary.innerHTML = "";
        summary.__meshNetworkGraphSummaryHtml = "";
      }}
      if (legend instanceof HTMLElement) {{
        legend.innerHTML = "";
        legend.hidden = true;
      }}
      if (empty instanceof HTMLElement) {{
        empty.hidden = true;
      }}
      networkGraphViewState.lastRootId = "";
      networkGraphViewState.lastSelectedId = "";
      networkGraphViewState.lastSceneStructureSignature = "";
      networkGraphViewState.renderedPositions = new Map();
      networkGraphViewState.renderedLayoutSnapshot = null;
      networkGraphViewState.pendingFocusTransition = null;
      networkGraphViewState.pendingSelectedNodeCenterId = "";
      networkGraphViewState.pendingEntryViewportSync = true;
      networkGraphViewState.forceCenteredFitOnce = true;
      networkGraphViewState.skipSceneAnimationOnce = true;
    }}

    function scheduleNetworkGraphEmptyRetry() {{
      if (
        networkGraphViewState.emptyRetryTimer !== null
        || networkGraphViewState.emptyRetryCount >= 4
      ) {{
        return;
      }}
      const retryDelayMs = 140 + (networkGraphViewState.emptyRetryCount * 180);
      networkGraphViewState.emptyRetryCount += 1;
      networkGraphViewState.emptyRetryTimer = window.setTimeout(() => {{
        networkGraphViewState.emptyRetryTimer = null;
        if (
          activeLayoutView === "network"
          && activeNetworkSubview === "graph"
          && !networkSubviewUsesMap(activeNetworkSubview)
          && typeof renderNetworkGraphView === "function"
        ) {{
          renderNetworkGraphView(latestState);
        }}
      }}, retryDelayMs);
    }}

    function easeNetworkGraphAnimationProgress(progress) {{
      const safeProgress = Math.min(1, Math.max(0, Number(progress) || 0));
      return 1 - Math.pow(1 - safeProgress, 3);
    }}

    function interpolateNetworkGraphViewBox(fromViewBox, toViewBox, progress) {{
      const from = cloneNetworkGraphViewBox(fromViewBox);
      const to = cloneNetworkGraphViewBox(toViewBox);
      const ratio = Math.min(1, Math.max(0, Number(progress) || 0));
      return {{
        x: from.x + ((to.x - from.x) * ratio),
        y: from.y + ((to.y - from.y) * ratio),
        width: from.width + ((to.width - from.width) * ratio),
        height: from.height + ((to.height - from.height) * ratio),
      }};
    }}

    function networkGraphEdgeKeyBetween(fromNodeId, toNodeId) {{
      const a = normalizeNodeId(fromNodeId || "");
      const b = normalizeNodeId(toNodeId || "");
      if (!isSelectableNodeId(a) || !isSelectableNodeId(b) || a === b) return "";
      return a < b ? `${{a}}::${{b}}` : `${{b}}::${{a}}`;
    }}

    function buildNetworkGraphEdgeDomKey(edge) {{
      return networkGraphEdgeKeyBetween(edge && edge.a, edge && edge.b);
    }}

    function resolveNetworkGraphShortestPathSegments(edges, fromNodeId, toNodeId) {{
      const startId = normalizeNodeId(fromNodeId || "");
      const targetId = normalizeNodeId(toNodeId || "");
      if (!isSelectableNodeId(startId) || !isSelectableNodeId(targetId) || startId === targetId) {{
        return [];
      }}
      const adjacency = new Map();
      for (const edge of (Array.isArray(edges) ? edges : [])) {{
        const a = normalizeNodeId(edge && edge.a);
        const b = normalizeNodeId(edge && edge.b);
        const edgeKey = networkGraphEdgeKeyBetween(a, b);
        if (!edgeKey) continue;
        if (!adjacency.has(a)) adjacency.set(a, []);
        if (!adjacency.has(b)) adjacency.set(b, []);
        adjacency.get(a).push({{ peerId: b, edgeKey }});
        adjacency.get(b).push({{ peerId: a, edgeKey }});
      }}
      if (!adjacency.has(startId) || !adjacency.has(targetId)) return [];

      const parents = new Map([[startId, null]]);
      const queue = [startId];
      for (let cursor = 0; cursor < queue.length && !parents.has(targetId); cursor += 1) {{
        const currentId = queue[cursor];
        const neighbors = adjacency.get(currentId) || [];
        for (const neighbor of neighbors) {{
          const peerId = normalizeNodeId(neighbor && neighbor.peerId);
          if (!peerId || parents.has(peerId)) continue;
          parents.set(peerId, {{
            nodeId: currentId,
            edgeKey: neighbor.edgeKey,
          }});
          if (peerId === targetId) break;
          queue.push(peerId);
        }}
      }}
      if (!parents.has(targetId)) return [];

      let currentId = targetId;
      const pathSegments = [];
      while (currentId && currentId !== startId) {{
        const parent = parents.get(currentId);
        if (!parent || !parent.nodeId || !parent.edgeKey) break;
        pathSegments.unshift({{
          edgeKey: parent.edgeKey,
          fromNodeId: parent.nodeId,
          toNodeId: currentId,
        }});
        currentId = parent.nodeId;
      }}
      return pathSegments;
    }}

    function resolveNetworkGraphShortestPathEdgeKeys(edges, fromNodeId, toNodeId) {{
      const pathEdgeKeys = new Set();
      for (const segment of resolveNetworkGraphShortestPathSegments(edges, fromNodeId, toNodeId)) {{
        if (segment && segment.edgeKey) {{
          pathEdgeKeys.add(segment.edgeKey);
        }}
      }}
      return pathEdgeKeys;
    }}

    function networkGraphSelfPathIsVisible() {{
      return networkGraphViewState.selfPathVisible !== false;
    }}

    function resolveNetworkGraphSelfPathInfo(scene) {{
      const safeScene = (scene && typeof scene === "object") ? scene : {{}};
      const edges = Array.isArray(safeScene.edges) ? safeScene.edges : [];
      const localId = normalizeNodeId(
        safeScene.localId
        || resolveLocalNodeId(latestState || {{}})
        || ""
      );
      const selectedId = normalizeNodeId(safeScene.selectedId || selectedNodeId || "");
      const targetId = isSelectableNodeId(selectedId) ? selectedId : "";
      const shouldOffer = !!(
        isSelectableNodeId(localId)
        && isSelectableNodeId(targetId)
        && localId !== targetId
      );
      const segments = shouldOffer
        ? resolveNetworkGraphShortestPathSegments(edges, localId, targetId)
        : [];
      const edgeKeys = new Set();
      segments.forEach((segment) => {{
        if (segment && segment.edgeKey) {{
          edgeKeys.add(segment.edgeKey);
        }}
      }});
      return {{
        sourceId: localId,
        targetId,
        offered: shouldOffer,
        available: shouldOffer && segments.length > 0,
        visible: shouldOffer && segments.length > 0 && networkGraphSelfPathIsVisible(),
        hopCount: segments.length,
        segments,
        edgeKeys,
      }};
    }}

    function resolveNetworkGraphTaggedItems(items) {{
      return (Array.isArray(items) ? items : [])
        .map((item) => {{
          const nodeId = normalizeNodeId(item && item.nodeId);
          const tagEntry = (typeof nodeTagEntryForNode === "function")
            ? nodeTagEntryForNode(nodeId)
            : null;
          if (!isSelectableNodeId(nodeId) || !(tagEntry && tagEntry.preset)) return null;
          const color = (typeof normalizeNodeTagColor === "function")
            ? normalizeNodeTagColor(tagEntry.preset.color, "#2aa85a")
            : "#2aa85a";
          const label = (typeof nodeTagDisplayLabel === "function")
            ? nodeTagDisplayLabel(tagEntry, "Tagged")
            : "Tagged";
          const iconHtml = (typeof nodeTagIconSvgHtml === "function")
            ? nodeTagIconSvgHtml(tagEntry, "network-graph-tag-filter-icon")
            : "";
          const presetId = normalizeNetworkGraphTagRoutePresetId(
            tagEntry.presetId
            || (tagEntry.preset && tagEntry.preset.id)
            || label
          );
          if (!presetId) return null;
          return {{ nodeId, presetId, color, label, iconHtml }};
        }})
        .filter(Boolean)
        .sort((itemA, itemB) => (
          String(itemA.label || "").localeCompare(String(itemB.label || ""))
          || String(itemA.nodeId || "").localeCompare(String(itemB.nodeId || ""))
        ));
    }}

    function buildNetworkGraphTagRouteKey(presetId, sourceId, targetId) {{
      const cleanPresetId = normalizeNetworkGraphTagRoutePresetId(presetId);
      const cleanSourceId = normalizeNodeId(sourceId || "");
      const cleanTargetId = normalizeNodeId(targetId || "");
      if (!cleanPresetId || !isSelectableNodeId(cleanSourceId) || !isSelectableNodeId(cleanTargetId)) return "";
      return `${{cleanPresetId}}|${{cleanSourceId}}|${{cleanTargetId}}`;
    }}

    function resolveNetworkGraphTaggedRouteSegments(edges, items, rootId, routeAnchorId = "") {{
      const cleanRootId = normalizeNodeId(rootId || "");
      if (!isSelectableNodeId(cleanRootId)) return [];
      const cleanRouteAnchorId = normalizeNodeId(routeAnchorId || "");
      const taggedItems = resolveNetworkGraphTaggedItems(items);
      const segmentsByEdgeKey = new Map();
      for (const taggedItem of taggedItems) {{
        const routeStartId = (
          taggedItem.nodeId === cleanRootId
          && isSelectableNodeId(cleanRouteAnchorId)
          && cleanRouteAnchorId !== taggedItem.nodeId
        )
          ? cleanRouteAnchorId
          : cleanRootId;
        if (routeStartId === taggedItem.nodeId) continue;
        const pathSegments = resolveNetworkGraphShortestPathSegments(edges, routeStartId, taggedItem.nodeId);
        const hopCount = pathSegments.length;
        const routeKey = buildNetworkGraphTagRouteKey(taggedItem.presetId, routeStartId, taggedItem.nodeId);
        if (!routeKey) continue;
        for (const segment of pathSegments) {{
          if (!segment || !segment.edgeKey) continue;
          if (!segmentsByEdgeKey.has(segment.edgeKey)) {{
            segmentsByEdgeKey.set(segment.edgeKey, []);
          }}
          segmentsByEdgeKey.get(segment.edgeKey).push({{
            ...segment,
            sourceId: routeStartId,
            targetId: taggedItem.nodeId,
            routeKey,
            hopCount,
            presetId: taggedItem.presetId,
            color: taggedItem.color,
            label: taggedItem.label,
          }});
        }}
      }}
      const routeSegments = [];
      for (const stack of segmentsByEdgeKey.values()) {{
        const stackCount = stack.length;
        stack.forEach((segment, stackIndex) => {{
          routeSegments.push({{
            ...segment,
            stackCount,
            stackIndex,
          }});
        }});
      }}
      return routeSegments;
    }}

    function networkGraphTagRoutePresetIsVisible(presetId) {{
      const cleanPresetId = normalizeNetworkGraphTagRoutePresetId(presetId);
      if (!cleanPresetId) return true;
      const hiddenIds = networkGraphViewState.hiddenTagRoutePresetIds instanceof Set
        ? networkGraphViewState.hiddenTagRoutePresetIds
        : new Set();
      return !hiddenIds.has(cleanPresetId);
    }}

    function networkGraphTagEntryPresetId(tagEntry) {{
      return normalizeNetworkGraphTagRoutePresetId(
        (tagEntry && tagEntry.presetId)
        || (tagEntry && tagEntry.preset && tagEntry.preset.id)
        || (tagEntry && tagEntry.preset && tagEntry.preset.name)
        || ""
      );
    }}

    function networkGraphVisibleTagEntryForNode(nodeId) {{
      const tagEntry = (typeof nodeTagEntryForNode === "function")
        ? nodeTagEntryForNode(nodeId)
        : null;
      if (!(tagEntry && tagEntry.preset)) return null;
      const presetId = networkGraphTagEntryPresetId(tagEntry);
      return networkGraphTagRoutePresetIsVisible(presetId) ? tagEntry : null;
    }}

    function networkGraphVisibleNodeEmojiForNode(nodeId, node = null) {{
      const cleanNodeId = normalizeNodeId(nodeId || "");
      if (!cleanNodeId) return "";
      if (typeof nodeEmojiMarkersAreEnabled === "function" && !nodeEmojiMarkersAreEnabled()) return "";
      const tagEntry = networkGraphVisibleTagEntryForNode(cleanNodeId);
      if (tagEntry && typeof nodeVisualEmojiForNode === "function") {{
        return String(nodeVisualEmojiForNode(cleanNodeId, tagEntry, node) || "").trim();
      }}
      const localEmoji = typeof localVisualEmojiForNode === "function"
        ? String(localVisualEmojiForNode(cleanNodeId, node) || "").trim()
        : "";
      if (localEmoji) return localEmoji;
      const overrideEmoji = typeof nodeEmojiOverrideForNode === "function"
        ? String(nodeEmojiOverrideForNode(cleanNodeId) || "").trim()
        : "";
      if (overrideEmoji) return overrideEmoji;
      if (typeof nodeIntrinsicEmojiForNode === "function") {{
        return String(nodeIntrinsicEmojiForNode(cleanNodeId, node) || "").trim();
      }}
      return typeof nodeVisualEmojiForNode === "function"
        ? String(nodeVisualEmojiForNode(cleanNodeId, null, node) || "").trim()
        : "";
    }}

    function resolveNetworkGraphTagRouteLegendItems(edges, items, rootId, routeAnchorId = "") {{
      const byPresetId = new Map();
      for (const taggedItem of resolveNetworkGraphTaggedItems(items)) {{
        const presetId = normalizeNetworkGraphTagRoutePresetId(taggedItem && taggedItem.presetId);
        if (!presetId) continue;
        if (!byPresetId.has(presetId)) {{
          byPresetId.set(presetId, {{
            presetId,
            label: String(taggedItem.label || "Tagged"),
            color: String(taggedItem.color || "#2aa85a"),
            iconHtml: String(taggedItem.iconHtml || ""),
            nodeIds: new Set(),
            routeTargetIds: new Set(),
          }});
        }}
        const item = byPresetId.get(presetId);
        if (item && taggedItem.iconHtml && !item.iconHtml) {{
          item.iconHtml = String(taggedItem.iconHtml || "");
        }}
        if (item && taggedItem.nodeId) {{
          item.nodeIds.add(normalizeNodeId(taggedItem.nodeId));
        }}
      }}
      for (const segment of resolveNetworkGraphTaggedRouteSegments(edges, items, rootId, routeAnchorId)) {{
        const presetId = normalizeNetworkGraphTagRoutePresetId(segment && segment.presetId);
        if (!presetId) continue;
        if (!byPresetId.has(presetId)) {{
          byPresetId.set(presetId, {{
            presetId,
            label: String(segment.label || "Tagged"),
            color: String(segment.color || "#2aa85a"),
            iconHtml: "",
            nodeIds: new Set(),
            routeTargetIds: new Set(),
          }});
        }}
        const item = byPresetId.get(presetId);
        if (item && segment.targetId) {{
          item.routeTargetIds.add(normalizeNodeId(segment.targetId));
        }}
      }}
      return Array.from(byPresetId.values())
        .map((item) => ({{
          presetId: item.presetId,
          label: item.label,
          color: item.color,
          iconHtml: item.iconHtml,
          count: item.nodeIds.size,
          routeCount: item.routeTargetIds.size,
          visible: networkGraphTagRoutePresetIsVisible(item.presetId),
        }}))
        .sort((itemA, itemB) => (
          String(itemA.label || "").localeCompare(String(itemB.label || ""))
          || String(itemA.presetId || "").localeCompare(String(itemB.presetId || ""))
        ));
    }}

    function buildNetworkGraphTagRouteOverlayMarkup(scene) {{
      const safeScene = (scene && typeof scene === "object") ? scene : {{}};
      const rootId = normalizeNodeId(safeScene.rootId || "");
      const nodeMap = safeScene.nodeMap instanceof Map ? safeScene.nodeMap : new Map();
      const positions = safeScene.positions instanceof Map ? safeScene.positions : new Map();
      const edges = Array.isArray(safeScene.edges) ? safeScene.edges : [];
      const items = Array.isArray(safeScene.items) ? safeScene.items : [];
      const routeAnchorId = normalizeNodeId(
        safeScene.localId
        || safeScene.routeAnchorId
        || resolveLocalNodeId(latestState || {{}})
        || ""
      );
      const edgeByKey = new Map(edges.map((edge) => [buildNetworkGraphEdgeDomKey(edge), edge]));
      return resolveNetworkGraphTaggedRouteSegments(edges, items, rootId, routeAnchorId).filter((segment) => (
        networkGraphTagRoutePresetIsVisible(segment && segment.presetId)
      )).map((segment) => {{
        const edge = edgeByKey.get(segment.edgeKey);
        if (!edge) return "";
        const fromPos = positions.get(edge.a);
        const toPos = positions.get(edge.b);
        if (!fromPos || !toPos) return "";
        const x1Raw = Number(fromPos.x);
        const y1Raw = Number(fromPos.y);
        const x2Raw = Number(toPos.x);
        const y2Raw = Number(toPos.y);
        const dx = x2Raw - x1Raw;
        const dy = y2Raw - y1Raw;
        const length = Math.max(1, Math.hypot(dx, dy));
        const unitX = dx / length;
        const unitY = dy / length;
        const normalX = -unitY;
        const normalY = unitX;
        const stackCount = Math.max(1, Math.trunc(Number(segment.stackCount) || 1));
        const stackIndex = Math.max(0, Math.trunc(Number(segment.stackIndex) || 0));
        const stackOffset = Math.max(-11, Math.min(11, (stackIndex - ((stackCount - 1) / 2)) * 2.8));
        const endpointInset = Math.min(7, Math.max(2, length * 0.07));
        const x1 = x1Raw + (unitX * endpointInset) + (normalX * stackOffset);
        const y1 = y1Raw + (unitY * endpointInset) + (normalY * stackOffset);
        const x2 = x2Raw - (unitX * endpointInset) + (normalX * stackOffset);
        const y2 = y2Raw - (unitY * endpointInset) + (normalY * stackOffset);
        const color = String(segment.color || "#2aa85a");
        const width = Math.max(1.35, Math.min(2.2, 1.9 - (Math.min(6, stackCount - 1) * 0.08)));
        const sourceId = normalizeNodeId(segment.sourceId || rootId || "");
        const sourceLabel = sourceId ? networkGraphNodeDisplayName(sourceId, nodeMap) : "Root";
        const targetLabel = networkGraphNodeDisplayName(segment.targetId, nodeMap);
        const hopCount = Math.max(0, Math.trunc(Number(segment.hopCount) || 0));
        const hopLabel = hopCount === 1 ? "1 graph hop" : `${{hopCount}} graph hops`;
        const title = [
          `Tag route: ${{segment.label || "Tagged"}}`,
          `${{sourceLabel}} -> ${{targetLabel}}`,
          hopLabel,
        ].join("\n");
        return `
          <line
            class="network-graph-tag-route"
            data-network-graph-tag-route-key="${{escAttr(segment.routeKey)}}"
            data-network-graph-tag-preset-id="${{escAttr(segment.presetId)}}"
            data-network-graph-tag-target-id="${{escAttr(segment.targetId)}}"
            data-network-graph-tag-edge-key="${{escAttr(segment.edgeKey)}}"
            x1="${{x1.toFixed(1)}}"
            y1="${{y1.toFixed(1)}}"
            x2="${{x2.toFixed(1)}}"
            y2="${{y2.toFixed(1)}}"
            style="--network-graph-tag-route-color:${{escAttr(color)}};stroke-width:${{width.toFixed(2)}}"
          >
            <title>${{escAttr(title)}}</title>
          </line>
        `;
      }}).join("");
    }}

    function buildNetworkGraphSelfPathOverlayMarkup(scene) {{
      const safeScene = (scene && typeof scene === "object") ? scene : {{}};
      const nodeMap = safeScene.nodeMap instanceof Map ? safeScene.nodeMap : new Map();
      const positions = safeScene.positions instanceof Map ? safeScene.positions : new Map();
      const pathInfo = resolveNetworkGraphSelfPathInfo(safeScene);
      if (!pathInfo.visible) return "";
      const sourceLabel = networkGraphNodeDisplayName(pathInfo.sourceId, nodeMap);
      const targetLabel = networkGraphNodeDisplayName(pathInfo.targetId, nodeMap);
      const hopLabel = pathInfo.hopCount === 1 ? "1 graph hop" : `${{pathInfo.hopCount}} graph hops`;
      const title = [
        "Self path",
        `${{sourceLabel}} -> ${{targetLabel}}`,
        hopLabel,
      ].join("\n");
      return pathInfo.segments.map((segment, index) => {{
        const fromPos = positions.get(segment && segment.fromNodeId);
        const toPos = positions.get(segment && segment.toNodeId);
        if (!fromPos || !toPos) return "";
        const x1Raw = Number(fromPos.x);
        const y1Raw = Number(fromPos.y);
        const x2Raw = Number(toPos.x);
        const y2Raw = Number(toPos.y);
        const dx = x2Raw - x1Raw;
        const dy = y2Raw - y1Raw;
        const length = Math.max(1, Math.hypot(dx, dy));
        const endpointInset = Math.min(8, Math.max(2, length * 0.06));
        const unitX = dx / length;
        const unitY = dy / length;
        const x1 = x1Raw + (unitX * endpointInset);
        const y1 = y1Raw + (unitY * endpointInset);
        const x2 = x2Raw - (unitX * endpointInset);
        const y2 = y2Raw - (unitY * endpointInset);
        return `
          <line
            class="network-graph-self-path-segment is-halo"
            data-network-graph-self-path-edge-key="${{escAttr(segment.edgeKey)}}"
            data-network-graph-self-path-index="${{index}}"
            x1="${{x1.toFixed(1)}}"
            y1="${{y1.toFixed(1)}}"
            x2="${{x2.toFixed(1)}}"
            y2="${{y2.toFixed(1)}}"
          ></line>
          <line
            class="network-graph-self-path-segment"
            data-network-graph-self-path-edge-key="${{escAttr(segment.edgeKey)}}"
            data-network-graph-self-path-index="${{index}}"
            x1="${{x1.toFixed(1)}}"
            y1="${{y1.toFixed(1)}}"
            x2="${{x2.toFixed(1)}}"
            y2="${{y2.toFixed(1)}}"
          >
            <title>${{escAttr(title)}}</title>
          </line>
        `;
      }}).join("");
    }}

    function syncNetworkGraphSelectedTagRoute(svg) {{
      if (!(svg instanceof SVGElement)) return;
      const routeEls = svg.querySelectorAll("[data-network-graph-tag-route-key]");
      let selectedKey = String(networkGraphViewState.selectedTagRouteKey || "");
      let hasSelectedRoute = false;
      routeEls.forEach((routeEl) => {{
        if (!(routeEl instanceof SVGElement)) return;
        if (selectedKey && routeEl.getAttribute("data-network-graph-tag-route-key") === selectedKey) {{
          hasSelectedRoute = true;
        }}
      }});
      if (selectedKey && !hasSelectedRoute) {{
        selectedKey = "";
        networkGraphViewState.selectedTagRouteKey = "";
      }}
      const selectedEls = [];
      routeEls.forEach((routeEl) => {{
        if (!(routeEl instanceof SVGElement)) return;
        const isSelected = !!selectedKey && routeEl.getAttribute("data-network-graph-tag-route-key") === selectedKey;
        routeEl.classList.toggle("is-selected", isSelected);
        routeEl.classList.toggle("is-muted-by-selection", !!selectedKey && !isSelected);
        if (isSelected) {{
          selectedEls.push(routeEl);
        }}
      }});
      selectedEls.forEach((routeEl) => {{
        if (routeEl.parentElement instanceof SVGElement) {{
          routeEl.parentElement.appendChild(routeEl);
        }}
      }});
      svg.classList.toggle("has-selected-tag-route", !!selectedKey);
    }}

    function syncNetworkGraphTagRouteLayer(svg, scene) {{
      if (!(svg instanceof SVGElement)) return;
      const tagRouteLayer = svg.querySelector(".network-graph-tag-routes");
      if (tagRouteLayer instanceof SVGElement) {{
        tagRouteLayer.innerHTML = buildNetworkGraphTagRouteOverlayMarkup(scene);
        syncNetworkGraphSelectedTagRoute(svg);
      }}
    }}

    function syncNetworkGraphSelfPathLayer(svg, scene) {{
      if (!(svg instanceof SVGElement)) return;
      const selfPathLayer = svg.querySelector(".network-graph-self-path");
      if (selfPathLayer instanceof SVGElement) {{
        selfPathLayer.innerHTML = buildNetworkGraphSelfPathOverlayMarkup(scene);
      }}
    }}

    function bindNetworkGraphTagRouteLegendControls(legend, scene) {{
      if (!(legend instanceof HTMLElement)) return;
      const inputs = legend.querySelectorAll("[data-network-graph-tag-filter-id]");
      inputs.forEach((input) => {{
        if (!(input instanceof HTMLInputElement) || input.dataset.boundTagRouteFilter === "1") return;
        input.dataset.boundTagRouteFilter = "1";
        input.addEventListener("change", () => {{
          const presetId = normalizeNetworkGraphTagRoutePresetId(input.dataset.networkGraphTagFilterId || "");
          if (!presetId) return;
          if (!(networkGraphViewState.hiddenTagRoutePresetIds instanceof Set)) {{
            networkGraphViewState.hiddenTagRoutePresetIds = new Set();
          }}
          if (input.checked) {{
            networkGraphViewState.hiddenTagRoutePresetIds.delete(presetId);
          }} else {{
            networkGraphViewState.hiddenTagRoutePresetIds.add(presetId);
          }}
          persistPreferredNetworkGraphHiddenTagRoutePresetIds(networkGraphViewState.hiddenTagRoutePresetIds);
          const graphSvg = document.getElementById("network-graph-svg");
          if (graphSvg instanceof SVGElement) {{
            syncNetworkGraphSceneData(graphSvg, scene);
          }}
          renderNetworkGraphTagRouteLegend(scene);
        }});
      }});
      const selfPathInput = legend.querySelector("[data-network-graph-self-path-toggle]");
      if (selfPathInput instanceof HTMLInputElement && selfPathInput.dataset.boundSelfPathToggle !== "1") {{
        selfPathInput.dataset.boundSelfPathToggle = "1";
        selfPathInput.addEventListener("change", () => {{
          networkGraphViewState.selfPathVisible = !!selfPathInput.checked;
          persistPreferredNetworkGraphSelfPathVisible(networkGraphViewState.selfPathVisible);
          const graphSvg = document.getElementById("network-graph-svg");
          if (graphSvg instanceof SVGElement) {{
            syncNetworkGraphSceneData(graphSvg, scene);
          }}
          renderNetworkGraphTagRouteLegend(scene);
        }});
      }}
    }}

    function renderNetworkGraphTagRouteLegend(scene) {{
      const legend = document.getElementById("network-graph-legend");
      if (!(legend instanceof HTMLElement)) return;
      const safeScene = (scene && typeof scene === "object") ? scene : {{}};
      const edges = Array.isArray(safeScene.edges) ? safeScene.edges : [];
      const items = Array.isArray(safeScene.items) ? safeScene.items : [];
      const rootId = normalizeNodeId(safeScene.rootId || "");
      const routeAnchorId = normalizeNodeId(
        safeScene.localId
        || safeScene.routeAnchorId
        || resolveLocalNodeId(latestState || {{}})
        || ""
      );
      const tagItems = resolveNetworkGraphTagRouteLegendItems(edges, items, rootId, routeAnchorId);
      const selfPathInfo = resolveNetworkGraphSelfPathInfo(safeScene);
      if (!tagItems.length && !selfPathInfo.offered) {{
        legend.innerHTML = "";
        legend.hidden = true;
        return;
      }}
      legend.hidden = false;
      const selfPathRow = selfPathInfo.offered
        ? (() => {{
          const checkedAttr = networkGraphSelfPathIsVisible() ? " checked" : "";
          const disabledAttr = selfPathInfo.available ? "" : " disabled";
          const countLabel = selfPathInfo.available ? ` <span class="network-graph-tag-filter-count">${{selfPathInfo.hopCount}}</span>` : "";
          const title = selfPathInfo.available
            ? "Toggle self to selected node path"
            : "No current path from self to selected node";
          return `<label class="network-graph-tag-filter network-graph-self-path-filter${{selfPathInfo.visible ? "" : " is-muted"}}${{selfPathInfo.available ? "" : " is-empty"}}" style="--network-graph-tag-route-color:var(--network-graph-self-path-color, var(--theme-base-color, var(--ui-accent, #2f855a)));" title="${{escAttr(title)}}">
            <input
              class="network-graph-tag-filter-input"
              type="checkbox"
              data-network-graph-self-path-toggle="1"
              aria-label="Show self to selected node path"
              ${{checkedAttr}}
              ${{disabledAttr}}
            />
            <span class="network-graph-tag-filter-name">Self path</span>${{countLabel}}
          </label>`;
        }})()
        : "";
      legend.innerHTML = `
        <div class="network-graph-tag-legend-title">Routes</div>
        <div class="network-graph-tag-filter-list">
          ${{selfPathRow}}
          ${{
            tagItems.map((item) => {{
              const hasRoutes = Number(item.routeCount || 0) > 0;
              const canToggle = Number(item.count || 0) > 0 || hasRoutes;
              const checkedAttr = item.visible ? " checked" : "";
              const disabledAttr = canToggle ? "" : " disabled";
              const countLabel = item.count > 1 ? ` <span class="network-graph-tag-filter-count">${{item.count}}</span>` : "";
              const title = hasRoutes
                ? `Toggle ${{item.label}} nodes and routes`
                : canToggle
                ? `Toggle ${{item.label}} node highlighting; no current routes from this view`
                : `No current ${{item.label}} nodes or routes from this view`;
              return `<label class="network-graph-tag-filter${{item.visible ? "" : " is-muted"}}${{canToggle ? "" : " is-empty"}}" style="--network-graph-tag-route-color:${{escAttr(item.color)}};" title="${{escAttr(title)}}">
                <input
                  class="network-graph-tag-filter-input"
                  type="checkbox"
                  data-network-graph-tag-filter-id="${{escAttr(item.presetId)}}"
                  aria-label="${{escAttr(`Show ${{item.label}} tag routes`)}}"
                  ${{checkedAttr}}
                  ${{disabledAttr}}
                />
                <span class="network-graph-tag-filter-name">${{item.iconHtml || ""}}<span class="network-graph-tag-filter-label">${{escAttr(item.label)}}</span></span>${{countLabel}}
              </label>`;
            }}).join("")
          }}
        </div>
      `;
      bindNetworkGraphTagRouteLegendControls(legend, safeScene);
    }}

    function buildNetworkGraphEdgeTitle(edge, nodeMap = null) {{
      const safeNodeMap = nodeMap instanceof Map ? nodeMap : new Map();
      if (!edge || typeof edge !== "object") return "";
      const fromLabel = networkGraphNodeDisplayName(edge.a, safeNodeMap);
      const toLabel = networkGraphNodeDisplayName(edge.b, safeNodeMap);
      const lastAgeLabel = Number.isFinite(edge.lastSeenUnix) && edge.lastSeenUnix > 0
        ? (
          typeof formatIdleAge === "function"
            ? formatIdleAge(edge.lastSeenUnix, Math.floor(Date.now() / 1000))
            : `${{Math.max(0, Math.floor((Date.now() / 1000) - edge.lastSeenUnix))}}s ago`
        )
        : (edge.lastSeenLabel || "n/a");
      return [
        `${{fromLabel}} <-> ${{toLabel}}`,
        `Packets: ${{Math.round(edge.weight)}}`,
        `Directions observed: ${{edge.directionCount}}`,
        `Last seen: ${{lastAgeLabel}}`,
        `Avg packet hops: ${{edge.avgHops == null ? "n/a" : edge.avgHops}}`,
      ].join("\n");
    }}

    function buildNetworkGraphNodeTitle(item, nodeMap = null, rootId = "") {{
      const safeNodeMap = nodeMap instanceof Map ? nodeMap : new Map();
      if (!item || typeof item !== "object") return "";
      const displayName = networkGraphNodeDisplayName(item.nodeId, safeNodeMap);
      const statusLine = item.broadcastOnly
        ? (
          item.nodeId === rootId
            ? "Heard recently via broadcast only"
            : "No explicit node link, only recent broadcast evidence"
        )
        : item.detached
        ? "No current path from the root"
        : (item.layer === 0 ? "Root node" : `${{item.layer}} hop${{item.layer === 1 ? "" : "s"}} away`);
      return [
        displayName,
        item.nodeId,
        statusLine,
        `Visible links: ${{item.degree}}`,
        `Observed packets on links: ${{Math.round(item.weight)}}`,
        item.signalMeta && item.broadcastOnly
          ? (
            Number(item.signalMeta.broadcastPacketCount || 0) > 0
              ? `Recent broadcast packets: ${{item.signalMeta.broadcastPacketCount}}${{item.signalMeta.lastPortnum ? ` (${{item.signalMeta.lastPortnum}})` : ""}}`
              : `Saved heard packets: ${{Math.max(0, Math.trunc(Number(item.signalMeta.savedPackets) || 0))}}, last packet hops away: ${{Number.isFinite(Number(item.signalMeta.hopsAway)) ? Math.trunc(Number(item.signalMeta.hopsAway)) : "n/a"}}`
          )
          : "",
        `Last heard: ${{(item.node && item.node.last_heard) || "n/a"}}`,
      ].filter(Boolean).join("\n");
    }}

    function setNetworkGraphLazyTitle(target, titleText) {{
      if (!(target instanceof SVGElement)) return;
      const cleanText = String(titleText || "");
      if (!cleanText) return;
      let titleEl = null;
      for (const child of Array.from(target.children || [])) {{
        if (child instanceof SVGTitleElement) {{
          titleEl = child;
          break;
        }}
      }}
      if (!(titleEl instanceof SVGTitleElement)) {{
        titleEl = document.createElementNS("http://www.w3.org/2000/svg", "title");
        target.insertBefore(titleEl, target.firstChild);
      }}
      if (titleEl.textContent !== cleanText) {{
        titleEl.textContent = cleanText;
      }}
    }}

    function hydrateNetworkGraphLazyTitle(rawTarget) {{
      if (!(rawTarget instanceof Element)) return;
      const edgeEl = rawTarget.closest("[data-network-graph-edge-key]");
      if (edgeEl instanceof SVGElement) {{
        const edgeKey = String(edgeEl.getAttribute("data-network-graph-edge-key") || "");
        const edges = Array.isArray(networkGraphViewState.cachedCombinedEdges)
          ? networkGraphViewState.cachedCombinedEdges
          : [];
        const edge = edges.find((candidate) => buildNetworkGraphEdgeDomKey(candidate) === edgeKey);
        if (edge) {{
          setNetworkGraphLazyTitle(
            edgeEl,
            buildNetworkGraphEdgeTitle(edge, networkGraphViewState.cachedNodeMap)
          );
        }}
        return;
      }}
      const nodeEl = rawTarget.closest("[data-network-graph-node-id]");
      if (nodeEl instanceof SVGElement) {{
        const nodeId = normalizeNodeId(nodeEl.getAttribute("data-network-graph-node-id") || "");
        const layout = networkGraphViewState.cachedLayout;
        const item = Array.isArray(layout && layout.items)
          ? layout.items.find((candidate) => normalizeNodeId(candidate && candidate.nodeId) === nodeId)
          : null;
        if (item) {{
          setNetworkGraphLazyTitle(
            nodeEl,
            buildNetworkGraphNodeTitle(item, networkGraphViewState.cachedNodeMap, networkGraphRootNodeId)
          );
        }}
      }}
    }}

    function buildNetworkGraphSceneMarkup(scene) {{
      const safeScene = (scene && typeof scene === "object") ? scene : {{}};
      const rootId = normalizeNodeId(safeScene.rootId || "");
      const selectedId = normalizeNodeId(safeScene.selectedId || "");
      const localId = normalizeNodeId(resolveLocalNodeId(latestState || {{}}) || "");
      const nodeMap = safeScene.nodeMap instanceof Map ? safeScene.nodeMap : new Map();
      const positions = safeScene.positions instanceof Map ? safeScene.positions : new Map();
      const rings = Array.isArray(safeScene.rings) ? safeScene.rings : [];
      const regions = Array.isArray(safeScene.regions) ? safeScene.regions : [];
      const edges = Array.isArray(safeScene.edges) ? safeScene.edges : [];
      const items = Array.isArray(safeScene.items) ? safeScene.items : [];
      const selfPathInfo = resolveNetworkGraphSelfPathInfo(safeScene);
      const localPathEdgeKeys = selfPathInfo.visible ? selfPathInfo.edgeKeys : new Set();

      const regionMarkup = regions.map((region) => `
        <g class="network-graph-region-wrap">
          <rect
            class="network-graph-region${{region.isRoot ? " is-root" : ""}}"
            x="${{Number(region.x).toFixed(1)}}"
            y="${{Number(region.y).toFixed(1)}}"
            width="${{Number(region.width).toFixed(1)}}"
            height="${{Number(region.height).toFixed(1)}}"
            rx="18"
            ry="18"
          ></rect>
          <text class="network-graph-region-label" x="${{(Number(region.x) + 12).toFixed(1)}}" y="${{(Number(region.y) + 18).toFixed(1)}}">${{escAttr(region.label || "")}}</text>
        </g>
      `).join("");

      const ringMarkup = rings.map((ring) => `
        <g class="network-graph-ring-wrap">
          <circle class="network-graph-ring${{ring.detached ? " is-detached" : ""}}${{ring.broadcastOnly ? " is-broadcast-only" : ""}}" cx="480" cy="310" r="${{Number(ring.radius).toFixed(1)}}"></circle>
          <text class="network-graph-ring-label" x="480" y="${{(310 - Number(ring.radius) - 8).toFixed(1)}}" text-anchor="middle">${{escAttr(ring.label)}}</text>
        </g>
      `).join("");

      function resolveNetworkGraphNodeEmoji(item) {{
        const nodeId = normalizeNodeId(item && item.nodeId || "");
        if (!nodeId) return "";
        return networkGraphVisibleNodeEmojiForNode(nodeId, item && item.node);
      }}

      const edgeRenderItems = edges.map((edge, index) => ({{
        edge,
        edgeKey: buildNetworkGraphEdgeDomKey(edge),
        index,
      }})).sort((itemA, itemB) => {{
        const pathDelta = (localPathEdgeKeys.has(itemA.edgeKey) ? 1 : 0) - (localPathEdgeKeys.has(itemB.edgeKey) ? 1 : 0);
        return pathDelta || (itemA.index - itemB.index);
      }});
      const edgeMarkup = edgeRenderItems.map((renderItem) => {{
        const edge = renderItem.edge;
        const edgeKey = renderItem.edgeKey;
        const fromPos = positions.get(edge.a);
        const toPos = positions.get(edge.b);
        if (!fromPos || !toPos) return "";
        const classes = [
          "network-graph-edge",
          edge.isReal ? "is-real" : "is-observed",
          (edge.a === rootId || edge.b === rootId) ? "is-root-link" : "",
          localPathEdgeKeys.has(edgeKey) ? "is-local-path" : "",
        ].filter(Boolean).join(" ");
        const width = Math.max(1.1, Math.min(5.2, 1.2 + (Math.log2(Math.max(1, edge.weight) + 1) * 0.85) + (edge.isReal ? 0.35 : 0)));
        return `
          <line
            class="${{classes}}"
            data-network-graph-edge-key="${{escAttr(edgeKey)}}"
            x1="${{Number(fromPos.x).toFixed(1)}}"
            y1="${{Number(fromPos.y).toFixed(1)}}"
            x2="${{Number(toPos.x).toFixed(1)}}"
            y2="${{Number(toPos.y).toFixed(1)}}"
            style="stroke-width:${{width.toFixed(2)}}"
          ></line>
        `;
      }}).join("");

      const tagRouteOverlayMarkup = buildNetworkGraphTagRouteOverlayMarkup(safeScene);
      const selfPathOverlayMarkup = buildNetworkGraphSelfPathOverlayMarkup(safeScene);

      function networkGraphNodeRenderPriority(item) {{
        const nodeId = normalizeNodeId(item && item.nodeId || "");
        let priority = networkGraphNodeDisplayPriority(nodeId, nodeMap);
        if (nodeId === rootId) priority += 4;
        if (nodeId === localId) priority += 5;
        if (nodeId === selectedId) priority += 6;
        return priority;
      }}

      const nodeRenderItems = items.map((item, index) => ({{ item, index }})).sort((itemA, itemB) => {{
        const priorityDelta = networkGraphNodeRenderPriority(itemA.item) - networkGraphNodeRenderPriority(itemB.item);
        if (priorityDelta !== 0) return priorityDelta;
        return itemA.index - itemB.index;
      }});

      const nodeMarkup = nodeRenderItems.map((renderItem) => {{
        const item = renderItem.item;
        const displayName = networkGraphNodeDisplayName(item.nodeId, nodeMap);
        const label = truncateNetworkGraphLabel(displayName, item.layer === 0 ? 28 : 16);
        const nodeEmoji = resolveNetworkGraphNodeEmoji(item);
        const tagEntry = networkGraphVisibleTagEntryForNode(item.nodeId);
        const isTaggedNode = !!(tagEntry && tagEntry.preset);
        const rawTagEntry = (typeof nodeTagEntryForNode === "function")
          ? nodeTagEntryForNode(item.nodeId)
          : null;
        const appearanceEntry = rawTagEntry
          ? tagEntry
          : ((typeof effectiveNodeAppearanceForNode === "function")
            ? effectiveNodeAppearanceForNode(item.nodeId)
            : null);
        const hasNodeAppearance = !!(appearanceEntry && appearanceEntry.preset);
        const isProfiledNode = hasNodeAppearance && !isTaggedNode;
        const profileTheme = isProfiledNode && typeof normalizeMeshyfaceProfileTheme === "function"
          ? normalizeMeshyfaceProfileTheme(appearanceEntry.theme)
          : null;
        const hasProfileThemeIdentity = !!profileTheme;
        const appearanceStyleVars = (hasNodeAppearance && typeof nodeAppearanceStyleVars === "function")
          ? nodeAppearanceStyleVars(appearanceEntry)
          : "";
        const labelOffsetRaw = item && item.labelOffsetY;
        const labelOffsetY = (
          labelOffsetRaw == null
          || labelOffsetRaw === ""
          || !Number.isFinite(Number(labelOffsetRaw))
        )
          ? (Number(item.radius) + 14)
          : Number(labelOffsetRaw);
        const isLocalNode = item.nodeId === localId;
        const isRootNode = item.nodeId === rootId;
        const isSelectedNode = item.nodeId === selectedId;
        const labelPriority = isRootNode || isLocalNode || isSelectedNode
          ? "persistent"
          : item.broadcastOnly || item.detached
          ? "low"
          : Number(item.layer) <= 1 || Number(item.degree) >= 6
          ? "high"
          : Number(item.layer) <= 2 || Number(item.degree) >= 3
          ? "medium"
          : "low";
        const classes = [
          "network-graph-node",
          isLocalNode ? "is-local" : "",
          nodeEmoji ? "has-emoji-glyph" : "",
          isRootNode ? "is-root" : "",
          isSelectedNode ? "is-selected" : "",
          hasNodeAppearance ? "is-tagged" : "",
          isProfiledNode ? "is-profiled" : "",
          hasProfileThemeIdentity ? "has-theme-identity" : "",
          item.detached ? "is-detached" : "",
          item.broadcastOnly ? "is-broadcast-only" : "",
          `label-priority-${{labelPriority}}`,
        ].filter(Boolean).join(" ");
        const emojiBoxSize = Math.max(24, Math.round(Number(item.radius) * 2.5));
        const emojiBoxOffset = -(emojiBoxSize / 2);
        const themeSurfaceBoxSize = Math.max(10, Number(item.radius) * 1.56);
        const themeSurfaceBoxOffset = -(themeSurfaceBoxSize / 2);
        return `
          <g
            class="${{classes}}"
            data-network-graph-node-id="${{escAttr(item.nodeId)}}"
            ${{appearanceStyleVars ? `style="${{escAttr(appearanceStyleVars)}}"` : ""}}
            transform="translate(${{Number(item.x).toFixed(1)}} ${{Number(item.y).toFixed(1)}})"
          >
            <circle class="network-graph-node-core" r="${{Number(item.radius).toFixed(1)}}"></circle>
            ${{
              hasProfileThemeIdentity
                ? `<foreignObject class="network-graph-node-theme-surface-fo" x="${{themeSurfaceBoxOffset.toFixed(1)}}" y="${{themeSurfaceBoxOffset.toFixed(1)}}" width="${{themeSurfaceBoxSize.toFixed(1)}}" height="${{themeSurfaceBoxSize.toFixed(1)}}" aria-hidden="true">
                    <div xmlns="http://www.w3.org/1999/xhtml" class="network-graph-node-theme-surface"></div>
                  </foreignObject>`
                : ""
            }}
            ${{
              nodeEmoji
                ? `<foreignObject class="network-graph-node-emoji-fo" x="${{emojiBoxOffset.toFixed(1)}}" y="${{emojiBoxOffset.toFixed(1)}}" width="${{emojiBoxSize.toFixed(1)}}" height="${{emojiBoxSize.toFixed(1)}}" aria-hidden="true">
                    <div xmlns="http://www.w3.org/1999/xhtml" class="network-graph-node-emoji">${{escAttr(nodeEmoji)}}</div>
                  </foreignObject>`
                : ""
            }}
            ${{
              item.showLabel
                ? `<text class="network-graph-node-label is-priority-${{labelPriority}}${{labelOffsetY < 0 ? " is-above" : " is-below"}}${{(item.detached || item.broadcastOnly) ? " is-secondary" : ""}}${{item.broadcastOnly ? " is-broadcast-only" : ""}}" x="0" y="${{labelOffsetY.toFixed(1)}}" data-network-graph-label-offset-y="${{labelOffsetY.toFixed(1)}}" data-network-graph-node-radius="${{Number(item.radius).toFixed(1)}}" text-anchor="middle">${{escAttr(label)}}</text>`
                : ""
            }}
          </g>
        `;
      }}).join("");

      return `
        <g class="network-graph-layers">
          ${{regionMarkup}}
          ${{ringMarkup}}
        </g>
        <g class="network-graph-links">
          ${{edgeMarkup}}
        </g>
        <g class="network-graph-tag-routes">
          ${{tagRouteOverlayMarkup}}
        </g>
        <g class="network-graph-self-path">
          ${{selfPathOverlayMarkup}}
        </g>
        <g class="network-graph-nodes">
          ${{nodeMarkup}}
        </g>
      `;
    }}

    function cloneNetworkGraphLayoutSnapshot(layout) {{
      if (!layout || typeof layout !== "object") return null;
      return {{
        rootId: normalizeNodeId(layout.rootId || ""),
        positions: new Map(
          Array.from((layout.positions instanceof Map ? layout.positions : new Map()).entries()).map(([nodeId, position]) => [
            normalizeNodeId(nodeId),
            {{
              x: Number(position && position.x),
              y: Number(position && position.y),
            }},
          ])
        ),
        rings: Array.isArray(layout.rings)
          ? layout.rings.map((ring) => ({{
              radius: Number(ring && ring.radius),
              label: String((ring && ring.label) || ""),
              detached: !!(ring && ring.detached),
              broadcastOnly: !!(ring && ring.broadcastOnly),
            }}))
          : [],
        regions: Array.isArray(layout.regions)
          ? layout.regions.map((region) => ({{
              x: Number(region && region.x),
              y: Number(region && region.y),
              width: Number(region && region.width),
              height: Number(region && region.height),
              label: String((region && region.label) || ""),
              isRoot: !!(region && region.isRoot),
            }}))
          : [],
      }};
    }}

    function syncNetworkGraphSceneSelection(svg, options = {{}}) {{
      if (!(svg instanceof SVGElement)) return;
      const rootId = normalizeNodeId(options && options.rootId);
      const selectedId = normalizeNodeId(options && options.selectedId);
      const groups = svg.querySelectorAll("[data-network-graph-node-id]");
      groups.forEach((group) => {{
        if (!(group instanceof SVGGElement)) return;
        const nodeId = normalizeNodeId(group.getAttribute("data-network-graph-node-id") || "");
        group.classList.toggle("is-root", !!rootId && nodeId === rootId);
        group.classList.toggle("is-selected", !!selectedId && nodeId === selectedId);
      }});
    }}

    function buildNetworkGraphSceneStructureSignature(scene) {{
