      if (next !== "saved") {{
        closeSavedNodeSearchDropdown();
      }}
      renderSavedNodeSearchDropdown(latestState);
      renderFavoriteMenuNodeSearchDropdown(latestState);
      // Ensure node history loads immediately when switching into the map views.
      void refreshSelectedNodeHistory(false);
      if (next === "chat" || next === "macros" || next === "files" || next === "bbs" || next === "bots" || next === "games" || next === "remote" || next === "history" || next === "network" || next === "saved" || next === "channels" || next === "environment") {{
        requestImmediatePoll(0);
