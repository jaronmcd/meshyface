          const latestOwnDirectEcho = (() => {{
            for (let idx = popoutBucket.length - 1; idx >= 0; idx -= 1) {{
              const msg = popoutBucket[idx];
              if (!(msg && (msg.local_echo === true || msg.localEcho === true))) continue;
              const endpoints = endpointsForMessage(msg);
              const fromId = normalizeNodeId(endpoints && endpoints.fromId);
              const toId = normalizeNodeId(endpoints && endpoints.toId);
              if (isCanonicalNodeId(localNodeId) && fromId !== localNodeId) continue;
              if (isCanonicalNodeId(activePopoutPeerId) && toId !== activePopoutPeerId) continue;
              return msg;
