                popoutFileProgressFill.style.width = "0%";
              }}
              return;
            }}
            const pct = Math.max(0, Math.min(100, Math.round(Number(snapshot.percent) || 0)));
            const text = String(snapshot.text || "").trim() || "File transfer active";
            const phase = String(snapshot.phase || "").trim().toLowerCase();
            popoutFileProgress.hidden = false;
            popoutFileProgress.classList.toggle("is-error", !!snapshot.isError);
