                <button type="button" id="peer-dm-popout-file-manage-btn" class="peer-dm-popout-file-manage-btn" title="Open the full Files workspace">Open Files</button>
              </div>
              <div
                id="peer-dm-popout-file-progress"
                class="peer-dm-popout-file-progress${{popoutFileState && popoutFileState.isError ? " is-error" : ""}}${{popoutFilePhase === "delivered" ? " is-success" : ""}}"
                title="${{escAttr(popoutFileProgressTitle)}}"
                ${{popoutFileState ? "" : "hidden"}}
              >
                <div class="peer-dm-popout-file-progress-head">
                  <span id="peer-dm-popout-file-progress-text" class="peer-dm-popout-file-progress-text">${{escAttr(popoutFileText || "No file transfer activity yet.")}}</span>
                  <span id="peer-dm-popout-file-progress-pct" class="peer-dm-popout-file-progress-pct">${{escAttr(`${{popoutFilePercent}}%`)}}</span>
                </div>
                <div class="peer-dm-popout-file-progress-meter">
                  <span id="peer-dm-popout-file-progress-fill" style="width:${{escAttr(String(popoutFilePercent))}}%;"></span>
                </div>
              </div>
              <div id="peer-dm-popout-status" class="peer-dm-popout-status" hidden></div>
            </div>
          </section>`;
          const openMainBtn = document.getElementById("peer-dm-popout-open-main-btn");
          if (openMainBtn instanceof HTMLButtonElement) {{
            openMainBtn.addEventListener("click", (ev) => {{
