        if (document.activeElement !== searchInput && searchInput.value !== String(chatFeedSearchQuery || "")) {{
          searchInput.value = String(chatFeedSearchQuery || "");
        }}
        if (searchInput.dataset.bound !== "1") {{
          searchInput.dataset.bound = "1";
          searchInput.addEventListener("input", () => {{
            chatFeedSearchQuery = String(searchInput.value || "").slice(0, 120);
            applyChatFeedSearchFilter();
          }});
        }}
      }}
      applyChatFeedSearchFilter();
      if (caption instanceof HTMLElement) {{
        if (chatPerfEnabled) {{
          caption.title = `Chat render avg ${{chatPerfStats.avgMs.toFixed(1)}}ms, max ${{chatPerfStats.maxMs.toFixed(1)}}ms, samples ${{chatPerfStats.samples}}`;
        }} else {{
          caption.removeAttribute("title");
        }}
      }}
    }}
