            const updateTime = formatLocalChatTime(updateUnix, updateRawTime || "n/a", nowUnix);
            if (deliveryState === "pending") {{
              setPopoutStatus(`Awaiting ACK · ${{updateTime}}`);
            }} else if (deliveryState === "acked") {{
              setPopoutStatus(`Delivered · ${{updateTime}}`);
            }} else if (deliveryState === "nak" || deliveryState === "timeout" || deliveryState === "error") {{
              const base = deliveryState === "timeout" ? "Delivery timeout" : "Delivery failed";
              setPopoutStatus(
                deliveryError ? `${{base}} · ${{deliveryError}}` : base,
