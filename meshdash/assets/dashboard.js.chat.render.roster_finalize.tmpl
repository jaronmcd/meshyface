      if (activeChatChannel === "all" && participants.size === 0) {{
        for (const msg of baseMessages) {{
          if (classifyMessageChannel(msg) !== "all") continue;
          touchNodeById(msg.from, latestUnixTimestamp(msg.rx_time, msg.captured_at));
        }}
      }}
      if (activeChatChannel === "direct") {{
        for (const peerId of manualDirectPeerIds) {{
          if (!isCanonicalNodeId(peerId)) continue;
          if (isCanonicalNodeId(localNodeId) && peerId === localNodeId) continue;
          const snapshot = resolveChatNodeFreshness(peerId);
          const node = snapshot.node;
          const name = preferredNodeName(node) || nodeNameCache.get(peerId) || peerId;
          const existing = participants.get(peerId);
          if (!existing) {{
            participants.set(peerId, {{
              id: peerId,
              name,
              status: snapshot.status,
              lastSeenUnix: snapshot.lastSeenUnix,
              lastMessageUnix: null,
              p2pPinned: true,
            }});
            continue;
          }}
          existing.p2pPinned = true;
          if (name && name !== "Unknown node") {{
            existing.name = name;
          }}
          existing.lastSeenUnix = latestUnixTimestamp(existing.lastSeenUnix, snapshot.lastSeenUnix);
          existing.status = freshnessStatus(existing.lastSeenUnix, nowUnix);
        }}
      }}
      if (activeChatChannel === "direct" && isCanonicalNodeId(selectedNodeId)) {{
        touchNodeById(selectedNodeId);
      }}
      for (const node of nodes) {{
        touchNodeById(node && node.id);
      }}
      if (historyCapsById && typeof historyCapsById.keys === "function") {{
        for (const nodeId of historyCapsById.keys()) {{
          touchNodeById(nodeId);
        }}
      }}
      if (favoriteNodeIds && typeof favoriteNodeIds.forEach === "function") {{
        favoriteNodeIds.forEach((nodeId) => {{
          touchNodeById(nodeId);
        }});
      }}
      if (nodeNotesById && typeof nodeNotesById.forEach === "function") {{
        nodeNotesById.forEach((_entry, nodeId) => {{
          touchNodeById(nodeId);
        }});
      }}
      const feed = document.getElementById("chat-feed");
      if (feed) {{
        feed.classList.toggle("chat-feed-view-monitor", chatViewMode === "monitor");
        feed.dataset.chatViewMode = chatViewMode === "monitor" ? "monitor" : "default";
        const emptyText = (activeChatChannel === "direct" && !isCanonicalNodeId(directSelectedId))
          ? "Select a user to view peer-to-peer messages."
          : `No ${{channelLabel(activeChatChannel).toLowerCase()}} messages yet.`;
        closeReactionPopover(true);
        feed.innerHTML = feedItems.length > 0
          ? feedItems.join("")
          : `<div class="chat-feed-empty">${{emptyText}}</div>`;
      }}
      renderChatChangeSummary(nowUnix);

      const rosterQuery = globalNodeSearchQuery();
      const roomList = document.getElementById("chat-room-list");
      const rosterAll = Array.from(participants.values())
        .sort((a, b) => {{
          const pinDiff = Number(!!b.p2pPinned) - Number(!!a.p2pPinned);
          if (pinDiff !== 0) return pinDiff;
          const rankDiff = statusRank(a.status) - statusRank(b.status);
          if (rankDiff !== 0) return rankDiff;
          const aTime = a.lastMessageUnix || 0;
          const bTime = b.lastMessageUnix || 0;
          if (aTime !== bTime) return bTime - aTime;
          return String(a.name || a.id).localeCompare(String(b.name || b.id));
        }});
      const roster = rosterAll;
      // Preserve the full (unfiltered) roster so tickFreshnessUI() can compute canonical
      // online/aging/stale counts even when the user is search-filtering the roster DOM.
      chatRosterModel = rosterAll;
      const rosterFiltered = roster.filter((item) => (
        matchesIdOrNameQuery(item.id, item.name, rosterQuery, {{
          node: nodesById.get(normalizeNodeId(item.id)),
        }})
      ));
      const buildNodePacketSparklinePath = (bucketValuesRaw, width = 56, height = 12) => {{
        const buckets = Array.isArray(bucketValuesRaw)
          ? bucketValuesRaw.map((value) => Math.max(0, Number(value) || 0))
          : [];
        const plotWidth = Math.max(12, Number(width) || 56);
        const plotHeight = Math.max(8, Number(height) || 12);
        const baselineY = Math.max(1, plotHeight - 1);
        if (buckets.length <= 0) {{
          return `M 0 ${{baselineY.toFixed(2)}} L ${{plotWidth.toFixed(2)}} ${{baselineY.toFixed(2)}}`;
        }}
        const maxValue = Math.max(0, ...buckets);
        const padY = 1;
        const usableHeight = Math.max(2, plotHeight - (padY * 2));
        const points = buckets.map((value, idx) => {{
          const x = buckets.length <= 1
            ? (plotWidth / 2)
            : ((idx / Math.max(1, buckets.length - 1)) * plotWidth);
          const y = maxValue > 0
            ? (padY + ((maxValue - value) / maxValue) * usableHeight)
            : baselineY;
          return {{
            x,
            y,
          }};
        }});
        if (typeof buildSmoothSvgPath === "function") {{
          const smoothPath = buildSmoothSvgPath(points, 0.2);
          if (smoothPath) {{
            return smoothPath;
          }}
        }}
        return points.map((point, idx) => (
          `${{idx === 0 ? "M" : "L"}} ${{point.x.toFixed(2)}} ${{point.y.toFixed(2)}}`
        )).join(" ");
      }};
      const classifyNodePacketSparklineTrend = (bucketValuesRaw) => {{
        const buckets = Array.isArray(bucketValuesRaw)
          ? bucketValuesRaw.map((value) => Math.max(0, Number(value) || 0))
          : [];
        if (buckets.length <= 1) return "trend-flat";
        const segmentSize = Math.max(1, Math.trunc(buckets.length / 3));
        const startSlice = buckets.slice(0, segmentSize);
        const endSlice = buckets.slice(-segmentSize);
        const avg = (rows) => {{
          const list = Array.isArray(rows) ? rows : [];
          if (list.length === 0) return 0;
          const total = list.reduce((sum, value) => sum + (Number(value) || 0), 0);
          return total / Math.max(1, list.length);
        }};
        const startAvg = avg(startSlice);
        const endAvg = avg(endSlice);
        const delta = endAvg - startAvg;
        const threshold = Math.max(0.5, Math.max(...buckets, 0) * 0.15);
        if (delta > threshold) return "trend-up";
        if (delta < -threshold) return "trend-down";
        return "trend-flat";
      }};
      const onlineCount = rosterAll.filter((item) => item.status === "online").length;
      const warnCount = rosterAll.filter((item) => item.status === "warn").length;
      const staleCount = rosterAll.filter((item) => item.status === "stale").length;
      const syncPendingDirectAckStatus = () => {{
        const pending = (
          chatPendingDirectAck && typeof chatPendingDirectAck === "object"
        ) ? chatPendingDirectAck : null;
        if (!pending) return;
        const pendingMessageId = Number(pending.messageId);
        const pendingDest = normalizeNodeId(pending.destination || "");
        if (!Number.isInteger(pendingMessageId) || pendingMessageId <= 0 || !isCanonicalNodeId(pendingDest)) {{
          chatPendingDirectAck = null;
          return;
        }}
        const pendingChannelIndex = Math.max(0, Math.trunc(Number(pending.channelIndex) || 0));
        const pendingChannelLabel = meshChannelViewMenuLabel(pendingChannelIndex, {{
          verbose: false,
          allowAll: false,
        }});
        const pendingSentUnix = latestUnixTimestamp(
          pending.sentUnix,
          Math.floor(Date.now() / 1000)
        );
        let pendingMsg = null;
        for (let idx = baseMessages.length - 1; idx >= 0; idx -= 1) {{
          const candidate = baseMessages[idx];
          if (!candidate || typeof candidate !== "object") continue;
          const messageId = Number(messageIdOfChatPacket(candidate));
          if (!Number.isInteger(messageId) || messageId <= 0 || messageId !== pendingMessageId) continue;
          pendingMsg = candidate;
          break;
        }}
        if (pendingMsg) {{
          const deliveryState = normalizeDeliveryState(
            pendingMsg && (pendingMsg.delivery_state ?? pendingMsg.deliveryState)
          );
          const deliveryErrorRaw = String(
            (pendingMsg && (pendingMsg.delivery_error ?? pendingMsg.deliveryError)) || ""
          ).trim();
          const deliveryError = (typeof trimInlineError === "function")
            ? trimInlineError(deliveryErrorRaw, 96)
            : deliveryErrorRaw;
          const updateRawTime = String(
            (pendingMsg && (pendingMsg.delivery_updated_at || pendingMsg.rx_time || pendingMsg.captured_at)) || ""
          ).trim();
          const updateUnix = latestUnixTimestamp(
            pendingMsg && pendingMsg.delivery_updated_unix,
            pendingMsg && pendingMsg.delivery_updated_at,
            pendingMsg && pendingMsg.rx_time,
            pendingMsg && pendingMsg.captured_at
          );
          const updateTime = formatLocalChatTime(updateUnix, updateRawTime || "n/a", nowUnix);
          if (deliveryState === "acked") {{
            setChatSendStatus(`Delivered direct to ${{pendingDest}} on ${{pendingChannelLabel}} at ${{updateTime}}`);
            chatPendingDirectAck = null;
            return;
          }}
          if (deliveryState === "nak" || deliveryState === "timeout" || deliveryState === "error") {{
            const failPrefix = deliveryState === "timeout"
              ? "Direct timed out"
              : "Direct failed";
            setChatSendStatus(
              deliveryError
                ? `${{failPrefix}} to ${{pendingDest}} on ${{pendingChannelLabel}}: ${{deliveryError}}`
                : `${{failPrefix}} to ${{pendingDest}} on ${{pendingChannelLabel}}`,
              true
            );
            chatPendingDirectAck = null;
            return;
          }}
        }}
        if (isCanonicalNodeId(localNodeId)) {{
          for (let idx = baseMessages.length - 1; idx >= 0; idx -= 1) {{
            const msg = baseMessages[idx];
            if (!msg || typeof msg !== "object") continue;
            if (classifyMessageChannel(msg) !== "direct") continue;
            const endpoints = endpointsForMessage(msg);
            const fromId = normalizeNodeId(endpoints && endpoints.fromId);
            const toId = normalizeNodeId(endpoints && endpoints.toId);
            if (fromId !== pendingDest || toId !== localNodeId) continue;
            const peerReplyUnix = latestUnixTimestamp(msg && msg.rx_time, msg && msg.captured_at);
            if (peerReplyUnix <= 0 || peerReplyUnix < pendingSentUnix) continue;
            const replyTime = formatLocalChatTime(peerReplyUnix, "n/a", nowUnix);
            setChatSendStatus(`Direct to ${{pendingDest}} reached peer (reply seen at ${{replyTime}}).`);
            chatPendingDirectAck = null;
            return;
          }}
        }}
      }};
      syncPendingDirectAckStatus();
      const isKnownPeerNode = (peerIdRaw) => {{
        const peerId = normalizeNodeId(peerIdRaw || "");
        if (!isCanonicalNodeId(peerId)) return false;
        if (isCanonicalNodeId(localNodeId) && peerId === localNodeId) return false;
        if (manualDirectPeerIds.has(peerId)) return true;
        if (nodesById.has(peerId)) return true;
        if (isSelectableNodeId(selectedNodeId) && normalizeNodeId(selectedNodeId) === peerId) return true;
        if (isCanonicalNodeId(chatDirectActivePeerId) && normalizeNodeId(chatDirectActivePeerId) === peerId) return true;
        return false;
      }};
      const directBucketForPeer = (peerIdRaw) => {{
        const peerId = normalizeNodeId(peerIdRaw || "");
        const bucketRaw = directMessagesByPeer.get(peerId);
        return Array.isArray(bucketRaw) ? bucketRaw : [];
      }};
      const isPinnedDirectPeerVisible = (peerIdRaw) => {{
        const peerId = normalizeNodeId(peerIdRaw || "");
        if (!isKnownPeerNode(peerId)) return false;
        if (directBucketForPeer(peerId).length > 0) return true;
        if (activeChatChannel === "direct" && isSelectableNodeId(selectedNodeId) && normalizeNodeId(selectedNodeId) === peerId) {{
          return true;
        }}
        if (isCanonicalNodeId(peerDmActivePeerId) && normalizeNodeId(peerDmActivePeerId) === peerId) {{
          return true;
        }}
        return false;
      }};
      const directConversationPeerIds = new Set();
      for (const peerIdRaw of directMessagesByPeer.keys()) {{
        const peerId = normalizeNodeId(peerIdRaw || "");
        if (!isPinnedDirectPeerVisible(peerId)) continue;
        directConversationPeerIds.add(peerId);
      }}
      for (const peerIdRaw of manualDirectPeerIds) {{
        const peerId = normalizeNodeId(peerIdRaw || "");
        if (!isPinnedDirectPeerVisible(peerId)) continue;
        directConversationPeerIds.add(peerId);
      }}
      if (isCanonicalNodeId(chatDirectActivePeerId)) {{
        const activePeer = normalizeNodeId(chatDirectActivePeerId);
        if (isPinnedDirectPeerVisible(activePeer)) {{
          directConversationPeerIds.add(activePeer);
        }}
      }}
      const unreadDirectByPeer = new Map();
      const directAckSet = chatChangeAcknowledgedKeySetForChannel("direct");
      for (const notice of chatChangeNoticesForChannel("direct")) {{
        const noticeKey = String((notice && notice.key) || "").trim();
        if (directAckSet instanceof Set && noticeKey && directAckSet.has(noticeKey)) continue;
        const peerId = normalizeNodeId(notice && notice.peerNodeId);
        if (!directConversationPeerIds.has(peerId)) continue;
        if (directBucketForPeer(peerId).length <= 0) continue;
        unreadDirectByPeer.set(peerId, (unreadDirectByPeer.get(peerId) || 0) + 1);
      }}
      const directConversationRows = Array.from(directConversationPeerIds)
        .map((peerId) => {{
          const bucket = directBucketForPeer(peerId);
          const lastMsg = bucket.length > 0 ? bucket[bucket.length - 1] : null;
          const lastUnix = lastMsg
            ? latestUnixTimestamp(lastMsg && lastMsg.rx_time, lastMsg && lastMsg.captured_at)
            : 0;
          const lastRaw = lastMsg
            ? String((lastMsg && (lastMsg.rx_time || lastMsg.captured_at)) || "").trim()
            : "";
          const endpoints = lastMsg ? endpointsForMessage(lastMsg) : {{ fromId: "", toId: "" }};
          const fromId = normalizeNodeId(endpoints && endpoints.fromId);
          const isOwnLast = isCanonicalNodeId(localNodeId) && fromId === localNodeId;
          const textPreview = lastMsg
            ? compactInlineMessage(lastMsg && lastMsg.text, 72)
            : "";
          const emojiPreview = lastMsg ? String(emojiOf(lastMsg) || "").trim() : "";
          const previewCore = textPreview || emojiPreview || "No direct messages yet.";
          const preview = isOwnLast ? `You: ${{previewCore}}` : previewCore;
          const node = nodesById.get(peerId);
          const name = preferredNodeName(node) || nodeNameCache.get(peerId) || peerId;
          const unread = Math.max(0, Number(unreadDirectByPeer.get(peerId) || 0));
          return {{
            id: peerId,
            name,
            preview,
            unread,
            lastUnix: Number.isFinite(lastUnix) ? lastUnix : 0,
            lastRaw,
          }};
        }})
        .sort((a, b) => {{
          const unreadDiff = Number(b.unread || 0) - Number(a.unread || 0);
          if (unreadDiff !== 0) return unreadDiff;
          const timeDiff = Number(b.lastUnix || 0) - Number(a.lastUnix || 0);
          if (timeDiff !== 0) return timeDiff;
          return String(a.name || a.id).localeCompare(String(b.name || b.id));
        }});
      const directUnreadTotal = directConversationRows.reduce(
        (sum, row) => sum + Math.max(0, Number(row.unread || 0)),
        0
      );
      updatePeerDmBadge(directUnreadTotal);
      const peerDmMenuList = document.getElementById("peer-dm-menu-list");
      if (peerDmMenuList instanceof HTMLElement) {{
        peerDmMenuList.innerHTML = directConversationRows.length > 0
          ? directConversationRows.map((row) => {{
              const lastSeenText = row.lastUnix > 0
                ? formatLocalChatTime(row.lastUnix, row.lastRaw || "n/a", nowUnix)
                : "no traffic";
              const unreadChip = row.unread > 0
                ? `<span class="peer-dm-menu-unread" title="${{row.unread}} unread">${{row.unread > 99 ? "99+" : row.unread}}</span>`
                : "";
              const activeClass = normalizeNodeId(peerDmActivePeerId || "") === row.id ? " is-active" : "";
              return `<button type="button" class="peer-dm-menu-item${{activeClass}}" data-peer-node-id="${{escAttr(row.id)}}" title="${{escAttr(`${{row.name}} (${{row.id}})` )}}">
                <span class="peer-dm-menu-item-main">
                  <span class="peer-dm-menu-peer">${{escAttr(row.name)}}</span>
                  <span class="peer-dm-menu-preview">${{escAttr(row.preview)}}</span>
                </span>
                <span class="peer-dm-menu-meta">
                  <span>${{escAttr(lastSeenText)}}</span>
                  ${{unreadChip}}
                </span>
              </button>`;
            }}).join("")
          : '<div class="peer-dm-menu-empty">No peer-to-peer conversations yet.</div>';
      }}
      const peerDmHost = document.getElementById("peer-dm-popout-host");
      let activePopoutPeerId = normalizeNodeId(peerDmActivePeerId || "");
      const activePopoutBucketRaw = directMessagesByPeer.get(activePopoutPeerId);
      const activePopoutHasMessages = (
        Array.isArray(activePopoutBucketRaw)
        && activePopoutBucketRaw.length > 0
      );
      const activePopoutIsKnownPeer = isKnownPeerNode(activePopoutPeerId);
      if (
        !isCanonicalNodeId(activePopoutPeerId)
        || (
          !activePopoutIsKnownPeer
          && !directConversationPeerIds.has(activePopoutPeerId)
          && !activePopoutHasMessages
        )
      ) {{
        activePopoutPeerId = "";
        peerDmActivePeerId = "";
      }}
      if (peerDmHost instanceof HTMLElement) {{
        if (!isCanonicalNodeId(activePopoutPeerId)) {{
          peerDmHost.innerHTML = "";
        }} else {{
          const popoutNode = nodesById.get(activePopoutPeerId);
          const popoutName = preferredNodeName(popoutNode) || nodeNameCache.get(activePopoutPeerId) || activePopoutPeerId;
          const popoutBucketRaw = directMessagesByPeer.get(activePopoutPeerId);
          const popoutBucket = Array.isArray(popoutBucketRaw) ? popoutBucketRaw : [];
          const popoutMessages = popoutBucket.length > chatFeedMaxEntries
            ? popoutBucket.slice(-chatFeedMaxEntries)
            : popoutBucket;
          const popoutDraft = String(peerDmDraftByPeer.get(activePopoutPeerId) || "");
          const popoutFileState = summarizePeerDmFileTransferState(activePopoutPeerId);
          const popoutFilePercent = popoutFileState
            ? Math.max(0, Math.min(100, Math.round(Number(popoutFileState.percent) || 0)))
            : 0;
          const popoutFileText = popoutFileState
            ? String(popoutFileState.text || "").trim()
            : "";
          const popoutFilePhase = popoutFileState ? String(popoutFileState.phase || "").trim().toLowerCase() : "";
          const popoutFileLabel = popoutFileState && popoutFileState.fileName
            ? normalizeFileTransferName(popoutFileState.fileName)
            : "";
          const popoutFileProgressTitle = popoutFileLabel
            ? `File transfer: ${{popoutFileLabel}}`
            : "File transfer";
          const popoutThreadChannelIndex = (() => {{
            for (let idx = popoutBucket.length - 1; idx >= 0; idx -= 1) {{
              const candidate = popoutBucket[idx];
              if (!candidate || typeof candidate !== "object") continue;
              const explicitIdx = (typeof explicitMessageMeshChannelIndex === "function")
                ? explicitMessageMeshChannelIndex(candidate)
                : null;
              if (Number.isInteger(explicitIdx) && explicitIdx >= 0) {{
                return Math.trunc(explicitIdx);
              }}
            }}
            const sendCtx = meshChannelSendContext();
            return normalizeMeshChannelIndex(sendCtx && sendCtx.sendIndex);
          }})();
          const popoutThreadChannelLabel = meshChannelLabelForIndex(
            popoutThreadChannelIndex,
            {{ compact: true, allowAll: false }}
          );
          const popoutThreadChannelMeta = meshChannelColorMeta(popoutThreadChannelIndex, {{ allowAll: false }});
          const popoutThreadChannelStyle = `--peer-dm-channel-fill: ${{popoutThreadChannelMeta.fill}}; --peer-dm-channel-rgb: ${{hexColorRgbTriplet(popoutThreadChannelMeta.fill)}};`;
          const popoutMessageRows = popoutMessages.length > 0
            ? popoutMessages.map((msg) => {{
                const endpoints = endpointsForMessage(msg);
                const fromId = normalizeNodeId(endpoints && endpoints.fromId);
                const isOwn = isCanonicalNodeId(localNodeId) && fromId === localNodeId;
                const fromMeta = chatEndpointParts(fromId, latestUnixTimestamp(msg && msg.rx_time, msg && msg.captured_at));
                const fromLabel = isOwn ? "You" : (fromMeta.label || fromId || "Peer");
                const rawTime = String((msg && (msg.rx_time || msg.captured_at)) || "").trim();
                const msgUnix = latestUnixTimestamp(msg && msg.rx_time, msg && msg.captured_at);
                const timeLabel = formatLocalChatTime(msgUnix, rawTime || "n/a", nowUnix);
                const isLocalEcho = msg && (msg.local_echo === true || msg.localEcho === true);
                const deliveryState = normalizeDeliveryState(msg && (msg.delivery_state ?? msg.deliveryState));
                const deliveryError = String((msg && (msg.delivery_error ?? msg.deliveryError)) || "").trim();
                const compactDeliveryError = (typeof trimInlineError === "function")
                  ? trimInlineError(deliveryError, 72)
                  : (deliveryError.length > 72 ? `${{deliveryError.slice(0, 69)}}...` : deliveryError);
                const deliverySuffix = (() => {{
                  if (!isOwn || !isLocalEcho) return "";
                  if (!deliveryState || deliveryState === "sent" || deliveryState === "acked") return "";
                  if (deliveryState === "pending") return " • awaiting ACK";
                  if (deliveryState === "nak") {{
                    return compactDeliveryError
                      ? ` • failed (${{compactDeliveryError}})`
                      : " • failed";
                  }}
                  if (deliveryState === "error") {{
                    return compactDeliveryError
                      ? ` • error (${{compactDeliveryError}})`
                      : " • error";
                  }}
                  return ` • ${{deliveryState}}`;
                }})();
                const textHtml = chatPlainTextToHtml((msg && msg.text) || "", true)
                  || escAttr(String(emojiOf(msg) || "").trim() || "(no text)");
                return `<div class="peer-dm-popout-msg${{isOwn ? " is-own" : ""}}">
                  <div class="peer-dm-popout-msg-meta"><span>${{escAttr(fromLabel)}}</span><span>${{escAttr(`${{timeLabel}}${{deliverySuffix}}`)}}</span></div>
                  <div class="peer-dm-popout-msg-text">${{textHtml}}</div>
                </div>`;
              }}).join("")
            : '<div class="peer-dm-popout-empty">No messages in this peer thread yet.</div>';
          peerDmHost.innerHTML = `<section
            class="peer-dm-popout-window"
            data-peer-node-id="${{escAttr(activePopoutPeerId)}}"
            data-peer-dm-channel-index="${{escAttr(popoutThreadChannelIndex)}}"
            style="${{escAttr(popoutThreadChannelStyle)}}"
          >
            <header class="peer-dm-popout-head">
              <div class="peer-dm-popout-title">
                <span class="peer-dm-popout-name">${{escAttr(popoutName)}}</span>
                <span class="peer-dm-popout-id-row">
                  <span class="peer-dm-popout-id">${{escAttr(activePopoutPeerId)}}</span>
                  <span class="peer-dm-popout-channel" title="Thread channel">${{escAttr(popoutThreadChannelLabel)}}</span>
                </span>
              </div>
              <div class="peer-dm-popout-actions">
                <button type="button" id="peer-dm-popout-open-main-btn" class="peer-dm-popout-btn" title="Focus this peer in the node list">Focus node</button>
                <button type="button" id="peer-dm-popout-close-btn" class="peer-dm-popout-btn" title="Close this peer window">&times;</button>
              </div>
            </header>
            <div id="peer-dm-popout-body" class="peer-dm-popout-body">${{popoutMessageRows}}</div>
            <div class="peer-dm-popout-composer">
              <input id="peer-dm-popout-input" class="peer-dm-popout-input" type="text" autocomplete="off" placeholder="Direct message to ${{escAttr(activePopoutPeerId)}}..." value="${{escAttr(popoutDraft)}}" />
              <button type="button" id="peer-dm-popout-send-btn" class="peer-dm-popout-send-btn"${{chatSendInFlight ? " disabled" : ""}}>Send</button>
              <div class="peer-dm-popout-file-row">
