          const popoutFileProgressPct = document.getElementById("peer-dm-popout-file-progress-pct");
          const popoutFileProgressFill = document.getElementById("peer-dm-popout-file-progress-fill");
          const popoutStatus = document.getElementById("peer-dm-popout-status");
          const setPopoutStatus = (text, isError = false) => {{
            if (!(popoutStatus instanceof HTMLElement)) return;
