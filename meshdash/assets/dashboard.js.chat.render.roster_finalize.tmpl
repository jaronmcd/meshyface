          actionButtons.push(`<button type="button" class="peer-dm-popout-btn" data-peer-dm-action="popout" title="${{escAttr(popoutActionTitle)}}">${{escAttr(popoutActionLabel)}}</button>`);
        }}
        if (showFocusAction) {{
          actionButtons.push(`<button type="button" class="peer-dm-popout-btn" data-peer-dm-action="focus"${{isPopout ? ' id="peer-dm-popout-open-main-btn"' : ""}} title="Focus this peer in the node list">Focus node</button>`);
        }}
        if (showCloseAction) {{
          actionButtons.push(`<button type="button" class="peer-dm-popout-btn" data-peer-dm-action="close"${{isPopout ? ' id="peer-dm-popout-close-btn"' : ""}} title="Close this peer window">&times;</button>`);
        }}
        const actionsHtml = actionButtons.length > 0
          ? `<div class="peer-dm-popout-actions">${{actionButtons.join("")}}</div>`
          : "";
        host.innerHTML = `<section
          class="peer-dm-popout-window${{isPopout ? "" : " is-embedded"}}"
          data-peer-node-id="${{escAttr(peerId)}}"
          data-peer-dm-channel-index="${{escAttr(threadChannelIndex)}}"
          style="${{escAttr(threadChannelStyle)}}"
        >
          <header class="peer-dm-popout-head">
            <div class="peer-dm-popout-title">
              <span class="peer-dm-popout-name">${{escAttr(peerName)}}</span>
              <span class="peer-dm-popout-id-row">
                <span class="peer-dm-popout-id">${{escAttr(peerId)}}</span>
                <span class="peer-dm-popout-channel" title="Thread channel">${{escAttr(threadChannelLabel)}}</span>
              </span>
            </div>
            ${{actionsHtml}}
          </header>
          <div class="peer-dm-popout-body" data-peer-dm-role="body"${{isPopout ? ' id="peer-dm-popout-body"' : ""}}>${{messageRows}}</div>
          <div class="peer-dm-popout-composer">
            <input
              class="peer-dm-popout-input"
              data-peer-dm-role="input"
              ${{isPopout ? 'id="peer-dm-popout-input"' : ""}}
              type="text"
              autocomplete="off"
              placeholder="Direct message to ${{escAttr(peerId)}}..."
              value="${{escAttr(draft)}}"
            />
            <button
              type="button"
              class="peer-dm-popout-send-btn"
              data-peer-dm-role="send"
              ${{isPopout ? 'id="peer-dm-popout-send-btn"' : ""}}
              ${{chatSendInFlight ? "disabled" : ""}}
            >Send</button>
            <div
              class="peer-dm-popout-file-progress${{fileState && fileState.isError ? " is-error" : ""}}${{filePhase === "delivered" ? " is-success" : ""}}"
              data-peer-dm-role="file-progress"
              ${{isPopout ? 'id="peer-dm-popout-file-progress"' : ""}}
              title="${{escAttr(fileProgressTitle)}}"
              ${{fileState ? "" : "hidden"}}
            >
              <div class="peer-dm-popout-file-progress-head">
                <span
                  class="peer-dm-popout-file-progress-text"
                  data-peer-dm-role="file-progress-text"
                  ${{isPopout ? 'id="peer-dm-popout-file-progress-text"' : ""}}
                >${{escAttr(fileText || "No file transfer activity yet.")}}</span>
                <span
                  class="peer-dm-popout-file-progress-pct"
                  data-peer-dm-role="file-progress-pct"
                  ${{isPopout ? 'id="peer-dm-popout-file-progress-pct"' : ""}}
                >${{escAttr(`${{filePercent}}%`)}}</span>
              </div>
              <div class="peer-dm-popout-file-progress-meter">
                <span
                  data-peer-dm-role="file-progress-fill"
                  ${{isPopout ? 'id="peer-dm-popout-file-progress-fill"' : ""}}
                  style="width:${{escAttr(String(filePercent))}}%;"
                ></span>
              </div>
            </div>
            <div
              class="peer-dm-popout-status"
              data-peer-dm-role="status"
              ${{isPopout ? 'id="peer-dm-popout-status"' : ""}}
              hidden
            ></div>
          </div>
        </section>`;

        const focusBtn = host.querySelector('[data-peer-dm-action="focus"]');
        if (focusBtn instanceof HTMLButtonElement) {{
          focusBtn.addEventListener("click", (ev) => {{
            ev.preventDefault();
            setPeerDmMenuOpen(false);
            applyLayoutView("chat", true);
            applyChatChannel("all", true);
            selectNode(peerId, true, false);
          }});
        }}
        const popoutBtn = host.querySelector('[data-peer-dm-action="popout"]');
        if (popoutBtn instanceof HTMLButtonElement) {{
          popoutBtn.addEventListener("click", (ev) => {{
            ev.preventDefault();
            const activePeerId = normalizeNodeId(peerDmActivePeerId || "");
            const activeForPeer = isCanonicalNodeId(activePeerId) && activePeerId === peerId;
            if (activeForPeer) {{
              if (typeof setPeerDmPopoutStatusDisplay === "function") {{
                setPeerDmPopoutStatusDisplay(peerId, "");
              }}
              peerDmActivePeerId = "";
              if (latestState) {{
                renderChat(latestState);
              }}
              window.requestAnimationFrame(() => {{
                const drawerInput = host.querySelector('[data-peer-dm-role="input"]');
                if (drawerInput instanceof HTMLInputElement) {{
                  drawerInput.focus({{ preventScroll: true }});
                }}
              }});
              return;
            }}
            peerDmActivePeerId = peerId;
            setPeerDmMenuOpen(false);
            if (latestState) {{
              renderChat(latestState);
            }}
            window.requestAnimationFrame(() => {{
              const popoutInput = document.getElementById("peer-dm-popout-input");
              if (!(popoutInput instanceof HTMLInputElement)) return;
              popoutInput.focus({{ preventScroll: true }});
              const tail = popoutInput.value.length;
              try {{
                popoutInput.setSelectionRange(tail, tail);
              }} catch (_err) {{
              }}
            }});
          }});
        }}
        const closeBtn = host.querySelector('[data-peer-dm-action="close"]');
        if (closeBtn instanceof HTMLButtonElement) {{
          closeBtn.addEventListener("click", (ev) => {{
            ev.preventDefault();
            if (isPopout && typeof setPeerDmPopoutStatusDisplay === "function") {{
              setPeerDmPopoutStatusDisplay(peerId, "");
            }}
            if (isPopout) {{
              peerDmActivePeerId = "";
            }}
            host.innerHTML = "";
          }});
        }}

        const input = host.querySelector('[data-peer-dm-role="input"]');
        const sendBtn = host.querySelector('[data-peer-dm-role="send"]');
        const fileProgress = host.querySelector('[data-peer-dm-role="file-progress"]');
        const fileProgressText = host.querySelector('[data-peer-dm-role="file-progress-text"]');
        const fileProgressPct = host.querySelector('[data-peer-dm-role="file-progress-pct"]');
        const fileProgressFill = host.querySelector('[data-peer-dm-role="file-progress-fill"]');
        const statusEl = host.querySelector('[data-peer-dm-role="status"]');
        const statusMaxAgeSecForState = (state) => {{
          const clean = normalizeDeliveryState(state);
          if (clean === "sent") return 12;
          if (clean === "acked") return 20;
          if (clean === "nak" || clean === "timeout" || clean === "error") return 30;
          return null;
        }};
        const statusStateStillFresh = (state, updateUnix) => {{
          const ttlSec = statusMaxAgeSecForState(state);
          if (!Number.isFinite(Number(ttlSec)) || ttlSec == null) return true;
          const stamp = Number(updateUnix);
          if (!Number.isFinite(stamp) || stamp <= 0) return false;
          return (nowUnix - stamp) <= ttlSec;
        }};
        const statusRemainingMs = (state, updateUnix) => {{
          const ttlSec = statusMaxAgeSecForState(state);
          if (!Number.isFinite(Number(ttlSec)) || ttlSec == null) return null;
          const stamp = Number(updateUnix);
          if (!Number.isFinite(stamp) || stamp <= 0) return 0;
          return Math.max(0, Math.round((ttlSec - Math.max(0, nowUnix - stamp)) * 1000));
        }};
        const setStatus = (text, isError = false, statusOptions = null) => {{
          const localOptions = statusOptions && typeof statusOptions === "object" ? statusOptions : {{}};
          if (isPopout && typeof setPeerDmPopoutStatusDisplay === "function") {{
            const handled = setPeerDmPopoutStatusDisplay(peerId, text, {{
              isError,
              ttlMs: localOptions.ttlMs,
              statusToken: localOptions.statusToken,
            }});
            if (handled) return;
          }}
          if (!(statusEl instanceof HTMLElement)) return;
          const label = String(text || "").trim();
          if (!label) {{
            statusEl.textContent = "";
            statusEl.classList.remove("is-error");
            statusEl.hidden = true;
            return;
          }}
          statusEl.textContent = label;
          statusEl.classList.toggle("is-error", !!isError);
          statusEl.hidden = false;
        }};
        const renderFileTransferState = () => {{
          const snapshot = summarizePeerDmFileTransferState(peerId);
          if (!(fileProgress instanceof HTMLElement)) return;
          if (!snapshot) {{
            fileProgress.hidden = true;
            fileProgress.classList.remove("is-error");
            fileProgress.classList.remove("is-success");
            if (fileProgressText instanceof HTMLElement) {{
              fileProgressText.textContent = "";
            }}
            if (fileProgressPct instanceof HTMLElement) {{
              fileProgressPct.textContent = "";
            }}
            if (fileProgressFill instanceof HTMLElement) {{
              fileProgressFill.style.width = "0%";
            }}
            return;
          }}
          const pct = Math.max(0, Math.min(100, Math.round(Number(snapshot.percent) || 0)));
          const text = String(snapshot.text || "").trim() || "File transfer active";
          const phase = String(snapshot.phase || "").trim().toLowerCase();
          fileProgress.hidden = false;
          fileProgress.classList.toggle("is-error", !!snapshot.isError);
          fileProgress.classList.toggle("is-success", phase === "delivered" && !snapshot.isError);
          const liveFileLabel = snapshot.fileName
            ? normalizeFileTransferName(snapshot.fileName)
            : "file transfer";
          fileProgress.title = `File transfer: ${{liveFileLabel}}`;
          if (fileProgressText instanceof HTMLElement) {{
            fileProgressText.textContent = text;
          }}
          if (fileProgressPct instanceof HTMLElement) {{
            fileProgressPct.textContent = `${{pct}}%`;
          }}
          if (fileProgressFill instanceof HTMLElement) {{
            fileProgressFill.style.width = `${{pct}}%`;
          }}
        }};
        const latestOwnDirectEcho = (() => {{
          for (let idx = bucket.length - 1; idx >= 0; idx -= 1) {{
            const msg = bucket[idx];
            if (!(msg && (msg.local_echo === true || msg.localEcho === true))) continue;
            const endpoints = endpointsForMessage(msg);
            const fromId = normalizeNodeId(endpoints && endpoints.fromId);
            const toId = normalizeNodeId(endpoints && endpoints.toId);
            if (isCanonicalNodeId(localNodeId) && fromId !== localNodeId) continue;
            if (isCanonicalNodeId(peerId) && toId !== peerId) continue;
            return msg;
          }}
          return null;
        }})();
        if (latestOwnDirectEcho) {{
          const deliveryState = normalizeDeliveryState(
            latestOwnDirectEcho && (latestOwnDirectEcho.delivery_state ?? latestOwnDirectEcho.deliveryState)
          );
          const deliveryErrorRaw = String(
            (latestOwnDirectEcho && (latestOwnDirectEcho.delivery_error ?? latestOwnDirectEcho.deliveryError)) || ""
          ).trim();
          const deliveryError = (typeof trimInlineError === "function")
            ? trimInlineError(deliveryErrorRaw, 92)
            : deliveryErrorRaw;
          const updateRawTime = String(
            (latestOwnDirectEcho && (latestOwnDirectEcho.delivery_updated_at || latestOwnDirectEcho.rx_time || latestOwnDirectEcho.captured_at)) || ""
          ).trim();
          const updateUnix = latestUnixTimestamp(
            latestOwnDirectEcho && latestOwnDirectEcho.delivery_updated_unix,
            latestOwnDirectEcho && latestOwnDirectEcho.delivery_updated_at,
            latestOwnDirectEcho && latestOwnDirectEcho.rx_time,
            latestOwnDirectEcho && latestOwnDirectEcho.captured_at
          );
          const updateTime = formatLocalChatTime(updateUnix, updateRawTime || "n/a", nowUnix);
          if (deliveryState === "pending") {{
            setStatus(`Awaiting ACK · ${{updateTime}}`);
          }} else if (deliveryState === "acked" && statusStateStillFresh(deliveryState, updateUnix)) {{
            setStatus(`Delivered · ${{updateTime}}`, false, {{
              ttlMs: statusRemainingMs(deliveryState, updateUnix),
              statusToken: `acked:${{updateUnix}}`,
            }});
          }} else if (
            (deliveryState === "nak" || deliveryState === "timeout" || deliveryState === "error")
            && statusStateStillFresh(deliveryState, updateUnix)
          ) {{
            const base = deliveryState === "timeout" ? "Delivery timeout" : "Delivery failed";
            setStatus(
              deliveryError ? `${{base}} · ${{deliveryError}}` : base,
              true,
              {{
                ttlMs: statusRemainingMs(deliveryState, updateUnix),
                statusToken: `${{deliveryState}}:${{updateUnix}}:${{deliveryError}}`,
              }}
            );
          }} else if (deliveryState === "sent" && statusStateStillFresh(deliveryState, updateUnix)) {{
            setStatus(`Sent · ${{updateTime}}`, false, {{
              ttlMs: statusRemainingMs(deliveryState, updateUnix),
              statusToken: `sent:${{updateUnix}}`,
            }});
          }} else {{
            setStatus("");
          }}
        }} else {{
          setStatus("");
        }}
        renderFileTransferState();

        const submitMessage = async () => {{
          if (!(input instanceof HTMLInputElement)) return;
          if (!isCanonicalNodeId(peerId)) return;
          if (chatSendInFlight) return;
          const text = String(input.value || "").trim();
          if (!text) return;
          setStatus("Sending...");
          const sendChannelIndex = normalizeMeshChannelIndex(threadChannelIndex);
          const sendChannelLabel = meshChannelLabelForIndex(
            sendChannelIndex,
            {{ compact: true, allowAll: false }}
          );
          const payload = await sendChatPayload(
            {{
              text,
              destination: peerId,
              channel_index: sendChannelIndex,
            }},
            null,
            {{
              statusFn: setStatus,
              showSendingStatus: false,
              showSuccessStatus: false,
              showErrorStatus: true,
            }}
          );
          if (!(payload && payload.ok)) return;
          peerDmDraftByPeer.delete(peerId);
          input.value = "";
          const awaitingAck = (
            payload.ack_requested === true
            && normalizeDeliveryState(payload.delivery_state) === "pending"
          );
          if (awaitingAck) {{
            setStatus(`Sent on ${{sendChannelLabel}} at ${{payload.sent_at || "now"}} (awaiting ACK)`);
          }} else {{
            setStatus(`Sent on ${{sendChannelLabel}} at ${{payload.sent_at || "now"}}`);
          }}
          if (latestState) {{
            renderChat(latestState);
          }}
        }};
        if (input instanceof HTMLInputElement) {{
          input.addEventListener("focus", acknowledgeUnreadThreadNotices);
          input.addEventListener("click", acknowledgeUnreadThreadNotices);
          input.addEventListener("input", () => {{
            const nextDraft = String(input.value || "");
            if (nextDraft.trim()) {{
              peerDmDraftByPeer.set(peerId, nextDraft);
            }} else {{
              peerDmDraftByPeer.delete(peerId);
            }}
          }});
          input.addEventListener("keydown", (ev) => {{
            if (ev.key !== "Enter" || ev.shiftKey) return;
            ev.preventDefault();
            void submitMessage();
          }});
          if (preserveInputFocus && priorPeerId === peerId) {{
            const valueLen = String(input.value || "").length;
            const nextSelectionStart = Number.isFinite(priorSelectionStart)
              ? Math.max(0, Math.min(valueLen, Math.trunc(Number(priorSelectionStart))))
              : valueLen;
            const nextSelectionEnd = Number.isFinite(priorSelectionEnd)
              ? Math.max(nextSelectionStart, Math.min(valueLen, Math.trunc(Number(priorSelectionEnd))))
              : nextSelectionStart;
            window.requestAnimationFrame(() => {{
              if (input.disabled) return;
              try {{
                input.focus({{ preventScroll: true }});
              }} catch (_err) {{
                input.focus();
              }}
              try {{
                input.setSelectionRange(nextSelectionStart, nextSelectionEnd);
              }} catch (_err) {{
              }}
            }});
          }}
        }}
        if (sendBtn instanceof HTMLButtonElement) {{
          sendBtn.addEventListener("click", (ev) => {{
            ev.preventDefault();
            void submitMessage();
          }});
        }}
        const bodyEl = host.querySelector('[data-peer-dm-role="body"]');
        if (bodyEl instanceof HTMLElement) {{
          scheduleBodyScroll(bodyEl, unreadFocusKeys);
        }}
      }};

      const peerDmHost = document.getElementById("peer-dm-popout-host");
      const priorPopoutWindow = document.querySelector("#peer-dm-popout-host .peer-dm-popout-window");
      const priorPopoutPeerId = normalizeNodeId(
        priorPopoutWindow instanceof HTMLElement
          ? (priorPopoutWindow.dataset.peerNodeId || "")
          : (peerDmActivePeerId || "")
      );
      let activePopoutPeerId = normalizeNodeId(peerDmActivePeerId || "");
      const activePopoutBucketRaw = directMessagesByPeer.get(activePopoutPeerId);
      const activePopoutHasMessages = (
        Array.isArray(activePopoutBucketRaw)
        && activePopoutBucketRaw.length > 0
      );
      const activePopoutIsKnownPeer = isKnownPeerNode(activePopoutPeerId);
      if (
        !isCanonicalNodeId(activePopoutPeerId)
        || (
          !activePopoutIsKnownPeer
          && !directConversationPeerIds.has(activePopoutPeerId)
          && !activePopoutHasMessages
        )
      ) {{
        if (typeof setPeerDmPopoutStatusDisplay === "function") {{
          setPeerDmPopoutStatusDisplay(priorPopoutPeerId || peerDmActivePeerId || "", "");
        }}
        activePopoutPeerId = "";
        peerDmActivePeerId = "";
      }}
      renderPeerDmThreadHost(peerDmHost, activePopoutPeerId, {{
        mode: "popout",
        showFocusAction: true,
        showCloseAction: true,
      }});

      const drawerMessagesHost = document.getElementById("chat-node-details-messages-host");
      const drawerMessagesActive = (
        drawerMessagesHost instanceof HTMLElement
        && typeof isChatNodeDetailsDrawerExpanded === "function"
        && isChatNodeDetailsDrawerExpanded()
        && normalizeChatNodeDetailsDrawerTab(chatNodeDetailsDrawerTab) === "messages"
      );
      if (drawerMessagesActive) {{
        renderPeerDmThreadHost(
          drawerMessagesHost,
          chatNodeDetailsDrawerTargetNodeId(selectedNodeId),
          {{
            mode: "drawer",
            showPopoutAction: true,
            unavailableMessage: "Direct messaging is unavailable for this node.",
          }}
        );
      }} else if (drawerMessagesHost instanceof HTMLElement) {{
        drawerMessagesHost.innerHTML = "";
      }}
      markRenderChatPhase("roster-render");
      renderChatNodeNavigatorList(state, {{
        nowUnix,
        rosterAll,
        nodesById,
        historyCapsById,
        unreadDirectByPeer,
        resolveChatNodeFreshnessFn: resolveChatNodeFreshness,
        packetTickerByNode,
        packetSparklineByNode,
      }});

      markRenderChatPhase("post-bind");
      renderChatReplyContext();
      bindChatAutoScroll();
      bindChatFeedClicks();
      bindChatReactionControls();
      bindChatRetryControls();
      bindChatChangeSummaryControls();
      syncChatChangeAutoDismiss();
      renderChatPeerAddPanel(state);
      highlightNodeSelection();
      syncChatNodeDetailsDrawer(state, {{
        fetchHistory: false,
      }});
      if (pendingSelectionScroll) {{
        scrollSelectionIntoView();
      }} else if (chatScroller instanceof HTMLElement && shouldStickBottom) {{
        requestAnimationFrame(() => {{
          chatScroller.scrollTop = chatScroller.scrollHeight;
          chatStickToBottom = true;
          syncChatChangeAutoDismiss();
        }});
      }}
      const chatRenderElapsedMs = (
        chatRenderStartMs > 0
        && typeof window.performance !== "undefined"
        && typeof window.performance.now === "function"
      ) ? Math.max(0, window.performance.now() - chatRenderStartMs) : 0;
      if (pollStructuralSignature) {{
        chatPollStructuralSignature = pollStructuralSignature;
        chatPollStructuralRenderedAtMs = Date.now();
      }}
      recordChatPerfSample(chatRenderElapsedMs, feedItems.length, rosterFiltered.length);

      if (typeof applyChatFeedSearchFilter === "function") {{
        applyChatFeedSearchFilter();
      }}
      }} catch (err) {{
        handleRenderChatFailure(err);
      }}
    }}
