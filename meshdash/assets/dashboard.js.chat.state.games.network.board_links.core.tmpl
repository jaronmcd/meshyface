            }};
          }},
        }};
      }}
      if (id === "wallchess") {{
        return {{
          id,
          protocolVersion: wallChessProtocolVersion,
          maxSeenMessages: wallChessMaxSeenNetworkMessages,
          defaultLocalColor: "white",
          defaultRemoteColor: "black",
          opponent: wallChessOpponent,
          playerLabel: wallChessPlayerLabel,
          getPeerId: () => wallChessPeerId,
          setPeerId: (value) => {{ wallChessPeerId = normalizeNodeId(value || ""); }},
          getHostColorPreference: () => wallChessHostColorPreference,
          setHostColorPreference: (value) => {{
            wallChessHostColorPreference = boardGameParseColor(value, "white");
          }},
          getPendingInvites: () => (Array.isArray(wallChessPendingInvites) ? wallChessPendingInvites : []),
          setPendingInvites: (rows) => {{
            wallChessPendingInvites = Array.isArray(rows) ? rows : [];
          }},
          getSelectedInviteKey: () => wallChessSelectedInviteKey,
          setSelectedInviteKey: (value) => {{
            wallChessSelectedInviteKey = String(value || "").trim().toLowerCase();
          }},
          getSeenKeys: () => wallChessSeenNetworkMessageKeys,
          getSeenOrder: () => wallChessSeenNetworkMessageOrder,
          setSeenOrder: (rows) => {{
            wallChessSeenNetworkMessageOrder = Array.isArray(rows) ? rows : [];
          }},
          getLink: () => wallChessLink,
          setLink: (value) => {{
            wallChessLink = value && typeof value === "object" ? value : {{
              mode: "local",
              role: "",
              session_id: "",
              peer_id: "",
              channel_index: 0,
              local_color: "white",
              remote_color: "black",
              local_move_seq: 0,
              remote_move_seq: 0,
              last_remote_ack_seq: 0,
              local_control_seq: 0,
              last_remote_control_ack_seq: 0,
              status: "Local hotseat mode.",
            }};
          }},
        }};
      }}
      return {{
        id: "checkers",
        protocolVersion: checkersProtocolVersion,
        maxSeenMessages: checkersMaxSeenNetworkMessages,
        defaultLocalColor: "black",
        defaultRemoteColor: "white",
        opponent: checkersOpponent,
        playerLabel: checkersPlayerLabel,
        getPeerId: () => checkersPeerId,
        setPeerId: (value) => {{ checkersPeerId = normalizeNodeId(value || ""); }},
        getHostColorPreference: () => checkersHostColorPreference,
        setHostColorPreference: (value) => {{
          checkersHostColorPreference = boardGameParseColor(value, "black");
        }},
        getPendingInvites: () => (Array.isArray(checkersPendingInvites) ? checkersPendingInvites : []),
        setPendingInvites: (rows) => {{
          checkersPendingInvites = Array.isArray(rows) ? rows : [];
        }},
        getSelectedInviteKey: () => checkersSelectedInviteKey,
        setSelectedInviteKey: (value) => {{
          checkersSelectedInviteKey = String(value || "").trim().toLowerCase();
        }},
        getSeenKeys: () => checkersSeenNetworkMessageKeys,
        getSeenOrder: () => checkersSeenNetworkMessageOrder,
        setSeenOrder: (rows) => {{
          checkersSeenNetworkMessageOrder = Array.isArray(rows) ? rows : [];
        }},
        getLink: () => checkersLink,
        setLink: (value) => {{
          checkersLink = value && typeof value === "object" ? value : {{
            mode: "local",
            role: "",
            session_id: "",
            peer_id: "",
            channel_index: 0,
            local_color: "black",
            remote_color: "white",
            local_move_seq: 0,
            remote_move_seq: 0,
            last_remote_ack_seq: 0,
            local_control_seq: 0,
            last_remote_control_ack_seq: 0,
            status: "Local hotseat mode.",
          }};
        }},
      }};
    }}

    function createBoardGameLinkState(gameId, overrides = {{}}) {{
      const refs = boardGameRefs(gameId);
      const mode = String(overrides.mode || "local").trim().toLowerCase();
      const role = String(overrides.role || "").trim().toLowerCase();
      const peerId = normalizeNodeId(overrides.peer_id ?? overrides.peerId ?? "");
      const channelIndexRaw = Number(overrides.channel_index ?? overrides.channelIndex);
      const channelIndex = Number.isInteger(channelIndexRaw) && channelIndexRaw >= 0
        ? channelIndexRaw
        : meshChannelEffectiveSendIndexForApp("games");
      const localColor = boardGameParseColor(overrides.local_color, refs.defaultLocalColor);
      const remoteColor = boardGameParseColor(overrides.remote_color, refs.defaultRemoteColor);
      return {{
        mode: mode === "connected" || mode === "pending_host" ? mode : "local",
        role: role === "host" || role === "guest" ? role : "",
        session_id: String(overrides.session_id ?? overrides.sessionId ?? "").trim().toLowerCase(),
        peer_id: isCanonicalNodeId(peerId) ? peerId : "",
        channel_index: channelIndex,
        local_color: localColor,
        remote_color: remoteColor,
        local_move_seq: Math.max(0, Math.trunc(Number(overrides.local_move_seq) || 0)),
        remote_move_seq: Math.max(0, Math.trunc(Number(overrides.remote_move_seq) || 0)),
        last_remote_ack_seq: Math.max(0, Math.trunc(Number(overrides.last_remote_ack_seq) || 0)),
        local_control_seq: Math.max(0, Math.trunc(Number(overrides.local_control_seq) || 0)),
        last_remote_control_ack_seq: Math.max(0, Math.trunc(Number(overrides.last_remote_control_ack_seq) || 0)),
        status: String(overrides.status || "Local hotseat mode.").trim().slice(0, 220) || "Local hotseat mode.",
      }};
    }}

    function boardGameUpdateLinkStatus(gameId, statusText) {{
      const refs = boardGameRefs(gameId);
      const current = refs.getLink();
      if (!current || typeof current !== "object") {{
        refs.setLink(createBoardGameLinkState(gameId));
      }}
      const next = refs.getLink();
      next.status = String(statusText || "").trim().slice(0, 220) || "Local hotseat mode.";
    }}

    function boardGameResetNetworkLink(
      gameId,
      statusText = "Local hotseat mode.",
      {{ keepPeer = true }} = {{}}
    ) {{
      const refs = boardGameRefs(gameId);
      const current = refs.getLink();
      const preservedPeer = keepPeer ? normalizeNodeId(current && current.peer_id) : "";
      refs.setLink(createBoardGameLinkState(gameId, {{
        status: statusText,
        peer_id: preservedPeer,
      }}));
      if (isCanonicalNodeId(preservedPeer)) {{
        refs.setPeerId(preservedPeer);
      }}
    }}

    function boardGameIsNetworkLinked(gameId) {{
      const refs = boardGameRefs(gameId);
      const link = refs.getLink();
      return !!(
        link
        && link.mode === "connected"
        && isCanonicalNodeId(link.peer_id)
        && String(link.session_id || "").trim()
      );
    }}

    function generateBoardGameSessionId(gameId) {{
      const normalizedGameId = boardGameNormalizeId(gameId);
      const prefix = normalizedGameId === "chess"
        ? "ch"
        : (normalizedGameId === "wallchess" ? "wc" : "ck");
      const now = Date.now().toString(36).slice(-4);
      const rand = Math.random().toString(36).slice(2, 8);
      return `${{prefix}}${{now}}${{rand}}`.slice(0, 10);
    }}

    const boardGameProtocolCellAlphabet = "0123456789abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ-_";

    function boardGameProtocolSanitizeField(value) {{
      return String(value == null ? "" : value).trim().replace(/\|/g, "");
    }}

    function boardGameProtocolEncodeInt(value) {{
      const num = Math.max(0, Math.trunc(Number(value) || 0));
      return num.toString(36);
    }}

    function boardGameProtocolDecodeInt(value) {{
      const token = String(value == null ? "" : value).trim().toLowerCase();
      if (!token) return 0;
      const parsed = Number.parseInt(token, 36);
      if (Number.isFinite(parsed) && parsed >= 0) return parsed;
      return Math.max(0, Math.trunc(Number(token) || 0));
    }}

    function boardGameProtocolParseCoordinate(value, fallback = -1) {{
      const parsed = Number(value);
      if (!Number.isFinite(parsed)) return Math.trunc(Number(fallback) || -1);
      return Math.trunc(parsed);
    }}

    function boardGameProtocolTypeCode(typeRaw) {{
      const clean = String(typeRaw || "").trim().toLowerCase();
      if (clean === "invite") return "i";
      if (clean === "accept") return "a";
      if (clean === "decline") return "d";
      if (clean === "leave") return "l";
      if (clean === "move") return "m";
      if (clean === "ack") return "k";
      if (clean === "chat") return "t";
      return "";
    }}

    function boardGameProtocolTypeFromCode(codeRaw) {{
      const code = String(codeRaw || "").trim().toLowerCase();
      if (code === "i") return "invite";
      if (code === "a") return "accept";
      if (code === "d") return "decline";
      if (code === "l") return "leave";
      if (code === "m") return "move";
      if (code === "k") return "ack";
      if (code === "t") return "chat";
      return "";
    }}

    function boardGameProtocolControlCode(typeRaw) {{
      const clean = String(typeRaw || "").trim().toLowerCase();
      if (clean === "invite") return "i";
      if (clean === "accept") return "a";
      if (clean === "decline") return "d";
      if (clean === "leave") return "l";
      return "";
    }}

    function boardGameProtocolControlFromCode(codeRaw) {{
      const code = String(codeRaw || "").trim().toLowerCase();
      if (code === "i") return "invite";
      if (code === "a") return "accept";
      if (code === "d") return "decline";
      if (code === "l") return "leave";
      return "";
    }}

    function boardGameProtocolEncodeCell(gameId, rowRaw, colRaw) {{
      const row = Math.trunc(Number(rowRaw) || 0);
      const col = Math.trunc(Number(colRaw) || 0);
      const inBounds = boardGameNormalizeId(gameId) === "chess"
        ? chessInBounds(row, col)
        : checkersInBounds(row, col);
      if (!inBounds) return "";
      const idx = (row * 8) + col;
      return boardGameProtocolCellAlphabet[idx] || "";
    }}

    function boardGameProtocolDecodeCell(tokenRaw) {{
      const token = String(tokenRaw == null ? "" : tokenRaw).trim().slice(0, 1);
      if (!token) return null;
      const idx = boardGameProtocolCellAlphabet.indexOf(token);
      if (idx < 0 || idx >= 64) return null;
      return [Math.trunc(idx / 8), idx % 8];
    }}

    function encodeBoardGameProtocolMessage(gameId, type, ...fields) {{
      const refs = boardGameRefs(gameId);
      const cleanType = String(type || "").trim().toLowerCase();
      const typeCode = boardGameProtocolTypeCode(cleanType);
      if (!typeCode) return "";
      if (cleanType === "invite") {{
        const sessionId = boardGameProtocolSanitizeField(fields[0]);
        const hostColor = boardGameParseColor(fields[2], refs.defaultLocalColor) === "white" ? "w" : "b";
        const seq = boardGameProtocolEncodeInt(fields[4]);
        return [refs.protocolVersion, typeCode, sessionId, hostColor, seq].join("|");
      }}
      if (cleanType === "accept" || cleanType === "decline" || cleanType === "leave") {{
        const sessionId = boardGameProtocolSanitizeField(fields[0]);
        const seq = boardGameProtocolEncodeInt(fields[1]);
        return [refs.protocolVersion, typeCode, sessionId, seq].join("|");
      }}
      if (cleanType === "move") {{
        const sessionId = boardGameProtocolSanitizeField(fields[0]);
        const seq = boardGameProtocolEncodeInt(fields[1]);
        if (boardGameNormalizeId(gameId) === "wallchess") {{
          const moveKind = String(fields[2] || "").trim().toLowerCase();
          if (moveKind === "pawn") {{
            return [
              refs.protocolVersion,
              typeCode,
              sessionId,
              seq,
              "p",
              boardGameProtocolEncodeInt(fields[3]),
              boardGameProtocolEncodeInt(fields[4]),
              boardGameProtocolEncodeInt(fields[5]),
              boardGameProtocolEncodeInt(fields[6]),
            ].join("|");
          }}
          if (moveKind === "wall") {{
            const orientation = String(fields[3] || "").trim().toLowerCase() === "v" ? "v" : "h";
            return [
              refs.protocolVersion,
              typeCode,
              sessionId,
              seq,
              "w",
              orientation,
              boardGameProtocolEncodeInt(fields[4]),
              boardGameProtocolEncodeInt(fields[5]),
            ].join("|");
          }}
          return "";
        }}
        const fromCell = boardGameProtocolEncodeCell(gameId, fields[2], fields[3]);
        const toCell = boardGameProtocolEncodeCell(gameId, fields[4], fields[5]);
        if (!sessionId || !fromCell || !toCell) return "";
        return [refs.protocolVersion, typeCode, sessionId, seq, fromCell, toCell].join("|");
      }}
      if (cleanType === "chat") {{
        const sessionId = boardGameProtocolSanitizeField(fields[0]);
        const sentUnix = boardGameProtocolEncodeInt(fields[1]);
        const text = boardGameProtocolSanitizeField(fields[2]);
        if (!sessionId || !text) return "";
        return [refs.protocolVersion, typeCode, sessionId, sentUnix, text].join("|");
      }}
      if (cleanType === "ack") {{
        const sessionId = boardGameProtocolSanitizeField(fields[0]);
        const ackKindRaw = String(fields[1] || "").trim().toLowerCase();
        if (ackKindRaw === "move") {{
          const seq = boardGameProtocolEncodeInt(fields[2]);
          return [refs.protocolVersion, typeCode, sessionId, "m", seq].join("|");
        }}
        if (ackKindRaw === "control") {{
          const controlCode = boardGameProtocolControlCode(fields[2]);
          const seq = boardGameProtocolEncodeInt(fields[3]);
          if (!controlCode) return "";
          return [refs.protocolVersion, typeCode, sessionId, "c", controlCode, seq].join("|");
        }}
        return "";
      }}
      return "";
    }}

    function parseBoardGameProtocolMessage(gameId, text) {{
      const refs = boardGameRefs(gameId);
      const raw = String(text || "").trim();
      if (!raw) return null;
      if (!raw.startsWith(`${{refs.protocolVersion}}|`)) return null;
      const parts = raw.split("|").map((part) => String(part || "").trim());
      if (parts.length < 2) return null;
      const type = boardGameProtocolTypeFromCode(parts[1]);
      if (!type) return null;
      if (type === "invite") {{
        const sessionId = boardGameProtocolSanitizeField(parts[2]);
        if (!sessionId) return null;
        const hostColor = boardGameParseColor(parts[3], refs.defaultLocalColor);
        const controlSeq = boardGameProtocolDecodeInt(parts[4]);
        return {{
          raw,
          type,
          parts: [refs.protocolVersion, "invite", sessionId, "", hostColor, "", String(controlSeq)],
        }};
      }}
      if (type === "accept" || type === "decline" || type === "leave") {{
        const sessionId = boardGameProtocolSanitizeField(parts[2]);
        if (!sessionId) return null;
        const controlSeq = boardGameProtocolDecodeInt(parts[3]);
        return {{
          raw,
          type,
          parts: [refs.protocolVersion, type, sessionId, String(controlSeq)],
        }};
      }}
      if (type === "move") {{
        const sessionId = boardGameProtocolSanitizeField(parts[2]);
        const seq = boardGameProtocolDecodeInt(parts[3]);
        if (boardGameNormalizeId(gameId) === "wallchess") {{
          const moveKind = String(parts[4] || "").trim().toLowerCase();
          if (moveKind === "p") {{
            return {{
              raw,
              type,
              parts: [
                refs.protocolVersion,
                "move",
                sessionId,
                String(seq),
                "pawn",
                String(boardGameProtocolDecodeInt(parts[5])),
                String(boardGameProtocolDecodeInt(parts[6])),
                String(boardGameProtocolDecodeInt(parts[7])),
                String(boardGameProtocolDecodeInt(parts[8])),
              ],
            }};
          }}
          if (moveKind === "w") {{
            return {{
              raw,
              type,
              parts: [
                refs.protocolVersion,
                "move",
                sessionId,
                String(seq),
                "wall",
                String(parts[5] || "").trim().toLowerCase() === "v" ? "v" : "h",
                String(boardGameProtocolDecodeInt(parts[6])),
                String(boardGameProtocolDecodeInt(parts[7])),
              ],
            }};
          }}
          return null;
        }}
        const fromCell = boardGameProtocolDecodeCell(parts[4]);
        const toCell = boardGameProtocolDecodeCell(parts[5]);
        if (!sessionId || seq <= 0 || !Array.isArray(fromCell) || !Array.isArray(toCell)) return null;
        return {{
          raw,
          type,
          parts: [
            refs.protocolVersion,
            "move",
            sessionId,
            String(seq),
            String(fromCell[0]),
            String(fromCell[1]),
            String(toCell[0]),
            String(toCell[1]),
          ],
        }};
      }}
      if (type === "chat") {{
        const sessionId = boardGameProtocolSanitizeField(parts[2]);
        const sentUnix = boardGameProtocolDecodeInt(parts[3]);
        const chatText = boardGameProtocolSanitizeField(parts[4]);
        if (!sessionId || !chatText) return null;
        return {{
          raw,
          type,
          parts: [refs.protocolVersion, "chat", sessionId, String(sentUnix), chatText],
        }};
      }}
      if (type === "ack") {{
        const sessionId = boardGameProtocolSanitizeField(parts[2]);
        if (!sessionId) return null;
        const ackKind = String(parts[3] || "").trim().toLowerCase();
        if (ackKind === "m") {{
          const seq = boardGameProtocolDecodeInt(parts[4]);
          if (seq <= 0) return null;
          return {{
            raw,
            type,
            parts: [refs.protocolVersion, "ack", sessionId, "move", String(seq)],
          }};
        }}
        if (ackKind === "c") {{
          const controlType = boardGameProtocolControlFromCode(parts[4]);
          const seq = boardGameProtocolDecodeInt(parts[5]);
          if (!controlType || seq <= 0) return null;
          return {{
            raw,
            type,
            parts: [refs.protocolVersion, "ack", sessionId, "control", controlType, String(seq)],
          }};
        }}
        return null;
      }}
      return null;
    }}

    function rememberBoardGameNetworkMessage(gameId, key) {{
      const refs = boardGameRefs(gameId);
      const clean = String(key || "").trim();
      if (!clean) return false;
      const seenKeys = refs.getSeenKeys();
      if (seenKeys.has(clean)) return false;
      seenKeys.add(clean);
      const order = refs.getSeenOrder();
      order.push(clean);
      if (order.length > refs.maxSeenMessages) {{
        while (order.length > Math.floor(refs.maxSeenMessages * 0.72)) {{
          const stale = order.shift();
          if (stale) seenKeys.delete(stale);
        }}
      }}
      refs.setSeenOrder(order);
      return true;
    }}

    function boardGameInviteKey(fromId, sessionId) {{
      return `${{normalizeNodeId(fromId)}}|${{String(sessionId || "").trim().toLowerCase()}}`;
    }}

    function registerBoardGamePendingInvite(
      gameId,
      {{
        from_id = "",
        session_id = "",
        received_unix = Math.floor(Date.now() / 1000),
        host_color = "black",
        channel_index = 0,
      }} = {{}}
    ) {{
      const refs = boardGameRefs(gameId);
      const fromId = normalizeNodeId(from_id);
      const sessionId = String(session_id || "").trim().toLowerCase();
      if (!isCanonicalNodeId(fromId) || !sessionId) return;
      const hostColor = boardGameParseColor(host_color, refs.defaultLocalColor);
      const channelIndexRaw = Number(channel_index);
      const channelIndex = Number.isInteger(channelIndexRaw) && channelIndexRaw >= 0 ? channelIndexRaw : 0;
      const targetKey = boardGameInviteKey(fromId, sessionId);
      const nextRows = [];
      for (const row of refs.getPendingInvites()) {{
        if (!row || typeof row !== "object") continue;
        const rowFrom = normalizeNodeId(row.from_id || row.fromId || "");
        const rowSession = String(row.session_id || row.sessionId || "").trim().toLowerCase();
        if (!isCanonicalNodeId(rowFrom) || !rowSession) continue;
        if (rowFrom === fromId) {{
          // Keep only the newest invite per peer so reconnect attempts don't
          // accidentally target stale sessions.
          continue;
        }}
        nextRows.push({{
          from_id: rowFrom,
          session_id: rowSession,
          received_unix: Math.max(0, Math.trunc(Number(row.received_unix ?? row.receivedUnix) || 0)),
          host_color: boardGameParseColor(row.host_color ?? row.hostColor, refs.defaultLocalColor),
          channel_index: (Number.isInteger(Number(row.channel_index ?? row.channelIndex)) && Number(row.channel_index ?? row.channelIndex) >= 0)
            ? Number(row.channel_index ?? row.channelIndex)
            : 0,
        }});
      }}
      nextRows.push({{
        from_id: fromId,
        session_id: sessionId,
        received_unix: Math.max(0, Math.trunc(Number(received_unix) || 0)),
        host_color: hostColor,
        channel_index: channelIndex,
      }});
      const nowUnix = Math.floor(Date.now() / 1000);
      nextRows.sort((a, b) => (Number(b.received_unix) || 0) - (Number(a.received_unix) || 0));
      const filtered = nextRows
        .filter((row) => (nowUnix - (Number(row.received_unix) || 0)) <= reversiInviteStaleSeconds)
        .slice(0, reversiInviteMaxRows);
      refs.setPendingInvites(filtered);
      if (!isCanonicalNodeId(refs.getPeerId())) {{
        refs.setPeerId(fromId);
      }}
      refs.setSelectedInviteKey(targetKey);
    }}

    function removeBoardGamePendingInvite(gameId, fromId, sessionId = "") {{
      const refs = boardGameRefs(gameId);
      const cleanFrom = normalizeNodeId(fromId);
      const cleanSession = String(sessionId || "").trim().toLowerCase();
      const next = refs.getPendingInvites().filter((row) => {{
        if (!row || typeof row !== "object") return false;
        const rowFrom = normalizeNodeId(row.from_id || row.fromId || "");
        const rowSession = String(row.session_id || row.sessionId || "").trim().toLowerCase();
        if (!isCanonicalNodeId(rowFrom) || !rowSession) return false;
        if (rowFrom !== cleanFrom) return true;
        if (!cleanSession) return false;
        return rowSession !== cleanSession;
      }});
      refs.setPendingInvites(next);
      if (refs.getSelectedInviteKey() && !next.some((row) => boardGameInviteKey(row && row.from_id, row && row.session_id) === refs.getSelectedInviteKey())) {{
        refs.setSelectedInviteKey("");
      }}
    }}

    function removeAllBoardGamePendingInvitesFromPeer(gameId, fromId) {{
      const cleanFrom = normalizeNodeId(fromId);
      if (!isCanonicalNodeId(cleanFrom)) return;
      removeBoardGamePendingInvite(gameId, cleanFrom, "");
    }}

    function boardGamePendingInviteChoice(gameId) {{
      const refs = boardGameRefs(gameId);
      const rows = refs.getPendingInvites();
      if (rows.length < 1) return null;
      const selectedInvite = String(refs.getSelectedInviteKey() || "").trim().toLowerCase();
      if (selectedInvite) {{
        const exact = rows.find((row) => boardGameInviteKey(row && row.from_id, row && row.session_id) === selectedInvite);
        if (exact) return exact;
      }}
      const selectedPeer = normalizeNodeId(refs.getPeerId());
      if (isCanonicalNodeId(selectedPeer)) {{
        const preferred = rows.find((row) => normalizeNodeId(row && row.from_id) === selectedPeer);
        if (preferred) return preferred;
      }}
      return rows[0] || null;
    }}

    async function sendBoardGameProtocolMessage(
      gameId,
      type,
      fields = [],
      {{
        destination_id = "",
        channel_index = null,
      }} = {{}}
    ) {{
      const destinationId = normalizeNodeId(destination_id);
      const label = boardGameLabel(gameId);
      if (!isCanonicalNodeId(destinationId)) {{
        boardGameUpdateLinkStatus(gameId, "Pick a valid peer node ID first.");
        return false;
      }}
      const encoded = encodeBoardGameProtocolMessage(gameId, type, ...(Array.isArray(fields) ? fields : []));
      if (!encoded) {{
        boardGameUpdateLinkStatus(gameId, `Could not encode ${{label}} network payload.`);
        return false;
      }}
      const channelIndex = normalizeMeshChannelIndex(
        channel_index == null ? meshChannelEffectiveSendIndexForApp("games") : channel_index
      );
      const payload = await sendChatPayload(
        {{
          text: encoded,
          destination: destinationId,
          channel_index: channelIndex,
        }},
        null
      );
      if (!payload || payload.ok !== true) {{
        boardGameUpdateLinkStatus(gameId, `Failed to send ${{label}} network payload.`);
        return false;
      }}
      return true;
    }}

    function boardGameProtocolMessageKey(gameId, msg, parsed) {{
      const messageId = messageIdOfChatPacket(msg);
      if (messageId) return `${{boardGameNormalizeId(gameId)}}:msg:${{messageId}}`;
      const fromId = protocolMessageFromNodeId(msg);
      const toId = protocolMessageToNodeId(msg);
      return [
        boardGameNormalizeId(gameId),
        "raw",
        fromId,
        toId,
        String(protocolMessageUnix(msg) || ""),
        String(parsed && parsed.raw || ""),
      ].join("|");
    }}

    function boardGameLocalColor(gameId) {{
      const refs = boardGameRefs(gameId);
      return boardGameParseColor(refs.getLink() && refs.getLink().local_color, refs.defaultLocalColor);
    }}

    function boardGameRemoteColor(gameId) {{
      const refs = boardGameRefs(gameId);
      return boardGameParseColor(refs.getLink() && refs.getLink().remote_color, refs.defaultRemoteColor);
    }}

    function boardGameLocalParticipantName(gameId, state = latestState) {{
      const safeState = state && typeof state === "object" ? state : latestState;
      const localNodeId = normalizeNodeId(resolveLocalNodeId(safeState) || "");
      if (isCanonicalNodeId(localNodeId)) {{
        return reversiNodeLabel(localNodeId, safeState);
      }}
      return "Local Radio";
    }}

    function boardGameRemoteParticipantName(gameId, state = latestState) {{
      const refs = boardGameRefs(gameId);
      const safeState = state && typeof state === "object" ? state : latestState;
      const peerNodeId = normalizeNodeId((refs.getLink() && refs.getLink().peer_id) || refs.getPeerId() || "");
      if (isCanonicalNodeId(peerNodeId)) {{
        return reversiNodeLabel(peerNodeId, safeState);
      }}
      return "Remote Player";
    }}

    function startBoardGameLocalState(gameId) {{
      const id = boardGameNormalizeId(gameId);
