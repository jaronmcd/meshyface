          }},
          getSeenKeys: () => chessSeenNetworkMessageKeys,
          getSeenOrder: () => chessSeenNetworkMessageOrder,
          setSeenOrder: (rows) => {{
            chessSeenNetworkMessageOrder = Array.isArray(rows) ? rows : [];
          }},
          getLink: () => chessLink,
          setLink: (value) => {{
            chessLink = value && typeof value === "object" ? value : {{
              mode: "local",
              role: "",
              session_id: "",
              peer_id: "",
              channel_index: 0,
              local_color: "white",
              remote_color: "black",
              local_move_seq: 0,
              remote_move_seq: 0,
              last_remote_ack_seq: 0,
              local_control_seq: 0,
              last_remote_control_ack_seq: 0,
