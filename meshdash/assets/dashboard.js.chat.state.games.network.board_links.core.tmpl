    function boardGameNormalizeId(value) {{
      const token = String(value || "").trim().toLowerCase();
      if (token === "chess") return "chess";
      if (token === "wallchess") return "wallchess";
      return "checkers";
    }}

    function boardGameLabel(gameId) {{
      const id = boardGameNormalizeId(gameId);
      if (id === "chess") return "Chess";
      if (id === "wallchess") return "Wall Chess";
      return "Checkers";
    }}

    function boardGameParseColor(value, fallback = "black") {{
      const token = String(value || "").trim().toLowerCase();
      if (token === "white" || token === "w") return "white";
      if (token === "black" || token === "b") return "black";
      return String(fallback || "").trim().toLowerCase() === "white" ? "white" : "black";
    }}

    function gamesInviteSeedPeerId(state = latestState) {{
      const safeState = state && typeof state === "object" ? state : latestState;
      const selectedId = normalizeNodeId(selectedNodeId || "");
      if (!isCanonicalNodeId(selectedId)) return "";
      const localNodeId = normalizeNodeId(resolveLocalNodeId(safeState || {{}}) || "");
      if (isCanonicalNodeId(localNodeId) && selectedId === localNodeId) return "";
      return selectedId;
    }}

    function gamesInviteSeedPeerLabel(state = latestState) {{
      const safeState = state && typeof state === "object" ? state : latestState;
      const peerId = gamesInviteSeedPeerId(safeState);
      if (!isCanonicalNodeId(peerId)) return "";
      const nodes = Array.isArray(safeState && safeState.nodes) ? safeState.nodes : [];
      for (const node of nodes) {{
        const nodeId = normalizeNodeId(node && node.id);
        if (nodeId !== peerId) continue;
        const label = preferredNodeName(node) || nodeNameCache.get(peerId) || peerId;
        return String(label || peerId);
      }}
      return String(nodeNameCache.get(peerId) || peerId);
    }}

    function protocolMessageSummary(msg) {{
      return (msg && msg.summary && typeof msg.summary === "object")
        ? msg.summary
        : {{}};
    }}

    function protocolMessagePacket(msg) {{
      return (msg && msg.packet && typeof msg.packet === "object")
        ? msg.packet
        : {{}};
    }}

    function protocolMessageDecoded(msg) {{
      const packet = protocolMessagePacket(msg);
      return (packet.decoded && typeof packet.decoded === "object")
        ? packet.decoded
        : {{}};
    }}

    function protocolMessageRawPacket(msg) {{
      const packet = protocolMessagePacket(msg);
      return (packet.raw && typeof packet.raw === "object")
        ? packet.raw
        : {{}};
    }}

    function protocolMessageRawDecoded(msg) {{
      const rawPacket = protocolMessageRawPacket(msg);
      return (rawPacket.decoded && typeof rawPacket.decoded === "object")
        ? rawPacket.decoded
        : {{}};
    }}

    function protocolMessageText(msg) {{
      if (!msg || typeof msg !== "object") return "";
      const summary = protocolMessageSummary(msg);
      const packet = protocolMessagePacket(msg);
      const decoded = protocolMessageDecoded(msg);
      const rawDecoded = protocolMessageRawDecoded(msg);
      return String(
        msg.text
        ?? msg.decoded_text
        ?? msg.payload_text
        ?? summary.decoded_text
        ?? decoded.text
        ?? rawDecoded.text
        ?? packet.text
        ?? ""
      ).trim();
    }}

    function protocolMessageFromNodeId(msg) {{
      if (!msg || typeof msg !== "object") return "";
      const summary = protocolMessageSummary(msg);
      const packet = protocolMessagePacket(msg);
      const rawPacket = protocolMessageRawPacket(msg);
      return normalizeNodeId(
        msg.from
        ?? summary.from
        ?? packet.fromId
        ?? packet.from
        ?? rawPacket.fromId
        ?? rawPacket.from
        ?? ""
      );
    }}

    function protocolMessageToNodeId(msg) {{
      if (!msg || typeof msg !== "object") return "";
      const summary = protocolMessageSummary(msg);
      const packet = protocolMessagePacket(msg);
      const rawPacket = protocolMessageRawPacket(msg);
      return normalizeNodeId(
        msg.to
        ?? msg.destination
        ?? summary.to
        ?? packet.toId
        ?? packet.to
        ?? packet.destination
        ?? rawPacket.toId
        ?? rawPacket.to
        ?? rawPacket.destination
        ?? ""
      );
    }}

    function protocolMessageUnix(msg) {{
      if (!msg || typeof msg !== "object") return Math.floor(Date.now() / 1000);
      const summary = protocolMessageSummary(msg);
      const packet = protocolMessagePacket(msg);
      const rawPacket = protocolMessageRawPacket(msg);
      return latestUnixTimestamp(
        msg.rx_time,
        msg.captured_at,
        msg.sent_at,
        msg.created_at,
        summary.rx_time_unix,
        packet.rxTime,
        rawPacket.rx_time,
        summary.rx_time,
        summary.captured_at
      ) || Math.floor(Date.now() / 1000);
    }}

    function protocolMessageIsLocalEcho(msg) {{
      if (!msg || typeof msg !== "object") return false;
      const summary = protocolMessageSummary(msg);
      const packet = protocolMessagePacket(msg);
      return !!(
        msg.local_echo === true
        || msg.localEcho === true
        || summary.local_echo === true
        || summary.localEcho === true
        || packet.local_echo === true
        || packet.localEcho === true
      );
    }}

    function boardGameRefs(gameId) {{
      const id = boardGameNormalizeId(gameId);
      if (id === "chess") {{
        return {{
          id,
          protocolVersion: chessProtocolVersion,
          maxSeenMessages: chessMaxSeenNetworkMessages,
          defaultLocalColor: "white",
          defaultRemoteColor: "black",
          opponent: chessOpponent,
          playerLabel: chessPlayerLabel,
          getPeerId: () => chessPeerId,
          setPeerId: (value) => {{ chessPeerId = normalizeNodeId(value || ""); }},
          getHostColorPreference: () => chessHostColorPreference,
          setHostColorPreference: (value) => {{
            chessHostColorPreference = boardGameParseColor(value, "white");
          }},
          getPendingInvites: () => (Array.isArray(chessPendingInvites) ? chessPendingInvites : []),
          setPendingInvites: (rows) => {{
            chessPendingInvites = Array.isArray(rows) ? rows : [];
          }},
          getSelectedInviteKey: () => chessSelectedInviteKey,
          setSelectedInviteKey: (value) => {{
