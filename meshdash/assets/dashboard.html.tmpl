                    <button id="settings-update-check" class="btn btn-secondary" type="button">Check for Updates</button>
                    <button id="settings-update-cleanup-rollbacks" class="btn btn-secondary" type="button" disabled hidden>Clean Rollbacks</button>
                    <button id="settings-update-reload" class="btn btn-secondary" type="button">Reload Backend</button>
