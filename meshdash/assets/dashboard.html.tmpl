            </div>
            <div id="channels-overview" class="overview-grid"></div>
            <section class="channels-app-routing" aria-label="App channel routing">
              <div class="channels-app-routing-head">
                <div class="channels-app-routing-head-main">
                  <h4>App Channels</h4>
                  <button
                    id="channels-app-routing-toggle-btn"
                    class="btn btn-secondary channels-app-routing-toggle"
                    type="button"
                    aria-expanded="false"
                  >Expand</button>
                </div>
                <div id="channels-app-routing-summary" class="channels-app-routing-summary">Loading app routing summary…</div>
                <div id="channels-app-routing-copy" class="channels-app-routing-copy" hidden>Choose whether Files, Games, and BBS follow global send or stay locked to a fixed channel.</div>
              </div>
              <div id="channels-app-routing-grid" class="channels-app-routing-grid" hidden>
                <div class="channels-app-route-placeholder">Loading app channel routing controls…</div>
              </div>
            </section>
            <div class="channels-summary-footer">
              <div class="settings-help-note channels-current-note">
                Blank <strong>PSK</strong> keeps the current key. <strong>Ch 0</strong> may be active with no name.
              </div>
              <div class="channels-status-row">
                <span id="channels-apply-status" class="settings-status channels-status"></span>
              </div>
            </div>
          </section>

          <section class="channels-dashboard-panel settings-panel channels-dashboard-panel-activity" aria-label="Channel activity">
            <div class="channels-section-head">
              <div>
                <h3>Channel Activity</h3>
              </div>
            </div>
            <div class="channels-activity-table-wrap scroll">
              <table class="settings-channels-table" id="settings-channels-table">
                <thead>
                  <tr>
                    <th>Index</th>
                    <th>Role</th>
                    <th>Name</th>
                    <th class="settings-channel-mqtt">MQTT Up</th>
                    <th class="settings-channel-mqtt">MQTT Down</th>
                    <th>PSK (new)</th>
                    <th>Actions</th>
                    <th>Evidence</th>
                    <th>Packets</th>
                    <th>Everyone</th>
                    <th>Direct</th>
                    <th>Nodes</th>
                    <th>Top ports</th>
                    <th>Latest</th>
                  </tr>
                </thead>
                <tbody id="settings-channels-tbody">
                  <tr><td colspan="14" class="settings-channels-empty">Fetch settings to load channels.</td></tr>
                </tbody>
              </table>
            </div>
          </section>
        </div>
      </div>
    </section>

    <section class="card encription">
      <h2>Encrypted Traffic</h2>
      <div class="body">
        <div id="encription-caption" class="history-caption">Packets that could not be decoded by this node.</div>
        <div class="encription-panels">
          <section class="encription-panel">
            <h3>Recent encrypted packets</h3>
            <div class="scroll">
              <table id="encription-packets-table">
                <thead>
                  <tr>
                    <th>Captured</th><th>From</th><th>To</th><th>Hops</th><th>RSSI</th><th>SNR</th><th>Payload</th><th>Reason</th>
                  </tr>
                </thead>
                <tbody></tbody>
              </table>
            </div>
          </section>
          <section class="encription-panel">
            <h3>Encrypted route activity</h3>
            <div class="scroll">
              <table id="encription-traffic-table">
                <thead>
                  <tr>
                    <th>From</th><th>To</th><th>Packets</th><th>Avg hops</th><th>Latest</th>
                  </tr>
                </thead>
                <tbody></tbody>
              </table>
            </div>
          </section>
          <section class="encription-panel encription-panel-wide">
            <h3>Encrypted traffic over time</h3>
            <div id="encription-trend-chart-wrap">
              <svg id="encription-trend-chart" viewBox="0 0 900 220" preserveAspectRatio="none" aria-label="Encrypted traffic over time"></svg>
              <div id="encription-trend-empty" class="signal-empty">No encrypted packet timestamps in recent buffer.</div>
            </div>
          </section>
        </div>
      </div>
    </section>

    <div class="splitter" data-row="8" title="Drag to resize side panels"></div>

    <section class="card environment">
      <h2>Sensors</h2>
      <div class="body">
        <section class="env-metrics-explorer" aria-label="Sensor metrics explorer">
          <div class="env-metrics-head">
            <h3>Historical Sensor Metrics</h3>
            <div id="env-metrics-status" class="env-metrics-status">Waiting for saved sensor history...</div>
          </div>
          <div class="env-metrics-controls">
            <label for="env-window-select">Window</label>
            <select id="env-window-select" class="env-metric-select" aria-label="Sensor history window">
              <option value="6">6h</option>
              <option value="12">12h</option>
              <option value="24">24h</option>
              <option value="72" selected>72h</option>
              <option value="168">7d</option>
              <option value="336">14d</option>
            </select>
            <label for="env-metric-select">Metric</label>
            <select id="env-metric-select" class="env-metric-select" aria-label="Sensor metric selector">
              <option value="">No environment metrics</option>
            </select>
            <label for="env-node-select">Node</label>
            <select id="env-node-select" class="env-metric-select" aria-label="Sensor node selector">
              <option value="">All nodes</option>
            </select>
            <button id="env-metrics-refresh-btn" class="env-metrics-refresh-btn" type="button">Refresh</button>
          </div>
          <div class="env-metrics-grid">
            <div id="env-metrics-chart-wrap">
              <svg id="env-metrics-chart" viewBox="0 0 900 260" preserveAspectRatio="none" aria-label="Sensor metrics over time chart"></svg>
              <div id="env-metrics-empty" class="signal-empty">No historical sensor metrics found yet.</div>
            </div>
            <div class="env-metrics-table-wrap scroll">
              <table id="env-metrics-table">
                <thead>
                  <tr>
                    <th>Time</th>
                    <th>Node</th>
                    <th>ID</th>
                    <th id="env-metrics-value-col">Value</th>
                    <th>Metric</th>
                  </tr>
                </thead>
                <tbody></tbody>
              </table>
            </div>
          </div>
          <div id="env-metrics-available" class="env-metrics-available"></div>
        </section>
      </div>
    </section>

    <section class="card raw">
      <h2>Raw Data</h2>
      <div class="body">
        <details><summary>my_info</summary><pre id="raw-my-info"></pre></details>
        <details><summary>metadata</summary><pre id="raw-metadata"></pre></details>
        <details><summary>local_config</summary><pre id="raw-local-config"></pre></details>
        <details><summary>module_config</summary><pre id="raw-module-config"></pre></details>
        <details><summary>channels</summary><pre id="raw-channels"></pre></details>
        <details><summary>nodes_full</summary><pre id="raw-nodes-full"></pre></details>
      </div>
    </section>

    <div class="hsplitter" data-target="low" title="Drag to resize lower panels and console"></div>

    <section class="card console">
      <div class="body">
        <div class="console-controls">
          <button id="console-clear-btn" type="button">Clear</button>
          <label><input id="console-autoscroll" type="checkbox" checked /> Auto-scroll</label>
          <label><input id="console-timestamps" type="checkbox" /> Timestamps</label>
          <label class="console-filter-label" for="console-filter-input">Search</label>
          <input
            id="console-filter-input"
            class="console-filter-input"
            type="search"
            spellcheck="false"
            autocomplete="off"
            placeholder="Filter console text (e.g. ack -C2)..."
            aria-label="Filter console text"
          />
          <label class="console-select-label" for="console-font-size-select">Text size</label>
          <select id="console-font-size-select" class="console-select" aria-label="Console text size">
            <option value="sm">Small</option>
            <option value="md">Medium</option>
            <option value="lg">Large</option>
            <option value="xl">XL</option>
          </select>
        </div>
        <div id="console-terminal-screen" class="console-terminal-screen">
          <pre id="live-console"></pre>
          <input
            id="console-command-input"
            class="console-command-input-proxy"
            type="text"
            spellcheck="false"
            autocomplete="off"
            autocapitalize="off"
            autocorrect="off"
            tabindex="-1"
            aria-label="Console command input"
          />
        </div>
      </div>
    </section>
  </div>
  <div id="peer-dm-popout-host" class="peer-dm-popout-host" aria-live="polite"></div>
    </main>
  </div>

  <script
    src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
    integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
    crossorigin=""
  ></script>
  <script
    src="https://unpkg.com/leaflet.heat@0.2.0/dist/leaflet-heat.js"
    crossorigin=""
  ></script>
  <script>
{app_js}
  </script>
</body>
</html>
