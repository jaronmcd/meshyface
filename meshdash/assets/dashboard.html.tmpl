                    <span class="topbar-view-submenu-item-copy">
                      <span class="topbar-view-submenu-item-label-row">
                        <span class="topbar-view-submenu-item-label">Files</span>
                        <span class="topbar-view-submenu-item-beta">BETA</span>
                      </span>
                      <span class="topbar-view-submenu-item-meta">Transfers and inbox</span>
                    </span>
                  </button>
                </div>
              </div>
              <button
                class="topbar-view-menu-item"
                data-view="settings"
                type="button"
                role="menuitemradio"
                aria-checked="false"
                title="Radio + dashboard settings"
              >
