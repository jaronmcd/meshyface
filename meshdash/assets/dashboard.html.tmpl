            data-theme-toggle="compact"
            title="Toggle theme between dark and light"
            aria-label="Toggle theme between dark and light"
            aria-pressed="false"
          >
            <svg class="chat-users-head-theme-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
              <path d="M12 2A10 10 0 0 0 2 12A10 10 0 0 0 12 22V2Z" />
            </svg>
          </button>
          <div class="workspace-launcher-shell chat-users-head-launcher-shell">
            <button
              id="layout-view-menu-btn"
              class="topbar-view-menu-btn"
              type="button"
              title="Switch workspace view"
              aria-label="Switch workspace view"
              aria-haspopup="menu"
              aria-expanded="false"
            >
              <span class="topbar-view-menu-btn-main">
                <span id="layout-view-menu-btn-label" class="topbar-view-menu-btn-label">
                  <span id="layout-view-menu-btn-label-text" class="topbar-view-menu-btn-label-text">Chat</span>
                </span>
                <span id="layout-view-menu-btn-badge" class="topbar-view-menu-btn-badge" hidden>0</span>
