              <thead>
                <tr>
                  <th>Captured</th><th>From</th><th>To</th><th>Message</th>
                </tr>
              </thead>
              <tbody></tbody>
            </table>
          </div>
          <div id="history-chat-splitter" class="history-chat-splitter" title="Drag to resize chat and notification history panels"></div>
          <div class="history-notification-section">
            <div class="history-notification-head">
              <div id="history-notification-caption" class="history-caption">Recent inbound system notification history from this browser.</div>
              <button id="history-notification-clear-btn" class="history-notification-clear-btn" type="button" title="Clear saved system notification history">Clear</button>
            </div>
            <div id="history-notification-list" class="history-notification-list" aria-live="polite"></div>
          </div>
        </div>
      </div>
    </section>

    <div class="hsplitter" data-target="mid" title="Drag to resize middle and lower panels"></div>

    <section class="card packets">
      <h2>Recent Packets</h2>
      <div class="body scroll">
        <table id="packets-table">
          <thead>
            <tr>
              <th>Captured</th><th>From</th><th>To</th><th>Port</th><th>SNR</th><th>RSSI</th><th>Text</th>
            </tr>
          </thead>
          <tbody></tbody>
        </table>
      </div>
    </section>

    <section class="card channels-view" aria-label="Inferred message channels">
      <h2>Channels</h2>
      <div class="body">
        <div id="channels-caption" class="history-caption">Observed message channels inferred from recent packets. Message channels are encryption groups, not RF frequency slots.</div>
        <div id="channels-overview" class="overview-grid"></div>
        <div class="channels-panels">
          <section class="channels-panel channels-panel-wide">
            <h3>Observed and inferred message channels</h3>
            <div class="scroll">
              <table id="channels-inference-table">
                <thead>
                  <tr>
                    <th>Channel</th><th>Local label</th><th>Evidence</th><th>Packets</th><th>Everyone</th><th>Direct</th><th>Nodes</th><th>Top ports</th><th>Latest</th>
                  </tr>
                </thead>
                <tbody></tbody>
              </table>
            </div>
          </section>
          <section class="channels-panel">
            <h3>Local channel hints</h3>
            <div class="scroll">
              <table id="channels-local-table">
                <thead>
                  <tr>
                    <th>Channel</th><th>Name</th><th>Role</th><th>State</th><th>Observed</th><th>Latest</th>
                  </tr>
                </thead>
                <tbody></tbody>
              </table>
            </div>
          </section>
        </div>
      </div>
    </section>

    <section class="card encription">
      <h2>Encrypted Traffic</h2>
      <div class="body">
        <div id="encription-caption" class="history-caption">Packets that could not be decoded by this node.</div>
        <div class="encription-panels">
          <section class="encription-panel">
            <h3>Recent encrypted packets</h3>
            <div class="scroll">
              <table id="encription-packets-table">
                <thead>
                  <tr>
                    <th>Captured</th><th>From</th><th>To</th><th>Hops</th><th>RSSI</th><th>SNR</th><th>Payload</th><th>Reason</th>
                  </tr>
                </thead>
                <tbody></tbody>
              </table>
            </div>
          </section>
          <section class="encription-panel">
            <h3>Encrypted route activity</h3>
            <div class="scroll">
              <table id="encription-traffic-table">
                <thead>
                  <tr>
                    <th>From</th><th>To</th><th>Packets</th><th>Avg hops</th><th>Latest</th>
                  </tr>
                </thead>
                <tbody></tbody>
              </table>
            </div>
          </section>
          <section class="encription-panel encription-panel-wide">
            <h3>Encrypted traffic over time</h3>
            <div id="encription-trend-chart-wrap">
              <svg id="encription-trend-chart" viewBox="0 0 900 220" preserveAspectRatio="none" aria-label="Encrypted traffic over time"></svg>
              <div id="encription-trend-empty" class="signal-empty">No encrypted packet timestamps in recent buffer.</div>
            </div>
          </section>
        </div>
      </div>
    </section>

    <div class="splitter" data-row="8" title="Drag to resize side panels"></div>

    <section class="card raw">
      <h2>Raw Data</h2>
      <div class="body">
        <details><summary>my_info</summary><pre id="raw-my-info"></pre></details>
        <details><summary>metadata</summary><pre id="raw-metadata"></pre></details>
        <details><summary>local_config</summary><pre id="raw-local-config"></pre></details>
        <details><summary>module_config</summary><pre id="raw-module-config"></pre></details>
        <details><summary>channels</summary><pre id="raw-channels"></pre></details>
        <details><summary>nodes_full</summary><pre id="raw-nodes-full"></pre></details>
      </div>
    </section>

    <div class="hsplitter" data-target="low" title="Drag to resize lower panels and console"></div>

    <section class="card console">
      <div class="body">
        <div class="console-controls">
          <button id="console-clear-btn" type="button">Clear</button>
          <label><input id="console-autoscroll" type="checkbox" checked /> Auto-scroll</label>
        </div>
        <pre id="live-console"></pre>
        <form id="console-command-form" class="console-command-form" autocomplete="off">
          <label class="console-command-label" for="console-command-input">Command</label>
          <input
            id="console-command-input"
            class="console-command-input"
            type="text"
            placeholder='Type "live -v" or "help"'
            spellcheck="false"
            autocomplete="off"
          />
          <button id="console-command-run-btn" type="submit">Run</button>
        </form>
      </div>
    </section>
  </div>
    </main>
  </div>

  <script
    src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
    integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
    crossorigin=""
  ></script>
  <script
    src="https://unpkg.com/leaflet.heat@0.2.0/dist/leaflet-heat.js"
    crossorigin=""
  ></script>
  <script>
{app_js}
  </script>
</body>
</html>
