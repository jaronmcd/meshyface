        <div id="chat-node-details-inline-host" class="chat-node-details-inline-host"></div>
      </div>
      <div class="chat-left-bottom-bar workspace-stack-bottom-shell">
        <div class="chat-user-search-wrap">
          <input id="chat-user-search-input" class="list-search-input" type="search" placeholder="Search nodes by ID or name" autocomplete="off" />
