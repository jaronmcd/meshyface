                Runtime status for this dashboard process.
              </div>
              <div class="chat-settings-meta-list">
                <div class="chat-settings-meta-item">{safety_label}</div>
              </div>
              <span id="disk-meter" class="disk-meter settings-system-disk-meter" title="Disk free on dashboard host">
                <span id="disk-label" class="disk-label">Disk free: n/a</span>
