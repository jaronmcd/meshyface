<!doctype html>
<html>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{app_title}</title>
  <script>
    (function () {{
      window.__meshDashboardBootComplete = false;
      window.__meshDashboardMarkBooted = function () {{
        window.__meshDashboardBootComplete = true;
        try {{
          window.sessionStorage.removeItem("meshDashboardBootRetryCount");
        }} catch (err) {{}}
      }};
      window.setTimeout(function () {{
        if (window.__meshDashboardBootComplete) return;
        var retryCount = 0;
        try {{
          retryCount = Number(window.sessionStorage.getItem("meshDashboardBootRetryCount") || "0") || 0;
          retryCount += 1;
          window.sessionStorage.setItem("meshDashboardBootRetryCount", String(retryCount));
        }} catch (err) {{
          retryCount = 1;
        }}
        if (retryCount > 3) return;
        try {{
          var nextUrl = new URL(window.location.href);
          nextUrl.searchParams.set("_mesh_boot_retry", String(Date.now()));
          window.location.replace(nextUrl.toString());
        }} catch (err) {{
          window.location.reload();
        }}
      }}, 10000);
    }})();
  </script>
  <link rel="stylesheet" href="/assets/vendor/leaflet-1.9.4.css" />
  <!-- mesh-dashboard-style:start -->
  <style>
{style_css}
  </style>
  <!-- mesh-dashboard-style:end -->
</head>
<body{body_attrs}>
  <div id="dashboard-image-bg" class="{dashboard_image_bg_class}" aria-hidden="true"{dashboard_image_bg_attrs}></div>
  <div id="dashboard-particles-bg" class="{dashboard_particles_bg_class}" aria-hidden="true"{dashboard_particles_bg_attrs}></div>
  <div id="dashboard-livemap-bg" class="{dashboard_livemap_bg_class}" aria-hidden="true"{dashboard_livemap_bg_attrs}></div>
