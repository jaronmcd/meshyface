                    data-view="bots"
                    data-app-view="bots"
                    type="button"
                    role="menuitemradio"
                    aria-checked="false"
                    title="Bots workspace"
                    {bots_app_tab_hidden_attrs}
                  >
                    <span class="topbar-view-submenu-item-icon" aria-hidden="true">BT</span>
                    <span class="topbar-view-submenu-item-copy">
                      <span class="topbar-view-submenu-item-label-row">
                        <span class="topbar-view-submenu-item-label">Bots</span>
                        <span class="topbar-view-submenu-item-beta">BETA</span>
                      </span>
                      <span class="topbar-view-submenu-item-meta">Automation and commands</span>
                    </span>
                  </button>
                  <button
                    class="topbar-view-submenu-item"
                    data-view="bbs"
                    data-app-view="bbs"
                    type="button"
                    role="menuitemradio"
                    aria-checked="false"
                    title="BBS workspace"
                    {bbs_app_tab_hidden_attrs}
