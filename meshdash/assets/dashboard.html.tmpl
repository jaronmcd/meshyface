            </div>
            <div id="history-activity-panel-activity" class="history-activity-panel" role="tabpanel" aria-label="History activity trends">
              <div class="history-activity-weekly-panel">
                <div id="weekly-summary-caption" class="history-caption">Minute-level trend by saved snapshots.</div>
                <div class="history-metric-controls">
                  <div class="history-metric-wrap">
                    <label for="weekly-summary-metric" class="history-metric-label">Metric</label>
                    <select id="weekly-summary-metric" class="history-metric-select" aria-label="Weekly summary metric">
                      <option value="packets">Packets</option>
                      <option value="nodes">Nodes</option>
                      <option value="links">Links</option>
                    </select>
                  </div>
                  <div id="weekly-summary-node-lines-wrap" class="history-metric-wrap history-metric-wrap-lines" hidden>
                    <span class="history-metric-label">Node Lines</span>
                    <label class="history-metric-inline" for="weekly-summary-node-line-online">
                      <input
                        id="weekly-summary-node-line-online"
                        class="history-metric-toggle"
                        type="checkbox"
                        aria-label="Show online nodes line"
                      />
                      <span>Online</span>
                    </label>
                    <label class="history-metric-inline" for="weekly-summary-node-line-known">
                      <input
                        id="weekly-summary-node-line-known"
                        class="history-metric-toggle"
                        type="checkbox"
                        aria-label="Show known nodes radio line"
                      />
                      <span>Known</span>
                    </label>
                    <label class="history-metric-inline" for="weekly-summary-node-line-saved">
                      <input
                        id="weekly-summary-node-line-saved"
                        class="history-metric-toggle"
                        type="checkbox"
                        aria-label="Show saved nodes database line"
                      />
                      <span>Saved</span>
                    </label>
                    <label class="history-metric-inline" for="weekly-summary-node-line-position">
                      <input
                        id="weekly-summary-node-line-position"
                        class="history-metric-toggle"
                        type="checkbox"
                        aria-label="Show nodes with position line"
                      />
                      <span>Position</span>
                    </label>
                  </div>
                </div>
                <div id="weekly-summary-chart-wrap">
                  <svg id="weekly-summary-chart" viewBox="0 0 900 220" preserveAspectRatio="none" aria-label="Weekly metric trend"></svg>
                  <div id="weekly-summary-empty" class="signal-empty" hidden>No weekly summary history yet.</div>
                </div>
                <div id="weekly-summary-timeline" class="signal-timeline" aria-label="Weekly trend timeline"></div>
                <div id="weekly-summary-overview" class="overview-grid"></div>
              </div>
              <section class="history-activity-chat-trend">
                <div class="history-caption">Chat message trend from recent saved activity.</div>
                <div id="history-chat-trend-chart-wrap">
                  <svg id="history-chat-trend-chart" viewBox="0 0 900 220" preserveAspectRatio="none" aria-label="Chat activity trend"></svg>
                  <div id="history-chat-trend-empty" class="signal-empty">No chat timestamps in recent history.</div>
                </div>
              </section>
            </div>
            <div
              id="history-activity-panel-encrypted"
              class="history-activity-panel"
              role="tabpanel"
              aria-label="Encrypted traffic trends"
              hidden
            >
              <section class="history-activity-encryption-trend">
                <div class="history-caption">Encrypted packet trend from the recent packet buffer.</div>
                <div id="encription-trend-chart-wrap">
                  <svg id="encription-trend-chart" viewBox="0 0 900 220" preserveAspectRatio="none" aria-label="Encrypted traffic over time"></svg>
                  <div id="encription-trend-empty" class="signal-empty">No encrypted packet timestamps in recent buffer.</div>
                </div>
              </section>
              <section class="history-activity-encryption-routes">
                <div class="history-caption">Top encrypted routes in the recent packet buffer.</div>
                <div id="encription-route-chart-wrap">
                  <svg id="encription-route-chart" viewBox="0 0 900 220" preserveAspectRatio="none" aria-label="Encrypted route distribution"></svg>
                  <div id="encription-route-empty" class="signal-empty">No encrypted routes in recent buffer.</div>
                </div>
              </section>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="card history-chat">
      <h2>Chat History</h2>
      <div class="body">
        <div class="history-chat-tabbar" role="tablist" aria-label="History chat panels">
          <button
            id="history-chat-tab-activity-btn"
            class="history-chat-tab-btn is-active"
            type="button"
            role="tab"
            aria-selected="true"
            aria-controls="history-chat-panel-activity"
            data-history-chat-tab="activity"
          >Activity</button>
          <button
            id="history-chat-tab-encrypted-btn"
            class="history-chat-tab-btn"
            type="button"
            role="tab"
            aria-selected="false"
            aria-controls="history-chat-panel-encrypted"
            data-history-chat-tab="encrypted"
          >Encrypted</button>
        </div>
        <div id="history-chat-panel-activity" class="history-chat-panel" role="tabpanel" aria-labelledby="history-chat-tab-activity-btn">
          <div id="history-chat-caption" class="history-caption">Recent saved chat and derived status activity.</div>
          <div class="history-chat-stack">
            <div class="scroll history-chat-main-scroll">
              <table id="history-chat-table">
                <thead>
                  <tr>
                    <th>Captured</th><th>From</th><th>To</th><th>Message</th>
                  </tr>
                </thead>
                <tbody></tbody>
              </table>
            </div>
            <div id="history-chat-splitter" class="history-chat-splitter" title="Drag to resize chat and notification history panels"></div>
            <div class="history-notification-section">
              <div class="history-notification-head">
                <div id="history-notification-caption" class="history-caption">Recent inbound system notification history from this browser.</div>
                <button id="history-notification-clear-btn" class="history-notification-clear-btn" type="button" title="Clear saved system notification history">Clear</button>
              </div>
              <div id="history-notification-list" class="history-notification-list" aria-live="polite"></div>
            </div>
          </div>
        </div>
        <div
          id="history-chat-panel-encrypted"
          class="history-chat-panel"
          role="tabpanel"
          aria-labelledby="history-chat-tab-encrypted-btn"
          hidden
        >
          <section class="history-encription-section">
            <div id="encription-caption" class="history-caption">Packets that could not be decoded by this node.</div>
            <div class="history-encription-panels">
              <section class="history-encription-panel">
                <h3>Encrypted packets</h3>
                <div class="scroll">
                  <table id="encription-packets-table">
                    <thead>
                      <tr>
                        <th>Captured</th><th>From</th><th>To</th><th>Hops</th><th>RSSI</th><th>SNR</th><th>Payload</th><th>Reason</th>
                      </tr>
                    </thead>
                    <tbody></tbody>
                  </table>
                </div>
              </section>
              <section class="history-encription-panel">
                <h3>Encrypted route activity</h3>
                <div class="scroll">
                  <table id="encription-traffic-table">
                    <thead>
                      <tr>
                        <th>From</th><th>To</th><th>Packets</th><th>Avg hops</th><th>Latest</th>
                      </tr>
                    </thead>
                    <tbody></tbody>
                  </table>
                </div>
              </section>
            </div>
          </section>
        </div>
      </div>
    </section>

    <div class="hsplitter" data-target="mid" title="Drag to resize middle and lower panels"></div>

    <div class="splitter" data-row="8" title="Drag to resize side panels"></div>

    <section class="card environment">
      <h2>Sensors</h2>
      <div class="body">
        <div id="environment-metrics-home" class="environment-metrics-home">
          <section class="env-metrics-explorer" aria-label="Sensor metrics explorer">
            <div class="env-metrics-controls">
              <div class="history-metric-wrap env-metrics-control-group">
                <label for="env-window-select">Window</label>
                <select id="env-window-select" class="env-metric-select" aria-label="Sensor history window">
                  <option value="6">6h</option>
                  <option value="12">12h</option>
                  <option value="24">24h</option>
                  <option value="72" selected>72h</option>
                  <option value="168">7d</option>
                  <option value="336">14d</option>
                </select>
              </div>
              <div class="history-metric-wrap env-metrics-control-group">
                <label for="env-metric-select">Metric</label>
                <select id="env-metric-select" class="env-metric-select" aria-label="Sensor metric selector">
                  <option value="">No environment metrics</option>
                </select>
              </div>
              <div class="history-metric-wrap env-metrics-control-group">
                <label for="env-node-select">Node</label>
                <select id="env-node-select" class="env-metric-select" aria-label="Sensor node selector">
                  <option value="">All nodes</option>
                </select>
              </div>
              <button id="env-metrics-refresh-btn" class="env-metrics-refresh-btn" type="button">Refresh</button>
            </div>
            <div class="env-metrics-grid">
              <div id="env-metrics-chart-wrap">
                <svg id="env-metrics-chart" viewBox="0 0 900 320" preserveAspectRatio="none" aria-label="Sensor metrics over time chart"></svg>
                <div id="env-metrics-empty" class="signal-empty">No historical sensor metrics found yet.</div>
              </div>
            </div>
            <div id="env-metrics-timeline" class="signal-timeline" aria-label="Sensor metrics timeline"></div>
            <div id="env-metrics-available" class="env-metrics-available"></div>
          </section>
        </div>
      </div>
    </section>

    <div class="hsplitter" data-target="low" title="Drag to resize lower panels and console"></div>

    <section class="card console">
      <div class="body">
        <div id="console-terminal-screen" class="console-terminal-screen">
          <pre id="live-console"></pre>
          <div id="console-scroll-status" class="console-scroll-status" hidden aria-hidden="true">
            <span class="console-scroll-status-line">[paused] scroll down for newest console output</span>
          </div>
          <input
            id="console-command-input"
            class="console-command-input-proxy"
            type="text"
            spellcheck="false"
            autocomplete="off"
            autocapitalize="off"
            autocorrect="off"
            tabindex="-1"
            aria-label="Console command input"
          />
          <div id="console-context-menu" class="console-context-menu" role="menu" hidden aria-label="Console actions">
            <button
              id="console-context-menu-paste"
              class="console-context-menu-item"
              type="button"
              role="menuitem"
              data-console-action="paste"
            >
              <span id="console-context-menu-paste-label" class="console-context-menu-item-label">Paste</span>
              <span id="console-context-menu-paste-hint" class="console-context-menu-item-hint">Ctrl+V</span>
            </button>
            <button
              id="console-context-menu-copy"
              class="console-context-menu-item"
              type="button"
              role="menuitem"
              data-console-action="copy"
            >
              <span class="console-context-menu-item-label">Copy</span>
              <span class="console-context-menu-item-hint">Ctrl+C</span>
            </button>
            <button
              id="console-context-menu-select-all"
              class="console-context-menu-item"
              type="button"
              role="menuitem"
              data-console-action="select-all"
            >
              <span class="console-context-menu-item-label">Select All</span>
              <span class="console-context-menu-item-hint">Ctrl+A</span>
            </button>
          </div>
        </div>
      </div>
    </section>
  </div>
  <div id="peer-dm-popout-host" class="peer-dm-popout-host" aria-live="polite"></div>
    </main>
  </div>

  <script
    src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
    integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
    crossorigin=""
  ></script>
  <script
    src="https://unpkg.com/leaflet.heat@0.2.0/dist/leaflet-heat.js"
    crossorigin=""
  ></script>
  <script>
{app_js}
  </script>
</body>
</html>
