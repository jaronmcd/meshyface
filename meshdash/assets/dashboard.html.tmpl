            autocorrect="off"
            tabindex="-1"
            aria-label="Console command input"
          />
          <div
            id="console-autocomplete-menu"
            class="console-autocomplete-menu"
            role="listbox"
            hidden
            aria-hidden="true"
            aria-label="Console command suggestions"
          ></div>
          <div id="console-context-menu" class="console-context-menu" role="menu" hidden aria-label="Console actions">
            <button
              id="console-context-menu-paste"
              class="console-context-menu-item"
              type="button"
              role="menuitem"
              data-console-action="paste"
            >
              <span id="console-context-menu-paste-label" class="console-context-menu-item-label">Paste</span>
              <span id="console-context-menu-paste-hint" class="console-context-menu-item-hint">Ctrl+V</span>
            </button>
            <button
              id="console-context-menu-copy"
              class="console-context-menu-item"
              type="button"
              role="menuitem"
              data-console-action="copy"
            >
              <span class="console-context-menu-item-label">Copy</span>
              <span class="console-context-menu-item-hint">Ctrl+C</span>
            </button>
            <button
              id="console-context-menu-select-all"
              class="console-context-menu-item"
              type="button"
              role="menuitem"
              data-console-action="select-all"
            >
              <span class="console-context-menu-item-label">Select All</span>
              <span class="console-context-menu-item-hint">Ctrl+A</span>
            </button>
          </div>
        </div>
      </div>
    </section>
  </div>
  <div id="peer-dm-popout-host" class="peer-dm-popout-host" aria-live="polite"></div>
  <div id="console-command-palette" class="console-command-palette" hidden aria-hidden="true">
    <div class="console-command-palette-backdrop" data-command-palette-close="1"></div>
    <div class="console-command-palette-dialog" role="dialog" aria-modal="true" aria-labelledby="console-command-palette-title">
      <div class="console-command-palette-head">
        <strong id="console-command-palette-title" class="console-command-palette-title">Console Commands</strong>
        <span class="console-command-palette-hint">Ctrl+K</span>
      </div>
      <input
        id="console-command-palette-input"
        class="console-command-palette-input"
        type="search"
        placeholder="Type a command name or description..."
        autocomplete="off"
        spellcheck="false"
      />
      <div id="console-command-palette-list" class="console-command-palette-list" role="listbox" aria-label="Console command matches"></div>
      <div class="console-command-palette-footer">Enter runs command • Esc closes • ↑/↓ move</div>
    </div>
  </div>
    </main>
  </div>

  <script src="/assets/vendor/leaflet-1.9.4.js"></script>
  <script src="/assets/vendor/leaflet-heat-0.2.0.js"></script>
  <script src="/assets/vendor/particles-2.0.0.min.js"></script>
  <!-- mesh-dashboard-app:start -->
  <script>
{app_js}
  </script>
  <!-- mesh-dashboard-app:end -->
</body>
</html>
