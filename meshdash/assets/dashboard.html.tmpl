<!doctype html>
<html>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{app_title}</title>
  <link
    rel="stylesheet"
    href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
    integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
    crossorigin=""
  />
  <style>
{style_css}
  </style>
</head>
<body>
  <div class="topbar">
    <div class="sub">
      <div id="topbar-update-ticker" class="topbar-update-ticker workspace-update-ticker" role="status" aria-live="polite" aria-label="Live update ticker" hidden>
        <div id="topbar-update-viewport" class="topbar-update-viewport">
          <div id="topbar-update-track" class="topbar-update-track">
            <span id="topbar-update-text-primary" class="topbar-update-text"></span>
            <span id="topbar-update-text-secondary" class="topbar-update-text" aria-hidden="true"></span>
          </div>
        </div>
      </div>
      <div class="summary-ticker-row" aria-label="Summary tickers">
        <button
          id="summary-ticker-density-toggle"
          class="summary-ticker-density-toggle summary-ticker-item summary-ticker-item-control"
          type="button"
          aria-pressed="false"
          aria-label="Expand summary tickers"
          title="Expand summary tickers"
        >
          <span class="summary-ticker-density-toggle-label label">Tickers</span>
          <span id="summary-ticker-density-toggle-text" class="summary-ticker-density-toggle-text value">Show</span>
          <span id="summary-ticker-density-toggle-icon" class="summary-ticker-density-toggle-icon" aria-hidden="true">+</span>
        </button>
        <div class="summary-ticker-item summary-ticker-item-self" id="summary-ticker-self" data-ticker-id="self">
          <div class="label" data-ticker-label>Self</div>
          <div class="value" id="m-self">n/a</div>
        </div>
        <div class="summary-ticker-item summary-ticker-item-radio" id="summary-ticker-radio" data-ticker-id="radio">
          <div class="label" data-ticker-label>Radio</div>
          <div class="value radio-ticker-value" id="m-radio">n/a</div>
          <div class="radio-ticker-status-line" id="m-radio-status" hidden>n/a</div>
          <div class="metric-ticker" id="ticker-radio" hidden>
            <span class="metric-ticker-delta" id="ticker-delta-radio">n/a</span>
            <span class="metric-ticker-rate" id="ticker-rate-radio">n/a</span>
            <svg class="metric-ticker-chart" id="ticker-chart-radio" viewBox="0 0 72 16" preserveAspectRatio="none" aria-hidden="true"></svg>
          </div>
        </div>
        <div class="summary-ticker-item" id="summary-ticker-known-nodes" data-ticker-id="known_nodes">
          <div class="label" data-ticker-label>Known Nodes</div>
          <div class="value" id="m-nodes">0</div>
          <div class="metric-ticker" id="ticker-nodes" hidden>
            <span class="metric-ticker-delta" id="ticker-delta-nodes">n/a</span>
            <span class="metric-ticker-rate" id="ticker-rate-nodes">n/a</span>
            <svg class="metric-ticker-chart" id="ticker-chart-nodes" viewBox="0 0 72 16" preserveAspectRatio="none" aria-hidden="true"></svg>
          </div>
        </div>
        <div class="summary-ticker-item" id="summary-ticker-online-nodes" data-ticker-id="online_nodes">
          <div class="label" data-ticker-label>Nodes Online</div>
          <div class="value" id="m-online-nodes">0</div>
          <div class="metric-ticker" id="ticker-online-nodes" hidden>
            <span class="metric-ticker-delta" id="ticker-delta-online-nodes">n/a</span>
            <span class="metric-ticker-rate" id="ticker-rate-online-nodes">n/a</span>
            <svg class="metric-ticker-chart" id="ticker-chart-online-nodes" viewBox="0 0 72 16" preserveAspectRatio="none" aria-hidden="true"></svg>
          </div>
        </div>
        <div class="summary-ticker-item" id="summary-ticker-new-nodes" data-ticker-id="new_nodes">
          <div class="label" data-ticker-label>New Nodes</div>
          <div class="value" id="m-new-nodes">0</div>
          <div class="metric-ticker" id="ticker-new-nodes" hidden>
            <span class="metric-ticker-delta" id="ticker-delta-new-nodes">n/a</span>
            <span class="metric-ticker-rate" id="ticker-rate-new-nodes">n/a</span>
            <svg class="metric-ticker-chart" id="ticker-chart-new-nodes" viewBox="0 0 72 16" preserveAspectRatio="none" aria-hidden="true"></svg>
          </div>
        </div>
        <div class="summary-ticker-item" id="summary-ticker-packets" data-ticker-id="packets_per_min">
          <div class="label" data-ticker-label>Packets / min</div>
          <div class="value" id="m-live-packets">0</div>
          <div class="metric-ticker" id="ticker-live-packets" hidden>
            <span class="metric-ticker-delta" id="ticker-delta-live-packets">n/a</span>
            <span class="metric-ticker-rate" id="ticker-rate-live-packets">n/a</span>
            <svg class="metric-ticker-chart" id="ticker-chart-live-packets" viewBox="0 0 72 16" preserveAspectRatio="none" aria-hidden="true"></svg>
          </div>
        </div>
        <div class="summary-ticker-item" id="summary-ticker-channel-util" data-ticker-id="channel_util">
          <div class="label" data-ticker-label>Channel Util</div>
          <div class="value" id="m-channel-util">n/a</div>
          <div class="metric-ticker" id="ticker-channel-util" hidden>
            <span class="metric-ticker-delta" id="ticker-delta-channel-util">n/a</span>
            <span class="metric-ticker-rate" id="ticker-rate-channel-util">n/a</span>
            <svg class="metric-ticker-chart" id="ticker-chart-channel-util" viewBox="0 0 72 16" preserveAspectRatio="none" aria-hidden="true"></svg>
          </div>
        </div>
        <div class="summary-ticker-item" id="summary-ticker-battery" data-ticker-id="battery">
          <div class="label" data-ticker-label>Battery</div>
          <div class="value" id="m-battery">n/a</div>
          <div class="metric-ticker" id="ticker-battery" hidden>
            <span class="metric-ticker-delta" id="ticker-delta-battery">n/a</span>
            <span class="metric-ticker-rate" id="ticker-rate-battery">n/a</span>
            <svg class="metric-ticker-chart" id="ticker-chart-battery" viewBox="0 0 72 16" preserveAspectRatio="none" aria-hidden="true"></svg>
          </div>
        </div>
        <div class="summary-ticker-item" id="summary-ticker-wifi" data-ticker-id="wifi">
          <div class="label" data-ticker-label>Wi-Fi</div>
          <div class="value wifi-ticker-value" id="m-wifi-ticker">n/a</div>
          <div class="metric-ticker" id="ticker-wifi" hidden>
            <span class="metric-ticker-delta" id="ticker-delta-wifi">n/a</span>
            <span class="metric-ticker-rate" id="ticker-rate-wifi">n/a</span>
            <svg class="metric-ticker-chart" id="ticker-chart-wifi" viewBox="0 0 72 16" preserveAspectRatio="none" aria-hidden="true"></svg>
          </div>
        </div>
        <div class="summary-ticker-item" id="summary-ticker-node" data-ticker-id="node">
          <div class="label" data-ticker-label>Signal</div>
          <div class="value node-ticker-value" id="m-node-ticker">n/a</div>
          <div class="metric-ticker" id="ticker-node-signal" hidden>
            <span class="metric-ticker-delta" id="ticker-delta-node-signal">n/a</span>
            <span class="metric-ticker-rate" id="ticker-rate-node-signal">n/a</span>
            <svg class="metric-ticker-chart" id="ticker-chart-node-signal" viewBox="0 0 72 16" preserveAspectRatio="none" aria-hidden="true"></svg>
          </div>
        </div>
        <div class="summary-ticker-item" id="summary-ticker-links" data-ticker-id="links">
          <div class="label" data-ticker-label>Links</div>
          <div class="value" id="m-links">n/a</div>
          <div class="metric-ticker" id="ticker-links" hidden>
            <span class="metric-ticker-delta" id="ticker-delta-links">n/a</span>
            <span class="metric-ticker-rate" id="ticker-rate-links">n/a</span>
            <svg class="metric-ticker-chart" id="ticker-chart-links" viewBox="0 0 72 16" preserveAspectRatio="none" aria-hidden="true"></svg>
          </div>
        </div>
        <div class="summary-ticker-item" id="summary-ticker-chat-channels" data-ticker-id="chat_channels">
          <div class="label" data-ticker-label>Chat Channels</div>
          <div class="value node-ticker-value" id="m-chat-channels">n/a</div>
        </div>
        <div class="summary-ticker-item" id="summary-ticker-chat-roster" data-ticker-id="chat_roster">
          <div class="label" data-ticker-label>Roster Health</div>
          <div class="value node-ticker-value" id="m-chat-roster">n/a</div>
        </div>
        <div class="summary-ticker-item" id="summary-ticker-gps" data-ticker-id="gps">
          <div class="label" data-ticker-label>GPS</div>
          <div class="value node-ticker-value" id="m-gps-ticker">n/a</div>
        </div>
        <div class="summary-ticker-item" id="summary-ticker-system" data-ticker-id="system">
          <div class="label" data-ticker-label>System</div>
          <div class="value node-ticker-value" id="m-system-ticker">n/a</div>
        </div>
        <div class="summary-ticker-item summary-ticker-item-time" id="summary-ticker-time" data-ticker-id="time">
          <div class="label" data-ticker-label>Time</div>
          <div class="value time-ticker-value">
            <div class="time-ticker-row">
              <span class="time-ticker-key">RADIO TIME</span>
              <span class="time-ticker-val" id="m-radio-time">n/a</span>
            </div>
            <div class="time-ticker-row">
              <span class="time-ticker-key">UPTIME</span>
              <span class="time-ticker-val" id="m-uptime">00:00:00</span>
            </div>
          </div>
        </div>
      </div>
      <div id="summary-ticker-expanded-slot" class="summary-ticker-expanded-slot" hidden></div>
    </div>
  </div>

  <div class="workspace-shell chat-panel-open">
    <aside id="chat-left-panel" class="chat-left-panel" aria-label="Global node selection and search">
      <div class="chat-left-head-shell">
        <div class="chat-users-head">
          <button
            id="theme-toggle-inline-btn"
            class="chat-peer-add-toggle-btn chat-users-head-theme-btn"
            type="button"
            data-theme-toggle="compact"
            title="Toggle theme between dark and light"
            aria-label="Toggle theme between dark and light"
            aria-pressed="false"
          >
            <svg class="chat-users-head-theme-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
              <path d="M12 2A10 10 0 0 0 2 12A10 10 0 0 0 12 22V2Z" />
            </svg>
          </button>
          <div class="workspace-launcher-shell chat-users-head-launcher-shell">
            <button
              id="layout-view-menu-btn"
              class="topbar-view-menu-btn"
              type="button"
              title="Switch workspace view"
              aria-label="Switch workspace view"
              aria-haspopup="menu"
              aria-expanded="false"
            >
              <span class="topbar-view-menu-btn-main">
                <span id="layout-view-menu-btn-label" class="topbar-view-menu-btn-label">
                  <span id="layout-view-menu-btn-label-text" class="topbar-view-menu-btn-label-text">Chat</span>
                </span>
                <span id="layout-view-menu-btn-badge" class="topbar-view-menu-btn-badge" hidden>0</span>
                <span id="layout-view-menu-attention-indicator" class="topbar-view-menu-btn-attention" hidden aria-hidden="true"></span>
                <span class="topbar-view-menu-caret" aria-hidden="true"></span>
              </span>
            </button>
            <div id="layout-view-menu" class="topbar-view-menu" role="menu" hidden>
              <button
                class="topbar-view-menu-item is-active"
                data-view="chat"
                type="button"
                role="menuitemradio"
                aria-checked="true"
                title="Teams-style chat workspace"
              >
                <span class="topbar-view-menu-item-icon" aria-hidden="true">CH</span>
                <span class="topbar-view-menu-item-copy">
                  <span class="topbar-view-menu-item-label">Chat</span>
                  <span class="topbar-view-menu-item-meta">Messages</span>
                </span>
                <span class="topbar-view-menu-item-badge" hidden>0</span>
              </button>
              <button
                class="topbar-view-menu-item"
                data-view="network"
                type="button"
                role="menuitemradio"
                aria-checked="false"
                title="Topology, nodes, and links"
              >
                <span class="topbar-view-menu-item-icon" aria-hidden="true">NW</span>
                <span class="topbar-view-menu-item-copy">
                  <span class="topbar-view-menu-item-label">Network</span>
                  <span class="topbar-view-menu-item-meta">Map and nodes</span>
                </span>
                <span class="topbar-view-menu-item-badge" hidden>0</span>
              </button>
              <button
                class="topbar-view-menu-item"
                data-view="console"
                type="button"
                role="menuitemradio"
                aria-checked="false"
                title="Realtime dashboard console"
              >
                <span class="topbar-view-menu-item-icon" aria-hidden="true">CL</span>
                <span class="topbar-view-menu-item-copy">
                  <span class="topbar-view-menu-item-label">Console</span>
                  <span class="topbar-view-menu-item-meta">Live logs</span>
                </span>
                <span class="topbar-view-menu-item-badge" hidden>0</span>
              </button>
              <div class="topbar-view-menu-group topbar-view-menu-group-apps">
                <button
                  class="topbar-view-menu-item topbar-view-menu-item-has-submenu"
                  data-view="apps"
                  data-submenu="apps"
                  type="button"
                  role="menuitem"
                  aria-haspopup="menu"
                  aria-expanded="false"
                  title="Games and app workspaces"
                >
                  <span class="topbar-view-menu-item-icon" aria-hidden="true">AP</span>
                  <span class="topbar-view-menu-item-copy">
                    <span class="topbar-view-menu-item-label-row">
                      <span class="topbar-view-menu-item-label">Apps</span>
                      <span id="layout-view-menu-apps-current" class="topbar-view-menu-item-context">Games</span>
                    </span>
                    <span id="layout-view-menu-apps-meta" class="topbar-view-menu-item-meta">Games and extras</span>
                  </span>
                  <span class="topbar-view-menu-item-badge" hidden>0</span>
                  <span class="topbar-view-menu-item-branch" aria-hidden="true"></span>
                </button>
                <div id="layout-view-menu-apps-submenu" class="topbar-view-submenu" role="menu" hidden>
                  <button
                    class="topbar-view-submenu-item is-active"
                    data-view="games"
                    data-app-view="games"
                    type="button"
                    role="menuitemradio"
                    aria-checked="true"
                    title="Games workspace"
                  >
                    <span class="topbar-view-submenu-item-icon" aria-hidden="true">GM</span>
                    <span class="topbar-view-submenu-item-copy">
                      <span class="topbar-view-submenu-item-label">Games</span>
                      <span class="topbar-view-submenu-item-meta">Boards and matches</span>
                    </span>
                  </button>
                  <button
                    class="topbar-view-submenu-item"
                    data-view="bbs"
                    data-app-view="bbs"
                    type="button"
                    role="menuitemradio"
                    aria-checked="false"
                    title="BBS workspace"
                    {bbs_app_tab_hidden_attrs}
                  >
                    <span class="topbar-view-submenu-item-icon" aria-hidden="true">BB</span>
                    <span class="topbar-view-submenu-item-copy">
                      <span class="topbar-view-submenu-item-label">BBS</span>
                      <span class="topbar-view-submenu-item-meta">Profiles and MOTDs</span>
                    </span>
                  </button>
                  <button
                    class="topbar-view-submenu-item"
                    data-view="files"
                    data-app-view="files"
                    type="button"
                    role="menuitemradio"
                    aria-checked="false"
                    title="Files workspace"
                    {file_transfer_files_tab_hidden_attrs}
                  >
                    <span class="topbar-view-submenu-item-icon" aria-hidden="true">FL</span>
                    <span class="topbar-view-submenu-item-copy">
                      <span class="topbar-view-submenu-item-label">Files</span>
                      <span class="topbar-view-submenu-item-meta">Transfers and inbox</span>
                    </span>
                  </button>
                </div>
              </div>
              <button
                class="topbar-view-menu-item"
                data-view="settings"
                type="button"
                role="menuitemradio"
                aria-checked="false"
                title="Radio + dashboard settings"
              >
                <span class="topbar-view-menu-item-icon" aria-hidden="true">ST</span>
                <span class="topbar-view-menu-item-copy">
                  <span class="topbar-view-menu-item-label">Settings</span>
                  <span class="topbar-view-menu-item-meta">Radio settings</span>
                </span>
                <span class="topbar-view-menu-item-badge" hidden>0</span>
              </button>
            </div>
          </div>
          <div class="chat-users-head-actions">
            <button
              id="chat-panel-collapse-btn"
              class="chat-peer-add-toggle-btn chat-panel-collapse-btn chat-users-head-action-btn"
              type="button"
              title="Collapse node list"
              aria-label="Collapse node list"
              aria-pressed="false"
              aria-controls="chat-left-panel"
            >
              <svg id="chat-panel-collapse-glyph" class="chat-panel-collapse-glyph" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                <path class="chat-panel-collapse-glyph-collapse" d="M7 5V19M15 7L11 12L15 17" />
                <path class="chat-panel-collapse-glyph-expand" d="M17 5V19M9 7L13 12L9 17" />
              </svg>
            </button>
            <button id="chat-peer-add-toggle-btn" class="chat-peer-add-toggle-btn" type="button" title="Add a peer-to-peer user" hidden>Add</button>
          </div>
        </div>
        <div id="chat-peer-add-panel" class="chat-peer-add-panel" hidden>
          <div class="chat-peer-add-row">
            <select id="chat-peer-detected-select" class="chat-peer-input" aria-label="Detected node"></select>
            <button id="chat-peer-add-detected-btn" class="chat-peer-add-btn" type="button">Add detected</button>
          </div>
          <div class="chat-peer-add-row">
            <input id="chat-peer-manual-input" class="chat-peer-input" type="text" placeholder="Node ID (e.g. !1234abcd)" autocomplete="off" spellcheck="false" />
            <button id="chat-peer-add-manual-btn" class="chat-peer-add-btn" type="button">Add ID</button>
          </div>
          <div class="chat-peer-add-help">Add peers from detected nodes or manually by Node ID.</div>
          <div class="chat-peer-saved-wrap">
            <div class="chat-peer-saved-title">Saved peers</div>
            <div id="chat-peer-saved-list" class="chat-peer-saved-list"></div>
          </div>
        </div>
      </div>
      <div class="chat-left-section chat-users-section chat-left-roster-shell">
        <div id="chat-room-unread-shell" class="chat-member-pinned-shell" hidden>
          <div class="chat-member-pinned-head">
            <span class="chat-member-pinned-title">Unread</span>
            <span id="chat-room-unread-count" class="chat-member-pinned-count">0</span>
          </div>
          <div id="chat-room-unread-list" class="chat-member-pinned-list"></div>
        </div>
        <div id="chat-room-pinned-shell" class="chat-member-pinned-shell" hidden>
          <div class="chat-member-pinned-head">
            <span class="chat-member-pinned-title">Pinned</span>
            <span id="chat-room-pinned-count" class="chat-member-pinned-count">0</span>
          </div>
          <div id="chat-room-pinned-list" class="chat-member-pinned-list"></div>
        </div>
        <div id="chat-room-list" class="chat-member-list"></div>
        <div
          id="chat-node-details-splitter"
          class="chat-node-details-splitter"
          title="Drag to resize user list and node details"
          hidden
        ></div>
        <section id="chat-node-details-drawer" class="chat-node-details-drawer" hidden>
          <div class="chat-node-details-head">
            <div class="chat-node-details-head-main">
              <button
                id="chat-node-details-icon-btn"
                class="chat-node-details-icon-btn"
                type="button"
                title="Set node icon"
                aria-label="Set node icon"
              ><span id="chat-node-details-icon-chip" class="chat-node-details-icon-chip is-empty" aria-hidden="true">+</span></button>
              <input id="chat-node-details-head-icon-input" type="text" hidden aria-hidden="true" tabindex="-1" />
              <button
                id="chat-node-details-tab-tag"
                class="chat-node-details-tab-btn chat-node-details-tab-tag-btn chat-node-details-head-tag-btn"
                type="button"
                role="tab"
                aria-selected="false"
                data-drawer-tab="tag"
                title="Add or edit node tag"
                aria-label="Add or edit node tag"
              ><span id="chat-node-details-tab-tag-label" class="chat-node-details-tab-tag-label">+tag</span></button>
              <button
                id="chat-node-details-reset-btn"
                class="chat-node-details-action-btn chat-node-details-reset-btn"
                type="button"
                title="Clear saved tag and custom icon"
                aria-label="Clear saved tag and custom icon"
                hidden
              >Reset</button>
              <div id="chat-node-details-title" class="chat-node-details-title">Node Details</div>
              <div class="chat-node-details-head-actions">
                <button
                  id="chat-node-details-pin-btn"
                  class="pin-toggle-btn chat-node-details-action-btn chat-node-details-pin-btn"
                  type="button"
                  title="Pin this node to the top of the chat list"
                  aria-label="Pin this node to the top of the chat list"
                  aria-pressed="false"
                  hidden
                ><span class="chat-node-details-pin-label">Pin</span></button>
                <button
                  id="chat-node-details-mute-btn"
                  class="mute-toggle-btn chat-node-details-action-btn chat-node-details-mute-btn"
                  type="button"
                  title="Mute this user in chat feed"
                  aria-pressed="false"
                  hidden
                ><span class="chat-node-details-mute-label">Mute</span></button>
              </div>
            </div>
            <button
              id="chat-node-details-close-btn"
              class="chat-node-details-close-btn"
              type="button"
              title="Collapse node details"
              aria-label="Collapse node details"
            >&times;</button>
          </div>
          <div class="chat-node-details-tabs" role="tablist" aria-label="Selected node detail tabs">
            <button
              id="chat-node-details-tab-messages"
              class="chat-node-details-tab-btn"
              type="button"
              role="tab"
              aria-selected="false"
              data-drawer-tab="messages"
            >Messages</button>
            <button
              id="chat-node-details-tab-details"
              class="chat-node-details-tab-btn is-active"
              type="button"
              role="tab"
              aria-selected="true"
              data-drawer-tab="details"
            >Details</button>
            <button
              id="chat-node-details-tab-history"
              class="chat-node-details-tab-btn"
              type="button"
              role="tab"
              aria-selected="false"
              data-drawer-tab="history"
            >History</button>
            <button
              id="chat-node-details-tab-location"
              class="chat-node-details-tab-btn"
              type="button"
              role="tab"
              aria-selected="false"
              data-drawer-tab="location"
