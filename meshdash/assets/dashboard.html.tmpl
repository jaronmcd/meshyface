<!doctype html>
<html>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{app_title}</title>
  <link
    rel="stylesheet"
    href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
    integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
    crossorigin=""
  />
  <style>
{style_css}
  </style>
</head>
<body>
  <div class="topbar">
    <div class="topbar-notify-corner">
      <div class="self-radio-menu-wrap topbar-self-radio-menu-wrap">
        <button
          id="self-radio-profile"
          class="topbar-self-profile"
          type="button"
          title="Connected local radio: unavailable"
          aria-label="Connected local radio"
          aria-haspopup="menu"
          aria-expanded="false"
        >
          <span id="self-radio-profile-short" class="topbar-self-profile-short">na</span>
        </button>
        <div id="self-radio-menu" class="self-radio-menu" hidden>
          <button
            id="self-radio-copy-id-btn"
            class="self-radio-menu-item"
            type="button"
            title="Full radio ID unavailable"
            disabled
          >
            Copy full radio ID
          </button>
        </div>
      </div>
      <div class="chat-change-menu-wrap topbar-chat-change-menu-wrap">
        <button
          id="chat-change-toggle-btn"
          class="chat-change-toggle-btn"
          type="button"
          title="No missed updates"
          aria-label="Missed updates"
          aria-haspopup="menu"
          aria-expanded="false"
        >
          <svg class="chat-change-toggle-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
            <path d="M12 22c1.32 0 2.4-1.08 2.4-2.4h-4.8c0 1.32 1.08 2.4 2.4 2.4Zm7.2-7.2v-5.4c0-3.31-2.05-6.09-4.95-7.08v-.72a2.25 2.25 0 0 0-4.5 0v.72C6.85 3.31 4.8 6.09 4.8 9.4v5.4l-2.1 2.1v1.2h18.6v-1.2l-2.1-2.1Z"/>
          </svg>
          <span id="chat-change-badge" class="chat-change-badge" hidden>0</span>
        </button>
        <div id="chat-change-summary" class="chat-change-menu" hidden></div>
      </div>
      <div class="peer-dm-menu-wrap topbar-peer-dm-menu-wrap">
        <button
          id="peer-dm-toggle-btn"
          class="peer-dm-toggle-btn"
          type="button"
          title="Peer conversations"
          aria-label="Peer conversations"
          aria-haspopup="menu"
          aria-expanded="false"
        >
          <svg class="peer-dm-toggle-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
            <path d="M4.5 5.5h15a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H11l-4.5 3v-3H4.5a2 2 0 0 1-2-2v-8a2 2 0 0 1 2-2Z"/>
            <path d="M7.5 10.25h9M7.5 13.25h6.5"/>
          </svg>
          <span id="peer-dm-badge" class="peer-dm-badge" hidden>0</span>
        </button>
        <div id="peer-dm-menu" class="peer-dm-menu" hidden>
          <div id="peer-dm-menu-list" class="peer-dm-menu-list">
            <div class="peer-dm-menu-empty">No peer-to-peer conversations yet.</div>
          </div>
        </div>
      </div>
      <div class="chat-settings-menu-wrap topbar-chat-settings-menu-wrap">
        <button
          id="chat-settings-toggle-btn"
          class="chat-settings-toggle-btn"
          type="button"
          title="Dashboard settings"
          aria-label="Dashboard settings"
          aria-haspopup="menu"
          aria-expanded="false"
        >
          <svg class="chat-settings-toggle-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
            <path d="M19.14 12.94a7.92 7.92 0 0 0 .06-.94 7.92 7.92 0 0 0-.06-.94l2.03-1.58a.5.5 0 0 0 .12-.63l-1.92-3.32a.5.5 0 0 0-.6-.22l-2.39.96a7.38 7.38 0 0 0-1.63-.94l-.36-2.54a.5.5 0 0 0-.5-.43h-3.84a.5.5 0 0 0-.5.43l-.36 2.54a7.38 7.38 0 0 0-1.63.94l-2.39-.96a.5.5 0 0 0-.6.22L2.71 8.85a.5.5 0 0 0 .12.63l2.03 1.58a7.92 7.92 0 0 0-.06.94 7.92 7.92 0 0 0 .06.94l-2.03 1.58a.5.5 0 0 0-.12.63l1.92 3.32a.5.5 0 0 0 .6.22l2.39-.96c.5.39 1.05.71 1.63.94l.36 2.54a.5.5 0 0 0 .5.43h3.84a.5.5 0 0 0 .5-.43l.36-2.54c.58-.23 1.13-.55 1.63-.94l2.39.96a.5.5 0 0 0 .6-.22l1.92-3.32a.5.5 0 0 0-.12-.63l-2.03-1.58ZM12 15.2A3.2 3.2 0 1 1 12 8.8a3.2 3.2 0 0 1 0 6.4Z"/>
          </svg>
        </button>
        <div id="chat-settings-menu" class="chat-settings-menu" hidden>
          <section class="chat-settings-section chat-settings-theme-section" aria-label="Theme">
            <h3 class="chat-settings-section-title">Theme</h3>
            <button id="theme-toggle-btn" class="theme-btn chat-settings-theme-btn" type="button" title="Toggle theme between dark and light">Theme: Dark</button>
            <label for="theme-preset-select" class="theme-preset-wrap chat-settings-theme-preset-wrap" title="Runtime color preset">
              <span class="theme-preset-label">Preset</span>
              <select id="theme-preset-select" class="theme-preset-select" aria-label="Theme preset">
                <option value="default">default</option>
              </select>
            </label>
          </section>
          <section class="chat-settings-section" aria-label="Runtime">
            <h3 class="chat-settings-section-title">Runtime</h3>
            <div class="chat-settings-meta-list">
              <div class="chat-settings-meta-item">{safety_label}</div>
              <div class="chat-settings-meta-item">Packet buffer: {packet_limit}</div>
              <div class="chat-settings-meta-item">{history_label}</div>
              <div class="chat-settings-meta-item">Refresh: {refresh_ms} ms</div>
            </div>
            <span id="disk-meter" class="disk-meter" title="Disk free on dashboard host">
              <span id="disk-label" class="disk-label">Disk free: n/a</span>
              <span class="disk-track"><span id="disk-fill" class="disk-fill"></span></span>
            </span>
          </section>
          <section class="chat-settings-section" aria-label="Notifications">
            <h3 class="chat-settings-section-title">Notifications</h3>
            <div class="chat-settings-meta-list" title="Notification behavior">
              <div class="chat-settings-meta-item">Chat counter: all inbound chat activity</div>
              <div class="chat-settings-meta-item">Bell: inbound to you, replies to you, and reactions to you</div>
            </div>
          </section>
        </div>
      </div>
      <div class="favorite-menu-wrap topbar-favorite-menu-wrap">
        <button
          id="favorite-menu-toggle-btn"
          class="favorite-menu-toggle-btn"
          type="button"
          title="Node menu"
          aria-label="Node menu"
          aria-haspopup="menu"
          aria-expanded="false"
        >
          <svg id="favorite-menu-toggle-icon" class="favorite-menu-toggle-icon" viewBox="0 0 20 20" aria-hidden="true" focusable="false">
            <rect x="2.5" y="4.5" width="9.5" height="6.5" rx="1.4"></rect>
            <path d="M5.8 13h2.9m-1.45 0v2m-2.4 0h4.8"></path>
            <circle class="node-signal-dot" cx="14.7" cy="6.2" r="0.9"></circle>
            <path d="M16.8 7.2a3.4 3.4 0 0 0-2.1-3.15"></path>
            <path d="M18.4 8.7a5.4 5.4 0 0 0-3.35-5.05"></path>
          </svg>
        </button>
        <div id="favorite-menu" class="favorite-menu" hidden>
          <section class="favorite-menu-section" aria-label="Selected node">
            <h3 class="favorite-menu-title">Selected</h3>
            <div id="favorite-menu-selected-list" class="favorite-menu-saved-list favorite-menu-selected-list" role="list" aria-label="Selected node">
              <div class="favorite-menu-node-search-wrap">
                <input
                  id="favorite-menu-node-search-input"
                  class="list-search-input"
                  type="search"
                  placeholder="Search by ID or name"
                  autocomplete="off"
                />
                <div id="favorite-menu-node-search-dropdown" class="node-search-dropdown favorite-menu-node-search-dropdown" hidden></div>
              </div>
            </div>
          </section>
          <section class="favorite-menu-section" aria-label="Saved nodes">
            <h3 class="favorite-menu-title">Saved nodes</h3>
            <div id="favorite-menu-saved-list" class="favorite-menu-saved-list" role="list" aria-label="Saved nodes">
              <div class="favorite-menu-saved-empty">No saved nodes yet.</div>
            </div>
          </section>
        </div>
      </div>
    </div>
    <div class="topbar-main-row">
      <div class="topbar-brand">
        <h1 class="topbar-heading">
          <span class="topbar-heading-app">{app_heading}</span>
        </h1>
        <span id="revision-text" class="sub-text revision-text" title="{revision_title}">{revision_label}</span>
      </div>
      <span id="topbar-chat-context" class="topbar-chat-context" title="Connected local radio: unavailable">n/a</span>
      <span class="topbar-main-spacer" aria-hidden="true"></span>
    </div>
    <div class="sub">
      <div class="sub-main">
        <div id="topbar-update-ticker" class="topbar-update-ticker" role="status" aria-live="polite" aria-label="Live update ticker" hidden>
          <div id="topbar-update-viewport" class="topbar-update-viewport">
            <div id="topbar-update-track" class="topbar-update-track">
              <span id="topbar-update-text-primary" class="topbar-update-text"></span>
              <span id="topbar-update-text-secondary" class="topbar-update-text" aria-hidden="true"></span>
            </div>
          </div>
        </div>
      </div>
      <div class="summary-ticker-row" aria-label="Summary tickers">
        <div class="summary-ticker-item summary-ticker-item-target" id="summary-ticker-target" data-ticker-id="target">
          <div class="label" data-ticker-label>Target</div>
          <div class="value" id="m-target">n/a</div>
          <div class="target-radio-status status-warn" id="m-target-radio-status" title="Radio status unavailable">Radio: n/a</div>
        </div>
        <div class="summary-ticker-item" id="summary-ticker-known-nodes" data-ticker-id="known_nodes">
          <div class="label" data-ticker-label>Known Nodes</div>
          <div class="value" id="m-nodes">0</div>
          <div class="metric-ticker" id="ticker-nodes" hidden>
            <span class="metric-ticker-delta" id="ticker-delta-nodes">n/a</span>
            <span class="metric-ticker-rate" id="ticker-rate-nodes">n/a</span>
            <svg class="metric-ticker-chart" id="ticker-chart-nodes" viewBox="0 0 72 16" preserveAspectRatio="none" aria-hidden="true"></svg>
          </div>
        </div>
        <div class="summary-ticker-item" id="summary-ticker-online-nodes" data-ticker-id="online_nodes">
          <div class="label" data-ticker-label>Nodes Online</div>
          <div class="value" id="m-online-nodes">0</div>
          <div class="metric-ticker" id="ticker-online-nodes" hidden>
            <span class="metric-ticker-delta" id="ticker-delta-online-nodes">n/a</span>
            <span class="metric-ticker-rate" id="ticker-rate-online-nodes">n/a</span>
            <svg class="metric-ticker-chart" id="ticker-chart-online-nodes" viewBox="0 0 72 16" preserveAspectRatio="none" aria-hidden="true"></svg>
          </div>
        </div>
        <div class="summary-ticker-item" id="summary-ticker-packets" data-ticker-id="packets_per_min">
          <div class="label" data-ticker-label>Packets / min</div>
          <div class="value" id="m-live-packets">0</div>
          <div class="metric-ticker" id="ticker-live-packets" hidden>
            <span class="metric-ticker-delta" id="ticker-delta-live-packets">n/a</span>
            <span class="metric-ticker-rate" id="ticker-rate-live-packets">n/a</span>
            <svg class="metric-ticker-chart" id="ticker-chart-live-packets" viewBox="0 0 72 16" preserveAspectRatio="none" aria-hidden="true"></svg>
          </div>
        </div>
        <div class="summary-ticker-item" id="summary-ticker-channel-util" data-ticker-id="channel_util">
          <div class="label" data-ticker-label>Channel Util</div>
          <div class="value" id="m-channel-util">n/a</div>
          <div class="metric-ticker" id="ticker-channel-util" hidden>
            <span class="metric-ticker-delta" id="ticker-delta-channel-util">n/a</span>
            <span class="metric-ticker-rate" id="ticker-rate-channel-util">n/a</span>
            <svg class="metric-ticker-chart" id="ticker-chart-channel-util" viewBox="0 0 72 16" preserveAspectRatio="none" aria-hidden="true"></svg>
          </div>
        </div>
        <div class="summary-ticker-item" id="summary-ticker-battery" data-ticker-id="battery">
          <div class="label" data-ticker-label>Battery</div>
          <div class="value" id="m-battery">n/a</div>
          <div class="metric-ticker" id="ticker-battery" hidden>
            <span class="metric-ticker-delta" id="ticker-delta-battery">n/a</span>
            <span class="metric-ticker-rate" id="ticker-rate-battery">n/a</span>
            <svg class="metric-ticker-chart" id="ticker-chart-battery" viewBox="0 0 72 16" preserveAspectRatio="none" aria-hidden="true"></svg>
          </div>
        </div>
        <div class="summary-ticker-item" id="summary-ticker-temperature" data-ticker-id="temperature">
          <div class="label" data-ticker-label>Temp</div>
          <div class="value" id="m-temperature">n/a</div>
          <div class="metric-ticker" id="ticker-temperature" hidden>
            <span class="metric-ticker-delta" id="ticker-delta-temperature">n/a</span>
            <span class="metric-ticker-rate" id="ticker-rate-temperature">n/a</span>
            <svg class="metric-ticker-chart" id="ticker-chart-temperature" viewBox="0 0 72 16" preserveAspectRatio="none" aria-hidden="true"></svg>
          </div>
        </div>
        <div class="summary-ticker-item" id="summary-ticker-humidity" data-ticker-id="humidity">
          <div class="label" data-ticker-label>Humidity</div>
          <div class="value" id="m-humidity">n/a</div>
          <div class="metric-ticker" id="ticker-humidity" hidden>
            <span class="metric-ticker-delta" id="ticker-delta-humidity">n/a</span>
            <span class="metric-ticker-rate" id="ticker-rate-humidity">n/a</span>
            <svg class="metric-ticker-chart" id="ticker-chart-humidity" viewBox="0 0 72 16" preserveAspectRatio="none" aria-hidden="true"></svg>
          </div>
        </div>
        <div class="summary-ticker-item" id="summary-ticker-pressure" data-ticker-id="pressure">
          <div class="label" data-ticker-label>Pressure</div>
          <div class="value" id="m-pressure">n/a</div>
          <div class="metric-ticker" id="ticker-pressure" hidden>
            <span class="metric-ticker-delta" id="ticker-delta-pressure">n/a</span>
            <span class="metric-ticker-rate" id="ticker-rate-pressure">n/a</span>
            <svg class="metric-ticker-chart" id="ticker-chart-pressure" viewBox="0 0 72 16" preserveAspectRatio="none" aria-hidden="true"></svg>
          </div>
        </div>
        <div class="summary-ticker-item" id="summary-ticker-wifi" data-ticker-id="wifi">
          <div class="label" data-ticker-label>Wi-Fi</div>
          <div class="value wifi-ticker-value" id="m-wifi-ticker">n/a</div>
          <div class="metric-ticker" id="ticker-wifi" hidden>
            <span class="metric-ticker-delta" id="ticker-delta-wifi">n/a</span>
            <span class="metric-ticker-rate" id="ticker-rate-wifi">n/a</span>
            <svg class="metric-ticker-chart" id="ticker-chart-wifi" viewBox="0 0 72 16" preserveAspectRatio="none" aria-hidden="true"></svg>
          </div>
        </div>
        <div class="summary-ticker-item" id="summary-ticker-node" data-ticker-id="node">
          <div class="label" data-ticker-label>Link</div>
          <div class="value node-ticker-value" id="m-node-ticker">n/a</div>
          <div class="metric-ticker" id="ticker-node-signal" hidden>
            <span class="metric-ticker-delta" id="ticker-delta-node-signal">n/a</span>
            <span class="metric-ticker-rate" id="ticker-rate-node-signal">n/a</span>
            <svg class="metric-ticker-chart" id="ticker-chart-node-signal" viewBox="0 0 72 16" preserveAspectRatio="none" aria-hidden="true"></svg>
          </div>
        </div>
        <div class="summary-ticker-item" id="summary-ticker-chat-channels" data-ticker-id="chat_channels">
          <div class="label" data-ticker-label>Chat Channels</div>
          <div class="value node-ticker-value" id="m-chat-channels">n/a</div>
        </div>
        <div class="summary-ticker-item" id="summary-ticker-chat-roster" data-ticker-id="chat_roster">
          <div class="label" data-ticker-label>Roster Health</div>
          <div class="value node-ticker-value" id="m-chat-roster">n/a</div>
        </div>
        <div class="summary-ticker-item" id="summary-ticker-gps" data-ticker-id="gps">
          <div class="label" data-ticker-label>GPS</div>
          <div class="value node-ticker-value" id="m-gps-ticker">n/a</div>
        </div>
        <div class="summary-ticker-item" id="summary-ticker-system" data-ticker-id="system">
          <div class="label" data-ticker-label>System</div>
          <div class="value node-ticker-value" id="m-system-ticker">n/a</div>
        </div>
        <div class="summary-ticker-item summary-ticker-item-time" id="summary-ticker-time" data-ticker-id="time">
          <div class="label" data-ticker-label>Time</div>
          <div class="value time-ticker-value">
            <div class="time-ticker-row">
              <span class="time-ticker-key">RADIO TIME</span>
              <span class="time-ticker-val" id="m-radio-time">n/a</span>
            </div>
            <div class="time-ticker-row">
              <span class="time-ticker-key">UPTIME</span>
              <span class="time-ticker-val" id="m-uptime">00:00:00</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="workspace-shell chat-panel-open">
    <aside class="teams-rail" aria-label="Dashboard views">
      <button class="rail-btn active" data-view="chat" type="button" title="Teams-style chat workspace">Chat</button>
      <button class="rail-btn" data-view="macros" type="button" title="Raw live chat workspace for macro design">MACROS</button>
      <button class="rail-btn" data-view="network" type="button" title="Topology, nodes, and links">Network</button>
      <button class="rail-btn" data-view="saved" type="button" title="Node details and saved nodes">Node</button>
      <button class="rail-btn" data-view="remote" type="button" title="Remote-node actions workspace">Remote</button>
      <button class="rail-btn" data-view="packets" type="button" title="Recent packet stream">Packets</button>
      <button class="rail-btn" data-view="channels" type="button" title="Inferred message channel activity">Channels</button>
      <button class="rail-btn" data-view="encription" type="button" title="Encrypted packets and route activity">Encription</button>
      <button class="rail-btn" data-view="data" type="button" title="Raw node/config views">Data</button>
      <button class="rail-btn" data-view="environment" type="button" title="Historical sensor telemetry">Sensors</button>
      <button class="rail-btn" data-view="history" type="button" title="Network and chat history">History</button>
      <button class="rail-btn" data-view="console" type="button" title="Realtime dashboard console">Console</button>
      <button class="rail-btn" data-view="bots" type="button" title="Mesh bot tools and request history">Bots</button>
      <button class="rail-btn" data-view="files" type="button" title="Peer-to-peer file transfer">Files</button>
      <button class="rail-btn" data-view="bbs" type="button" title="Retro dial-up style bulletin board">BBS</button>
      <button class="rail-btn" data-view="games" type="button" title="Local game prototypes">Games</button>
      <button class="rail-btn" data-view="settings" type="button" title="Radio + dashboard settings">Settings</button>
    </aside>
    <aside id="chat-left-panel" class="chat-left-panel" aria-label="Global node selection and search">
      <div class="chat-left-head">
        <div class="chat-user-search-wrap">
          <input id="chat-user-search-input" class="list-search-input" type="search" placeholder="Search nodes by ID or name" autocomplete="off" />
        </div>
      </div>
      <div class="chat-left-section chat-users-section">
        <div class="chat-users-head">
          <div id="chat-users-title" class="chat-left-label">Users</div>
          <button id="chat-peer-add-toggle-btn" class="chat-peer-add-toggle-btn" type="button" title="Add a peer-to-peer user" hidden>Add</button>
        </div>
        <div id="chat-peer-add-panel" class="chat-peer-add-panel" hidden>
          <div class="chat-peer-add-row">
            <select id="chat-peer-detected-select" class="chat-peer-input" aria-label="Detected node"></select>
            <button id="chat-peer-add-detected-btn" class="chat-peer-add-btn" type="button">Add detected</button>
          </div>
          <div class="chat-peer-add-row">
            <input id="chat-peer-manual-input" class="chat-peer-input" type="text" placeholder="Node ID (e.g. !49b54790)" autocomplete="off" spellcheck="false" />
            <button id="chat-peer-add-manual-btn" class="chat-peer-add-btn" type="button">Add ID</button>
          </div>
          <div class="chat-peer-add-help">Add peers from detected nodes or manually by Node ID.</div>
          <div class="chat-peer-saved-wrap">
            <div class="chat-peer-saved-title">Saved peers</div>
            <div id="chat-peer-saved-list" class="chat-peer-saved-list"></div>
          </div>
        </div>
        <div id="chat-room-list" class="chat-member-list"></div>
      </div>
    </aside>
    <div id="chat-panel-splitter" class="chat-panel-splitter" title="Drag to resize chat workspace and node navigator" aria-hidden="true"></div>
    <main class="workspace-main">
  <div id="dashboard-layout" class="layout view-chat">
    <section class="card settings" aria-label="Settings">
      <div class="settings-card-head">
        <h2>Settings</h2>
        <div class="settings-caption" id="settings-caption">
          Configure the connected radio. Some changes (especially LoRa) may reboot the device.
        </div>
      </div>
      <div class="body">
        <div class="settings-tabbar" role="tablist" aria-label="Settings categories">
          <button
            id="settings-tab-core-btn"
            class="settings-tab-btn is-active"
            type="button"
            role="tab"
            aria-selected="true"
            data-settings-tab="core"
          >
            Core
          </button>
          <button
            id="settings-tab-device-btn"
            class="settings-tab-btn"
            type="button"
            role="tab"
            aria-selected="false"
            data-settings-tab="device"
          >
            Device
          </button>
          <button
            id="settings-tab-connectivity-btn"
            class="settings-tab-btn"
            type="button"
            role="tab"
            aria-selected="false"
            data-settings-tab="connectivity"
          >
            Connectivity
          </button>
          <button
            id="settings-tab-security-btn"
            class="settings-tab-btn"
