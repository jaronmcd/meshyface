{theme_css}
    * {{ box-sizing: border-box; }}
    :root {{
      --topbar-sticky-offset: 72px;
      --workspace-viewport-offset: 84px;
      --topbar-right-inset: max(8px, env(safe-area-inset-right));
      --topbar-corner-reserve: 36px;
      --floating-stage-bg: color-mix(in srgb, var(--accent) 64%, var(--accent-2) 36%);
    }}
    html, body {{
      margin: 0;
      padding: 0;
      font-family: "IBM Plex Sans", "Segoe UI", sans-serif;
      color: var(--ink);
      background: var(--bg);
      min-height: 100%;
      min-height: 100vh;
      min-height: 100dvh;
      height: 100%;
      overflow: hidden;
    }}
    body {{
      display: flex;
      flex-direction: column;
      min-height: 100dvh;
    }}
    .topbar {{
      padding: 8px 8px 0;
      background: var(--floating-stage-bg);
      color: #f4fff7;
      box-shadow: none;
      position: sticky;
      top: 0;
      z-index: 1200;
      padding-right: var(--topbar-right-inset);
      flex: 0 0 auto;
    }}
    .topbar-notify-corner {{
      position: absolute;
      top: 8px;
      right: var(--topbar-right-inset);
      z-index: 2;
      display: inline-flex;
      align-items: center;
      justify-content: flex-end;
      flex-direction: row-reverse;
      gap: 6px;
    }}
    .topbar-self-profile {{
      min-width: 30px;
      max-width: min(30vw, 220px);
      height: 30px;
      border-radius: 999px;
      border: 1px solid rgba(214, 238, 223, 0.55);
      background: rgba(248, 255, 251, 0.12);
      color: #f1fff6;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 0 8px;
      margin: 0;
      font: inherit;
      font-size: 14px;
      font-weight: 700;
      line-height: 1;
      letter-spacing: 0.1px;
      white-space: nowrap;
      user-select: none;
      cursor: pointer;
      transition: border-color 140ms ease, background 140ms ease, color 140ms ease, box-shadow 140ms ease;
    }}
    .topbar-self-profile:focus-visible {{
      outline: 2px solid rgba(214, 238, 223, 0.92);
      outline-offset: 2px;
    }}
    .topbar-self-profile.status-online {{
      border-color: rgba(121, 230, 172, 0.78);
      background: rgba(53, 154, 101, 0.26);
      color: #ddffeb;
      box-shadow: 0 0 0 1px rgba(77, 190, 130, 0.32);
    }}
    .topbar-self-profile.status-warn {{
      border-color: rgba(234, 203, 129, 0.82);
      background: rgba(174, 134, 57, 0.24);
      color: #fff0cd;
      box-shadow: 0 0 0 1px rgba(213, 172, 96, 0.3);
    }}
    .topbar-self-profile.status-stale {{
      border-color: rgba(255, 162, 162, 0.88);
      background: rgba(182, 38, 38, 0.3);
      color: #fff0f0;
      box-shadow: 0 0 0 1px rgba(208, 83, 83, 0.34);
    }}
    .topbar-self-profile.status-unknown {{
      border-color: rgba(214, 238, 223, 0.5);
      background: rgba(248, 255, 251, 0.1);
      color: #f1fff6;
    }}
    .topbar-self-profile-short {{
      display: block;
      font-size: inherit;
      font-weight: inherit;
      letter-spacing: inherit;
      text-transform: none;
      max-width: min(20ch, 28vw);
      overflow: hidden;
      text-overflow: ellipsis;
    }}
    .topbar-chat-change-menu-wrap .chat-change-toggle-btn,
    .topbar-peer-dm-menu-wrap .peer-dm-toggle-btn,
    .topbar-chat-settings-menu-wrap .chat-settings-toggle-btn,
    .topbar-favorite-menu-wrap .favorite-menu-toggle-btn {{
      width: 30px;
      height: 30px;
      border-color: rgba(214, 238, 223, 0.55);
      background: rgba(248, 255, 251, 0.12);
      color: #f1fff6;
    }}
    .topbar-chat-change-menu-wrap .chat-change-toggle-btn:hover,
    .topbar-peer-dm-menu-wrap .peer-dm-toggle-btn:hover,
    .topbar-chat-settings-menu-wrap .chat-settings-toggle-btn:hover,
    .topbar-favorite-menu-wrap .favorite-menu-toggle-btn:hover {{
      border-color: rgba(214, 238, 223, 0.82);
      background: rgba(248, 255, 251, 0.22);
      color: #ffffff;
    }}
    .topbar-chat-change-menu-wrap .chat-change-toggle-btn[aria-expanded="true"],
    .topbar-peer-dm-menu-wrap .peer-dm-toggle-btn[aria-expanded="true"],
    .topbar-chat-settings-menu-wrap .chat-settings-toggle-btn[aria-expanded="true"],
    .topbar-favorite-menu-wrap .favorite-menu-toggle-btn[aria-expanded="true"] {{
      border-color: rgba(214, 238, 223, 0.82);
      background: rgba(248, 255, 251, 0.24);
      color: #ffffff;
    }}
    .topbar-chat-change-menu-wrap .chat-change-toggle-btn.has-unread {{
      border-color: #8be0af;
      color: #dbffe9;
      box-shadow: 0 0 0 1px rgba(83, 185, 124, 0.4);
    }}
    .topbar-chat-change-menu-wrap .chat-change-badge {{
      border-color: #173d2d;
    }}
    .topbar-chat-change-menu-wrap .chat-change-menu {{
      top: calc(100% + 10px);
    }}
    .topbar-peer-dm-menu-wrap .peer-dm-menu {{
      top: calc(100% + 10px);
    }}
    .topbar-self-radio-menu-wrap .self-radio-menu {{
      top: calc(100% + 10px);
    }}
    .topbar-chat-settings-menu-wrap .chat-settings-menu {{
      top: calc(100% + 10px);
    }}
    .topbar-favorite-menu-wrap .favorite-menu {{
      top: calc(100% + 10px);
    }}
    .topbar-favorite-menu-wrap .favorite-menu-toggle-btn {{
      width: 30px;
      height: 30px;
      padding: 0;
      border-radius: 999px;
    }}
    .topbar h1 {{
      margin: 0;
      font-size: 20px;
      line-height: 1.04;
      letter-spacing: 0.1px;
    }}
    .topbar .topbar-main-row {{
      display: grid;
      grid-template-columns: minmax(0, max-content) minmax(0, 1fr);
      align-items: center;
      column-gap: 6px;
      min-width: 0;
      min-height: 30px;
    }}
    .topbar .topbar-brand {{
      grid-column: 1;
      justify-self: start;
      display: grid;
      grid-template-columns: minmax(0, 1fr);
      grid-template-rows: auto auto;
      align-items: start;
      row-gap: 0;
      min-width: 0;
      max-width: min(44vw, 520px);
    }}
    .topbar .topbar-heading {{
      display: block;
      align-items: center;
      flex-wrap: nowrap;
      justify-content: flex-start;
      gap: 0;
      text-align: left;
      min-width: 0;
    }}
    .topbar .topbar-heading-app {{
      display: inline-flex;
      align-items: center;
      max-width: min(44vw, 520px);
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }}
    .topbar .topbar-main-row .revision-text {{
      margin: 0;
      max-width: min(44vw, 520px);
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
      font-size: 10px;
      line-height: 1.05;
    }}
    .topbar .topbar-main-spacer {{
      display: none;
    }}
    .topbar-update-ticker {{
      --topbar-update-start: 0px;
      --topbar-update-shift: 420px;
      --topbar-update-duration: 42s;
      flex: none;
      width: 100%;
      min-width: 0;
      max-width: none;
      display: grid;
      grid-template-columns: minmax(0, 1fr);
      align-items: center;
      gap: 6px;
      border: 1px solid rgba(236, 251, 243, 0.72);
      border-radius: 999px;
      background: linear-gradient(90deg, rgba(7, 24, 18, 0.6), rgba(10, 36, 27, 0.38));
      color: #f3fff8;
      padding: 3px 10px;
      min-height: 30px;
      opacity: 1;
      transition: opacity 220ms ease;
      overflow: hidden;
      box-shadow: none;
    }}
    .workspace-update-ticker {{
      flex: 1 1 auto;
      align-self: stretch;
      min-width: 0;
      min-height: 30px;
      margin: 0;
      padding: 0;
    }}
    .topbar .sub {{
      margin-top: 0;
      font-size: 11px;
      opacity: 0.95;
      display: flex;
      flex-direction: column;
      align-items: stretch;
      gap: 8px;
      padding: 0;
      border: 0;
      border-radius: 10px;
      background: var(--floating-stage-bg);
    }}
    .summary-ticker-density-toggle {{
      position: relative;
      z-index: 3;
      appearance: none;
      -webkit-appearance: none;
      border: 1px solid color-mix(in srgb, var(--line) 76%, var(--accent) 24%);
      border-radius: 8px;
      background: color-mix(in srgb, var(--panel) 92%, var(--accent) 8%);
      box-shadow: none;
      margin: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      width: var(--topbar-corner-reserve, 36px);
      min-width: var(--topbar-corner-reserve, 36px);
      max-width: var(--topbar-corner-reserve, 36px);
      min-height: 0;
      max-height: none;
      align-self: stretch;
      order: -1;
      padding: 0;
      font: inherit;
      cursor: pointer;
      transform: none;
      transition: border-color 120ms ease, background 120ms ease, color 120ms ease;
    }}
    .summary-ticker-density-toggle:hover,
    .summary-ticker-density-toggle:focus-visible {{
      border-color: color-mix(in srgb, var(--accent) 56%, var(--line) 44%);
      background: color-mix(in srgb, var(--panel) 84%, var(--accent) 16%);
      box-shadow: none;
      outline: none;
    }}
    .summary-ticker-density-toggle[aria-pressed="true"] {{
      background: color-mix(in srgb, var(--panel) 86%, var(--accent) 14%);
      border-color: color-mix(in srgb, var(--accent) 42%, var(--line) 58%);
    }}
    .summary-ticker-density-toggle-label {{
      position: absolute;
      width: 1px;
      height: 1px;
      padding: 0;
      margin: -1px;
      overflow: hidden;
      clip: rect(0, 0, 0, 0);
      white-space: nowrap;
      border: 0;
    }}
    .summary-ticker-density-toggle-icon {{
      display: none;
    }}
    .summary-ticker-density-toggle-text {{
      display: none;
    }}
    .topbar .sub .summary-ticker-row {{
      position: relative;
      --summary-visible-ticker-count: 10;
      padding-right: 0;
    }}
    .topbar-update-ticker.is-fading {{
      opacity: 0;
    }}
    .topbar-update-ticker-label {{
      display: inline-flex;
      align-items: center;
      font-size: 10px;
      line-height: 1;
      text-transform: uppercase;
      letter-spacing: 0.22em;
      color: rgba(222, 248, 233, 0.82);
      white-space: nowrap;
      user-select: none;
      flex: 0 0 auto;
    }}
    .topbar-update-viewport {{
      width: 100%;
      min-width: 0;
      display: flex;
      align-items: center;
      overflow: hidden;
      mask-image: linear-gradient(to right, transparent 0, #000 3%, #000 97%, transparent 100%);
      -webkit-mask-image: linear-gradient(to right, transparent 0, #000 3%, #000 97%, transparent 100%);
    }}
    .topbar-update-track {{
      position: relative;
      display: block;
      width: 100%;
      min-width: 0;
      min-height: 1.2em;
      animation: none;
      transform: none;
      overflow: visible;
    }}
    .topbar-update-text {{
      display: none;
      align-items: center;
      font-size: 14px;
      line-height: 1.2;
      letter-spacing: 0.12px;
      color: rgba(244, 255, 249, 0.96);
      white-space: nowrap;
      text-shadow: 0 0 8px rgba(101, 217, 160, 0.16);
    }}
    .topbar-update-item {{
      position: absolute;
      left: 0;
      top: 50%;
      display: inline-flex;
      align-items: center;
      font-size: 13px;
      line-height: 1.2;
      letter-spacing: 0.12px;
      color: rgba(244, 255, 249, 0.96);
      white-space: nowrap;
      text-shadow: 0 0 8px rgba(101, 217, 160, 0.16);
      will-change: transform;
      pointer-events: none;
      transform: translate3d(0, -50%, 0);
    }}
    .topbar-update-item.is-oneshot {{
      color: rgba(220, 245, 231, 0.95);
    }}
    .topbar-update-ticker.is-static .topbar-update-track {{
      animation: none;
      transform: translateX(0);
    }}
    .topbar-update-ticker.is-static #topbar-update-text-secondary {{
      display: none;
    }}
    .topbar-update-ticker:hover .topbar-update-track,
    .topbar-update-ticker:focus-within .topbar-update-track {{
      animation-play-state: paused;
    }}
    @keyframes topbarUpdateScroll {{
      from {{
        transform: translateX(var(--topbar-update-start, 0px));
      }}
      to {{
        transform: translateX(calc(var(--topbar-update-start, 0px) - var(--topbar-update-shift, 420px)));
      }}
    }}
    @media (prefers-reduced-motion: reduce) {{
      .topbar-update-track {{
        animation: none !important;
        transform: translateX(0);
      }}
      #topbar-update-text-secondary {{
        display: none;
      }}
    }}
    .topbar .sub .summary-ticker-row {{
      display: grid;
      grid-auto-flow: column;
      grid-template-columns: var(--topbar-corner-reserve, 36px) repeat(var(--summary-visible-ticker-count, 10), minmax(0, 1fr));
      grid-auto-columns: minmax(0, 1fr);
      gap: 5px;
      min-width: 0;
      overflow-x: auto;
      overflow-y: hidden;
      overscroll-behavior-x: contain;
      scrollbar-width: thin;
    }}
    .summary-ticker-expanded-slot {{
      width: 100%;
      min-width: 0;
      display: block;
    }}
    .summary-ticker-expanded-slot[hidden] {{
      display: none !important;
    }}
    .topbar .summary-ticker-item {{
      border: 1px solid color-mix(in srgb, var(--line) 82%, var(--accent) 18%);
      background: var(--panel);
      border-radius: 7px;
      padding: 4px 7px;
      min-width: 0;
      color: var(--ink);
      position: relative;
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      grid-template-rows: auto;
      column-gap: 7px;
      row-gap: 0;
      align-items: center;
      overflow: hidden;
      isolation: isolate;
      box-shadow: none;
    }}
    .topbar .summary-ticker-item[hidden] {{
      display: none !important;
    }}
    .topbar:not(.ticker-expanded) .summary-ticker-item[data-ticker-id]:not([data-ticker-id="self"]),
    .topbar:not(.ticker-expanded) .summary-ticker-item.is-compact-detail-open {{
      cursor: pointer;
    }}
    .topbar:not(.ticker-expanded) .summary-ticker-item[data-ticker-id]:not([data-ticker-id="self"]):hover,
    .topbar:not(.ticker-expanded) .summary-ticker-item[data-ticker-id]:not([data-ticker-id="self"]):focus-visible {{
      border-color: color-mix(in srgb, var(--line) 78%, var(--ink) 22%);
      background: color-mix(in srgb, var(--panel) 93%, var(--line) 7%);
      outline: none;
    }}
    .summary-ticker-expanded-slot .summary-ticker-expanded-card {{
      width: 100%;
      min-width: 0;
      box-sizing: border-box;
      cursor: pointer;
    }}
    .topbar.has-compact-ticker-detail:not(.ticker-expanded) .summary-ticker-item.is-compact-detail-open {{
      min-width: 0;
      border-radius: 10px;
      padding: 8px 10px;
      grid-template-columns: minmax(0, 1fr);
      grid-template-rows: auto auto auto;
      row-gap: 4px;
      align-items: start;
    }}
    .topbar.has-compact-ticker-detail:not(.ticker-expanded) .summary-ticker-item-radio.is-compact-detail-open {{
      grid-template-rows: auto auto auto auto;
    }}
    .topbar-update-ticker[hidden] {{
      display: none !important;
    }}
    .workspace-launcher-row {{
      grid-column: 1 / -1;
      grid-row: 1;
      position: relative;
      z-index: 500;
      display: flex;
      align-items: stretch;
      justify-content: flex-start;
      gap: 10px;
      min-width: 0;
    }}
    .workspace-launcher-shell {{
      position: relative;
      display: inline-flex;
      min-width: 0;
      min-height: 0;
      overflow: visible;
    }}
    .workspace-peer-dm-menu-wrap {{
      flex: 0 0 auto;
      align-self: stretch;
      min-height: 0;
    }}
    .workspace-peer-dm-menu-wrap .peer-dm-toggle-btn {{
      width: 38px;
      height: 38px;
    }}
    .workspace-peer-dm-menu-wrap .peer-dm-menu {{
      top: calc(100% + 8px);
      right: 0;
    }}
    .topbar-view-menu-btn {{
      width: auto;
      min-width: 88px;
      min-height: 38px;
      position: relative;
      border: 1px solid color-mix(in srgb, var(--line) 74%, var(--accent));
      background:
        linear-gradient(
          180deg,
          color-mix(in srgb, var(--panel) 94%, var(--accent) 6%),
          color-mix(in srgb, var(--panel) 84%, var(--accent) 16%)
        );
      color: #f2fff7;
      border-radius: 999px;
      padding: 0 9px 0 6px;
      display: inline-flex;
      align-items: center;
      justify-content: flex-start;
      gap: 0;
      cursor: pointer;
      font-size: 12px;
      line-height: 1.2;
      font-weight: 700;
      text-align: left;
      color: color-mix(in srgb, var(--ink) 86%, var(--accent-2));
      box-shadow: none;
      transition: border-color 140ms ease, background 140ms ease, color 140ms ease;
    }}
    .topbar-view-menu-btn-main {{
      min-width: 0;
      flex: 1 1 auto;
      display: inline-flex;
      align-items: center;
      gap: 7px;
    }}
    .topbar-view-menu-btn:hover,
    .topbar-view-menu-btn[aria-expanded="true"] {{
      border-color: color-mix(in srgb, var(--accent) 52%, var(--line));
      background:
        linear-gradient(
          180deg,
          color-mix(in srgb, var(--panel) 90%, var(--accent) 10%),
          color-mix(in srgb, var(--panel) 76%, var(--accent) 24%)
        );
      box-shadow: none;
    }}
    .topbar-view-menu-btn.has-unread {{
      border-color: var(--accent);
      box-shadow: none;
    }}
    .topbar-view-menu-btn:focus-visible {{
      outline: 2px solid color-mix(in srgb, var(--accent-2) 74%, black);
      outline-offset: 2px;
    }}
    .topbar-view-menu-btn-label {{
      min-width: 0;
      flex: 1 1 auto;
      display: inline-flex;
      align-items: center;
      gap: 4px;
      font-size: 12px;
      line-height: 1;
      font-weight: 700;
      letter-spacing: 0.16px;
      color: color-mix(in srgb, var(--ink) 84%, var(--accent-2));
    }}
    .topbar-view-menu-btn-label-text {{
      min-width: 0;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }}
    .topbar-view-menu-btn-badge {{
      flex: 0 0 auto;
      margin-left: auto;
      min-width: 18px;
      height: 18px;
      padding: 0 6px;
      border-radius: 999px;
      border: 1px solid color-mix(in srgb, var(--accent) 28%, transparent);
      background: color-mix(in srgb, var(--accent) 14%, transparent);
      color: color-mix(in srgb, var(--accent-2) 78%, var(--ink));
      display: inline-flex;
      align-items: center;
      justify-content: center;
      font-size: 10px;
      line-height: 1;
      font-weight: 700;
      box-shadow: none;
    }}
    .topbar-view-menu-btn-attention {{
      flex: 0 0 auto;
      width: 10px;
      height: 10px;
      border-radius: 3px;
      border: 1px solid color-mix(in srgb, var(--accent-2) 54%, transparent);
      background:
        linear-gradient(
          135deg,
          color-mix(in srgb, var(--accent) 58%, white) 0%,
          var(--accent) 100%
        );
      box-shadow:
        0 0 0 3px color-mix(in srgb, var(--accent) 16%, transparent),
        0 0 12px color-mix(in srgb, var(--accent) 26%, transparent);
      transform: rotate(18deg);
    }}
    .topbar-view-menu-btn-badge[hidden],
    .topbar-view-menu-btn-attention[hidden],
    .topbar-view-menu-item-badge[hidden] {{
      display: none !important;
    }}
    .topbar-view-menu-caret {{
      flex: 0 0 auto;
      margin-left: 1px;
      width: 0;
      height: 0;
      border-left: 3px solid transparent;
      border-right: 3px solid transparent;
      border-top: 5px solid color-mix(in srgb, var(--accent-2) 64%, var(--ink));
      transition: transform 140ms ease;
    }}
    .topbar-view-menu-btn[aria-expanded="true"] .topbar-view-menu-caret {{
      transform: rotate(180deg);
    }}
    .topbar-view-menu {{
      position: fixed;
      top: 8px;
      left: 8px;
      min-width: max(260px, 100%);
      max-width: min(320px, calc(100vw - 24px));
      display: flex;
      flex-direction: column;
      gap: 6px;
      padding: 10px;
      border: 1px solid color-mix(in srgb, var(--accent) 32%, #b8d3c2);
      border-radius: 16px;
      background: color-mix(in srgb, var(--accent-2) 38%, #07140f);
      box-shadow: 0 16px 34px color-mix(in srgb, var(--accent-2) 24%, rgba(4, 12, 8, 0.42));
      z-index: 1350;
      backdrop-filter: blur(14px);
    }}
    .topbar-view-menu[hidden] {{
      display: none !important;
    }}
    .topbar-view-menu-item {{
      width: 100%;
      border: 1px solid transparent;
      border-radius: 12px;
      background: transparent;
      color: #f2fff7;
      padding: 10px;
      display: grid;
      grid-template-columns: auto minmax(0, 1fr) auto;
      align-items: center;
      column-gap: 10px;
      row-gap: 2px;
      text-align: left;
      cursor: pointer;
      line-height: 1.2;
    }}
    .topbar-view-menu-item-icon {{
      width: 30px;
      height: 30px;
      border-radius: 9px;
      border: 1px solid color-mix(in srgb, var(--accent) 18%, rgba(214, 238, 223, 0.18));
      background: color-mix(in srgb, var(--accent) 10%, transparent);
      color: rgba(239, 255, 246, 0.9);
      display: inline-flex;
      align-items: center;
      justify-content: center;
      font-size: 9px;
      line-height: 1;
      font-weight: 800;
      letter-spacing: 0.4px;
      text-transform: uppercase;
    }}
    .topbar-view-menu-item-copy {{
      min-width: 0;
      display: flex;
      flex-direction: column;
      gap: 2px;
    }}
    .topbar-view-menu-item-label-row {{
      display: inline-flex;
      align-items: center;
      gap: 6px;
