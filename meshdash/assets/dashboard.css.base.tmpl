    }}
    .reversi-hint.hint-white {{
      background: radial-gradient(circle at 30% 24%, #ffffff 0%, #edf3f8 52%, #d6e0e9 100%);
      border-color: rgba(168, 188, 205, 0.9);
      box-shadow: 0 0 0 1px rgba(23, 74, 50, 0.24);
    }}
    .checkers-board,
    .chess-board,
    .wall-chess-board {{
      --classic-board-accent: var(--ui-accent-soft, var(--ui-accent));
      --classic-board-accent-strong: var(--ui-accent, var(--ui-accent-soft, var(--ui-accent)));
      --classic-board-root: color-mix(in srgb, var(--classic-board-accent) 22%, var(--surface-tint-bg) 78%);
      --classic-board-frame: color-mix(in srgb, var(--classic-board-accent-strong) 24%, var(--surface-tint-border-strong) 76%);
      --classic-board-frame-inner: color-mix(in srgb, var(--classic-board-accent) 24%, #dbe5ef 76%);
      --classic-board-cell-light: color-mix(in srgb, #fbf7ef 84%, var(--classic-board-root) 16%);
      --classic-board-cell-dark: color-mix(in srgb, var(--classic-board-root) 66%, #6b88a5);
      --classic-board-cell-dark-hover: color-mix(in srgb, var(--classic-board-cell-dark) 86%, #ffffff);
      --classic-board-focus: color-mix(in srgb, var(--classic-board-accent-strong) 58%, #ffffff);
      --classic-board-target: color-mix(in srgb, var(--classic-board-accent) 34%, #f8fff8);
    }}
    .checkers-board {{
      --checkers-cell-size: clamp(32px, min(6.9vw, 8.7vh), 94px);
      display: grid;
      grid-template-columns: repeat(8, var(--checkers-cell-size));
      grid-template-rows: repeat(8, var(--checkers-cell-size));
      border: 1px solid var(--classic-board-frame);
      border-radius: 12px;
      overflow: hidden;
      background: var(--classic-board-frame-inner);
      box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--classic-board-frame) 42%, #ffffff);
    }}
    .checkers-cell {{
      width: var(--checkers-cell-size);
      height: var(--checkers-cell-size);
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 0;
      margin: 0;
      border: 0;
      border-radius: 0;
      position: relative;
    }}
    .checkers-cell.is-light {{
      background: var(--classic-board-cell-light);
    }}
    button.checkers-cell.is-dark {{
      background: var(--classic-board-cell-dark);
      cursor: pointer;
    }}
    button.checkers-cell.is-dark:hover {{
      background: var(--classic-board-cell-dark-hover);
    }}
    button.checkers-cell:focus-visible {{
      outline: 2px solid var(--classic-board-focus);
      outline-offset: -2px;
      z-index: 2;
    }}
    button.checkers-cell.is-movable {{
      box-shadow: inset 0 0 0 1px rgba(227, 218, 168, 0.35);
    }}
    button.checkers-cell.is-selected {{
      box-shadow: inset 0 0 0 3px rgba(246, 233, 148, 0.85);
      z-index: 1;
    }}
    button.checkers-cell.is-target {{
      box-shadow: inset 0 0 0 2px rgba(152, 214, 160, 0.72);
    }}
    button.checkers-cell.is-last-from,
    button.checkers-cell.is-last-to {{
      box-shadow: inset 0 0 0 2px rgba(255, 230, 143, 0.7);
    }}
    .checkers-disc {{
      width: calc(var(--checkers-cell-size) * 0.76);
      height: calc(var(--checkers-cell-size) * 0.76);
      border-radius: 999px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      font-size: clamp(10px, 1.4vw, 15px);
      font-weight: 800;
      line-height: 1;
      box-shadow: inset 0 -2px 8px rgba(0, 0, 0, 0.3);
      user-select: none;
    }}
    .checkers-disc.disc-black {{
      background: radial-gradient(circle at 30% 24%, #52616b 0%, #2d3a43 52%, #202b33 100%);
      color: #ecf7ff;
      border: 1px solid #1b242b;
    }}
    .checkers-disc.disc-white {{
      background: radial-gradient(circle at 30% 24%, #ffffff 0%, #eff4f8 52%, #d6e0e8 100%);
      color: #204054;
      border: 1px solid #a8bdcc;
    }}
    .checkers-disc.is-king {{
      box-shadow: inset 0 -2px 8px rgba(0, 0, 0, 0.26), 0 0 0 1px rgba(244, 214, 112, 0.68);
    }}
    .checkers-hint {{
      width: calc(var(--checkers-cell-size) * 0.22);
      height: calc(var(--checkers-cell-size) * 0.22);
      border-radius: 999px;
      background: var(--classic-board-target);
      border: 1px solid color-mix(in srgb, var(--classic-board-accent) 72%, #f4fffa);
      box-shadow: 0 0 0 1px color-mix(in srgb, var(--classic-board-frame) 42%, transparent);
    }}
    .chess-board {{
      --chess-cell-size: clamp(32px, min(6.9vw, 8.7vh), 94px);
      display: grid;
      grid-template-columns: repeat(8, var(--chess-cell-size));
      grid-template-rows: repeat(8, var(--chess-cell-size));
      border: 1px solid var(--classic-board-frame);
      border-radius: 12px;
      overflow: hidden;
      background: var(--classic-board-frame-inner);
      box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--classic-board-frame) 42%, #ffffff);
    }}
    .chess-cell {{
      width: var(--chess-cell-size);
      height: var(--chess-cell-size);
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 0;
      margin: 0;
      border: 0;
      border-radius: 0;
      cursor: pointer;
      position: relative;
      user-select: none;
    }}
    .chess-cell.is-light {{
      background: var(--classic-board-cell-light);
    }}
    .chess-cell.is-dark {{
      background: var(--classic-board-cell-dark);
    }}
    .chess-cell:hover {{
      filter: brightness(1.04);
    }}
    .chess-cell:focus-visible {{
      outline: 2px solid var(--classic-board-focus);
      outline-offset: -2px;
      z-index: 2;
    }}
    .chess-cell.is-movable {{
      box-shadow: inset 0 0 0 1px rgba(236, 223, 172, 0.42);
    }}
    .chess-cell.is-selected {{
      box-shadow: inset 0 0 0 3px rgba(251, 236, 150, 0.85);
      z-index: 1;
    }}
    .chess-cell.is-target {{
      box-shadow: inset 0 0 0 2px rgba(149, 209, 160, 0.8);
    }}
    .chess-cell.is-last-from,
    .chess-cell.is-last-to {{
      box-shadow: inset 0 0 0 2px rgba(255, 229, 141, 0.72);
    }}
    .chess-cell.is-checked {{
      box-shadow: inset 0 0 0 3px rgba(227, 85, 85, 0.84);
    }}
    .chess-piece {{
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 100%;
      height: 100%;
      font-size: calc(var(--chess-cell-size) * 0.9);
      line-height: 0.84;
      font-weight: 800;
      letter-spacing: -0.02em;
      transform: translateY(1px);
      text-shadow: 0 1px 0 rgba(0, 0, 0, 0.2);
    }}
    .chess-piece.piece-white {{
      color: #f8fdff;
      -webkit-text-stroke: clamp(0.4px, calc(var(--chess-cell-size) * 0.018), 1.2px) rgba(17, 34, 45, 0.78);
      text-shadow:
        0 1px 0 rgba(10, 21, 28, 0.62),
        1px 0 0 rgba(14, 30, 39, 0.5),
        -1px 0 0 rgba(14, 30, 39, 0.5),
        0 -1px 0 rgba(14, 30, 39, 0.5);
    }}
    .chess-piece.piece-black {{
      color: #1e2a31;
      -webkit-text-stroke: clamp(0.35px, calc(var(--chess-cell-size) * 0.016), 1px) rgba(226, 240, 247, 0.52);
      text-shadow:
        0 1px 0 rgba(236, 247, 255, 0.26),
        1px 0 0 rgba(228, 239, 246, 0.34),
        -1px 0 0 rgba(228, 239, 246, 0.34),
        0 -1px 0 rgba(228, 239, 246, 0.34);
    }}
    .chess-hint {{
      width: calc(var(--chess-cell-size) * 0.2);
      height: calc(var(--chess-cell-size) * 0.2);
      border-radius: 999px;
      background: var(--classic-board-target);
      border: 1px solid color-mix(in srgb, var(--classic-board-accent) 72%, #f4fffa);
      box-shadow: 0 0 0 1px color-mix(in srgb, var(--classic-board-frame) 42%, transparent);
    }}
    .wall-chess-board {{
      --wall-chess-cell-size: clamp(16px, min(3.8vw, 5.2vh), 46px);
      --wall-chess-gap-size: calc(var(--wall-chess-cell-size) * 0.17);
      --wall-chess-frame: color-mix(in srgb, var(--classic-board-frame) 74%, #c4d8e7 26%);
      --wall-chess-frame-inner: color-mix(in srgb, var(--classic-board-frame-inner) 76%, #ffffff 24%);
      --wall-chess-surface:
        radial-gradient(circle at 50% 0%, rgba(255, 255, 255, 0.18) 0%, transparent 58%),
        linear-gradient(180deg, color-mix(in srgb, var(--classic-board-root) 64%, #7895b4 36%), color-mix(in srgb, var(--classic-board-root) 52%, #243d56 48%));
      --wall-chess-cell: color-mix(in srgb, #122536 72%, #203d55 28%);
      --wall-chess-cell-hover: color-mix(in srgb, var(--wall-chess-cell) 76%, #6f8eaa 24%);
      --wall-chess-grid: color-mix(in srgb, #9cb3c7 56%, #dce8f0 44%);
      --wall-chess-focus: color-mix(in srgb, var(--classic-board-focus) 70%, #ffffff);
      --wall-chess-target: color-mix(in srgb, var(--classic-board-target) 76%, #ffffff 24%);
      --wall-chess-wall: linear-gradient(180deg, #dbe7f1, #9fb5c8);
      --wall-chess-wall-border: color-mix(in srgb, #5f7e99 66%, #ecf6ff 34%);
      --wall-chess-black-piece: radial-gradient(circle at 30% 24%, #6f8599 0%, #34485c 46%, #1a2836 100%);
      --wall-chess-white-piece: radial-gradient(circle at 30% 24%, #ffffff 0%, #eef4f9 56%, #cad8e2 100%);
      display: grid;
      grid-template-columns: repeat(17, auto);
      grid-template-rows: repeat(17, auto);
      gap: 0;
      width: max-content;
      max-width: 100%;
      max-height: 100%;
      padding: clamp(6px, calc(var(--wall-chess-cell-size) * 0.22), 10px);
      border: 1px solid var(--wall-chess-frame);
      border-radius: 12px;
      background: var(--wall-chess-surface);
      box-shadow:
        inset 0 0 0 1px color-mix(in srgb, var(--wall-chess-frame-inner) 70%, #ffffff 30%),
        0 0 0 1px rgba(255, 255, 255, 0.06);
    }}
    .wall-chess-cell,
    .wall-chess-slot,
    .wall-chess-corner {{
      padding: 0;
      margin: 0;
      border: 0;
      border-radius: 0;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      position: relative;
    }}
    .wall-chess-cell {{
      width: var(--wall-chess-cell-size);
      height: var(--wall-chess-cell-size);
      background: var(--wall-chess-cell);
      box-shadow: inset 0 0 0 1px var(--wall-chess-grid);
      cursor: pointer;
    }}
    .wall-chess-cell:hover {{
      background: var(--wall-chess-cell-hover);
    }}
    .wall-chess-cell:focus-visible,
    .wall-chess-slot:focus-visible {{
      outline: 2px solid var(--wall-chess-focus);
      outline-offset: -2px;
      z-index: 3;
    }}
    .wall-chess-cell.is-selected {{
      box-shadow: inset 0 0 0 3px rgba(255, 220, 114, 0.88);
      z-index: 2;
    }}
    .wall-chess-cell.is-target {{
      box-shadow: inset 0 0 0 2px rgba(110, 214, 146, 0.8);
    }}
    .wall-chess-cell.is-last-from,
    .wall-chess-cell.is-last-to {{
      box-shadow: inset 0 0 0 2px rgba(255, 229, 141, 0.74);
    }}
    .wall-chess-piece {{
      width: calc(var(--wall-chess-cell-size) * 0.44);
      height: calc(var(--wall-chess-cell-size) * 0.62);
      border-radius: 999px 999px 44% 44%;
      box-shadow: inset 0 -2px 6px rgba(0, 0, 0, 0.26);
      border: 1px solid rgba(38, 24, 10, 0.28);
    }}
    .wall-chess-piece.piece-black {{
      background: var(--wall-chess-black-piece);
    }}
    .wall-chess-piece.piece-white {{
      background: var(--wall-chess-white-piece);
    }}
    .wall-chess-slot {{
      background: transparent;
      cursor: pointer;
    }}
    .wall-chess-slot.horizontal {{
      width: calc((var(--wall-chess-cell-size) * 2) + var(--wall-chess-gap-size));
      height: var(--wall-chess-gap-size);
    }}
    .wall-chess-slot.vertical {{
      width: var(--wall-chess-gap-size);
      height: calc((var(--wall-chess-cell-size) * 2) + var(--wall-chess-gap-size));
    }}
    .wall-chess-slot.is-preview::before,
    .wall-chess-slot.is-placed::before {{
      content: "";
      width: 100%;
      height: 100%;
      border-radius: 999px;
      background: var(--wall-chess-wall);
      box-shadow: inset 0 0 0 1px var(--wall-chess-wall-border), 0 1px 1px rgba(0, 0, 0, 0.12);
    }}
    .wall-chess-slot.is-preview::before {{
      opacity: 0.38;
    }}
    .wall-chess-slot.is-placed::before {{
      opacity: 1;
    }}
    .wall-chess-slot.is-illegal {{
      cursor: not-allowed;
      opacity: 0.36;
    }}
    .wall-chess-corner {{
      width: var(--wall-chess-gap-size);
      height: var(--wall-chess-gap-size);
      background: transparent;
    }}
    @supports (width: 1cqi) {{
      .games-main {{
        container-type: inline-size;
      }}
      .reversi-board {{
        --reversi-cell-size: clamp(30px, 14.1cqi, 94px);
      }}
      .checkers-board {{
        --checkers-cell-size: clamp(30px, 14.1cqi, 94px);
      }}
      .chess-board {{
        --chess-cell-size: clamp(30px, 14.1cqi, 94px);
      }}
      .wall-chess-board {{
        --wall-chess-cell-size: clamp(16px, 7.35cqi, 46px);
      }}
      .checkers-disc {{
        font-size: clamp(10px, 2.8cqi, 16px);
      }}
    }}
