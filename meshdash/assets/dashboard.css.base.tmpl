{theme_css}
    * {{ box-sizing: border-box; }}
    :root {{
      --topbar-sticky-offset: 72px;
      --workspace-viewport-offset: 84px;
      --topbar-right-inset: max(12px, env(safe-area-inset-right));
      --topbar-corner-reserve: 172px;
    }}
    html, body {{
      margin: 0;
      padding: 0;
      font-family: "IBM Plex Sans", "Segoe UI", sans-serif;
      color: var(--ink);
      background:
        radial-gradient(circle at 20% -10%, #d7ead3 0, transparent 45%),
        radial-gradient(circle at 80% 0%, #d0e6d4 0, transparent 40%),
        var(--bg);
      min-height: 100%;
      min-height: 100vh;
      min-height: 100dvh;
      height: 100%;
      overflow: hidden;
    }}
    body {{
      display: flex;
      flex-direction: column;
      min-height: 100dvh;
    }}
    .topbar {{
      padding: 8px 12px;
      background: linear-gradient(100deg, #173d2d, #2d6f50);
      color: #f4fff7;
      box-shadow: var(--shadow);
      position: sticky;
      top: 0;
      z-index: 1200;
      padding-right: var(--topbar-corner-reserve, 172px);
      flex: 0 0 auto;
    }}
    .topbar-notify-corner {{
      position: absolute;
      top: 8px;
      right: var(--topbar-right-inset);
      z-index: 2;
      display: inline-flex;
      align-items: center;
      justify-content: flex-end;
      flex-direction: row-reverse;
      gap: 6px;
    }}
    .topbar-self-profile {{
      min-width: 30px;
      max-width: min(30vw, 220px);
      height: 30px;
      border-radius: 999px;
      border: 1px solid rgba(214, 238, 223, 0.55);
      background: rgba(248, 255, 251, 0.12);
      color: #f1fff6;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 0 8px;
      margin: 0;
      font: inherit;
      font-size: 14px;
      font-weight: 700;
      line-height: 1;
      letter-spacing: 0.1px;
      white-space: nowrap;
      user-select: none;
      cursor: pointer;
      transition: border-color 140ms ease, background 140ms ease, color 140ms ease, box-shadow 140ms ease;
    }}
    .topbar-self-profile:focus-visible {{
      outline: 2px solid rgba(214, 238, 223, 0.92);
      outline-offset: 2px;
    }}
    .topbar-self-profile.status-online {{
      border-color: rgba(121, 230, 172, 0.78);
      background: rgba(53, 154, 101, 0.26);
      color: #ddffeb;
      box-shadow: 0 0 0 1px rgba(77, 190, 130, 0.32);
    }}
    .topbar-self-profile.status-warn {{
      border-color: rgba(234, 203, 129, 0.82);
      background: rgba(174, 134, 57, 0.24);
      color: #fff0cd;
      box-shadow: 0 0 0 1px rgba(213, 172, 96, 0.3);
    }}
    .topbar-self-profile.status-stale {{
      border-color: rgba(255, 162, 162, 0.88);
      background: rgba(182, 38, 38, 0.3);
      color: #fff0f0;
      box-shadow: 0 0 0 1px rgba(208, 83, 83, 0.34);
    }}
    .topbar-self-profile.status-unknown {{
      border-color: rgba(214, 238, 223, 0.5);
      background: rgba(248, 255, 251, 0.1);
      color: #f1fff6;
    }}
    .topbar-self-profile-short {{
      display: block;
      font-size: inherit;
      font-weight: inherit;
      letter-spacing: inherit;
      text-transform: none;
      max-width: min(20ch, 28vw);
      overflow: hidden;
      text-overflow: ellipsis;
    }}
    .topbar-chat-change-menu-wrap .chat-change-toggle-btn,
    .topbar-peer-dm-menu-wrap .peer-dm-toggle-btn,
    .topbar-chat-settings-menu-wrap .chat-settings-toggle-btn,
    .topbar-favorite-menu-wrap .favorite-menu-toggle-btn {{
      width: 30px;
      height: 30px;
      border-color: rgba(214, 238, 223, 0.55);
      background: rgba(248, 255, 251, 0.12);
      color: #f1fff6;
    }}
    .topbar-chat-change-menu-wrap .chat-change-toggle-btn:hover,
    .topbar-peer-dm-menu-wrap .peer-dm-toggle-btn:hover,
    .topbar-chat-settings-menu-wrap .chat-settings-toggle-btn:hover,
    .topbar-favorite-menu-wrap .favorite-menu-toggle-btn:hover {{
      border-color: rgba(214, 238, 223, 0.82);
      background: rgba(248, 255, 251, 0.22);
      color: #ffffff;
    }}
    .topbar-chat-change-menu-wrap .chat-change-toggle-btn[aria-expanded="true"],
    .topbar-peer-dm-menu-wrap .peer-dm-toggle-btn[aria-expanded="true"],
    .topbar-chat-settings-menu-wrap .chat-settings-toggle-btn[aria-expanded="true"],
    .topbar-favorite-menu-wrap .favorite-menu-toggle-btn[aria-expanded="true"] {{
      border-color: rgba(214, 238, 223, 0.82);
      background: rgba(248, 255, 251, 0.24);
      color: #ffffff;
    }}
    .topbar-chat-change-menu-wrap .chat-change-toggle-btn.has-unread {{
      border-color: #8be0af;
      color: #dbffe9;
      box-shadow: 0 0 0 1px rgba(83, 185, 124, 0.4);
    }}
    .topbar-chat-change-menu-wrap .chat-change-badge {{
      border-color: #173d2d;
    }}
    .topbar-chat-change-menu-wrap .chat-change-menu {{
      top: calc(100% + 10px);
    }}
    .topbar-peer-dm-menu-wrap .peer-dm-menu {{
      top: calc(100% + 10px);
    }}
    .topbar-self-radio-menu-wrap .self-radio-menu {{
      top: calc(100% + 10px);
    }}
    .topbar-chat-settings-menu-wrap .chat-settings-menu {{
      top: calc(100% + 10px);
    }}
    .topbar-favorite-menu-wrap .favorite-menu {{
      top: calc(100% + 10px);
    }}
    .topbar-favorite-menu-wrap .favorite-menu-toggle-btn {{
      width: 30px;
      height: 30px;
      padding: 0;
      border-radius: 999px;
    }}
    .topbar h1 {{
      margin: 0;
      font-size: 20px;
      line-height: 1.04;
      letter-spacing: 0.1px;
    }}
    .topbar .topbar-main-row {{
      display: grid;
      grid-template-columns: minmax(0, max-content) minmax(0, 1fr);
      align-items: center;
      column-gap: 6px;
      min-width: 0;
      min-height: 30px;
    }}
    .topbar .topbar-brand {{
      grid-column: 1;
      justify-self: start;
      display: grid;
      grid-template-columns: minmax(0, 1fr);
      grid-template-rows: auto auto;
      align-items: start;
      row-gap: 0;
      min-width: 0;
      max-width: min(44vw, 520px);
    }}
    .topbar .topbar-heading {{
      display: block;
      align-items: center;
      flex-wrap: nowrap;
      justify-content: flex-start;
      gap: 0;
      text-align: left;
      min-width: 0;
    }}
    .topbar .topbar-heading-app {{
      display: inline-flex;
      align-items: center;
      max-width: min(44vw, 520px);
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }}
    .topbar .topbar-main-row .revision-text {{
      margin: 0;
      max-width: min(44vw, 520px);
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
      font-size: 10px;
      line-height: 1.05;
    }}
    .topbar .topbar-main-spacer {{
      display: none;
    }}
    .topbar-update-ticker {{
      --topbar-update-start: 0px;
      --topbar-update-shift: 420px;
      --topbar-update-duration: 42s;
      flex: none;
      width: 100%;
      min-width: 0;
      max-width: none;
      display: grid;
      grid-template-columns: minmax(0, 1fr);
      align-items: center;
      gap: 6px;
      border: 1px solid rgba(236, 251, 243, 0.72);
      border-radius: 999px;
      background: linear-gradient(90deg, rgba(7, 24, 18, 0.6), rgba(10, 36, 27, 0.38));
      color: #f3fff8;
      padding: 3px 10px;
      min-height: 30px;
      opacity: 1;
      transition: opacity 220ms ease;
      overflow: hidden;
      box-shadow: inset 0 0 0 1px rgba(203, 236, 219, 0.08);
    }}
    .workspace-update-ticker {{
      flex: 1 1 auto;
      align-self: stretch;
      min-width: 0;
      min-height: 38px;
      margin: 0;
      padding: 0 12px;
    }}
    .topbar .sub {{
      margin-top: 4px;
      font-size: 11px;
      opacity: 0.95;
      display: flex;
      flex-direction: column;
      align-items: stretch;
      gap: 2px;
    }}
    .topbar .sub .summary-ticker-row {{
      width: calc(100% + var(--topbar-corner-reserve, 172px));
      margin-right: calc(var(--topbar-corner-reserve, 172px) * -1);
    }}
    .topbar .sub .summary-ticker-row {{
      padding-right: var(--topbar-right-inset);
    }}
    .topbar-update-ticker.is-fading {{
      opacity: 0;
    }}
    .topbar-update-ticker-label {{
      display: inline-flex;
      align-items: center;
      font-size: 10px;
      line-height: 1;
      text-transform: uppercase;
      letter-spacing: 0.22em;
      color: rgba(222, 248, 233, 0.82);
      white-space: nowrap;
      user-select: none;
      flex: 0 0 auto;
    }}
    .topbar-update-viewport {{
      width: 100%;
      min-width: 0;
      display: flex;
      align-items: center;
      overflow: hidden;
      mask-image: linear-gradient(to right, transparent 0, #000 3%, #000 97%, transparent 100%);
      -webkit-mask-image: linear-gradient(to right, transparent 0, #000 3%, #000 97%, transparent 100%);
    }}
    .topbar-update-track {{
      position: relative;
      display: block;
      width: 100%;
      min-width: 0;
      min-height: 1.2em;
      animation: none;
      transform: none;
      overflow: visible;
    }}
    .topbar-update-text {{
      display: none;
      align-items: center;
      font-size: 14px;
      line-height: 1.2;
      letter-spacing: 0.12px;
      color: rgba(244, 255, 249, 0.96);
      white-space: nowrap;
      text-shadow: 0 0 8px rgba(101, 217, 160, 0.16);
    }}
    .topbar-update-item {{
      position: absolute;
      left: 0;
      top: 50%;
      display: inline-flex;
      align-items: center;
      font-size: 13px;
      line-height: 1.2;
      letter-spacing: 0.12px;
      color: rgba(244, 255, 249, 0.96);
      white-space: nowrap;
      text-shadow: 0 0 8px rgba(101, 217, 160, 0.16);
      will-change: transform;
      pointer-events: none;
      transform: translate3d(0, -50%, 0);
    }}
    .topbar-update-item.is-oneshot {{
      color: rgba(220, 245, 231, 0.95);
    }}
    .topbar-update-ticker.is-static .topbar-update-track {{
      animation: none;
      transform: translateX(0);
    }}
    .topbar-update-ticker.is-static #topbar-update-text-secondary {{
      display: none;
    }}
    .topbar-update-ticker:hover .topbar-update-track,
    .topbar-update-ticker:focus-within .topbar-update-track {{
      animation-play-state: paused;
    }}
    @keyframes topbarUpdateScroll {{
      from {{
        transform: translateX(var(--topbar-update-start, 0px));
      }}
      to {{
        transform: translateX(calc(var(--topbar-update-start, 0px) - var(--topbar-update-shift, 420px)));
      }}
    }}
    @media (prefers-reduced-motion: reduce) {{
      .topbar-update-track {{
        animation: none !important;
        transform: translateX(0);
      }}
      #topbar-update-text-secondary {{
        display: none;
      }}
    }}
    .topbar .sub .summary-ticker-row {{
      display: grid;
      grid-auto-flow: column;
      grid-auto-columns: minmax(112px, 1fr);
      gap: 4px;
      min-width: 0;
      overflow-x: auto;
      overflow-y: hidden;
      overscroll-behavior-x: contain;
      scrollbar-width: thin;
    }}
    .topbar .summary-ticker-item {{
      border: 1px solid rgba(214, 238, 223, 0.45);
      background: rgba(248, 255, 251, 0.1);
      border-radius: 7px;
      padding: 3px 5px;
      min-width: 0;
      color: #f2fff7;
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      grid-template-rows: auto auto;
      column-gap: 5px;
      row-gap: 1px;
      align-items: end;
    }}
    .topbar .summary-ticker-item[hidden] {{
      display: none !important;
    }}
    .workspace-launcher-row {{
      grid-column: 1 / -1;
      grid-row: 1;
      display: flex;
      align-items: stretch;
      justify-content: flex-start;
      gap: 10px;
      min-width: 0;
    }}
    .workspace-launcher-shell {{
      position: relative;
      display: inline-flex;
      min-width: 0;
      min-height: 0;
      overflow: visible;
    }}
    .topbar-view-menu-btn {{
      width: auto;
      min-width: 88px;
      min-height: 38px;
      position: relative;
      border: 1px solid #c6d6c0;
      background:
        linear-gradient(180deg, rgba(247, 253, 249, 0.98), rgba(230, 242, 234, 0.96));
      color: #f2fff7;
      border-radius: 999px;
      padding: 0 12px;
      display: inline-flex;
      align-items: center;
      justify-content: flex-start;
      gap: 7px;
      cursor: pointer;
      font-size: 12px;
      line-height: 1.2;
      font-weight: 700;
      text-align: left;
      color: #143226;
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.4),
        0 8px 18px rgba(9, 28, 18, 0.12);
      transition: border-color 140ms ease, background 140ms ease, color 140ms ease, box-shadow 140ms ease;
    }}
    .topbar-view-menu-btn:hover,
    .topbar-view-menu-btn[aria-expanded="true"] {{
      border-color: #9fc7ae;
      background:
        linear-gradient(180deg, rgba(250, 255, 252, 0.99), rgba(221, 239, 229, 0.98));
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.48),
        0 10px 22px rgba(9, 28, 18, 0.16);
    }}
    .topbar-view-menu-btn.has-unread {{
      border-color: #67b886;
      box-shadow:
        inset 0 0 0 1px rgba(103, 184, 134, 0.18),
        0 10px 22px rgba(9, 28, 18, 0.16);
    }}
    .topbar-view-menu-btn:focus-visible {{
      outline: 2px solid rgba(67, 125, 92, 0.9);
      outline-offset: 2px;
    }}
    .topbar-view-menu-btn-label {{
      font-size: 12px;
      line-height: 1;
      font-weight: 700;
      letter-spacing: 0.16px;
      color: #17372a;
    }}
    .topbar-view-menu-btn-attention {{
      flex: 0 0 auto;
      width: 10px;
      height: 10px;
      border-radius: 3px;
      border: 1px solid rgba(41, 130, 84, 0.54);
      background: linear-gradient(135deg, #9ef0bd 0%, #31bb72 100%);
      box-shadow:
        0 0 0 3px rgba(110, 224, 160, 0.16),
        0 0 12px rgba(49, 187, 114, 0.26);
      transform: rotate(18deg);
    }}
    .topbar-view-menu-btn-attention[hidden],
    .topbar-view-menu-item-badge[hidden] {{
      display: none !important;
    }}
    .topbar-view-menu-caret {{
      flex: 0 0 auto;
      margin-left: 1px;
      width: 0;
      height: 0;
      border-left: 3px solid transparent;
      border-right: 3px solid transparent;
      border-top: 5px solid rgba(31, 68, 48, 0.78);
      transition: transform 140ms ease;
    }}
    .topbar-view-menu-btn[aria-expanded="true"] .topbar-view-menu-caret {{
      transform: rotate(180deg);
    }}
    .topbar-view-menu {{
      position: fixed;
      top: 8px;
      left: 8px;
      min-width: max(260px, 100%);
      max-width: min(320px, calc(100vw - 24px));
      display: flex;
      flex-direction: column;
      gap: 6px;
      padding: 10px;
      border: 1px solid rgba(184, 211, 194, 0.78);
      border-radius: 16px;
      background: rgba(7, 20, 15, 0.96);
      box-shadow: 0 16px 34px rgba(4, 12, 8, 0.42);
      z-index: 32;
      backdrop-filter: blur(14px);
    }}
    .topbar-view-menu[hidden] {{
      display: none !important;
    }}
    .topbar-view-menu-head {{
      display: flex;
      flex-direction: column;
      gap: 2px;
      padding: 2px 4px 8px;
      border-bottom: 1px solid rgba(214, 238, 223, 0.18);
    }}
    .topbar-view-menu-head-kicker {{
      font-size: 9px;
      line-height: 1.1;
      text-transform: uppercase;
      letter-spacing: 0.42px;
      color: rgba(207, 233, 218, 0.62);
    }}
    .topbar-view-menu-head-title {{
      font-size: 15px;
      line-height: 1.15;
      font-weight: 700;
      color: #f2fff7;
    }}
    .topbar-view-menu-head-current {{
      font-size: 10px;
      line-height: 1.2;
      color: rgba(222, 244, 231, 0.78);
    }}
    .topbar-view-menu-item {{
      width: 100%;
      border: 1px solid transparent;
      border-radius: 12px;
      background: transparent;
      color: #f2fff7;
      padding: 10px;
      display: grid;
      grid-template-columns: auto minmax(0, 1fr) auto;
      align-items: center;
      column-gap: 10px;
      row-gap: 2px;
      text-align: left;
      cursor: pointer;
      line-height: 1.2;
    }}
    .topbar-view-menu-item-icon {{
      width: 30px;
      height: 30px;
      border-radius: 9px;
      border: 1px solid rgba(214, 238, 223, 0.18);
      background: rgba(248, 255, 251, 0.08);
      color: rgba(239, 255, 246, 0.9);
      display: inline-flex;
      align-items: center;
      justify-content: center;
      font-size: 9px;
      line-height: 1;
      font-weight: 800;
      letter-spacing: 0.4px;
      text-transform: uppercase;
    }}
    .topbar-view-menu-item-copy {{
      min-width: 0;
      display: flex;
      flex-direction: column;
      gap: 2px;
    }}
    .topbar-view-menu-item-badge {{
      min-width: 22px;
      height: 20px;
      padding: 0 6px;
      border-radius: 999px;
      border: 1px solid rgba(102, 211, 148, 0.34);
      background: rgba(49, 187, 114, 0.14);
      color: #e4fff0;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      font-size: 10px;
      line-height: 1;
      font-weight: 700;
      letter-spacing: 0.02em;
      box-shadow: inset 0 1px 0 rgba(208, 255, 228, 0.08);
    }}
    .topbar-view-menu-item:hover {{
      border-color: rgba(121, 230, 172, 0.34);
      background: rgba(53, 154, 101, 0.16);
    }}
    .topbar-view-menu-item.has-notifications .topbar-view-menu-item-icon {{
      border-color: rgba(102, 211, 148, 0.34);
      background: rgba(49, 187, 114, 0.12);
      color: #effff5;
    }}
    .topbar-view-menu-item.is-active,
    .topbar-view-menu-item[aria-checked="true"] {{
      border-color: rgba(121, 230, 172, 0.62);
      background: rgba(53, 154, 101, 0.24);
      box-shadow: inset 0 0 0 1px rgba(121, 230, 172, 0.08);
    }}
    .topbar-view-menu-item:focus-visible {{
      outline: 2px solid rgba(214, 238, 223, 0.92);
      outline-offset: 2px;
    }}
    .topbar-view-menu-item-label {{
      font-size: 12px;
      font-weight: 700;
      color: inherit;
    }}
    .topbar-view-menu-item-meta {{
      font-size: 10px;
      color: rgba(226, 245, 234, 0.68);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }}
    .topbar .summary-ticker-item-target {{
      grid-column: span 1;
      grid-template-rows: auto auto auto;
      row-gap: 2px;
    }}
    .topbar .summary-ticker-item-target .target-radio-status {{
      grid-column: 1 / span 2;
      grid-row: 3;
      font-size: 8px;
      line-height: 1.2;
      letter-spacing: 0.16px;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      border-radius: 999px;
      border: 1px solid rgba(214, 238, 223, 0.35);
      background: rgba(248, 255, 251, 0.08);
      color: rgba(236, 255, 244, 0.9);
      padding: 1px 5px;
      justify-self: start;
      max-width: 100%;
    }}
    .topbar .summary-ticker-item-target .target-radio-status::before {{
      content: "";
      display: inline-block;
      width: 5px;
      height: 5px;
      border-radius: 999px;
      margin-right: 4px;
      vertical-align: middle;
      background: #f2ce7a;
    }}
    .topbar .summary-ticker-item-target .target-radio-status.status-online {{
      border-color: rgba(121, 230, 172, 0.7);
      color: #d5ffea;
      background: rgba(53, 154, 101, 0.22);
    }}
    .topbar .summary-ticker-item-target .target-radio-status.status-online::before {{
      background: #79e6ac;
    }}
    .topbar .summary-ticker-item-target .target-radio-status.status-warn {{
      border-color: rgba(234, 203, 129, 0.76);
      color: #fff0cc;
      background: rgba(174, 134, 57, 0.2);
    }}
    .topbar .summary-ticker-item-target .target-radio-status.status-warn::before {{
      background: #f2ce7a;
    }}
    .topbar .summary-ticker-item-target .target-radio-status.status-stale {{
      border-color: rgba(234, 203, 129, 0.76);
      color: #fff0cc;
      background: rgba(174, 134, 57, 0.2);
    }}
    .topbar .summary-ticker-item-target .target-radio-status.status-stale::before {{
      background: #f2ce7a;
    }}
    .topbar .summary-ticker-item-target .target-radio-status.status-lost {{
      border-color: rgba(255, 162, 162, 0.88);
      color: #fff0f0;
      background: rgba(182, 38, 38, 0.28);
    }}
    .topbar .summary-ticker-item-target .target-radio-status.status-lost::before {{
      background: #ff9e9e;
    }}
    .topbar .summary-ticker-item-target .target-radio-status.status-unknown {{
      border-color: rgba(234, 203, 129, 0.76);
      color: #fff0cc;
      background: rgba(174, 134, 57, 0.2);
    }}
    .topbar .summary-ticker-item-target .target-radio-status.status-unknown::before {{
      background: #f2ce7a;
    }}
    .topbar .summary-ticker-item .label {{
      grid-column: 1 / span 2;
      grid-row: 1;
      font-size: 7px;
      line-height: 1.15;
      text-transform: uppercase;
      letter-spacing: 0.18px;
      color: rgba(236, 255, 244, 0.92);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }}
    .topbar .summary-ticker-item .value {{
      grid-column: 1;
