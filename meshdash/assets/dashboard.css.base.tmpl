{theme_css}
    * {{ box-sizing: border-box; }}
    :root {{
      --topbar-sticky-offset: 72px;
      --workspace-viewport-offset: 84px;
      --topbar-right-inset: max(8px, env(safe-area-inset-right));
      --topbar-corner-reserve: 36px;
      --floating-stage-bg: var(--theme-background-gradient, var(--theme-gradient-primary, color-mix(in srgb, var(--ui-accent) 64%, var(--ui-accent-soft) 36%)));
    }}
    html, body {{
      margin: 0;
      padding: 0;
      font-family: var(--theme-font-family, "IBM Plex Sans", "Segoe UI", sans-serif);
      color: var(--ui-text);
      background: var(--theme-background-gradient, var(--theme-gradient-primary, var(--ui-bg)));
      min-height: 100%;
      min-height: 100vh;
      min-height: 100dvh;
      height: 100%;
      overflow: hidden;
    }}
    body {{
      display: flex;
      flex-direction: column;
      min-height: 100dvh;
    }}
    body.dashboard-image-enabled {{
      background: var(--floating-stage-bg);
    }}
    .dashboard-image-bg,
    .dashboard-particles-bg,
    .dashboard-livemap-bg {{
      position: fixed;
      inset: 0;
      z-index: 0;
      display: block;
      overflow: hidden;
      pointer-events: none;
      opacity: 0;
      visibility: hidden;
    }}
    .dashboard-background-active {{
      z-index: 1;
    }}
    .dashboard-image-bg::after {{
      content: "";
      position: absolute;
      inset: 0;
      pointer-events: none;
      background: rgba(0, 0, 0, var(--dashboard-image-darken, 0));
    }}
    body.dashboard-image-enabled .dashboard-image-bg {{
      --dashboard-background-target-opacity: 0;
      opacity: 0;
      visibility: visible;
      transition: opacity 1800ms ease;
    }}
    body.dashboard-image-enabled .dashboard-image-bg.dashboard-image-background-loaded {{
      --dashboard-background-target-opacity: 1;
      opacity: var(--dashboard-background-target-opacity);
    }}
    body.dashboard-particles-enabled .dashboard-image-bg,
    body.dashboard-livemap-enabled .dashboard-image-bg {{
      opacity: 0;
      visibility: hidden;
    }}
    body.dashboard-particles-enabled {{
      background: var(--floating-stage-bg);
    }}
    .dashboard-particles-bg {{
      --dashboard-background-target-opacity: var(--dashboard-particles-opacity, 0.42);
    }}
    body.dashboard-particles-enabled .dashboard-particles-bg {{
      opacity: 0;
      transition: opacity 1800ms ease;
      visibility: visible;
    }}
    body.dashboard-particles-enabled .dashboard-particles-bg.dashboard-particles-background-loaded {{
      opacity: var(--dashboard-background-target-opacity);
    }}
    .dashboard-particles-bg canvas {{
      display: block;
      width: 100% !important;
      height: 100% !important;
    }}
    body.dashboard-livemap-enabled {{
      background: var(--floating-stage-bg);
    }}
    .dashboard-livemap-bg {{
      transition: opacity 1400ms ease;
    }}
    body.dashboard-livemap-enabled .dashboard-livemap-bg {{
      --dashboard-background-target-opacity: 1;
      visibility: visible;
    }}
    body.dashboard-livemap-enabled .dashboard-livemap-bg.dashboard-background-ready {{
      opacity: var(--dashboard-background-target-opacity);
    }}
    .dashboard-livemap-bg canvas {{
      display: block;
      width: 100%;
      height: 100%;
    }}
    .topbar {{
      padding: 8px 8px 0;
      background: transparent;
      color: #f4fff7;
      box-shadow: none;
      position: sticky;
      top: 0;
      z-index: 1200;
      padding-right: var(--topbar-right-inset);
      flex: 0 0 auto;
    }}
    .topbar-notify-corner {{
      position: absolute;
      top: 8px;
      right: var(--topbar-right-inset);
      z-index: 2;
      display: inline-flex;
      align-items: center;
      justify-content: flex-end;
      flex-direction: row-reverse;
      gap: 6px;
    }}
    .topbar-self-profile {{
      min-width: 30px;
      max-width: min(30vw, 220px);
      height: 30px;
      border-radius: 999px;
      border: 1px solid rgba(214, 238, 223, 0.55);
      background: rgba(248, 255, 251, 0.12);
      color: #f1fff6;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 0 8px;
      margin: 0;
      font: inherit;
      font-size: 14px;
      font-weight: 700;
      line-height: 1;
      letter-spacing: 0.1px;
      white-space: nowrap;
      user-select: none;
      cursor: pointer;
      transition: border-color 140ms ease, background 140ms ease, color 140ms ease, box-shadow 140ms ease;
    }}
    .topbar-self-profile:focus-visible {{
      outline: 2px solid rgba(214, 238, 223, 0.92);
      outline-offset: 2px;
    }}
    .topbar-self-profile.status-online {{
      border-color: rgba(121, 230, 172, 0.78);
      background: rgba(53, 154, 101, 0.26);
      color: #ddffeb;
      box-shadow: 0 0 0 1px rgba(77, 190, 130, 0.32);
    }}
    .topbar-self-profile.status-warn {{
      border-color: rgba(234, 203, 129, 0.82);
      background: rgba(174, 134, 57, 0.24);
      color: #fff0cd;
      box-shadow: 0 0 0 1px rgba(213, 172, 96, 0.3);
    }}
    .topbar-self-profile.status-stale {{
      border-color: rgba(255, 162, 162, 0.88);
      background: rgba(182, 38, 38, 0.3);
      color: #fff0f0;
      box-shadow: 0 0 0 1px rgba(208, 83, 83, 0.34);
    }}
    .topbar-self-profile.status-unknown {{
      border-color: rgba(214, 238, 223, 0.5);
      background: rgba(248, 255, 251, 0.1);
      color: #f1fff6;
    }}
    .topbar-self-profile-short {{
      display: block;
      font-size: inherit;
      font-weight: inherit;
      letter-spacing: inherit;
      text-transform: none;
      max-width: min(20ch, 28vw);
      overflow: hidden;
      text-overflow: ellipsis;
    }}
    .topbar-chat-change-menu-wrap .chat-change-toggle-btn,
    .topbar-chat-settings-menu-wrap .chat-settings-toggle-btn,
    .topbar-favorite-menu-wrap .favorite-menu-toggle-btn {{
      width: 30px;
      height: 30px;
      border-color: rgba(214, 238, 223, 0.55);
      background: rgba(248, 255, 251, 0.12);
      color: #f1fff6;
    }}
    .topbar-chat-change-menu-wrap .chat-change-toggle-btn:hover,
    .topbar-chat-settings-menu-wrap .chat-settings-toggle-btn:hover,
    .topbar-favorite-menu-wrap .favorite-menu-toggle-btn:hover {{
      border-color: rgba(214, 238, 223, 0.82);
      background: rgba(248, 255, 251, 0.22);
      color: #ffffff;
    }}
    .topbar-chat-change-menu-wrap .chat-change-toggle-btn[aria-expanded="true"],
    .topbar-chat-settings-menu-wrap .chat-settings-toggle-btn[aria-expanded="true"],
    .topbar-favorite-menu-wrap .favorite-menu-toggle-btn[aria-expanded="true"] {{
      border-color: rgba(214, 238, 223, 0.82);
      background: rgba(248, 255, 251, 0.24);
      color: #ffffff;
    }}
    .topbar-chat-change-menu-wrap .chat-change-toggle-btn.has-unread {{
      border-color: #8be0af;
      color: #dbffe9;
      box-shadow: 0 0 0 1px rgba(83, 185, 124, 0.4);
    }}
    .topbar-chat-change-menu-wrap .chat-change-badge {{
      border-color: #173d2d;
    }}
    .topbar-chat-change-menu-wrap .chat-change-menu {{
      top: calc(100% + 10px);
    }}
    .topbar-self-radio-menu-wrap .self-radio-menu {{
      top: calc(100% + 10px);
    }}
    .topbar-chat-settings-menu-wrap .chat-settings-menu {{
      top: calc(100% + 10px);
    }}
    .topbar-favorite-menu-wrap .favorite-menu {{
      top: calc(100% + 10px);
    }}
    .topbar-favorite-menu-wrap .favorite-menu-toggle-btn {{
      width: 30px;
      height: 30px;
      padding: 0;
      border-radius: 999px;
    }}
    .topbar h1 {{
      margin: 0;
      font-size: 20px;
      line-height: 1.04;
      letter-spacing: 0.1px;
    }}
    .topbar .topbar-main-row {{
      display: grid;
      grid-template-columns: minmax(0, max-content) minmax(0, 1fr);
      align-items: center;
      column-gap: 6px;
      min-width: 0;
      min-height: 30px;
    }}
    .topbar .topbar-brand {{
      grid-column: 1;
      justify-self: start;
      display: grid;
      grid-template-columns: minmax(0, 1fr);
      grid-template-rows: auto auto;
      align-items: start;
      row-gap: 0;
      min-width: 0;
      max-width: min(44vw, 520px);
    }}
    .topbar .topbar-heading {{
      display: block;
      align-items: center;
      flex-wrap: nowrap;
      justify-content: flex-start;
      gap: 0;
      text-align: left;
      min-width: 0;
    }}
    .topbar .topbar-heading-app {{
      display: inline-flex;
      align-items: center;
      max-width: min(44vw, 520px);
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }}
    .topbar .topbar-main-spacer {{
      display: none;
    }}
    .topbar .sub {{
      margin-top: 0;
      font-size: 11px;
      opacity: 0.95;
      display: flex;
      flex-direction: column;
      align-items: stretch;
      gap: 8px;
      padding: 0;
      border: 0;
      border-radius: 10px;
      background: transparent;
    }}
    .summary-ticker-density-toggle {{
      position: relative;
      z-index: 3;
      appearance: none;
      -webkit-appearance: none;
      border: 1px solid color-mix(in srgb, var(--ui-border) 76%, var(--ui-accent) 24%);
      border-radius: 8px;
      background: color-mix(in srgb, var(--ui-panel) 92%, var(--ui-accent) 8%);
      box-shadow: none;
      margin: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      width: var(--topbar-corner-reserve, 36px);
      min-width: var(--topbar-corner-reserve, 36px);
      max-width: var(--topbar-corner-reserve, 36px);
      min-height: 0;
      max-height: none;
      align-self: stretch;
      order: -1;
      padding: 0;
      font: inherit;
      cursor: pointer;
      transform: none;
      transition: border-color 120ms ease, background 120ms ease, color 120ms ease;
    }}
    .summary-ticker-density-toggle:hover,
    .summary-ticker-density-toggle:focus-visible {{
      border-color: color-mix(in srgb, var(--ui-accent) 56%, var(--ui-border) 44%);
      background: color-mix(in srgb, var(--ui-panel) 84%, var(--ui-accent) 16%);
      box-shadow: none;
      outline: none;
    }}
    .summary-ticker-density-toggle[aria-pressed="true"] {{
      background: color-mix(in srgb, var(--ui-panel) 86%, var(--ui-accent) 14%);
      border-color: color-mix(in srgb, var(--ui-accent) 42%, var(--ui-border) 58%);
    }}
    .summary-ticker-density-toggle-label {{
      position: absolute;
      width: 1px;
      height: 1px;
      padding: 0;
      margin: -1px;
      overflow: hidden;
      clip: rect(0, 0, 0, 0);
      white-space: nowrap;
      border: 0;
    }}
    .summary-ticker-density-toggle-icon {{
      display: none;
    }}
    .summary-ticker-density-toggle-text {{
      display: none;
    }}
    .topbar .sub .summary-ticker-row {{
      position: relative;
      --summary-visible-ticker-count: 10;
      padding-right: 0;
    }}
    .topbar .sub .summary-ticker-row {{
      display: grid;
      grid-auto-flow: column;
      grid-template-columns: var(--topbar-corner-reserve, 36px) repeat(var(--summary-visible-ticker-count, 10), minmax(0, 1fr));
      grid-auto-columns: minmax(0, 1fr);
      gap: 5px;
      min-width: 0;
      overflow-x: auto;
      overflow-y: hidden;
      overscroll-behavior-x: contain;
      scrollbar-width: thin;
    }}
    .summary-ticker-expanded-slot {{
      width: 100%;
      min-width: 0;
      display: block;
    }}
    .summary-ticker-expanded-slot[hidden] {{
      display: none !important;
    }}
    .topbar .summary-ticker-item {{
      --ticker-text: var(--theme-text-color, var(--ui-text));
      --ticker-text-strong: var(--theme-text-color-strong, var(--ticker-text));
      --ticker-text-soft: var(--theme-text-color-soft, var(--ui-text-soft));
      --ticker-text-muted: var(--theme-text-color-muted, var(--ticker-text-soft));
      border: 1px solid color-mix(in srgb, var(--ui-border) 82%, var(--ui-accent) 18%);
      background: var(--ui-panel);
      border-radius: 7px;
      padding: 4px 7px;
      min-width: 0;
      color: var(--ticker-text);
      position: relative;
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      grid-template-rows: auto;
      column-gap: 7px;
      row-gap: 0;
      align-items: center;
      overflow: hidden;
      isolation: isolate;
      box-shadow: none;
    }}
    .topbar .summary-ticker-item[hidden] {{
      display: none !important;
    }}
    .topbar:not(.ticker-expanded) .summary-ticker-item[data-ticker-id]:not([data-ticker-id="self"]),
    .topbar:not(.ticker-expanded) .summary-ticker-item.is-compact-detail-open {{
      cursor: pointer;
    }}
    .topbar:not(.ticker-expanded) .summary-ticker-item[data-ticker-id]:not([data-ticker-id="self"]):hover,
    .topbar:not(.ticker-expanded) .summary-ticker-item[data-ticker-id]:not([data-ticker-id="self"]):focus-visible {{
      border-color: color-mix(in srgb, var(--ui-border) 78%, var(--ui-text) 22%);
      background: color-mix(in srgb, var(--ui-panel) 93%, var(--ui-border) 7%);
      outline: none;
    }}
    .summary-ticker-expanded-slot .summary-ticker-expanded-card {{
      width: 100%;
      min-width: 0;
      box-sizing: border-box;
      cursor: pointer;
    }}
    .topbar.has-compact-ticker-detail:not(.ticker-expanded) .summary-ticker-item.is-compact-detail-open {{
      min-width: 0;
      border-radius: 10px;
      padding: 8px 10px;
      grid-template-columns: minmax(0, 1fr);
      grid-template-rows: auto auto auto;
      row-gap: 4px;
      align-items: start;
    }}
    .topbar.has-compact-ticker-detail:not(.ticker-expanded) .summary-ticker-item-radio.is-compact-detail-open {{
      grid-template-rows: auto auto auto auto;
    }}
    .workspace-launcher-shell {{
      position: relative;
      display: inline-flex;
      min-width: 0;
      min-height: 0;
      overflow: visible;
    }}
    .topbar-view-menu-btn {{
      width: auto;
      min-width: 88px;
      min-height: 38px;
      position: relative;
      border: 1px solid color-mix(in srgb, var(--ui-border) 74%, var(--ui-accent));
      background:
        linear-gradient(
          180deg,
          color-mix(in srgb, var(--ui-panel) 94%, var(--ui-accent) 6%),
          color-mix(in srgb, var(--ui-panel) 84%, var(--ui-accent) 16%)
        );
      color: #f2fff7;
      border-radius: 999px;
      padding: 0 9px 0 6px;
      display: inline-flex;
      align-items: center;
      justify-content: flex-start;
      gap: 0;
      cursor: pointer;
      font-size: 12px;
      line-height: 1.2;
      font-weight: 700;
      text-align: left;
      color: color-mix(in srgb, var(--ui-text) 86%, var(--ui-accent-soft));
      box-shadow: none;
      transition: border-color 140ms ease, background 140ms ease, color 140ms ease;
    }}
    .topbar-view-menu-btn-main {{
      min-width: 0;
      flex: 1 1 auto;
      display: inline-flex;
      align-items: center;
      gap: 7px;
    }}
    .topbar-view-menu-btn:hover,
    .topbar-view-menu-btn[aria-expanded="true"] {{
      border-color: color-mix(in srgb, var(--ui-accent) 52%, var(--ui-border));
      background:
        linear-gradient(
          180deg,
          color-mix(in srgb, var(--ui-panel) 90%, var(--ui-accent) 10%),
          color-mix(in srgb, var(--ui-panel) 76%, var(--ui-accent) 24%)
        );
      box-shadow: none;
    }}
    .topbar-view-menu-btn.has-unread {{
      border-color: var(--ui-accent);
      box-shadow: none;
    }}
    .topbar-view-menu-btn:focus-visible {{
      outline: 2px solid color-mix(in srgb, var(--ui-accent-soft) 74%, black);
      outline-offset: 2px;
    }}
    .topbar-view-menu-btn-label {{
      min-width: 0;
      flex: 1 1 auto;
      display: inline-flex;
      align-items: center;
      gap: 4px;
      font-size: 12px;
      line-height: 1;
      font-weight: 700;
      letter-spacing: 0.16px;
      color: color-mix(in srgb, var(--ui-text) 84%, var(--ui-accent-soft));
    }}
    .topbar-view-menu-btn-label-text {{
      min-width: 0;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }}
    .topbar-view-menu-btn-badge {{
      flex: 0 0 auto;
      margin-left: auto;
      min-width: 18px;
      height: 18px;
      padding: 0 6px;
      border-radius: 999px;
      border: 1px solid color-mix(in srgb, var(--ui-accent) 28%, transparent);
      background: color-mix(in srgb, var(--ui-accent) 14%, transparent);
      color: color-mix(in srgb, var(--ui-accent-soft) 78%, var(--ui-text));
      display: inline-flex;
      align-items: center;
      justify-content: center;
      font-size: 10px;
      line-height: 1;
      font-weight: 700;
      box-shadow: none;
    }}
    .topbar-view-menu-btn-attention {{
      flex: 0 0 auto;
      width: 10px;
      height: 10px;
      border-radius: 3px;
      border: 1px solid color-mix(in srgb, var(--ui-accent-soft) 54%, transparent);
      background:
        linear-gradient(
          135deg,
          color-mix(in srgb, var(--ui-accent) 58%, white) 0%,
          var(--ui-accent) 100%
        );
      box-shadow:
        0 0 0 3px color-mix(in srgb, var(--ui-accent) 16%, transparent),
        0 0 12px color-mix(in srgb, var(--ui-accent) 26%, transparent);
      transform: rotate(18deg);
    }}
    .topbar-view-menu-btn-badge[hidden],
    .topbar-view-menu-btn-attention[hidden],
    .topbar-view-menu-item-badge[hidden] {{
      display: none !important;
    }}
    .topbar-view-menu-caret {{
      flex: 0 0 auto;
      margin-left: 1px;
      width: 0;
      height: 0;
      border-left: 3px solid transparent;
      border-right: 3px solid transparent;
      border-top: 5px solid color-mix(in srgb, var(--ui-accent-soft) 64%, var(--ui-text));
      transition: transform 140ms ease;
    }}
    .topbar-view-menu-btn[aria-expanded="true"] .topbar-view-menu-caret {{
      transform: rotate(180deg);
    }}
    .topbar-view-menu {{
      position: fixed;
      top: 8px;
      left: 8px;
      min-width: max(260px, 100%);
      max-width: min(320px, calc(100vw - 24px));
      display: flex;
      flex-direction: column;
      gap: 6px;
      padding: 10px;
      border: 1px solid color-mix(in srgb, var(--workspace-shell-border, var(--surface-tint-border)) 72%, var(--ui-border, transparent));
      border-radius: 16px;
      background:
        linear-gradient(
          180deg,
          color-mix(in srgb, var(--workspace-shell-bg-alt, var(--ui-panel)) 86%, #07121f 14%),
          color-mix(in srgb, var(--workspace-shell-bg, var(--ui-panel)) 94%, #050b13 6%)
        ),
        var(--workspace-shell-bg-alt, var(--ui-panel));
      box-shadow: 0 18px 38px rgba(5, 17, 28, 0.24);
      z-index: 1350;
      overflow-y: auto;
      backdrop-filter: blur(14px) saturate(138%);
      -webkit-backdrop-filter: blur(14px) saturate(138%);
    }}
    .topbar-view-menu[hidden] {{
      display: none !important;
    }}
    .topbar-view-menu-item {{
      width: 100%;
      border: 1px solid transparent;
      border-radius: 12px;
      background: transparent;
      color: var(--workspace-shell-text, var(--ui-text));
      padding: 10px;
      display: grid;
      grid-template-columns: auto minmax(0, 1fr) auto;
      align-items: center;
      column-gap: 10px;
      row-gap: 2px;
      text-align: left;
      cursor: pointer;
      line-height: 1.2;
    }}
    .topbar-view-menu-item-icon {{
      width: 30px;
      height: 30px;
      border-radius: 9px;
      border: 1px solid color-mix(in srgb, var(--workspace-shell-border-muted, #d1e0d4) 74%, transparent);
      background: color-mix(in srgb, var(--workspace-shell-bg-alt, #ffffff) 82%, transparent);
      color: var(--workspace-shell-text-soft, #4f6e5a);
      display: inline-flex;
      align-items: center;
      justify-content: center;
      font-size: 9px;
      line-height: 1;
      font-weight: 800;
      letter-spacing: 0.4px;
      text-transform: uppercase;
    }}
    .topbar-view-menu-item-copy {{
      min-width: 0;
      display: flex;
      flex-direction: column;
      gap: 2px;
    }}
    .topbar-view-menu-item-label-row {{
      display: inline-flex;
      align-items: center;
      gap: 6px;
      min-width: 0;
    }}
    .topbar-view-menu-item-badge {{
      min-width: 22px;
      height: 20px;
      padding: 0 6px;
      border-radius: 999px;
      border: 1px solid color-mix(in srgb, var(--workspace-shell-border-strong, #9dc3a7) 34%, transparent);
      background: color-mix(in srgb, var(--workspace-shell-active-bg, #dbeee3) 62%, transparent);
      color: var(--workspace-shell-active-text, var(--workspace-shell-text, #123523));
      display: inline-flex;
      align-items: center;
      justify-content: center;
      font-size: 10px;
      line-height: 1;
      font-weight: 700;
      letter-spacing: 0.02em;
      box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.32);
    }}
    .topbar-view-menu-item:hover {{
      border-color: color-mix(in srgb, var(--workspace-shell-border-strong, #9dc3a7) 48%, transparent);
      background: color-mix(in srgb, var(--workspace-shell-hover-bg, #e6f2e9) 82%, transparent);
    }}
    .topbar-view-menu-item.has-notifications .topbar-view-menu-item-icon {{
      border-color: color-mix(in srgb, var(--workspace-shell-border-strong, #9dc3a7) 62%, transparent);
      background: color-mix(in srgb, var(--workspace-shell-active-bg, #dbeee3) 72%, transparent);
      color: var(--workspace-shell-active-text, var(--workspace-shell-text, #123523));
    }}
    .topbar-view-menu-item.is-active,
    .topbar-view-menu-item[aria-checked="true"] {{
