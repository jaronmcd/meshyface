      inset: calc(-3px - var(--map-node-ring-width, 2px));
      border-radius: 999px;
      pointer-events: none;
      opacity: 0;
      z-index: 0;
      background: conic-gradient(
        var(--map-node-trace-color, #7dd3fc) var(--map-node-trace-angle, 0deg),
        rgba(125, 211, 252, 0.2) 0deg
      );
      -webkit-mask: radial-gradient(farthest-side, transparent calc(100% - 4px), #000 calc(100% - 3px));
      mask: radial-gradient(farthest-side, transparent calc(100% - 4px), #000 calc(100% - 3px));
      filter: drop-shadow(0 0 5px rgba(125, 211, 252, 0.52));
      transition: opacity 140ms ease;
    }}
    .map-node-emoji-marker.is-trace-running::before {{
      opacity: 1;
