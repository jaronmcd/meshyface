    function selectConsoleNodeFromSyntax(rawNodeId) {{
      const nodeId = normalizeNodeId(rawNodeId || "");
      if (!isSelectableNodeId(nodeId)) return false;
      if (typeof selectNode === "function") {{
        selectNode(nodeId, true, false);
      }} else {{
        selectedNodeId = nodeId;
        persistSelection();
        highlightNodeSelection("", nodeId);
