      window.requestAnimationFrame(() => {{
        if (typeof chatNodeNavigatorFindRowForNodeId === "function") {{
          const located = chatNodeNavigatorFindRowForNodeId(nodeId);
          if (located && located.rowEl instanceof HTMLElement) {{
            if (typeof noteChatNodeNavigatorProgrammaticScrollReset === "function") {{
              noteChatNodeNavigatorProgrammaticScrollReset(420);
