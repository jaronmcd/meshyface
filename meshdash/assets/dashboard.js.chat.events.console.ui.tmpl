    const consoleCommandPaletteState = {{
      open: false,
      query: "",
      commands: [],
      filtered: [],
      selectedIndex: 0,
    }};

    function syncConsoleTerminalScreenFillHeight() {{
      const terminalScreen = document.getElementById("console-terminal-screen");
      if (!(terminalScreen instanceof HTMLElement)) return;
      if (activeLayoutView !== "console") {{
        terminalScreen.style.removeProperty("height");
        terminalScreen.style.removeProperty("min-height");
        terminalScreen.style.removeProperty("max-height");
        return;
      }}
      const container = terminalScreen.parentElement;
      if (!(container instanceof HTMLElement)) return;
      const rect = terminalScreen.getBoundingClientRect();
      const containerRect = container.getBoundingClientRect();
      const consoleCard = terminalScreen.closest(".console");
      const layout = document.getElementById("dashboard-layout");
      const workspaceMain = terminalScreen.closest(".workspace-main");
      const top = Number(rect && rect.top);
      let bottom = Number(containerRect && containerRect.bottom);
      if (consoleCard instanceof HTMLElement) {{
        const cardRect = consoleCard.getBoundingClientRect();
        const cardBottom = Number(cardRect && cardRect.bottom);
        if (Number.isFinite(cardBottom) && cardBottom > bottom) {{
          bottom = cardBottom;
        }}
      }}
      if (layout instanceof HTMLElement) {{
        const layoutRect = layout.getBoundingClientRect();
        const layoutBottom = Number(layoutRect && layoutRect.bottom);
        if (Number.isFinite(layoutBottom) && layoutBottom > bottom) {{
          bottom = layoutBottom;
        }}
      }}
      if (workspaceMain instanceof HTMLElement) {{
        const mainRect = workspaceMain.getBoundingClientRect();
        const mainBottom = Number(mainRect && mainRect.bottom);
        if (Number.isFinite(mainBottom) && mainBottom > bottom) {{
          bottom = mainBottom;
        }}
      }}
      if (!Number.isFinite(top) || !Number.isFinite(bottom)) return;
      let bottomInset = 0;
      try {{
        const styles = window.getComputedStyle(container);
        bottomInset = Math.max(0, Number.parseFloat(styles.paddingBottom) || 0);
      }} catch (_err) {{
      }}
      const measuredHeight = Math.floor(bottom - top - bottomInset);
      if (!Number.isFinite(measuredHeight) || measuredHeight <= 0) {{
        terminalScreen.style.removeProperty("height");
        terminalScreen.style.removeProperty("min-height");
        terminalScreen.style.removeProperty("max-height");
        return;
      }}
      const nextHeight = Math.max(140, measuredHeight);
      terminalScreen.style.height = `${{nextHeight}}px`;
      terminalScreen.style.removeProperty("min-height");
      terminalScreen.style.removeProperty("max-height");
    }}

    function scheduleConsoleTerminalScreenFillHeight() {{
      if (typeof window === "undefined") return;
      if (consoleFrameFillRaf !== null && typeof window.cancelAnimationFrame === "function") {{
        try {{
          window.cancelAnimationFrame(consoleFrameFillRaf);
        }} catch (_err) {{
        }}
      }}
      if (typeof window.requestAnimationFrame !== "function") {{
        syncConsoleTerminalScreenFillHeight();
        return;
      }}
      consoleFrameFillRaf = window.requestAnimationFrame(() => {{
        consoleFrameFillRaf = null;
        syncConsoleTerminalScreenFillHeight();
      }});
    }}

    function isConsoleHotkeyTextEntryTarget(target) {{
      if (!(target instanceof Element)) return false;
      if (target instanceof HTMLTextAreaElement) return true;
      if (target instanceof HTMLSelectElement) return true;
      if (target instanceof HTMLInputElement) {{
        return target.id !== "console-command-input";
      }}
      if (target instanceof HTMLElement && target.isContentEditable) {{
        return true;
      }}
      const editableHost = target.closest("[contenteditable=''], [contenteditable='true'], [contenteditable='plaintext-only']");
      return editableHost instanceof HTMLElement;
    }}

    function bindConsoleDropdownHotkey() {{
      if (document.body.dataset.consoleHotkeyBound === "1") return;
      document.body.dataset.consoleHotkeyBound = "1";
      document.addEventListener("keydown", (ev) => {{
        if (!ev || ev.defaultPrevented) return;
        if (ev.isComposing || ev.repeat) return;
        if (ev.ctrlKey || ev.metaKey || ev.altKey) return;
        const key = String(ev.key || "");
        const code = String(ev.code || "");
        if (!(code === "Backquote" || key === "`" || key === "~")) return;
        const target = ev.target;
        if (
          activeLayoutView !== "console"
          && isConsoleHotkeyTextEntryTarget(target instanceof Element ? target : null)
        ) {{
          return;
        }}
        const remembered = normalizeLayoutView(consoleHotkeyReturnLayoutView || "chat");
        const nextView = activeLayoutView === "console"
          ? (remembered === "console" ? "chat" : remembered)
          : "console";
        ev.preventDefault();
        applyLayoutView(nextView, true);
      }});
    }}

    function consoleCommandPaletteElement() {{
      const el = document.getElementById("console-command-palette");
      return el instanceof HTMLElement ? el : null;
    }}

    function consoleCommandPaletteInputElement() {{
      const el = document.getElementById("console-command-palette-input");
      return el instanceof HTMLInputElement ? el : null;
    }}

    function consoleCommandPaletteListElement() {{
      const el = document.getElementById("console-command-palette-list");
      return el instanceof HTMLElement ? el : null;
    }}

    function collectConsoleCommandPaletteEntries() {{
      ensureConsoleCommandsRegistered();
      const entries = Array.from(consoleCommandRegistry.values())
        .filter((entry) => entry && typeof entry === "object")
        .map((entry) => {{
          const name = String(entry.name || "").trim().toLowerCase();
          const usage = String(entry.usage || name).trim() || name;
          const description = String(entry.description || "").trim();
          return {{
            name,
            usage,
            description,
            hiddenFromHelp: entry.hiddenFromHelp === true,
            requiresArgs: /<[^>]+>/.test(usage),
            searchText: `${{name}} ${{usage}} ${{description}}`.toLowerCase(),
          }};
        }})
        .filter((entry) => !!entry.name)
        .sort((a, b) => a.name.localeCompare(b.name));
      return entries;
    }}

    function filterConsoleCommandPaletteEntries(query, entries = null) {{
      const source = Array.isArray(entries) ? entries : collectConsoleCommandPaletteEntries();
      const cleanQuery = String(query == null ? "" : query).trim().toLowerCase();
      const includeHidden = cleanQuery.startsWith("--");
      const visibleSource = includeHidden
        ? source
        : source.filter((entry) => entry && !entry.hiddenFromHelp);
      if (!cleanQuery) {{
        return visibleSource.slice(0, 80);
      }}
      const terms = cleanQuery.split(/\s+/).filter(Boolean);
      const ranked = [];
      for (const entry of visibleSource) {{
        if (!entry || typeof entry !== "object") continue;
        const haystack = String(entry.searchText || "").toLowerCase();
        if (terms.some((term) => !haystack.includes(term))) continue;
        let score = 0;
        if (entry.name === cleanQuery) score += 60;
        if (entry.name.startsWith(cleanQuery)) score += 30;
        if (entry.name.includes(cleanQuery)) score += 12;
        if (entry.usage.toLowerCase().startsWith(cleanQuery)) score += 8;
        if (entry.description.toLowerCase().includes(cleanQuery)) score += 4;
        score += Math.max(0, 6 - terms.length);
        ranked.push({{ entry, score }});
      }}
      ranked.sort((a, b) => {{
        if (b.score !== a.score) return b.score - a.score;
        return String(a.entry.name || "").localeCompare(String(b.entry.name || ""));
      }});
      return ranked.slice(0, 80).map((item) => item.entry);
    }}

    function renderConsoleCommandPaletteList() {{
      const list = consoleCommandPaletteListElement();
      if (!(list instanceof HTMLElement)) return;
      list.innerHTML = "";
      const items = Array.isArray(consoleCommandPaletteState.filtered)
        ? consoleCommandPaletteState.filtered
        : [];
      if (!items.length) {{
        const empty = document.createElement("div");
        empty.className = "console-command-palette-empty";
        empty.textContent = "No command matches. Try a shorter keyword.";
        list.appendChild(empty);
        return;
      }}
      const selectedIndex = Math.max(0, Math.min(items.length - 1, Number(consoleCommandPaletteState.selectedIndex) || 0));
      consoleCommandPaletteState.selectedIndex = selectedIndex;
      const fragment = document.createDocumentFragment();
      for (let index = 0; index < items.length; index += 1) {{
        const item = items[index];
        const option = document.createElement("button");
        option.type = "button";
        option.className = `console-command-palette-item${{index === selectedIndex ? " is-selected" : ""}}`;
        option.setAttribute("role", "option");
        option.setAttribute("aria-selected", index === selectedIndex ? "true" : "false");
        option.dataset.commandPaletteIndex = String(index);

        const name = document.createElement("span");
        name.className = "console-command-palette-item-name";
        name.textContent = item.name;
        option.appendChild(name);

        const runHint = document.createElement("span");
        runHint.className = "console-command-palette-item-run";
        runHint.textContent = item.requiresArgs ? "Needs args" : "Run";
        option.appendChild(runHint);

        const usage = document.createElement("span");
        usage.className = "console-command-palette-item-usage";
        usage.textContent = item.usage;
        option.appendChild(usage);

        if (item.description) {{
          const description = document.createElement("span");
          description.className = "console-command-palette-item-description";
          description.textContent = item.description;
          option.appendChild(description);
        }}

        fragment.appendChild(option);
      }}
      list.appendChild(fragment);
      const selectedEl = list.querySelector(".console-command-palette-item.is-selected");
      if (selectedEl instanceof HTMLElement) {{
        selectedEl.scrollIntoView({{ block: "nearest" }});
      }}
    }}

    function refreshConsoleCommandPaletteResults(query = consoleCommandPaletteState.query) {{
      const cleanQuery = String(query == null ? "" : query);
      consoleCommandPaletteState.query = cleanQuery;
      const baseEntries = Array.isArray(consoleCommandPaletteState.commands) && consoleCommandPaletteState.commands.length
        ? consoleCommandPaletteState.commands
        : collectConsoleCommandPaletteEntries();
      consoleCommandPaletteState.commands = baseEntries;
      const filtered = filterConsoleCommandPaletteEntries(cleanQuery, baseEntries);
      consoleCommandPaletteState.filtered = filtered;
      const maxIndex = Math.max(0, filtered.length - 1);
      consoleCommandPaletteState.selectedIndex = Math.max(0, Math.min(maxIndex, Number(consoleCommandPaletteState.selectedIndex) || 0));
      renderConsoleCommandPaletteList();
    }}

    function moveConsoleCommandPaletteSelection(delta) {{
      const items = Array.isArray(consoleCommandPaletteState.filtered)
        ? consoleCommandPaletteState.filtered
        : [];
      if (!items.length) return;
      const cleanDelta = Math.trunc(Number(delta) || 0);
      if (!cleanDelta) return;
      const total = items.length;
      const current = Math.max(0, Math.min(total - 1, Number(consoleCommandPaletteState.selectedIndex) || 0));
      const next = (current + cleanDelta + total) % total;
      consoleCommandPaletteState.selectedIndex = next;
      renderConsoleCommandPaletteList();
    }}

    function stageConsoleCommandPaletteDraft(rawDraft) {{
      const input = consoleCommandInputElement();
      if (!(input instanceof HTMLInputElement)) return false;
      input.value = String(rawDraft == null ? "" : rawDraft);
      consoleCommandHistoryCursor = -1;
      consoleCommandDraft = "";
      if (typeof resetConsoleAutocompleteState === "function") {{
        resetConsoleAutocompleteState();
      }}
      if (typeof syncConsoleCommandDraftRender === "function") {{
        syncConsoleCommandDraftRender(input.value);
      }} else {{
        renderConsolePromptBuffer(false);
      }}
      focusConsoleCommandInput(false);
      return true;
    }}

    function runConsoleCommandPaletteSelection() {{
      const items = Array.isArray(consoleCommandPaletteState.filtered)
        ? consoleCommandPaletteState.filtered
        : [];
      if (!items.length) return false;
      const index = Math.max(0, Math.min(items.length - 1, Number(consoleCommandPaletteState.selectedIndex) || 0));
      const item = items[index];
      if (!item || typeof item !== "object") return false;
      setConsoleCommandPaletteOpen(false);
      applyLayoutView("console", true);
      if (item.requiresArgs) {{
        return stageConsoleCommandPaletteDraft(`${{item.name}} `);
      }}
      if (typeof runConsoleCommandLine === "function") {{
        void runConsoleCommandLine(item.name);
      }}
      focusConsoleCommandInput(false);
      return true;
    }}

    function setConsoleCommandPaletteOpen(open, options = null) {{
      const root = consoleCommandPaletteElement();
      if (!(root instanceof HTMLElement)) {{
        consoleCommandPaletteState.open = false;
        return;
      }}
      const opts = (options && typeof options === "object") ? options : {{}};
      const nextOpen = !!open;
      consoleCommandPaletteState.open = nextOpen;
      if (!nextOpen) {{
        root.hidden = true;
        root.setAttribute("aria-hidden", "true");
        return;
      }}
      consoleCommandPaletteState.commands = collectConsoleCommandPaletteEntries();
      if (opts.resetQuery === true) {{
        consoleCommandPaletteState.query = "";
      }} else if (Object.prototype.hasOwnProperty.call(opts, "query")) {{
        consoleCommandPaletteState.query = String(opts.query == null ? "" : opts.query);
      }}
      const input = consoleCommandPaletteInputElement();
      if (input instanceof HTMLInputElement) {{
        input.value = consoleCommandPaletteState.query;
      }}
      consoleCommandPaletteState.selectedIndex = 0;
      refreshConsoleCommandPaletteResults(consoleCommandPaletteState.query);
      root.hidden = false;
      root.setAttribute("aria-hidden", "false");
      window.requestAnimationFrame(() => {{
        const activeInput = consoleCommandPaletteInputElement();
        if (!(activeInput instanceof HTMLInputElement)) return;
        try {{
          activeInput.focus({{ preventScroll: true }});
        }} catch (_err) {{
          activeInput.focus();
        }}
        activeInput.select();
      }});
    }}

    function bindConsoleCommandPaletteControls() {{
      const root = consoleCommandPaletteElement();
      const input = consoleCommandPaletteInputElement();
      const list = consoleCommandPaletteListElement();
      if (!(root instanceof HTMLElement) || !(input instanceof HTMLInputElement) || !(list instanceof HTMLElement)) {{
        return;
      }}
      if (root.dataset.bound !== "1") {{
        root.dataset.bound = "1";
        root.addEventListener("click", (ev) => {{
          const target = ev.target;
          if (!(target instanceof Element)) return;
          if (target.closest("[data-command-palette-close]")) {{
            setConsoleCommandPaletteOpen(false);
            return;
          }}
          const btn = target.closest(".console-command-palette-item");
          if (!(btn instanceof HTMLButtonElement)) return;
          const index = Math.trunc(Number(btn.dataset.commandPaletteIndex));
          if (Number.isFinite(index) && index >= 0) {{
            consoleCommandPaletteState.selectedIndex = index;
          }}
          runConsoleCommandPaletteSelection();
        }});
      }}
      if (input.dataset.bound !== "1") {{
        input.dataset.bound = "1";
        input.addEventListener("input", () => {{
          consoleCommandPaletteState.selectedIndex = 0;
          refreshConsoleCommandPaletteResults(input.value);
        }});
        input.addEventListener("keydown", (ev) => {{
          if (ev.key === "ArrowDown") {{
            ev.preventDefault();
            moveConsoleCommandPaletteSelection(1);
            return;
          }}
          if (ev.key === "ArrowUp") {{
            ev.preventDefault();
            moveConsoleCommandPaletteSelection(-1);
            return;
          }}
          if (ev.key === "Enter" && !ev.shiftKey && !ev.ctrlKey && !ev.metaKey && !ev.altKey) {{
            ev.preventDefault();
            runConsoleCommandPaletteSelection();
            return;
          }}
          if (ev.key === "Escape") {{
            ev.preventDefault();
            setConsoleCommandPaletteOpen(false);
          }}
        }});
      }}
      if (document.body.dataset.consoleCommandPaletteHotkeyBound !== "1") {{
        document.body.dataset.consoleCommandPaletteHotkeyBound = "1";
        document.addEventListener("keydown", (ev) => {{
          if (!ev || ev.defaultPrevented || ev.isComposing || ev.repeat) return;
          const key = String(ev.key || "").toLowerCase();
          if (key === "k" && (ev.ctrlKey || ev.metaKey) && !ev.shiftKey && !ev.altKey) {{
            ev.preventDefault();
            setConsoleCommandPaletteOpen(!consoleCommandPaletteState.open, {{
              resetQuery: !consoleCommandPaletteState.open,
            }});
            return;
          }}
          if (key === "escape" && consoleCommandPaletteState.open) {{
            ev.preventDefault();
            setConsoleCommandPaletteOpen(false);
          }}
        }});
      }}
    }}

    function consoleContextMenuElement() {{
      const menu = document.getElementById("console-context-menu");
      return menu instanceof HTMLElement ? menu : null;
    }}

    function canUseConsoleMenuScriptPaste() {{
      return !!(
        window.isSecureContext
        && navigator.clipboard
        && typeof navigator.clipboard.readText === "function"
      );
    }}

    function resolveConsoleContextMenuSelectionText() {{
      const pre = document.getElementById("live-console");
      return selectionTextWithin(pre instanceof HTMLElement ? pre : null);
    }}

    function selectAllConsoleText() {{
      const pre = document.getElementById("live-console");
      const selection = window.getSelection ? window.getSelection() : null;
      if (!(pre instanceof HTMLElement) || !selection || typeof selection.removeAllRanges !== "function") {{
        return false;
      }}
      try {{
        const range = document.createRange();
        range.selectNodeContents(pre);
        selection.removeAllRanges();
        selection.addRange(range);
        consoleContextMenuSelectionText = String(selection.toString() || "");
        return consoleContextMenuSelectionText.trim().length > 0;
      }} catch (_err) {{
        return false;
      }}
    }}

    function syncConsoleContextMenuActionState(menuEl = null) {{
      const menu = menuEl instanceof HTMLElement ? menuEl : consoleContextMenuElement();
      if (!(menu instanceof HTMLElement)) return;
      const pasteBtn = document.getElementById("console-context-menu-paste");
      const pasteLabel = document.getElementById("console-context-menu-paste-label");
      const pasteHint = document.getElementById("console-context-menu-paste-hint");
      const copyBtn = document.getElementById("console-context-menu-copy");
      const selectAllBtn = document.getElementById("console-context-menu-select-all");
      const selectionText = consoleContextMenuSelectionText || resolveConsoleContextMenuSelectionText();
      const pre = document.getElementById("live-console");
      const hasConsoleText = pre instanceof HTMLElement && String(pre.textContent || "").trim().length > 0;
      const supportsScriptPaste = canUseConsoleMenuScriptPaste();
      if (pasteLabel instanceof HTMLElement) {{
        pasteLabel.textContent = supportsScriptPaste ? "Paste" : "Use Ctrl+V";
      }}
      if (pasteHint instanceof HTMLElement) {{
        pasteHint.textContent = supportsScriptPaste ? "Ctrl+V" : "HTTP";
      }}
      if (pasteBtn instanceof HTMLButtonElement) {{
        pasteBtn.disabled = false;
        pasteBtn.title = supportsScriptPaste
          ? "Paste clipboard into the console"
          : "This HTTP page cannot read the clipboard directly. Click here to focus the console, then press Ctrl+V.";
      }}
      if (copyBtn instanceof HTMLButtonElement) {{
        copyBtn.disabled = selectionText.trim().length < 1;
        copyBtn.title = copyBtn.disabled
          ? "Select console text to copy"
          : "Copy the current console selection";
      }}
      if (selectAllBtn instanceof HTMLButtonElement) {{
        selectAllBtn.disabled = !hasConsoleText;
        selectAllBtn.title = hasConsoleText
          ? "Select the full console output"
          : "No console text to select";
      }}
    }}

    function setConsoleContextMenuOpen(open, options = null) {{
      const menu = consoleContextMenuElement();
      if (!(menu instanceof HTMLElement)) {{
        consoleContextMenuOpen = false;
        consoleContextMenuSelectionText = "";
        return;
      }}
      consoleContextMenuOpen = !!open;
      if (!consoleContextMenuOpen) {{
        consoleContextMenuSelectionText = "";
        menu.hidden = true;
        menu.style.removeProperty("left");
        menu.style.removeProperty("top");
        menu.style.removeProperty("visibility");
        return;
      }}
      const terminalScreen = document.getElementById("console-terminal-screen");
      if (!(terminalScreen instanceof HTMLElement)) {{
        consoleContextMenuOpen = false;
        menu.hidden = true;
        return;
      }}
      consoleContextMenuSelectionText = resolveConsoleContextMenuSelectionText();
      menu.hidden = false;
      menu.style.visibility = "hidden";
      syncConsoleContextMenuActionState(menu);
      const terminalRect = terminalScreen.getBoundingClientRect();
      const opts = (options && typeof options === "object") ? options : {{}};
      const rawClientX = Number(opts.clientX);
      const rawClientY = Number(opts.clientY);
      const clientX = Number.isFinite(rawClientX) && rawClientX > 0
        ? rawClientX
        : (terminalRect.left + 16);
      const clientY = Number.isFinite(rawClientY) && rawClientY > 0
        ? rawClientY
        : (terminalRect.top + 16);
      const menuRect = menu.getBoundingClientRect();
      const maxLeft = Math.max(8, terminalRect.width - menuRect.width - 8);
      const maxTop = Math.max(8, terminalRect.height - menuRect.height - 8);
      const nextLeft = Math.max(8, Math.min(maxLeft, clientX - terminalRect.left));
      const nextTop = Math.max(8, Math.min(maxTop, clientY - terminalRect.top));
      menu.style.left = `${{Math.round(nextLeft)}}px`;
      menu.style.top = `${{Math.round(nextTop)}}px`;
      menu.style.visibility = "";
    }}

    async function pasteConsoleFromContextMenu() {{
      focusConsoleCommandInput(false);
      const input = consoleCommandInputElement();
      if (!(input instanceof HTMLInputElement)) return false;
      if (!canUseConsoleMenuScriptPaste()) {{
        return false;
      }}
      try {{
        const pastedText = String(await navigator.clipboard.readText() || "");
        const handledPaste = typeof handleConsolePastedText === "function"
          ? handleConsolePastedText(pastedText, input)
          : insertTextIntoConsoleCommandInput(pastedText, input);
        if (handledPaste) {{
          return true;
        }}
      }} catch (_err) {{
      }}
      return false;
    }}

    function bindConsoleAutocompleteMenuControls() {{
      const menu = consoleAutocompleteMenuElement();
      if (!(menu instanceof HTMLElement) || menu.dataset.bound === "1") return;
      menu.dataset.bound = "1";
      menu.addEventListener("mousedown", (ev) => {{
        const target = ev.target;
        if (target instanceof Element && target.closest(".console-autocomplete-item")) {{
          ev.preventDefault();
        }}
      }});
      menu.addEventListener("click", (ev) => {{
