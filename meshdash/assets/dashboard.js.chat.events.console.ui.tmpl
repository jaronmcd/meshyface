        const item = target.closest(".console-autocomplete-item");
        if (!(item instanceof HTMLElement)) return;
        const index = Math.trunc(Number(item.dataset.consoleAutocompleteIndex));
        if (Number.isFinite(index) && index >= 0) {{
          consoleAutocompleteMenuSelectedIndex = index;
        }}
        ev.preventDefault();
        ev.stopPropagation();
