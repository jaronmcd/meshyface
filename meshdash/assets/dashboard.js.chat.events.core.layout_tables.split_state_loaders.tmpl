    function applyChatPanelSplitState() {{
      const shell = document.querySelector(".workspace-shell");
      if (!(shell instanceof HTMLElement)) return;
      const rect = shell.getBoundingClientRect();
      chatPanelWidthPx = clampChatPanelWidthPx(chatPanelWidthPx, rect.width);
      chatPanelCollapsedWidthPx = clampChatPanelCollapsedWidthPx(chatPanelCollapsedWidthPx, rect.width);
      shell.style.setProperty("--chat-panel-width", `${{chatPanelWidthPx}}px`);
      shell.style.setProperty("--chat-panel-collapsed-width", `${{chatPanelCollapsedWidthPx}}px`);
    }}

    function applyChatPanelCollapseState() {{
      const shell = document.querySelector(".workspace-shell");
      const panel = document.getElementById("chat-left-panel");
      const toggleBtn = document.getElementById("chat-panel-collapse-btn");
      const collapsed = !!chatPanelCollapsed;

      if (shell instanceof HTMLElement) {{
        shell.classList.toggle("chat-panel-collapsed", collapsed);
      }}
      if (panel instanceof HTMLElement) {{
        panel.classList.toggle("chat-panel-collapsed", collapsed);
      }}
      if (toggleBtn instanceof HTMLButtonElement) {{
        const nextLabel = collapsed ? "Expand node list" : "Collapse node list";
        toggleBtn.setAttribute("aria-pressed", collapsed ? "true" : "false");
        toggleBtn.setAttribute("aria-label", nextLabel);
        toggleBtn.title = nextLabel;
      }}
      if (typeof syncChatNodeDetailsDrawer === "function") {{
        syncChatNodeDetailsDrawer(latestState, {{
          fetchHistory: false,
        }});
      }}
      if (typeof scheduleChatNodeNavigatorSearchBoundsSync === "function") {{
        scheduleChatNodeNavigatorSearchBoundsSync();
      }}
    }}

    function setChatPanelCollapsed(nextCollapsed, options = null) {{
      const opts = options && typeof options === "object" ? options : {{}};
      const collapsed = !!nextCollapsed;
      if (chatPanelCollapsed === collapsed) {{
        applyChatPanelCollapseState();
        return;
      }}
      chatPanelCollapsed = collapsed;
      if (collapsed) {{
        chatNodeNavigatorMenuOpen = false;
        if (typeof renderChatNodeNavigatorMenuControls === "function") {{
          renderChatNodeNavigatorMenuControls();
        }}
      }}
      applyChatPanelCollapseState();
      if (opts.persist !== false && typeof persistChatPanelCollapseState === "function") {{
        persistChatPanelCollapseState();
      }}
      if (typeof requestMapResize === "function") {{
        requestMapResize();
      }}
    }}

