    function clampSplitPct(value) {{
      return Math.max(42, Math.min(78, value));
    }}

    function clampTopSplitPx(value) {{
      const max = Math.max(300, Math.min(760, window.innerHeight - 320));
      return Math.max(220, Math.min(max, value));
    }}

    function clampMidSplitPx(value) {{
      const max = Math.max(220, Math.min(620, window.innerHeight - 380));
      return Math.max(160, Math.min(max, value));
    }}

    function clampLowSplitPx(value) {{
      const max = Math.max(220, Math.min(560, window.innerHeight - 320));
      return Math.max(160, Math.min(max, value));
    }}

    function clampNetworkNodesListPct(value) {{
      return Math.max(28, Math.min(78, value));
    }}

    function clampSavedNodePanePct(value) {{
      return Math.max(30, Math.min(70, value));
    }}

    function clampSavedNodeMainPct(value) {{
      return Math.max(28, Math.min(78, value));
    }}

    function clampHistoryActivityTopPct(value) {{
      return Math.max(30, Math.min(76, value));
    }}

    function clampHistoryChatMainPct(value) {{
      return Math.max(42, Math.min(86, value));
    }}

    function clampBotsMainPanePct(value) {{
      return Math.max(30, Math.min(70, value));
    }}

    function clampBotsCommandListPct(value) {{
      return Math.max(30, Math.min(70, value));
    }}

    function clampChatPanelWidthPx(value, containerWidth = window.innerWidth) {{
      const numeric = Number(value);
      if (!Number.isFinite(numeric)) return 250;
      const min = 190;
      const width = Number(containerWidth);
      const safeWidth = Number.isFinite(width) && width > 0 ? width : window.innerWidth;
      const max = Math.max(260, Math.min(900, safeWidth - 220));
      return Math.max(min, Math.min(max, Math.round(numeric)));
    }}

    function clampChatPanelCollapsedWidthPx(value, containerWidth = window.innerWidth) {{
      const numeric = Number(value);
      if (!Number.isFinite(numeric)) return 160;
      const min = 96;
      const width = Number(containerWidth);
      const safeWidth = Number.isFinite(width) && width > 0 ? width : window.innerWidth;
      const max = Math.max(160, Math.min(420, safeWidth - 220));
      return Math.max(min, Math.min(max, Math.round(numeric)));
    }}

    function clampChatNodeListPct(value) {{
      return Math.max(18, Math.min(82, value));
    }}

    function clampMacrosPanelWidthPx(value, containerWidth = window.innerWidth) {{
      const numeric = Number(value);
      if (!Number.isFinite(numeric)) return 460;
      const min = 360;
      const rightMin = 280;
      const splitterWidth = 12;
      const bodyPadding = 12;
      const width = Number(containerWidth);
      const safeWidth = Number.isFinite(width) && width > 0 ? width : window.innerWidth;
      const max = Math.max(min, Math.min(980, safeWidth - rightMin - splitterWidth - bodyPadding));
      return Math.max(min, Math.min(max, Math.round(numeric)));
    }}

    function applySplitState() {{
      const layout = document.querySelector(".layout");
      if (!(layout instanceof HTMLElement)) return;
      layout.style.setProperty("--split-left-pct", `${{splitPct}}%`);
      layout.style.setProperty("--split-top-px", `${{splitTopPx}}px`);
      layout.style.setProperty("--split-mid-px", `${{splitMidPx}}px`);
      layout.style.setProperty("--split-low-px", `${{splitLowPx}}px`);
