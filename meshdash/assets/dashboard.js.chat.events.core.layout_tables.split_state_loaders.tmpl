    function clampSplitPct(value) {{
      return Math.max(42, Math.min(78, value));
    }}

    function clampTopSplitPx(value) {{
      const max = Math.max(300, Math.min(760, window.innerHeight - 320));
      return Math.max(220, Math.min(max, value));
    }}

    function clampMidSplitPx(value) {{
      const max = Math.max(220, Math.min(620, window.innerHeight - 380));
      return Math.max(160, Math.min(max, value));
    }}

    function clampLowSplitPx(value) {{
      const max = Math.max(220, Math.min(560, window.innerHeight - 320));
      return Math.max(160, Math.min(max, value));
    }}

    function clampNetworkNodesListPct(value) {{
      return Math.max(28, Math.min(78, value));
    }}

    function clampSavedNodePanePct(value) {{
      return Math.max(30, Math.min(70, value));
    }}

    function clampSavedNodeMainPct(value) {{
      return Math.max(28, Math.min(78, value));
    }}

    function clampHistoryActivityTopPct(value) {{
      return Math.max(30, Math.min(76, value));
    }}

    function clampHistoryChatMainPct(value) {{
      return Math.max(42, Math.min(86, value));
    }}

    function resolveGamesShellMetrics(containerWidth = window.innerWidth) {{
      const width = Number(containerWidth);
      const safeWidth = Number.isFinite(width) && width > 0 ? width : window.innerWidth;
      const stackedStatus = typeof window.matchMedia === "function"
        && window.matchMedia("(max-width: 1180px)").matches;
      return {{
        safeWidth,
        stackedStatus,
        splitterWidth: 8,
        sidebarMin: stackedStatus ? 160 : 176,
        sidebarMax: 420,
        statusMin: 140,
        statusMax: 320,
        boardMin: stackedStatus ? 280 : 360,
      }};
    }}

    function clampGamesSidebarWidthPx(value, containerWidth = window.innerWidth, statusWidth = gamesStatusWidthPx) {{
      const numeric = Number(value);
      if (!Number.isFinite(numeric)) return 220;
      const metrics = resolveGamesShellMetrics(containerWidth);
      const pairedStatusWidth = Number.isFinite(Number(statusWidth))
        ? Math.max(metrics.statusMin, Math.round(Number(statusWidth)))
        : gamesStatusWidthPx;
      const reservedWidth = metrics.boardMin + metrics.splitterWidth + (
        metrics.stackedStatus ? 0 : (metrics.splitterWidth + pairedStatusWidth)
      );
      const max = Math.max(
        metrics.sidebarMin,
        Math.min(metrics.sidebarMax, metrics.safeWidth - reservedWidth)
      );
      return Math.max(metrics.sidebarMin, Math.min(max, Math.round(numeric)));
    }}

    function clampGamesStatusWidthPx(value, containerWidth = window.innerWidth, sidebarWidth = gamesSidebarWidthPx) {{
      const numeric = Number(value);
      if (!Number.isFinite(numeric)) return 176;
      const metrics = resolveGamesShellMetrics(containerWidth);
      const pairedSidebarWidth = Number.isFinite(Number(sidebarWidth))
        ? Math.max(metrics.sidebarMin, Math.round(Number(sidebarWidth)))
        : gamesSidebarWidthPx;
      if (metrics.stackedStatus) {{
        return Math.max(metrics.statusMin, Math.min(metrics.statusMax, Math.round(numeric)));
      }}
      const reservedWidth = metrics.boardMin + (metrics.splitterWidth * 2) + pairedSidebarWidth;
      const max = Math.max(
        metrics.statusMin,
        Math.min(metrics.statusMax, metrics.safeWidth - reservedWidth)
      );
      return Math.max(metrics.statusMin, Math.min(max, Math.round(numeric)));
    }}

    function clampChatPanelWidthPx(value, containerWidth = window.innerWidth) {{
      const numeric = Number(value);
      if (!Number.isFinite(numeric)) return 250;
      const min = 190;
      const width = Number(containerWidth);
      const safeWidth = Number.isFinite(width) && width > 0 ? width : window.innerWidth;
      const max = Math.max(260, Math.min(900, safeWidth - 220));
      return Math.max(min, Math.min(max, Math.round(numeric)));
    }}

    function clampChatPanelCollapsedWidthPx(value, containerWidth = window.innerWidth) {{
      const numeric = Number(value);
      if (!Number.isFinite(numeric)) return 160;
      const min = 96;
      const width = Number(containerWidth);
      const safeWidth = Number.isFinite(width) && width > 0 ? width : window.innerWidth;
      const max = Math.max(160, Math.min(420, safeWidth - 220));
      return Math.max(min, Math.min(max, Math.round(numeric)));
    }}

    function clampChatNodeListPct(value) {{
      return Math.max(18, Math.min(82, value));
    }}

    function clampFilesTransferListHeightPx(value) {{
      const numeric = Number(value);
      const fallback = 96;
      const shell = document.querySelector(".files-shell");
      if (!(shell instanceof HTMLElement)) {{
        return Number.isFinite(numeric) ? Math.max(48, Math.min(220, Math.round(numeric))) : fallback;
      }}
      const shellHeight = shell.getBoundingClientRect().height;
      if (!Number.isFinite(shellHeight) || shellHeight < 220) {{
        return Number.isFinite(numeric) ? Math.max(48, Math.min(220, Math.round(numeric))) : fallback;
      }}
      const controls = shell.querySelector(".files-controls");
      const controlsHeight = controls instanceof HTMLElement ? controls.getBoundingClientRect().height : 0;
      const consoleMin = 120;
      const chrome = controlsHeight + 24;
      const max = Math.max(48, Math.min(360, shellHeight - chrome - consoleMin));
      return Number.isFinite(numeric) ? Math.max(48, Math.min(max, Math.round(numeric))) : Math.min(fallback, max);
    }}

    function applySplitState() {{
      const layout = document.querySelector(".layout");
      if (!(layout instanceof HTMLElement)) return;
      layout.style.setProperty("--split-left-pct", `${{splitPct}}%`);
      layout.style.setProperty("--split-top-px", `${{splitTopPx}}px`);
      layout.style.setProperty("--split-mid-px", `${{splitMidPx}}px`);
      layout.style.setProperty("--split-low-px", `${{splitLowPx}}px`);
    }}

