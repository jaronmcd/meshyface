    function loadMapNodeLayerVisibilityPreference() {{
      mapActualNodesEnabled = true;
      mapLinkInferredNodesEnabled = true;
      mapRssiTrilateratedNodesEnabled = true;
      try {{
        const raw = window.localStorage.getItem(mapNodeLayerVisibilityStorageKey);
        if (!raw) return;
        const parsed = JSON.parse(raw);
        if (!parsed || typeof parsed !== "object" || Array.isArray(parsed)) return;
        if (Object.prototype.hasOwnProperty.call(parsed, "actual")) {{
          mapActualNodesEnabled = parsed.actual !== false;
        }}
        if (Object.prototype.hasOwnProperty.call(parsed, "inferred")) {{
          mapLinkInferredNodesEnabled = parsed.inferred !== false;
        }}
        if (Object.prototype.hasOwnProperty.call(parsed, "trilaterated")) {{
          mapRssiTrilateratedNodesEnabled = parsed.trilaterated !== false;
        }}
      }} catch (_err) {{
      }}
    }}

