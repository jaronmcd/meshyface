    function normalizeMapLinkLayerMode(value) {{
      const clean = String(value || "").trim().toLowerCase();
      if (clean === "none" || clean === "history" || clean === "live" || clean === "both") return clean;
      return "none";
    }}

    function mapLinkLayerModeForCurrentView(value = mapLinkLayerMode) {{
      const clean = normalizeMapLinkLayerMode(value);
      return clean;
    }}

