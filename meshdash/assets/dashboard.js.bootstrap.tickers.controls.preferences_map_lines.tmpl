    function bindMapPacketLinesControl() {{
      const toggle = document.getElementById("map-lines-toggle");
      if (toggle instanceof HTMLInputElement && toggle.dataset.bound !== "1") {{
        toggle.dataset.bound = "1";
        toggle.checked = mapPacketLinesEnabled;
        toggle.addEventListener("change", () => {{
          mapPacketLinesEnabled = !!toggle.checked;
          persistMapPacketLinesPreference();
          updateMapPacketLinesControl();
          lastMapSignature = "";
          lastMapGraphSignature = "";
          lastMapRenderMode = "";
          if (latestState && activeLayoutView === "network") {{
            renderMap(
              latestState.nodes || [],
              (latestState.traffic || {{}}).edges || [],
              null
            );
          }}
        }});
      }}
      updateMapPacketLinesControl();
    }}

    function bindMapLinkLayerControl() {{
      const modeSelect = document.getElementById("map-link-mode");
      if (modeSelect instanceof HTMLSelectElement && modeSelect.dataset.bound !== "1") {{
        modeSelect.dataset.bound = "1";
        modeSelect.value = mapLinkLayerModeForCurrentView(mapLinkLayerMode);
        modeSelect.addEventListener("change", () => {{
          mapLinkLayerMode = normalizeMapLinkLayerMode(modeSelect.value);
          if (mapLinkLayerMode !== "none") {{
            mapLinkLayerMode = "both";
          }}
          persistMapLinkLayerModePreference();
          updateMapLinkLayerControl();
          lastMapSignature = "";
          lastMapGraphSignature = "";
          lastMapRenderMode = "";
          if (latestState && activeLayoutView === "network") {{
            renderMap(
              latestState.nodes || [],
              (latestState.traffic || {{}}).edges || [],
              null
            );
          }}
        }});
      }}
      updateMapLinkLayerControl();
    }}

