    function normalizeSummaryWindowHours(raw, fallback = defaultSummaryWindowHours) {{
      const parsed = Number(raw);
      if (!Number.isFinite(parsed)) {{
        return Math.max(1, Math.trunc(Number(fallback) || defaultSummaryWindowHours));
      }}
      return Math.max(1, Math.min(24 * 365, Math.trunc(parsed)));
    }}

