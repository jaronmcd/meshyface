    function applyConsoleFontSizePreference() {{
      const pre = document.getElementById("live-console");
      const key = normalizeConsoleFontSize(consoleFontSize);
      const px = Number(consoleFontSizePxByKey[key]) || 12;
      if (pre instanceof HTMLElement) {{
        pre.style.fontSize = `${{px}}px`;
      }}
      const input = consoleCommandInputElement();
      if (input instanceof HTMLInputElement) {{
        input.style.fontSize = `${{Math.max(8, px)}}px`;
      }}
      consoleFontSize = key;
    }}
