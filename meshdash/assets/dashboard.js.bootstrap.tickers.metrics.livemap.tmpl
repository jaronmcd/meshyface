    let dashboardLivemapInteractionBound = false;
    let dashboardLivemapLastInteractionMs = 0;
    let dashboardLivemapIntroPending = false;
    let dashboardLivemapPendingNodeTarget = null;
    let dashboardLivemapNodePanActive = false;
    let dashboardLivemapMapFadeStartedAt = 0;
    let dashboardLivemapMapLayerFadeStartedAt = new Map();
    let dashboardLivemapFirstMapLayerFadeStartedAt = null;
