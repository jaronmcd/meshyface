    const dashboardLivemapGeometryRefreshMs = 5000;
    const dashboardLivemapMinViewSpan = 0.004;
    const dashboardLivemapViewEasing = 0.055;
    const dashboardLivemapNodeDriftEasing = 0.00035;
    const dashboardLivemapNodeDriftWanderRatio = 0.004;
    const dashboardLivemapNodeDriftPeriodMs = 420000;
    const dashboardLivemapNodeRefitDeltaRatio = 0.02;
    const dashboardLivemapViewSnapEpsilon = 0.000004;
    const dashboardLivemapMapFadeMs = 1600;
    const dashboardLivemapMeshFadeMs = 2800;
    const dashboardLivemapLinkFadeInEasing = 0.025;
    const dashboardLivemapLinkFadeOutEasing = 0.012;
    const dashboardLivemapLinkPruneOpacity = 0.004;
    const dashboardLivemapNodePanAfterMapDelayMs = 450;
    const dashboardLivemapNodePanFallbackMapWaitMs = 2400;
    const dashboardLivemapActiveDrawMs = 33;
    const dashboardLivemapIdleDrawMs = 1000;
    const dashboardLivemapInteractionWindowMs = 5000;
    const dashboardLivemapInteractionThrottleDelayMs = 250;
    const dashboardLivemapInputThrottleDelayMs = 250;
    const dashboardLivemapInputThrottleDrawMs = 1000;
    const dashboardLivemapHiddenThrottleDelayMs = 1000;
    const dashboardLivemapCachedViewStorageKey = "meshyface.dashboard.livemap.lastGpsView.v1";
    const dashboardLivemapCachedViewMaxAgeMs = 24 * 60 * 60 * 1000;
    const dashboardLivemapEstimatedRangeFallbackPreset = "LONG_FAST";
    const dashboardLivemapEstimatedRangeByPreset = Object.freeze({{
      SHORT_TURBO: {{ rangeKm: 6, strongKm: 2 }},
      SHORT_FAST: {{ rangeKm: 10, strongKm: 3 }},
      SHORT_SLOW: {{ rangeKm: 16, strongKm: 5 }},
      MEDIUM_FAST: {{ rangeKm: 32, strongKm: 9 }},
      MEDIUM_SLOW: {{ rangeKm: 42, strongKm: 12 }},
      LONG_TURBO: {{ rangeKm: 26, strongKm: 8 }},
      LONG_FAST: {{ rangeKm: 52, strongKm: 15 }},
      LONG_MODERATE: {{ rangeKm: 68, strongKm: 20 }},
      LONG_SLOW: {{ rangeKm: 82, strongKm: 25 }},
      VERY_LONG_SLOW: {{ rangeKm: 110, strongKm: 34 }},
    }});
    const dashboardLivemapEstimatedRangeMaxLinks = 360;
    const dashboardLivemapEstimatedRangeMaxLinksPerNode = 5;
    const dashboardLivemapMaxMercatorLat = 85.05112878;

    // Offline map expansion packs: the background reuses the map screen's
    // manifest cache and chunk endpoints, but renders chunks as monochrome
    // Path2D strokes in the livemap's unit-mercator space.
    const dashboardLivemapPackChunkBudget = 240;
    const dashboardLivemapPackDrawOrder = [
      "urban",
