      states: {{ alpha: 0.2, width: 0.8 }},
      lakes: {{ alpha: 0.28, width: 0.8 }},
      rivers: {{ alpha: 0.22, width: 0.8 }},
      urban: {{ alpha: 0.12, width: 0.6 }},
      roads: {{ alpha: 0.16, width: 0.7 }},
