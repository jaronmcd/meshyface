          <label for="settings-node-tag-preset-select" class="favorite-menu-tag-editor-label">Preset</label>
          <select id="settings-node-tag-preset-select" class="favorite-menu-tag-preset-select">
            ${{optionsHtml}}
          </select>
        </div>
        <div class="favorite-menu-tag-editor-row">
          <label for="settings-node-tag-name-input" class="favorite-menu-tag-editor-label">Name</label>
          <input id="settings-node-tag-name-input" class="favorite-menu-tag-editor-input" type="text" maxlength="40" value="${{escAttr(formName)}}" placeholder="Tag name" />
        </div>
        <div class="favorite-menu-tag-editor-row">
          <label for="settings-node-tag-emoji-input" class="favorite-menu-tag-editor-label">Emoji</label>
          <input id="settings-node-tag-emoji-input" class="favorite-menu-tag-editor-input favorite-menu-tag-emoji-input" type="text" maxlength="8" value="${{escAttr(formEmoji)}}" placeholder="Optional emoji" />
        </div>
        <div class="favorite-menu-tag-editor-row favorite-menu-tag-editor-row-inline">
          <label for="settings-node-tag-color-input" class="favorite-menu-tag-editor-label">Color</label>
          <input id="settings-node-tag-color-input" class="favorite-menu-tag-color-input" type="color" value="${{escAttr(formColor)}}" />
          <label for="settings-node-tag-vibrance-input" class="favorite-menu-tag-editor-label">Vibrance</label>
          <input id="settings-node-tag-vibrance-input" class="favorite-menu-tag-vibrance-input" type="range" min="0" max="100" step="1" value="${{escAttr(formVibrance)}}" />
          <span id="settings-node-tag-vibrance-value" class="favorite-menu-tag-vibrance-value">${{escAttr(formVibrance)}}%</span>
          <span id="settings-node-tag-preview" class="favorite-menu-tag-chip favorite-menu-tag-chip-preview${{previewEmoji ? " has-emoji" : ""}}" style="${{escAttr(previewStyle)}}" aria-hidden="true">${{previewEmoji}}</span>
        </div>
        <div class="favorite-menu-tag-editor-actions">
          <button id="settings-node-tag-save-btn" class="btn btn-secondary" type="button">Save Preset</button>
          <button id="settings-node-tag-new-btn" class="btn btn-secondary" type="button">New Preset</button>
          <button id="settings-node-tag-delete-btn" class="btn btn-secondary" type="button"${{selectedPresetId === "tag-default" ? " disabled" : ""}}>Delete Preset</button>
        </div>
        <div id="settings-node-tag-status" class="favorite-menu-tag-status"></div>
      </div>`;
