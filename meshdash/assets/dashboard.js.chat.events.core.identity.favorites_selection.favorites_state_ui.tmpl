    function clampNodeTagVibrance(value, fallback = 70) {{
      const raw = Number(value);
      const safeFallback = Number.isFinite(Number(fallback)) ? Number(fallback) : 70;
      const normalized = Number.isFinite(raw) ? raw : safeFallback;
      return Math.max(0, Math.min(100, Math.round(normalized)));
    }}

    function normalizeNodeTagColor(value, fallback = "#2aa85a") {{
      const fallbackColor = /^#[0-9a-f]{6}$/i.test(String(fallback || "").trim())
        ? String(fallback || "").trim().toLowerCase()
        : "#2aa85a";
      let text = String(value == null ? "" : value).trim().toLowerCase();
      if (!text) return fallbackColor;
      if (text[0] !== "#") text = `#${{text}}`;
      if (/^#[0-9a-f]{3}$/i.test(text)) {{
        return `#${{text[1]}}${{text[1]}}${{text[2]}}${{text[2]}}${{text[3]}}${{text[3]}}`;
      }}
      if (/^#[0-9a-f]{6}$/i.test(text)) {{
        return text;
      }}
      return fallbackColor;
    }}

    function nodeTagColorHue(value, fallbackHue = 145) {{
      const fallback = Math.max(0, Math.min(359, Math.trunc(Number(fallbackHue) || 145)));
      const color = normalizeNodeTagColor(value, "#2aa85a");
      const r = parseInt(color.slice(1, 3), 16) / 255;
      const g = parseInt(color.slice(3, 5), 16) / 255;
      const b = parseInt(color.slice(5, 7), 16) / 255;
      const max = Math.max(r, g, b);
      const min = Math.min(r, g, b);
      const delta = max - min;
      if (!Number.isFinite(delta) || delta <= 0) {{
        return fallback;
      }}
      let hueSeg = 0;
      if (max === r) {{
        hueSeg = ((g - b) / delta) % 6;
      }} else if (max === g) {{
        hueSeg = ((b - r) / delta) + 2;
      }} else {{
        hueSeg = ((r - g) / delta) + 4;
      }}
      let hue = Math.round(hueSeg * 60);
      if (!Number.isFinite(hue)) {{
        return fallback;
      }}
      while (hue < 0) hue += 360;
      while (hue >= 360) hue -= 360;
      return Math.max(0, Math.min(359, hue));
    }}

    function nodeTagTintHue(tagEntry, fallbackHue = 145) {{
      const preset = tagEntry && typeof tagEntry === "object" && tagEntry.preset
        ? tagEntry.preset
        : null;
      return nodeTagColorHue(preset && preset.color, fallbackHue);
    }}

    function normalizeNodeTagPresetName(value, fallback = "Tagged") {{
      const text = String(value == null ? "" : value).replace(/\s+/g, " ").trim();
      if (!text) return String(fallback || "Tagged");
      return text.slice(0, 40);
    }}

    function normalizeNodeTagPresetId(value, fallback = "tag-default") {{
      const text = String(value == null ? "" : value)
        .trim()
        .toLowerCase()
        .replace(/[^a-z0-9_-]+/g, "-")
        .replace(/^-+|-+$/g, "");
      if (text) return text.slice(0, 48);
      return String(fallback);
    }}

    function normalizeNodeTagEmoji(value, fallback = "") {{
      const fallbackEmoji = String(fallback == null ? "" : fallback).trim();
      const raw = String(value == null ? "" : value).trim();
      if (!raw) return fallbackEmoji;
      const graphemes = (typeof chatSplitGraphemes === "function")
        ? chatSplitGraphemes(raw).filter((entry) => String(entry == null ? "" : entry).trim())
        : Array.from(raw).filter((entry) => String(entry == null ? "" : entry).trim());
      for (const grapheme of graphemes) {{
        const clean = String(grapheme == null ? "" : grapheme).trim();
        if (!clean) continue;
        const isEmoji = (typeof chatIsEmojiOnlyText === "function")
          ? chatIsEmojiOnlyText(clean)
          : (typeof chatInlineEmojiTokenRe !== "undefined" && chatInlineEmojiTokenRe instanceof RegExp && chatInlineEmojiTokenRe.test(clean));
        if (isEmoji) return clean;
      }}
      return fallbackEmoji;
    }}

    function defaultNodeTagPreset() {{
      return {{
        id: "tag-default",
        name: "Tagged",
        emoji: "",
        color: "#2aa85a",
        vibrance: 70,
      }};
    }}

    function normalizeNodeTagPreset(rawPreset, fallbackId = "tag-default") {{
      const base = (rawPreset && typeof rawPreset === "object") ? rawPreset : {{}};
      const fallback = defaultNodeTagPreset();
      const id = normalizeNodeTagPresetId(
        base.id ?? base.preset_id ?? base.presetId ?? fallbackId,
        fallbackId || fallback.id
      );
      const name = normalizeNodeTagPresetName(base.name, fallback.name);
      const emoji = normalizeNodeTagEmoji(base.emoji ?? base.icon ?? base.badge, fallback.emoji);
      const color = normalizeNodeTagColor(base.color ?? base.hex, fallback.color);
      const vibrance = clampNodeTagVibrance(base.vibrance ?? base.saturation ?? base.intensity, fallback.vibrance);
      return {{ id, name, emoji, color, vibrance }};
    }}

    function syncFavoriteNodeIdsFromTags() {{
      favoriteNodeIds.clear();
      for (const [rawNodeId, rawPresetId] of nodeTagByNodeId.entries()) {{
        const nodeId = normalizeNodeId(rawNodeId);
        const presetId = normalizeNodeTagPresetId(rawPresetId, "");
        if (!isSelectableNodeId(nodeId)) continue;
        if (!presetId || !nodeTagPresetsById.has(presetId)) continue;
        favoriteNodeIds.add(nodeId);
      }}
    }}

    function nodeTagPresetEntries() {{
      const entries = Array.from(nodeTagPresetsById.values())
        .filter((entry) => entry && typeof entry === "object")
        .map((entry) => normalizeNodeTagPreset(entry, entry.id || "tag-default"));
      entries.sort((a, b) => {{
        if (a.id === "tag-default" && b.id !== "tag-default") return -1;
        if (b.id === "tag-default" && a.id !== "tag-default") return 1;
        const nameDiff = String(a.name || "").localeCompare(String(b.name || ""));
        if (nameDiff !== 0) return nameDiff;
        return String(a.id || "").localeCompare(String(b.id || ""));
      }});
      return entries;
    }}

    function nodeTagPresetForId(presetId) {{
      const cleanPresetId = normalizeNodeTagPresetId(presetId);
      if (!cleanPresetId) return null;
      const entry = nodeTagPresetsById.get(cleanPresetId);
      return entry && typeof entry === "object"
        ? normalizeNodeTagPreset(entry, cleanPresetId)
        : null;
    }}

    function nodeTagEntryForNode(nodeId) {{
      const cleanNodeId = normalizeNodeId(nodeId);
      if (!isSelectableNodeId(cleanNodeId)) return null;
      const presetId = normalizeNodeTagPresetId(nodeTagByNodeId.get(cleanNodeId), "");
      if (!presetId) return null;
      const preset = nodeTagPresetForId(presetId);
      if (!preset) return null;
      return {{
        nodeId: cleanNodeId,
        presetId: preset.id,
        preset,
      }};
    }}

    function nodeEmojiOverrideForNode(nodeId) {{
      const cleanNodeId = normalizeNodeId(nodeId);
      if (!isSelectableNodeId(cleanNodeId)) return "";
      return normalizeNodeTagEmoji(nodeEmojiByNodeId.get(cleanNodeId), "");
    }}

    function nodeTagEmojiForEntry(tagEntry) {{
      return normalizeNodeTagEmoji(tagEntry && tagEntry.preset && tagEntry.preset.emoji, "");
    }}

    function nodeTagEmojiForNode(nodeId) {{
      return nodeTagEmojiForEntry(nodeTagEntryForNode(nodeId));
    }}

    function nodeIntrinsicEmojiForNode(nodeId, node = null) {{
      const cleanNodeId = normalizeNodeId(nodeId);
      const candidates = [
        preferredNodeName(node),
        node && node.long_name,
        node && node.short_name,
        nodeNameCache.get(cleanNodeId),
      ];
      for (const candidate of candidates) {{
        const emoji = normalizeNodeTagEmoji(candidate, "");
        if (emoji) return emoji;
      }}
      return "";
    }}

    function localBadgeEmojiForNode(nodeId) {{
      const cleanNodeId = normalizeNodeId(nodeId);
      if (!isSelectableNodeId(cleanNodeId)) return "";
      const localNodeId = normalizeNodeId(
        typeof resolveLocalNodeId === "function" ? resolveLocalNodeId(latestState) : ""
      );
      if (!localNodeId || cleanNodeId !== localNodeId) return "";
      if (
        typeof settingsBadgeEmojiChoiceSet === "undefined"
        || !(settingsBadgeEmojiChoiceSet instanceof Set)
      ) return "";
      const badgeEmoji = String(settingsBadgeEmoji || "").trim();
      return settingsBadgeEmojiChoiceSet.has(badgeEmoji) ? badgeEmoji : "";
    }}

    function nodeVisualEmojiForNode(nodeId, tagEntry = null, node = null) {{
      const localBadgeEmoji = localBadgeEmojiForNode(nodeId);
      if (localBadgeEmoji) return localBadgeEmoji;
      const overrideEmoji = nodeEmojiOverrideForNode(nodeId);
      if (overrideEmoji) return overrideEmoji;
      const tagEmoji = nodeTagEmojiForEntry(tagEntry || nodeTagEntryForNode(nodeId));
      if (tagEmoji) return tagEmoji;
      return nodeIntrinsicEmojiForNode(nodeId, node);
    }}

    function nodeTagDisplayLabel(tagEntry, fallback = "Tagged") {{
      const preset = tagEntry && typeof tagEntry === "object" && tagEntry.preset
        ? tagEntry.preset
        : null;
      const label = normalizeNodeTagPresetName(preset && preset.name, fallback);
      const emoji = nodeTagEmojiForEntry(tagEntry);
      return emoji ? `${emoji} ${label}` : label;
    }}

    function nodeTagChipEmojiHtml(tagEntry, nodeId = "") {{
      const emoji = nodeVisualEmojiForNode(nodeId, tagEntry);
      if (!emoji) return "";
      return `<span class="favorite-menu-tag-chip-emoji" aria-hidden="true">${escAttr(emoji)}</span>`;
    }}

    function nodeTagStyleVars(tagEntry) {{
      const preset = tagEntry && typeof tagEntry === "object" && tagEntry.preset
        ? tagEntry.preset
        : null;
      if (!preset) return "";
      const color = normalizeNodeTagColor(preset.color);
      const vibrance = clampNodeTagVibrance(preset.vibrance, 70);
      const vibranceRatio = Math.max(0, Math.min(1, vibrance / 100));
      return `--node-tag-color:${{color}};--node-tag-vibrance:${{vibranceRatio.toFixed(3)}};`;
    }}

    function nodeTagStyleAttrForNode(nodeId) {{
      const entry = nodeTagEntryForNode(nodeId);
      if (!entry) return "";
      return nodeTagStyleVars(entry);
    }}

    function persistNodeTagPresets() {{
      try {{
        const payload = {{}};
        let count = 0;
        for (const preset of nodeTagPresetEntries()) {{
          if (!preset || typeof preset !== "object") continue;
          const presetId = normalizeNodeTagPresetId(preset.id);
          if (!presetId) continue;
          payload[presetId] = {{
            name: normalizeNodeTagPresetName(preset.name),
            emoji: normalizeNodeTagEmoji(preset.emoji, ""),
            color: normalizeNodeTagColor(preset.color),
            vibrance: clampNodeTagVibrance(preset.vibrance, 70),
          }};
          count += 1;
          if (count >= 200) break;
        }}
        window.localStorage.setItem(nodeTagPresetsStorageKey, JSON.stringify(payload));
      }} catch (_err) {{
      }}
    }}

    function persistNodeTags() {{
      try {{
        const payload = {{}};
        let count = 0;
        for (const [rawNodeId, rawPresetId] of nodeTagByNodeId.entries()) {{
          if (count >= 4000) break;
          const nodeId = normalizeNodeId(rawNodeId);
          const presetId = normalizeNodeTagPresetId(rawPresetId, "");
          if (!isSelectableNodeId(nodeId)) continue;
          if (!presetId || !nodeTagPresetsById.has(presetId)) continue;
          payload[nodeId] = presetId;
          count += 1;
        }}
        window.localStorage.setItem(nodeTagsStorageKey, JSON.stringify(payload));
      }} catch (_err) {{
      }}
    }}

    function persistNodeTagEmojis() {{
      try {{
        const payload = {{}};
        let count = 0;
        for (const [rawNodeId, rawEmoji] of nodeEmojiByNodeId.entries()) {{
          if (count >= 4000) break;
          const nodeId = normalizeNodeId(rawNodeId);
          const emoji = normalizeNodeTagEmoji(rawEmoji, "");
          if (!isSelectableNodeId(nodeId) || !emoji) continue;
          payload[nodeId] = emoji;
          count += 1;
        }}
        window.localStorage.setItem(nodeTagEmojiStorageKey, JSON.stringify(payload));
      }} catch (_err) {{
      }}
    }}

    function persistActiveNodeTagPreset() {{
      try {{
        const presetId = normalizeNodeTagPresetId(activeNodeTagPresetId);
        if (presetId && nodeTagPresetsById.has(presetId)) {{
          window.localStorage.setItem(nodeTagQuickPresetStorageKey, presetId);
        }} else {{
          window.localStorage.removeItem(nodeTagQuickPresetStorageKey);
        }}
      }} catch (_err) {{
      }}
    }}

    function setActiveNodeTagPreset(presetId, persist = true) {{
      let cleanPresetId = normalizeNodeTagPresetId(presetId);
      if (!cleanPresetId || !nodeTagPresetsById.has(cleanPresetId)) {{
        const fallback = nodeTagPresetEntries()[0] || defaultNodeTagPreset();
        cleanPresetId = normalizeNodeTagPresetId(fallback.id, "tag-default");
      }}
      activeNodeTagPresetId = cleanPresetId;
      if (persist) {{
        persistActiveNodeTagPreset();
      }}
      return cleanPresetId;
    }}

    function upsertNodeTagPreset(name, color, vibrance, options = null) {{
      const opts = options && typeof options === "object" ? options : {{}};
      const preferredId = normalizeNodeTagPresetId(opts.preferredId || "", "");
      const cleanName = normalizeNodeTagPresetName(name, "Tagged");
      const cleanEmoji = normalizeNodeTagEmoji(opts.emoji, "");
      const cleanColor = normalizeNodeTagColor(color, "#2aa85a");
      const cleanVibrance = clampNodeTagVibrance(vibrance, 70);
      let presetId = preferredId;
      if (!presetId || (!nodeTagPresetsById.has(presetId) && presetId === "tag-default")) {{
        if (cleanName.toLowerCase() === "tagged") {{
          presetId = "tag-default";
        }} else {{
          const base = normalizeNodeTagPresetId(cleanName, "tag");
          presetId = base;
          let suffix = 2;
          while (nodeTagPresetsById.has(presetId)) {{
            presetId = `${{base}}-${{suffix}}`;
            suffix += 1;
            if (suffix > 99) break;
          }}
        }}
      }}
      const preset = {{
        id: presetId,
        name: cleanName,
        emoji: cleanEmoji,
        color: cleanColor,
        vibrance: cleanVibrance,
      }};
      nodeTagPresetsById.set(presetId, preset);
      persistNodeTagPresets();
      setActiveNodeTagPreset(presetId, true);
      return preset;
    }}

    function assignNodeTagPresetToNode(nodeId, presetId, options = null) {{
      const cleanNodeId = normalizeNodeId(nodeId);
      if (!isSelectableNodeId(cleanNodeId)) return false;
      const cleanPresetId = normalizeNodeTagPresetId(presetId, "");
      if (!cleanPresetId || !nodeTagPresetsById.has(cleanPresetId)) return false;
      nodeTagByNodeId.set(cleanNodeId, cleanPresetId);
      syncFavoriteNodeIdsFromTags();
      if (!(options && options.persist === false)) {{
        persistFavoriteNodes();
      }}
      setActiveNodeTagPreset(cleanPresetId, true);
      return true;
    }}

    function clearNodeTagForNode(nodeId, options = null) {{
      const cleanNodeId = normalizeNodeId(nodeId);
      if (!isSelectableNodeId(cleanNodeId)) return false;
      const existed = nodeTagByNodeId.delete(cleanNodeId);
      if (!existed) return false;
      syncFavoriteNodeIdsFromTags();
      if (!(options && options.persist === false)) {{
        persistFavoriteNodes();
      }}
      return true;
    }}

    function clearNodeTagAndEmojiForNode(nodeId, options = null) {{
      const cleanNodeId = normalizeNodeId(nodeId);
      if (!isSelectableNodeId(cleanNodeId)) {{
        return {{
          tagCleared: false,
          emojiCleared: false,
          changed: false,
        }};
      }}
      const tagCleared = nodeTagByNodeId.delete(cleanNodeId);
      const emojiCleared = nodeEmojiByNodeId.delete(cleanNodeId);
      const changed = !!(tagCleared || emojiCleared);
      if (!changed) {{
        return {{
          tagCleared: false,
          emojiCleared: false,
          changed: false,
        }};
      }}
      syncFavoriteNodeIdsFromTags();
      if (!(options && options.persist === false)) {{
        persistFavoriteNodes();
      }}
      return {{
        tagCleared: !!tagCleared,
        emojiCleared: !!emojiCleared,
        changed: true,
      }};
    }}

    function saveNodeEmojiOverride(nodeId, rawEmoji, options = null) {{
      const cleanNodeId = normalizeNodeId(nodeId);
      if (!isSelectableNodeId(cleanNodeId)) return "";
      const emoji = normalizeNodeTagEmoji(rawEmoji, "");
      if (emoji) {{
        nodeEmojiByNodeId.set(cleanNodeId, emoji);
      }} else {{
        nodeEmojiByNodeId.delete(cleanNodeId);
      }}
      if (!(options && options.persist === false)) {{
        persistFavoriteNodes();
      }}
      return emoji;
    }}

    function loadFavoriteNodes() {{
      favoriteNodeIds.clear();
      nodeTagByNodeId.clear();
      nodeTagPresetsById.clear();
      nodeEmojiByNodeId.clear();
      let migratedLegacyFavorites = false;
      let hydratedPresets = false;

      try {{
        const rawPresets = window.localStorage.getItem(nodeTagPresetsStorageKey);
        if (rawPresets) {{
          const parsed = JSON.parse(rawPresets);
          const entries = Array.isArray(parsed)
            ? parsed
            : (parsed && typeof parsed === "object" ? Object.entries(parsed).map(([id, value]) => ({{ id, ...(value && typeof value === "object" ? value : {{}}) }})) : []);
          for (const rawPreset of entries) {{
            const normalized = normalizeNodeTagPreset(rawPreset, rawPreset && rawPreset.id);
            if (!normalized.id) continue;
            nodeTagPresetsById.set(normalized.id, normalized);
            hydratedPresets = true;
          }}
        }}
      }} catch (_err) {{
      }}

      const fallbackPreset = defaultNodeTagPreset();
      if (!nodeTagPresetsById.has(fallbackPreset.id)) {{
        nodeTagPresetsById.set(fallbackPreset.id, fallbackPreset);
      }}

      try {{
        const rawTags = window.localStorage.getItem(nodeTagsStorageKey);
        if (rawTags) {{
          const parsed = JSON.parse(rawTags);
          const entries = Array.isArray(parsed)
            ? parsed
            : (parsed && typeof parsed === "object" ? Object.entries(parsed) : []);
          for (const entry of entries) {{
            if (!Array.isArray(entry) || entry.length < 2) continue;
            const nodeId = normalizeNodeId(entry[0]);
            const presetId = normalizeNodeTagPresetId(entry[1], "");
            if (!isSelectableNodeId(nodeId)) continue;
            if (!presetId || !nodeTagPresetsById.has(presetId)) continue;
            nodeTagByNodeId.set(nodeId, presetId);
          }}
        }}
      }} catch (_err) {{
      }}

      try {{
        const rawTagEmojis = window.localStorage.getItem(nodeTagEmojiStorageKey);
        if (rawTagEmojis) {{
          const parsed = JSON.parse(rawTagEmojis);
          const entries = Array.isArray(parsed)
            ? parsed
            : (parsed && typeof parsed === "object" ? Object.entries(parsed) : []);
          for (const entry of entries) {{
            if (!Array.isArray(entry) || entry.length < 2) continue;
            const nodeId = normalizeNodeId(entry[0]);
            const emoji = normalizeNodeTagEmoji(entry[1], "");
            if (!isSelectableNodeId(nodeId) || !emoji) continue;
            nodeEmojiByNodeId.set(nodeId, emoji);
          }}
        }}
      }} catch (_err) {{
      }}

      try {{
        const rawLegacyFavorites = window.localStorage.getItem(favoritesStorageKey);
        if (rawLegacyFavorites) {{
          const parsed = JSON.parse(rawLegacyFavorites);
          if (Array.isArray(parsed)) {{
            for (const entry of parsed) {{
              const nodeId = normalizeNodeId(entry);
              if (!isSelectableNodeId(nodeId)) continue;
              if (nodeTagByNodeId.has(nodeId)) continue;
              nodeTagByNodeId.set(nodeId, fallbackPreset.id);
              migratedLegacyFavorites = true;
            }}
          }}
        }}
      }} catch (_err) {{
      }}

      syncFavoriteNodeIdsFromTags();

      try {{
        const rawQuickPreset = window.localStorage.getItem(nodeTagQuickPresetStorageKey);
        setActiveNodeTagPreset(rawQuickPreset, false);
      }} catch (_err) {{
        setActiveNodeTagPreset("", false);
      }}

      if (migratedLegacyFavorites || !hydratedPresets) {{
        persistFavoriteNodes();
      }}
    }}

    function persistFavoriteNodes() {{
      syncFavoriteNodeIdsFromTags();
      try {{
        const ids = Array.from(favoriteNodeIds).slice(0, 2000);
        window.localStorage.setItem(favoritesStorageKey, JSON.stringify(ids));
      }} catch (_err) {{
      }}
      persistNodeTagPresets();
      persistNodeTags();
      persistNodeTagEmojis();
      persistActiveNodeTagPreset();
    }}

    function loadMutedNodes() {{
      mutedNodeIds.clear();
      try {{
        const raw = window.localStorage.getItem(mutedNodesStorageKey);
        if (!raw) return;
        const parsed = JSON.parse(raw);
        if (!Array.isArray(parsed)) return;
        for (const entry of parsed) {{
          const nodeId = normalizeNodeId(entry);
          if (isSelectableNodeId(nodeId) && !isSelfNodeId(nodeId)) {{
            mutedNodeIds.add(nodeId);
          }}
        }}
      }} catch (_err) {{
      }}
    }}

    function persistMutedNodes() {{
      try {{
        const ids = Array.from(mutedNodeIds).slice(0, 2000);
        window.localStorage.setItem(mutedNodesStorageKey, JSON.stringify(ids));
      }} catch (_err) {{
      }}
    }}

    function loadPinnedNodes() {{
      pinnedNodeIds.clear();
      try {{
        const raw = window.localStorage.getItem(pinnedNodesStorageKey);
        if (!raw) return;
        const parsed = JSON.parse(raw);
        if (!Array.isArray(parsed)) return;
        for (const entry of parsed) {{
          const nodeId = normalizeNodeId(entry);
          if (isSelectableNodeId(nodeId)) {{
            pinnedNodeIds.add(nodeId);
          }}
        }}
      }} catch (_err) {{
      }}
    }}

    function persistPinnedNodes() {{
      try {{
        const ids = Array.from(pinnedNodeIds).slice(0, 2000);
        window.localStorage.setItem(pinnedNodesStorageKey, JSON.stringify(ids));
      }} catch (_err) {{
      }}
    }}

    function normalizeNodeVisibilityListIds(rawValue) {{
      const entries = Array.isArray(rawValue)
        ? rawValue
        : (rawValue == null ? [] : [rawValue]);
      const seen = new Set();
      const out = [];
      for (const entry of entries) {{
        const nodeId = normalizeNodeId(entry);
        if (!isSelectableNodeId(nodeId) || seen.has(nodeId)) continue;
        seen.add(nodeId);
        out.push(nodeId);
      }}
      out.sort((a, b) => a.localeCompare(b));
      return out;
    }}

    function loadNodeVisibilityLists() {{
      nodeVisibilityWhitelistIds.clear();
      nodeVisibilityBlacklistIds.clear();
      try {{
        const raw = window.localStorage.getItem(nodeVisibilityWhitelistStorageKey);
        if (raw) {{
          const parsed = JSON.parse(raw);
          for (const nodeId of normalizeNodeVisibilityListIds(parsed)) {{
            nodeVisibilityWhitelistIds.add(nodeId);
          }}
        }}
      }} catch (_err) {{
      }}
      try {{
        const raw = window.localStorage.getItem(nodeVisibilityBlacklistStorageKey);
        if (raw) {{
          const parsed = JSON.parse(raw);
          for (const nodeId of normalizeNodeVisibilityListIds(parsed)) {{
            nodeVisibilityBlacklistIds.add(nodeId);
          }}
        }}
      }} catch (_err) {{
      }}
    }}

    function persistNodeVisibilityLists() {{
      try {{
        window.localStorage.setItem(
          nodeVisibilityWhitelistStorageKey,
          JSON.stringify(normalizeNodeVisibilityListIds(Array.from(nodeVisibilityWhitelistIds)).slice(0, 2000))
        );
      }} catch (_err) {{
      }}
      try {{
        window.localStorage.setItem(
          nodeVisibilityBlacklistStorageKey,
          JSON.stringify(normalizeNodeVisibilityListIds(Array.from(nodeVisibilityBlacklistIds)).slice(0, 2000))
        );
      }} catch (_err) {{
      }}
    }}

    function nodeVisibilityListsActive() {{
      return nodeVisibilityWhitelistIds.size > 0 || nodeVisibilityBlacklistIds.size > 0;
    }}

    function isNodeVisibleByLists(nodeId) {{
      const clean = normalizeNodeId(nodeId || "");
      if (!clean || clean === "^all" || clean === "^local") return true;
      if (!isSelectableNodeId(clean) && !isCanonicalNodeId(clean)) return true;
      if (nodeVisibilityBlacklistIds.has(clean)) return false;
      if (nodeVisibilityWhitelistIds.size > 0) {{
        return nodeVisibilityWhitelistIds.has(clean);
      }}
      return true;
    }}

    function visibleFavoriteNodeIds() {{
      return Array.from(favoriteNodeIds).filter((nodeId) => isNodeVisibleByLists(nodeId));
    }}

    function countVisibleOnlineNodes(nodes, nowUnix = Math.floor(Date.now() / 1000)) {{
      const entries = Array.isArray(nodes) ? nodes : [];
      let count = 0;
      for (const node of entries) {{
        const nodeId = normalizeNodeId(node && node.id);
        if (!isSelectableNodeId(nodeId) || !isNodeVisibleByLists(nodeId)) continue;
        const lastHeardUnix = nodeLastHeardUnix(node);
        if (!Number.isFinite(lastHeardUnix) || lastHeardUnix <= 0) continue;
        if ((nowUnix - lastHeardUnix) <= (2 * 60 * 60)) {{
          count += 1;
        }}
      }}
      return count;
    }}

    function nodeVisibilityMessagePasses(msg) {{
      if (!nodeVisibilityListsActive()) return true;
      const fromId = normalizeNodeId(
        (msg && (msg.from || msg.from_id || msg.fromId || msg.source || msg.source_id || msg.sourceId)) || ""
      );
      const toId = normalizeNodeId(
        (msg && (msg.to || msg.to_id || msg.toId || msg.destination || msg.dest || msg.dest_id || msg.destId)) || ""
      );
      if ((isSelectableNodeId(fromId) || isCanonicalNodeId(fromId)) && !isNodeVisibleByLists(fromId)) {{
        return false;
      }}
      if ((isSelectableNodeId(toId) || isCanonicalNodeId(toId)) && !isNodeVisibleByLists(toId)) {{
        return false;
      }}
      return true;
    }}

    function nodeVisibilityPacketPasses(packetEntry) {{
      if (!nodeVisibilityListsActive()) return true;
      const summary = (packetEntry && typeof packetEntry.summary === "object") ? packetEntry.summary : packetEntry;
      const packet = (packetEntry && typeof packetEntry.packet === "object") ? packetEntry.packet : packetEntry;
      const fromId = normalizeNodeId(
        (summary && (summary.from_id ?? summary.fromId ?? summary.from))
        ?? (packet && (packet.from_id ?? packet.fromId ?? packet.from))
        ?? ""
      );
      const toId = normalizeNodeId(
        (summary && (summary.to_id ?? summary.toId ?? summary.to))
        ?? (packet && (packet.to_id ?? packet.toId ?? packet.to ?? packet.destination))
        ?? ""
      );
      if ((isSelectableNodeId(fromId) || isCanonicalNodeId(fromId)) && !isNodeVisibleByLists(fromId)) {{
        return false;
      }}
      if ((isSelectableNodeId(toId) || isCanonicalNodeId(toId)) && !isNodeVisibleByLists(toId)) {{
        return false;
      }}
      return true;
    }}

    function applyNodeVisibilityFiltersToState(rawState) {{
      const safeState = rawState && typeof rawState === "object" ? rawState : {{}};
      if (!nodeVisibilityListsActive()) return safeState;

      const nodes = Array.isArray(safeState.nodes) ? safeState.nodes : [];
      const filteredNodes = nodes.filter((node) => isNodeVisibleByLists(node && node.id));
      const historyCapsRaw = (safeState.history_caps && typeof safeState.history_caps === "object")
        ? safeState.history_caps
        : {{}};
      const filteredHistoryCaps = Object.fromEntries(
        Object.entries(historyCapsRaw).filter(([nodeId]) => isNodeVisibleByLists(nodeId))
      );
      const trafficRaw = (safeState.traffic && typeof safeState.traffic === "object")
        ? safeState.traffic
        : {{}};
      const filteredEdges = Array.isArray(trafficRaw.edges)
        ? trafficRaw.edges.filter((edge) => (
          isNodeVisibleByLists(edge && edge.from) && isNodeVisibleByLists(edge && edge.to)
        ))
        : [];
      const filteredRecentChat = Array.isArray(trafficRaw.recent_chat)
        ? trafficRaw.recent_chat.filter((entry) => nodeVisibilityMessagePasses(entry))
        : [];
      const filteredRecentPackets = Array.isArray(trafficRaw.recent_packets)
        ? trafficRaw.recent_packets.filter((entry) => nodeVisibilityPacketPasses(entry))
        : [];
      const summaryRaw = (safeState.summary && typeof safeState.summary === "object")
        ? safeState.summary
        : {{}};
      const nodesWithPosition = filteredNodes.filter((node) => (
        Number.isFinite(Number(node && node.lat)) && Number.isFinite(Number(node && node.lon))
      )).length;
      const realEdgeCount = filteredEdges.filter((edge) => !!(edge && edge.is_real)).length;
      const filteredSummary = {{
        ...summaryRaw,
        node_count: filteredNodes.length,
        online_node_count: countVisibleOnlineNodes(filteredNodes),
        nodes_with_position: nodesWithPosition,
        edge_count: filteredEdges.length,
        real_edge_count: realEdgeCount,
      }};

      return {{
        ...safeState,
        summary: filteredSummary,
        nodes: filteredNodes,
        history_caps: filteredHistoryCaps,
        traffic: {{
          ...trafficRaw,
          edges: filteredEdges,
          recent_chat: filteredRecentChat,
          recent_packets: filteredRecentPackets,
        }},
      }};
    }}

    function syncSelectedNodeWithVisibilityFilters() {{
      const selectedId = normalizeNodeId(selectedNodeId || "");
      if (!isSelectableNodeId(selectedId)) return false;
      if (isNodeVisibleByLists(selectedId)) return false;
      if (typeof clearNodeSelection === "function") {{
        clearNodeSelection();
        return true;
      }}
      selectedNodeId = null;
      return true;
    }}

    function resolveNodeVisibilityEntryName(nodeId, nodesById = null) {{
      const clean = normalizeNodeId(nodeId || "");
      if (!isSelectableNodeId(clean)) return clean;
      const map = nodesById instanceof Map ? nodesById : new Map();
      const node = map.get(clean) || null;
      return preferredNodeName(node) || nodeNameCache.get(clean) || clean;
    }}

    function nodeVisibilityRuleLabel(nodeId) {{
      const clean = normalizeNodeId(nodeId || "");
      if (!isSelectableNodeId(clean)) return "Unlisted";
      if (nodeVisibilityBlacklistIds.has(clean)) return "Blocked";
      if (nodeVisibilityWhitelistIds.size > 0) {{
        return nodeVisibilityWhitelistIds.has(clean) ? "Allowed" : "Hidden";
      }}
      return "Visible";
    }}

    function applyNodeVisibilityListChange(statusText = "") {{
      persistNodeVisibilityLists();
      if (latestRawState && typeof latestRawState === "object") {{
        latestState = applyNodeVisibilityFiltersToState(latestRawState);
      }} else if (latestState && typeof latestState === "object") {{
        latestState = applyNodeVisibilityFiltersToState(latestState);
      }}
      syncSelectedNodeWithVisibilityFilters();
      renderNodeVisibilityListsUi(latestRawState || latestState || {{}});
      if (typeof renderSelectionStatus === "function") {{
        renderSelectionStatus();
      }}
      if (statusText && typeof setSettingsStatusText === "function") {{
        setSettingsStatusText(statusText);
      }}
      if (typeof requestImmediatePoll === "function") {{
        requestImmediatePoll(0);
      }}
    }}

    function addNodeVisibilityWhitelistId(nodeId) {{
      const clean = normalizeNodeId(nodeId || "");
      if (!isSelectableNodeId(clean)) return;
      nodeVisibilityBlacklistIds.delete(clean);
      nodeVisibilityWhitelistIds.add(clean);
      applyNodeVisibilityListChange(`Allowed ${{clean}} in frontend lists.`);
    }}

    function addNodeVisibilityBlacklistId(nodeId) {{
      const clean = normalizeNodeId(nodeId || "");
      if (!isSelectableNodeId(clean)) return;
      nodeVisibilityWhitelistIds.delete(clean);
      nodeVisibilityBlacklistIds.add(clean);
      applyNodeVisibilityListChange(`Blocked ${{clean}} from frontend lists.`);
    }}

    function removeNodeVisibilityWhitelistId(nodeId) {{
      const clean = normalizeNodeId(nodeId || "");
      if (!isSelectableNodeId(clean) || !nodeVisibilityWhitelistIds.delete(clean)) return;
      applyNodeVisibilityListChange(`Removed ${{clean}} from frontend whitelist.`);
    }}

    function removeNodeVisibilityBlacklistId(nodeId) {{
      const clean = normalizeNodeId(nodeId || "");
      if (!isSelectableNodeId(clean) || !nodeVisibilityBlacklistIds.delete(clean)) return;
      applyNodeVisibilityListChange(`Removed ${{clean}} from frontend blacklist.`);
    }}

    function clearNodeVisibilityWhitelist() {{
      if (nodeVisibilityWhitelistIds.size <= 0) return;
      nodeVisibilityWhitelistIds.clear();
      applyNodeVisibilityListChange("Cleared frontend whitelist.");
    }}

    function clearNodeVisibilityBlacklist() {{
      if (nodeVisibilityBlacklistIds.size <= 0) return;
      nodeVisibilityBlacklistIds.clear();
      applyNodeVisibilityListChange("Cleared frontend blacklist.");
    }}

    function deleteNodeTagPreset(presetId, options = null) {{
      const cleanPresetId = normalizeNodeTagPresetId(presetId, "");
      if (!cleanPresetId || cleanPresetId === "tag-default" || !nodeTagPresetsById.has(cleanPresetId)) return false;
      const fallbackPreset = nodeTagPresetForId("tag-default") || defaultNodeTagPreset();
      if (!nodeTagPresetsById.has(fallbackPreset.id)) {{
        nodeTagPresetsById.set(fallbackPreset.id, fallbackPreset);
      }}
      for (const [nodeId, assignedPresetId] of Array.from(nodeTagByNodeId.entries())) {{
        if (normalizeNodeTagPresetId(assignedPresetId, "") !== cleanPresetId) continue;
        nodeTagByNodeId.set(nodeId, fallbackPreset.id);
      }}
      nodeTagPresetsById.delete(cleanPresetId);
      syncFavoriteNodeIdsFromTags();
      if (activeNodeTagPresetId === cleanPresetId) {{
        setActiveNodeTagPreset(fallbackPreset.id, true);
      }}
      if (!(options && options.persist === false)) {{
        persistFavoriteNodes();
      }}
      return true;
    }}

