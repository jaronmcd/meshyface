      const cleanNodeId = normalizeNodeId(nodeId);
      if (!isSelectableNodeId(cleanNodeId)) return "";
      const emoji = normalizeNodeTagEmoji(rawEmoji, "");
      if (emoji) {{
        nodeEmojiByNodeId.set(cleanNodeId, emoji);
