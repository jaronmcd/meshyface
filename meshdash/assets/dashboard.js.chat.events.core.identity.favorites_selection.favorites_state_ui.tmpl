      try {{
        const raw = window.localStorage.getItem(pinnedNodesStorageKey);
        if (!raw) return;
        const parsed = JSON.parse(raw);
        if (!Array.isArray(parsed)) return;
        for (const entry of parsed) {{
          const nodeId = normalizeNodeId(entry);
          if (isSelectableNodeId(nodeId)) {{
            pinnedNodeIds.add(nodeId);
          }}
        }}
      }} catch (_err) {{
      }}
    }}

    function persistPinnedNodes() {{
      try {{
        const ids = Array.from(pinnedNodeIds).slice(0, 2000);
        window.localStorage.setItem(pinnedNodesStorageKey, JSON.stringify(ids));
      }} catch (_err) {{
      }}
    }}

    function meshtasticNodeFavoriteFlag(value) {{
      if (typeof parseBoolToken === "function") {{
        return parseBoolToken(value, false);
      }}
      if (typeof value === "boolean") return value;
      if (typeof value === "number") return Number.isFinite(value) && value !== 0;
      const clean = String(value == null ? "" : value).trim().toLowerCase();
      return clean === "1" || clean === "true" || clean === "yes" || clean === "on";
    }}

    function shouldIgnoreMeshtasticFavoriteNodeId(nodeId, state = latestState) {{
      const cleanNodeId = normalizeNodeId(nodeId);
      if (!isSelectableNodeId(cleanNodeId)) return true;
      return isSelfNodeId(cleanNodeId, state);
    }}

    function meshtasticFavoriteNodeIdsFromState(state = latestState) {{
      const safeState = (state && typeof state === "object") ? state : {{}};
      const nodes = Array.isArray(safeState.nodes) ? safeState.nodes : [];
      const ids = new Set();
      for (const node of nodes) {{
        if (!(node && typeof node === "object")) continue;
        const nodeId = normalizeNodeId(node.id || node.node_id || node.nodeId || "");
        if (!isSelectableNodeId(nodeId)) continue;
        if (shouldIgnoreMeshtasticFavoriteNodeId(nodeId, safeState)) continue;
        const favoriteValue = (
          Object.prototype.hasOwnProperty.call(node, "is_favorite")
            ? node.is_favorite
            : (Object.prototype.hasOwnProperty.call(node, "isFavorite")
              ? node.isFavorite
              : null)
        );
        if (meshtasticNodeFavoriteFlag(favoriteValue)) {{
          ids.add(nodeId);
        }}
      }}
      return ids;
    }}

    function meshtasticFavoriteTaggedNodeIds() {{
      const ids = new Set();
      for (const [rawNodeId, rawPresetId] of nodeTagByNodeId.entries()) {{
        const nodeId = normalizeNodeId(rawNodeId);
        if (!isSelectableNodeId(nodeId)) continue;
        if (shouldIgnoreMeshtasticFavoriteNodeId(nodeId)) continue;
        if (!isMeshtasticFavoritePresetId(rawPresetId)) continue;
        ids.add(nodeId);
      }}
      return ids;
    }}

    function meshtasticFavoriteNodeIdsWithPending(state = latestState) {{
      const nextFavoriteIds = meshtasticFavoriteNodeIdsFromState(state);
      const pendingTimeoutMs = 30000;
      for (const [rawNodeId, pendingRaw] of Array.from(meshtasticFavoritePendingDesiredByNodeId.entries())) {{
        const nodeId = normalizeNodeId(rawNodeId);
        if (!isSelectableNodeId(nodeId) || shouldIgnoreMeshtasticFavoriteNodeId(nodeId, state)) {{
          meshtasticFavoritePendingDesiredByNodeId.delete(rawNodeId);
          continue;
        }}
        const pending = (pendingRaw && typeof pendingRaw === "object") ? pendingRaw : {{}};
        const desiredActive = !!pending.active;
        const sinceMs = Number(pending.sinceMs);
        const ageMs = Number.isFinite(sinceMs) ? Math.max(0, Date.now() - sinceMs) : 0;
        const hasFavorite = nextFavoriteIds.has(nodeId);
        if (hasFavorite === desiredActive || ageMs > pendingTimeoutMs) {{
          meshtasticFavoritePendingDesiredByNodeId.delete(rawNodeId);
          continue;
        }}
        if (desiredActive) {{
          nextFavoriteIds.add(nodeId);
        }} else {{
          nextFavoriteIds.delete(nodeId);
        }}
      }}
      return nextFavoriteIds;
    }}

    function syncNodeTagsWithMeshtasticFavorites(state = latestState) {{
      const meshtasticPreset = ensureMeshtasticFavoriteTagPreset();
      const meshtasticPresetId = normalizeNodeTagPresetId(meshtasticPreset.id, meshtasticFavoriteTagPresetId);
      const nextFavoriteIds = meshtasticFavoriteNodeIdsWithPending(state);
      let changed = false;

      for (const nodeId of nextFavoriteIds) {{
        const currentPresetId = normalizeNodeTagPresetId(nodeTagByNodeId.get(nodeId), "");
        if (currentPresetId === meshtasticPresetId) continue;
        nodeTagByNodeId.set(nodeId, meshtasticPresetId);
        changed = true;
      }}

      for (const [rawNodeId, rawPresetId] of Array.from(nodeTagByNodeId.entries())) {{
        const nodeId = normalizeNodeId(rawNodeId);
        const presetId = normalizeNodeTagPresetId(rawPresetId, "");
        if (!isSelectableNodeId(nodeId) || presetId !== meshtasticPresetId) continue;
        if (nextFavoriteIds.has(nodeId)) continue;
        nodeTagByNodeId.delete(nodeId);
        changed = true;
      }}

      if (changed) {{
        persistFavoriteNodes();
      }}
      return changed;
    }}

    function normalizeNodeVisibilityListIds(rawValue) {{
      const entries = Array.isArray(rawValue)
        ? rawValue
        : (rawValue == null ? [] : [rawValue]);
      const seen = new Set();
      const out = [];
      for (const entry of entries) {{
        const nodeId = normalizeNodeId(entry);
        if (!isSelectableNodeId(nodeId) || seen.has(nodeId)) continue;
        seen.add(nodeId);
        out.push(nodeId);
      }}
      out.sort((a, b) => a.localeCompare(b));
      return out;
    }}

    function loadNodeVisibilityLists() {{
      nodeVisibilityWhitelistIds.clear();
      nodeVisibilityBlacklistIds.clear();
      try {{
        const raw = window.localStorage.getItem(nodeVisibilityWhitelistStorageKey);
        if (raw) {{
          const parsed = JSON.parse(raw);
          for (const nodeId of normalizeNodeVisibilityListIds(parsed)) {{
            nodeVisibilityWhitelistIds.add(nodeId);
          }}
        }}
      }} catch (_err) {{
      }}
      try {{
        const raw = window.localStorage.getItem(nodeVisibilityBlacklistStorageKey);
        if (raw) {{
          const parsed = JSON.parse(raw);
          for (const nodeId of normalizeNodeVisibilityListIds(parsed)) {{
            nodeVisibilityBlacklistIds.add(nodeId);
          }}
        }}
      }} catch (_err) {{
      }}
    }}

    function persistNodeVisibilityLists() {{
      try {{
        window.localStorage.setItem(
          nodeVisibilityWhitelistStorageKey,
          JSON.stringify(normalizeNodeVisibilityListIds(Array.from(nodeVisibilityWhitelistIds)).slice(0, 2000))
        );
      }} catch (_err) {{
      }}
      try {{
        window.localStorage.setItem(
          nodeVisibilityBlacklistStorageKey,
          JSON.stringify(normalizeNodeVisibilityListIds(Array.from(nodeVisibilityBlacklistIds)).slice(0, 2000))
        );
      }} catch (_err) {{
      }}
    }}

    function meshtasticFavoriteIdsForVisibility(state = latestRawState || latestState) {{
      if (typeof meshtasticFavoriteNodeIdsFromState !== "function") return new Set();
      const ids = meshtasticFavoriteNodeIdsFromState(state);
      return ids instanceof Set ? ids : new Set();
    }}

    function nodeVisibilityWhitelistFilterActive(state = latestRawState || latestState) {{
      if (nodeVisibilityWhitelistIds.size <= 0) return false;
      const meshtasticFavoriteIds = meshtasticFavoriteIdsForVisibility(state);
      for (const nodeId of nodeVisibilityWhitelistIds) {{
        if (!meshtasticFavoriteIds.has(nodeId)) return true;
      }}
      return false;
    }}

    function nodeVisibilityListsActive(state = latestRawState || latestState) {{
      return nodeVisibilityBlacklistIds.size > 0 || nodeVisibilityWhitelistFilterActive(state);
    }}

    function isNodeVisibleByLists(nodeId, state = latestRawState || latestState) {{
      const clean = normalizeNodeId(nodeId || "");
      if (!clean || clean === "^all" || clean === "^local") return true;
      if (!isSelectableNodeId(clean) && !isCanonicalNodeId(clean)) return true;
      if (nodeVisibilityBlacklistIds.has(clean)) return false;
      if (nodeVisibilityWhitelistFilterActive(state)) {{
        return nodeVisibilityWhitelistIds.has(clean);
      }}
      return true;
    }}

    function visibleFavoriteNodeIds(state = latestRawState || latestState) {{
      return Array.from(favoriteNodeIds).filter((nodeId) => isNodeVisibleByLists(nodeId, state));
    }}

    function countVisibleOnlineNodes(nodes, nowUnix = Math.floor(Date.now() / 1000), state = latestRawState || latestState) {{
      const entries = Array.isArray(nodes) ? nodes : [];
      let count = 0;
      for (const node of entries) {{
        const nodeId = normalizeNodeId(node && node.id);
        if (!isSelectableNodeId(nodeId) || !isNodeVisibleByLists(nodeId, state)) continue;
        const lastHeardUnix = nodeLastHeardUnix(node);
        if (!Number.isFinite(lastHeardUnix) || lastHeardUnix <= 0) continue;
        if ((nowUnix - lastHeardUnix) <= (2 * 60 * 60)) {{
          count += 1;
        }}
      }}
      return count;
    }}

    function nodeVisibilityMessagePasses(msg, state = latestRawState || latestState) {{
      if (!nodeVisibilityListsActive(state)) return true;
      const fromId = normalizeNodeId(
        (msg && (msg.from || msg.from_id || msg.fromId || msg.source || msg.source_id || msg.sourceId)) || ""
      );
      const toId = normalizeNodeId(
        (msg && (msg.to || msg.to_id || msg.toId || msg.destination || msg.dest || msg.dest_id || msg.destId)) || ""
      );
      if ((isSelectableNodeId(fromId) || isCanonicalNodeId(fromId)) && !isNodeVisibleByLists(fromId, state)) {{
        return false;
      }}
      if ((isSelectableNodeId(toId) || isCanonicalNodeId(toId)) && !isNodeVisibleByLists(toId, state)) {{
        return false;
      }}
      return true;
    }}

    function nodeVisibilityPacketPasses(packetEntry, state = latestRawState || latestState) {{
      if (!nodeVisibilityListsActive(state)) return true;
      const summary = (packetEntry && typeof packetEntry.summary === "object") ? packetEntry.summary : packetEntry;
      const packet = (packetEntry && typeof packetEntry.packet === "object") ? packetEntry.packet : packetEntry;
      const fromId = normalizeNodeId(
        (summary && (summary.from_id ?? summary.fromId ?? summary.from))
        ?? (packet && (packet.from_id ?? packet.fromId ?? packet.from))
        ?? ""
      );
      const toId = normalizeNodeId(
        (summary && (summary.to_id ?? summary.toId ?? summary.to))
        ?? (packet && (packet.to_id ?? packet.toId ?? packet.to ?? packet.destination))
        ?? ""
      );
      if ((isSelectableNodeId(fromId) || isCanonicalNodeId(fromId)) && !isNodeVisibleByLists(fromId, state)) {{
        return false;
      }}
      if ((isSelectableNodeId(toId) || isCanonicalNodeId(toId)) && !isNodeVisibleByLists(toId, state)) {{
        return false;
      }}
      return true;
    }}

    function applyNodeVisibilityFiltersToState(rawState) {{
      const safeState = rawState && typeof rawState === "object" ? rawState : {{}};
      if (!nodeVisibilityListsActive(safeState)) return safeState;

      const nodes = Array.isArray(safeState.nodes) ? safeState.nodes : [];
      const filteredNodes = nodes.filter((node) => isNodeVisibleByLists(node && node.id, safeState));
      const historyCapsRaw = (safeState.history_caps && typeof safeState.history_caps === "object")
        ? safeState.history_caps
        : {{}};
      const filteredHistoryCaps = Object.fromEntries(
        Object.entries(historyCapsRaw).filter(([nodeId]) => isNodeVisibleByLists(nodeId, safeState))
      );
      const trafficRaw = (safeState.traffic && typeof safeState.traffic === "object")
        ? safeState.traffic
        : {{}};
      const filteredEdges = Array.isArray(trafficRaw.edges)
        ? trafficRaw.edges.filter((edge) => (
          isNodeVisibleByLists(edge && edge.from, safeState) && isNodeVisibleByLists(edge && edge.to, safeState)
        ))
        : [];
      const filteredRecentChat = Array.isArray(trafficRaw.recent_chat)
        ? trafficRaw.recent_chat.filter((entry) => nodeVisibilityMessagePasses(entry, safeState))
        : [];
      const filteredRecentPackets = Array.isArray(trafficRaw.recent_packets)
        ? trafficRaw.recent_packets.filter((entry) => nodeVisibilityPacketPasses(entry, safeState))
        : [];
      const summaryRaw = (safeState.summary && typeof safeState.summary === "object")
        ? safeState.summary
        : {{}};
      const nodesWithPosition = filteredNodes.filter((node) => (
        Number.isFinite(Number(node && node.lat)) && Number.isFinite(Number(node && node.lon))
      )).length;
      const realEdgeCount = filteredEdges.filter((edge) => !!(edge && edge.is_real)).length;
      const filteredSummary = {{
        ...summaryRaw,
        node_count: filteredNodes.length,
        online_node_count: countVisibleOnlineNodes(filteredNodes, Math.floor(Date.now() / 1000), safeState),
        nodes_with_position: nodesWithPosition,
        edge_count: filteredEdges.length,
        real_edge_count: realEdgeCount,
      }};

      return {{
        ...safeState,
        summary: filteredSummary,
        nodes: filteredNodes,
        history_caps: filteredHistoryCaps,
        traffic: {{
          ...trafficRaw,
          edges: filteredEdges,
          recent_chat: filteredRecentChat,
          recent_packets: filteredRecentPackets,
        }},
      }};
    }}

    function syncSelectedNodeWithVisibilityFilters() {{
      const selectedId = normalizeNodeId(selectedNodeId || "");
      if (!isSelectableNodeId(selectedId)) return false;
      if (isNodeVisibleByLists(selectedId, latestRawState || latestState)) return false;
      if (typeof clearNodeSelection === "function") {{
        clearNodeSelection();
        return true;
      }}
      selectedNodeId = null;
      return true;
    }}

    function resolveNodeVisibilityEntryName(nodeId, nodesById = null) {{
      const clean = normalizeNodeId(nodeId || "");
      if (!isSelectableNodeId(clean)) return clean;
      const map = nodesById instanceof Map ? nodesById : new Map();
      const node = map.get(clean) || null;
      return preferredNodeName(node) || nodeNameCache.get(clean) || clean;
    }}

    function nodeVisibilityRuleLabel(nodeId) {{
      const clean = normalizeNodeId(nodeId || "");
      if (!isSelectableNodeId(clean)) return "Unlisted";
      if (nodeVisibilityBlacklistIds.has(clean)) return "Blocked";
      if (nodeVisibilityWhitelistFilterActive(latestRawState || latestState)) {{
        return nodeVisibilityWhitelistIds.has(clean) ? "Allowed" : "Hidden";
      }}
      return "Visible";
    }}

    function applyNodeVisibilityListChange(statusText = "") {{
      persistNodeVisibilityLists();
      if (latestRawState && typeof latestRawState === "object") {{
        latestState = applyNodeVisibilityFiltersToState(latestRawState);
      }} else if (latestState && typeof latestState === "object") {{
        latestState = applyNodeVisibilityFiltersToState(latestState);
      }}
      syncSelectedNodeWithVisibilityFilters();
      renderNodeVisibilityListsUi(latestRawState || latestState || {{}});
      if (typeof renderSelectionStatus === "function") {{
        renderSelectionStatus();
      }}
      if (statusText && typeof setSettingsStatusText === "function") {{
        setSettingsStatusText(statusText);
      }}
      if (typeof requestImmediatePoll === "function") {{
        requestImmediatePoll(0);
      }}
    }}

    function addNodeVisibilityWhitelistId(nodeId) {{
      const clean = normalizeNodeId(nodeId || "");
      if (!isSelectableNodeId(clean)) return;
      nodeVisibilityBlacklistIds.delete(clean);
      nodeVisibilityWhitelistIds.add(clean);
      applyNodeVisibilityListChange(`Allowed ${{clean}} in frontend lists.`);
    }}

    function addNodeVisibilityBlacklistId(nodeId) {{
      const clean = normalizeNodeId(nodeId || "");
      if (!isSelectableNodeId(clean)) return;
      nodeVisibilityWhitelistIds.delete(clean);
      nodeVisibilityBlacklistIds.add(clean);
      applyNodeVisibilityListChange(`Blocked ${{clean}} from frontend lists.`);
    }}

    function removeNodeVisibilityWhitelistId(nodeId) {{
      const clean = normalizeNodeId(nodeId || "");
      if (!isSelectableNodeId(clean) || !nodeVisibilityWhitelistIds.delete(clean)) return;
      applyNodeVisibilityListChange(`Removed ${{clean}} from frontend whitelist.`);
    }}

    function removeNodeVisibilityBlacklistId(nodeId) {{
      const clean = normalizeNodeId(nodeId || "");
      if (!isSelectableNodeId(clean) || !nodeVisibilityBlacklistIds.delete(clean)) return;
      applyNodeVisibilityListChange(`Removed ${{clean}} from frontend blacklist.`);
    }}

    function clearNodeVisibilityWhitelist() {{
      if (nodeVisibilityWhitelistIds.size <= 0) return;
      nodeVisibilityWhitelistIds.clear();
      applyNodeVisibilityListChange("Cleared frontend whitelist.");
    }}

    function clearNodeVisibilityBlacklist() {{
      if (nodeVisibilityBlacklistIds.size <= 0) return;
      nodeVisibilityBlacklistIds.clear();
      applyNodeVisibilityListChange("Cleared frontend blacklist.");
    }}

    function deleteNodeTagPreset(presetId, options = null) {{
      const cleanPresetId = normalizeNodeTagPresetId(presetId, "");
      if (!cleanPresetId || isNodeTagPresetIdLocked(cleanPresetId) || !nodeTagPresetsById.has(cleanPresetId)) return false;
      const fallbackPreset = nodeTagPresetForId("tag-default") || defaultNodeTagPreset();
      if (!nodeTagPresetsById.has(fallbackPreset.id)) {{
        nodeTagPresetsById.set(fallbackPreset.id, fallbackPreset);
      }}
      for (const [nodeId, assignedPresetId] of Array.from(nodeTagByNodeId.entries())) {{
        if (normalizeNodeTagPresetId(assignedPresetId, "") !== cleanPresetId) continue;
        nodeTagByNodeId.set(nodeId, fallbackPreset.id);
      }}
      nodeTagPresetsById.delete(cleanPresetId);
      syncFavoriteNodeIdsFromTags();
      if (activeNodeTagPresetId === cleanPresetId) {{
        setActiveNodeTagPreset(fallbackPreset.id, true);
      }}
      if (!(options && options.persist === false)) {{
        persistFavoriteNodes();
      }}
      return true;
    }}

    function settingsNodeTagPresetManagerHtml() {{
      const presets = nodeTagPresetEntries();
      const activePreset = nodeTagPresetForId(activeNodeTagPresetId) || nodeTagPresetForId("tag-default") || defaultNodeTagPreset();
      const draft = settingsNodeTagPresetDraft && typeof settingsNodeTagPresetDraft === "object"
        ? settingsNodeTagPresetDraft
        : null;
      const selectedPresetId = normalizeNodeTagPresetId(
        draft && draft.selectedPresetId,
        normalizeNodeTagPresetId(activePreset.id, "tag-default")
      );
      const selectedPresetLocked = isNodeTagPresetIdLocked(selectedPresetId);
      const formName = normalizeNodeTagPresetName(draft && draft.name, activePreset.name);
      const formEmoji = normalizeNodeTagEmoji(draft && draft.emoji, activePreset.emoji);
      const formColor = normalizeNodeTagColor(draft && draft.color, activePreset.color);
      const formVibrance = clampNodeTagVibrance(draft && draft.vibrance, activePreset.vibrance);
      const optionsHtml = [`<option value="">New preset</option>`].concat(
        presets.map((preset) => {{
          const presetId = normalizeNodeTagPresetId(preset.id, "tag-default");
          const selectedAttr = presetId === selectedPresetId ? " selected" : "";
          return `<option value="${{escAttr(presetId)}}"${{selectedAttr}}>${{escAttr(nodeTagDisplayLabel({{ preset }}, "Tagged"))}}</option>`;
        }})
      ).join("");
      const previewPreset = {{
        color: formColor,
        vibrance: formVibrance,
        emoji: formEmoji,
      }};
      const previewStyle = nodeTagStyleVars({{ preset: previewPreset }});
      const previewEmoji = nodeTagChipEmojiHtml({{ preset: previewPreset }});
      return `<div id="settings-node-tag-presets-panel" class="favorite-menu-tag-editor">
        <div class="favorite-menu-tag-editor-row">
          <label for="settings-node-tag-preset-select" class="favorite-menu-tag-editor-label">Preset</label>
          <select id="settings-node-tag-preset-select" class="favorite-menu-tag-preset-select">
            ${{optionsHtml}}
          </select>
        </div>
        <div class="favorite-menu-tag-editor-row">
          <label for="settings-node-tag-name-input" class="favorite-menu-tag-editor-label">Name</label>
          <input id="settings-node-tag-name-input" class="favorite-menu-tag-editor-input" type="text" maxlength="40" value="${{escAttr(formName)}}" placeholder="Tag name"${{selectedPresetLocked ? " disabled" : ""}} />
        </div>
        <div class="favorite-menu-tag-editor-row">
          <label for="settings-node-tag-emoji-input" class="favorite-menu-tag-editor-label">Emoji</label>
          <input id="settings-node-tag-emoji-input" class="favorite-menu-tag-editor-input favorite-menu-tag-emoji-input" type="text" maxlength="8" value="${{escAttr(formEmoji)}}" placeholder="Optional emoji"${{selectedPresetLocked ? " disabled" : ""}} />
        </div>
        <div class="favorite-menu-tag-editor-row favorite-menu-tag-editor-row-inline">
          <label for="settings-node-tag-color-input" class="favorite-menu-tag-editor-label">Color</label>
          <input id="settings-node-tag-color-input" class="favorite-menu-tag-color-input" type="color" value="${{escAttr(formColor)}}"${{selectedPresetLocked ? " disabled" : ""}} />
          <label for="settings-node-tag-vibrance-input" class="favorite-menu-tag-editor-label">Vibrance</label>
          <input id="settings-node-tag-vibrance-input" class="favorite-menu-tag-vibrance-input" type="range" min="0" max="100" step="1" value="${{escAttr(formVibrance)}}"${{selectedPresetLocked ? " disabled" : ""}} />
          <span id="settings-node-tag-vibrance-value" class="favorite-menu-tag-vibrance-value">${{escAttr(formVibrance)}}%</span>
          <span id="settings-node-tag-preview" class="favorite-menu-tag-chip favorite-menu-tag-chip-preview${{previewEmoji ? " has-emoji" : ""}}" style="${{escAttr(previewStyle)}}" aria-hidden="true">${{previewEmoji}}</span>
        </div>
        <div class="favorite-menu-tag-editor-actions">
          <button id="settings-node-tag-save-btn" class="btn btn-secondary" type="button"${{selectedPresetLocked ? " disabled" : ""}}>Save Preset</button>
          <button id="settings-node-tag-new-btn" class="btn btn-secondary" type="button">New Preset</button>
          <button id="settings-node-tag-delete-btn" class="btn btn-secondary" type="button"${{selectedPresetLocked ? " disabled" : ""}}>Delete Preset</button>
        </div>
        <div id="settings-node-tag-status" class="favorite-menu-tag-status"></div>
      </div>`;
    }}

    function renderNodeTagPresetManagerUi(force = false) {{
      const host = document.getElementById("settings-node-tag-presets-manager");
      if (!(host instanceof HTMLElement)) return;
      if (!force && host.contains(document.activeElement)) {{
        bindNodeTagPresetManagerControls();
        return;
      }}
      host.innerHTML = settingsNodeTagPresetManagerHtml();
      bindNodeTagPresetManagerControls();
    }}

    function bindNodeTagPresetManagerControls() {{
      const host = document.getElementById("settings-node-tag-presets-panel");
      if (!(host instanceof HTMLElement) || host.dataset.boundNodeTagPresets === "1") return;
      host.dataset.boundNodeTagPresets = "1";
      const presetSelect = document.getElementById("settings-node-tag-preset-select");
      const nameInput = document.getElementById("settings-node-tag-name-input");
      const emojiInput = document.getElementById("settings-node-tag-emoji-input");
      const colorInput = document.getElementById("settings-node-tag-color-input");
      const vibranceInput = document.getElementById("settings-node-tag-vibrance-input");
      const vibranceValue = document.getElementById("settings-node-tag-vibrance-value");
      const preview = document.getElementById("settings-node-tag-preview");
      const statusEl = document.getElementById("settings-node-tag-status");
      const saveBtn = document.getElementById("settings-node-tag-save-btn");
      const newBtn = document.getElementById("settings-node-tag-new-btn");
      const deleteBtn = document.getElementById("settings-node-tag-delete-btn");
      if (!(presetSelect instanceof HTMLSelectElement)) return;
      if (!(nameInput instanceof HTMLInputElement)) return;
      if (!(emojiInput instanceof HTMLInputElement)) return;
      if (!(colorInput instanceof HTMLInputElement)) return;
      if (!(vibranceInput instanceof HTMLInputElement)) return;
      if (!(vibranceValue instanceof HTMLElement)) return;
      if (!(preview instanceof HTMLElement)) return;
      if (!(statusEl instanceof HTMLElement)) return;
      if (!(saveBtn instanceof HTMLButtonElement)) return;
      if (!(newBtn instanceof HTMLButtonElement)) return;
      if (!(deleteBtn instanceof HTMLButtonElement)) return;

      const setStatus = (text) => {{
        statusEl.textContent = String(text == null ? "" : text);
      }};

      const syncDraft = () => {{
        settingsNodeTagPresetDraft = {{
          selectedPresetId: normalizeNodeTagPresetId(presetSelect.value || "", ""),
          name: nameInput.value,
          emoji: emojiInput.value,
          color: colorInput.value,
          vibrance: vibranceInput.value,
        }};
      }};

      const applyPreview = () => {{
        const emoji = normalizeNodeTagEmoji(emojiInput.value, "");
        const color = normalizeNodeTagColor(colorInput.value, "#2aa85a");
        const vibrance = clampNodeTagVibrance(vibranceInput.value, 70);
        emojiInput.value = emoji;
        vibranceValue.textContent = `${{vibrance}}%`;
        preview.setAttribute("style", nodeTagStyleVars({{ preset: {{ color, vibrance }} }}));
        preview.classList.toggle("has-emoji", !!emoji);
        preview.innerHTML = emoji ? `<span class="favorite-menu-tag-chip-emoji" aria-hidden="true">${{escAttr(emoji)}}</span>` : "";
        syncDraft();
      }};

      const applyPresetLockState = (presetId) => {{
        const locked = isNodeTagPresetIdLocked(presetId);
        const hasPreset = !!normalizeNodeTagPresetId(presetId, "");
        nameInput.disabled = locked;
        emojiInput.disabled = locked;
        colorInput.disabled = locked;
        vibranceInput.disabled = locked;
        saveBtn.disabled = locked;
        deleteBtn.disabled = locked || !hasPreset;
      }};

      const loadPreset = (presetId) => {{
