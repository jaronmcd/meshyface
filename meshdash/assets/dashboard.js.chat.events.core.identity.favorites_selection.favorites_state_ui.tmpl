      const beforePresetId = normalizeNodeTagPresetId(nodeTagByNodeId.get(cleanNodeId), "");
      const tagCleared = nodeTagByNodeId.delete(cleanNodeId);
      const emojiCleared = nodeEmojiByNodeId.delete(cleanNodeId);
      const changed = !!(tagCleared || emojiCleared);
      if (!changed) {{
        return {{
          tagCleared: false,
          emojiCleared: false,
          changed: false,
        }};
      }}
      syncFavoriteNodeIdsFromTags();
      if (!(options && options.persist === false)) {{
        persistFavoriteNodes();
      }}
      if (tagCleared) {{
        syncMeshtasticFavoriteFromTagTransition(cleanNodeId, beforePresetId, "", options);
