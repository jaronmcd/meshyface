    function setActiveNodeTagPreset(presetId, persist = true) {{
      let cleanPresetId = normalizeNodeTagPresetId(presetId);
      if (!cleanPresetId || !nodeTagPresetsById.has(cleanPresetId)) {{
        const fallback = nodeTagPresetEntries()[0] || defaultNodeTagPreset();
        cleanPresetId = normalizeNodeTagPresetId(fallback.id, "tag-default");
      }}
      activeNodeTagPresetId = cleanPresetId;
      if (persist) {{
        persistActiveNodeTagPreset();
      }}
      return cleanPresetId;
    }}

    function upsertNodeTagPreset(name, color, vibrance, options = null) {{
      const opts = options && typeof options === "object" ? options : {{}};
      const preferredId = normalizeNodeTagPresetId(opts.preferredId || "", "");
      if (isMeshtasticFavoritePresetId(preferredId)) {{
        const preset = ensureMeshtasticFavoriteTagPreset();
        persistNodeTagPresets();
        setActiveNodeTagPreset(preset.id, true);
        return preset;
      }}
      const cleanName = normalizeNodeTagPresetName(name, "Tagged");
      if (cleanName.toLowerCase() === "meshtastic") {{
        const preset = ensureMeshtasticFavoriteTagPreset();
        persistNodeTagPresets();
        setActiveNodeTagPreset(preset.id, true);
        return preset;
      }}
      const cleanEmoji = normalizeNodeTagEmoji(opts.emoji, "");
      const cleanColor = normalizeNodeTagColor(color, "#2aa85a");
      const cleanVibrance = clampNodeTagVibrance(vibrance, 70);
      let presetId = preferredId;
      if (!presetId || (!nodeTagPresetsById.has(presetId) && presetId === "tag-default")) {{
        if (cleanName.toLowerCase() === "tagged") {{
          presetId = "tag-default";
        }} else {{
          const base = normalizeNodeTagPresetId(cleanName, "tag");
          presetId = base;
          let suffix = 2;
          while (nodeTagPresetsById.has(presetId)) {{
            presetId = `${{base}}-${{suffix}}`;
            suffix += 1;
            if (suffix > 99) break;
          }}
        }}
      }}
      const preset = {{
        id: presetId,
        name: cleanName,
        emoji: cleanEmoji,
        color: cleanColor,
        vibrance: cleanVibrance,
      }};
      nodeTagPresetsById.set(presetId, preset);
      persistNodeTagPresets();
      setActiveNodeTagPreset(presetId, true);
      return preset;
    }}

    function syncMeshtasticFavoriteFromTagTransition(nodeId, beforePresetId, afterPresetId, options = null) {{
      const opts = options && typeof options === "object" ? options : {{}};
      if (opts.syncMeshtasticFavorite === false) return;
      const cleanNodeId = normalizeNodeId(nodeId);
      if (!isCanonicalNodeId(cleanNodeId)) return;
      if (shouldIgnoreMeshtasticFavoriteNodeId(cleanNodeId)) return;
      const wasMeshtastic = isMeshtasticFavoritePresetId(beforePresetId);
      const isMeshtastic = isMeshtasticFavoritePresetId(afterPresetId);
      if (wasMeshtastic === isMeshtastic) return;
      if (typeof requestMeshtasticFavoriteTagSync === "function") {{
        void requestMeshtasticFavoriteTagSync(cleanNodeId, isMeshtastic);
      }}
    }}

    function assignNodeTagPresetToNode(nodeId, presetId, options = null) {{
      const cleanNodeId = normalizeNodeId(nodeId);
      if (!isSelectableNodeId(cleanNodeId)) return false;
