    function renderNodeTagPresetManagerUi(force = false) {{
      const host = document.getElementById("settings-node-tag-presets-manager");
      if (!(host instanceof HTMLElement)) return;
      if (!force && host.contains(document.activeElement)) {{
        bindNodeTagPresetManagerControls();
        return;
      }}
      host.innerHTML = settingsNodeTagPresetManagerHtml();
      bindNodeTagPresetManagerControls();
    }}

    function bindNodeTagPresetManagerControls() {{
      const host = document.getElementById("settings-node-tag-presets-panel");
      if (!(host instanceof HTMLElement) || host.dataset.boundNodeTagPresets === "1") return;
      host.dataset.boundNodeTagPresets = "1";
      const presetSelect = document.getElementById("settings-node-tag-preset-select");
      const nameInput = document.getElementById("settings-node-tag-name-input");
      const emojiInput = document.getElementById("settings-node-tag-emoji-input");
      const colorInput = document.getElementById("settings-node-tag-color-input");
      const vibranceInput = document.getElementById("settings-node-tag-vibrance-input");
      const vibranceValue = document.getElementById("settings-node-tag-vibrance-value");
      const preview = document.getElementById("settings-node-tag-preview");
      const statusEl = document.getElementById("settings-node-tag-status");
      const saveBtn = document.getElementById("settings-node-tag-save-btn");
      const newBtn = document.getElementById("settings-node-tag-new-btn");
      const deleteBtn = document.getElementById("settings-node-tag-delete-btn");
      if (!(presetSelect instanceof HTMLSelectElement)) return;
      if (!(nameInput instanceof HTMLInputElement)) return;
      if (!(emojiInput instanceof HTMLInputElement)) return;
      if (!(colorInput instanceof HTMLInputElement)) return;
      if (!(vibranceInput instanceof HTMLInputElement)) return;
      if (!(vibranceValue instanceof HTMLElement)) return;
      if (!(preview instanceof HTMLElement)) return;
      if (!(statusEl instanceof HTMLElement)) return;
      if (!(saveBtn instanceof HTMLButtonElement)) return;
      if (!(newBtn instanceof HTMLButtonElement)) return;
      if (!(deleteBtn instanceof HTMLButtonElement)) return;

      const setStatus = (text) => {{
        statusEl.textContent = String(text == null ? "" : text);
      }};

      const syncDraft = () => {{
        settingsNodeTagPresetDraft = {{
          selectedPresetId: normalizeNodeTagPresetId(presetSelect.value || "", ""),
          name: nameInput.value,
          emoji: emojiInput.value,
          color: colorInput.value,
          vibrance: vibranceInput.value,
        }};
      }};

      const applyPreview = () => {{
        const emoji = normalizeNodeTagEmoji(emojiInput.value, "");
        const color = normalizeNodeTagColor(colorInput.value, "#2aa85a");
        const vibrance = clampNodeTagVibrance(vibranceInput.value, 70);
        emojiInput.value = emoji;
        vibranceValue.textContent = `${{vibrance}}%`;
        preview.setAttribute("style", nodeTagStyleVars({{ preset: {{ color, vibrance }} }}));
        preview.classList.toggle("has-emoji", !!emoji);
        preview.innerHTML = emoji ? `<span class="favorite-menu-tag-chip-emoji" aria-hidden="true">${{escAttr(emoji)}}</span>` : "";
        syncDraft();
      }};

      const loadPreset = (presetId) => {{
        const preset = nodeTagPresetForId(presetId);
        if (!preset) {{
          nameInput.value = "";
          emojiInput.value = "";
          colorInput.value = "#2aa85a";
          vibranceInput.value = "70";
          deleteBtn.disabled = true;
          applyPreview();
          return;
        }}
        nameInput.value = normalizeNodeTagPresetName(preset.name, "Tagged");
        emojiInput.value = normalizeNodeTagEmoji(preset.emoji, "");
        colorInput.value = normalizeNodeTagColor(preset.color, "#2aa85a");
        vibranceInput.value = String(clampNodeTagVibrance(preset.vibrance, 70));
        deleteBtn.disabled = normalizeNodeTagPresetId(preset.id, "tag-default") === "tag-default";
        applyPreview();
      }};

      const refreshViews = () => {{
        renderNodeTagPresetManagerUi(true);
        renderNodeVisibilityListsUi(latestRawState || latestState || {{}});
        renderStarredNodeSelect(latestState || latestRawState || {{}});
        refreshFavoriteToggleButtons();
        if (latestState) {{
          renderFavorites(latestState);
        }}
        if (typeof syncChatNodeDetailsDrawer === "function") {{
          syncChatNodeDetailsDrawer(latestState, {{ fetchHistory: false }});
        }}
      }};

      const openEmojiPicker = () => {{
        if (typeof openChatEmojiPanel !== "function") return;
        openChatEmojiPanel("tag", null, emojiInput);
      }};

      presetSelect.addEventListener("change", () => {{
        const presetId = normalizeNodeTagPresetId(presetSelect.value || "", "");
        if (presetId && nodeTagPresetsById.has(presetId)) {{
          setActiveNodeTagPreset(presetId, true);
        }}
        settingsNodeTagPresetDraft = null;
        loadPreset(presetId);
        setStatus("");
      }});
      nameInput.addEventListener("input", () => {{
        applyPreview();
        setStatus("");
      }});
      emojiInput.addEventListener("input", () => {{
        applyPreview();
        setStatus("");
      }});
      emojiInput.addEventListener("blur", () => {{
        emojiInput.value = normalizeNodeTagEmoji(emojiInput.value, "");
        applyPreview();
      }});
      emojiInput.addEventListener("click", openEmojiPicker);
      emojiInput.addEventListener("focus", openEmojiPicker);
      emojiInput.addEventListener("keydown", (ev) => {{
        const key = String(ev.key || "");
        if (key === "Enter" || key === "ArrowDown" || key === " ") {{
          ev.preventDefault();
          openEmojiPicker();
        }}
      }});
      const syncColorPreview = () => {{
        applyPreview();
        setStatus("");
      }};
      colorInput.addEventListener("input", syncColorPreview);
      colorInput.addEventListener("change", syncColorPreview);
      const syncVibrancePreview = () => {{
        applyPreview();
        setStatus("");
      }};
      vibranceInput.addEventListener("input", syncVibrancePreview);
      vibranceInput.addEventListener("change", syncVibrancePreview);
      saveBtn.addEventListener("click", () => {{
        const preferredId = normalizeNodeTagPresetId(presetSelect.value || "", "");
        const preset = upsertNodeTagPreset(
          nameInput.value,
          colorInput.value,
          vibranceInput.value,
          {{
            preferredId,
            emoji: emojiInput.value,
          }}
        );
        settingsNodeTagPresetDraft = {{
          selectedPresetId: normalizeNodeTagPresetId(preset.id, ""),
          name: preset.name,
          emoji: preset.emoji,
          color: preset.color,
          vibrance: preset.vibrance,
        }};
        setStatus(`Preset saved: ${{preset.name}}`);
        refreshViews();
      }});
      newBtn.addEventListener("click", () => {{
        presetSelect.value = "";
        settingsNodeTagPresetDraft = {{
          selectedPresetId: "",
          name: "",
          emoji: "",
          color: "#2aa85a",
          vibrance: 70,
        }};
        loadPreset("");
        setStatus("New preset");
        nameInput.focus();
      }});
      deleteBtn.addEventListener("click", () => {{
        const presetId = normalizeNodeTagPresetId(presetSelect.value || "", "");
        if (!deleteNodeTagPreset(presetId, {{ persist: true }})) return;
        setStatus("Preset deleted. Tagged nodes moved to Tagged.");
        setActiveNodeTagPreset("tag-default", true);
        settingsNodeTagPresetDraft = null;
        refreshViews();
      }});

      applyPreview();
    }}

    function renderNodeVisibilityListsUi(state = latestRawState || latestState) {{
      renderNodeTagPresetManagerUi();
      const selectedHost = document.getElementById("settings-node-visibility-selected");
      const searchInput = document.getElementById("settings-nodes-node-search-input");
      const resultsHost = document.getElementById("settings-nodes-search-results");
      const whitelistHost = document.getElementById("settings-whitelist-list");
      const blacklistHost = document.getElementById("settings-blacklist-list");
      if (!(selectedHost instanceof HTMLElement)) return;
      if (!(resultsHost instanceof HTMLElement)) return;
      if (!(whitelistHost instanceof HTMLElement)) return;
      if (!(blacklistHost instanceof HTMLElement)) return;
      if (searchInput instanceof HTMLInputElement && searchInput.value !== nodeVisibilitySettingsSearchQuery) {{
        searchInput.value = nodeVisibilitySettingsSearchQuery;
      }}

      const safeState = state && typeof state === "object" ? state : {{}};
      const nodes = Array.isArray(safeState.nodes) ? safeState.nodes : [];
      const nodesById = new Map(
        nodes
          .map((node) => [normalizeNodeId(node && node.id), node])
          .filter(([nodeId]) => isSelectableNodeId(nodeId))
      );
      const selectedId = normalizeNodeId(selectedNodeId || "");
      if (isSelectableNodeId(selectedId)) {{
        const selectedName = resolveNodeVisibilityEntryName(selectedId, nodesById);
        const selectedRule = nodeVisibilityRuleLabel(selectedId);
        selectedHost.classList.remove("node-visibility-card-empty");
        selectedHost.innerHTML = `<div class="node-visibility-item">
          <div class="node-visibility-meta">
            <div class="node-visibility-name-row">
              <span class="node-visibility-name">${{escAttr(selectedName)}}</span>
              <span class="node-visibility-badge">${{escAttr(selectedRule)}}</span>
            </div>
            <div class="node-visibility-id">${{escAttr(selectedId)}}</div>
          </div>
          <div class="node-visibility-actions">
            <button type="button" class="btn btn-secondary" data-node-visibility-action="allow" data-node-id="${{escAttr(selectedId)}}"${{nodeVisibilityWhitelistIds.has(selectedId) ? " disabled" : ""}}>Allow</button>
            <button type="button" class="btn btn-secondary" data-node-visibility-action="block" data-node-id="${{escAttr(selectedId)}}"${{nodeVisibilityBlacklistIds.has(selectedId) ? " disabled" : ""}}>Block</button>
          </div>
        </div>`;
      }} else {{
        selectedHost.classList.add("node-visibility-card-empty");
        selectedHost.textContent = "Select a node to manage it here.";
      }}

      const query = String(nodeVisibilitySettingsSearchQuery || "").trim();
      const searchRows = buildNodeSearchResults(safeState, query, 200, {{
        includeHiddenNodes: true,
      }});
      if (!searchRows.length) {{
        resultsHost.innerHTML = '<div class="node-visibility-empty">No nodes match this search.</div>';
      }} else {{
        resultsHost.innerHTML = searchRows.map((row) => {{
          const cleanNodeId = normalizeNodeId(row && row.nodeId);
          const ruleLabel = nodeVisibilityRuleLabel(cleanNodeId);
          return `<div class="node-visibility-item">
            <div class="node-visibility-meta">
              <div class="node-visibility-name-row">
                <span class="node-visibility-name">${{escAttr(row && row.name ? row.name : cleanNodeId)}}</span>
                <span class="node-visibility-badge">${{escAttr(ruleLabel)}}</span>
              </div>
              <div class="node-visibility-id">${{escAttr(cleanNodeId)}}</div>
            </div>
            <div class="node-visibility-actions">
              <button type="button" class="btn btn-secondary" data-node-visibility-action="allow" data-node-id="${{escAttr(cleanNodeId)}}"${{nodeVisibilityWhitelistIds.has(cleanNodeId) ? " disabled" : ""}}>Allow</button>
              <button type="button" class="btn btn-secondary" data-node-visibility-action="block" data-node-id="${{escAttr(cleanNodeId)}}"${{nodeVisibilityBlacklistIds.has(cleanNodeId) ? " disabled" : ""}}>Block</button>
            </div>
          </div>`;
        }}).join("");
      }}

      const renderList = (host, ids, removeAction, emptyText) => {{
        if (!ids.length) {{
          host.innerHTML = `<div class="node-visibility-empty">${{escAttr(emptyText)}}</div>`;
          return;
        }}
        host.innerHTML = ids.map((nodeId) => {{
          const name = resolveNodeVisibilityEntryName(nodeId, nodesById);
          return `<div class="node-visibility-item">
            <div class="node-visibility-meta">
              <div class="node-visibility-name-row">
                <span class="node-visibility-name">${{escAttr(name)}}</span>
              </div>
              <div class="node-visibility-id">${{escAttr(nodeId)}}</div>
            </div>
            <div class="node-visibility-actions">
              <button type="button" class="btn btn-secondary" data-node-visibility-action="${{escAttr(removeAction)}}" data-node-id="${{escAttr(nodeId)}}">Remove</button>
            </div>
          </div>`;
        }}).join("");
      }};

      const sortIdsByName = (ids) => ids.slice().sort((a, b) => {{
        const aName = resolveNodeVisibilityEntryName(a, nodesById);
        const bName = resolveNodeVisibilityEntryName(b, nodesById);
        const nameDiff = String(aName || "").localeCompare(String(bName || ""));
        if (nameDiff !== 0) return nameDiff;
        return String(a || "").localeCompare(String(b || ""));
      }});
      renderList(
        whitelistHost,
        sortIdsByName(Array.from(nodeVisibilityWhitelistIds)),
        "remove-allow",
        "No whitelist entries yet. Leave this empty to show all non-blacklisted nodes."
      );
      renderList(
        blacklistHost,
        sortIdsByName(Array.from(nodeVisibilityBlacklistIds)),
        "remove-block",
        "No blacklist entries yet."
      );
    }}

    function bindNodeVisibilityListControls() {{
      const panel = document.querySelector('.card.settings [data-settings-tab-panel="nodes"]');
      if (!(panel instanceof HTMLElement) || panel.dataset.boundNodeVisibility === "1") return;
      panel.dataset.boundNodeVisibility = "1";
      const searchInput = document.getElementById("settings-nodes-node-search-input");
      if (searchInput instanceof HTMLInputElement) {{
        searchInput.addEventListener("input", () => {{
          nodeVisibilitySettingsSearchQuery = String(searchInput.value || "").trim().toLowerCase();
          renderNodeVisibilityListsUi(latestRawState || latestState || {{}});
        }});
      }}
      panel.addEventListener("click", (ev) => {{
        const target = ev.target instanceof Element ? ev.target : null;
        if (!target) return;
        const actionButton = target.closest("button[data-node-visibility-action]");
        if (actionButton instanceof HTMLButtonElement) {{
          const nodeId = normalizeNodeId(actionButton.dataset.nodeId || "");
          const action = String(actionButton.dataset.nodeVisibilityAction || "").trim().toLowerCase();
          if (action === "allow") {{
            addNodeVisibilityWhitelistId(nodeId);
          }} else if (action === "block") {{
            addNodeVisibilityBlacklistId(nodeId);
          }} else if (action === "remove-allow") {{
            removeNodeVisibilityWhitelistId(nodeId);
          }} else if (action === "remove-block") {{
            removeNodeVisibilityBlacklistId(nodeId);
          }}
          return;
        }}
        const clearWhitelistBtn = target.closest("#settings-whitelist-clear-btn");
        if (clearWhitelistBtn instanceof HTMLButtonElement) {{
          clearNodeVisibilityWhitelist();
          return;
        }}
        const clearBlacklistBtn = target.closest("#settings-blacklist-clear-btn");
        if (clearBlacklistBtn instanceof HTMLButtonElement) {{
          clearNodeVisibilityBlacklist();
        }}
      }});
    }}

    function normalizeNodeNoteText(rawValue, maxChars = 1200) {{
      let text = String(rawValue == null ? "" : rawValue)
        .replace(/\r\n?/g, "\n")
        .replace(/\u0000/g, "");
      const cap = Math.max(80, Math.trunc(Number(maxChars) || 1200));
      if (text.length > cap) {{
        text = text.slice(0, cap);
      }}
      if (!text.trim()) {{
        return "";
      }}
      return text.trim();
    }}

    function loadNodeNotes() {{
      nodeNotesById.clear();
      try {{
        const raw = window.localStorage.getItem(nodeNotesStorageKey);
        if (!raw) return;
        const parsed = JSON.parse(raw);
        const entries = Array.isArray(parsed)
          ? parsed
          : (parsed && typeof parsed === "object" ? Object.entries(parsed) : []);
        for (const item of entries) {{
          let rawNodeId = "";
          let rawEntry = null;
          if (Array.isArray(item)) {{
            rawNodeId = String(item[0] || "");
            rawEntry = item[1];
          }} else {{
            continue;
          }}
          const nodeId = normalizeNodeId(rawNodeId);
          if (!isSelectableNodeId(nodeId)) continue;
          const rawNote = (
            typeof rawEntry === "string"
              ? rawEntry
              : (rawEntry && (rawEntry.note ?? rawEntry.text))
          );
          const note = normalizeNodeNoteText(rawNote);
          if (!note) continue;
          const updatedRaw = Number(rawEntry && (rawEntry.updated_unix ?? rawEntry.updatedUnix));
          const updatedUnix = Number.isFinite(updatedRaw) && updatedRaw > 0
            ? Math.trunc(updatedRaw)
            : 0;
          nodeNotesById.set(nodeId, {{
            note,
            updatedUnix,
          }});
        }}
      }} catch (_err) {{
      }}
    }}

    function persistNodeNotes() {{
      try {{
        const payload = {{}};
        let count = 0;
        for (const [nodeId, rawEntry] of nodeNotesById.entries()) {{
          if (count >= 4000) break;
          const cleanNodeId = normalizeNodeId(nodeId);
          if (!isSelectableNodeId(cleanNodeId)) continue;
          const note = normalizeNodeNoteText(rawEntry && rawEntry.note);
          if (!note) continue;
          const updatedRaw = Number(rawEntry && rawEntry.updatedUnix);
          const updatedUnix = Number.isFinite(updatedRaw) && updatedRaw > 0
            ? Math.trunc(updatedRaw)
            : Math.floor(Date.now() / 1000);
          payload[cleanNodeId] = {{
            note,
            updated_unix: updatedUnix,
          }};
          count += 1;
        }}
        window.localStorage.setItem(nodeNotesStorageKey, JSON.stringify(payload));
      }} catch (_err) {{
      }}
    }}

    function nodeNoteEntry(nodeId) {{
      const normalized = normalizeNodeId(nodeId);
      if (!isSelectableNodeId(normalized)) return null;
      const rawEntry = nodeNotesById.get(normalized);
      if (!rawEntry || typeof rawEntry !== "object") return null;
      const note = normalizeNodeNoteText(rawEntry.note);
      if (!note) return null;
      const updatedRaw = Number(rawEntry.updatedUnix);
      const updatedUnix = Number.isFinite(updatedRaw) && updatedRaw > 0
        ? Math.trunc(updatedRaw)
        : 0;
      return {{
        nodeId: normalized,
        note,
        updatedUnix,
      }};
    }}

    function saveNodeNote(nodeId, rawNote) {{
      const normalized = normalizeNodeId(nodeId);
      if (!isSelectableNodeId(normalized)) {{
        return {{ ok: false, nodeId: normalized, note: "", updatedUnix: 0, cleared: false }};
      }}
      const note = normalizeNodeNoteText(rawNote);
      if (!note) {{
        nodeNotesById.delete(normalized);
        persistNodeNotes();
        return {{ ok: true, nodeId: normalized, note: "", updatedUnix: 0, cleared: true }};
      }}
      const updatedUnix = Math.floor(Date.now() / 1000);
      nodeNotesById.set(normalized, {{
        note,
        updatedUnix,
      }});
      persistNodeNotes();
      return {{ ok: true, nodeId: normalized, note, updatedUnix, cleared: false }};
    }}

    function isFavoriteNode(nodeId) {{
      const normalized = normalizeNodeId(nodeId);
      return isSelectableNodeId(normalized) && favoriteNodeIds.has(normalized);
    }}

    function nodeTagLabelForNode(nodeId) {{
      const entry = nodeTagEntryForNode(nodeId);
      if (!entry || !entry.preset) return "";
      return nodeTagDisplayLabel(entry, "Tagged");
    }}

    function isMutedNode(nodeId) {{
      const normalized = normalizeNodeId(nodeId);
      return isSelectableNodeId(normalized) && mutedNodeIds.has(normalized);
    }}

    function isPinnedNode(nodeId) {{
      const normalized = normalizeNodeId(nodeId);
      return isSelectableNodeId(normalized) && pinnedNodeIds.has(normalized);
    }}

    function favoriteToggleButtonHtml(nodeId, extraClass = "") {{
      const normalized = normalizeNodeId(nodeId);
      if (!isSelectableNodeId(normalized)) return "";
      const tagEntry = nodeTagEntryForNode(normalized);
      const active = !!tagEntry;
      const activePresetId = normalizeNodeTagPresetId(activeNodeTagPresetId || "tag-default", "tag-default");
      const activePreset = nodeTagPresetForId(activePresetId);
      const quickLabel = activePreset ? normalizeNodeTagPresetName(activePreset.name, "Tagged") : "tag";
      const title = active
        ? `Clear tag (${{normalizeNodeTagPresetName(tagEntry.preset.name, "Tagged")}})`
        : `Tag node with ${{quickLabel}}`;
      const styleVars = active ? nodeTagStyleVars(tagEntry) : "";
      const styleAttr = styleVars ? ` style="${{escAttr(styleVars)}}"` : "";
      return `<button type="button" class="favorite-toggle-btn ${{extraClass}}${{active ? " active" : ""}}" data-node-id="${{escAttr(normalized)}}" title="${{title}}" aria-label="${{title}}" aria-pressed="${{active ? "true" : "false"}}"${{styleAttr}}><span class="favorite-toggle-icon node-tag-dot"></span></button>`;
    }}

    function muteToggleButtonHtml(nodeId, extraClass = "") {{
      const normalized = normalizeNodeId(nodeId);
      if (!isSelectableNodeId(normalized) || isSelfNodeId(normalized)) return "";
      const active = mutedNodeIds.has(normalized);
      const title = active ? "Unmute this user in chat feed" : "Mute this user in chat feed";
      return `<button type="button" class="mute-toggle-btn ${{extraClass}}${{active ? " active" : ""}}" data-node-id="${{escAttr(normalized)}}" title="${{title}}" aria-label="${{title}}" aria-pressed="${{active ? "true" : "false"}}"><span class="mute-toggle-icon">${{active ? "🔇" : "🔊"}}</span></button>`;
    }}

    function renderSavedRailStatus() {{
      const count = Math.max(0, visibleFavoriteNodeIds().length);
      const explicitSelectedId = isSelectableNodeId(selectedNodeId) ? normalizeNodeId(selectedNodeId) : "";
      const selectedId = activeLayoutView === "saved"
        ? resolveSavedViewNodeId(latestState)
        : explicitSelectedId;
      const usingLocalFallback = activeLayoutView === "saved" && !explicitSelectedId && !!selectedId;
      const selectedName = selectedId
        ? (
            usingLocalFallback
              ? (resolveSavedViewNodeName(latestState, selectedId) || selectedId)
              : (resolveSelectedNodeName() || selectedId)
          )
        : "";
      const btn = document.querySelector('.teams-rail .rail-btn[data-view="saved"]');
      if (btn instanceof HTMLButtonElement) {{
        if (!btn.dataset.baseTitle) {{
          btn.dataset.baseTitle = btn.getAttribute("title") || "Node details and tagged nodes";
        }}
        btn.textContent = "Node";
        const baseTitle = btn.dataset.baseTitle || "Node details and tagged nodes";
        if (selectedId) {{
          btn.title = usingLocalFallback
            ? `${{baseTitle}}. Showing local node: ${{selectedName}}.`
            : `${{baseTitle}}. Selected: ${{selectedName}}.`;
        }} else {{
          btn.title = count > 0
            ? `${{baseTitle}}. ${{count}} tagged node${{count === 1 ? "" : "s"}}.`
            : `${{baseTitle}}. No tagged nodes yet.`;
        }}
        btn.setAttribute("aria-label", btn.title);
      }}

      const favMenuBtn = document.getElementById("favorite-menu-toggle-btn");
      if (favMenuBtn instanceof HTMLButtonElement) {{
        favMenuBtn.classList.toggle("has-saved", count > 0);
        favMenuBtn.classList.toggle("has-selected", !!selectedId);
        const title = selectedId
          ? (
              usingLocalFallback
                ? `Showing local node: ${{selectedName}}. Open node menu.`
                : `Selected node: ${{selectedName}}. Open node menu.`
            )
          : (count > 0
            ? `${{count}} tagged node${{count === 1 ? "" : "s"}}. Open node menu.`
            : "No node selected. Open node menu.");
        favMenuBtn.title = title;
        favMenuBtn.setAttribute("aria-label", title);
      }}
    }}
