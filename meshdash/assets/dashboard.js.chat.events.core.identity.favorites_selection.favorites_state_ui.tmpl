      if (!cleanPresetId || !nodeTagPresetsById.has(cleanPresetId)) return false;
      if (isMeshtasticFavoritePresetId(cleanPresetId) && shouldIgnoreMeshtasticFavoriteNodeId(cleanNodeId)) return false;
      const beforePresetId = normalizeNodeTagPresetId(nodeTagByNodeId.get(cleanNodeId), "");
      nodeTagByNodeId.set(cleanNodeId, cleanPresetId);
      syncFavoriteNodeIdsFromTags();
      if (!(options && options.persist === false)) {{
        persistFavoriteNodes();
      }}
      setActiveNodeTagPreset(cleanPresetId, true);
      syncMeshtasticFavoriteFromTagTransition(cleanNodeId, beforePresetId, cleanPresetId, options);
      return true;
