    function timelinePointUnix(
      point,
      bucketUnixKey = "bucket_unix",
      bucketTextKeys = ["bucket_time", "bucket_local"]
    ) {{
      const direct = Number(point && point[bucketUnixKey]);
      if (Number.isFinite(direct) && direct > 0) {{
        return Math.trunc(direct);
      }}
      let stamp = "";
      for (const key of bucketTextKeys) {{
        const value = String((point && point[key]) || "").trim();
        if (value) {{
          stamp = value;
          break;
        }}
      }}
      if (!stamp) return null;
      const normalized = stamp.includes("T")
        ? stamp
        : stamp.replace(" ", "T");
      const parsed = Date.parse(normalized);
      if (Number.isFinite(parsed)) {{
        return Math.trunc(parsed / 1000);
      }}
      return null;
    }}

    function formatTimelineLabel(unixTs, includeDate) {{
      if (!Number.isFinite(unixTs)) return "";
      const dt = new Date(unixTs * 1000);
      if (Number.isNaN(dt.getTime())) return "";
      const hh = String(dt.getHours()).padStart(2, "0");
      const mm = String(dt.getMinutes()).padStart(2, "0");
      const timeLabel = `${{hh}}:${{mm}}`;
      if (!includeDate) return timeLabel;
      const mon = String(dt.getMonth() + 1).padStart(2, "0");
      const day = String(dt.getDate()).padStart(2, "0");
      return `${{mon}}/${{day}} ${{timeLabel}}`;
    }}

    function timelineDayKey(unixTs) {{
      if (!Number.isFinite(unixTs)) return "";
      const dt = new Date(unixTs * 1000);
      if (Number.isNaN(dt.getTime())) return "";
      return `${{dt.getFullYear()}}-${{dt.getMonth() + 1}}-${{dt.getDate()}}`;
    }}

    function formatTimelineDayLabel(unixTs) {{
      if (!Number.isFinite(unixTs)) return "";
      const dt = new Date(unixTs * 1000);
      if (Number.isNaN(dt.getTime())) return "";
      return `${{dt.getMonth() + 1}}/${{dt.getDate()}}`;
    }}

    function buildLinearAxisTicks(minValue, maxValue, tickCount = 5) {{
      const lo = Number(minValue);
      const hi = Number(maxValue);
      if (!Number.isFinite(lo) || !Number.isFinite(hi)) return [];
      const count = Math.max(2, Math.min(7, Math.trunc(Number(tickCount) || 5)));
      if (Math.abs(hi - lo) < 1e-9) {{
        return [{{ ratio: 0, value: hi }}, {{ ratio: 1, value: lo }}];
      }}
      const ticks = [];
      for (let i = 0; i < count; i += 1) {{
        const ratio = i / Math.max(1, count - 1);
        const value = hi - ((hi - lo) * ratio);
        ticks.push({{ ratio, value }});
      }}
      return ticks;
    }}

    function setTimelineMessage(timelineId, message) {{
      const timeline = document.getElementById(String(timelineId || "").trim());
      if (!(timeline instanceof HTMLElement)) return;
      timeline.innerHTML = "";
      const text = String(message || "").trim();
      if (!text) return;
      const note = document.createElement("div");
      note.className = "signal-timeline-empty";
      note.textContent = text;
      timeline.appendChild(note);
    }}

    function renderTimeline(timelineId, rows, padLeft, padRight, width, resolveUnix) {{
      const timeline = document.getElementById(String(timelineId || "").trim());
      if (!(timeline instanceof HTMLElement)) return;

      const total = Array.isArray(rows) ? rows.length : 0;
      if (!total) {{
        setTimelineMessage(timelineId, "Timeline available when history points are present.");
        return;
      }}

      const pointUnixResolver = typeof resolveUnix === "function"
        ? resolveUnix
        : ((row) => timelinePointUnix(row));
      const timestamps = rows.map((row) => pointUnixResolver(row));
      const validPoints = [];
      for (let idx = 0; idx < timestamps.length; idx += 1) {{
        const unixTs = Number(timestamps[idx]);
        if (!Number.isFinite(unixTs)) continue;
        validPoints.push({{ idx, unixTs }});
      }}
      if (!validPoints.length) {{
        setTimelineMessage(timelineId, "Timeline unavailable (missing timestamps).");
        return;
      }}

      const axisStartPct = Math.max(0, Math.min(100, (padLeft / width) * 100));
      const axisEndPct = Math.max(axisStartPct, Math.min(100, ((width - padRight) / width) * 100));
      const axisWidthPct = axisEndPct - axisStartPct;
      const firstValid = validPoints[0];
      const lastValid = validPoints[validPoints.length - 1];
      const startUnix = firstValid.unixTs;
      const endUnix = lastValid.unixTs;
      const spanCrossesDay = Math.floor(startUnix / 86400) !== Math.floor(endUnix / 86400);
      const spanSeconds = Math.max(1, endUnix - startUnix);

      const unixToLeftPct = (unixTs) => {{
        const ratio = Math.max(0, Math.min(1, (Number(unixTs) - startUnix) / spanSeconds));
        return axisStartPct + (ratio * axisWidthPct);
      }};

      timeline.innerHTML = "";
      const track = document.createElement("div");
      track.className = "signal-timeline-track";
      track.style.left = `${{axisStartPct.toFixed(3)}}%`;
      track.style.right = `${{(100 - axisEndPct).toFixed(3)}}%`;
      timeline.appendChild(track);

      const dailyMode = spanSeconds >= (36 * 3600);
      const majorStepCandidates = dailyMode
        ? [86400]
        : [300, 600, 900, 1800, 3600, 7200, 10800, 21600, 43200, 86400];
      const majorLabelLimit = dailyMode ? 8 : 9;
      let majorStep = majorStepCandidates[majorStepCandidates.length - 1];
      for (let i = 0; i < majorStepCandidates.length; i += 1) {{
        const step = majorStepCandidates[i];
        if (((spanSeconds / step) + 1) <= majorLabelLimit) {{
          majorStep = step;
          break;
        }}
      }}

      let minorStep = dailyMode
        ? 21600
        : (majorStep >= 86400
          ? 21600
          : (majorStep >= 21600 ? 3600 : (majorStep >= 3600 ? 900 : Math.max(60, Math.floor(majorStep / 4)))));
      const maxMinorTicks = 120;
      while ((spanSeconds / minorStep) > maxMinorTicks) {{
        minorStep *= 2;
      }}

      const majorEpsilon = Math.max(1, Math.floor(majorStep / 40));
      const nearMajorTick = (unixTs) => {{
        const rem = ((Number(unixTs) % majorStep) + majorStep) % majorStep;
        return rem <= majorEpsilon || (majorStep - rem) <= majorEpsilon;
      }};

      const renderTick = (unixTs, options = {{}}) => {{
        const opts = options && typeof options === "object" ? options : {{}};
        const leftPct = unixToLeftPct(unixTs);
        const mark = document.createElement("div");
        mark.className = "signal-timeline-mark";
        if (opts.minor) mark.classList.add("signal-timeline-mark-minor");
        if (opts.major) mark.classList.add("signal-timeline-mark-major");
        if (opts.edgeStart) mark.classList.add("edge-start");
        if (opts.edgeEnd) mark.classList.add("edge-end");
        mark.style.left = `${{leftPct.toFixed(3)}}%`;

        const tick = document.createElement("div");
        tick.className = "signal-timeline-tick";
        if (opts.minor) tick.classList.add("signal-timeline-tick-minor");
        if (opts.major) tick.classList.add("signal-timeline-tick-major");
        mark.appendChild(tick);

        const labelText = String(opts.label || "").trim();
        if (labelText) {{
          const label = document.createElement("div");
          label.className = "signal-timeline-label";
          if (opts.major) label.classList.add("signal-timeline-label-major");
          label.textContent = labelText;
          mark.appendChild(label);
        }}
        if (Number.isFinite(Number(unixTs))) {{
          mark.title = new Date(Number(unixTs) * 1000).toLocaleString();
        }}
        timeline.appendChild(mark);
      }};

      const firstMinor = Math.ceil(startUnix / minorStep) * minorStep;
      for (let unixTs = firstMinor; unixTs <= endUnix; unixTs += minorStep) {{
        if (nearMajorTick(unixTs)) continue;
        renderTick(unixTs, {{ minor: true }});
      }}

      const majorTicks = [];
      const addMajorTick = (unixTs) => {{
        const value = Number(unixTs);
        if (!Number.isFinite(value)) return;
        for (let i = 0; i < majorTicks.length; i += 1) {{
          if (Math.abs(majorTicks[i] - value) <= majorEpsilon) return;
        }}
        majorTicks.push(value);
      }};
      const firstMajor = Math.ceil(startUnix / majorStep) * majorStep;
      for (let unixTs = firstMajor; unixTs <= endUnix; unixTs += majorStep) {{
        addMajorTick(unixTs);
      }}
      addMajorTick(startUnix);
      addMajorTick(endUnix);
      majorTicks.sort((a, b) => a - b);
      const renderedDayKeys = new Set();

      for (let i = 0; i < majorTicks.length; i += 1) {{
        const unixTs = majorTicks[i];
        const edgeStart = Math.abs(unixTs - startUnix) <= majorEpsilon;
        const edgeEnd = Math.abs(unixTs - endUnix) <= majorEpsilon;
        let label = "";
        if (dailyMode) {{
          const dayKey = timelineDayKey(unixTs);
          if (dayKey && !renderedDayKeys.has(dayKey)) {{
            renderedDayKeys.add(dayKey);
            label = formatTimelineDayLabel(unixTs);
          }}
        }} else if (edgeStart || edgeEnd) {{
          label = formatTimelineLabel(unixTs, spanCrossesDay || spanSeconds >= (12 * 3600));
        }} else {{
          const dt = new Date(unixTs * 1000);
          if (
            spanCrossesDay
            && majorStep >= 21600
            && dt.getHours() === 0
            && dt.getMinutes() === 0
          ) {{
            label = formatTimelineDayLabel(unixTs);
          }} else {{
            label = formatTimelineLabel(unixTs, false);
          }}
        }}
        renderTick(unixTs, {{
          major: true,
          edgeStart,
          edgeEnd,
          label,
        }});
      }}
    }}

