    function readThemeCustomBackgroundImageFile(file) {{
      return new Promise((resolve, reject) => {{
        if (!(file instanceof File)) {{
          reject(new Error("No image selected"));
          return;
        }}
        if (!themeCustomBackgroundImageMimeTypes.has(String(file.type || "").toLowerCase())) {{
          reject(new Error("Unsupported image type"));
          return;
        }}
        const estimatedDataLength = Math.ceil(Number(file.size || 0) * 1.38) + 64;
        if (estimatedDataLength > themeCustomBackgroundImageDataMaxLength) {{
          reject(new Error("Image is too large"));
          return;
        }}
        if (typeof FileReader !== "function") {{
          reject(new Error("Image picker is unavailable"));
          return;
        }}
        const reader = new FileReader();
        reader.addEventListener("load", () => resolve(String(reader.result || "")));
        reader.addEventListener("error", () => reject(new Error("Image could not be read")));
        reader.readAsDataURL(file);
      }});
    }}

