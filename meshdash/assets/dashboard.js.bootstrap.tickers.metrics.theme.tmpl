        }});
      }}

      const backgroundImageFileInput = document.getElementById("theme-custom-background-image-file");
      if (backgroundImageFileInput instanceof HTMLInputElement && backgroundImageFileInput.dataset.bound !== "1") {{
        backgroundImageFileInput.dataset.bound = "1";
        backgroundImageFileInput.addEventListener("change", async () => {{
          const file = backgroundImageFileInput.files && backgroundImageFileInput.files.length
            ? backgroundImageFileInput.files[0]
            : null;
          if (!file) return;
          backgroundImageFileInput.disabled = true;
          try {{
            setThemeCustomBackgroundImageStatus("Loading image");
            const imageData = normalizeThemeCustomBackgroundImageData(
              await readThemeCustomBackgroundImageFile(file)
            );
            if (!imageData) {{
              throw new Error("Unsupported image data");
            }}
            beginThemeCustomEditFromSelectedPreset();
            themeCustomBackgroundType = "image";
            themeCustomBackgroundImageData = imageData;
            syncThemeCustomControls();
            applyDashboardBackground(currentThemeCustomSettings());
            await persistThemeCustomControls();
          }} catch (err) {{
            const msg = err instanceof Error ? err.message : String(err || "Image could not be read");
            syncThemeCustomControls();
            setThemeCustomBackgroundImageStatus(msg);
            appendConsoleLine(`theme-background-image|${{Date.now()}}|${{msg}}`, `[theme background] ${{msg}}`);
          }} finally {{
            backgroundImageFileInput.value = "";
            backgroundImageFileInput.disabled = false;
          }}
        }});
      }}

      const backgroundImageClearBtn = document.getElementById("theme-custom-background-image-clear");
      if (backgroundImageClearBtn instanceof HTMLButtonElement && backgroundImageClearBtn.dataset.bound !== "1") {{
        backgroundImageClearBtn.dataset.bound = "1";
        backgroundImageClearBtn.addEventListener("click", async () => {{
          beginThemeCustomEditFromSelectedPreset();
          themeCustomBackgroundType = "image";
          themeCustomBackgroundImageData = "";
          syncThemeCustomControls();
          applyDashboardBackground(currentThemeCustomSettings());
          await persistThemeCustomControls();
        }});
      }}

      const particlesEnabledInput = document.getElementById("theme-custom-particles-enabled");
      if (particlesEnabledInput instanceof HTMLInputElement && particlesEnabledInput.dataset.bound !== "1") {{
        particlesEnabledInput.dataset.bound = "1";
        particlesEnabledInput.addEventListener("change", async () => {{
          beginThemeCustomEditFromSelectedPreset();
          themeCustomParticlesEnabled = !!particlesEnabledInput.checked;
          syncThemeCustomControls();
          applyDashboardBackground(currentThemeCustomSettings());
          await persistThemeCustomControls();
        }});
      }}

      const particlesColorInput = document.getElementById("theme-custom-particles-color");
      if (particlesColorInput instanceof HTMLInputElement && particlesColorInput.dataset.bound !== "1") {{
        if (typeof attachDashboardColorPicker === "function") {{
          attachDashboardColorPicker(particlesColorInput, {{
            fallback: themeCustomLineContrastColor || "#548dff",
            label: "Particle color",
            buttonLabel: "Pick particle color",
          }});
        }}
        particlesColorInput.dataset.bound = "1";
        particlesColorInput.addEventListener("input", () => {{
          if (!themeCustomColorInputHasCompleteHex(particlesColorInput)) return;
          beginThemeCustomEditFromSelectedPreset();
          themeCustomParticlesColor = normalizeThemeCustomParticlesColor(
            particlesColorInput.value,
            themeCustomLineContrastColor
          );
          syncThemeCustomControls();
          queueLiveThemePreview();
        }});
        particlesColorInput.addEventListener("change", async () => {{
          if (!themeCustomColorInputHasCompleteHex(particlesColorInput)) {{
            syncThemeCustomControls();
            return;
          }}
          beginThemeCustomEditFromSelectedPreset();
          themeCustomParticlesColor = normalizeThemeCustomParticlesColor(
            particlesColorInput.value,
            themeCustomLineContrastColor
          );
          syncThemeCustomControls();
          await persistThemeCustomControls();
        }});
      }}

      const particlesLinkColorInput = document.getElementById("theme-custom-particles-link-color");
      if (particlesLinkColorInput instanceof HTMLInputElement && particlesLinkColorInput.dataset.bound !== "1") {{
        if (typeof attachDashboardColorPicker === "function") {{
          attachDashboardColorPicker(particlesLinkColorInput, {{
            fallback: themeCustomLineContrastColor || themeCustomParticlesColor || "#4f55ff",
            label: "Line or link color",
            buttonLabel: "Pick line or link color",
          }});
        }}
        const setActiveBackgroundLinkColor = () => {{
          const nextColor = normalizeThemeCustomParticlesColor(
            particlesLinkColorInput.value,
            themeCustomLineContrastColor || themeCustomParticlesColor
          );
          if (normalizeThemeCustomBackgroundType(themeCustomBackgroundType) === "livemap") {{
            themeCustomLivemapLinkColor = nextColor;
          }} else {{
            themeCustomParticlesLinkColor = nextColor;
          }}
        }};
        particlesLinkColorInput.dataset.bound = "1";
        particlesLinkColorInput.addEventListener("input", () => {{
          if (!themeCustomColorInputHasCompleteHex(particlesLinkColorInput)) return;
          beginThemeCustomEditFromSelectedPreset();
          setActiveBackgroundLinkColor();
          syncThemeCustomControls();
          queueLiveThemePreview();
        }});
        particlesLinkColorInput.addEventListener("change", async () => {{
          if (!themeCustomColorInputHasCompleteHex(particlesLinkColorInput)) {{
            syncThemeCustomControls();
            return;
          }}
          beginThemeCustomEditFromSelectedPreset();
          setActiveBackgroundLinkColor();
          syncThemeCustomControls();
          await persistThemeCustomControls();
        }});
      }}

      bindParticleRangeInput("theme-custom-particles-count", {{
        normalize: normalizeThemeCustomParticlesCount,
        setValue: (value) => {{
          themeCustomParticlesCount = value;
        }},
      }});
      bindParticleRangeInput("theme-custom-particles-speed", {{
        normalize: normalizeThemeCustomParticlesSpeed,
        setValue: (value) => {{
          themeCustomParticlesSpeed = value;
        }},
      }});
      bindParticleRangeInput("theme-custom-particles-size", {{
        normalize: normalizeThemeCustomParticlesSize,
        setValue: (value) => {{
          themeCustomParticlesSize = value;
        }},
      }});
      bindParticleRangeInput("theme-custom-particles-opacity", {{
        normalize: normalizeThemeCustomParticlesOpacity,
        setValue: (value) => {{
          themeCustomParticlesOpacity = value;
        }},
      }});

      const particlesLinksInput = document.getElementById("theme-custom-particles-links");
      if (particlesLinksInput instanceof HTMLInputElement && particlesLinksInput.dataset.bound !== "1") {{
        particlesLinksInput.dataset.bound = "1";
        particlesLinksInput.addEventListener("change", async () => {{
          beginThemeCustomEditFromSelectedPreset();
          themeCustomParticlesLinks = !!particlesLinksInput.checked;
          syncThemeCustomControls();
          applyDashboardBackground(currentThemeCustomSettings());
          await persistThemeCustomControls();
        }});
      }}

      for (const input of document.querySelectorAll("[data-livemap-layer]")) {{
        if (!(input instanceof HTMLInputElement) || input.dataset.bound === "1") continue;
        input.dataset.bound = "1";
        input.addEventListener("change", async () => {{
          const layerKey = String(input.dataset.livemapLayer || "").trim();
          if (!Object.prototype.hasOwnProperty.call(themeCustomLivemapLayerDefaults, layerKey)) {{
            syncThemeCustomControls();
            return;
          }}
          beginThemeCustomEditFromSelectedPreset();
          const nextLayers = normalizeThemeCustomLivemapLayers(themeCustomLivemapLayers);
          nextLayers[layerKey] = !!input.checked;
          themeCustomLivemapLayers = nextLayers;
          syncThemeCustomControls();
          applyDashboardBackground(currentThemeCustomSettings());
          await persistThemeCustomControls();
        }});
      }}

      const depthInput = document.getElementById("theme-custom-color-depth");
      if (depthInput instanceof HTMLInputElement && depthInput.dataset.bound !== "1") {{
        depthInput.dataset.bound = "1";
        depthInput.addEventListener("input", () => {{
          beginThemeCustomEditFromSelectedPreset();
          themeCustomColorDepth = normalizeThemeCustomColorDepth(depthInput.value);
          syncThemeCustomControls();
          queueLiveThemePreview();
        }});
        depthInput.addEventListener("change", async () => {{
          beginThemeCustomEditFromSelectedPreset();
          themeCustomColorDepth = normalizeThemeCustomColorDepth(depthInput.value);
          syncThemeCustomControls();
          await persistThemeCustomControls();
        }});
      }}

      const foregroundTransparencyInput = document.getElementById("theme-custom-foreground-transparency");
      if (foregroundTransparencyInput instanceof HTMLInputElement && foregroundTransparencyInput.dataset.bound !== "1") {{
        foregroundTransparencyInput.dataset.bound = "1";
        foregroundTransparencyInput.addEventListener("input", () => {{
          beginThemeCustomEditFromSelectedPreset();
          themeCustomForegroundTransparency = normalizeThemeCustomForegroundTransparency(foregroundTransparencyInput.value);
          syncThemeCustomControls();
          queueLiveThemePreview();
        }});
        foregroundTransparencyInput.addEventListener("change", async () => {{
          beginThemeCustomEditFromSelectedPreset();
          themeCustomForegroundTransparency = normalizeThemeCustomForegroundTransparency(foregroundTransparencyInput.value);
          syncThemeCustomControls();
          await persistThemeCustomControls();
        }});
      }}

      const foregroundBlurInput = document.getElementById("theme-custom-foreground-blur");
      if (foregroundBlurInput instanceof HTMLInputElement && foregroundBlurInput.dataset.bound !== "1") {{
        foregroundBlurInput.dataset.bound = "1";
        foregroundBlurInput.addEventListener("input", () => {{
          beginThemeCustomEditFromSelectedPreset();
          themeCustomForegroundBlur = normalizeThemeCustomForegroundBlur(foregroundBlurInput.value);
          syncThemeCustomControls();
          queueLiveThemePreview();
        }});
        foregroundBlurInput.addEventListener("change", async () => {{
          beginThemeCustomEditFromSelectedPreset();
          themeCustomForegroundBlur = normalizeThemeCustomForegroundBlur(foregroundBlurInput.value);
          syncThemeCustomControls();
          await persistThemeCustomControls();
        }});
      }}

      syncThemeCustomControls();
    }}
