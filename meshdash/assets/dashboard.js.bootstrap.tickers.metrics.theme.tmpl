          ),
        }},
      }};
    }}

    async function saveThemeSettings(options = null, requestOptions = null) {{
      const opts = requestOptions && typeof requestOptions === "object" ? requestOptions : {{}};
      const payloadBody = buildThemeSettingsSavePayload(options);
      const requestSerial = ++themeSettingsRequestSerial;
      let abortController = null;
      if (typeof AbortController === "function") {{
        if (themeSettingsAbortController instanceof AbortController) {{
          themeSettingsAbortController.abort();
        }}
        abortController = new AbortController();
        themeSettingsAbortController = abortController;
      }}
      try {{
        const requestInit = {{
          method: "POST",
          headers: {{ "Content-Type": "application/json" }},
          body: JSON.stringify(payloadBody),
        }};
        if (abortController instanceof AbortController) {{
          requestInit.signal = abortController.signal;
        }}
        const resp = await fetch(themeSettingsEndpoint, requestInit);
        const payload = await resp.json().catch(() => ({{ ok: false, error: `API ${{resp.status}}` }}));
        if (!resp.ok || !payload || payload.ok === false) {{
          const message = payload && payload.error ? payload.error : `API ${{resp.status}}`;
          throw new Error(String(message));
        }}
        if (requestSerial < themeSettingsAppliedSerial) {{
          return false;
        }}
        themeSettingsAppliedSerial = requestSerial;
        return applyThemeSettingsPayload(payload, {{
          refreshControls: opts.refreshControls !== false,
        }});
      }} catch (err) {{
        if (abortController instanceof AbortController && abortController.signal.aborted) {{
          return false;
        }}
        const msg = err instanceof Error ? err.message : String(err || "unknown error");
        if (opts.logErrors !== false) {{
          appendConsoleLine(`theme-settings-save|${{Date.now()}}|${{msg}}`, `[theme settings] save failed: ${{msg}}`);
        }}
        if (opts.refreshControls !== false) {{
          updateThemePresetControl();
        }} else {{
          syncThemePresetControlValue();
          syncThemeCustomControls();
        }}
      }} finally {{
        if (themeSettingsAbortController === abortController) {{
          themeSettingsAbortController = null;
        }}
      }}
      return false;
    }}

    function queueLiveThemePreview() {{
      clearThemeSettingsPreviewTimer();
      applyDashboardBackground(currentThemeCustomSettings());
      themeSettingsSaveDebounceTimer = window.setTimeout(() => {{
        themeSettingsSaveDebounceTimer = null;
        void saveThemeSettings(
          buildCurrentThemeCustomOptions({{ previewOnly: true }}),
          {{
            refreshControls: false,
            logErrors: false,
          }},
        );
      }}, 110);
    }}

