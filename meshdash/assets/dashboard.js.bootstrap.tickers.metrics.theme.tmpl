    function applyThemeSettingsPayload(payload, options = null) {{
      if (!payload || typeof payload !== "object" || Array.isArray(payload)) {{
        return false;
      }}
      const opts = options && typeof options === "object" ? options : {{}};
      const normalizedCatalog = normalizeThemePresetCatalog(payload.presets);
      const normalizedCustomTheme = normalizeThemeCustomSettings(payload.custom_theme);
      themePresetCatalog = normalizedCatalog;
      themePresetCustomSettingsCatalog = normalizeThemePresetCustomSettingsCatalog(payload.preset_custom_settings);
      themeManagedPresetNames = normalizeThemeManagedPresetNames(payload.custom_preset_names);
      themePresetSelected = normalizeThemePresetName(payload.selected_preset, normalizedCatalog);
      applyThemeCustomSettings(normalizedCustomTheme);
      if (opts.refreshControls === false) {{
        syncThemePresetControlValue();
        syncThemeCustomControls();
        syncThemePresetActionButtons();
      }} else {{
        updateThemePresetControl(payload.available_presets);
      }}
      applyThemePreference(themePreference, false);
      applyDashboardBackground(themeEditableSettingsForPreset(themePresetSelected));
      return true;
    }}

    async function loadThemeSettingsFromServer(logErrors = true) {{
      try {{
        const resp = await fetch(themeSettingsEndpoint, {{ cache: "no-store" }});
        if (!resp.ok) {{
          throw new Error(`API ${{resp.status}}`);
        }}
        const payload = await resp.json();
        if (!payload || payload.ok === false) {{
          const message = payload && payload.error ? payload.error : "Invalid theme settings payload";
          throw new Error(String(message));
        }}
        return applyThemeSettingsPayload(payload);
      }} catch (err) {{
        if (logErrors) {{
          const msg = err instanceof Error ? err.message : String(err || "unknown error");
          appendConsoleLine(`theme-settings-load|${{Date.now()}}|${{msg}}`, `[theme settings] load failed: ${{msg}}`);
        }}
      }}
      return false;
    }}

    function buildThemeSettingsSavePayload(options = null) {{
      const opts = options && typeof options === "object" ? options : {{}};
      const cleanPreset = String(
        opts.presetName == null ? themePresetSelected : opts.presetName
      ).trim();
      const normalizedBaseColor = normalizeThemeCustomBaseColor(
        opts.baseColor == null ? themeCustomBaseColor : opts.baseColor
      );
      const normalizedLineColor = normalizeThemeCustomLineColor(
        opts.lineColor == null ? themeCustomLineColor : opts.lineColor,
        normalizedBaseColor
      );
      const normalizedLineContrastColor = normalizeThemeCustomLineContrastColor(
        opts.lineContrastColor == null ? themeCustomLineContrastColor : opts.lineContrastColor
      );
      return {{
        preset_name: cleanPreset || "default",
        preview_only: Boolean(opts.previewOnly),
        custom_theme: {{
          base_color: normalizedBaseColor,
          line_color: normalizedLineColor,
          line_contrast_color: normalizedLineContrastColor,
          color_depth: normalizeThemeCustomColorDepth(
            opts.colorDepth == null ? themeCustomColorDepth : opts.colorDepth
          ),
          foreground_transparency: normalizeThemeCustomForegroundTransparency(
            opts.foregroundTransparency == null
              ? themeCustomForegroundTransparency
              : opts.foregroundTransparency
          ),
          foreground_blur: normalizeThemeCustomForegroundBlur(
            opts.foregroundBlur == null
              ? themeCustomForegroundBlur
              : opts.foregroundBlur
          ),
          text_font: normalizeThemeCustomTextFont(
            opts.textFont == null ? themeCustomTextFont : opts.textFont
          ),
          gradient_primary_start_color: normalizeThemeCustomGradientColor(
            opts.gradientPrimaryStartColor == null
              ? themeCustomGradientPrimaryStartColor
              : opts.gradientPrimaryStartColor,
            normalizedBaseColor
          ),
          gradient_primary_end_color: normalizeThemeCustomGradientColor(
            opts.gradientPrimaryEndColor == null ? themeCustomGradientPrimaryEndColor : opts.gradientPrimaryEndColor,
            "#060d1f"
          ),
          gradient_primary_type: normalizeThemeCustomGradientType(
            opts.gradientPrimaryType == null ? themeCustomGradientPrimaryType : opts.gradientPrimaryType
          ),
          gradient_primary_direction: normalizeThemeCustomGradientDirection(
            opts.gradientPrimaryDirection == null ? themeCustomGradientPrimaryDirection : opts.gradientPrimaryDirection
          ),
          background_type: normalizeThemeCustomBackgroundType(
            opts.backgroundType == null ? themeCustomBackgroundType : opts.backgroundType
          ),
          background_image_data: normalizeThemeCustomBackgroundImageData(
            opts.backgroundImageData == null ? themeCustomBackgroundImageData : opts.backgroundImageData
          ),
          background_image_layout: normalizeThemeCustomBackgroundImageLayout(
            opts.backgroundImageLayout == null ? themeCustomBackgroundImageLayout : opts.backgroundImageLayout
          ),
          background_image_darken: normalizeThemeCustomBackgroundImageDarken(
            opts.backgroundImageDarken == null ? themeCustomBackgroundImageDarken : opts.backgroundImageDarken
          ),
          particles_enabled: normalizeThemeCustomParticlesEnabled(
            opts.particlesEnabled == null ? themeCustomParticlesEnabled : opts.particlesEnabled
          ),
          particles_color: normalizeThemeCustomParticlesColor(
            opts.particlesColor == null ? themeCustomParticlesColor : opts.particlesColor,
            normalizedLineContrastColor
          ),
          particles_link_color: normalizeThemeCustomParticlesColor(
            opts.particlesLinkColor == null ? themeCustomParticlesLinkColor : opts.particlesLinkColor,
            normalizedLineContrastColor
          ),
          livemap_link_color: normalizeThemeCustomParticlesColor(
            opts.livemapLinkColor == null ? themeCustomLivemapLinkColor : opts.livemapLinkColor,
            opts.particlesLinkColor == null ? themeCustomParticlesLinkColor : opts.particlesLinkColor
          ),
          particles_count: normalizeThemeCustomParticlesCount(
            opts.particlesCount == null ? themeCustomParticlesCount : opts.particlesCount
          ),
          particles_speed: normalizeThemeCustomParticlesSpeed(
