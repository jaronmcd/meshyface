      if (foregroundTransparencyValue instanceof HTMLOutputElement || foregroundTransparencyValue instanceof HTMLElement) {{
        foregroundTransparencyValue.textContent = `${{normalizeThemeCustomForegroundTransparency(displayForegroundTransparency)}}%`;
      }}
      const foregroundBlurInput = document.getElementById("theme-custom-foreground-blur");
      if (foregroundBlurInput instanceof HTMLInputElement) {{
        foregroundBlurInput.value = String(
