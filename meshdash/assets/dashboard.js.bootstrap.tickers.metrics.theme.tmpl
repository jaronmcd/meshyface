      resetDashboardBackgroundActiveState(host);
      destroyDashboardParticles();
    }}

    function dashboardImageHost() {{
      const host = document.getElementById("dashboard-image-bg");
      return host instanceof HTMLElement ? host : null;
    }}

    function dashboardBackgroundHostForType(type) {{
      if (type === "image") {{
        return dashboardImageHost();
      }}
      if (type === "particles") {{
        return dashboardParticlesHost();
      }}
      if (type === "livemap") {{
        const host = document.getElementById("dashboard-livemap-bg");
        return host instanceof HTMLElement ? host : null;
      }}
      return null;
    }}

    function dashboardBackgroundBodyClass(type) {{
      if (type === "image") return "dashboard-image-enabled";
      if (type === "particles") return "dashboard-particles-enabled";
      if (type === "livemap") return "dashboard-livemap-enabled";
      return "";
    }}

    function deactivateDashboardBackgroundType(type) {{
      const cleanType = String(type || "");
      if (!cleanType || cleanType === dashboardBackgroundActiveType) {{
        return;
      }}
      const bodyClass = dashboardBackgroundBodyClass(cleanType);
      const handler = dashboardBackgroundHandlers[cleanType];
      if (!handler || typeof handler.disable !== "function") {{
        return;
      }}
      if (!document.body || !bodyClass || !document.body.classList.contains(bodyClass)) {{
        handler.disable();
        return;
      }}
      const host = dashboardBackgroundHostForType(cleanType);
      if (host) {{
        host.classList.remove("dashboard-background-active");
      }}
      handler.disable();
    }}

    function deactivateInactiveDashboardBackgrounds(activeType) {{
      for (const type of Object.keys(dashboardBackgroundHandlers)) {{
        if (type !== activeType) {{
          deactivateDashboardBackgroundType(type);
        }}
      }}
    }}

    function disableAllDashboardBackgrounds() {{
      dashboardBackgroundActiveType = "";
      for (const [type, handler] of Object.entries(dashboardBackgroundHandlers)) {{
        if (handler && typeof handler.disable === "function") {{
          handler.disable();
        }}
      }}
    }}

    function markDashboardBackgroundActive(host, signature = "") {{
      if (!(host instanceof HTMLElement)) return;
      const cleanSignature = String(signature || "");
      host.dataset.dashboardBackgroundSignature = cleanSignature;
      host.classList.add("dashboard-background-ready");
      host.classList.add("dashboard-background-active");
    }}

    function resetDashboardBackgroundActiveState(host) {{
      if (!(host instanceof HTMLElement)) return;
      host.classList.remove("dashboard-background-ready");
      host.classList.remove("dashboard-background-active");
      delete host.dataset.dashboardBackgroundSignature;
    }}

    function dashboardImageLayoutStyles(layout) {{
      const clean = normalizeThemeCustomBackgroundImageLayout(layout);
      if (clean === "contain") {{
        return {{ size: "contain", repeat: "no-repeat", position: "center center" }};
      }}
      if (clean === "stretch") {{
        return {{ size: "100% 100%", repeat: "no-repeat", position: "center center" }};
      }}
      if (clean === "center") {{
        return {{ size: "auto", repeat: "no-repeat", position: "center center" }};
      }}
      if (clean === "tile") {{
        return {{ size: "auto", repeat: "repeat", position: "center center" }};
      }}
      return {{ size: "cover", repeat: "no-repeat", position: "center center" }};
    }}

    function resetDashboardImageRevealState(host = null) {{
      dashboardImageBackgroundLoadSerial += 1;
      const imageHost = host instanceof HTMLElement ? host : dashboardImageHost();
      if (imageHost) {{
        imageHost.classList.remove("dashboard-image-background-loaded");
      }}
    }}

    function revealDashboardImageBackground(host, signature, serial) {{
      if (!(host instanceof HTMLElement)) return;
      if (serial !== dashboardImageBackgroundLoadSerial) return;
      if (dashboardBackgroundActiveType !== "image") return;
      if (!document.body || !document.body.classList.contains("dashboard-image-enabled")) return;
      if (host.dataset.dashboardBackgroundSignature !== signature) return;
      window.requestAnimationFrame(() => {{
        if (serial !== dashboardImageBackgroundLoadSerial) return;
        if (dashboardBackgroundActiveType !== "image") return;
        if (!document.body || !document.body.classList.contains("dashboard-image-enabled")) return;
        if (host.dataset.dashboardBackgroundSignature !== signature) return;
        host.classList.add("dashboard-image-background-loaded");
      }});
    }}

    function preloadDashboardImageBackground(imageData, host, signature, serial) {{
      const preload = new Image();
      const reveal = () => revealDashboardImageBackground(host, signature, serial);
      preload.onload = reveal;
      preload.onerror = reveal;
      preload.src = imageData;
      if (preload.complete) {{
        reveal();
      }}
    }}

    function disableDashboardImage() {{
      if (dashboardBackgroundActiveType === "image") {{
        dashboardBackgroundActiveType = "";
      }}
      const host = dashboardImageHost();
      if (document.body) {{
        document.body.classList.remove("dashboard-image-enabled");
      }}
      if (!host) return;
      resetDashboardImageRevealState(host);
      resetDashboardBackgroundActiveState(host);
      host.style.removeProperty("background-image");
      host.style.removeProperty("background-size");
      host.style.removeProperty("background-repeat");
      host.style.removeProperty("background-position");
      host.style.removeProperty("--dashboard-image-darken");
    }}

    function applyDashboardImage(rawSettings = null) {{
      const host = dashboardImageHost();
      if (!host || !document.body) {{
        return false;
      }}
      const settings = normalizeThemeCustomSettings(rawSettings || currentThemeCustomSettings());
      const imageData = normalizeThemeCustomBackgroundImageData(settings.background_image_data);
      if (!imageData) {{
        disableDashboardImage();
        return false;
      }}
      const layoutKey = normalizeThemeCustomBackgroundImageLayout(settings.background_image_layout);
      const layout = dashboardImageLayoutStyles(settings.background_image_layout);
      const signature = `image:${{layoutKey}}:${{imageData}}`;
      const preserveLoadedImage =
        host.dataset.dashboardBackgroundSignature === signature &&
        host.classList.contains("dashboard-image-background-loaded");
      if (!preserveLoadedImage) {{
        resetDashboardImageRevealState(host);
      }}
      host.style.backgroundImage = `url("${{imageData}}")`;
      host.style.backgroundSize = layout.size;
      host.style.backgroundRepeat = layout.repeat;
      host.style.backgroundPosition = layout.position;
      host.style.setProperty(
        "--dashboard-image-darken",
        String(normalizeThemeCustomBackgroundImageDarken(settings.background_image_darken) / 100)
      );
      document.body.classList.add("dashboard-image-enabled");
      dashboardBackgroundActiveType = "image";
      markDashboardBackgroundActive(host, signature);
      if (preserveLoadedImage) {{
        host.classList.add("dashboard-image-background-loaded");
      }} else {{
        preloadDashboardImageBackground(imageData, host, signature, dashboardImageBackgroundLoadSerial);
      }}
      return true;
    }}

    function buildDashboardParticlesConfig(settings) {{
      const color = normalizeThemeCustomParticlesColor(settings.particles_color);
      const linkColor = normalizeThemeCustomParticlesColor(settings.particles_link_color, color);
      const opacity = normalizeThemeCustomParticlesOpacity(settings.particles_opacity) / 100;
      const count = normalizeThemeCustomParticlesCount(settings.particles_count);
      const linksEnabled = normalizeThemeCustomParticlesEnabled(settings.particles_links, true) && count > 0;
      return {{
        particles: {{
          number: {{
            value: count,
            density: {{
              enable: true,
              value_area: 900,
            }},
          }},
          color: {{
            value: color,
          }},
          shape: {{
            type: "circle",
            stroke: {{
              width: 0,
              color: color,
            }},
          }},
          opacity: {{
            value: opacity,
            random: false,
            anim: {{
              enable: false,
              speed: 1,
              opacity_min: 0.1,
              sync: false,
            }},
          }},
          size: {{
            value: normalizeThemeCustomParticlesSize(settings.particles_size),
            random: true,
            anim: {{
              enable: false,
              speed: 4,
              size_min: 0.3,
              sync: false,
            }},
          }},
          line_linked: {{
            enable: linksEnabled,
            distance: 145,
            color: linkColor,
            opacity: Math.min(0.72, Math.max(0.08, opacity * 0.74)),
            width: 1,
          }},
          move: {{
            enable: true,
            speed: normalizeThemeCustomParticlesSpeed(settings.particles_speed),
            direction: "none",
            random: false,
            straight: false,
            out_mode: "out",
            bounce: false,
            attract: {{
              enable: false,
              rotateX: 600,
              rotateY: 1200,
            }},
          }},
        }},
        interactivity: {{
          detect_on: "canvas",
          events: {{
            onhover: {{
              enable: false,
              mode: "grab",
            }},
            onclick: {{
              enable: false,
              mode: "push",
            }},
            resize: true,
          }},
        }},
        retina_detect: true,
      }};
    }}

    function applyDashboardParticles(rawSettings = null) {{
      const host = dashboardParticlesHost();
      if (!host || !document.body) {{
        return false;
      }}
      const settings = normalizeThemeCustomSettings(rawSettings || currentThemeCustomSettings());
      const enabled = normalizeThemeCustomParticlesEnabled(settings.particles_enabled);
      const opacity = normalizeThemeCustomParticlesOpacity(settings.particles_opacity);
      host.style.setProperty("--dashboard-particles-opacity", String(opacity / 100));
      if (!enabled) {{
        document.body.classList.remove("dashboard-particles-enabled");
        if (dashboardBackgroundActiveType === "particles") {{
          dashboardBackgroundActiveType = "";
        }}
        resetDashboardParticlesRevealState(host);
        resetDashboardBackgroundActiveState(host);
        destroyDashboardParticles();
        return false;
      }}
      if (typeof window.particlesJS !== "function") {{
        document.body.classList.remove("dashboard-particles-enabled");
        if (dashboardBackgroundActiveType === "particles") {{
          dashboardBackgroundActiveType = "";
        }}
        resetDashboardParticlesRevealState(host);
        resetDashboardBackgroundActiveState(host);
        removeDashboardParticlesCanvas();
        return false;
      }}
      const signature = JSON.stringify({{
        color: settings.particles_color,
        linkColor: settings.particles_link_color,
        count: settings.particles_count,
        speed: settings.particles_speed,
        size: settings.particles_size,
        opacity: settings.particles_opacity,
        links: settings.particles_links,
      }});
      const backgroundSignature = `particles:${{signature}}`;
      if (dashboardParticlesSignature === signature && host.querySelector("canvas")) {{
        const preserveLoadedParticles =
          host.dataset.dashboardBackgroundSignature === backgroundSignature &&
          host.classList.contains("dashboard-particles-background-loaded");
        document.body.classList.add("dashboard-particles-enabled");
        dashboardBackgroundActiveType = "particles";
        markDashboardBackgroundActive(host, backgroundSignature);
        if (preserveLoadedParticles) {{
          host.classList.add("dashboard-particles-background-loaded");
        }} else {{
          void host.offsetWidth;
          if (!revealDashboardParticlesBackground(host, backgroundSignature, dashboardParticlesBackgroundLoadSerial)) {{
            scheduleDashboardParticlesReveal(host, backgroundSignature, dashboardParticlesBackgroundLoadSerial);
          }}
        }}
        return true;
      }}
      resetDashboardParticlesRevealState(host);
      destroyDashboardParticles();
      dashboardParticlesSignature = signature;
      document.body.classList.add("dashboard-particles-enabled");
      dashboardBackgroundActiveType = "particles";
      markDashboardBackgroundActive(host, backgroundSignature);
      void host.offsetWidth;
      window.particlesJS("dashboard-particles-bg", buildDashboardParticlesConfig(settings));
      if (!revealDashboardParticlesBackground(host, backgroundSignature, dashboardParticlesBackgroundLoadSerial)) {{
        scheduleDashboardParticlesReveal(host, backgroundSignature, dashboardParticlesBackgroundLoadSerial);
      }}
      return true;
    }}

    function disableDashboardLivemapBackground() {{
      if (dashboardBackgroundActiveType === "livemap") {{
        dashboardBackgroundActiveType = "";
      }}
      if (document.body) {{
        document.body.classList.remove("dashboard-livemap-enabled");
      }}
      const host = document.getElementById("dashboard-livemap-bg");
      resetDashboardBackgroundActiveState(host instanceof HTMLElement ? host : null);
      if (typeof disableDashboardLivemap === "function") {{
        disableDashboardLivemap();
      }}
    }}

    function applyDashboardLivemapBackground(rawSettings = null) {{
      if (!document.body) {{
        return false;
      }}
      let applied = false;
      if (typeof applyDashboardLivemap === "function") {{
        applied = !!applyDashboardLivemap(rawSettings);
      }}
      if (applied) {{
        const host = document.getElementById("dashboard-livemap-bg");
        document.body.classList.add("dashboard-livemap-enabled");
        dashboardBackgroundActiveType = "livemap";
        markDashboardBackgroundActive(host instanceof HTMLElement ? host : null, "livemap");
      }} else {{
        const host = document.getElementById("dashboard-livemap-bg");
        document.body.classList.remove("dashboard-livemap-enabled");
        if (dashboardBackgroundActiveType === "livemap") {{
          dashboardBackgroundActiveType = "";
        }}
        resetDashboardBackgroundActiveState(host instanceof HTMLElement ? host : null);
      }}
      return applied;
    }}

    const dashboardBackgroundHandlers = {{
      particles: {{
        apply: applyDashboardParticles,
        disable: disableDashboardParticles,
      }},
      livemap: {{
        apply: applyDashboardLivemapBackground,
        disable: disableDashboardLivemapBackground,
      }},
      image: {{
        apply: applyDashboardImage,
        disable: disableDashboardImage,
      }},
    }};

    function applyDashboardBackground(rawSettings = null) {{
      if (!document.body) {{
        return false;
      }}
      const settings = normalizeThemeCustomSettings(rawSettings || currentThemeCustomSettings());
      const backgroundType = normalizeThemeCustomBackgroundType(settings.background_type);
      const handler = dashboardBackgroundHandlers[backgroundType] || dashboardBackgroundHandlers.particles;
      if (backgroundType !== "image") {{
        disableDashboardImage();
      }}
      const applied = handler.apply(settings);
      if (applied) {{
        dashboardBackgroundActiveType = backgroundType;
        deactivateInactiveDashboardBackgrounds(backgroundType);
        return true;
      }}
      disableAllDashboardBackgrounds();
      return false;
    }}

    function syncThemeCustomControls() {{
