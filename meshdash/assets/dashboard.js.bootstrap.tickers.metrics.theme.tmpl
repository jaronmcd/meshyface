      const gradientPrimaryTypeSelect = document.getElementById("theme-custom-gradient-primary-type");
      if (gradientPrimaryTypeSelect instanceof HTMLSelectElement) {{
        gradientPrimaryTypeSelect.value = normalizeThemeCustomGradientType(displayGradientPrimaryType);
