      const foregroundBlurValue = document.getElementById("theme-custom-foreground-blur-value");
      if (foregroundBlurValue instanceof HTMLOutputElement || foregroundBlurValue instanceof HTMLElement) {{
        foregroundBlurValue.textContent = `${{normalizeThemeCustomForegroundBlur(displayForegroundBlur)}}px`;
      }}
      const displayBackgroundType = normalizeThemeCustomBackgroundType(editableSettings.background_type);
      const backgroundTypeSelect = document.getElementById("theme-custom-background-type");
      if (backgroundTypeSelect instanceof HTMLSelectElement) {{
