      const particlesLinkColorInput = document.getElementById("theme-custom-particles-link-color");
      if (particlesLinkColorInput instanceof HTMLInputElement) {{
        particlesLinkColorInput.value = normalizeThemeCustomParticlesColor(
          livemapMode ? displayLivemapLinkColor : displayParticlesLinkColor,
