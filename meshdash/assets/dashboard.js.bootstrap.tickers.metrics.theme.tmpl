        const body = await resp.json().catch(() => ({{ ok: false, error: `API ${{resp.status}}` }}));
        if (!resp.ok || !body || body.ok === false) {{
          const message = body && body.error ? body.error : `API ${{resp.status}}`;
          throw new Error(String(message));
        }}
        applyThemeSettingsPayload(body, {{ refreshControls: true }});
        return true;
      }} catch (err) {{
