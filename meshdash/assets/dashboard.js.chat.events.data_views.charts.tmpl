            label = formatTimelineDayLabel(unixTs);
          }} else {{
            label = formatTimelineLabel(unixTs, false);
          }}
        }}
        renderTick(unixTs, {{
          major: true,
          edgeStart,
          edgeEnd,
          label,
        }});
      }}
    }}

