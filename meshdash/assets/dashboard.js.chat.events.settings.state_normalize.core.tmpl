    function syncOwnerNameLocally(shortNameRaw, longNameRaw) {{
      const shortName = String(shortNameRaw || "").trim();
      const longName = String(longNameRaw || "").trim();
      if (!shortName && !longName) return;

      if (
        !settingsLocalStateCache
        && latestState
        && typeof latestState === "object"
        && latestState.local_state
        && typeof latestState.local_state === "object"
      ) {{
        settingsLocalStateCache = latestState.local_state;
      }}

      let changed = false;
      const patchRecord = (record) => {{
        if (patchOwnerNamesOnRecord(record, shortName, longName)) {{
          changed = true;
        }}
      }};

      const cachedLocalInfo =
        settingsLocalStateCache
        && typeof settingsLocalStateCache === "object"
        && settingsLocalStateCache.local_node_info
        && typeof settingsLocalStateCache.local_node_info === "object"
          ? settingsLocalStateCache.local_node_info
          : null;
      patchRecord(cachedLocalInfo);

      const safeState = latestState && typeof latestState === "object" ? latestState : null;
      const selfId = safeState ? resolveLocalNodeId(safeState) : "";
      if (safeState) {{
        const localState = safeState.local_state && typeof safeState.local_state === "object"
          ? safeState.local_state
          : null;
        const localInfo = localState && localState.local_node_info && typeof localState.local_node_info === "object"
          ? localState.local_node_info
          : null;
        patchRecord(localInfo);

        if (isCanonicalNodeId(selfId) && Array.isArray(safeState.nodes)) {{
          const selfNode = safeState.nodes.find((node) => normalizeNodeId(node && node.id) === selfId) || null;
          patchRecord(selfNode);
          const preferredName = longName || shortName;
          if (preferredName && nodeNameCache.get(selfId) !== preferredName) {{
            nodeNameCache.set(selfId, preferredName);
            persistNodeNameCache();
            changed = true;
          }}
        }}
      }}

      settingsLocalStateFetchedAt = Date.now();
      if (!changed) return;

      if (safeState) {{
        renderSelfRadioPill(safeState);
        if (activeLayoutView === "chat") {{
          renderChat(safeState);
        }} else if (activeLayoutView === "files") {{
          renderFilesView(safeState);
        }} else if (activeLayoutView === "history") {{
          renderHistoryChat((safeState.traffic && typeof safeState.traffic === "object") ? safeState.traffic : {{}});
        }} else if (activeLayoutView === "channels") {{
          renderChannelsView(safeState);
        }} else if (activeLayoutView === "network") {{
          renderNodes(Array.isArray(safeState.nodes) ? safeState.nodes : []);
        }} else if (activeLayoutView === "saved") {{
          renderFavorites(safeState);
        }} else if (activeLayoutView === "bots") {{
          renderBotsView(safeState);
        }} else if (activeLayoutView === "games") {{
          renderGamesView(safeState);
        }}
      }}

      if (activeLayoutView === "settings") {{
        const settingsState =
          settingsLocalStateCache && typeof settingsLocalStateCache === "object"
            ? {{ local_state: settingsLocalStateCache }}
            : safeState;
        if (settingsState) {{
          renderSettings(settingsState, true);
        }}
      }}
    }}

