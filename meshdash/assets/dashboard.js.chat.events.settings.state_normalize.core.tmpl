    function patchOwnerNamesOnRecord(record, shortNameRaw, longNameRaw) {{
      if (!record || typeof record !== "object") return false;
      const user = (record.user && typeof record.user === "object") ? record.user : record;
      const shortName = String(shortNameRaw || "").trim();
      const longName = String(longNameRaw || "").trim();
      let changed = false;

      if (shortName) {{
        if (String(user.shortName ?? "").trim() !== shortName) {{
          user.shortName = shortName;
          changed = true;
        }}
        if (String(user.short_name ?? "").trim() !== shortName) {{
          user.short_name = shortName;
          changed = true;
        }}
        if (String(record.short_name ?? "").trim() !== shortName) {{
