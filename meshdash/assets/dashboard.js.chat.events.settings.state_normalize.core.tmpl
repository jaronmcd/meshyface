    function sortedConfigSectionNames(scopeObj, excludedNames = []) {{
      if (!scopeObj || typeof scopeObj !== "object") return [];
      const excluded = new Set(excludedNames.map((name) => String(name || "").trim().toLowerCase()));
      const names = [];
      for (const [name, value] of Object.entries(scopeObj)) {{
        if (!name || excluded.has(String(name).toLowerCase())) continue;
        if (!value || typeof value !== "object" || Array.isArray(value)) continue;
        names.push(name);
      }}
      names.sort((a, b) => a.localeCompare(b));
      return names;
    }}

    function syncSectionSelectOptions(selectId, names, placeholderText) {{
      const select = document.getElementById(selectId);
      if (!(select instanceof HTMLSelectElement)) return;
      const previous = String(select.value || "");
      select.innerHTML = "";

      const placeholder = document.createElement("option");
      placeholder.value = "";
      placeholder.textContent = placeholderText;
      select.appendChild(placeholder);
      for (const name of names) {{
        const option = document.createElement("option");
        option.value = name;
        option.textContent = name;
        select.appendChild(option);
      }}

      if (previous && names.includes(previous)) {{
        select.value = previous;
        return;
      }}
      select.value = names.length ? names[0] : "";
    }}

    function syncSectionEditorFromState(state, scopeKey, selectId, textareaId, placeholderText, excludedNames = []) {{
      const scopeObj = configSectionMapFromState(state, scopeKey);
      const sectionNames = sortedConfigSectionNames(scopeObj, excludedNames);
      syncSectionSelectOptions(selectId, sectionNames, placeholderText);

      const select = document.getElementById(selectId);
      const textarea = document.getElementById(textareaId);
      if (!(select instanceof HTMLSelectElement) || !(textarea instanceof HTMLTextAreaElement)) return;

      const sectionName = String(select.value || "");
      const sectionData =
        sectionName && scopeObj && typeof scopeObj === "object" && scopeObj[sectionName] && typeof scopeObj[sectionName] === "object"
          ? scopeObj[sectionName]
          : {{}};
      let text = "{{}}";
      try {{
        text = JSON.stringify(sectionData, null, 2);
      }} catch (_err) {{
        text = "{{}}";
      }}
      setFormValue(textarea, text);
    }}

    function setFormValue(el, value) {{
      if (!(el instanceof HTMLInputElement) && !(el instanceof HTMLSelectElement) && !(el instanceof HTMLTextAreaElement)) return;
      const next = value == null ? "" : String(value);
      if (el.value !== next) {{
        el.value = next;
      }}
    }}

    function setFormChecked(el, checked) {{
      if (!(el instanceof HTMLInputElement) || el.type !== "checkbox") return;
      const next = !!checked;
      if (el.checked !== next) {{
        el.checked = next;
      }}
    }}

