    function normalizeTickerId(value) {{
      const key = String(value || "").trim().toLowerCase();
      if (key === "target") return "self";
      return tickerCatalogById.has(key) ? key : "";
    }}

    function tickerPreferenceRawValue(rawObject, id) {{
      const raw = rawObject && typeof rawObject === "object" ? rawObject : {{}};
      if (Object.prototype.hasOwnProperty.call(raw, id)) return raw[id];
      if (id === "self" && Object.prototype.hasOwnProperty.call(raw, "target")) return raw.target;
      return undefined;
    }}

    function defaultTickerOneshotPreferences() {{
      return {{
        node_online: {{
          enabled: false,
          favorites_only: true,
        }},
      }};
    }}

    function defaultTickerPreferences() {{
      return {{
        order: [...tickerDefaultOrder],
        enabled: {{ ...tickerDefaultEnabled }},
        labels: {{}},
        trend: {{ ...tickerDefaultTrendVisibility }},
        battery_window_hours: tickerDefaultBatteryWindowHours,
        node_rows: {{ ...nodeTickerDefaultRows }},
        node_packet_trend: true,
        update_ticker_enabled: false,
        oneshots: defaultTickerOneshotPreferences(),
      }};
    }}

    function normalizeTickerPreferences(value) {{
      const raw = value && typeof value === "object" ? value : {{}};
      const base = defaultTickerPreferences();
      const order = [];
      const seen = new Set();
      const rawOrder = Array.isArray(raw.order) ? raw.order : [];
      for (const rawId of rawOrder) {{
        const id = normalizeTickerId(rawId);
        if (!id || seen.has(id)) continue;
        seen.add(id);
        order.push(id);
      }}
      if (seen.has("self") && !seen.has("radio")) {{
        const selfIndex = order.indexOf("self");
        const insertAt = selfIndex >= 0 ? selfIndex + 1 : order.length;
        order.splice(insertAt, 0, "radio");
        seen.add("radio");
      }}
      for (const id of tickerDefaultOrder) {{
        if (seen.has(id)) continue;
        seen.add(id);
        order.push(id);
      }}

      const enabledRaw = raw.enabled && typeof raw.enabled === "object" ? raw.enabled : {{}};
      const enabled = {{}};
      for (const id of tickerDefaultOrder) {{
        const fallbackEnabled = parseBoolToken(base.enabled[id], true);
        const rawEnabledValue = tickerPreferenceRawValue(enabledRaw, id);
        if (rawEnabledValue === undefined) {{
          enabled[id] = fallbackEnabled;
          continue;
        }}
        enabled[id] = parseBoolToken(rawEnabledValue, fallbackEnabled);
      }}

      const labelsRaw = raw.labels && typeof raw.labels === "object" ? raw.labels : {{}};
      const labels = {{}};
      for (const [rawId, rawValue] of Object.entries(labelsRaw)) {{
        const id = normalizeTickerId(rawId);
        if (!id) continue;
        const text = String(rawValue == null ? "" : rawValue).trim().slice(0, 26);
        if (!text) continue;
        const defaultLabel = String((tickerCatalogById.get(id) && tickerCatalogById.get(id).defaultLabel) || id);
        if (id === "self" && text === "Target") continue;
        if (text === defaultLabel) continue;
        labels[id] = text;
      }}

      const trendRaw = raw.trend && typeof raw.trend === "object" ? raw.trend : {{}};
      const trend = {{}};
      for (const id of tickerDefaultOrder) {{
        const defaultTrend = !!tickerDefaultTrendVisibility[id];
        if (!(id in trendRaw)) {{
          trend[id] = defaultTrend;
          continue;
        }}
        trend[id] = parseBoolToken(trendRaw[id], defaultTrend);
      }}

      const batteryWindowRaw = Number(raw.battery_window_hours ?? raw.batteryWindowHours);
      const batteryWindowHours = Number.isFinite(batteryWindowRaw)
        ? Math.max(1, Math.min(24, Math.round(batteryWindowRaw)))
        : base.battery_window_hours;
      const nodeRowsRaw = (
        raw.node_rows && typeof raw.node_rows === "object"
          ? raw.node_rows
          : (raw.nodeRows && typeof raw.nodeRows === "object" ? raw.nodeRows : {{}})
      );
      const nodeRows = {{}};
      for (const key of nodeTickerRowKeys) {{
        const fallback = !!nodeTickerDefaultRows[key];
        nodeRows[key] = key in nodeRowsRaw
          ? parseBoolToken(nodeRowsRaw[key], fallback)
          : fallback;
      }}
      const nodePacketTrend = parseBoolToken(
        raw.node_packet_trend
          ?? raw.nodePacketTrend
          ?? raw.node_list_packet_sparkline
          ?? raw.nodeListPacketSparkline,
        true
      );
      const updateTickerEnabled = parseBoolToken(
        raw.update_ticker_enabled
          ?? raw.updateTickerEnabled
          ?? raw.show_update_ticker
          ?? raw.showUpdateTicker,
        false
      );
      const oneshotsRaw = (
        raw.oneshots && typeof raw.oneshots === "object"
          ? raw.oneshots
          : (raw.one_shots && typeof raw.one_shots === "object" ? raw.one_shots : {{}})
      );
      const defaultOneshots = defaultTickerOneshotPreferences();
      const nodeOnlineRaw = (
        oneshotsRaw.node_online && typeof oneshotsRaw.node_online === "object"
          ? oneshotsRaw.node_online
          : {{}}
      );
      const nodeOnlineEnabled = parseBoolToken(
        nodeOnlineRaw.enabled
          ?? nodeOnlineRaw.on
          ?? raw.node_online_oneshot_enabled
          ?? raw.nodeOnlineOneshotEnabled,
        !!(defaultOneshots.node_online && defaultOneshots.node_online.enabled)
      );
      const nodeOnlineFavoritesOnly = parseBoolToken(
        nodeOnlineRaw.favorites_only
          ?? nodeOnlineRaw.favoritesOnly
          ?? raw.node_online_oneshot_favorites_only
          ?? raw.nodeOnlineOneshotFavoritesOnly,
        !!(defaultOneshots.node_online && defaultOneshots.node_online.favorites_only)
      );
      const oneshots = {{
        node_online: {{
          enabled: nodeOnlineEnabled,
          favorites_only: nodeOnlineFavoritesOnly,
        }},
      }};

      return {{
        order,
        enabled,
        labels,
        trend,
        battery_window_hours: batteryWindowHours,
        node_rows: nodeRows,
        node_packet_trend: nodePacketTrend,
        update_ticker_enabled: updateTickerEnabled,
        oneshots,
      }};
    }}

    function currentTickerPreferences() {{
      if (!tickerPreferences || typeof tickerPreferences !== "object") {{
        tickerPreferences = defaultTickerPreferences();
      }}
      return tickerPreferences;
    }}

    function persistTickerPreferences() {{
      try {{
        window.localStorage.setItem(
          tickerPreferencesStorageKey,
          JSON.stringify(normalizeTickerPreferences(currentTickerPreferences()))
        );
      }} catch (_err) {{
      }}
    }}

    function loadTickerPreferences() {{
      let parsed = null;
      try {{
        const raw = window.localStorage.getItem(tickerPreferencesStorageKey) || "";
        if (raw) {{
          parsed = JSON.parse(raw);
        }}
      }} catch (_err) {{
        parsed = null;
      }}
      tickerPreferences = normalizeTickerPreferences(parsed || defaultTickerPreferences());
      applyTickerPreferencesToTopbar();
    }}

    function tickerLabelText(tickerId) {{
      const id = normalizeTickerId(tickerId);
      if (!id) return "";
      const prefs = currentTickerPreferences();
      const custom = String((prefs.labels && prefs.labels[id]) || "").trim();
      if (custom) return custom;
      const defaultLabel = tickerCatalogById.get(id) && tickerCatalogById.get(id).defaultLabel;
      return String(defaultLabel || id);
    }}

    function tickerEnabled(tickerId) {{
      const id = normalizeTickerId(tickerId);
      if (!id) return false;
      const prefs = currentTickerPreferences();
      if (!prefs.enabled || typeof prefs.enabled !== "object") return true;
      if (!(id in prefs.enabled)) return true;
      return !!prefs.enabled[id];
    }}

    function tickerTrendEnabled(tickerId) {{
      const id = normalizeTickerId(tickerId);
      if (!id || !tickerMetricIds.has(id)) return false;
      const prefs = currentTickerPreferences();
      if (!prefs.trend || typeof prefs.trend !== "object") return true;
      if (!(id in prefs.trend)) return true;
      return !!prefs.trend[id];
    }}

    function batteryTrendWindowHours() {{
      const prefs = currentTickerPreferences();
      const raw = Number(prefs && prefs.battery_window_hours);
      if (!Number.isFinite(raw)) return tickerDefaultBatteryWindowHours;
      return Math.max(1, Math.min(24, Math.round(raw)));
    }}

    function nodeTickerRowPreferences() {{
      const prefs = currentTickerPreferences();
      const raw = prefs && prefs.node_rows && typeof prefs.node_rows === "object"
        ? prefs.node_rows
        : {{}};
      const normalized = {{}};
      for (const key of nodeTickerRowKeys) {{
        normalized[key] = key in raw
          ? parseBoolToken(raw[key], !!nodeTickerDefaultRows[key])
          : !!nodeTickerDefaultRows[key];
      }}
      return normalized;
    }}

    function nodeNavigatorPacketTrendEnabled() {{
      return true;
    }}

    function topbarUpdateTickerEnabled() {{
      const prefs = currentTickerPreferences();
      return parseBoolToken(
        prefs && (prefs.update_ticker_enabled ?? prefs.updateTickerEnabled),
        false
      );
    }}

    function syncTopbarUpdateTickerVisibilityPreference() {{
      const tickerEl = document.getElementById("topbar-update-ticker");
      const trackEl = document.getElementById("topbar-update-track");
      const primaryEl = document.getElementById("topbar-update-text-primary");
      const secondaryEl = document.getElementById("topbar-update-text-secondary");
      if (!(tickerEl instanceof HTMLElement)) return;
      if (!(trackEl instanceof HTMLElement)) return;
      if (!(primaryEl instanceof HTMLElement)) return;
      if (!(secondaryEl instanceof HTMLElement)) return;
      cancelTopbarTickerClearTimers(tickerEl);
      if (topbarUpdateTickerEnabled()) {{
        setTopbarUpdateTickerVisibility(tickerEl, true);
        tickerEl.classList.add("is-static");
        tickerEl.classList.remove("is-fading");
        return;
      }}
      hideTopbarUpdateTickerNow(tickerEl, trackEl, primaryEl, secondaryEl);
    }}

    function topbarOneshotNodeOnlineEnabled() {{
      return false;
    }}

    function topbarOneshotNodeOnlineFavoritesOnly() {{
      const prefs = currentTickerPreferences();
      const oneShots = prefs && prefs.oneshots && typeof prefs.oneshots === "object"
        ? prefs.oneshots
        : {{}};
      const nodeOnline = oneShots.node_online && typeof oneShots.node_online === "object"
        ? oneShots.node_online
        : {{}};
      return parseBoolToken(nodeOnline.favorites_only, true);
    }}

    function isTickerSettingsControlId(controlId) {{
      return String(controlId || "").trim().startsWith("settings-ticker-");
    }}

    function applyTickerPreferencesToTopbar() {{
      const row = document.querySelector(".summary-ticker-row");
      if (!(row instanceof HTMLElement)) return;
      const prefs = currentTickerPreferences();

      const orderedIds = [];
      const seen = new Set();
      for (const rawId of (Array.isArray(prefs.order) ? prefs.order : [])) {{
        const id = normalizeTickerId(rawId);
        if (!id || seen.has(id)) continue;
        seen.add(id);
        orderedIds.push(id);
      }}
      for (const id of tickerDefaultOrder) {{
        if (seen.has(id)) continue;
        seen.add(id);
        orderedIds.push(id);
      }}

      let orderIndex = 0;
      let visibleTickerCount = 0;
      for (const id of orderedIds) {{
        const item = row.querySelector(`.summary-ticker-item[data-ticker-id="${{id}}"]`);
        if (!(item instanceof HTMLElement)) continue;
        item.style.order = String(orderIndex);
        const isEnabled = tickerEnabled(id);
        item.hidden = !isEnabled;
        if (isEnabled) {{
          visibleTickerCount += 1;
        }}
        const labelEl = item.querySelector("[data-ticker-label]");
        if (labelEl instanceof HTMLElement) {{
          const defaultLabel = String((tickerCatalogById.get(id) && tickerCatalogById.get(id).defaultLabel) || id);
          if (!labelEl.dataset.defaultLabel) {{
            labelEl.dataset.defaultLabel = defaultLabel;
          }}
          labelEl.textContent = tickerLabelText(id) || defaultLabel;
        }}
        orderIndex += 1;
      }}
      if (topbarElement instanceof HTMLElement) {{
        topbarElement.classList.toggle("ticker-wrap-balanced", visibleTickerCount > 8);
      }}
      if (activeCompactTickerDetailId && !tickerEnabled(activeCompactTickerDetailId)) {{
        closeCompactTickerDetail();
      }} else {{
        refreshCompactTickerDetailTray();
      }}
      requestTopbarLayoutMetricsSync();
      syncTopbarUpdateTickerVisibilityPreference();
    }}

    function saveTickerPreferences({{
      rerenderSummary = true,
      rerenderSettings = true,
      status = "",
    }} = {{}}) {{
      tickerPreferences = normalizeTickerPreferences(currentTickerPreferences());
      persistTickerPreferences();
      applyTickerPreferencesToTopbar();
      if (rerenderSummary && latestState) {{
        renderSummary(latestState);
      }}
      if (rerenderSettings && activeSettingsTab === "tickers") {{
        renderTickerSettingsUi();
      }}
      if (status !== undefined && status !== null) {{
        setSettingsStatusText(status);
      }}
    }}

    function resetTickerPreferencesForId(tickerId) {{
      const id = normalizeTickerId(tickerId);
      if (!id) return;
      const defaults = defaultTickerPreferences();
      const prefs = currentTickerPreferences();
      if (!prefs.enabled || typeof prefs.enabled !== "object") prefs.enabled = {{}};
      if (!prefs.labels || typeof prefs.labels !== "object") prefs.labels = {{}};
      if (!prefs.trend || typeof prefs.trend !== "object") prefs.trend = {{}};
      prefs.enabled[id] = !!defaults.enabled[id];
      delete prefs.labels[id];
      prefs.trend[id] = !!defaults.trend[id];
      if (id === "battery") {{
        prefs.battery_window_hours = defaults.battery_window_hours;
      }}
      if (id === "node") {{
        prefs.node_rows = {{ ...defaults.node_rows }};
      }}
    }}

    function updateThemeToggleLabel(resolvedTheme) {{
      const resolvedText = resolvedTheme === "dark" ? "Dark" : "Light";
      const nextText = resolvedTheme === "dark" ? "Light" : "Dark";
      for (const btn of document.querySelectorAll("[data-theme-toggle]")) {{
        if (!(btn instanceof HTMLButtonElement)) continue;
        const variant = String(btn.dataset.themeToggle || "").trim().toLowerCase();
        if (variant !== "compact") {{
          btn.textContent = `Theme: ${{resolvedText}}`;
        }}
        if (themePreference === "auto") {{
          btn.title = `Theme follows system (${{resolvedText}}). Click to lock ${{nextText}}.`;
        }} else {{
          btn.title = `Theme locked to ${{resolvedText}}. Click to switch to ${{nextText}}.`;
        }}
        btn.setAttribute("aria-label", btn.title);
        btn.setAttribute("aria-pressed", resolvedTheme === "dark" ? "true" : "false");
      }}
    }}

    function applyThemePreference(mode, persist = true) {{
      const normalized = normalizeThemeMode(mode);
      themePreference = normalized;
      const resolvedTheme = normalized === "auto" ? systemPreferredTheme() : normalized;
      applyThemePresetTokens(resolvedTheme);
      document.documentElement.setAttribute("data-theme", resolvedTheme);
      document.documentElement.setAttribute("data-theme-pref", normalized);
      applyMapTiles(resolvedTheme);
      applySettingsFixedMapTiles(resolvedTheme);
      updateThemeToggleLabel(resolvedTheme);
      const historyNodeId = activeLayoutView === "saved"
        ? resolveSavedViewNodeId(latestState)
        : normalizeNodeId(selectedNodeId || "");
      if (isSelectableNodeId(historyNodeId)) {{
        const cached = nodeHistoryCache.get(historyNodeId);
        if (cached && cached.data && Array.isArray(cached.data.points)) {{
          renderSignalChart(cached.data.points);
        }}
      }}
      const cachedHistoryWeekly = summaryMetricsCache.get(String(weeklySummaryWindowHours));
      if (cachedHistoryWeekly && cachedHistoryWeekly.data && Array.isArray(cachedHistoryWeekly.data.points)) {{
        if (activeMapDataMode === "activity") {{
          renderWeeklySummary(cachedHistoryWeekly.data);
        }}
      }}
      const cachedNetworkWeekly = summaryMetricsCache.get(String(networkOverviewWindowHours));
      if (
        activeLayoutView === "network"
        && cachedNetworkWeekly
        && cachedNetworkWeekly.data
        && Array.isArray(cachedNetworkWeekly.data.points)
      ) {{
        renderNetworkOverviewSummary(cachedNetworkWeekly.data);
      }}

      if (!persist) return;
      try {{
        window.localStorage.setItem(themeStorageKey, normalized);
      }} catch (_err) {{
      }}
    }}

    function bindThemeToggle() {{
      for (const btn of document.querySelectorAll("[data-theme-toggle]")) {{
        if (!(btn instanceof HTMLButtonElement) || btn.dataset.themeToggleBound === "1") continue;
        btn.dataset.themeToggleBound = "1";
        btn.addEventListener("click", () => {{
          const resolved = themePreference === "auto" ? systemPreferredTheme() : themePreference;
          const next = resolved === "dark" ? "light" : "dark";
          applyThemePreference(next, true);
        }});
      }}

      if (!themeMediaQuery && window.matchMedia) {{
        themeMediaQuery = window.matchMedia("(prefers-color-scheme: dark)");
        const onThemeChange = () => {{
          if (themePreference === "auto") {{
            applyThemePreference("auto", false);
          }}
        }};
        if (typeof themeMediaQuery.addEventListener === "function") {{
          themeMediaQuery.addEventListener("change", onThemeChange);
        }} else if (typeof themeMediaQuery.addListener === "function") {{
          themeMediaQuery.addListener(onThemeChange);
        }}
      }}
    }}
