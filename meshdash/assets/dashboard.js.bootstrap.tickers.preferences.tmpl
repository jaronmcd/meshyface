    function resolveWeeklySummaryMetricMeta(
      metricKey,
      nodeSeries = weeklySummaryNodeSeriesEnabled,
      packetSeries = null,
      linkMode = null
    ) {{
      const metric = normalizeWeeklySummaryMetric(metricKey);
      const base = weeklySummaryMetricCatalog.get(metric) || {{
        label: "Metric",
        decimals: 0,
      }};
      if (metric === "packets" && packetSeries && typeof packetSeries === "object") {{
        const normalizedSeries = normalizeNetworkOverviewPacketSeries(packetSeries);
        const seriesOrder = networkOverviewPacketSeriesOrder.filter((key) => normalizedSeries[key]);
        const resolvedStyles = {{}};
        for (const seriesKey of networkOverviewPacketSeriesOrder) {{
          const baseStyle = (
            networkOverviewPacketSeriesStyles[seriesKey]
            && typeof networkOverviewPacketSeriesStyles[seriesKey] === "object"
          ) ? networkOverviewPacketSeriesStyles[seriesKey] : {{}};
          const paletteColor = networkOverviewPacketSeriesPaletteColor(seriesKey);
          resolvedStyles[seriesKey] = paletteColor
            ? {{
                ...baseStyle,
                color: paletteColor,
                labelColor: paletteColor,
              }}
            : {{ ...baseStyle }};
        }}
        return {{
          ...base,
          seriesOrder: seriesOrder.length ? seriesOrder : ["all"],
          seriesLabels: networkOverviewPacketSeriesLabels,
          seriesStyles: resolvedStyles,
        }};
      }}
      if (metric === "links" && linkMode !== null && linkMode !== undefined) {{
        const normalizedLinkMode = normalizeNetworkOverviewLinkMode(linkMode);
        const seriesOrder = normalizedLinkMode === "both"
          ? ["links", "real_links"]
          : [normalizedLinkMode === "live" ? "real_links" : "links"];
        const resolvedStyles = {{}};
        for (const seriesKey of networkOverviewLinkSeriesOrder) {{
          const baseStyle = (
            networkOverviewLinkSeriesStyles[seriesKey]
            && typeof networkOverviewLinkSeriesStyles[seriesKey] === "object"
          ) ? networkOverviewLinkSeriesStyles[seriesKey] : {{}};
          const paletteColor = networkOverviewLinkSeriesPaletteColor(seriesKey);
          resolvedStyles[seriesKey] = paletteColor
            ? {{
                ...baseStyle,
                color: paletteColor,
                labelColor: paletteColor,
              }}
            : {{ ...baseStyle }};
        }}
        return {{
          ...base,
          seriesOrder,
          seriesLabels: networkOverviewLinkSeriesLabels,
          seriesStyles: resolvedStyles,
        }};
      }}
      if (metric !== "nodes") {{
        return base;
      }}
      const normalizedSeries = normalizeWeeklySummaryNodeSeries(nodeSeries);
      const seriesOrder = weeklySummaryNodeSeriesOrder.filter((key) => normalizedSeries[key]);
      const resolvedStyles = {{}};
      for (const seriesKey of weeklySummaryNodeSeriesOrder) {{
        const baseStyle = (
          weeklySummaryNodeSeriesStyles[seriesKey]
          && typeof weeklySummaryNodeSeriesStyles[seriesKey] === "object"
        ) ? weeklySummaryNodeSeriesStyles[seriesKey] : {{}};
        const paletteColor = weeklySummaryNodeSeriesPaletteColor(seriesKey);
        resolvedStyles[seriesKey] = paletteColor
          ? {{
              ...baseStyle,
              color: paletteColor,
              labelColor: paletteColor,
            }}
          : {{ ...baseStyle }};
      }}
      return {{
        ...base,
        seriesOrder: seriesOrder.length ? seriesOrder : ["online_nodes"],
        seriesLabels: weeklySummaryNodeSeriesLabels,
        seriesStyles: resolvedStyles,
      }};
    }}

    function updateWeeklySummaryNodeSeriesControls(metricKey = weeklySummaryMetric) {{
      const metric = normalizeWeeklySummaryMetric(metricKey);
      const showLines = metric === "nodes";
      const wrap = document.getElementById("weekly-summary-node-lines-wrap");
      if (wrap instanceof HTMLElement) {{
        wrap.hidden = !showLines;
      }}
      for (const key of weeklySummaryNodeSeriesOrder) {{
        const toggleId = weeklySummaryNodeSeriesControlIds[key];
        const toggle = document.getElementById(toggleId);
        if (!(toggle instanceof HTMLInputElement)) continue;
        const seriesColor = weeklySummaryNodeSeriesPaletteColor(key);
        if (seriesColor) {{
          toggle.style.accentColor = seriesColor;
        }} else {{
          toggle.style.removeProperty("accent-color");
        }}
        toggle.checked = !!weeklySummaryNodeSeriesEnabled[key];
        toggle.disabled = !showLines;
      }}
    }}

