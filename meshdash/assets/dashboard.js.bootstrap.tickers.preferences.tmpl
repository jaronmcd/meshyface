    function normalizeTickerDensityMode(mode) {{
      const clean = String(mode || "").trim().toLowerCase();
      return clean === "expanded" ? "expanded" : "compact";
    }}

    let activeCompactTickerDetailId = "";
    let activeExpandedTickerZoomId = "";

    function compactTickerDetailModeActive() {{
      return topbarElement instanceof HTMLElement
        && !topbarElement.classList.contains("ticker-expanded");
    }}

    function expandedTickerZoomModeActive() {{
      return topbarElement instanceof HTMLElement
        && topbarElement.classList.contains("ticker-expanded");
    }}

    function tickerNavigationTarget(tickerId) {{
      const id = normalizeTickerId(tickerId);
      if (id === "bots") return "bots";
      return "";
    }}

    function compactTickerDetailItemIsExpandable(item) {{
      if (!(item instanceof HTMLElement)) return false;
      if (item.hidden) return false;
      if (item.classList.contains("summary-ticker-item-control")) return false;
      const id = normalizeTickerId(item.dataset.tickerId || "");
      if (tickerNavigationTarget(id)) return false;
      return !!id && id !== "self";
    }}

    function expandedTickerPlotItemIsZoomable(item) {{
      if (!(item instanceof HTMLElement)) return false;
      if (item.hidden) return false;
      if (item.classList.contains("summary-ticker-item-control")) return false;
      const id = normalizeTickerId(item.dataset.tickerId || "");
      if (!id || id === "self") return false;
      if (tickerNavigationTarget(id)) return false;
      const metricTicker = item.querySelector(".metric-ticker");
      return metricTicker instanceof HTMLElement && !metricTicker.hidden;
    }}

    function syncCompactTickerColumnCount(row) {{
      if (!(row instanceof HTMLElement)) return;
      const visibleTickerCount = Array.from(row.querySelectorAll(".summary-ticker-item[data-ticker-id]"))
        .filter((item) => item instanceof HTMLElement && !item.hidden).length;
      row.style.setProperty("--summary-visible-ticker-count", String(Math.max(1, visibleTickerCount)));
    }}

    function compactTickerExpandedSlot() {{
      const slot = document.getElementById("summary-ticker-expanded-slot");
      return slot instanceof HTMLElement ? slot : null;
    }}

    function clearCompactTickerExpandedSlot() {{
      const slot = compactTickerExpandedSlot();
      if (!(slot instanceof HTMLElement)) return;
      slot.hidden = true;
      slot.dataset.tickerId = "";
      slot.replaceChildren();
    }}

    function stripClonedTickerIds(root) {{
      if (!(root instanceof HTMLElement)) return;
      root.removeAttribute("id");
      for (const element of Array.from(root.querySelectorAll("[id]"))) {{
        element.removeAttribute("id");
      }}
    }}

    function renderCompactTickerExpandedSlot(sourceItem, cleanId) {{
      const slot = compactTickerExpandedSlot();
      if (!(slot instanceof HTMLElement) || !compactTickerDetailItemIsExpandable(sourceItem)) return;
      const clone = sourceItem.cloneNode(true);
      if (!(clone instanceof HTMLElement)) return;
      stripClonedTickerIds(clone);
      clone.classList.remove("is-compact-detail-source");
      clone.classList.add("is-compact-detail-open", "summary-ticker-expanded-card");
      clone.dataset.tickerId = cleanId;
      clone.setAttribute("aria-hidden", "true");
      clone.removeAttribute("role");
      clone.removeAttribute("tabindex");
      clone.removeAttribute("aria-expanded");
      clone.removeAttribute("aria-label");
      slot.replaceChildren(clone);
      slot.dataset.tickerId = cleanId;
      slot.hidden = false;
    }}

    function closeCompactTickerDetail({{ rerenderSummary = false }} = {{}}) {{
      activeCompactTickerDetailId = "";
      if (topbarElement instanceof HTMLElement) {{
        topbarElement.classList.remove("has-compact-ticker-detail");
      }}
      clearCompactTickerExpandedSlot();
      syncCompactTickerDetailAffordances();
      requestTopbarLayoutMetricsSync();
      if (rerenderSummary && latestState) {{
        renderSummary(latestState);
      }}
    }}

    function closeExpandedTickerPlotZoom({{ rerenderSummary = false }} = {{}}) {{
      activeExpandedTickerZoomId = "";
      syncExpandedTickerZoomAffordances();
      requestTopbarLayoutMetricsSync();
      if (rerenderSummary && latestState) {{
        renderSummary(latestState);
      }}
    }}

    function renderCompactTickerDetail(id) {{
      const cleanId = normalizeTickerId(id);
      const row = document.querySelector(".summary-ticker-row");
      if (!cleanId || cleanId === "self" || !(row instanceof HTMLElement)) {{
        closeCompactTickerDetail();
        return;
      }}
      if (!compactTickerDetailModeActive()) {{
        closeCompactTickerDetail();
        return;
      }}
      const item = row.querySelector(`.summary-ticker-item[data-ticker-id="${{cleanId}}"]`);
      if (!compactTickerDetailItemIsExpandable(item)) {{
        closeCompactTickerDetail();
        return;
      }}
      activeCompactTickerDetailId = cleanId;
      if (topbarElement instanceof HTMLElement) {{
        topbarElement.classList.add("has-compact-ticker-detail");
      }}
      syncCompactTickerDetailAffordances();
      renderCompactTickerExpandedSlot(item, cleanId);
      requestTopbarLayoutMetricsSync();
    }}

    function refreshCompactTickerDetailTray() {{
      if (!activeCompactTickerDetailId) {{
        clearCompactTickerExpandedSlot();
        syncCompactTickerDetailAffordances();
        return;
      }}
      const row = document.querySelector(".summary-ticker-row");
      const item = row instanceof HTMLElement
        ? row.querySelector(`.summary-ticker-item[data-ticker-id="${{activeCompactTickerDetailId}}"]`)
        : null;
      if (!compactTickerDetailModeActive() || !compactTickerDetailItemIsExpandable(item)) {{
        closeCompactTickerDetail();
        return;
      }}
      if (topbarElement instanceof HTMLElement) {{
        topbarElement.classList.add("has-compact-ticker-detail");
      }}
      syncCompactTickerDetailAffordances();
      renderCompactTickerExpandedSlot(item, activeCompactTickerDetailId);
      requestTopbarLayoutMetricsSync();
    }}

    function toggleCompactTickerDetail(id) {{
      const cleanId = normalizeTickerId(id);
      if (!cleanId || cleanId === "self") return;
      if (!compactTickerDetailModeActive()) return;
      if (activeCompactTickerDetailId === cleanId) {{
        closeCompactTickerDetail({{ rerenderSummary: true }});
        return;
      }}
      renderCompactTickerDetail(cleanId);
      if (latestState) {{
        renderSummary(latestState);
      }}
    }}

    function toggleExpandedTickerPlotZoom(id) {{
      const cleanId = normalizeTickerId(id);
      if (!cleanId || cleanId === "self") return;
      if (!expandedTickerZoomModeActive()) return;
      if (activeExpandedTickerZoomId === cleanId) {{
        closeExpandedTickerPlotZoom({{ rerenderSummary: true }});
        return;
      }}
      activeExpandedTickerZoomId = cleanId;
      syncExpandedTickerZoomAffordances();
      requestTopbarLayoutMetricsSync();
      if (latestState) {{
        renderSummary(latestState);
      }}
    }}

    function syncExpandedTickerZoomAffordances() {{
      const row = document.querySelector(".summary-ticker-row");
      if (!(row instanceof HTMLElement)) return;
      const expanded = expandedTickerZoomModeActive();
      let activeZoomStillVisible = false;
      for (const item of Array.from(row.querySelectorAll(".summary-ticker-item[data-ticker-id]"))) {{
        if (!(item instanceof HTMLElement)) continue;
        const id = normalizeTickerId(item.dataset.tickerId || "");
        const zoomable = expanded && expandedTickerPlotItemIsZoomable(item);
        if (zoomable && id === activeExpandedTickerZoomId) {{
          activeZoomStillVisible = true;
        }}
        item.classList.toggle("is-expanded-plot-zoom", zoomable && id === activeExpandedTickerZoomId);
        if (!zoomable) {{
          if (!compactTickerDetailModeActive() && !tickerNavigationTarget(id) && id !== "self") {{
            item.removeAttribute("role");
            item.removeAttribute("tabindex");
            item.removeAttribute("aria-pressed");
            item.removeAttribute("aria-label");
          }}
          continue;
        }}
        item.setAttribute("role", "button");
        item.tabIndex = 0;
        item.setAttribute("aria-pressed", id === activeExpandedTickerZoomId ? "true" : "false");
        const labelText = tickerLabelText(id) || id;
        item.setAttribute("aria-label", `${{id === activeExpandedTickerZoomId ? "Zoom out" : "Zoom in"}} ${{labelText}} plot`);
      }}
      if (expanded && activeExpandedTickerZoomId && !activeZoomStillVisible) {{
        activeExpandedTickerZoomId = "";
      }}
    }}

    function syncCompactTickerDetailAffordances() {{
      const row = document.querySelector(".summary-ticker-row");
      if (!(row instanceof HTMLElement)) return;
      const compact = compactTickerDetailModeActive();
      for (const item of Array.from(row.querySelectorAll(".summary-ticker-item[data-ticker-id]"))) {{
        if (!(item instanceof HTMLElement)) continue;
        const id = normalizeTickerId(item.dataset.tickerId || "");
        const navigationTarget = tickerNavigationTarget(id);
        if (navigationTarget && !item.hidden) {{
          item.classList.remove("is-compact-detail-open", "is-compact-detail-source");
          item.setAttribute("role", "button");
          item.tabIndex = 0;
          item.removeAttribute("aria-expanded");
          item.setAttribute("aria-label", `Open ${{tickerLabelText(id) || id}} view`);
          continue;
        }}
        const expandable = compact && compactTickerDetailItemIsExpandable(item);
        item.classList.remove("is-compact-detail-open");
        item.classList.toggle("is-compact-detail-source", expandable && id === activeCompactTickerDetailId);
        if (!expandable) {{
          if (id !== "self") {{
            item.removeAttribute("role");
            item.removeAttribute("tabindex");
            item.removeAttribute("aria-expanded");
            item.removeAttribute("aria-label");
          }}
          continue;
        }}
        item.setAttribute("role", "button");
        item.tabIndex = 0;
        item.setAttribute("aria-expanded", id === activeCompactTickerDetailId ? "true" : "false");
        const labelText = tickerLabelText(id) || id;
        item.setAttribute("aria-label", `${{id === activeCompactTickerDetailId ? "Collapse" : "Show"}} ${{labelText}} ticker detail`);
      }}
      syncCompactTickerColumnCount(row);
      syncExpandedTickerZoomAffordances();
    }}

    function bindCompactTickerDetailTrayControls() {{
      const row = document.querySelector(".summary-ticker-row");
      if (row instanceof HTMLElement && row.dataset.compactTickerDetailBound !== "1") {{
        row.dataset.compactTickerDetailBound = "1";
        row.addEventListener("click", (ev) => {{
          const target = ev.target;
          if (!(target instanceof Element)) return;
          if (target.closest("button, a, input, select, textarea")) return;
          const item = target.closest(".summary-ticker-item[data-ticker-id]");
          if (item instanceof HTMLElement) {{
            const navigationTarget = tickerNavigationTarget(item.dataset.tickerId || "");
            if (navigationTarget && !item.hidden) {{
              ev.preventDefault();
              closeCompactTickerDetail();
              applyLayoutView(navigationTarget, true);
              return;
            }}
          }}
          if (!compactTickerDetailItemIsExpandable(item)) return;
          if (!compactTickerDetailModeActive()) {{
            if (!expandedTickerPlotItemIsZoomable(item)) return;
            toggleExpandedTickerPlotZoom(item.dataset.tickerId || "");
            return;
          }}
          toggleCompactTickerDetail(item.dataset.tickerId || "");
        }});
        row.addEventListener("keydown", (ev) => {{
          if (ev.key !== "Enter" && ev.key !== " ") return;
          const target = ev.target;
          if (!(target instanceof Element)) return;
          const item = target.closest(".summary-ticker-item[data-ticker-id]");
          if (item instanceof HTMLElement) {{
            const navigationTarget = tickerNavigationTarget(item.dataset.tickerId || "");
            if (navigationTarget && !item.hidden) {{
              ev.preventDefault();
              closeCompactTickerDetail();
              applyLayoutView(navigationTarget, true);
              return;
            }}
          }}
          if (!compactTickerDetailItemIsExpandable(item)) return;
          if (!compactTickerDetailModeActive()) {{
            if (!expandedTickerPlotItemIsZoomable(item)) return;
            ev.preventDefault();
            toggleExpandedTickerPlotZoom(item.dataset.tickerId || "");
            return;
          }}
          ev.preventDefault();
          toggleCompactTickerDetail(item.dataset.tickerId || "");
        }});
      }}

      const slot = compactTickerExpandedSlot();
      if (slot instanceof HTMLElement && slot.dataset.compactTickerDetailBound !== "1") {{
        slot.dataset.compactTickerDetailBound = "1";
        slot.addEventListener("click", (ev) => {{
          const target = ev.target;
          if (!(target instanceof Element)) return;
          if (target.closest("button, a, input, select, textarea")) return;
          if (!activeCompactTickerDetailId || !compactTickerDetailModeActive()) return;
          closeCompactTickerDetail({{ rerenderSummary: true }});
        }});
        slot.addEventListener("keydown", (ev) => {{
          if (ev.key !== "Enter" && ev.key !== " ") return;
          if (!activeCompactTickerDetailId || !compactTickerDetailModeActive()) return;
          ev.preventDefault();
          closeCompactTickerDetail({{ rerenderSummary: true }});
        }});
      }}

      syncCompactTickerDetailAffordances();
      syncExpandedTickerZoomAffordances();
    }}

    function normalizeWeeklySummaryMetric(raw) {{
      const clean = String(raw || "").trim().toLowerCase();
      if (clean === "sensors" || clean === "sensor" || clean === "telemetry_history") return "nodes";
      if (clean === "packets" || clean === "live_packet_count") return "packets";
      if (
        clean === "nodes"
        || clean === "node_count"
        || clean === "online_node_count"
        || clean === "saved_node_count"
        || clean === "nodes_with_position"
      ) return "nodes";
      if (clean === "links" || clean === "real_edge_count") return "links";
      return "packets";
    }}

    function normalizeNetworkOverviewMetric(raw) {{
      const normalized = normalizeWeeklySummaryMetric(raw);
      return normalized === "links" ? "nodes" : normalized;
    }}

    function normalizeWeeklySummaryNodesCompare(raw) {{
      if (raw === true || raw === 1) return true;
      const clean = String(raw || "").trim().toLowerCase();
      return clean === "1" || clean === "true" || clean === "on" || clean === "yes";
    }}

    function normalizeWeeklySummaryNodeSeries(raw) {{
      const normalized = {{}};
      for (const key of weeklySummaryNodeSeriesOrder) {{
        normalized[key] = weeklySummaryNodeSeriesDefaults[key] === true;
      }}
      if (raw && typeof raw === "object") {{
        for (const key of weeklySummaryNodeSeriesOrder) {{
          if (Object.prototype.hasOwnProperty.call(raw, key)) {{
            normalized[key] = !!raw[key];
          }}
        }}
      }}
      if (!weeklySummaryNodeSeriesOrder.some((key) => normalized[key])) {{
        normalized.online_nodes = true;
      }}
      return normalized;
    }}

    function weeklySummaryNodeSeriesPaletteColor(seriesKey) {{
      const paletteName = String(weeklySummaryNodeSeriesPaletteNames[seriesKey] || "").trim().toLowerCase();
      if (!paletteName) return "";
      for (const palette of meshChannelColorPalette) {{
        const name = String(palette && palette.name || "").trim().toLowerCase();
        if (name !== paletteName) continue;
        const fill = String(palette && palette.fill || "").trim();
        if (fill) return fill;
      }}
      return "";
    }}

    function normalizeNetworkOverviewPacketSeries(raw) {{
      const normalized = {{}};
      for (const key of networkOverviewPacketSeriesOrder) {{
        normalized[key] = networkOverviewPacketSeriesDefaults[key] === true;
      }}
      if (raw && typeof raw === "object") {{
        for (const key of networkOverviewPacketSeriesOrder) {{
          if (Object.prototype.hasOwnProperty.call(raw, key)) {{
            normalized[key] = !!raw[key];
          }}
        }}
      }}
      if (!networkOverviewPacketSeriesOrder.some((key) => normalized[key])) {{
        normalized.all = true;
      }}
      return normalized;
    }}

    function normalizeNodePacketSeries(raw) {{
      const normalized = {{}};
      for (const key of networkOverviewPacketSeriesOrder) {{
        normalized[key] = nodePacketSeriesDefaults[key] === true;
      }}
      if (raw && typeof raw === "object") {{
        for (const key of networkOverviewPacketSeriesOrder) {{
          if (Object.prototype.hasOwnProperty.call(raw, key)) {{
            normalized[key] = !!raw[key];
          }}
        }}
      }}
      if (!networkOverviewPacketSeriesOrder.some((key) => normalized[key])) {{
        normalized.all = true;
      }}
      return normalized;
    }}

    function networkOverviewPacketSeriesPaletteColor(seriesKey) {{
      const paletteName = String(networkOverviewPacketSeriesPaletteNames[seriesKey] || "").trim().toLowerCase();
      if (!paletteName) return "";
      for (const palette of meshChannelColorPalette) {{
        const name = String(palette && palette.name || "").trim().toLowerCase();
        if (name !== paletteName) continue;
        const fill = String(palette && palette.fill || "").trim();
        if (fill) return fill;
      }}
      return "";
    }}

    function normalizeNetworkOverviewLinkMode(raw) {{
      const clean = String(raw || "").trim().toLowerCase();
      if (clean === "live" || clean === "both") return clean;
      return "history";
    }}

    function networkOverviewLinkSeriesPaletteColor(seriesKey) {{
      const paletteName = String(networkOverviewLinkSeriesPaletteNames[seriesKey] || "").trim().toLowerCase();
      if (!paletteName) return "";
      for (const palette of meshChannelColorPalette) {{
        const name = String(palette && palette.name || "").trim().toLowerCase();
        if (name !== paletteName) continue;
        const fill = String(palette && palette.fill || "").trim();
        if (fill) return fill;
      }}
      return "";
    }}

    function resolveWeeklySummaryMetricMeta(
      metricKey,
      nodeSeries = weeklySummaryNodeSeriesEnabled,
      packetSeries = null,
      linkMode = null
    ) {{
      const metric = normalizeWeeklySummaryMetric(metricKey);
      const base = weeklySummaryMetricCatalog.get(metric) || {{
        label: "Metric",
        decimals: 0,
      }};
      if (metric === "packets" && packetSeries && typeof packetSeries === "object") {{
        const normalizedSeries = normalizeNetworkOverviewPacketSeries(packetSeries);
        const seriesOrder = networkOverviewPacketSeriesOrder.filter((key) => normalizedSeries[key]);
        const resolvedStyles = {{}};
        for (const seriesKey of networkOverviewPacketSeriesOrder) {{
          const baseStyle = (
            networkOverviewPacketSeriesStyles[seriesKey]
            && typeof networkOverviewPacketSeriesStyles[seriesKey] === "object"
          ) ? networkOverviewPacketSeriesStyles[seriesKey] : {{}};
          const paletteColor = networkOverviewPacketSeriesPaletteColor(seriesKey);
          resolvedStyles[seriesKey] = paletteColor
            ? {{
                ...baseStyle,
                color: paletteColor,
                labelColor: paletteColor,
              }}
            : {{ ...baseStyle }};
        }}
        return {{
          ...base,
          seriesOrder: seriesOrder.length ? seriesOrder : ["all"],
          seriesLabels: networkOverviewPacketSeriesLabels,
          seriesStyles: resolvedStyles,
        }};
      }}
      if (metric === "links" && linkMode !== null && linkMode !== undefined) {{
        const normalizedLinkMode = normalizeNetworkOverviewLinkMode(linkMode);
        const seriesOrder = normalizedLinkMode === "both"
          ? ["links", "real_links"]
          : [normalizedLinkMode === "live" ? "real_links" : "links"];
        const resolvedStyles = {{}};
        for (const seriesKey of networkOverviewLinkSeriesOrder) {{
          const baseStyle = (
            networkOverviewLinkSeriesStyles[seriesKey]
            && typeof networkOverviewLinkSeriesStyles[seriesKey] === "object"
          ) ? networkOverviewLinkSeriesStyles[seriesKey] : {{}};
          const paletteColor = networkOverviewLinkSeriesPaletteColor(seriesKey);
          resolvedStyles[seriesKey] = paletteColor
            ? {{
                ...baseStyle,
                color: paletteColor,
                labelColor: paletteColor,
              }}
            : {{ ...baseStyle }};
        }}
        return {{
          ...base,
          seriesOrder,
          seriesLabels: networkOverviewLinkSeriesLabels,
          seriesStyles: resolvedStyles,
        }};
      }}
      if (metric !== "nodes") {{
        return base;
      }}
      const normalizedSeries = normalizeWeeklySummaryNodeSeries(nodeSeries);
      const seriesOrder = weeklySummaryNodeSeriesOrder.filter((key) => normalizedSeries[key]);
      const resolvedStyles = {{}};
      for (const seriesKey of weeklySummaryNodeSeriesOrder) {{
        const baseStyle = (
          weeklySummaryNodeSeriesStyles[seriesKey]
          && typeof weeklySummaryNodeSeriesStyles[seriesKey] === "object"
        ) ? weeklySummaryNodeSeriesStyles[seriesKey] : {{}};
        const paletteColor = weeklySummaryNodeSeriesPaletteColor(seriesKey);
        resolvedStyles[seriesKey] = paletteColor
          ? {{
              ...baseStyle,
              color: paletteColor,
              labelColor: paletteColor,
            }}
          : {{ ...baseStyle }};
      }}
      return {{
        ...base,
        seriesOrder: seriesOrder.length ? seriesOrder : ["online_nodes"],
        seriesLabels: weeklySummaryNodeSeriesLabels,
        seriesStyles: resolvedStyles,
      }};
    }}

    function updateWeeklySummaryNodeSeriesControls(metricKey = weeklySummaryMetric) {{
      const metric = normalizeWeeklySummaryMetric(metricKey);
      const showLines = metric === "nodes";
      const wrap = document.getElementById("weekly-summary-node-lines-wrap");
      if (wrap instanceof HTMLElement) {{
        wrap.hidden = !showLines;
      }}
      for (const key of weeklySummaryNodeSeriesOrder) {{
        const toggleId = weeklySummaryNodeSeriesControlIds[key];
        const toggle = document.getElementById(toggleId);
        if (!(toggle instanceof HTMLInputElement)) continue;
        const seriesColor = weeklySummaryNodeSeriesPaletteColor(key);
        if (seriesColor) {{
          toggle.style.accentColor = seriesColor;
        }} else {{
          toggle.style.removeProperty("accent-color");
        }}
        toggle.checked = !!weeklySummaryNodeSeriesEnabled[key];
        toggle.disabled = !showLines;
      }}
    }}

    function applyWeeklySummaryMetric(metricKey, persist = true) {{
      const normalized = normalizeWeeklySummaryMetric(metricKey);
      weeklySummaryMetric = normalized;
      const select = document.getElementById("weekly-summary-metric");
      if (select instanceof HTMLSelectElement && select.value !== normalized) {{
        select.value = normalized;
      }}
      updateWeeklySummaryNodeSeriesControls(normalized);
      const cached = summaryMetricsCache.get(
        summaryMetricsCacheKey(weeklySummaryWindowHours, historySummaryNeedsPacketSeries())
      );
      if (cached && cached.data) {{
        renderWeeklySummary(cached.data);
      }}
      if (!persist) return;
      try {{
        window.localStorage.setItem(weeklySummaryMetricStorageKey, normalized);
      }} catch (_err) {{
      }}
    }}

