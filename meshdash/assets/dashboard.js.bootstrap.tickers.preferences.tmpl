    function networkOverviewPacketSeriesPaletteColor(seriesKey) {{
      const paletteName = String(networkOverviewPacketSeriesPaletteNames[seriesKey] || "").trim().toLowerCase();
      if (!paletteName) return "";
      for (const palette of meshChannelColorPalette) {{
