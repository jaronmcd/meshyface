    async function waitForBoardGameControlAck(checkAck, timeoutMs) {{
      const probe = typeof checkAck === "function" ? checkAck : null;
      if (!probe) return false;
      const windowMs = Math.max(500, Math.trunc(Number(timeoutMs) || 0));
      const pollMs = Math.max(80, Math.trunc(Number(gamesMoveAckPollMs) || 0) || 180);
      const deadline = Date.now() + windowMs;
      while (Date.now() < deadline) {{
        if (probe()) return true;
        await new Promise((resolve) => setTimeout(resolve, pollMs));
      }}
      return !!probe();
    }}

    async function sendBoardGameControlWithRetry(
      gameId,
      controlType,
      fields = [],
      {{
        destination_id = "",
        session_id = "",
        channel_index = null,
        status_label = "Control message",
      }} = {{}}
    ) {{
      const refs = boardGameRefs(gameId);
      const cleanType = String(controlType || "").trim().toLowerCase();
      const link = refs.getLink();
      const peerId = normalizeNodeId(destination_id || link.peer_id || "");
      const sessionId = String(
        session_id || link.session_id || (Array.isArray(fields) ? fields[0] : "")
      ).trim().toLowerCase();
      if (!cleanType || !isCanonicalNodeId(peerId) || !sessionId) {{
        return {{ sent: false, acked: false, seq: 0 }};
      }}
      const currentChannelRaw = Number(link.channel_index);
      const defaultChannel = Number.isInteger(currentChannelRaw) && currentChannelRaw >= 0
        ? currentChannelRaw
        : meshChannelEffectiveSendIndexForApp("games");
      const sendChannel = normalizeMeshChannelIndex(channel_index == null ? defaultChannel : channel_index);
      const seq = Math.max(0, Math.trunc(Number(link.local_control_seq) || 0)) + 1;
      const waitPlan = Array.isArray(gamesMoveAckWaitPlanMs) && gamesMoveAckWaitPlanMs.length
        ? gamesMoveAckWaitPlanMs
        : [2500, 3500, 5000, 7000];
      const label = String(status_label || "Control message").trim() || "Control message";
      const isAcked = () => {{
        const current = refs.getLink();
        const currentPeer = normalizeNodeId(current.peer_id || "");
        const currentSession = String(current.session_id || "").trim().toLowerCase();
        if (currentPeer !== peerId) return false;
        if (currentSession !== sessionId) return false;
        return Math.max(0, Math.trunc(Number(current.last_remote_control_ack_seq) || 0)) >= seq;
      }};
      let atLeastOneSent = false;
      for (let attemptIndex = 0; attemptIndex < waitPlan.length; attemptIndex += 1) {{
        if (isAcked()) return {{ sent: true, acked: true, seq }};
        const sent = await sendBoardGameProtocolMessage(
          gameId,
          cleanType,
          [...(Array.isArray(fields) ? fields : []), seq],
          {{ destination_id: peerId, channel_index: sendChannel }}
        );
        if (sent) {{
          atLeastOneSent = true;
          const current = refs.getLink();
          current.local_control_seq = Math.max(
            Math.max(0, Math.trunc(Number(current.local_control_seq) || 0)),
            seq
          );
          const attemptNumber = attemptIndex + 1;
          const totalAttempts = waitPlan.length;
          if (attemptNumber <= 1) {{
            boardGameUpdateLinkStatus(gameId, `${{label}} sent. Waiting for ACK...`);
          }} else {{
            boardGameUpdateLinkStatus(gameId, `${{label}} retry ${{attemptNumber}}/${{totalAttempts}}. Waiting for ACK...`);
          }}
        }}
        const acked = await waitForBoardGameControlAck(isAcked, waitPlan[attemptIndex]);
        if (acked) {{
          boardGameUpdateLinkStatus(gameId, `${{label}} acknowledged by peer.`);
          return {{ sent: true, acked: true, seq }};
        }}
      }}
      if (atLeastOneSent) {{
        boardGameUpdateLinkStatus(gameId, `${{label}} sent, but ACK has not arrived yet (high latency or packet loss).`);
        return {{ sent: true, acked: false, seq }};
      }}
      boardGameUpdateLinkStatus(gameId, `${{label}} failed to send.`);
      return {{ sent: false, acked: false, seq: 0 }};
    }}

    async function hostBoardGameMatch(gameId) {{
      const refs = boardGameRefs(gameId);
      const peerId = gamesInviteSeedPeerId(latestState);
      if (!isCanonicalNodeId(peerId)) {{
        boardGameUpdateLinkStatus(gameId, "Select a node in the main list before hosting.");
        if (activeLayoutView === "games") renderGamesView(latestState);
        return;
      }}
      refs.setPeerId(peerId);
      const hostColor = boardGameParseColor(refs.getHostColorPreference(), refs.defaultLocalColor);
      const guestColor = refs.opponent(hostColor);
      const sessionChannel = meshChannelEffectiveSendIndexForApp("games");
      const sessionId = generateBoardGameSessionId(gameId);

      startBoardGameLocalState(gameId);
      refs.setLink(createBoardGameLinkState(gameId, {{
        mode: "pending_host",
        role: "host",
        session_id: sessionId,
        peer_id: peerId,
        channel_index: sessionChannel,
        local_color: hostColor,
        remote_color: guestColor,
        local_move_seq: 0,
        remote_move_seq: 0,
        local_control_seq: 0,
        last_remote_control_ack_seq: 0,
        status: `Invite sent to ${{reversiNodeLabel(peerId)}}. You are ${{refs.playerLabel(hostColor)}}; waiting for accept...`,
      }}));
      removeAllBoardGamePendingInvitesFromPeer(gameId, peerId);
      const sendResult = await sendBoardGameControlWithRetry(
        gameId,
        "invite",
        [sessionId, normalizeNodeId(resolveLocalNodeId(latestState) || ""), hostColor, sessionChannel],
        {{
          destination_id: peerId,
          session_id: sessionId,
          channel_index: sessionChannel,
          status_label: `${{boardGameLabel(gameId)}} invite`,
        }}
      );
      if (!sendResult.sent) {{
        const link = refs.getLink();
        link.mode = "local";
        link.role = "";
        link.session_id = "";
      }} else if (sendResult.acked) {{
        boardGameUpdateLinkStatus(
          gameId,
          `Invite delivered to ${{reversiNodeLabel(peerId)}}. You are ${{refs.playerLabel(hostColor)}}; waiting for accept...`
        );
      }}
      if (activeLayoutView === "games") renderGamesView(latestState);
    }}

    async function acceptBoardGameInvite(gameId) {{
      const refs = boardGameRefs(gameId);
      const invite = boardGamePendingInviteChoice(gameId);
      if (!invite) {{
        boardGameUpdateLinkStatus(gameId, "No pending invite to accept.");
        if (activeLayoutView === "games") renderGamesView(latestState);
        return;
      }}
      const peerId = normalizeNodeId(invite.from_id || "");
      const sessionId = String(invite.session_id || "").trim().toLowerCase();
      const hostColor = boardGameParseColor(invite.host_color, refs.defaultLocalColor);
      const guestColor = refs.opponent(hostColor);
      const inviteChannelRaw = Number(invite.channel_index);
      const inviteChannel = Number.isInteger(inviteChannelRaw) && inviteChannelRaw >= 0
        ? inviteChannelRaw
        : meshChannelEffectiveSendIndexForApp("games");
      if (!isCanonicalNodeId(peerId) || !sessionId) {{
        boardGameUpdateLinkStatus(gameId, "Invite details are invalid.");
        if (activeLayoutView === "games") renderGamesView(latestState);
        return;
      }}
      const link = refs.getLink();
      if (
        link.mode === "pending_host"
        && isCanonicalNodeId(link.peer_id)
        && String(link.session_id || "").trim()
        && (
          normalizeNodeId(link.peer_id) !== peerId
          || String(link.session_id || "").trim().toLowerCase() !== sessionId
        )
      ) {{
        await sendBoardGameControlWithRetry(
          gameId,
          "leave",
          [link.session_id],
          {{
            destination_id: link.peer_id,
            session_id: String(link.session_id || "").trim().toLowerCase(),
            channel_index: Number.isInteger(Number(link.channel_index)) ? Number(link.channel_index) : meshChannelEffectiveSendIndexForApp("games"),
            status_label: `${{boardGameLabel(gameId)}} leave`,
          }}
        );
      }}
      refs.setPeerId(peerId);
      startBoardGameLocalState(gameId);
      refs.setLink(createBoardGameLinkState(gameId, {{
        mode: "connected",
        role: "guest",
        session_id: sessionId,
        peer_id: peerId,
        channel_index: inviteChannel,
        local_color: guestColor,
        remote_color: hostColor,
        local_move_seq: 0,
        remote_move_seq: 0,
        local_control_seq: 0,
        last_remote_control_ack_seq: 0,
        status: `Connected to ${{reversiNodeLabel(peerId)}}. You are ${{refs.playerLabel(guestColor)}}.`,
      }}));
      removeBoardGamePendingInvite(gameId, peerId, sessionId);
      removeAllBoardGamePendingInvitesFromPeer(gameId, peerId);
      await sendBoardGameControlWithRetry(
        gameId,
        "accept",
        [sessionId],
        {{
          destination_id: peerId,
          session_id: sessionId,
          channel_index: inviteChannel,
          status_label: `${{boardGameLabel(gameId)}} accept`,
        }}
      );
      if (activeLayoutView === "games") renderGamesView(latestState);
    }}

    async function declineBoardGameInvite(gameId) {{
      const invite = boardGamePendingInviteChoice(gameId);
      if (!invite) {{
        boardGameUpdateLinkStatus(gameId, "No pending invite to decline.");
        if (activeLayoutView === "games") renderGamesView(latestState);
        return;
      }}
      const peerId = normalizeNodeId(invite.from_id || "");
      const sessionId = String(invite.session_id || "").trim().toLowerCase();
      const inviteChannelRaw = Number(invite.channel_index);
      const inviteChannel = Number.isInteger(inviteChannelRaw) && inviteChannelRaw >= 0
        ? inviteChannelRaw
        : meshChannelEffectiveSendIndexForApp("games");
      removeBoardGamePendingInvite(gameId, peerId, sessionId);
      const sent = await sendBoardGameControlWithRetry(
        gameId,
        "decline",
        [sessionId],
        {{
          destination_id: peerId,
          session_id: sessionId,
          channel_index: inviteChannel,
          status_label: `${{boardGameLabel(gameId)}} decline`,
        }}
      );
      if (sent.sent) {{
        boardGameUpdateLinkStatus(gameId, `Declined invite from ${{reversiNodeLabel(peerId)}}.`);
      }} else {{
        boardGameUpdateLinkStatus(gameId, `Declined locally; failed to notify ${{reversiNodeLabel(peerId)}}.`);
      }}
      if (activeLayoutView === "games") renderGamesView(latestState);
    }}

    async function disconnectBoardGameMatch(gameId) {{
      const refs = boardGameRefs(gameId);
      const link = refs.getLink();
      const linked = boardGameIsNetworkLinked(gameId) || link.mode === "pending_host";
      if (linked && isCanonicalNodeId(link.peer_id) && String(link.session_id || "").trim()) {{
        await sendBoardGameControlWithRetry(
          gameId,
          "leave",
          [link.session_id],
          {{
            destination_id: link.peer_id,
            session_id: String(link.session_id || "").trim().toLowerCase(),
            channel_index: Number.isInteger(Number(link.channel_index)) ? Number(link.channel_index) : meshChannelEffectiveSendIndexForApp("games"),
            status_label: `${{boardGameLabel(gameId)}} leave`,
          }}
        );
      }}
      boardGameResetNetworkLink(gameId, "Disconnected. Local hotseat mode.", {{ keepPeer: true }});
      if (activeLayoutView === "games") renderGamesView(latestState);
    }}
