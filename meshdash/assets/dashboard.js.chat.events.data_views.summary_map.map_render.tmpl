    function renderNetworkTrailOverlay(nodeHistory, selectionId) {{
      trailLayer.clearLayers();
      const trailPoints = collectTrailPoints(nodeHistory, selectionId);
      if (trailPoints.length >= 2) {{
        const line = L.polyline(
          trailPoints.map((point) => [point.lat, point.lon]),
          {{
            color: "#d06a1b",
            opacity: 0.72,
            weight: 3,
            lineCap: "round",
            lineJoin: "round",
          }}
        );
        line.bindTooltip(`Selected node trail (${{trailPoints.length}} points)`, {{ sticky: true, opacity: 0.9 }});
        line.addTo(trailLayer);
      }}
      if (trailPoints.length > 0) {{
        const endPoint = trailPoints[trailPoints.length - 1];
        for (let i = 0; i < trailPoints.length; i += 1) {{
          const point = trailPoints[i];
          const isLatestPoint = i === (trailPoints.length - 1);
          const ratio = trailPoints.length <= 1 ? 1 : (i / (trailPoints.length - 1));
          const marker = L.circleMarker([point.lat, point.lon], {{
            radius: isLatestPoint ? 4.8 : (i === 0 ? 3.4 : 2.4),
            color: isLatestPoint ? "#f97316" : "#2f855a",
            fillColor: isLatestPoint ? "#f97316" : "#63d297",
            fillOpacity: isLatestPoint ? 0.92 : (0.2 + (ratio * 0.45)),
            weight: isLatestPoint ? 1.8 : 1,
            bubblingMouseEvents: false,
          }});
          const pointTime = point.time || "n/a";
          marker.bindTooltip(
            isLatestPoint
              ? `Selected trail newest point: ${{pointTime}}`
              : `Selected trail point ${{i + 1}}/${{trailPoints.length}}: ${{pointTime}}`,
            {{ sticky: true, opacity: 0.88 }}
          );
          marker.addTo(trailLayer);
        }}

        const latestHalo = L.circleMarker([endPoint.lat, endPoint.lon], {{
          radius: 8,
          color: "#f97316",
          fillColor: "#f97316",
          fillOpacity: 0.14,
          weight: 2,
          bubblingMouseEvents: false,
        }});
        latestHalo.bindTooltip(`Selected trail latest: ${{endPoint.time || "n/a"}}`, {{ sticky: true, opacity: 0.9 }});
        latestHalo.addTo(trailLayer);
      }}
    }}

    function parseEdgeLastSeenUnix(edge) {{
      const helperUnix = (typeof edgeRxUnix === "function") ? edgeRxUnix(edge, "last") : null;
      if (Number.isFinite(helperUnix) && helperUnix > 0) {{
        return Math.floor(helperUnix);
      }}
      const directUnix = Number(edge && (edge.last_rx_unix ?? edge.last_seen_unix ?? edge.last_unix));
      if (Number.isFinite(directUnix) && directUnix > 0) {{
        return Math.floor(directUnix);
      }}
      const rawLast = String(edge && edge.last_rx_time ? edge.last_rx_time : "").trim();
      if (!rawLast) return null;
      if (typeof parseDashboardTimeToUnix === "function") {{
        const parsedUnix = parseDashboardTimeToUnix(rawLast);
        if (Number.isFinite(parsedUnix) && parsedUnix > 0) {{
          return Math.floor(parsedUnix);
        }}
      }}
      const normalized = rawLast.includes("T") ? rawLast : rawLast.replace(" ", "T");
      const parsedMs = Date.parse(normalized);
      if (!Number.isFinite(parsedMs) || parsedMs <= 0) return null;
      return Math.floor(parsedMs / 1000);
    }}

    function packetLineRecencyFade(lastSeenUnix, nowUnix = Math.floor(Date.now() / 1000)) {{
      const ts = Number(lastSeenUnix);
      if (!Number.isFinite(ts) || ts <= 0) return 1;
      const ageSec = Math.max(0, nowUnix - ts);
      const onlineWindowSec = Math.max(0, Number(chatWarnWindowSeconds) || (10 * 60));
      const staleWindowSec = Math.max(
        onlineWindowSec + 1,
        Number(chatStaleWindowSeconds) || (30 * 60)
      );
      if (ageSec <= onlineWindowSec) return 1;
      if (ageSec >= staleWindowSec) return 0;
      const span = Math.max(1, staleWindowSec - onlineWindowSec);
      return 1 - ((ageSec - onlineWindowSec) / span);
    }}

    function syncMapLinkLegendOffset() {{
      if (!(mapElement instanceof HTMLElement)) return;
      const legend = document.getElementById("map-link-legend");
      const offsetPx = (
        legend instanceof HTMLElement
        && !legend.hidden
        && activeLayoutView === "network"
        && networkSubviewUsesMap(activeNetworkSubview)
      )
        ? Math.ceil(legend.getBoundingClientRect().height + 18)
        : 0;
      mapElement.style.setProperty("--map-link-legend-space", `${{Math.max(0, offsetPx)}}px`);
    }}

    function scheduleMapLinkLegendOffsetSync() {{
      if (mapLinkLegendOffsetRaf !== null) {{
        window.cancelAnimationFrame(mapLinkLegendOffsetRaf);
      }}
      mapLinkLegendOffsetRaf = window.requestAnimationFrame(() => {{
        mapLinkLegendOffsetRaf = null;
        syncMapLinkLegendOffset();
      }});
    }}

    function mapLinkLayerModeParts(modeName = mapLinkLayerMode) {{
      const mode = (typeof mapLinkLayerModeForCurrentView === "function")
        ? mapLinkLayerModeForCurrentView(modeName)
        : normalizeMapLinkLayerMode(modeName);
      return {{
        estimatedLinks: mode !== "none",
        estimated: mode !== "none",
        history: mode === "history" || mode === "both",
        live: mode === "live" || mode === "both",
      }};
    }}

    function mapEstimatedLineTrafficValue(line) {{
      const weight = Math.max(0, Number(line && line.weight) || 0);
      const sessionWeight = Math.max(0, Number(line && line.sessionWeight) || 0);
      const sampleCount = Math.max(0, Number(line && line.sampleCount) || 0);
      return weight + (sessionWeight * 0.65) + (sampleCount * 1.25);
    }}

    function mapEstimatedLineTrafficPct(line, maxTrafficValue) {{
      const trafficValue = mapEstimatedLineTrafficValue(line);
      const maxValue = Math.max(1, Number(maxTrafficValue) || 0, trafficValue);
      return clampMapLinkValue(Math.log1p(trafficValue) / Math.log1p(maxValue), 0.08, 1);
    }}

    function mapEstimatedLineCorridorKey(line) {{
      const fromId = String(line && line.fromId || "").trim().toLowerCase();
      const toId = String(line && line.toId || "").trim().toLowerCase();
      if (!fromId || !toId) return "";
      return fromId < toId ? `${{fromId}}::${{toId}}` : `${{toId}}::${{fromId}}`;
    }}

    function mergeMapEstimatedLineCorridors(lines) {{
      if (!Array.isArray(lines) || lines.length <= 0) return [];
      const corridors = new Map();
      for (const line of lines) {{
        const key = mapEstimatedLineCorridorKey(line);
        if (!key) continue;
        const trafficValue = mapEstimatedLineTrafficValue(line);
        const qualityScore = clampMapLinkValue(Number(line && line.qualityScore), 0.08, 0.98);
        const lastSeenUnix = Number(line && line.lastSeenUnix) || 0;
        const existing = corridors.get(key);
        if (!existing) {{
          corridors.set(key, Object.assign({{}}, line, {{
            key: `corridor::${{key}}`,
            renderCorridorKey: key,
            renderTrafficValue: trafficValue,
            renderQualityWeight: Math.max(0.1, trafficValue),
            renderQualityTotal: qualityScore * Math.max(0.1, trafficValue),
          }}));
          continue;
        }}

        const existingTraffic = Number(existing.renderTrafficValue) || 0;
        const nextTraffic = existingTraffic + trafficValue;
        const qualityWeight = Math.max(0.1, trafficValue);
        existing.renderTrafficValue = nextTraffic;
        existing.renderQualityWeight = (Number(existing.renderQualityWeight) || 0) + qualityWeight;
        existing.renderQualityTotal = (Number(existing.renderQualityTotal) || 0) + (qualityScore * qualityWeight);
        existing.qualityScore = clampMapLinkValue(
          (Number(existing.renderQualityTotal) || 0) / Math.max(0.1, Number(existing.renderQualityWeight) || 0),
          0.08,
          0.98
        );
        existing.weight = Math.max(Number(existing.weight) || 0, Number(line && line.weight) || 0);
        existing.sessionWeight = Math.max(Number(existing.sessionWeight) || 0, Number(line && line.sessionWeight) || 0);
        existing.sampleCount = Math.max(Number(existing.sampleCount) || 0, Number(line && line.sampleCount) || 0);
        existing.lastSeenUnix = Math.max(Number(existing.lastSeenUnix) || 0, lastSeenUnix);
        if (String(line && line.mode || "history").trim().toLowerCase() === "live") {{
          existing.mode = "live";
        }}
      }}
      return Array.from(corridors.values());
    }}

    function mapEstimatedLinkRenderScore(line, nowUnix) {{
      const mode = String((line && line.mode) || "history").trim().toLowerCase() === "live"
        ? "live"
        : "history";
      const qualityScore = clampMapLinkValue(Number(line && line.qualityScore), 0.08, 0.98);
      const trafficValue = Math.max(
        Number(line && line.renderTrafficValue) || 0,
        mapEstimatedLineTrafficValue(line)
      );
      const lastSeenUnix = Number(line && line.lastSeenUnix);
      const ageSeconds = Number.isFinite(lastSeenUnix) && lastSeenUnix > 0
        ? Math.max(0, nowUnix - lastSeenUnix)
        : Number.POSITIVE_INFINITY;
      const recencyScore = Number.isFinite(ageSeconds)
        ? clampMapLinkValue(1 - (ageSeconds / (60 * 60 * 6)), 0, 1)
        : 0;
      return (
        (Math.log1p(trafficValue) * 2.2)
        + (qualityScore * 0.38)
        + (recencyScore * 0.2)
        + (mode === "live" ? 0.08 : 0)
      );
    }}

    function selectMapEstimatedLinesForRender(lines, options = null) {{
      const opts = (options && typeof options === "object") ? options : {{}};
      const maxLines = Math.max(0, Math.trunc(Number(opts.maxLines) || 18));
      if (maxLines <= 0 || !Array.isArray(lines) || lines.length <= 0) return [];
      const nowUnix = Math.floor(Date.now() / 1000);
      const validLines = lines.filter((line) => (
        line
        && isValidMapCoord(Number(line.fromLat), Number(line.fromLon))
        && isValidMapCoord(Number(line.toLat), Number(line.toLon))
      ));
      const corridorLines = mergeMapEstimatedLineCorridors(validLines);
      const maxTrafficValue = corridorLines.reduce((maxValue, line) => (
        Math.max(maxValue, Number(line && line.renderTrafficValue) || mapEstimatedLineTrafficValue(line))
      ), 0);
      const rankedLines = corridorLines
        .map((line, index) => ({{
          line: Object.assign({{}}, line, {{
            renderTrafficPct: mapEstimatedLineTrafficPct(line, maxTrafficValue),
          }}),
          index,
          score: mapEstimatedLinkRenderScore(line, nowUnix),
        }}))
        .sort((a, b) => (
          (b.score - a.score)
          || ((Number(b.line && b.line.renderTrafficValue) || 0) - (Number(a.line && a.line.renderTrafficValue) || 0))
          || (a.index - b.index)
        ));
      if (rankedLines.length <= maxLines) return rankedLines.map((entry) => entry.line);
      return rankedLines
        .slice(0, maxLines)
        .map((entry) => entry.line);
    }}

    function refreshNetworkMapAfterLegendControlChange(options = null) {{
      const opts = (options && typeof options === "object") ? options : {{}};
      updateMapPacketLinesControl();
      updateMapLinkLayerControl();
      lastMapSignature = "";
      lastMapGraphSignature = "";
      lastMapRenderMode = "";
      if (latestState && activeLayoutView === "network" && networkSubviewUsesMap(activeNetworkSubview)) {{
        renderMap(
          latestState.nodes || [],
          (latestState.traffic || {{}}).edges || [],
          null,
          {{
            bypassHeatmapFade: !!opts.bypassHeatmapFade,
            bypassNodeFade: !!opts.bypassNodeFade,
          }}
        );
      }}
    }}

    function countMapPacketLineCandidates(nodes, edges) {{
      const byId = Object.create(null);
      for (const node of (nodes || [])) {{
        byId[normalizeNodeId(node && node.id)] = node;
      }}
      let count = 0;
      for (const edge of (edges || [])) {{
        const isReal = !!(edge && edge.is_real);
        if (!isReal) continue;
        const src = byId[normalizeNodeId(edge && edge.from)];
        const dst = byId[normalizeNodeId(edge && edge.to)];
        if (!src || !dst) continue;
        if (!isValidMapCoord(Number(src.lat), Number(src.lon))) continue;
        if (!isValidMapCoord(Number(dst.lat), Number(dst.lon))) continue;
        count += 1;
      }}
      return count;
    }}

    function supportsLinkEstimateHeatmap() {{
      return !!(window.L && typeof L.heatLayer === "function");
    }}

    function ensureLinkEstimateHeatmapLayer() {{
      if (!supportsLinkEstimateHeatmap()) return null;
      if (linkEstimateHeatmapLayer) return linkEstimateHeatmapLayer;
      let pane = map.getPane(linkEstimateHeatmapPaneName);
      if (!pane) {{
        pane = map.createPane(linkEstimateHeatmapPaneName);
      }}
      if (pane) {{
        pane.style.zIndex = "432";
        pane.style.pointerEvents = "none";
      }}
      linkEstimateHeatmapLayer = L.heatLayer(
        [],
        Object.assign(
          {{
            pane: linkEstimateHeatmapPaneName,
            radius: 30,
            blur: 24,
            minOpacity: 0.22,
          }},
          linkEstimateHeatmapLayerOptions || {{}}
        )
      );
      return linkEstimateHeatmapLayer;
    }}

    function clearLinkEstimateHeatmapLayer(options = null) {{
      if (!linkEstimateHeatmapLayer) return;
      const opts = (options && typeof options === "object") ? options : {{}};
      const layer = linkEstimateHeatmapLayer;
      const removeNow = () => {{
        cancelMapHeatLayerDrift(layer, true);
        cancelMapHeatLayerOpacityFade(layer);
        if (layer._frame && window.L && L.Util && typeof L.Util.cancelAnimFrame === "function") {{
          try {{
            L.Util.cancelAnimFrame(layer._frame);
          }} catch (_err) {{
          }}
          layer._frame = null;
        }}
        if (map.hasLayer(layer)) {{
          map.removeLayer(layer);
        }}
      }};
      const canFade = opts.fade !== false
        && typeof fadeOutMapHeatLayer === "function"
        && map.hasLayer(layer);
      if (!canFade) {{
        removeNow();
        return;
      }}
      fadeOutMapHeatLayer(layer, {{
        keyPrefix: "estimate",
        durationMs: mapHeatLayerFadeOutMs,
        onComplete: removeNow,
      }});
    }}

    function syncLinkEstimateHeatmapLayer(linkDensity = null, show = false, options = null) {{
      const opts = (options && typeof options === "object") ? options : {{}};
      const bypassFade = !!opts.bypassFade;
      const layer = ensureLinkEstimateHeatmapLayer();
      if (!layer) return;
      const mapDrawable = (
        typeof signalHeatmapMapHasDrawableSize === "function"
          ? signalHeatmapMapHasDrawableSize()
          : true
      );
      const heatPoints = (
        mapDrawable
        &&
        linkDensity
        && Array.isArray(linkDensity.heatPoints)
      )
        ? linkDensity.heatPoints
        : [];
      const shouldShow = !!show && mapDrawable && heatPoints.length > 0;
      if (!shouldShow) {{
        clearLinkEstimateHeatmapLayer({{ fade: !bypassFade }});
        return;
      }}
      const layerAlreadyVisible = map.hasLayer(layer);
      if (!layerAlreadyVisible) {{
        layer.addTo(map);
        setMapHeatLayerCanvasOpacity(layer, bypassFade ? 1 : 0);
      }}
      if (typeof forceHeatLayerPointerPassthrough === "function") {{
        forceHeatLayerPointerPassthrough(layer);
      }}
      if (bypassFade) {{
        cancelMapHeatLayerOpacityFade(layer);
        setMapHeatLayerCanvasOpacity(layer, 1);
      }}
      animateMapHeatLayerLatLngs(layer, heatPoints, {{
        keyPrefix: "estimate",
        durationMs: mapEstimatedOverlayDriftMs,
      }});
      if (!bypassFade) {{
        animateMapHeatLayerCanvasOpacity(layer, 1, {{
          durationMs: mapHeatLayerFadeInMs,
        }});
      }}
    }}

