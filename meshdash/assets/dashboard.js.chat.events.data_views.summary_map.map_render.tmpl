    function renderMapLinkLegend(nodes = [], rawEdges = [], estimatedPositions = new Map(), linkOverlay = null) {{
      const legend = document.getElementById("map-link-legend");
      if (!(legend instanceof HTMLElement)) return;
      if (activeLayoutView !== "network" || !networkSubviewUsesMap(activeNetworkSubview)) {{
        legend.innerHTML = "";
        legend.hidden = true;
        scheduleMapLinkLegendOffsetSync();
        return;
      }}
      const actualCount = (nodes || []).reduce((count, node) => (
        count + (isValidMapCoord(Number(node && node.lat), Number(node && node.lon)) ? 1 : 0)
      ), 0);
      let linkedCount = 0;
      let trilateratedCount = 0;
      if (estimatedPositions instanceof Map) {{
        for (const estimate of estimatedPositions.values()) {{
          const estimateSource = String(estimate && estimate.estimateSource || "").trim();
          if (estimateSource === "rssi_trilateration") {{
            trilateratedCount += 1;
          }} else {{
            linkedCount += 1;
          }}
        }}
      }}
      const packetCount = countMapPacketLineCandidates(nodes, rawEdges);
      const lines = (linkOverlay && Array.isArray(linkOverlay.lines)) ? linkOverlay.lines : [];
      const linkDensity = (linkOverlay && linkOverlay.linkDensity && typeof linkOverlay.linkDensity === "object")
        ? linkOverlay.linkDensity
        : null;
      const inferredHeatmapEnabled = !!mapEstimatedNodeCloudsEnabled;
      const rawRenderedEstimatedLineCount = Number(linkOverlay && linkOverlay.renderedEstimatedLineCount);
      const renderedEstimatedLineCount = Number.isFinite(rawRenderedEstimatedLineCount)
        ? Math.max(0, Math.trunc(rawRenderedEstimatedLineCount))
        : -1;
      const estimatedCount = renderedEstimatedLineCount >= 0
        ? renderedEstimatedLineCount
        : lines.length;
      const modeParts = mapLinkLayerModeParts(mapLinkLayerMode);
      const estimatedLinksEnabled = !!modeParts.estimatedLinks;
      const signalHeatProfile = resolveSignalHeatProfile();
      const signalHeatmapSupported = supportsSignalHeatmap();
      const signalCoverageBuckets = signalHeatmapSupported
        ? collectSignalHeatmapBuckets(nodes, signalHeatProfile, "coverage")
        : [];
      const signalLiveBuckets = signalHeatmapSupported
        ? collectSignalHeatmapBuckets(nodes, signalHeatProfile, "live")
        : [];
      const signalCoveragePointCount = signalCoverageBuckets.reduce((count, bucket) => (
        count + (Array.isArray(bucket) ? bucket.length : 0)
      ), 0);
      const signalLivePointCount = signalLiveBuckets.reduce((count, bucket) => (
        count + (Array.isArray(bucket) ? bucket.length : 0)
      ), 0);
      const inferredHeatmapCount = Math.max(
        0,
        Math.trunc(Number(linkDensity && (linkDensity.cloudCount || linkDensity.corePointCount)) || 0)
      );
      legend.hidden = false;
      legend.innerHTML = `
        <div class="map-link-legend-title">Map layers</div>
        <div class="map-link-legend-list">
          <label class="map-link-legend-item is-toggle is-heatmap" style="--map-link-legend-color:#d9951a;" title="Show amber historical signal coverage">
            <input class="map-link-legend-input" type="checkbox" data-map-link-legend-toggle="signal-coverage"${{signalHeatmapCoverageEnabled ? " checked" : ""}} aria-label="Show signal coverage heatmap" />
            <span class="map-link-legend-swatch is-signal-coverage-heat" aria-hidden="true"></span>
            <span class="map-link-legend-name">Coverage</span>
            <span class="map-link-legend-count">${{signalCoveragePointCount}}</span>
          </label>
          <label class="map-link-legend-item is-toggle is-heatmap" style="--map-link-legend-color:#0a9396;" title="Show cyan live signal heatmap over coverage">
            <input class="map-link-legend-input" type="checkbox" data-map-link-legend-toggle="signal-live"${{signalHeatmapLiveEnabled ? " checked" : ""}} aria-label="Show live signal heatmap" />
            <span class="map-link-legend-swatch is-signal-live-heat" aria-hidden="true"></span>
            <span class="map-link-legend-name">Live</span>
            <span class="map-link-legend-count">${{signalLivePointCount}}</span>
          </label>
          <label class="map-link-legend-item is-toggle is-heatmap" style="--map-link-legend-color:#5fa4ff;" title="Show inferred node density heatmap">
            <input class="map-link-legend-input" type="checkbox" data-map-link-legend-toggle="estimated-heatmap"${{inferredHeatmapEnabled ? " checked" : ""}} aria-label="Show inferred heatmap" />
            <span class="map-link-legend-swatch is-cloud-heat" aria-hidden="true"></span>
            <span class="map-link-legend-name">Inferred heatmap</span>
            <span class="map-link-legend-count">${{inferredHeatmapCount}}</span>
          </label>
          <label class="map-link-legend-item is-toggle" style="--map-link-legend-color:#35b96f;" title="Show nodes with direct GPS or fixed position data">
            <input class="map-link-legend-input" type="checkbox" data-map-link-legend-toggle="real-nodes"${{mapActualNodesEnabled ? " checked" : ""}} aria-label="Show real nodes" />
            <span class="map-link-legend-swatch is-node-actual" aria-hidden="true"></span>
            <span class="map-link-legend-name">Real nodes</span>
            <span class="map-link-legend-count">${{actualCount}}</span>
          </label>
          <label class="map-link-legend-item is-toggle" style="--map-link-legend-color:#68bde8;" title="Show nodes positioned by link topology">
            <input class="map-link-legend-input" type="checkbox" data-map-link-legend-toggle="link-inferred-nodes"${{mapLinkInferredNodesEnabled ? " checked" : ""}} aria-label="Show link-inferred nodes" />
            <span class="map-link-legend-swatch is-node-linked" aria-hidden="true"></span>
            <span class="map-link-legend-name">Link-inferred nodes</span>
            <span class="map-link-legend-count">${{linkedCount}}</span>
          </label>
          <label class="map-link-legend-item is-toggle" style="--map-link-legend-color:#cc79a7;" title="Show nodes positioned by RSSI/SNR trilateration against known GPS anchors">
            <input class="map-link-legend-input" type="checkbox" data-map-link-legend-toggle="rssi-trilaterated-nodes"${{mapRssiTrilateratedNodesEnabled ? " checked" : ""}} aria-label="Show RSSI trilaterated nodes" />
            <span class="map-link-legend-swatch is-node-trilaterated" aria-hidden="true"></span>
            <span class="map-link-legend-name">RSSI trilaterated</span>
            <span class="map-link-legend-count">${{trilateratedCount}}</span>
          </label>
          <label class="map-link-legend-item is-toggle" style="--map-link-legend-color:#bf1f43;" title="Show confirmed packet lines between positioned nodes">
            <input class="map-link-legend-input" type="checkbox" data-map-link-legend-toggle="packet"${{mapPacketLinesEnabled ? " checked" : ""}} aria-label="Show real links" />
            <span class="map-link-legend-swatch is-packet-line" aria-hidden="true"></span>
            <span class="map-link-legend-name">Real links</span>
            <span class="map-link-legend-count">${{packetCount}}</span>
          </label>
          <label class="map-link-legend-item is-toggle" style="--map-link-legend-color:#5fa4ff;" title="Show the most-used link-inferred paths built from observed evidence.">
            <input class="map-link-legend-input" type="checkbox" data-map-link-legend-toggle="estimated"${{estimatedLinksEnabled ? " checked" : ""}} aria-label="Show common link-inferred paths" />
            <span class="map-link-legend-swatch is-link-heat" aria-hidden="true"></span>
            <span class="map-link-legend-name">Common paths</span>
            <span class="map-link-legend-count">${{estimatedCount}}</span>
          </label>
        </div>
      `;
      bindMapLinkLegendControls(legend);
      scheduleMapLinkLegendOffsetSync();
    }}

    function renderMap(nodes, edges, nodeHistory = null, options = null) {{
      const renderOpts = (options && typeof options === "object") ? options : {{}};
      const bypassHeatmapFade = !!renderOpts.bypassHeatmapFade;
      const bypassNodeFade = !!renderOpts.bypassNodeFade;
      ensureMapSizeSync();
      const hideHeatmap = activeLayoutView === "saved";
      const mapRenderEdges = edges;
      const signatures = buildMapSignatures(nodes, mapRenderEdges, nodeHistory);
      const signature = signatures.signature;
      const graphSignature = signatures.graphSignature;
      const savedSelectionMode = signatures.savedSelectionMode;
      const networkSelectionMode = signatures.networkSelectionMode;
      const selectionId = signatures.selection;

      syncSignalHeatmapLayer(nodes, hideHeatmap, {{ bypassFade: bypassHeatmapFade }});
      refreshMapCardTitle();
      updateMapPacketLinesControl();
      updateMapLinkLayerControl();

      if (savedSelectionMode) {{
        if (signature === lastMapSignature && lastMapRenderMode === "saved") {{
          ensureMapSizeSync();
          updateMapSelection(false);
          return;
        }}

        nodeLayer.clearLayers();
        edgeLayer.clearLayers();
        trailLayer.clearLayers();
        for (const line of linkEstimateLines.values()) {{
          cancelMapPolylineDrift(line);
        }}
        for (const marker of nodeMarkers.values()) {{
          cancelMapMarkerDrift(marker);
        }}
        linkEstimateLayer.clearLayers();
        clearLinkEstimateHeatmapLayer({{ fade: !bypassHeatmapFade }});
        renderMapLinkLegend();
        nodeMarkers.clear();
        nodeMarkerMeta.clear();
        nodeMarkerKinds.clear();
        nodeMarkerConfidence.clear();
        edgeLines.clear();
        edgeLineMeta.clear();
        linkEstimateLines.clear();
        linkEstimateLineMeta.clear();

        const historyCapsById = new Map(
          Object.entries((latestState && latestState.history_caps && typeof latestState.history_caps === "object") ? latestState.history_caps : {{}})
            .map(([rawNodeId, caps]) => [normalizeNodeId(rawNodeId), caps])
            .filter(([nodeId, caps]) => isSelectableNodeId(nodeId) && caps && typeof caps === "object")
        );
        const nowUnix = Math.floor(Date.now() / 1000);
        const selectedNode = savedViewNodeFrom(nodes, latestState);
        const selectedNodeIdNormalized = normalizeNodeId((selectedNode && selectedNode.id) || "");
        const hasSelectedPosition = !!selectedNode
          && typeof selectedNode.lat === "number"
          && typeof selectedNode.lon === "number";
        const trailPoints = collectTrailPoints(nodeHistory, selectionId);

        if (trailPoints.length >= 2) {{
          const line = L.polyline(
            trailPoints.map((point) => [point.lat, point.lon]),
            {{
              color: "#d06a1b",
              opacity: 0.78,
              weight: 4,
              lineCap: "round",
              lineJoin: "round",
            }}
          );
          line.bindTooltip(`Location trail (${{trailPoints.length}} points)`, {{ sticky: true, opacity: 0.9 }});
          line.addTo(trailLayer);
        }}
        if (trailPoints.length > 0) {{
          const endPoint = trailPoints[trailPoints.length - 1];
          for (let i = 0; i < trailPoints.length; i += 1) {{
            const point = trailPoints[i];
            const isLatestPoint = i === (trailPoints.length - 1);
            const ratio = trailPoints.length <= 1 ? 1 : (i / (trailPoints.length - 1));
            const marker = L.circleMarker([point.lat, point.lon], {{
              radius: isLatestPoint ? 5.8 : (i === 0 ? 3.6 : 2.6),
              color: isLatestPoint ? "#f97316" : "#2f855a",
              fillColor: isLatestPoint ? "#f97316" : "#63d297",
              fillOpacity: isLatestPoint ? 0.96 : (0.2 + (ratio * 0.5)),
              weight: isLatestPoint ? 2 : 1,
              bubblingMouseEvents: false,
            }});
            const pointTime = point.time || "n/a";
            marker.bindTooltip(
              isLatestPoint
                ? `Newest trail point: ${{pointTime}}`
                : `Trail point ${{i + 1}}/${{trailPoints.length}}: ${{pointTime}}`,
              {{ sticky: true, opacity: 0.88 }}
            );
            marker.addTo(trailLayer);
          }}

          const latestHalo = L.circleMarker([endPoint.lat, endPoint.lon], {{
            radius: 10,
            color: "#f97316",
            fillColor: "#f97316",
            fillOpacity: 0.16,
            weight: 2,
            bubblingMouseEvents: false,
          }});
          latestHalo.bindTooltip(`Newest trail point: ${{endPoint.time || "n/a"}}`, {{ sticky: true, opacity: 0.9 }});
          latestHalo.addTo(trailLayer);
        }}

        if (hasSelectedPosition) {{
          const trailPointsCount = trailPoints.length;
          const trailLast = trailPointsCount > 0
            ? (trailPoints[trailPointsCount - 1].time || "n/a")
            : "n/a";
          const selectedCaps = historyCapsById.get(selectionId) || null;
          const posBadge = resolveMapPositionBadge(selectedNode, selectedCaps, nowUnix);
          const marker = createMapNodeMarker(
            selectedNode.lat,
            selectedNode.lon,
            selectedNodeIdNormalized,
            true,
            "actual",
            1,
            latestState
          );
          bindMapNodeInfoOverlays(marker, selectedNode, {{
            nodeId: selectedNodeIdNormalized,
            nowUnix,
            state: latestState,
            caps: selectedCaps,
            positionBadge: posBadge,
            trailPointsCount: trailPointsCount,
            trailLatest: trailLast,
            suppressHoverTooltip: true,
          }});
          marker.on("click", () => {{
            selectNode(normalizeNodeId(selectedNode.id || ""), true, false);
          }});
          marker.addTo(nodeLayer);
          nodeMarkers.set(normalizeNodeId(selectedNode.id || ""), marker);
          nodeMarkerKinds.set(normalizeNodeId(selectedNode.id || ""), "actual");
          nodeMarkerConfidence.set(normalizeNodeId(selectedNode.id || ""), 1);
          if (trailPoints.length > 1) {{
            const trailBounds = L.latLngBounds(trailPoints.map((point) => [point.lat, point.lon]));
            trailBounds.extend([selectedNode.lat, selectedNode.lon]);
            if (trailBounds.isValid()) {{
              map.fitBounds(trailBounds.pad(0.2), {{ animate: false, maxZoom: 16 }});
            }}
          }} else {{
            map.setView([selectedNode.lat, selectedNode.lon], Math.max(map.getZoom(), 11), {{ animate: false }});
          }}
          marker.openPopup();
        }} else if (trailPoints.length > 0) {{
          const trailBounds = L.latLngBounds(trailPoints.map((point) => [point.lat, point.lon]));
          if (trailBounds.isValid()) {{
            map.fitBounds(trailBounds.pad(0.2), {{ animate: false, maxZoom: 16 }});
          }}
        }} else {{
          map.closePopup();
        }}

        lastMapSignature = signature;
        lastMapGraphSignature = "";
        lastMapRenderMode = "saved";
        requestMapResize();
        return;
      }}

      const effectiveMapLinkMode = (typeof mapLinkLayerModeForCurrentView === "function")
        ? mapLinkLayerModeForCurrentView(mapLinkLayerMode)
        : normalizeMapLinkLayerMode(mapLinkLayerMode);
      let estimatedPositions = new Map();
      const graphChanged = lastMapRenderMode !== "graph" || graphSignature !== lastMapGraphSignature;
      const shouldRenderGraph = graphChanged || !!mapEstimatedPositionSmoothingActive;
      const allowEstimatedNodeFade = !!networkMapGraphRenderSeen && !bypassNodeFade;
      if (!shouldRenderGraph && signature === lastMapSignature) {{
        ensureMapSizeSync();
        if (activeLayoutView === "network" && !fitDone) {{
          // View-switch fast path: still run initial network auto-fit even when map data is unchanged.
          const didFit = fitMapToMostNodes(nodes, {{ pad: 0.18, maxZoom: 13 }});
          if (didFit) {{
            fitDone = true;
          }} else {{
            requestMapResize();
          }}
        }}
        updateMapSelection(false);
        return;
      }}

      if (shouldRenderGraph) {{
        const byId = Object.create(null);
        for (const node of (nodes || [])) {{
          byId[normalizeNodeId(node && node.id)] = node;
        }}
        const inferredHeatmapEnabled = !!mapEstimatedNodeCloudsEnabled;
        const needsMapLinkEstimateOverlay = (
          activeLayoutView === "network"
        );
        const rawLinkOverlayUnsmoothed = needsMapLinkEstimateOverlay
          ? buildMapLinkLayerOverlay(nodes, mapRenderEdges, {{
              mode: effectiveMapLinkMode !== "none" ? effectiveMapLinkMode : "both",
            }})
          : {{ estimates: new Map(), lines: [] }};
        const densitySourceOverlayUnsmoothed = needsMapLinkEstimateOverlay
          ? buildMapLinkLayerOverlay(nodes, mapRenderEdges, {{ mode: "both" }})
          : {{ estimates: new Map(), lines: [] }};
        const densitySourceOverlay = smoothMapLinkLayerOverlay(densitySourceOverlayUnsmoothed, {{
          updateCache: true,
        }});
        const rawLinkOverlay = smoothMapLinkLayerOverlay(rawLinkOverlayUnsmoothed, {{
          updateCache: false,
        }});
        const linkDensity = (
          needsMapLinkEstimateOverlay
          && typeof buildMapLinkEstimateDensityOverlay === "function"
        )
          ? buildMapLinkEstimateDensityOverlay(densitySourceOverlay, {{
              byId,
              localNodeId: normalizeNodeId(resolveLocalNodeId(latestState || {}) || ""),
            }})
          : null;
        const linkOverlay = Object.assign({{}}, rawLinkOverlay, {{
          linkDensity,
        }});
        const showEstimatedLinks = activeLayoutView === "network" && effectiveMapLinkMode !== "none";
        const estimateLinesAvailable = showEstimatedLinks
          ? (Array.isArray(linkOverlay.lines) ? linkOverlay.lines.slice() : [])
          : [];
        const estimateLinesToRender = selectMapEstimatedLinesForRender(estimateLinesAvailable, {{
          maxLines: 18,
        }});
        linkOverlay.renderedEstimatedLineCount = estimateLinesToRender.length;
        linkOverlay.availableEstimatedLineCount = estimateLinesAvailable.length;
        estimatedPositions = linkOverlay.estimates instanceof Map
          ? linkOverlay.estimates
          : new Map();
        const historyCapsById = new Map(
          Object.entries((latestState && latestState.history_caps && typeof latestState.history_caps === "object") ? latestState.history_caps : {{}})
            .map(([rawNodeId, caps]) => [normalizeNodeId(rawNodeId), caps])
            .filter(([nodeId, caps]) => isSelectableNodeId(nodeId) && caps && typeof caps === "object")
        );
        cacheNetworkMapActivityPositions(nodes, estimatedPositions);
        cacheMapEstimatedCorridorActivityPaths(estimateLinesToRender);
        const nowUnix = Math.floor(Date.now() / 1000);
        const seenNodeIds = new Set();

        for (const node of (nodes || [])) {{
          const normalizedId = normalizeNodeId(node.id || "");
          const rawLat = Number(node && node.lat);
          const rawLon = Number(node && node.lon);
          const hasActualPosition = isValidMapCoord(rawLat, rawLon);
          const estimate = hasActualPosition ? null : (estimatedPositions.get(normalizedId) || null);
          const markerLat = hasActualPosition ? rawLat : Number(estimate && estimate.lat);
          const markerLon = hasActualPosition ? rawLon : Number(estimate && estimate.lon);
          const isEstimated = !hasActualPosition && !!estimate;
          const estimateSource = isEstimated ? String(estimate && estimate.estimateSource || "").trim() : "";
          const markerKind = isEstimated
            ? (estimateSource === "rssi_trilateration" ? "trilaterated" : "estimated")
            : "actual";
          const markerKindVisible = markerKind === "actual"
            ? !!mapActualNodesEnabled
            : (markerKind === "trilaterated" ? !!mapRssiTrilateratedNodesEnabled : !!mapLinkInferredNodesEnabled);
          if (!markerKindVisible) continue;
          if (!isValidMapCoord(markerLat, markerLon)) continue;
          const isSelected = !!selectedNodeId && normalizedId === selectedNodeId;
          const nodeCaps = historyCapsById.get(normalizedId) || null;
          const posBadge = resolveMapPositionBadge(node, nodeCaps, nowUnix);
          let markerHash = 2166136261;
          markerHash = hashMixStr(markerHash, "network-node");
          markerHash = hashMixStr(markerHash, normalizedId);
          markerHash = hashMixInt(markerHash, Math.round(markerLat * 100000));
          markerHash = hashMixInt(markerHash, Math.round(markerLon * 100000));
          markerHash = hashMixInt(markerHash, isSelected ? 1 : 0);
          markerHash = hashMixInt(markerHash, isEstimated ? 1 : 0);
          markerHash = hashMixStr(markerHash, node && (node.num ?? ""));
          markerHash = hashMixStr(markerHash, node && (node.snr ?? ""));
          markerHash = hashMixStr(markerHash, node && (node.rssi ?? ""));
          markerHash = hashMixStr(
            markerHash,
            (typeof nodeLastHeardLabel === "function")
              ? nodeLastHeardLabel(node, "n/a", nowUnix)
              : (node && (node.last_heard || ""))
          );
          markerHash = hashMixStr(markerHash, isEstimated ? markerKind : posBadge.className);
          markerHash = hashMixInt(
            markerHash,
            isEstimated
              ? Math.round(Number(estimate && estimate.confidence) * 1000)
              : 1000
          );
          markerHash = hashMixInt(
            markerHash,
            normalizeNodeId(resolveLocalNodeId(latestState || {}) || "") === normalizedId ? 1 : 0
          );
          markerHash = hashMixStr(
            markerHash,
            resolveMapNodeEmoji(normalizedId, latestState)
          );
          markerHash = hashMixInt(markerHash, isEstimated ? Math.trunc(Number(estimate && estimate.anchorCount) || 0) : 0);
          markerHash = hashMixInt(markerHash, isEstimated ? Math.trunc(Number(estimate && estimate.supportLinks) || 0) : 0);
          markerHash = hashMixInt(markerHash, isEstimated ? (Math.round(Number(estimate && estimate.fitScore) * 1000) || 0) : 1000);
          markerHash = hashMixInt(markerHash, isEstimated ? (Math.round(Number(estimate && estimate.residualKm) * 10) || 0) : 0);
          const existingMarker = nodeMarkers.get(normalizedId);
          const prevMarkerHash = nodeMarkerMeta.get(normalizedId);
          const existingMarkerKind = nodeMarkerKinds.get(normalizedId) || "";
          const markerConfidence = isEstimated ? Number(estimate && estimate.confidence) : 1;
          let fadeExistingEstimatedMarkerOut = false;
          if (existingMarker && (existingMarkerKind === "estimated" || existingMarkerKind === "trilaterated")) {{
            if (!isEstimated) {{
              fadeExistingEstimatedMarkerOut = true;
            }} else if (typeof existingMarker.getLatLng === "function") {{
              const prevLatLng = existingMarker.getLatLng();
              const markerDriftMeters = mapEstimatedPositionDistanceMeters(
                {{ lat: Number(prevLatLng && prevLatLng.lat), lon: Number(prevLatLng && prevLatLng.lng) }},
                {{ lat: markerLat, lon: markerLon }}
              );
              fadeExistingEstimatedMarkerOut = (
                Number.isFinite(markerDriftMeters)
                && markerDriftMeters > mapEstimatedOverlayMaxDriftMeters
              );
            }}
          }}
          seenNodeIds.add(normalizedId);
          const existingMarkerFadingOut = !!(
            existingMarker
            && typeof mapNodeMarkerIsFadingOut === "function"
            && mapNodeMarkerIsFadingOut(existingMarker)
          );
          if (existingMarker && prevMarkerHash === markerHash && !existingMarkerFadingOut) {{
            continue;
          }}
          const desiredUsesEmojiMarker = !!(
            typeof mapNodeUsesEmojiMarker === "function"
            && mapNodeUsesEmojiMarker(normalizedId, markerKind, latestState)
          );
          const existingUsesEmojiMarker = !!(existingMarker && typeof existingMarker.setIcon === "function");
          const canDriftExistingEstimatedMarker = !!(
            existingMarker
            && (existingMarkerKind === "estimated" || existingMarkerKind === "trilaterated")
            && isEstimated
            && !fadeExistingEstimatedMarkerOut
            && desiredUsesEmojiMarker === existingUsesEmojiMarker
          );
          let marker = null;
          if (canDriftExistingEstimatedMarker) {{
            marker = existingMarker;
            const activeFadeState = (marker._meshMapNodeMarkerFadeAnimation && typeof marker._meshMapNodeMarkerFadeAnimation === "object")
              ? marker._meshMapNodeMarkerFadeAnimation
              : null;
            const activeFadeScale = activeFadeState
              ? (typeof mapNodeMarkerFadeScale === "function"
                ? mapNodeMarkerFadeScale(
                  marker,
                  Number(activeFadeState.toScale) > Number(activeFadeState.fromScale) ? 0 : 1
                )
                : (Number.isFinite(Number(activeFadeState.currentScale))
                  ? clampMapLinkValue(Number(activeFadeState.currentScale), 0, 1)
                  : (Number(activeFadeState.toScale) > Number(activeFadeState.fromScale) ? 0 : 1)))
              : 1;
            if (!activeFadeState) {{
              const fadeBaseStyle = marker._meshMapNodeMarkerFadeBaseStyle || null;
              cancelMapNodeMarkerFade(marker);
              setMapNodeMarkerOpacityScale(marker, 1, fadeBaseStyle);
              marker._meshMapNodeMarkerFadeBaseStyle = null;
              refreshMapNodeMarkerPresentation(
                marker,
                normalizedId,
                isSelected,
                markerKind,
                markerConfidence,
                latestState
              );
            }} else {{
              const activeFadeBaseStyle = resolveMapNodeMarkerStyle(
                normalizedId,
                isSelected,
                markerKind,
                markerConfidence,
                latestState
              );
              if (isSelected) {{
                if (typeof marker.closeTooltip === "function") {{
                  marker.closeTooltip();
                }}
                if (typeof marker.unbindTooltip === "function") {{
                  marker.unbindTooltip();
                }}
              }}
              marker._meshMapNodeMarkerFadeBaseStyle = activeFadeBaseStyle;
              setMapNodeMarkerOpacityScale(marker, activeFadeScale, activeFadeBaseStyle);
              if (existingMarkerFadingOut) {{
                fadeInMapNodeMarker(marker, {{
                  layerGroup: nodeLayer,
                  durationMs: mapEstimatedOverlayLongJumpFadeMs,
                  baseStyle: activeFadeBaseStyle,
                  fromScale: activeFadeScale,
                  primeElementOpacity: false,
                }});
              }}
            }}
            if (typeof animateMapMarkerLatLng === "function") {{
              animateMapMarkerLatLng(marker, [markerLat, markerLon], {{
                durationMs: mapEstimatedOverlayDriftMs,
              }});
            }} else if (typeof marker.setLatLng === "function") {{
              marker.setLatLng([markerLat, markerLon]);
            }}
          }}
          if (existingMarker && !canDriftExistingEstimatedMarker) {{
            if (fadeExistingEstimatedMarkerOut && allowEstimatedNodeFade) {{
              cancelMapNodeMarkerFade(existingMarker);
              cancelMapMarkerDrift(existingMarker);
              nodeLayer.removeLayer(existingMarker);
            }} else {{
              cancelMapNodeMarkerFade(existingMarker);
              cancelMapMarkerDrift(existingMarker);
              nodeLayer.removeLayer(existingMarker);
            }}
            nodeMarkers.delete(normalizedId);
          }}
          const fadeEstimatedMarkerIn = !!(
            allowEstimatedNodeFade
            &&
            isEstimated
            && (
              !existingMarker
              || existingMarkerKind !== markerKind
              || fadeExistingEstimatedMarkerOut
            )
          );
          let fadeEstimatedMarkerBaseStyle = null;
          let fadeEstimatedMarkerInitialStyle = null;
          if (fadeEstimatedMarkerIn) {{
            fadeEstimatedMarkerBaseStyle = resolveMapNodeMarkerStyle(
              normalizedId,
              isSelected,
              markerKind,
              markerConfidence,
              latestState
            );
            fadeEstimatedMarkerInitialStyle = mapNodeMarkerStyleWithOpacityScale(fadeEstimatedMarkerBaseStyle, 0);
          }}
          if (!marker) {{
            marker = createMapNodeMarker(
              markerLat,
              markerLon,
              normalizedId,
              isSelected,
              markerKind,
              markerConfidence,
              latestState,
              fadeEstimatedMarkerInitialStyle
                ? {{
                  initialStyle: fadeEstimatedMarkerInitialStyle,
                  initialElementOpacity: 0,
                }}
                : null
            );
          }}
          if (isEstimated) {{
            const confidenceValue = clampMapLinkValue(Number(estimate && estimate.confidence), 0, 1);
            const confidenceLabel = mapLinkConfidenceLabel(confidenceValue);
            const qualityPct = Math.round(clampMapLinkValue(Number(estimate && estimate.avgLinkQuality), 0, 1) * 100);
            const estimateSource = String(estimate && estimate.estimateSource || "").trim();
            const estimatedLocationLabel = estimateSource === "rssi_trilateration"
              ? "RSSI trilaterated"
              : "Link-inferred";
            const estimatedPositionTitle = estimateSource === "rssi_trilateration"
              ? "Position is trilaterated from RSSI/SNR ranges to known GPS anchors."
              : "Position is inferred from link topology rather than a direct GPS fix.";
            bindMapNodeInfoOverlays(marker, node, {{
              nodeId: normalizedId,
              nowUnix,
              state: latestState,
              isEstimated: true,
              positionBadge: {{
                label: "Inferred",
                className: "history",
                title: estimatedPositionTitle,
              }},
              estimatedLocationLabel,
              confidenceLabel,
              confidencePct: confidenceValue * 100,
              qualityPct,
              fitPct: clampMapLinkValue(Number(estimate && estimate.fitScore), 0, 1) * 100,
              residualKm: estimate && estimate.residualKm != null ? estimate.residualKm : null,
              anchorCount: estimate && estimate.anchorCount ? estimate.anchorCount : 0,
              supportLinks: estimate && estimate.supportLinks ? estimate.supportLinks : 0,
              avgHops: estimate && estimate.avgHops != null ? estimate.avgHops : null,
              avgSnr: estimate && estimate.avgSnr != null ? estimate.avgSnr : null,
              avgRssi: estimate && estimate.avgRssi != null ? estimate.avgRssi : null,
              suppressHoverTooltip: isSelected,
            }});
          }} else {{
            bindMapNodeInfoOverlays(marker, node, {{
              nodeId: normalizedId,
              nowUnix,
              state: latestState,
              caps: nodeCaps,
              positionBadge: posBadge,
              suppressHoverTooltip: isSelected,
            }});
          }}
          if (!canDriftExistingEstimatedMarker) {{
            marker.on("click", () => {{
              selectNode(normalizedId, true, false);
            }});
          }}
          if (fadeEstimatedMarkerIn) {{
            marker._meshMapNodeMarkerFadeBaseStyle = (fadeEstimatedMarkerBaseStyle && typeof fadeEstimatedMarkerBaseStyle === "object")
              ? Object.assign({{}}, fadeEstimatedMarkerBaseStyle)
              : (marker.options && typeof marker.options === "object")
              ? Object.assign({{}}, marker.options)
              : {{}};
            setMapNodeMarkerOpacityScale(marker, 0, marker._meshMapNodeMarkerFadeBaseStyle);
          }}
          if (!canDriftExistingEstimatedMarker) {{
            marker.addTo(nodeLayer);
          }}
          if (fadeEstimatedMarkerIn) {{
            fadeInMapNodeMarker(marker, {{
              layerGroup: nodeLayer,
              durationMs: mapEstimatedOverlayLongJumpFadeMs,
              baseStyle: marker._meshMapNodeMarkerFadeBaseStyle,
            }});
          }}
          nodeMarkers.set(normalizedId, marker);
          nodeMarkerMeta.set(normalizedId, markerHash);
          nodeMarkerKinds.set(normalizedId, markerKind);
          nodeMarkerConfidence.set(normalizedId, markerConfidence);
        }}

        for (const [nodeId, marker] of Array.from(nodeMarkers.entries())) {{
          if (seenNodeIds.has(nodeId)) continue;
          cancelMapMarkerDrift(marker);
          const staleMarkerKind = nodeMarkerKinds.get(nodeId);
          if ((staleMarkerKind === "estimated" || staleMarkerKind === "trilaterated") && allowEstimatedNodeFade) {{
            if (!(typeof mapNodeMarkerIsFadingOut === "function" && mapNodeMarkerIsFadingOut(marker))) {{
              fadeOutMapNodeMarker(marker, {{
                layerGroup: nodeLayer,
                durationMs: mapEstimatedOverlayLongJumpFadeMs,
                onComplete: () => {{
                  if (typeof nodeLayer.hasLayer !== "function" || nodeLayer.hasLayer(marker)) {{
                    nodeLayer.removeLayer(marker);
                  }}
                  if (nodeMarkers.get(nodeId) === marker) {{
                    nodeMarkers.delete(nodeId);
                    nodeMarkerMeta.delete(nodeId);
                    nodeMarkerKinds.delete(nodeId);
                    nodeMarkerConfidence.delete(nodeId);
                  }}
                }},
              }});
            }}
            continue;
          }} else {{
            cancelMapNodeMarkerFade(marker);
            nodeLayer.removeLayer(marker);
          }}
          nodeMarkers.delete(nodeId);
          nodeMarkerMeta.delete(nodeId);
          nodeMarkerKinds.delete(nodeId);
          nodeMarkerConfidence.delete(nodeId);
        }}

        if (activeLayoutView === "network" && mapPacketLinesEnabled) {{
          const seenEdgeKeys = new Set();
          const edgeKeyCounts = new Map();
          for (const edge of (mapRenderEdges || [])) {{
            const fromId = normalizeNodeId(edge && edge.from);
            const toId = normalizeNodeId(edge && edge.to);
            const src = byId[fromId];
            const dst = byId[toId];
            if (!src || !dst) continue;
            if (typeof src.lat !== "number" || typeof src.lon !== "number") continue;
            if (typeof dst.lat !== "number" || typeof dst.lon !== "number") continue;
            const baseKey = `${{fromId}}>${{toId}}`;
            const duplicateIdx = edgeKeyCounts.get(baseKey) || 0;
            edgeKeyCounts.set(baseKey, duplicateIdx + 1);
            const edgeKey = duplicateIdx === 0 ? baseKey : `${{baseKey}}#${{duplicateIdx}}`;
            seenEdgeKeys.add(edgeKey);

            const lifetimeCount = edge.lifetime_count ?? edge.count ?? 0;
            const sessionCount = edge.session_count ?? edge.count ?? 0;
            const isReal = !!edge.is_real;
            if (!isReal) continue;
            const lastSeenUnix = parseEdgeLastSeenUnix(edge);
            const recencyFade = packetLineRecencyFade(lastSeenUnix, nowUnix);
            const ageMinutes = Number.isFinite(lastSeenUnix) && lastSeenUnix > 0
              ? Math.max(0, Math.floor((nowUnix - lastSeenUnix) / 60))
              : -1;
            const baseOpacity = isReal ? 0.82 : 0.64;
            const minOpacity = isReal ? 0.56 : 0.44;
            const edgeOpacity = minOpacity + ((baseOpacity - minOpacity) * recencyFade);
            const baseWeight = Math.min(8, 2 + lifetimeCount);
            const minWeight = Math.min(
              baseWeight - 0.2,
              Math.max(isReal ? 2.2 : 1.7, baseWeight * 0.62)
            );
            const edgeWeight = minWeight + ((baseWeight - minWeight) * recencyFade);
            const lastAgeLabel = Number.isFinite(lastSeenUnix) && lastSeenUnix > 0
              ? (
                typeof formatIdleAge === "function"
                  ? formatIdleAge(lastSeenUnix, nowUnix)
                  : `${{Math.floor((nowUnix - lastSeenUnix) / 60)}}m ago`
              )
              : "n/a";
            let edgeHash = 2166136261;
            edgeHash = hashMixStr(edgeHash, "network-edge");
            edgeHash = hashMixStr(edgeHash, edgeKey);
            edgeHash = hashMixInt(edgeHash, Math.round(src.lat * 100000));
            edgeHash = hashMixInt(edgeHash, Math.round(src.lon * 100000));
            edgeHash = hashMixInt(edgeHash, Math.round(dst.lat * 100000));
            edgeHash = hashMixInt(edgeHash, Math.round(dst.lon * 100000));
            edgeHash = hashMixInt(edgeHash, Number(lifetimeCount) || 0);
            edgeHash = hashMixInt(edgeHash, Number(sessionCount) || 0);
            edgeHash = hashMixInt(edgeHash, isReal ? 1 : 0);
            edgeHash = hashMixInt(edgeHash, ageMinutes);
            edgeHash = hashMixStr(edgeHash, edge && (edge.confidence || ""));
            edgeHash = hashMixStr(
              edgeHash,
              (typeof edgeRxLabel === "function") ? edgeRxLabel(edge, "first", "") : (edge && (edge.first_rx_time || ""))
            );
            edgeHash = hashMixStr(
              edgeHash,
              (typeof edgeRxLabel === "function") ? edgeRxLabel(edge, "last", "") : (edge && (edge.last_rx_time || ""))
            );
            edgeHash = hashMixStr(edgeHash, edge && (edge.avg_hops ?? ""));
            edgeHash = hashMixStr(edgeHash, edge && (edge.last_hops ?? ""));
            const ports = Array.isArray(edge && edge.portnums) ? edge.portnums : [];
            for (const port of ports) {{
              edgeHash = hashMixStr(edgeHash, port);
            }}

            const existingLine = edgeLines.get(edgeKey);
            const prevEdgeHash = edgeLineMeta.get(edgeKey);
            if (existingLine && prevEdgeHash === edgeHash) {{
              continue;
            }}
            if (existingLine) {{
              edgeLayer.removeLayer(existingLine);
              edgeLines.delete(edgeKey);
            }}

            const hopsLabel = edge.avg_hops == null
              ? "n/a"
              : `avg ${{edge.avg_hops}}${{edge.last_hops == null ? "" : ` (last ${{edge.last_hops}})`}}`;
            const firstRxLabel = (typeof edgeRxLabel === "function")
              ? edgeRxLabel(edge, "first", "n/a", nowUnix)
              : (edge.first_rx_time || "n/a");
            const lastRxLabel = (typeof edgeRxLabel === "function")
              ? edgeRxLabel(edge, "last", "n/a", nowUnix)
              : (edge.last_rx_time || "n/a");
            const line = L.polyline([[src.lat, src.lon], [dst.lat, dst.lon]], {{
              color: isReal ? "#bf1f43" : "#b7791f",
              dashArray: isReal ? null : "6 6",
              opacity: edgeOpacity,
              weight: edgeWeight,
              lineCap: "round",
              lineJoin: "round",
              bubblingMouseEvents: false,
            }});
            line.bindTooltip(`
              <b>${{edge.from}} -> ${{edge.to}}</b><br/>
              Status: ${{edge.confidence || (isReal ? "confirmed" : "observed")}}<br/>
              Packets: ${{lifetimeCount}}<br/>
              Last: ${{lastRxLabel}} (${{lastAgeLabel}})<br/>
              Hops: ${{hopsLabel}}
            `, {{ sticky: true, opacity: 0.92 }});
            line.bindPopup(`
              <b>${{edge.from}} -> ${{edge.to}}</b><br/>
              Status: ${{edge.confidence || (isReal ? "confirmed" : "observed")}}<br/>
              Session packets: ${{sessionCount}}<br/>
              Lifetime packets: ${{lifetimeCount}}<br/>
              First: ${{firstRxLabel}}<br/>
              Last: ${{lastRxLabel}}<br/>
              Age: ${{lastAgeLabel}}<br/>
              Hops: ${{hopsLabel}}<br/>
              Ports: ${{ports.join(", ") || "n/a"}}
            `);
            line.addTo(edgeLayer);
            edgeLines.set(edgeKey, line);
            edgeLineMeta.set(edgeKey, edgeHash);
          }}

          for (const [edgeKey, line] of Array.from(edgeLines.entries())) {{
            if (seenEdgeKeys.has(edgeKey)) continue;
            edgeLayer.removeLayer(line);
            edgeLines.delete(edgeKey);
            edgeLineMeta.delete(edgeKey);
          }}
        }} else {{
          for (const [edgeKey, line] of Array.from(edgeLines.entries())) {{
            edgeLayer.removeLayer(line);
            edgeLines.delete(edgeKey);
            edgeLineMeta.delete(edgeKey);
          }}
        }}

        if (showEstimatedLinks) {{
          const seenEstimateKeys = new Set();
          for (const estimateLine of estimateLinesToRender) {{
            const isCloudLink = !!(estimateLine && estimateLine.cloudLink);
            const lineKey = String(estimateLine && estimateLine.key || "");
            if (!lineKey) continue;
            seenEstimateKeys.add(lineKey);
            const lineMode = String((estimateLine && estimateLine.mode) || "history").trim().toLowerCase() === "live"
              ? "live"
              : "history";
            const qualityScore = clampMapLinkValue(Number(estimateLine && estimateLine.qualityScore), 0.08, 0.98);
            const trafficPct = clampMapLinkValue(Number(estimateLine && estimateLine.renderTrafficPct), 0.08, 1);
            const trafficValue = Math.max(0, Number(estimateLine && estimateLine.renderTrafficValue) || mapEstimatedLineTrafficValue(estimateLine));
            const trafficLabel = Math.max(0, Math.round(trafficValue));
            const estimatedEndpoints = Math.max(1, Math.trunc(Number(estimateLine && estimateLine.estimatedEndpoints) || 1));
            const lastSeenUnix = Number(estimateLine && estimateLine.lastSeenUnix);
            const ageLabel = Number.isFinite(lastSeenUnix) && lastSeenUnix > 0
              ? (
                typeof formatIdleAge === "function"
                  ? formatIdleAge(lastSeenUnix, nowUnix)
                  : `${{Math.floor((nowUnix - lastSeenUnix) / 60)}}m ago`
              )
              : "n/a";
            let lineHash = 2166136261;
            lineHash = hashMixStr(lineHash, "network-link-layer");
            lineHash = hashMixStr(lineHash, lineKey);
            lineHash = hashMixInt(lineHash, Math.round(Number(estimateLine && estimateLine.fromLat) * 100000));
            lineHash = hashMixInt(lineHash, Math.round(Number(estimateLine && estimateLine.fromLon) * 100000));
            lineHash = hashMixInt(lineHash, Math.round(Number(estimateLine && estimateLine.toLat) * 100000));
            lineHash = hashMixInt(lineHash, Math.round(Number(estimateLine && estimateLine.toLon) * 100000));
            lineHash = hashMixInt(lineHash, Math.round(qualityScore * 1000));
            lineHash = hashMixInt(lineHash, estimatedEndpoints);
            lineHash = hashMixInt(lineHash, Math.round(Number(estimateLine && estimateLine.desiredDistanceKm) * 10));
            lineHash = hashMixInt(lineHash, Number(estimateLine && estimateLine.weight) || 0);
            lineHash = hashMixInt(lineHash, Number(estimateLine && estimateLine.sessionWeight) || 0);
            lineHash = hashMixInt(lineHash, Math.round(trafficPct * 1000));
            lineHash = hashMixInt(lineHash, Math.round(trafficValue));
            lineHash = hashMixStr(lineHash, lineMode);
            lineHash = hashMixStr(
              lineHash,
              String(estimateLine ? (estimateLine.avgHops ?? "") : "")
            );
            lineHash = hashMixStr(
              lineHash,
              String(estimateLine ? (estimateLine.avgSnr ?? "") : "")
            );
            lineHash = hashMixStr(
              lineHash,
              String(estimateLine ? (estimateLine.avgRssi ?? "") : "")
            );
            lineHash = hashMixInt(
              lineHash,
              isCloudLink
                ? Math.trunc(Number(estimateLine && estimateLine.sampleCount) || 0)
                : 0
            );
            lineHash = hashMixInt(
              lineHash,
              isCloudLink
                ? Math.trunc(Number(estimateLine && estimateLine.clusterNodeCount) || 0)
                : 0
            );

            const linePath = [
              [Number(estimateLine.fromLat), Number(estimateLine.fromLon)],
              [Number(estimateLine.toLat), Number(estimateLine.toLon)],
            ];
            const lineStyle = {{
              color: isCloudLink
                ? (lineMode === "live" ? "#8fd3ff" : "#4f9bff")
                : (
                  lineMode === "live"
                    ? (estimatedEndpoints >= 2 ? "#9cd8ff" : "#7cc7ff")
                    : (estimatedEndpoints >= 2 ? "#2f6f8c" : "#3384a6")
                ),
              dashArray: isCloudLink
                ? (lineMode === "live" ? null : "6 7")
                : (
                  lineMode === "live"
                    ? (estimatedEndpoints >= 2 ? "2 5" : "5 5")
                    : (estimatedEndpoints >= 2 ? "4 7" : "8 6")
                ),
              opacity: isCloudLink
                ? (0.14 + (qualityScore * 0.13) + (trafficPct * 0.34))
                : (
                  lineMode === "live"
                    ? (0.12 + (qualityScore * 0.1) + (trafficPct * 0.34))
                    : (0.1 + (qualityScore * 0.08) + (trafficPct * 0.3))
                ),
              weight: isCloudLink
                ? (0.9 + (qualityScore * 0.9) + (trafficPct * 2.6))
                : (
                  lineMode === "live"
                    ? (0.8 + (qualityScore * 0.6) + (trafficPct * 2.8))
                    : (0.75 + (qualityScore * 0.45) + (trafficPct * 2.3))
                ),
              lineCap: "round",
              lineJoin: "round",
              bubblingMouseEvents: false,
            }};
            const existingLine = linkEstimateLines.get(lineKey);
            const prevLineHash = linkEstimateLineMeta.get(lineKey);
            if (existingLine && prevLineHash === lineHash) {{
              continue;
            }}
            let line = existingLine || null;
            if (line) {{
              if (typeof line.setStyle === "function") {{
                line.setStyle(lineStyle);
              }}
              animateMapPolylineLatLngs(line, linePath, {{
                durationMs: mapEstimatedOverlayDriftMs,
              }});
            }} else {{
              line = L.polyline(linePath, lineStyle);
            }}
            if (isCloudLink) {{
              const cloudId = String(estimateLine && estimateLine.cloudId || "n/a");
              const cloudNodeCount = Math.max(0, Math.trunc(Number(estimateLine && estimateLine.clusterNodeCount) || 0));
              const sampleCount = Math.max(0, Math.trunc(Number(estimateLine && estimateLine.sampleCount) || 0));
              line.bindTooltip(`
                <b>Cloud link (${{lineMode === "live" ? "live" : "history"}})</b><br/>
                Cloud: ${{cloudId}} (${{cloudNodeCount}} unknown node${{cloudNodeCount === 1 ? "" : "s"}})<br/>
                Known node: ${{estimateLine.toId}}<br/>
                Traffic: ${{trafficLabel}} weighted packet${{trafficLabel === 1 ? "" : "s"}}<br/>
                Samples: ${{sampleCount}}<br/>
                Quality: ${{Math.round(qualityScore * 100)}}%
              `, {{ sticky: true, opacity: 0.9 }});
              line.bindPopup(`
                <b>Cloud link (${{lineMode === "live" ? "live" : "history"}})</b><br/>
                Cloud: ${{cloudId}} (${{cloudNodeCount}} unknown node${{cloudNodeCount === 1 ? "" : "s"}})<br/>
                Known node: ${{estimateLine.toId}}<br/>
                Traffic: ${{trafficLabel}} weighted packet${{trafficLabel === 1 ? "" : "s"}}<br/>
                Samples: ${{sampleCount}}<br/>
                Quality: ${{Math.round(qualityScore * 100)}}%<br/>
                Cloud-node span: ${{estimateLine.desiredDistanceKm}} km<br/>
                Avg hops: ${{estimateLine.avgHops == null ? "n/a" : estimateLine.avgHops}}<br/>
                Avg SNR: ${{estimateLine.avgSnr == null ? "n/a" : estimateLine.avgSnr}}<br/>
                Avg RSSI: ${{estimateLine.avgRssi == null ? "n/a" : estimateLine.avgRssi}}<br/>
                Age: ${{ageLabel}}
              `);
            }} else {{
              line.bindTooltip(`
                <b>Link layer (${{lineMode === "live" ? "live" : "history"}})</b><br/>
                ${{estimateLine.fromId}} <-> ${{estimateLine.toId}}<br/>
                Traffic: ${{trafficLabel}} weighted packet${{trafficLabel === 1 ? "" : "s"}}<br/>
                Quality: ${{Math.round(qualityScore * 100)}}%<br/>
                Heuristic span: ${{estimateLine.desiredDistanceKm}} km
              `, {{ sticky: true, opacity: 0.9 }});
              line.bindPopup(`
                <b>Link layer (${{lineMode === "live" ? "live" : "history"}})</b><br/>
                Nodes: ${{estimateLine.fromId}} <-> ${{estimateLine.toId}}<br/>
                Traffic: ${{trafficLabel}} weighted packet${{trafficLabel === 1 ? "" : "s"}}<br/>
                Inferred endpoints: ${{estimatedEndpoints}}<br/>
                Quality: ${{Math.round(qualityScore * 100)}}%<br/>
                Heuristic span: ${{estimateLine.desiredDistanceKm}} km<br/>
                Avg hops: ${{estimateLine.avgHops == null ? "n/a" : estimateLine.avgHops}}<br/>
                Avg SNR: ${{estimateLine.avgSnr == null ? "n/a" : estimateLine.avgSnr}}<br/>
                Avg RSSI: ${{estimateLine.avgRssi == null ? "n/a" : estimateLine.avgRssi}}<br/>
                Age: ${{ageLabel}}
              `);
            }}
            if (!existingLine) {{
              line.addTo(linkEstimateLayer);
            }}
            linkEstimateLines.set(lineKey, line);
            linkEstimateLineMeta.set(lineKey, lineHash);
          }}

          for (const [lineKey, line] of Array.from(linkEstimateLines.entries())) {{
            if (seenEstimateKeys.has(lineKey)) continue;
            cancelMapPolylineDrift(line);
            linkEstimateLayer.removeLayer(line);
            linkEstimateLines.delete(lineKey);
            linkEstimateLineMeta.delete(lineKey);
          }}
        }} else {{
          for (const [lineKey, line] of Array.from(linkEstimateLines.entries())) {{
            cancelMapPolylineDrift(line);
            linkEstimateLayer.removeLayer(line);
            linkEstimateLines.delete(lineKey);
            linkEstimateLineMeta.delete(lineKey);
          }}
        }}
        const showInferredHeatmap = (
          activeLayoutView === "network"
          && inferredHeatmapEnabled
          && !!(linkDensity && linkDensity.enabled)
        );
        if (showInferredHeatmap) {{
          syncLinkEstimateHeatmapLayer(linkDensity, true, {{ bypassFade: bypassHeatmapFade }});
        }} else {{
          clearLinkEstimateHeatmapLayer({{ fade: !bypassHeatmapFade }});
        }}
        renderMapLinkLegend(nodes, mapRenderEdges, estimatedPositions, linkOverlay);
      }}

      if (networkSelectionMode) {{
        renderNetworkTrailOverlay(nodeHistory, selectionId);
      }} else {{
        trailLayer.clearLayers();
      }}

      if (!fitDone) {{
        // Network overview: fit to the densest footprint and ignore obvious outliers (e.g., 0,0 before GPS lock).
        const didFit = fitMapToMostNodes(nodes, {{ pad: 0.18, maxZoom: 13 }});
        if (didFit) {{
          fitDone = true;
        }}
      }}
      updateMapSelection(false);
      lastMapSignature = signature;
      lastMapGraphSignature = graphSignature;
      lastMapRenderMode = "graph";
      networkMapGraphRenderSeen = true;
    }}
