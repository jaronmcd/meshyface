    async function applyMqttSettings() {{
      if (settingsApplyInFlight) return;
      const mapReportSettings = {{
        publish_interval_secs: readNumberValue("settings-mqtt-map-publish-interval-secs"),
        position_precision: readNumberValue("settings-mqtt-map-position-precision"),
        should_report_location: readCheckboxValue("settings-mqtt-map-report-location"),
      }};
      for (const [key, value] of Object.entries(mapReportSettings)) {{
        if (value == null) delete mapReportSettings[key];
      }}

      const mqttSettings = {{
        enabled: readCheckboxValue("settings-mqtt-enabled"),
        address: readTextValue("settings-mqtt-address"),
        root: readTextValue("settings-mqtt-root"),
        username: readTextValue("settings-mqtt-username"),
        password: readTextValue("settings-mqtt-password"),
        encryption_enabled: readCheckboxValue("settings-mqtt-encryption-enabled"),
        json_enabled: readCheckboxValue("settings-mqtt-json-enabled"),
        tls_enabled: readCheckboxValue("settings-mqtt-tls-enabled"),
        proxy_to_client_enabled: readCheckboxValue("settings-mqtt-proxy-to-client-enabled"),
        map_reporting_enabled: readCheckboxValue("settings-mqtt-map-reporting-enabled"),
      }};
      if (Object.keys(mapReportSettings).length) {{
        mqttSettings.map_report_settings = mapReportSettings;
      }}
      for (const [key, value] of Object.entries(mqttSettings)) {{
        if (value == null) delete mqttSettings[key];
      }}
      if (!Object.keys(mqttSettings).length) {{
        setText("settings-apply-status", "No MQTT fields to apply.");
        return;
      }}

      const ok = await postRadioSettingsPayload(
        {{ module: {{ mqtt: mqttSettings }} }},
        "Applying MQTT settings…",
        "MQTT settings saved"
      );
      if (ok) {{
        setTimeout(() => {{
          void fetchSettingsFromRadio();
        }}, 600);
      }}
    }}

