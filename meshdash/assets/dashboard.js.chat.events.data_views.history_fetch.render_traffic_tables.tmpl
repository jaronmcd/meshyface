    function trafficTableHashMixInt(hash, value) {{
      const v = (Number.isFinite(Number(value)) ? Math.trunc(Number(value)) : 0) | 0;
      hash ^= v;
      hash = Math.imul(hash, 16777619);
      return hash >>> 0;
    }}

    function trafficTableHashMixStr(hash, value) {{
      const text = String(value == null ? "" : value);
      for (let i = 0; i < text.length; i += 1) {{
        hash ^= text.charCodeAt(i);
        hash = Math.imul(hash, 16777619);
      }}
      return hash >>> 0;
    }}

    function renderTraffic(traffic, nodes, nodeHistory) {{
      const drawerHistoryActive = (
        typeof isChatNodeDetailsHistoryActive === "function"
        && isChatNodeDetailsHistoryActive()
      );
      const drawerNodeId = normalizeNodeId(selectedNodeId || "");
      if (drawerHistoryActive && isSelectableNodeId(drawerNodeId)) {{
        if (nodeHistory && normalizeNodeId(nodeHistory.node_id) === drawerNodeId) {{
          return renderNodeHistory(nodeHistory, nodes);
        }} else {{
          renderNodeHistoryLoading(drawerNodeId);
        }}
        return false;
      }}

      setMapDataMode("live");
      const portsSortState = tableSortState["ports-table"] || {{ index: 1, dir: "desc" }};
      let portsHash = 2166136261;
      portsHash = trafficTableHashMixInt(portsHash, portsSortState.index);
      portsHash = trafficTableHashMixStr(portsHash, portsSortState.dir);
      const portsData = (traffic.port_counts || []).slice(0, 30);
      for (const item of portsData) {{
        const portValue = item.portnum ?? "";
        const countValue = item.count ?? "";
        portsHash = trafficTableHashMixStr(portsHash, portValue);
        portsHash = trafficTableHashMixInt(portsHash, countValue);
      }}
      portsHash = trafficTableHashMixInt(portsHash, portsData.length);
      if (portsHash !== trafficPortsTableLastHash) {{
        const ports = portsData.map((item) => {{
          const portValue = item.portnum ?? "";
          const countValue = item.count ?? "";
          return `<tr><td data-sort="${{escAttr(portValue)}}">${{portValue}}</td><td data-sort="${{escAttr(countValue)}}">${{countValue}}</td></tr>`;
        }});
        fillTable("ports-table", ports);
        trafficPortsTableLastHash = portsHash;
      }}

      const linksSortState = tableSortState["links-table"] || {{ index: 2, dir: "desc" }};
      let linksHash = 2166136261;
      linksHash = trafficTableHashMixInt(linksHash, linksSortState.index);
      linksHash = trafficTableHashMixStr(linksHash, linksSortState.dir);
      const linksData = (traffic.edges || []).slice(0, 60);
      for (const edge of linksData) {{
        const fromValue = edge.from ?? "";
        const toValue = edge.to ?? "";
        const countValue = edge.lifetime_count ?? edge.count ?? 0;
        const avgHopsRaw = edge.avg_hops;
        const avgHopsSortValue = avgHopsRaw ?? "";
        const confidenceValue = edge.confidence || (edge.is_real ? "confirmed" : "observed");
        const lastRxValue = (typeof edgeRxLabel === "function")
          ? edgeRxLabel(edge, "last", "n/a")
          : (edge.last_rx_time || "n/a");
        linksHash = trafficTableHashMixStr(linksHash, fromValue);
        linksHash = trafficTableHashMixStr(linksHash, toValue);
        linksHash = trafficTableHashMixInt(linksHash, countValue);
        linksHash = trafficTableHashMixStr(linksHash, avgHopsSortValue);
        linksHash = trafficTableHashMixStr(linksHash, confidenceValue);
        linksHash = trafficTableHashMixStr(linksHash, lastRxValue);
      }}
      linksHash = trafficTableHashMixInt(linksHash, linksData.length);
      if (linksHash !== trafficLinksTableLastHash) {{
        const links = linksData.map((edge) => {{
          const fromValue = edge.from ?? "";
          const toValue = edge.to ?? "";
          const countValue = edge.lifetime_count ?? edge.count ?? 0;
          const avgHopsRaw = edge.avg_hops;
          const avgHopsSortValue = avgHopsRaw ?? "";
          const avgHopsText = avgHopsRaw == null ? "n/a" : avgHopsRaw;
          const confidenceValue = edge.confidence || (edge.is_real ? "confirmed" : "observed");
          const lastRxValue = (typeof edgeRxLabel === "function")
            ? edgeRxLabel(edge, "last", "n/a")
            : (edge.last_rx_time || "n/a");
          return `<tr>
            <td data-sort="${{escAttr(fromValue)}}">${{fromValue}}</td>
            <td data-sort="${{escAttr(toValue)}}">${{toValue}}</td>
            <td data-sort="${{escAttr(countValue)}}">${{countValue}}</td>
            <td data-sort="${{escAttr(avgHopsSortValue)}}">${{avgHopsText}}</td>
            <td data-sort="${{escAttr(confidenceValue)}}">${{confidenceValue}}</td>
            <td data-sort="${{escAttr(lastRxValue)}}">${{lastRxValue}}</td>
          </tr>`;
        }});
        fillTable("links-table", links);
        trafficLinksTableLastHash = linksHash;
      }}
      return true;
    }}
