    function bindFavoriteMenuControls() {{
      const toggleBtn = document.getElementById("favorite-menu-toggle-btn");
      if (toggleBtn instanceof HTMLButtonElement && toggleBtn.dataset.bound !== "1") {{
        toggleBtn.dataset.bound = "1";
        toggleBtn.addEventListener("click", (ev) => {{
          ev.preventDefault();
          ev.stopPropagation();
          const nextOpen = !favoriteMenuOpen;
          setFavoriteMenuOpen(nextOpen);
          if (nextOpen) {{
            setChatChangeMenuOpen(false);
            setChatSettingsMenuOpen(false);
            renderStarredNodeSelect(latestState || {{}});
          }}
        }});
      }}

      const menu = document.getElementById("favorite-menu");
      if (menu instanceof HTMLElement && menu.dataset.bound !== "1") {{
        menu.dataset.bound = "1";
        menu.addEventListener("click", (ev) => {{
          const target = ev.target;
          if (!(target instanceof Element)) return;
          const item = target.closest(".favorite-menu-saved-item");
          if (!(item instanceof HTMLButtonElement)) return;
          const nodeId = normalizeNodeId(item.dataset.nodeId || "");
          if (item.classList.contains("favorite-menu-selected-item")) {{
            clearNodeSelection();
            setFavoriteMenuOpen(false);
            return;
          }}
          if (!isSelectableNodeId(nodeId)) return;
          selectNode(nodeId, true, false);
          setFavoriteMenuOpen(false);
        }});
      }}

      if (document.body.dataset.favoriteMenuDocBound !== "1") {{
        document.body.dataset.favoriteMenuDocBound = "1";
        document.addEventListener("pointerdown", (ev) => {{
          if (!favoriteMenuOpen) return;
          const target = ev.target;
          if (!(target instanceof Element)) {{
            setFavoriteMenuOpen(false);
            return;
          }}
          if (target.closest("#favorite-menu-toggle-btn") || target.closest("#favorite-menu")) {{
            return;
          }}
          setFavoriteMenuOpen(false);
        }});
        document.addEventListener("keydown", (ev) => {{
          if (ev.key !== "Escape" || !favoriteMenuOpen) return;
          setFavoriteMenuOpen(false);
        }});
      }}
    }}

