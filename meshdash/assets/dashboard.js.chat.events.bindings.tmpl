    function rerenderNodeSearchDependents(state = latestState) {{
      const safeState = state && typeof state === "object" ? state : null;
      if (!safeState) return;
      renderChat(safeState);
      if (activeLayoutView === "network") {{
        renderNodes(safeState.nodes || []);
      }}
      if (activeLayoutView === "saved") {{
        renderFavorites(safeState);
      }}
      if (activeLayoutView === "remote") {{
        renderRemoteView(safeState);
      }}
      renderSavedNodeSearchDropdown(safeState);
      renderFavoriteMenuNodeSearchDropdown(safeState);
    }}

    function bindFavoritesControls() {{
      bindSearchTextInput("favorites-search-input", {{
        value: globalNodeSearchQuery(),
        normalize: normalizeSearchQuery,
        onInput: (query) => {{
          const changed = setGlobalNodeSearchQuery(query, {{
            sourceInputId: "favorites-search-input",
            skipSourceInput: true,
          }});
          if (changed && latestState) {{
            rerenderNodeSearchDependents(latestState);
          }}
        }},
      }});
    }}

    function bindFavoriteMenuNodeSearchControls() {{
      const input = document.getElementById("favorite-menu-node-search-input");
      const dropdown = document.getElementById("favorite-menu-node-search-dropdown");
      if (!(input instanceof HTMLInputElement) || !(dropdown instanceof HTMLElement)) return;

      if (input.dataset.bound !== "1") {{
        input.dataset.bound = "1";
        const openFavoriteNodeSearch = () => {{
          if (favoriteMenuNodeSearchBlurTimer !== null) {{
            clearTimeout(favoriteMenuNodeSearchBlurTimer);
            favoriteMenuNodeSearchBlurTimer = null;
          }}
          setGlobalNodeSearchQuery(input.value, {{
            sourceInputId: "favorite-menu-node-search-input",
            skipSourceInput: true,
          }});
          favoriteMenuNodeSearchOpen = true;
          renderFavoriteMenuNodeSearchDropdown(latestState);
        }};
        input.addEventListener("focus", openFavoriteNodeSearch);
        input.addEventListener("click", openFavoriteNodeSearch);
        input.addEventListener("input", () => {{
          const changed = setGlobalNodeSearchQuery(input.value, {{
            sourceInputId: "favorite-menu-node-search-input",
            skipSourceInput: true,
          }});
          favoriteMenuNodeSearchOpen = true;
          if (changed && latestState) {{
            rerenderNodeSearchDependents(latestState);
          }}
          renderFavoriteMenuNodeSearchDropdown(latestState);
        }});
        input.addEventListener("keydown", (ev) => {{
          if (ev.key === "Escape") {{
            ev.preventDefault();
            closeFavoriteMenuNodeSearchDropdown();
          }}
        }});
        input.addEventListener("blur", () => {{
          if (favoriteMenuNodeSearchBlurTimer !== null) {{
            clearTimeout(favoriteMenuNodeSearchBlurTimer);
          }}
          favoriteMenuNodeSearchBlurTimer = window.setTimeout(() => {{
            favoriteMenuNodeSearchBlurTimer = null;
            closeFavoriteMenuNodeSearchDropdown();
          }}, 120);
        }});
      }}
      input.value = globalNodeSearchQuery();

      if (dropdown.dataset.bound !== "1") {{
        dropdown.dataset.bound = "1";
        dropdown.addEventListener("mousedown", (ev) => {{
          ev.preventDefault();
          if (favoriteMenuNodeSearchBlurTimer !== null) {{
            clearTimeout(favoriteMenuNodeSearchBlurTimer);
            favoriteMenuNodeSearchBlurTimer = null;
          }}
        }});
        dropdown.addEventListener("click", (ev) => {{
          const target = ev.target;
          if (!(target instanceof Element)) return;
          const item = target.closest(".node-search-item");
          if (!(item instanceof HTMLButtonElement)) return;
          const nodeId = normalizeNodeId(item.dataset.nodeId || "");
          if (!isSelectableNodeId(nodeId)) return;
          selectNode(nodeId, true, false);
          closeFavoriteMenuNodeSearchDropdown();
          setFavoriteMenuOpen(false);
        }});
      }}

      if (document.body.dataset.favoriteNodeSearchOutsideBound !== "1") {{
        document.body.dataset.favoriteNodeSearchOutsideBound = "1";
        document.addEventListener("pointerdown", (ev) => {{
          const inputEl = document.getElementById("favorite-menu-node-search-input");
          const dropdownEl = document.getElementById("favorite-menu-node-search-dropdown");
          if (!(inputEl instanceof HTMLInputElement) || !(dropdownEl instanceof HTMLElement)) return;
          const target = ev.target;
          if (!(target instanceof Node)) return;
          if (inputEl.contains(target) || dropdownEl.contains(target)) return;
          closeFavoriteMenuNodeSearchDropdown();
        }});
      }}
      renderFavoriteMenuNodeSearchDropdown(latestState);
    }}

    function bindSavedNodeSearchControls() {{
      const input = document.getElementById("saved-node-search-input");
      const dropdown = document.getElementById("saved-node-search-dropdown");
      if (!(input instanceof HTMLInputElement) || !(dropdown instanceof HTMLElement)) return;

      if (input.dataset.bound !== "1") {{
        input.dataset.bound = "1";
        const openSavedNodeSearch = () => {{
          if (savedNodeSearchBlurTimer !== null) {{
            clearTimeout(savedNodeSearchBlurTimer);
            savedNodeSearchBlurTimer = null;
          }}
          setGlobalNodeSearchQuery(input.value, {{
            sourceInputId: "saved-node-search-input",
            skipSourceInput: true,
          }});
          savedNodeSearchOpen = true;
          renderSavedNodeSearchDropdown(latestState);
        }};
        input.addEventListener("focus", openSavedNodeSearch);
        // Clicking an already-focused input does not fire "focus" again.
        // Reopen on click so the list pops every time the user clicks it.
        input.addEventListener("click", openSavedNodeSearch);
        input.addEventListener("input", () => {{
          const changed = setGlobalNodeSearchQuery(input.value, {{
            sourceInputId: "saved-node-search-input",
            skipSourceInput: true,
          }});
          savedNodeSearchOpen = true;
          if (changed && latestState) {{
            rerenderNodeSearchDependents(latestState);
          }}
          renderSavedNodeSearchDropdown(latestState);
        }});
        input.addEventListener("keydown", (ev) => {{
          if (ev.key === "Escape") {{
            ev.preventDefault();
            closeSavedNodeSearchDropdown();
          }}
        }});
        input.addEventListener("blur", () => {{
          if (savedNodeSearchBlurTimer !== null) {{
            clearTimeout(savedNodeSearchBlurTimer);
          }}
          savedNodeSearchBlurTimer = window.setTimeout(() => {{
            savedNodeSearchBlurTimer = null;
            closeSavedNodeSearchDropdown();
          }}, 120);
        }});
      }}
      input.value = globalNodeSearchQuery();

      if (dropdown.dataset.bound !== "1") {{
        dropdown.dataset.bound = "1";
        dropdown.addEventListener("mousedown", (ev) => {{
          ev.preventDefault();
          if (savedNodeSearchBlurTimer !== null) {{
            clearTimeout(savedNodeSearchBlurTimer);
            savedNodeSearchBlurTimer = null;
          }}
        }});
        dropdown.addEventListener("click", (ev) => {{
          const target = ev.target;
          if (!(target instanceof Element)) return;
          const item = target.closest(".node-search-item");
          if (!(item instanceof HTMLButtonElement)) return;
          const nodeId = normalizeNodeId(item.dataset.nodeId || "");
          if (!isSelectableNodeId(nodeId)) return;
          selectNode(nodeId, true, false);
          closeSavedNodeSearchDropdown();
        }});
      }}

      if (document.body.dataset.savedNodeSearchOutsideBound !== "1") {{
        document.body.dataset.savedNodeSearchOutsideBound = "1";
        document.addEventListener("pointerdown", (ev) => {{
          const inputEl = document.getElementById("saved-node-search-input");
          const dropdownEl = document.getElementById("saved-node-search-dropdown");
          if (!(inputEl instanceof HTMLInputElement) || !(dropdownEl instanceof HTMLElement)) return;
          const target = ev.target;
          if (!(target instanceof Node)) return;
          if (inputEl.contains(target) || dropdownEl.contains(target)) return;
          closeSavedNodeSearchDropdown();
        }});
      }}
      renderSavedNodeSearchDropdown(latestState);
    }}

