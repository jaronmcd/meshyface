    function rerenderNodeSearchDependents(state = latestState) {{
      const safeState = state && typeof state === "object" ? state : null;
      if (!safeState) return;
      if (isChatWorkspaceLayoutView(activeLayoutView)) {{
        renderChat(safeState);
      }} else if (typeof renderChatNodeNavigatorList === "function") {{
        renderChatNodeNavigatorList(safeState);
      }}
      if (activeLayoutView === "network") {{
        renderNodes(safeState.nodes || []);
      }}
      if (activeLayoutView === "saved") {{
        renderFavorites(safeState);
      }}
      if (activeLayoutView === "remote") {{
        renderRemoteView(safeState);
      }}
      renderSavedNodeSearchDropdown(safeState);
      renderFavoriteMenuNodeSearchDropdown(safeState);
    }}

