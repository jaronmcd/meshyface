    function bindChatFeedClicks() {{
      const feed = document.getElementById("chat-feed");
      if (!(feed instanceof HTMLElement) || feed.dataset.feedClickBound === "1") return;
      feed.dataset.feedClickBound = "1";
      feed.addEventListener("click", (ev) => {{
        const target = ev.target;
        if (!(target instanceof Element)) return;
        const item = target.closest(".chat-feed-item");
        if (!(item instanceof HTMLElement) || !feed.contains(item)) return;

        const retryBtn = target.closest(".chat-retry-btn");
        if (retryBtn instanceof HTMLButtonElement) {{
          ev.preventDefault();
          ev.stopPropagation();
          if (chatSendInFlight) return;
          retryChatMessage({{
            text: retryBtn.dataset.retryText || "",
            destination: retryBtn.dataset.retryDestination || "^all",
            channel_index: Number(retryBtn.dataset.retryChannel || "0"),
            reply_id: Number(retryBtn.dataset.retryReplyId || ""),
            retry_of: Number(retryBtn.dataset.retryOf || ""),
          }});
          return;
        }}

        const whoisBtn = target.closest(".chat-whois-btn");
        if (whoisBtn) {{
          ev.preventDefault();
          ev.stopPropagation();
          if (!chatBotCommandsEnabled) {{
            setChatSendStatus("Whois quick action is unavailable.", true);
            return;
          }}
          const whoisTargetId = normalizeNodeId(
            whoisBtn instanceof HTMLElement
              ? (whoisBtn.dataset.whoisTargetId || item.dataset.fromNodeId || "")
              : (item.dataset.fromNodeId || "")
          );
          const whoisSuffix = nodeIdSuffixForWhois(whoisTargetId);
          if (!isCanonicalNodeId(whoisTargetId) || !whoisSuffix) {{
            setChatSendStatus("Cannot build Whois command: sender ID is unavailable.", true);
            return;
          }}
          const command = buildWhoisCommandForNode(whoisTargetId);
          const input = document.getElementById("chat-input");
          if (!(input instanceof HTMLInputElement)) {{
            setChatSendStatus("Cannot prepare Whois command: chat input is unavailable.", true);
            return;
          }}
          if (chatWhoisQuickActionThreadReply) {{
            const replyId = Number(item.dataset.messageId || "");
            if (Number.isInteger(replyId) && replyId > 0) {{
              const replyName = item.dataset.replyName || "Unknown node";
              const replyText = item.dataset.replyText || "";
              setChatReplyTarget(replyId, replyName, replyText);
            }} else {{
              clearChatReplyTarget();
            }}
          }} else {{
            clearChatReplyTarget();
          }}
          input.value = command;
          input.focus();
          input.setSelectionRange(command.length, command.length);
          input.dispatchEvent(new Event("input", {{ bubbles: true }}));
          setChatSendStatus(
            `Prepared ${{command}} for ${{whoisTargetId}}${{chatWhoisQuickActionThreadReply ? " (reply attached)" : ""}}.`
          );
          return;
        }}

        const replyBtn = target.closest(".chat-reply-btn");
        if (replyBtn) {{
          ev.preventDefault();
          ev.stopPropagation();
          const replyId = Number(item.dataset.messageId || "");
          const replyName = item.dataset.replyName || "Unknown node";
          const replyText = item.dataset.replyText || "";
          if (chatMainDirectModeEnabled && activeChatChannel === "direct" && item.classList.contains("chat-selectable")) {{
            selectNode(item.dataset.nodeId || "", false, false);
          }}
          setChatReplyTarget(replyId, replyName, replyText);
          return;
        }}

        const ackBtn = target.closest(".chat-ack-btn");
        if (ackBtn) {{
          ev.preventDefault();
          ev.stopPropagation();
          const ackOptions = chatAckOptionsFromButton(
            ackBtn instanceof HTMLElement ? ackBtn : null
          );
          if (ackOptions) {{
            void sendChatAck(ackOptions);
          }}
          return;
        }}

        if (target.closest("a.chat-link")) {{
          // Let browser open the link (target=_blank) without selecting/replying.
          return;
        }}

        if (target.closest("button")) {{
          return;
        }}

        if (item.classList.contains("chat-selectable")) {{
          selectNode(item.dataset.nodeId || "", true);
        }}
      }});
    }}

    function bindChatReactionControls() {{
      bindReactionPopover();
      const bindFeedReactionDelegates = (feedId) => {{
        const feed = document.getElementById(feedId);
        if (!(feed instanceof HTMLElement)) return;
        if (feed.dataset.reactionDelegatedBound === "1") return;
        feed.dataset.reactionDelegatedBound = "1";

        const reactButtonFromTarget = (target) => {{
          if (!(target instanceof Element)) return null;
          const btn = target.closest(".chat-react-btn");
          if (!(btn instanceof HTMLButtonElement)) return null;
          if (!feed.contains(btn)) return null;
          return btn;
        }};
        const summaryButtonFromTarget = (target) => {{
          if (!(target instanceof Element)) return null;
          const summary = target.closest(".chat-reaction-summary");
          if (!(summary instanceof HTMLButtonElement)) return null;
          if (!feed.contains(summary)) return null;
          return summary;
        }};

        feed.addEventListener("click", (ev) => {{
          const reactBtn = reactButtonFromTarget(ev.target);
          if (reactBtn) {{
            ev.preventDefault();
            ev.stopPropagation();
            if (chatSendInFlight) return;
            const panel = document.getElementById("chat-emoji-panel");
            const replyId = Number(reactBtn.dataset.replyId || "");
            if (!Number.isInteger(replyId) || replyId <= 0) {{
              setChatSendStatus("Cannot react: target message id is missing.", true);
              return;
            }}
            const panelOpenForSameTarget = (
              panel instanceof HTMLElement
              && !panel.hidden
              && chatEmojiMode === "react"
              && Number.isInteger(chatReactionTargetId)
              && chatReactionTargetId === replyId
              && chatEmojiAnchorElement === reactBtn
            );
            if (panelOpenForSameTarget) {{
              closeChatEmojiPanel();
              return;
            }}
            openChatEmojiPanel("react", replyId, reactBtn);
            return;
          }}

          const summary = summaryButtonFromTarget(ev.target);
          if (!(summary instanceof HTMLButtonElement)) return;
          ev.preventDefault();
          ev.stopPropagation();
          clearReactionPopoverHideTimer();
          openReactionPopoverForSummary(summary);
        }});

        feed.addEventListener("pointerover", (ev) => {{
          const summary = summaryButtonFromTarget(ev.target);
          if (!(summary instanceof HTMLButtonElement)) return;
          const related = ev.relatedTarget;
          if (related instanceof Node && summary.contains(related)) {{
            return;
          }}
          clearReactionPopoverHideTimer();
          openReactionPopoverForSummary(summary);
        }});

        feed.addEventListener("pointerout", (ev) => {{
          const summary = summaryButtonFromTarget(ev.target);
          if (!(summary instanceof HTMLButtonElement)) return;
          const related = ev.relatedTarget;
          const popover = reactionPopoverElement();
          if (related instanceof Node) {{
            if (summary.contains(related)) {{
              return;
            }}
            if (popover instanceof HTMLElement && popover.contains(related)) {{
              return;
            }}
          }}
          scheduleReactionPopoverHide(120);
        }});

        feed.addEventListener("focusin", (ev) => {{
          const summary = summaryButtonFromTarget(ev.target);
          if (!(summary instanceof HTMLButtonElement)) return;
          clearReactionPopoverHideTimer();
          openReactionPopoverForSummary(summary);
        }});

        feed.addEventListener("focusout", (ev) => {{
          const summary = summaryButtonFromTarget(ev.target);
          if (!(summary instanceof HTMLButtonElement)) return;
          const related = ev.relatedTarget;
          const popover = reactionPopoverElement();
          if (related instanceof Node) {{
            if (summary.contains(related)) {{
              return;
            }}
            if (popover instanceof HTMLElement && popover.contains(related)) {{
              return;
            }}
          }}
          scheduleReactionPopoverHide(80);
        }});
      }};

      bindFeedReactionDelegates("chat-feed");
      bindFeedReactionDelegates("chat-labs-feed");
    }}

