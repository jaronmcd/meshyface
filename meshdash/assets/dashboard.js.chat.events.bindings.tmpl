    function chatFeedHasExpandedSelection(container = null) {{
      const selection = window.getSelection ? window.getSelection() : null;
      if (!selection || selection.rangeCount <= 0 || selection.isCollapsed) {{
        return false;
      }}
      const scope = container instanceof HTMLElement ? container : null;
      for (let idx = 0; idx < selection.rangeCount; idx += 1) {{
        let range = null;
        try {{
          range = selection.getRangeAt(idx);
        }} catch (_err) {{
          continue;
        }}
        if (!range) continue;
        const common = range.commonAncestorContainer;
        const node = common instanceof Element
          ? common
          : (common && common.parentElement ? common.parentElement : null);
        if (!node) continue;
        if (!(scope instanceof HTMLElement) || scope.contains(node)) {{
          return true;
        }}
      }}
      return false;
    }}

    function clearChatFeedRepeatToggleState() {{
      chatFeedRepeatToggleMessageKey = "";
      chatFeedRepeatToggleNodeId = "";
    }}

    function chatHopReplyLocationIsValid(lat, lon) {{
      if (typeof isValidLatLonRange === "function" && !isValidLatLonRange(lat, lon)) return false;
      if (!Number.isFinite(lat) || !Number.isFinite(lon)) return false;
      if (lat < -90 || lat > 90 || lon < -180 || lon > 180) return false;
      if (Math.abs(lat) < 1e-9 && Math.abs(lon) < 1e-9) return false;
      return true;
    }}

    function chatHopReplyCityCacheKey(location) {{
      if (!location || typeof location !== "object") return "";
      const lat = Number(location.lat);
      const lon = Number(location.lon);
      if (!chatHopReplyLocationIsValid(lat, lon)) return "";
      return `${{lat.toFixed(4)}},${{lon.toFixed(4)}}`;
    }}

    function chatHopReplyCachedCityText(location) {{
      const key = chatHopReplyCityCacheKey(location);
      if (!key || !(nodeCityHintCache instanceof Map)) return "";
      return String(nodeCityHintCache.get(key) || "").trim();
    }}

    function chatHopReplyLocationSuffixText(rawCityText) {{
      const clean = String(rawCityText || "").replace(/\\s+/g, " ").trim();
      if (!clean) return "";
      const parts = clean.split(",").map((part) => String(part || "").trim()).filter(Boolean);
      const city = String(parts[0] || "").trim();
      const state = String(parts[1] || "").trim();
      if (!city) return "";
      if (state) return ` to ${{city}}, ${{state}}`;
      return ` to ${{city}}`;
    }}

    function chatHopReplySourceNodeFromState(sourceNodeId, state = latestState) {{
      const safeState = (state && typeof state === "object") ? state : latestState;
      const nodes = Array.isArray(safeState && safeState.nodes) ? safeState.nodes : [];
      const cleanNodeId = normalizeNodeId(sourceNodeId || "");
      if (!cleanNodeId || !nodes.length) return null;
      return nodes.find((node) => normalizeNodeId(node && node.id) === cleanNodeId) || null;
    }}

    async function resolveChatHopReplyLocationSuffixForNode(sourceNodeId, state = latestState, item = null) {{
      const safeState = (state && typeof state === "object") ? state : latestState;
      const cleanNodeId = normalizeNodeId(sourceNodeId || "");
      if (!cleanNodeId) return "";
      const sourceNode = chatHopReplySourceNodeFromState(cleanNodeId, safeState);
      const locationMeta = (typeof resolveNodeCityLocationMeta === "function")
        ? resolveNodeCityLocationMeta(cleanNodeId, safeState, sourceNode || item || null, {{
            allowEstimate: true,
            estimateMode: "both",
          }})
        : null;
      const location = (locationMeta && locationMeta.location && typeof locationMeta.location === "object")
        ? locationMeta.location
        : null;
      if (!location) return "";
      let cityText = chatHopReplyCachedCityText(location);
      if (!cityText && typeof nearestOfflineCityHintFromCoords === "function") {{
        const lat = Number(location.lat);
        const lon = Number(location.lon);
        if (chatHopReplyLocationIsValid(lat, lon)) {{
          try {{
            cityText = String(
              await nearestOfflineCityHintFromCoords(lat, lon, offlineCityHintMaxDistanceKm)
            ).trim();
            const key = chatHopReplyCityCacheKey(location);
            if (key && nodeCityHintCache instanceof Map) {{
              nodeCityHintCache.set(key, cityText);
            }}
          }} catch (_err) {{
            cityText = "";
          }}
        }}
      }}
      return chatHopReplyLocationSuffixText(cityText);
    }}

    async function resolveChatHopReplyLocationSuffix(_sourceNodeId, state = latestState, _item = null) {{
      const safeState = (state && typeof state === "object") ? state : latestState;
      const localNodeId = normalizeNodeId(
        (typeof resolveLocalNodeId === "function")
          ? resolveLocalNodeId(safeState)
          : ""
      );
      if (!localNodeId) return "";
      return resolveChatHopReplyLocationSuffixForNode(localNodeId, safeState, null);
    }}

    function clearChatHopReplyLocationAutocomplete() {{
      chatHopReplyAutocompleteToken += 1;
      chatHopReplyAutocompletePrefix = "";
      chatHopReplyAutocompleteSuffix = "";
      renderChatHopReplyLocationGhost();
    }}

    function syncChatHopReplyLocationAutocompleteInputState(valueRaw) {{
      const prefix = String(chatHopReplyAutocompletePrefix || "").trim();
      if (!prefix) return;
      const value = String(valueRaw || "");
      if (value !== prefix) {{
        clearChatHopReplyLocationAutocomplete();
      }} else {{
        renderChatHopReplyLocationGhost();
      }}
    }}

    function renderChatHopReplyLocationGhost(inputEl = null) {{
      const input = inputEl instanceof HTMLInputElement
        ? inputEl
        : document.getElementById("chat-input");
      const ghost = document.getElementById("chat-input-inline-ghost");
      const ghostPrefix = document.getElementById("chat-input-inline-ghost-prefix");
      const ghostSuffix = document.getElementById("chat-input-inline-ghost-suffix");
      if (!(input instanceof HTMLInputElement) || !(ghost instanceof HTMLElement) || !(ghostPrefix instanceof HTMLElement) || !(ghostSuffix instanceof HTMLElement)) {{
        return;
      }}
      const prefix = String(chatHopReplyAutocompletePrefix || "").trim();
      const suffix = String(chatHopReplyAutocompleteSuffix || "");
      const value = String(input.value || "");
      const shouldShow = !!prefix && !!suffix && value === prefix;
      if (!shouldShow) {{
        ghost.hidden = true;
        ghostPrefix.textContent = "";
        ghostSuffix.textContent = "";
        return;
      }}
      ghostPrefix.textContent = prefix;
      ghostSuffix.textContent = suffix;
      const row = input.closest(".chat-composer-input-row");
      if (!(row instanceof HTMLElement)) {{
        ghost.hidden = true;
        return;
      }}
      const rowRect = row.getBoundingClientRect();
      const inputRect = input.getBoundingClientRect();
      const inputStyle = window.getComputedStyle(input);
      const padLeft = Number.parseFloat(inputStyle.paddingLeft || "0") || 0;
      const padRight = Number.parseFloat(inputStyle.paddingRight || "0") || 0;
      const contentWidth = Math.max(0, inputRect.width - padLeft - padRight);
      const insetLeft = Math.max(0, (inputRect.left - rowRect.left) + padLeft);
      const insetTop = Math.max(0, inputRect.top - rowRect.top);
      ghost.style.left = `${{insetLeft}}px`;
      ghost.style.top = `${{insetTop}}px`;
      ghost.style.height = `${{Math.max(0, inputRect.height)}}px`;
      ghost.style.maxWidth = `${{contentWidth}}px`;
      ghost.style.fontFamily = inputStyle.fontFamily;
      ghost.style.fontSize = inputStyle.fontSize;
      ghost.style.fontWeight = inputStyle.fontWeight;
      ghost.style.letterSpacing = inputStyle.letterSpacing;
      ghost.style.lineHeight = inputStyle.lineHeight;
      ghost.style.textTransform = inputStyle.textTransform;
      ghost.hidden = false;
    }}

    function prepareChatHopReplyLocationAutocomplete(prefixText, sourceNodeId, state = latestState, item = null) {{
      const prefix = String(prefixText || "").trim();
      chatHopReplyAutocompleteToken += 1;
      const token = chatHopReplyAutocompleteToken;
      chatHopReplyAutocompletePrefix = prefix;
      chatHopReplyAutocompleteSuffix = "";
      renderChatHopReplyLocationGhost();
      if (!prefix) return;
      void resolveChatHopReplyLocationSuffix(sourceNodeId, state, item)
        .then((suffix) => {{
          if (token !== chatHopReplyAutocompleteToken) return;
          const rawSuffix = String(suffix || "");
          if (!rawSuffix.trim()) return;
          chatHopReplyAutocompleteSuffix = rawSuffix.startsWith(" ")
            ? rawSuffix
            : ` ${{rawSuffix}}`;
          renderChatHopReplyLocationGhost();
        }})
        .catch(() => {{
          renderChatHopReplyLocationGhost();
        }});
    }}

    function applyChatHopReplyLocationAutocomplete(inputEl = null) {{
      const input = inputEl instanceof HTMLInputElement
        ? inputEl
        : document.getElementById("chat-input");
      if (!(input instanceof HTMLInputElement)) return false;
      const prefix = String(chatHopReplyAutocompletePrefix || "").trim();
      const suffix = String(chatHopReplyAutocompleteSuffix || "");
      if (!prefix || !suffix) return false;
      const value = String(input.value || "");
      if (value !== prefix) return false;
      const selectionStart = Number(input.selectionStart);
      const selectionEnd = Number(input.selectionEnd);
      if (
        Number.isFinite(selectionStart)
        && Number.isFinite(selectionEnd)
        && (selectionStart !== value.length || selectionEnd !== value.length)
      ) {{
        return false;
      }}
      const maxLength = Math.max(0, Math.trunc(Number(input.maxLength) || 0));
      const nextValue = `${{prefix}}${{suffix}}`;
      if (maxLength > 0 && nextValue.length > maxLength) {{
        setChatSendStatus("Cannot append location: message is at the length limit.", true);
        return false;
      }}
      input.value = nextValue;
      const tail = input.value.length;
      input.focus();
      input.setSelectionRange(tail, tail);
      input.dispatchEvent(new Event("input", {{ bubbles: true }}));
      clearChatHopReplyLocationAutocomplete();
      return true;
    }}

    function chatFeedSelectionKeyForItem(item) {{
      if (!(item instanceof HTMLElement)) return "";
      const messageKey = String(item.dataset.messageKey || "").trim();
      if (messageKey) return `key:${{messageKey}}`;
      const messageId = String(item.dataset.messageId || "").trim();
      if (messageId) return `id:${{messageId}}`;
      const nodeId = normalizeNodeId(item.dataset.nodeId || "");
      if (!nodeId) return "";
      const replyText = String(item.dataset.replyText || "").trim();
      if (replyText) return `node:${{nodeId}}:text:${{replyText}}`;
      return `node:${{nodeId}}`;
    }}

    function bindChatFeedClicks() {{
      const feed = document.getElementById("chat-feed");
      if (!(feed instanceof HTMLElement) || feed.dataset.feedClickBound === "1") return;
      feed.dataset.feedClickBound = "1";
      feed.addEventListener("click", (ev) => {{
        const target = ev.target;
        if (!(target instanceof Element)) return;
        const historyBtn = target.closest(".chat-history-load-btn");
        if (historyBtn instanceof HTMLButtonElement && feed.contains(historyBtn)) {{
          ev.preventDefault();
          ev.stopPropagation();
          void loadOlderChatMessagesForCurrentView();
          return;
        }}
        const item = target.closest(".chat-feed-item");
        if (!(item instanceof HTMLElement) || !feed.contains(item)) return;

        const replyInline = target.closest(".chat-reply-inline");
        if (replyInline instanceof HTMLElement && feed.contains(replyInline)) {{
          ev.preventDefault();
          ev.stopPropagation();
          const targetId = Number(replyInline.dataset.replyTargetId || "");
          if (Number.isInteger(targetId) && targetId > 0) {{
            void jumpToOriginalChatMessage(targetId);
          }}
          return;
        }}

        const retryBtn = target.closest(".chat-retry-btn");
        if (retryBtn instanceof HTMLButtonElement) {{
          ev.preventDefault();
          ev.stopPropagation();
          if (chatSendInFlight) return;
          retryChatMessage({{
            text: retryBtn.dataset.retryText || "",
            destination: retryBtn.dataset.retryDestination || "^all",
            channel_index: Number(retryBtn.dataset.retryChannel || "0"),
            reply_id: Number(retryBtn.dataset.retryReplyId || ""),
            retry_of: Number(retryBtn.dataset.retryOf || ""),
          }});
          return;
        }}

        const whoisBtn = target.closest(".chat-whois-btn");
        if (whoisBtn) {{
          ev.preventDefault();
          ev.stopPropagation();
          const whoisTargetId = normalizeNodeId(
            whoisBtn instanceof HTMLElement
              ? (whoisBtn.dataset.whoisTargetId || item.dataset.fromNodeId || "")
              : (item.dataset.fromNodeId || "")
          );
          const whoisSuffix = nodeIdSuffixForWhois(whoisTargetId);
          if (!isCanonicalNodeId(whoisTargetId) || !whoisSuffix) {{
            setChatSendStatus("Cannot build Whois command: sender ID is unavailable.", true);
            return;
          }}
          const command = buildWhoisCommandForNode(whoisTargetId);
          const input = document.getElementById("chat-input");
          if (!(input instanceof HTMLInputElement)) {{
            setChatSendStatus("Cannot prepare Whois command: chat input is unavailable.", true);
            return;
          }}
          if (chatWhoisQuickActionThreadReply) {{
            const replyId = Number(item.dataset.messageId || "");
            if (Number.isInteger(replyId) && replyId > 0) {{
              const replyName = item.dataset.replyName || "Unknown node";
              const replyText = item.dataset.replyText || "";
              setChatReplyTarget(replyId, replyName, replyText);
            }} else {{
              clearChatReplyTarget();
            }}
          }} else {{
            clearChatReplyTarget();
          }}
          input.value = command;
          input.focus();
          input.setSelectionRange(command.length, command.length);
          input.dispatchEvent(new Event("input", {{ bubbles: true }}));
          setChatSendStatus(
            `Prepared ${{command}} for ${{whoisTargetId}}${{chatWhoisQuickActionThreadReply ? " (reply attached)" : ""}}.`
          );
          return;
        }}

        const replyBtn = target.closest(".chat-reply-btn");
        if (replyBtn) {{
          ev.preventDefault();
          ev.stopPropagation();
          const replyId = Number(item.dataset.messageId || "");
          const replyName = item.dataset.replyName || "Unknown node";
          const replyText = item.dataset.replyText || "";
          if (chatMainDirectModeEnabled && activeChatChannel === "direct" && item.classList.contains("chat-selectable")) {{
            selectNode(item.dataset.nodeId || "", false, false);
          }}
          setChatReplyTarget(replyId, replyName, replyText);
          return;
        }}

        const hopReplyBtn = target.closest(".chat-hop-reply-btn");
        if (hopReplyBtn instanceof HTMLButtonElement) {{
          ev.preventDefault();
          ev.stopPropagation();
          const replyId = Number(item.dataset.messageId || "");
          const replyName = item.dataset.replyName || "Unknown node";
          const replyText = item.dataset.replyText || "";
          if (chatMainDirectModeEnabled && activeChatChannel === "direct" && item.classList.contains("chat-selectable")) {{
            selectNode(item.dataset.nodeId || "", false, false);
          }}
          if (Number.isInteger(replyId) && replyId > 0) {{
            setChatReplyTarget(replyId, replyName, replyText);
          }} else {{
            clearChatReplyTarget();
          }}
          const input = document.getElementById("chat-input");
          if (!(input instanceof HTMLInputElement)) {{
            setChatSendStatus("Cannot prepare hop reply: chat input is unavailable.", true);
            return;
          }}
          const templateText = String(hopReplyBtn.dataset.hopReplyTemplate || "").trim();
          if (!templateText) {{
            setChatSendStatus("Cannot prepare hop reply: hop count is unavailable.", true);
            return;
          }}
          const sourceNodeId = normalizeNodeId(item.dataset.fromNodeId || item.dataset.nodeId || "");
          prepareChatHopReplyLocationAutocomplete(templateText, sourceNodeId, latestState, item);
          input.value = templateText;
          input.focus();
          input.setSelectionRange(templateText.length, templateText.length);
          input.dispatchEvent(new Event("input", {{ bubbles: true }}));
          setChatSendStatus(`Prepared reply template: ${{templateText}} (Tab adds location if available)`);
          return;
        }}

        if (target.closest("a.chat-link")) {{
          // Let browser open the link (target=_blank) without selecting/replying.
          return;
        }}

        if (target.closest("button")) {{
          return;
        }}

        if (chatFeedHasExpandedSelection(item)) {{
          return;
        }}

        if (item.classList.contains("chat-selectable")) {{
          const nodeId = normalizeNodeId(item.dataset.nodeId || "");
          const selectedId = normalizeNodeId(selectedNodeId || "");
          const messageSelectionKey = chatFeedSelectionKeyForItem(item);
          const sameExactChat = (
            !!nodeId
            && nodeId === selectedId
            && nodeId === chatFeedRepeatToggleNodeId
            && !!messageSelectionKey
            && messageSelectionKey === chatFeedRepeatToggleMessageKey
          );
          if (sameExactChat) {{
            clearChatFeedRepeatToggleState();
            clearNodeSelection();
            return;
          }}
          chatFeedSelectionSyncInProgress = true;
          try {{
            chatFeedRepeatToggleNodeId = nodeId;
            chatFeedRepeatToggleMessageKey = messageSelectionKey;
            selectNode(nodeId, true, false);
          }} finally {{
            chatFeedSelectionSyncInProgress = false;
          }}
        }}
      }});
    }}

    function bindLocalNodeSummaryCard() {{
      const card = document.getElementById("summary-ticker-self");
      if (!(card instanceof HTMLElement) || card.dataset.localNodeBound === "1") return;
      card.dataset.localNodeBound = "1";

      const resolveSlotFocusTarget = (target) => {{
        if (!(target instanceof Element)) return null;
        const labelTarget = target.closest("[data-summary-focus-node-id]");
        if (labelTarget instanceof HTMLElement && card.contains(labelTarget)) {{
          const nodeId = normalizeNodeId(labelTarget.dataset.summaryFocusNodeId || "");
          if (isSelectableNodeId(nodeId)) {{
            const kind = String(labelTarget.dataset.summaryFocusKind || "").trim().toLowerCase();
            return {{
              slot: labelTarget,
              nodeId,
              kind: kind === "selected" ? "selected" : "self",
            }};
          }}
        }}
        const slot = target.closest(".self-node-identity-slot");
        if (!(slot instanceof HTMLElement) || !card.contains(slot)) return null;
        const nodeId = normalizeNodeId(slot.dataset.nodeId || "");
        if (!isSelectableNodeId(nodeId)) return null;
        return {{
          slot,
          nodeId,
          kind: String(slot.dataset.identityKind || "").trim().toLowerCase() === "selected"
            ? "selected"
            : "self",
        }};
      }};

      const handleActivate = (hit) => {{
        const cleanNodeId = normalizeNodeId(hit && hit.nodeId ? hit.nodeId : "");
        const kind = String(hit && hit.kind ? hit.kind : "self").trim().toLowerCase();
        if (!isSelectableNodeId(cleanNodeId)) return;
        if (typeof selectNode === "function") {{
          if (kind === "self") {{
            const localNodeId = normalizeNodeId(card.dataset.localNodeId || cleanNodeId);
            if (!isSelectableNodeId(localNodeId)) return;
            const currentSelectedId = normalizeNodeId(selectedNodeId || "");
            if (isSelectableNodeId(currentSelectedId) && currentSelectedId === localNodeId) {{
              if (typeof clearNodeSelection === "function") {{
                clearNodeSelection();
              }}
              return;
            }}
            selectNode(localNodeId, true, false);
            return;
          }}
          selectNode(cleanNodeId, true, false);
        }}
      }};
      card.addEventListener("click", (ev) => {{
        const target = ev.target;
        if (!(target instanceof Element)) return;
        if (target.closest("button, a, input, select, textarea")) return;
        const hit = resolveSlotFocusTarget(target);
        if (!hit) return;
        handleActivate(hit);
      }});
      card.addEventListener("keydown", (ev) => {{
        if (ev.key !== "Enter" && ev.key !== " ") return;
        const target = ev.target instanceof Element ? ev.target : null;
        const hit = resolveSlotFocusTarget(target);
        if (!hit) return;
        ev.preventDefault();
        handleActivate(hit);
      }});
    }}

    function bindChatReactionControls() {{
      bindReactionPopover();
      const bindFeedReactionDelegates = (feedId) => {{
        const feed = document.getElementById(feedId);
        if (!(feed instanceof HTMLElement)) return;
        if (feed.dataset.reactionDelegatedBound === "1") return;
        feed.dataset.reactionDelegatedBound = "1";

        const openReactionPickerFromAnchor = (anchor, options = null) => {{
          if (!(anchor instanceof HTMLButtonElement)) return false;
          if (chatSendInFlight) return false;
          if (Date.now() < chatReactionPickerSuppressOpenUntilMs) {{
            return false;
          }}
          const expand = !!(options && options.expand === true);
          const toggleExpanded = !!(options && options.toggleExpanded === true);
          const replyId = Number(anchor.dataset.replyId || "");
          if (!Number.isInteger(replyId) || replyId <= 0) {{
            setChatSendStatus("Cannot react: target message id is missing.", true);
            return false;
          }}
          const panelOpenForSameTarget = isChatReactionPickerOpenForAnchor(anchor);
          closeReactionPopover(true);
          if (panelOpenForSameTarget) {{
            clearChatReactionPickerHideTimer();
            if (toggleExpanded) {{
              setChatReactionPickerExpanded(!chatReactionPickerExpanded, true);
              return true;
            }}
            if (expand && !chatReactionPickerExpanded) {{
              setChatReactionPickerExpanded(true, true);
            }}
            return true;
          }}
          openChatEmojiPanel("react", replyId, anchor, expand);
          return true;
        }};

        const reactButtonFromTarget = (target) => {{
          if (!(target instanceof Element)) return null;
          const btn = target.closest(".chat-react-btn");
          if (!(btn instanceof HTMLButtonElement)) return null;
          if (!feed.contains(btn)) return null;
          return btn;
        }};
        const summaryButtonFromTarget = (target) => {{
          if (!(target instanceof Element)) return null;
          const summary = target.closest(".chat-reaction-summary");
          if (!(summary instanceof HTMLButtonElement)) return null;
          if (!feed.contains(summary)) return null;
          return summary;
        }};
        const reactionAnchorFromTarget = (target) => (
          reactButtonFromTarget(target) || summaryButtonFromTarget(target)
        );

        feed.addEventListener("click", (ev) => {{
          const reactBtn = reactButtonFromTarget(ev.target);
          if (reactBtn) {{
            ev.preventDefault();
            ev.stopPropagation();
            openReactionPickerFromAnchor(reactBtn, {{ expand: true, toggleExpanded: true }});
            return;
          }}

          const summary = summaryButtonFromTarget(ev.target);
          if (!(summary instanceof HTMLButtonElement)) return;
          ev.preventDefault();
          ev.stopPropagation();
          openReactionPickerFromAnchor(summary, {{ expand: true, toggleExpanded: true }});
        }});

        feed.addEventListener("pointerover", (ev) => {{
          const anchor = reactionAnchorFromTarget(ev.target);
          if (!(anchor instanceof HTMLButtonElement)) return;
          const related = ev.relatedTarget;
          if (related instanceof Node && anchor.contains(related)) {{
            return;
          }}
          clearChatReactionPickerHideTimer();
          openReactionPickerFromAnchor(anchor, {{ expand: false }});
        }});

        feed.addEventListener("pointerout", (ev) => {{
          const anchor = reactionAnchorFromTarget(ev.target);
          if (!(anchor instanceof HTMLButtonElement)) return;
          const related = ev.relatedTarget;
          if (related instanceof Node) {{
            if (anchor.contains(related)) {{
              return;
            }}
            const panel = document.getElementById("chat-emoji-panel");
            if (panel instanceof HTMLElement && panel.contains(related)) {{
              return;
            }}
          }}
          if (chatEmojiMode === "react") {{
            scheduleChatReactionPickerHide(260);
          }}
        }});

        feed.addEventListener("focusin", (ev) => {{
          const anchor = reactionAnchorFromTarget(ev.target);
          if (!(anchor instanceof HTMLButtonElement)) return;
          clearChatReactionPickerHideTimer();
          openReactionPickerFromAnchor(anchor, {{ expand: false }});
        }});
      }};

      bindFeedReactionDelegates("chat-feed");
    }}

    function bindChatRetryControls() {{
      // Retry clicks are handled via delegated `#chat-feed` listener in bindChatFeedClicks().
    }}

    function bindFavoriteMenuControls() {{
      const toggleBtn = document.getElementById("favorite-menu-toggle-btn");
      if (toggleBtn instanceof HTMLButtonElement && toggleBtn.dataset.bound !== "1") {{
        toggleBtn.dataset.bound = "1";
        toggleBtn.addEventListener("click", (ev) => {{
          ev.preventDefault();
          ev.stopPropagation();
          const nextOpen = !favoriteMenuOpen;
          setFavoriteMenuOpen(nextOpen);
          if (nextOpen) {{
            setChatChangeMenuOpen(false);
            setChatSettingsMenuOpen(false);
            scheduleMenuHydrationAfterPaint(() => {{
              if (!favoriteMenuOpen) return;
              renderStarredNodeSelect(latestState || {{}});
            }});
          }}
        }});
      }}

      const menu = document.getElementById("favorite-menu");
      if (menu instanceof HTMLElement && menu.dataset.bound !== "1") {{
        menu.dataset.bound = "1";
        menu.addEventListener("click", (ev) => {{
          const target = ev.target;
          if (!(target instanceof Element)) return;
          const item = target.closest(".favorite-menu-saved-item");
          if (!(item instanceof HTMLButtonElement)) return;
          const nodeId = normalizeNodeId(item.dataset.nodeId || "");
          if (item.classList.contains("favorite-menu-selected-item")) {{
            clearNodeSelection();
            setFavoriteMenuOpen(false);
            return;
          }}
          if (!isSelectableNodeId(nodeId)) return;
          selectNode(nodeId, true, false);
          setFavoriteMenuOpen(false);
        }});
      }}

      if (document.body.dataset.favoriteMenuDocBound !== "1") {{
        document.body.dataset.favoriteMenuDocBound = "1";
        document.addEventListener("pointerdown", (ev) => {{
          if (!favoriteMenuOpen) return;
          const target = ev.target;
          if (!(target instanceof Element)) {{
            setFavoriteMenuOpen(false);
            return;
          }}
          if (target.closest("#favorite-menu-toggle-btn") || target.closest("#favorite-menu")) {{
            return;
          }}
          setFavoriteMenuOpen(false);
        }});
        document.addEventListener("keydown", (ev) => {{
          if (ev.key !== "Escape" || !favoriteMenuOpen) return;
          setFavoriteMenuOpen(false);
        }});
      }}
    }}

    function bindFavoriteToggleControls() {{
      if (document.body.dataset.favoritesBound === "1") return;
      document.body.dataset.favoritesBound = "1";
      document.addEventListener("click", (ev) => {{
        const target = ev.target;
        if (!(target instanceof Element)) return;
        const btn = target.closest(".favorite-toggle-btn");
        if (!(btn instanceof HTMLButtonElement)) return;
        ev.preventDefault();
        ev.stopPropagation();
        toggleFavoriteNode(btn.dataset.nodeId || "");
      }}, true);
    }}

    function bindMuteToggleControls() {{
      if (document.body.dataset.muteBound === "1") return;
      document.body.dataset.muteBound = "1";
      document.addEventListener("click", (ev) => {{
        const target = ev.target;
        if (!(target instanceof Element)) return;
        const btn = target.closest(".mute-toggle-btn");
        if (!(btn instanceof HTMLButtonElement)) return;
        ev.preventDefault();
        ev.stopPropagation();
        toggleMutedNode(btn.dataset.nodeId || "");
      }}, true);
    }}

    function bindPinToggleControls() {{
      if (document.body.dataset.pinBound === "1") return;
      document.body.dataset.pinBound = "1";
      document.addEventListener("click", (ev) => {{
        const target = ev.target;
        if (!(target instanceof Element)) return;
        const btn = target.closest(".pin-toggle-btn");
        if (!(btn instanceof HTMLButtonElement)) return;
        ev.preventDefault();
        ev.stopPropagation();
        togglePinnedNode(btn.dataset.nodeId || "");
      }}, true);
    }}

    function rerenderNodeSearchDependents(state = latestState) {{
      const safeState = state && typeof state === "object" ? state : null;
      if (!safeState) return;
      if (isChatWorkspaceLayoutView(activeLayoutView)) {{
        renderChat(safeState);
      }} else if (typeof renderChatNodeNavigatorList === "function") {{
        renderChatNodeNavigatorList(safeState);
      }}
      if (activeLayoutView === "network") {{
        syncNodesTableForView(activeLayoutView, activeNetworkSubview, safeState.nodes || []);
        const subview = (typeof normalizeNetworkSubview === "function")
          ? normalizeNetworkSubview(activeNetworkSubview)
          : String(activeNetworkSubview || "").trim().toLowerCase();
        if (
          subview === "graph"
          && !(typeof networkSubviewUsesMap === "function" && networkSubviewUsesMap(subview))
          && typeof renderNetworkGraphView === "function"
        ) {{
          renderNetworkGraphView(safeState);
        }} else if (subview === "routes" && typeof renderNetworkRoutes === "function") {{
          renderNetworkRoutes(safeState);
        }} else if (subview === "top10" && typeof renderNetworkTopNodes === "function") {{
          renderNetworkTopNodes(safeState);
        }}
      }}
      renderFavoriteMenuNodeSearchDropdown(safeState);
    }}

    function bindFavoriteMenuNodeSearchControls() {{
      const input = document.getElementById("favorite-menu-node-search-input");
      const dropdown = document.getElementById("favorite-menu-node-search-dropdown");
      if (!(input instanceof HTMLInputElement) || !(dropdown instanceof HTMLElement)) return;

      if (input.dataset.bound !== "1") {{
        input.dataset.bound = "1";
        const openFavoriteNodeSearch = () => {{
          if (favoriteMenuNodeSearchBlurTimer !== null) {{
            clearTimeout(favoriteMenuNodeSearchBlurTimer);
            favoriteMenuNodeSearchBlurTimer = null;
          }}
          setGlobalNodeSearchQuery(input.value, {{
            sourceInputId: "favorite-menu-node-search-input",
            skipSourceInput: true,
          }});
          favoriteMenuNodeSearchOpen = true;
          renderFavoriteMenuNodeSearchDropdown(latestState);
        }};
        input.addEventListener("focus", openFavoriteNodeSearch);
        input.addEventListener("click", openFavoriteNodeSearch);
        input.addEventListener("input", () => {{
          const changed = setGlobalNodeSearchQuery(input.value, {{
            sourceInputId: "favorite-menu-node-search-input",
            skipSourceInput: true,
          }});
          favoriteMenuNodeSearchOpen = true;
          if (changed && latestState) {{
            rerenderNodeSearchDependents(latestState);
          }}
          renderFavoriteMenuNodeSearchDropdown(latestState);
        }});
        input.addEventListener("keydown", (ev) => {{
          if (ev.key === "Escape") {{
            ev.preventDefault();
            closeFavoriteMenuNodeSearchDropdown();
          }}
        }});
        input.addEventListener("blur", () => {{
          if (favoriteMenuNodeSearchBlurTimer !== null) {{
            clearTimeout(favoriteMenuNodeSearchBlurTimer);
          }}
          favoriteMenuNodeSearchBlurTimer = window.setTimeout(() => {{
            favoriteMenuNodeSearchBlurTimer = null;
            closeFavoriteMenuNodeSearchDropdown();
          }}, 120);
        }});
      }}
      if (typeof ensureSearchTextInputClearButton === "function") {{
        ensureSearchTextInputClearButton(input, {{
          clearLabel: "Clear favorite menu node search",
        }});
      }}
      input.value = globalNodeSearchQuery();
      if (typeof syncSearchTextInputClearButton === "function") {{
        syncSearchTextInputClearButton(input);
      }}

      if (dropdown.dataset.bound !== "1") {{
        dropdown.dataset.bound = "1";
        dropdown.addEventListener("mousedown", (ev) => {{
          ev.preventDefault();
          if (favoriteMenuNodeSearchBlurTimer !== null) {{
            clearTimeout(favoriteMenuNodeSearchBlurTimer);
            favoriteMenuNodeSearchBlurTimer = null;
          }}
        }});
        dropdown.addEventListener("click", (ev) => {{
          const target = ev.target;
          if (!(target instanceof Element)) return;
          const item = target.closest(".node-search-item");
          if (!(item instanceof HTMLButtonElement)) return;
          const nodeId = normalizeNodeId(item.dataset.nodeId || "");
          if (!isSelectableNodeId(nodeId)) return;
          selectNode(nodeId, true, false);
          closeFavoriteMenuNodeSearchDropdown();
          setFavoriteMenuOpen(false);
        }});
      }}

      if (document.body.dataset.favoriteNodeSearchOutsideBound !== "1") {{
        document.body.dataset.favoriteNodeSearchOutsideBound = "1";
        document.addEventListener("pointerdown", (ev) => {{
          const inputEl = document.getElementById("favorite-menu-node-search-input");
          const dropdownEl = document.getElementById("favorite-menu-node-search-dropdown");
          if (!(inputEl instanceof HTMLInputElement) || !(dropdownEl instanceof HTMLElement)) return;
          const target = ev.target;
          if (!(target instanceof Node)) return;
          if (inputEl.contains(target) || dropdownEl.contains(target)) return;
          closeFavoriteMenuNodeSearchDropdown();
        }});
      }}
      renderFavoriteMenuNodeSearchDropdown(latestState);
    }}

    function bindNodeListSearchControls() {{
      bindSearchTextInput("nodes-search-input", {{
        value: globalNodeSearchQuery(),
        clearable: true,
        clearLabel: "Clear node search",
        normalize: normalizeSearchQuery,
        onInput: (query) => {{
          const changed = setGlobalNodeSearchQuery(query, {{
            sourceInputId: "nodes-search-input",
            skipSourceInput: true,
          }});
          if (changed && latestState) {{
            rerenderNodeSearchDependents(latestState);
          }}
        }},
      }});

      bindSearchTextInput("chat-user-search-input", {{
        value: globalNodeSearchQuery(),
        clearable: true,
        clearLabel: "Clear node search",
        normalize: normalizeSearchQuery,
        onInput: (query) => {{
          const changed = setGlobalNodeSearchQuery(query, {{
            sourceInputId: "chat-user-search-input",
            skipSourceInput: true,
          }});
          if (changed && latestState) {{
            rerenderNodeSearchDependents(latestState);
          }}
        }},
      }});
    }}

    map.on("click", () => {{
      if (mapWheelJustArmed) {{
        mapWheelJustArmed = false;
        return;
      }}
      clearNodeSelection();
    }});

    map.on("popupopen", () => {{
      const selectedId = normalizeNodeId(selectedNodeId || "");
      if (!isSelectableNodeId(selectedId)) return;
      if (normalizeNodeId(networkNodeInfoCollapsedNodeId || "") === selectedId) {{
        networkNodeInfoCollapsedNodeId = "";
      }}
    }});

    map.on("popupclose", () => {{
      if ((Number(networkNodeInfoPopupProgrammaticDepth) || 0) > 0) return;
      if (activeLayoutView !== "network") return;
      const selectedId = normalizeNodeId(selectedNodeId || "");
      if (!isSelectableNodeId(selectedId)) return;
      networkNodeInfoCollapsedNodeId = selectedId;
    }});
