    function selectNode(nodeId, shouldFocus = true, toggleIfSelected = true) {{
      const normalized = normalizeNodeId(nodeId);
      if (!isSelectableNodeId(normalized)) return;
      if (toggleIfSelected && selectedNodeId && normalized === selectedNodeId) {{
        clearNodeSelection();
        return;
      }}
      selectedNodeId = normalized;
      mapDataFocus = "auto";
      pendingSelectionScroll = activeLayoutView !== "chat";
      persistSelection();
      renderSelectionStatus();
      renderSavedNodeSearchDropdown(latestState);
      if (activeLayoutView === "chat") {{
        pendingMapHistoryFocus = false;
        // Chat-only selection should not trigger map/history work.
        applyChatChannel(activeChatChannel, false);
        return;
      }}
      highlightNodeSelection();
      const focusSelection = shouldFocus && activeLayoutView !== "saved";
      pendingMapHistoryFocus = focusSelection;
      scrollSelectionIntoView();
      let cachedHistory = null;
      if (latestState && (activeLayoutView === "saved" || activeLayoutView === "network")) {{
        cachedHistory = cachedNodeHistory(selectedNodeId);
      }}

      if (activeLayoutView === "saved") {{
        if (cachedHistory) {{
          renderTraffic((latestState && latestState.traffic) || {{}}, (latestState && latestState.nodes) || [], cachedHistory, null);
          renderSavedNodeDetails(latestState || {{}}, cachedHistory);
        }} else {{
          renderNodeHistoryLoading(selectedNodeId);
        }}
      }} else if (activeLayoutView === "network") {{
        // Map-data panel is visible in these views.
        renderTraffic((latestState && latestState.traffic) || {{}}, (latestState && latestState.nodes) || [], cachedHistory, null);
        setMapDataMode(mapDataFocus === "activity" ? "activity" : "live");
      }} else {{
        setMapDataMode("live");
      }}

      if (latestState) {{
        renderMap(latestState.nodes || [], (latestState.traffic || {{}}).edges || [], cachedHistory);
      }}

      updateMapSelection(focusSelection);

      // Kick an immediate history refresh so the signal plot/trail doesn't wait for the next poll.
      void refreshSelectedNodeHistory(false);
      applyChatChannel(activeChatChannel, false);
    }}

    function clearNodeSelection() {{
      selectedNodeId = null;
      pendingMapHistoryFocus = false;
      abortNodeHistoryFetch();
      resetSignalChartZoom("");
      signalChartPoints = [];
      pendingSelectionScroll = false;
      persistSelection();
      renderSelectionStatus();
      renderSavedNodeSearchDropdown(latestState);
      if (activeLayoutView === "chat") {{
        applyChatChannel(activeChatChannel, false);
        return;
      }}
      highlightNodeSelection();
      // If the saved-view freshness chip was showing for a selected node, hide it
      // immediately. (The poll loop might see 304s and skip renderSummary.)
      const chip = document.getElementById("updated-freshness");
      if (chip instanceof HTMLElement) {{
        chip.textContent = "";
        chip.hidden = true;
        applyFreshnessClass(chip, "unknown");
      }}
      updateMapSelection(false);
      map.closePopup();
      setMapDataMode(mapDataFocus === "activity" ? "activity" : "live");
      if (latestState) {{
        renderMap(latestState.nodes || [], (latestState.traffic || {{}}).edges || [], null);
        renderTraffic(latestState.traffic || {{}}, latestState.nodes || [], null, null);
        renderSavedNodeDetails(latestState, null);
      }} else {{
        renderSavedNodeDetails({{}}, null);
      }}
      applyChatChannel(activeChatChannel, false);
    }}

