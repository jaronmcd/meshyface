      const lora = loraConfigFromState(state);
      if (!lora) {{
        if (!settingsDirty && !settingsFetchInFlight && !settingsAutoFetchAttempted) {{
          settingsAutoFetchAttempted = true;
          setText("settings-apply-status", "Fetching current radio settings…");
          void fetchSettingsFromRadio();
