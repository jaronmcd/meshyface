    function defaultNodesTableColPcts() {{
      return [0.13, 0.12, 0.20, 0.14, 0.06, 0.06, 0.07, 0.09, 0.10, 0.03];
    }}

    function normalizeColPcts(pcts) {{
      if (!Array.isArray(pcts) || pcts.length === 0) return null;
      const nums = pcts.map((v) => Number(v));
      if (nums.some((v) => !Number.isFinite(v) || v <= 0)) return null;
      const total = nums.reduce((a, b) => a + b, 0);
      if (!Number.isFinite(total) || total <= 0) return null;
      return nums.map((v) => v / total);
    }}

    function applyNodesTableColPcts(pcts) {{
      const cols = document.querySelectorAll("#nodes-table-cols col");
      if (!cols || cols.length === 0) return;
      const normalized = normalizeColPcts(pcts);
      if (!normalized || normalized.length !== cols.length) return;
      normalized.forEach((pct, idx) => {{
        const col = cols[idx];
        if (col instanceof HTMLElement) {{
          col.style.width = `${{(pct * 100).toFixed(3)}}%`;
        }}
      }});
    }}

    function readNodesTableColPctsFromDom() {{
      const table = document.getElementById("nodes-table");
      const cols = document.querySelectorAll("#nodes-table-cols col");
      if (!(table instanceof HTMLTableElement) || !cols || cols.length === 0) return null;
      const headerRow = table.tHead && table.tHead.rows && table.tHead.rows[0] ? table.tHead.rows[0] : null;
      if (!headerRow || !headerRow.cells || headerRow.cells.length !== cols.length) return null;
      const tableWidth = table.getBoundingClientRect().width;
      if (!Number.isFinite(tableWidth) || tableWidth <= 2) return null;

      const widths = Array.from(headerRow.cells).map((cell) => {{
        const rect = cell.getBoundingClientRect();
        return rect && Number.isFinite(rect.width) ? rect.width : null;
      }});
      if (widths.some((w) => !Number.isFinite(w) || w <= 0)) return null;
      const pcts = widths.map((w) => w / tableWidth);
      return normalizeColPcts(pcts);
    }}

    function persistNodesTableColPcts() {{
      const pcts = readNodesTableColPctsFromDom();
      if (!pcts) return;
      try {{
        window.localStorage.setItem(nodesTableColWidthsStorageKey, JSON.stringify(pcts));
      }} catch (_err) {{
      }}
    }}

