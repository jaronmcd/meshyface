      const nextStickyOffset = Math.max(72, Math.ceil(measuredHeight || 0));
      const nextViewportOffset = nextStickyOffset;
      let nextTopbarCornerReserve = topbarCornerReservePx;
      if (topbarElement instanceof HTMLElement && topbarNotifyCornerElement instanceof HTMLElement) {{
        const topRect = topbarElement.getBoundingClientRect();
