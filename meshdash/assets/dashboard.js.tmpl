    function renderStarredNodeSelect(state) {{
      const select = document.getElementById("starred-node-select");
      if (!(select instanceof HTMLSelectElement)) return;

      const safeState = (state && typeof state === "object") ? state : {{}};
      const nodes = Array.isArray(safeState.nodes) ? safeState.nodes : [];
      const nodesById = new Map(nodes.map((node) => [normalizeNodeId(node.id || ""), node]));
      const entries = Array.from(favoriteNodeIds)
        .map((nodeId) => {{
          const node = nodesById.get(nodeId);
          const name = preferredNodeName(node) || nodeNameCache.get(nodeId) || `Node ${{nodeId}}`;
          return {{ id: nodeId, name }};
        }})
        .sort((a, b) => {{
          const nameDiff = String(a.name || "").localeCompare(String(b.name || ""));
          if (nameDiff !== 0) return nameDiff;
          return String(a.id || "").localeCompare(String(b.id || ""));
        }});

      const placeholder = entries.length > 0
        ? `Starred nodes (${{entries.length}})`
        : "Starred nodes";
      const options = [`<option value="">${{escAttr(placeholder)}}</option>`];
      for (const entry of entries) {{
        options.push(`<option value="${{escAttr(entry.id)}}">${{escAttr(`${{entry.name}} (${{entry.id}})` )}}</option>`);
      }}
      select.innerHTML = options.join("");

      const selectedValue = (isSelectableNodeId(selectedNodeId) && favoriteNodeIds.has(selectedNodeId))
        ? selectedNodeId
        : "";
      select.value = selectedValue;
      select.disabled = entries.length === 0;
      select.title = entries.length > 0
        ? "Jump to a starred node"
        : "No starred nodes yet";
    }}

