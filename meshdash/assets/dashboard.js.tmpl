    function parseSectionJsonTextarea(textareaId) {{
      const textarea = document.getElementById(textareaId);
      if (!(textarea instanceof HTMLTextAreaElement)) {{
        return {{ ok: false, error: "Editor is unavailable", value: null }};
      }}
      const raw = String(textarea.value || "").trim();
      if (!raw) {{
        return {{ ok: false, error: "Enter a JSON object before applying", value: null }};
      }}
      try {{
        const parsed = JSON.parse(raw);
        if (!parsed || typeof parsed !== "object" || Array.isArray(parsed)) {{
          return {{ ok: false, error: "JSON must be an object (field/value pairs)", value: null }};
        }}
        return {{ ok: true, error: "", value: parsed }};
      }} catch (err) {{
        const msg = err instanceof Error ? err.message : String(err || "invalid JSON");
        return {{ ok: false, error: `Invalid JSON: ${{msg}}`, value: null }};
      }}
    }}

    async function postRadioSettingsPayload(payload, pendingLabel, successLabel) {{
      if (settingsApplyInFlight) return false;
      settingsApplyInFlight = true;
      setSettingsButtonsDisabled(true);
      setSettingsStatusText(pendingLabel);
      try {{
        const resp = await fetch(radioSettingsEndpoint, {{
          method: "POST",
          headers: {{ "Content-Type": "application/json" }},
          body: JSON.stringify(payload),
        }});

        const text = await resp.text();
        let parsed = null;
        try {{
          parsed = text ? JSON.parse(text) : null;
        }} catch (_err) {{
        }}

        if (!resp.ok) {{
          const errMsg = parsed && parsed.error ? String(parsed.error) : (text || `HTTP ${{resp.status}}`);
          setSettingsStatusText(`Apply failed: ${{errMsg}}`);
          appendConsoleLine(`settings|${{Date.now()}}|error`, `[settings] apply failed: ${{errMsg}}`);
          return false;
        }}

        const rebootHint = parsed && parsed.reboot_expected ? " Radio may reconnect." : "";
        const actionHint =
          parsed && Array.isArray(parsed.actions_applied) && parsed.actions_applied.length
            ? ` Actions: ${{parsed.actions_applied.join(", ")}}.`
            : "";
        const deletedHint =
          parsed && Number.isFinite(Number(parsed.deleted_history_rows))
            ? ` Cleared rows: ${{Number(parsed.deleted_history_rows)}}.`
            : "";
        setSettingsStatusText(`Applied. ${{successLabel}}.${{rebootHint}}${{actionHint}}${{deletedHint}}`);
        appendConsoleLine(
          `settings|${{Date.now()}}|ok`,
          `[settings] ${{successLabel}}.${{rebootHint}}${{actionHint}}${{deletedHint}}`
        );
        clearSettingsDirty();
        invalidateStateSnapshotCache(parsed && parsed.reboot_expected ? 200 : 20);
        return true;
      }} catch (err) {{
        const msg = err instanceof Error ? err.message : String(err || "unknown error");
        setSettingsStatusText(`Apply error: ${{msg}}`);
        appendConsoleLine(`settings|${{Date.now()}}|error`, `[settings] apply error: ${{msg}}`);
        return false;
      }} finally {{
        settingsApplyInFlight = false;
        setSettingsButtonsDisabled(false);
      }}
    }}

    async function fetchSettingsFromRadio() {{
      if (settingsFetchInFlight) return;
      settingsFetchInFlight = true;
      setSettingsButtonsDisabled(true);
      setSettingsAndChannelsStatusText("Fetching settings…");
      try {{
        const resp = await fetch("/api/raw/local_state", {{ cache: "no-store" }});
        if (!resp.ok) throw new Error(`HTTP ${{resp.status}}`);
        const data = await resp.json();
        const obj = (data && typeof data === "object") ? data : {{}};
        settingsLocalStateCache = obj;
        settingsLocalStateFetchedAt = Date.now();
        clearSettingsDirty();
        renderSettings({{ local_state: obj }}, true);
        try {{
          renderChannelsView({{ ...(latestState && typeof latestState === "object" ? latestState : {{}}), local_state: obj }});
        }} catch (_err) {{}}
        void hydrateMeshChannelOptions(false);
        setSettingsAndChannelsStatusText("Loaded current radio settings.");
        appendConsoleLine(`settings|${{Date.now()}}|fetch`, "[settings] loaded current radio settings.");
      }} catch (err) {{
        const msg = err instanceof Error ? err.message : String(err || "unknown error");
        setSettingsAndChannelsStatusText(`Fetch failed: ${{msg}}`);
        appendConsoleLine(`settings|${{Date.now()}}|error`, `[settings] fetch failed: ${{msg}}`);
      }} finally {{
        setSettingsButtonsDisabled(false);
        settingsFetchInFlight = false;
      }}
    }}

    async function applyLoraSettings() {{
      if (settingsApplyInFlight) return;

      const payload = {{
        lora: {{
          region: readSelectValue("settings-lora-region"),
          modem_preset: readSelectValue("settings-lora-modem-preset"),
          use_preset: readCheckboxValue("settings-lora-use-preset"),
          hop_limit: readNumberValue("settings-lora-hop-limit"),
          tx_power: readNumberValue("settings-lora-tx-power"),
          channel_num: readNumberValue("settings-lora-channel-num"),
          tx_enabled: readCheckboxValue("settings-lora-tx-enabled"),
          bandwidth: readNumberValue("settings-lora-bandwidth"),
          spread_factor: readNumberValue("settings-lora-spread-factor"),
          coding_rate: readNumberValue("settings-lora-coding-rate"),
          frequency_offset: readNumberValue("settings-lora-frequency-offset"),
          override_frequency: readNumberValue("settings-lora-override-frequency", true),
          ignore_mqtt: readCheckboxValue("settings-lora-ignore-mqtt"),
          config_ok_to_mqtt: readCheckboxValue("settings-lora-config-ok-to-mqtt"),
          override_duty_cycle: readCheckboxValue("settings-lora-override-duty-cycle"),
          sx126x_rx_boosted_gain: readCheckboxValue("settings-lora-sx126x-rx-boosted-gain"),
          pa_fan_disabled: readCheckboxValue("settings-lora-pa-fan-disabled"),
        }},
      }};

      for (const [key, value] of Object.entries(payload.lora)) {{
        if (value == null) delete payload.lora[key];
      }}

      if (!payload.lora.region || !payload.lora.modem_preset) {{
        setText("settings-apply-status", "Region + modem preset are required.");
        return;
      }}

      const ok = await postRadioSettingsPayload(
        payload,
        "Applying LoRa settings… (radio may reboot)",
        "LoRa settings saved"
      );
      if (ok) {{
        setTimeout(() => {{
          void fetchSettingsFromRadio();
        }}, 600);
      }}
