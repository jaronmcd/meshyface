    function loadMapBasemapModePreference() {{
      let stored = "online";
      try {{
        stored = window.localStorage.getItem(mapBasemapModeStorageKey) || "online";
      }} catch (_err) {{
      }}
      mapBasemapMode = normalizeMapBasemapMode(stored);
    }}

    function setMapBasemapStatus(status, detail = "") {{
      const el = document.getElementById("map-basemap-status");
      if (!(el instanceof HTMLElement)) {{
        return;
      }}
      const manualOffline = mapBasemapMode === "offline";
      const mode = manualOffline
        ? "offline"
        : (status === "online" || status === "offline" ? status : "loading");
      el.classList.remove("status-online", "status-loading", "status-offline");
      el.classList.add(`status-${{mode}}`);
      if (manualOffline) {{
        el.textContent = "Basemap: offline (forced)";
      }} else if (mode === "online") {{
        el.textContent = "Basemap: online";
      }} else if (mode === "offline") {{
        el.textContent = "Basemap: offline atlas";
      }} else {{
        el.textContent = "Basemap: checking...";
      }}
      if (el instanceof HTMLButtonElement) {{
        el.setAttribute("aria-pressed", manualOffline ? "true" : "false");
      }}
      const titleText = String(detail || "").trim();
      const toggleHint = manualOffline
        ? "Click to switch back to online tiles."
        : "Click to force offline atlas mode.";
      if (titleText) {{
        el.title = `${{titleText}} ${{toggleHint}}`;
      }} else if (manualOffline) {{
        el.title = `Offline mode is forced. Showing offline atlas (countries, coastline, borders, states, urban areas, rivers, lakes, cities). ${{toggleHint}}`;
      }} else if (mode === "offline") {{
        el.title = `Map tiles unavailable. Showing offline atlas (countries, coastline, borders, states, urban areas, rivers, lakes, cities). ${{toggleHint}}`;
      }} else if (mode === "online") {{
        el.title = `Map tiles loaded normally. ${{toggleHint}}`;
      }} else {{
        el.title = `Checking map tile availability. ${{toggleHint}}`;
      }}
    }}

    function setMapBasemapMode(mode, persist = true, reason = "") {{
      const next = normalizeMapBasemapMode(mode);
      mapBasemapMode = next;
      if (persist) {{
        persistMapBasemapMode();
      }}
      if (next === "offline") {{
        clearMapTileProbeTimer();
        if (mapTileLayer && map.hasLayer(mapTileLayer)) {{
          map.removeLayer(mapTileLayer);
        }}
        setMapOfflineFallbackState(true, reason || "Offline mode is forced by user.");
        return;
      }}

      // In online mode we never want offline vectors lingering underneath tiles.
      setMapOfflineFallbackState(false, "Online mode enabled.");
      setMapBasemapStatus("loading", reason || "Online mode enabled. Loading map tiles...");
      applyMapTiles(activeMapTileTheme());
    }}

    function bindMapBasemapToggleControl() {{
      const btn = document.getElementById("map-basemap-status");
      if (!(btn instanceof HTMLButtonElement) || btn.dataset.bound === "1") {{
        return;
      }}
      btn.dataset.bound = "1";
      btn.addEventListener("click", () => {{
        const nextMode = mapBasemapMode === "offline" ? "online" : "offline";
        const reason = nextMode === "offline"
          ? "Offline mode forced by user."
          : "Online mode restored by user.";
        setMapBasemapMode(nextMode, true, reason);
      }});
      setMapBasemapStatus(mapOfflineFallbackActive ? "offline" : "loading");
    }}

    function setMapOfflineFallbackState(enabled, reason = "") {{
      const active = !!enabled;
      if (active === mapOfflineFallbackActive) {{
        if (active) {{
          ensureMapOfflineGridPane();
          void ensureOfflineAtlasLayers();
        }}
        if (active) {{
          setMapBasemapStatus("offline", reason);
        }} else if (mapTileLoadSuccesses > 0) {{
          setMapBasemapStatus("online", reason);
        }}
        if (mapFrameElement instanceof HTMLElement) {{
          mapFrameElement.classList.toggle("map-basemap-offline", active);
        }}
        return;
      }}
      mapOfflineFallbackActive = active;
      if (active) {{
        ensureMapOfflineGridPane();
        void ensureOfflineAtlasLayers();
        setMapBasemapStatus("offline", reason);
      }} else {{
        removeOfflineAtlasLayersFromMap();
        if (mapTileLoadSuccesses > 0) {{
          setMapBasemapStatus("online", reason);
        }}
      }}
      if (mapFrameElement instanceof HTMLElement) {{
        mapFrameElement.classList.toggle("map-basemap-offline", active);
      }}
    }}

    function scheduleMapTileProbe(sessionId) {{
      clearMapTileProbeTimer();
      mapTileProbeTimer = window.setTimeout(() => {{
        if (mapBasemapMode === "offline") {{
          return;
        }}
        if (sessionId !== mapTileLoadSession) {{
          return;
        }}
        if (mapTileLoadSuccesses > 0) {{
          return;
        }}
        const offlineHint = typeof navigator !== "undefined" && navigator && navigator.onLine === false;
        const reason = offlineHint
          ? "Browser is offline. Showing offline atlas reference map."
          : "Map tiles unavailable. Showing offline atlas reference map.";
        setMapOfflineFallbackState(true, reason);
      }}, 2500);
    }}

    function bindMapBasemapConnectivityHandlers() {{
      if (document.body.dataset.mapBasemapConnectivityBound === "1") {{
        return;
      }}
      document.body.dataset.mapBasemapConnectivityBound = "1";
      window.addEventListener("offline", () => {{
        if (mapBasemapMode === "offline") {{
          setMapBasemapStatus("offline", "Offline mode is forced by user.");
          return;
        }}
        if (mapTileLoadSuccesses <= 0) {{
          setMapOfflineFallbackState(true, "Browser is offline. Showing offline atlas reference map.");
        }} else {{
          setMapBasemapStatus(
            "loading",
            "Browser is offline. Cached tiles may remain visible; offline atlas will show if tiles become unavailable."
          );
        }}
      }});
      window.addEventListener("online", () => {{
        if (mapBasemapMode === "offline") {{
          setMapBasemapStatus("offline", "Offline mode is forced by user.");
          return;
        }}
        setMapBasemapStatus("loading", "Connection restored. Checking map tiles...");
        if (mapTileLayer) {{
          mapTileLoadSuccesses = 0;
          mapTileLoadErrors = 0;
          mapTileLayer.redraw();
          scheduleMapTileProbe(mapTileLoadSession);
        }}
      }});
    }}

    function applyMapTiles(themeName) {{
      const nextTheme = themeName === "dark" ? "dark" : "light";
      if (mapTileLayer
        && mapTileTheme === nextTheme
        && mapBasemapMode !== "offline"
        && map.hasLayer(mapTileLayer)) {{
        return;
      }}
      const cfg = mapTileConfigs[nextTheme] || mapTileConfigs.light;
      if (mapTileLayer) {{
        mapTileLayer.off();
        map.removeLayer(mapTileLayer);
      }}
      mapTileLoadSession += 1;
      const sessionId = mapTileLoadSession;
      mapTileLoadSuccesses = 0;
      mapTileLoadErrors = 0;
      setMapBasemapStatus("loading", "Checking map tile availability...");
      const layerOptions = Object.assign({{}}, cfg.options || {{}}, {{
        crossOrigin: true,
      }});
      mapTileLayer = L.tileLayer(cfg.url, layerOptions);
      mapTileLayer.on("tileloadstart", () => {{
        if (mapBasemapMode === "offline") {{
          return;
        }}
        if (sessionId !== mapTileLoadSession) {{
          return;
        }}
        if (mapTileLoadSuccesses <= 0) {{
          setMapBasemapStatus("loading", "Loading map tiles...");
        }}
      }});
      mapTileLayer.on("tileload", () => {{
        if (mapBasemapMode === "offline") {{
          return;
        }}
        if (sessionId !== mapTileLoadSession) {{
          return;
        }}
        mapTileLoadSuccesses += 1;
        mapTileLoadErrors = 0;
        setMapOfflineFallbackState(false, "Map tiles loaded.");
      }});
      mapTileLayer.on("tileerror", () => {{
        if (mapBasemapMode === "offline") {{
          return;
        }}
        if (sessionId !== mapTileLoadSession) {{
          return;
        }}
        mapTileLoadErrors += 1;
        if (mapTileLoadSuccesses <= 0 && mapTileLoadErrors >= 2) {{
          setMapOfflineFallbackState(true, "Tile requests failed. Showing offline atlas reference map.");
        }} else if (mapTileLoadSuccesses <= 0) {{
          setMapBasemapStatus("loading", `Retrying map tiles (${{mapTileLoadErrors}} errors)...`);
        }}
      }});
      mapTileLayer.on("load", () => {{
        if (mapBasemapMode === "offline") {{
          return;
        }}
        if (sessionId !== mapTileLoadSession) {{
          return;
        }}
        if (mapTileLoadSuccesses > 0) {{
          setMapOfflineFallbackState(false, "Map tiles loaded.");
        }} else if (mapTileLoadErrors > 0) {{
          setMapOfflineFallbackState(true, "Map tile load cycle completed without valid tiles.");
        }}
      }});
      if (mapBasemapMode === "offline") {{
        setMapOfflineFallbackState(true, "Offline mode is forced by user.");
      }} else {{
        mapTileLayer.addTo(map);
        scheduleMapTileProbe(sessionId);
      }}
      mapTileTheme = nextTheme;
    }}

    function requestMapResize() {{
      if (mapResizeRaf !== null) {{
        cancelAnimationFrame(mapResizeRaf);
      }}
      mapResizeRaf = requestAnimationFrame(() => {{
        map.invalidateSize({{ pan: false, animate: false }});
        mapResizeRaf = null;
      }});
    }}

    function ensureMapSizeSync() {{
      if (!(mapElement instanceof HTMLElement)) return;
      const width = Math.round(mapElement.clientWidth || 0);
      const height = Math.round(mapElement.clientHeight || 0);
      if (width <= 0 || height <= 0) return;
      const mapSize = map.getSize();
      const mapW = Math.round((mapSize && mapSize.x) || 0);
      const mapH = Math.round((mapSize && mapSize.y) || 0);
      if (Math.abs(mapW - width) > 2 || Math.abs(mapH - height) > 2) {{
        requestMapResize();
      }}
    }}

    function clearMapResizeStabilizeTimers() {{
      if (!Array.isArray(mapResizeStabilizeTimers) || mapResizeStabilizeTimers.length === 0) return;
      for (const timerId of mapResizeStabilizeTimers) {{
        clearTimeout(timerId);
      }}
      mapResizeStabilizeTimers = [];
    }}

    function requestMapResizeStabilized() {{
      clearMapResizeStabilizeTimers();
      requestMapResize();
      for (const delayMs of [90, 220, 420]) {{
        const timerId = window.setTimeout(() => {{
          mapResizeStabilizeTimers = mapResizeStabilizeTimers.filter((id) => id !== timerId);
          requestMapResize();
        }}, delayMs);
        mapResizeStabilizeTimers.push(timerId);
      }}
    }}

    function syncMapSize() {{
      splitTopPx = clampTopSplitPx(splitTopPx);
      splitMidPx = clampMidSplitPx(splitMidPx);
      splitLowPx = clampLowSplitPx(splitLowPx);
      applySplitState();
      requestMapResize();
    }}

    function syncTopbarLayoutMetrics() {{
      const rootStyle = document.documentElement && document.documentElement.style;
      if (!rootStyle) return;
      let measuredHeight = 0;
      if (topbarElement instanceof HTMLElement) {{
        const rect = topbarElement.getBoundingClientRect();
        const rawHeight = Number(rect && rect.height);
        if (Number.isFinite(rawHeight) && rawHeight > 0) {{
          measuredHeight = rawHeight;
        }}
      }}
      const nextStickyOffset = Math.max(72, Math.ceil(measuredHeight || 0));
      const nextViewportOffset = nextStickyOffset;
      if (nextStickyOffset !== topbarStickyOffsetPx) {{
        topbarStickyOffsetPx = nextStickyOffset;
        rootStyle.setProperty("--topbar-sticky-offset", `${{nextStickyOffset}}px`);
      }}
      if (nextViewportOffset !== workspaceViewportOffsetPx) {{
        workspaceViewportOffsetPx = nextViewportOffset;
        rootStyle.setProperty("--workspace-viewport-offset", `${{nextViewportOffset}}px`);
      }}
    }}

    function requestTopbarLayoutMetricsSync() {{
      if (topbarLayoutSyncRaf != null) {{
        cancelAnimationFrame(topbarLayoutSyncRaf);
      }}
      topbarLayoutSyncRaf = requestAnimationFrame(() => {{
        topbarLayoutSyncRaf = null;
        syncTopbarLayoutMetrics();
      }});
    }}

    function bindMapContainerObserver() {{
      if (mapResizeObserver || !mapFrameElement || typeof ResizeObserver === "undefined") {{
        return;
      }}
      mapResizeObserver = new ResizeObserver(() => {{
        requestMapResize();
      }});
      mapResizeObserver.observe(mapFrameElement);
    }}

    function supportsSignalHeatmap() {{
      return !!(window.L && typeof L.heatLayer === "function");
    }}

    function clampUnitInterval(value) {{
      const numeric = Number(value);
      if (!Number.isFinite(numeric)) return 0;
      return Math.max(0, Math.min(1, numeric));
    }}

    function clampNumber(value, minValue, maxValue, fallbackValue) {{
      const numeric = Number(value);
      if (!Number.isFinite(numeric)) return fallbackValue;
      if (Number.isFinite(minValue) && numeric < minValue) return minValue;
      if (Number.isFinite(maxValue) && numeric > maxValue) return maxValue;
      return numeric;
    }}

    function metersPerPixelAtLatitude(lat, zoom) {{
      const latRadians = (Number(lat) * Math.PI) / 180;
      const cosLat = Math.max(0.01, Math.cos(latRadians));
      const zoomLevel = Number.isFinite(Number(zoom)) ? Number(zoom) : 0;
      return (156543.03392 * cosLat) / Math.pow(2, zoomLevel);
    }}

    function normalizeSignalHeatmapMode(rawValue) {{
      const clean = String(rawValue || "").trim().toLowerCase();
      return signalHeatmapModeAccepted.has(clean) ? clean : "coverage";
    }}

    function resolveSignalHeatModeConfig(mode = signalHeatmapMode) {{
      const key = normalizeSignalHeatmapMode(mode);
      return signalHeatModeDefaults[key] || signalHeatModeDefaults.coverage;
    }}

    function signalHeatNodeAgeSeconds(node, nowUnix = Math.floor(Date.now() / 1000)) {{
      const heardUnix = nodeLastHeardUnix(node);
      if (!Number.isFinite(heardUnix) || heardUnix <= 0) {{
        return null;
      }}
      return Math.max(0, nowUnix - heardUnix);
    }}

    function signalHeatNodeWithinWindow(ageSeconds, modeConfig = null) {{
      const config = modeConfig || resolveSignalHeatModeConfig();
      const includeUnknownAge = !!(config && config.includeUnknownAge);
      if (!Number.isFinite(ageSeconds)) {{
        return includeUnknownAge;
      }}
      const maxAgeRaw = Number(config && config.maxAgeSeconds);
      const maxAgeSeconds = Number.isFinite(maxAgeRaw) ? maxAgeRaw : 0;
      if (maxAgeSeconds <= 0) {{
        return true;
      }}
      return ageSeconds <= maxAgeSeconds;
    }}

    function sanitizeSignalHeatDevKnobs(raw) {{
      const next = Object.assign({{}}, signalHeatDevKnobDefaults);
      if (!raw || typeof raw !== "object" || Array.isArray(raw)) {{
        return next;
      }}
      for (const [name, bounds] of Object.entries(signalHeatDevKnobBounds)) {{
        if (!Object.prototype.hasOwnProperty.call(raw, name)) continue;
        const [minValue, maxValue] = bounds;
        next[name] = clampNumber(raw[name], minValue, maxValue, signalHeatDevKnobDefaults[name]);
      }}
      next.freshnessFloor = clampNumber(next.freshnessFloor, 0, 1, signalHeatDevKnobDefaults.freshnessFloor);
      next.freshnessGain = clampNumber(next.freshnessGain, 0, 1 - next.freshnessFloor, signalHeatDevKnobDefaults.freshnessGain);
      return next;
    }}

    function parseSignalHeatDevKnobsFromUrl() {{
      if (!(window.URLSearchParams && window.location && typeof window.location.search === "string")) {{
        return null;
      }}
      const params = new URLSearchParams(window.location.search);
      const fromUrl = {{}};
      const mapping = [
        ["radius", "heat_radius"],
        ["blur", "heat_blur"],
        ["radiusSignalGain", "heat_signal_gain"],
        ["minOpacity", "heat_min_opacity"],
        ["intensityFloor", "heat_floor"],
        ["intensityGamma", "heat_gamma"],
        ["freshnessFloor", "heat_fresh_floor"],
        ["freshnessGain", "heat_fresh_gain"],
        ["greenBias", "heat_green_bias"],
        ["geoRadiusLock", "heat_geo_lock"],
        ["coverageKm", "heat_coverage_km"],
        ["blurRatio", "heat_blur_ratio"],
      ];
      for (const [knobName, paramName] of mapping) {{
        if (!params.has(paramName)) continue;
        fromUrl[knobName] = params.get(paramName);
      }}
      return Object.keys(fromUrl).length > 0 ? fromUrl : null;
    }}

    function parseBoolToken(rawValue, fallbackValue = false) {{
      const clean = String(rawValue == null ? "" : rawValue).trim().toLowerCase();
      if (!clean) return !!fallbackValue;
      if (["1", "true", "yes", "on", "enabled", "enable"].includes(clean)) return true;
      if (["0", "false", "no", "off", "disabled", "disable"].includes(clean)) return false;
      return !!fallbackValue;
    }}

    function getQueryParamValue(name) {{
      if (!(window.URLSearchParams && window.location && typeof window.location.search === "string")) {{
        return null;
      }}
      try {{
        const params = new URLSearchParams(window.location.search);
        if (!params.has(name)) return null;
        return params.get(name);
      }} catch (_err) {{
        return null;
      }}
    }}

    function loadChatPerfPreference() {{
      let enabled = false;
      try {{
        enabled = parseBoolToken(window.localStorage.getItem(chatPerfStorageKey), false);
      }} catch (_err) {{
      }}
      const fromQuery = getQueryParamValue("chat_perf");
      if (fromQuery != null) {{
        enabled = parseBoolToken(fromQuery, enabled);
        try {{
          window.localStorage.setItem(chatPerfStorageKey, enabled ? "1" : "0");
        }} catch (_err) {{
        }}
      }}
      chatPerfEnabled = enabled;
    }}

    function recordChatPerfSample(renderMs, feedCount, rosterCount) {{
      if (!chatPerfEnabled) return;
      const ms = Math.max(0, Number(renderMs) || 0);
      chatPerfStats.samples += 1;
      chatPerfStats.lastMs = ms;
      chatPerfStats.avgMs = chatPerfStats.samples <= 1
        ? ms
        : ((chatPerfStats.avgMs * (chatPerfStats.samples - 1)) + ms) / chatPerfStats.samples;
      chatPerfStats.emaMs = chatPerfStats.samples <= 1
        ? ms
        : (chatPerfStats.emaMs * (1 - chatPerfEmaAlpha)) + (ms * chatPerfEmaAlpha);
      chatPerfStats.maxMs = Math.max(chatPerfStats.maxMs, ms);
      chatPerfStats.lastFeedCount = Math.max(0, Math.trunc(Number(feedCount) || 0));
      chatPerfStats.lastRosterCount = Math.max(0, Math.trunc(Number(rosterCount) || 0));
      chatPerfStats.lastChannel = activeChatChannel;
    }}

    function persistSignalHeatDevKnobs() {{
      try {{
        window.localStorage.setItem(signalHeatDevKnobsStorageKey, JSON.stringify(signalHeatDevKnobs));
      }} catch (_err) {{
      }}
    }}

    function syncSignalHeatmapAfterKnobChange() {{
      if (!latestState || !Array.isArray(latestState.nodes)) return;
      syncSignalHeatmapLayer(latestState.nodes, activeLayoutView === "saved");
    }}

    function setSignalHeatDevKnobs(overrides, persist = true) {{
      signalHeatDevKnobs = sanitizeSignalHeatDevKnobs(
        Object.assign({{}}, signalHeatDevKnobs, overrides || {{}})
      );
      if (persist) {{
        persistSignalHeatDevKnobs();
      }}
      syncSignalHeatmapAfterKnobChange();
      return Object.assign({{}}, signalHeatDevKnobs);
    }}

    function loadSignalHeatDevKnobs() {{
      let stored = null;
      try {{
        const raw = window.localStorage.getItem(signalHeatDevKnobsStorageKey);
        if (raw) {{
          stored = JSON.parse(raw);
        }}
      }} catch (_err) {{
      }}
      const fromUrl = parseSignalHeatDevKnobsFromUrl();
      signalHeatDevKnobs = sanitizeSignalHeatDevKnobs(
        Object.assign({{}}, signalHeatDevKnobDefaults, stored || {{}}, fromUrl || {{}})
      );
    }}

    function bindSignalHeatDevApi() {{
      const api = {{
        get: () => Object.assign({{}}, signalHeatDevKnobs),
        set: (overrides = {{}}, persist = true) => setSignalHeatDevKnobs(overrides, !!persist),
        reset: (persist = true) => {{
          signalHeatDevKnobs = Object.assign({{}}, signalHeatDevKnobDefaults);
          if (persist) {{
            persistSignalHeatDevKnobs();
          }}
          syncSignalHeatmapAfterKnobChange();
          return Object.assign({{}}, signalHeatDevKnobs);
        }},
      }};
      window.meshHeatmapDev = api;
    }}

    function ensureSignalHeatmapLayers() {{
      if (!supportsSignalHeatmap()) {{
        return [];
      }}
      if (Array.isArray(signalHeatmapLayers) && signalHeatmapLayers.length > 0) {{
        return signalHeatmapLayers;
      }}
      let pane = map.getPane(signalHeatmapPaneName);
      if (!pane) {{
        pane = map.createPane(signalHeatmapPaneName);
      }}
      if (pane) {{
        pane.style.zIndex = "430";
        pane.style.pointerEvents = "none";
      }}
      const baseRadius = signalHeatDevKnobs.radius;
      const baseBlur = signalHeatDevKnobs.blur;
      const baseOpacity = signalHeatDevKnobs.minOpacity;
      const signalGain = clampUnitInterval(signalHeatDevKnobs.radiusSignalGain);

      signalHeatmapLayers = signalHeatBucketDefs.map((bucket) => {{
        const baseRadiusMul = Number(bucket.radiusMul) || 1;
        const baseBlurMul = Number(bucket.blurMul) || 1;
        const radiusMul = 1 + ((baseRadiusMul - 1) * signalGain);
        const blurMul = 1 + ((baseBlurMul - 1) * signalGain);
        const radius = clampNumber(
          Math.round(baseRadius * radiusMul),
          10,
          160,
          baseRadius
        );
        const blur = clampNumber(
          Math.round(baseBlur * blurMul),
          8,
          140,
          baseBlur
        );
        return L.heatLayer(
          [],
          Object.assign(
            {{ pane: signalHeatmapPaneName }},
            signalHeatmapLayerOptions,
            {{ radius, blur, minOpacity: baseOpacity }}
          )
        );
      }});
      return signalHeatmapLayers;
    }}

    function forceHeatLayerPointerPassthrough(layer) {{
      if (!layer || typeof layer !== "object") return;
      const canvas = layer._canvas;
      if (!(canvas instanceof HTMLCanvasElement)) return;
      // Some leaflet.heat builds render into overlayPane (ignoring custom panes),
      // which can block marker hover/click unless canvas hit-testing is disabled.
      canvas.style.pointerEvents = "none";
    }}

    function resolveSignalHeatProfile() {{
      const presetRaw = latestState && latestState.summary
        ? String(latestState.summary.modem_preset || "")
        : "";
      const preset = presetRaw.trim().toUpperCase();
      if (preset.startsWith("LONG_")) {{
        return {{
          snrMin: -16,
          snrMax: 8,
          rssiMin: -128,
          rssiMax: -92,
          label: preset || "LONG_*",
        }};
      }}
      if (preset.startsWith("SHORT_")) {{
        return {{
          snrMin: -10,
          snrMax: 12,
          rssiMin: -120,
          rssiMax: -84,
          label: preset || "SHORT_*",
        }};
      }}
      if (preset.startsWith("MEDIUM_")) {{
        return {{
          snrMin: -12,
          snrMax: 10,
          rssiMin: -125,
          rssiMax: -88,
          label: preset,
        }};
      }}
      return {{
        snrMin: signalHeatProfileDefaults.snrMin,
        snrMax: signalHeatProfileDefaults.snrMax,
        rssiMin: signalHeatProfileDefaults.rssiMin,
        rssiMax: signalHeatProfileDefaults.rssiMax,
        label: preset || "DEFAULT",
      }};
    }}

    function normalizeSignalForHeat(rawValue, minValue, maxValue) {{
      const raw = Number(rawValue);
      if (!Number.isFinite(raw)) return null;
      const min = Number(minValue);
      const max = Number(maxValue);
      if (!Number.isFinite(min) || !Number.isFinite(max) || max <= min) return null;
      const clamped = Math.max(min, Math.min(max, raw));
      return (clamped - min) / (max - min);
    }}

    function signalHeatAgeFactor(
      node,
      nowUnix = Math.floor(Date.now() / 1000),
      modeConfig = null,
      ageSeconds = null
    ) {{
      const config = modeConfig || resolveSignalHeatModeConfig();
      const includeUnknownAge = !!(config && config.includeUnknownAge);
      const resolvedAgeSeconds = Number.isFinite(ageSeconds)
        ? ageSeconds
        : signalHeatNodeAgeSeconds(node, nowUnix);
      if (!Number.isFinite(resolvedAgeSeconds)) {{
        return includeUnknownAge ? 0.35 : 0;
      }}
      const freshFullRaw = Number(config && config.freshFullSeconds);
      const freshDropRaw = Number(config && config.freshDropSeconds);
      const tailRaw = Number(config && config.tailWeight);
      const freshFullSeconds = Math.max(0, Number.isFinite(freshFullRaw) ? freshFullRaw : 0);
      const freshDropSeconds = Math.max(
        freshFullSeconds + 1,
        Number.isFinite(freshDropRaw) ? freshDropRaw : freshFullSeconds + 1
      );
      const tailWeight = clampUnitInterval(Number.isFinite(tailRaw) ? tailRaw : 0.03);
      if (resolvedAgeSeconds <= freshFullSeconds) {{
        return 1;
      }}
      if (resolvedAgeSeconds >= freshDropSeconds) {{
        return tailWeight;
      }}
      const span = freshDropSeconds - freshFullSeconds;
      if (span <= 0) {{
        return tailWeight;
      }}
      const ratio = (resolvedAgeSeconds - freshFullSeconds) / span;
      return 1 - (clampUnitInterval(ratio) * (1 - tailWeight));
    }}

    function signalHeatSignalScore(node, profile) {{
      // Score that reflects raw signal quality (SNR/RSSI) but not freshness.
      if (!node || typeof node !== "object") return null;
      const activeProfile = profile || signalHeatProfileDefaults;
      const snrWeight = normalizeSignalForHeat(node.snr, activeProfile.snrMin, activeProfile.snrMax);
      const rssiWeight = normalizeSignalForHeat(node.rssi, activeProfile.rssiMin, activeProfile.rssiMax);
      let signalWeight = null;
      if (Number.isFinite(snrWeight) && Number.isFinite(rssiWeight)) {{
        // Use both when available so the score reflects the full reported signal context.
        signalWeight = ((snrWeight * 0.62) + (rssiWeight * 0.38));
      }} else if (Number.isFinite(snrWeight)) {{
        signalWeight = snrWeight;
      }} else if (Number.isFinite(rssiWeight)) {{
        signalWeight = rssiWeight;
      }}
      if (!Number.isFinite(signalWeight)) return null;
      const greenBiasedSignal = Math.pow(
        clampUnitInterval(signalWeight),
        1 + (clampUnitInterval(signalHeatDevKnobs.greenBias) * 0.55)
      );
      return clampUnitInterval(greenBiasedSignal);
    }}

    function signalHeatWeight(node, profile, nowUnix, modeConfig = null, ageSeconds = null) {{
      // Final weight used for intensity (includes freshness decay).
      const signalScore = signalHeatSignalScore(node, profile);
      if (!Number.isFinite(signalScore)) return null;
      const config = modeConfig || resolveSignalHeatModeConfig();
      const resolvedAgeSeconds = Number.isFinite(ageSeconds)
        ? ageSeconds
        : signalHeatNodeAgeSeconds(node, nowUnix);
      if (!signalHeatNodeWithinWindow(resolvedAgeSeconds, config)) {{
        return null;
      }}
      const ageWeight = signalHeatAgeFactor(node, nowUnix, config, resolvedAgeSeconds);
      const freshnessWeight = signalHeatDevKnobs.freshnessFloor + (ageWeight * signalHeatDevKnobs.freshnessGain);
      return clampUnitInterval(signalScore * freshnessWeight);
    }}

    function resolveSignalHeatBucketIndex(signalScore) {{
      const score = clampUnitInterval(signalScore);
      for (let i = 0; i < signalHeatBucketDefs.length; i++) {{
        const bucket = signalHeatBucketDefs[i];
        const min = Number(bucket && bucket.min);
        const max = Number(bucket && bucket.max);
        if (!Number.isFinite(min) || !Number.isFinite(max)) continue;
        if (score >= min && score < max) {{
          return i;
        }}
      }}
      return Math.max(0, signalHeatBucketDefs.length - 1);
    }}

    function collectSignalHeatmapBuckets(nodes, profile) {{
      const buckets = signalHeatBucketDefs.map(() => []);
      const nowUnix = Math.floor(Date.now() / 1000);
      const modeConfig = resolveSignalHeatModeConfig();
      const intensityFloor = signalHeatDevKnobs.intensityFloor;
      for (const node of (nodes || [])) {{
        const lat = Number(node && node.lat);
        const lon = Number(node && node.lon);
        if (!isValidMapCoord(lat, lon)) continue;
        const ageSeconds = signalHeatNodeAgeSeconds(node, nowUnix);
        if (!signalHeatNodeWithinWindow(ageSeconds, modeConfig)) continue;

        const signalScore = signalHeatSignalScore(node, profile);
        if (!Number.isFinite(signalScore)) continue;

        const weight = signalHeatWeight(node, profile, nowUnix, modeConfig, ageSeconds);
        if (!Number.isFinite(weight)) continue;

        const eased = Math.pow(clampUnitInterval(weight), signalHeatDevKnobs.intensityGamma);
        const intensity = intensityFloor + (eased * (1 - intensityFloor));
        const idx = resolveSignalHeatBucketIndex(signalScore);
        const bucket = signalHeatBucketDefs[idx] || {};
        const signalGain = clampUnitInterval(signalHeatDevKnobs.radiusSignalGain);
        const baseMul = Number(bucket && bucket.intensityMul);
        const intensityMul = 1 + (((Number.isFinite(baseMul) ? baseMul : 1) - 1) * signalGain);
        const adjusted = clampUnitInterval(intensity * intensityMul);
        const points = buckets[idx] || buckets[0];
        points.push([lat, lon, Math.max(intensityFloor, adjusted)]);
      }}
      return buckets;
    }}

    function collectSavedNodeHeatmapBuckets(nodes, profile) {{
      const buckets = signalHeatBucketDefs.map(() => []);
      const selectedId = normalizeNodeId(selectedNodeId || "");
      if (!(activeLayoutView === "saved" && isSelectableNodeId(selectedId))) {{
        return buckets;
      }}
      const selectedNode = (nodes || []).find((node) => normalizeNodeId(node && node.id) === selectedId);
      if (!selectedNode) {{
        return buckets;
      }}
      const lat = Number(selectedNode.lat);
      const lon = Number(selectedNode.lon);
      if (!isValidMapCoord(lat, lon)) {{
        return buckets;
      }}
      const nowUnix = Math.floor(Date.now() / 1000);
      const modeConfig = resolveSignalHeatModeConfig();
      const ageSeconds = signalHeatNodeAgeSeconds(selectedNode, nowUnix);
      if (!signalHeatNodeWithinWindow(ageSeconds, modeConfig)) {{
        return buckets;
      }}
      const weight = signalHeatWeight(selectedNode, profile, nowUnix, modeConfig, ageSeconds);
      if (!Number.isFinite(weight)) {{
        return buckets;
      }}
      const intensityFloor = signalHeatDevKnobs.intensityFloor;
      const eased = Math.pow(clampUnitInterval(weight), signalHeatDevKnobs.intensityGamma);
      const intensity = intensityFloor + (eased * (1 - intensityFloor));
      // Saved/Node view uses a simple singular footprint for the selected node.
      buckets[0].push([lat, lon, Math.max(intensityFloor, clampUnitInterval(intensity))]);
      return buckets;
    }}

    function resolveSignalHeatVisualOptions(pointsCount) {{
      const geoLocked = signalHeatDevKnobs.geoRadiusLock >= 0.5;
      const zoom = Number(map.getZoom());
      const safeCount = Number.isFinite(pointsCount) ? Math.max(0, Math.round(pointsCount)) : 0;
      let radius = signalHeatDevKnobs.radius;
      let blur = signalHeatDevKnobs.blur;

      if (geoLocked) {{
        const center = map.getCenter();
        const centerLat = center && Number.isFinite(center.lat) ? center.lat : 0;
        const metersPerPixel = metersPerPixelAtLatitude(centerLat, zoom);
        const targetMeters = Math.max(100, signalHeatDevKnobs.coverageKm * 1000);
        radius = clampNumber(Math.round(targetMeters / Math.max(1, metersPerPixel)), 10, 96, signalHeatDevKnobs.radius);
        blur = clampNumber(Math.round(radius * signalHeatDevKnobs.blurRatio), 8, 80, signalHeatDevKnobs.blur);
      }} else {{
        if (safeCount >= 36 || (safeCount >= 24 && zoom >= 11)) {{
          radius = Math.max(16, radius - 2);
          blur = Math.max(12, blur - 2);
        }} else if (safeCount >= 18 || zoom >= 10) {{
          radius = Math.max(15, radius - 1);
          blur = Math.max(11, blur - 1);
        }}
        if (zoom >= 13) {{
          radius = Math.max(14, radius - 2);
          blur = Math.max(10, blur - 2);
        }}
      }}

      return {{
        radius,
        blur,
        minOpacity: signalHeatDevKnobs.minOpacity,
      }};
    }}

    function updateSignalHeatmapControl(
      pointsCount = null,
      supported = supportsSignalHeatmap(),
      profileLabel = ""
    ) {{
      const wrap = document.getElementById("map-heatmap-wrap");
      const toggle = document.getElementById("map-heatmap-toggle");
      const modeWrap = document.getElementById("map-heatmap-mode-wrap");
      const modeSelect = document.getElementById("map-heatmap-mode");
      const modeConfig = resolveSignalHeatModeConfig();
      const modeLabel = String(modeConfig && modeConfig.label ? modeConfig.label : "Coverage");
      const maxAgeSeconds = Number(modeConfig && modeConfig.maxAgeSeconds);
      const fadeSeconds = Number(modeConfig && modeConfig.freshDropSeconds);
      const maxAgeMinutes = Math.max(
        1,
        Math.round((Number.isFinite(maxAgeSeconds) ? Math.max(0, maxAgeSeconds) : 0) / 60)
      );
      const fadeMinutes = Math.max(
        1,
        Math.round((Number.isFinite(fadeSeconds) ? Math.max(0, fadeSeconds) : 0) / 60)
      );
      const inMapHeatContext = (
        activeLayoutView === "network"
        || activeLayoutView === "saved"
      );
      if (wrap instanceof HTMLElement) {{
        wrap.hidden = !inMapHeatContext;
        wrap.classList.toggle("disabled", !supported);
        const profileText = profileLabel ? `Tuned for ${{profileLabel}}.` : "";
        const modeText = ` Mode: ${{modeLabel}} (heard within ~${{maxAgeMinutes}}m).`;
        const fadeText = ` Freshness decays over ~${{fadeMinutes}}m.`;
        const geoText = signalHeatDevKnobs.geoRadiusLock >= 0.5
          ? " Coverage is geo-locked (km-stable across zoom/latitude)."
          : "";
        const devText = " Dev knobs: window.meshHeatmapDev.get()/set()/reset().";
        const savedModeText = activeLayoutView === "saved"
          ? " In Node view this shows only the selected node's signal footprint."
          : "";
        const baseTitle = supported
          ? `Overlay realtime signal heatmap from positioned nodes. Intensity and radius are derived from reported SNR/RSSI (freshness-faded). ${{profileText}}${{modeText}}${{fadeText}}${{savedModeText}}${{geoText}}${{devText}}`
          : "Heatmap overlay is unavailable (leaflet.heat not loaded).";
        if (Number.isFinite(pointsCount)) {{
          wrap.title = `${{baseTitle}} Active nodes with signal+position: ${{pointsCount}}.`;
        }} else {{
          wrap.title = baseTitle;
        }}
      }}
      if (modeWrap instanceof HTMLElement) {{
        modeWrap.hidden = !inMapHeatContext;
        modeWrap.classList.toggle("disabled", !supported);
        modeWrap.title = supported
          ? `Heatmap recency mode. ${{modeLabel}} currently keeps nodes heard within about ${{maxAgeMinutes}} minutes.`
          : "Heatmap overlay is unavailable (leaflet.heat not loaded).";
      }}
      if (toggle instanceof HTMLInputElement) {{
        toggle.checked = signalHeatmapEnabled;
        toggle.disabled = !supported;
      }}
      if (modeSelect instanceof HTMLSelectElement) {{
        modeSelect.value = normalizeSignalHeatmapMode(signalHeatmapMode);
        modeSelect.disabled = !supported;
      }}
    }}

    function syncSignalHeatmapLayer(nodes, forceHide = false) {{
      const layers = ensureSignalHeatmapLayers();
      const profile = resolveSignalHeatProfile();
      const supported = Array.isArray(layers) && layers.length > 0;
      const savedSingleNodeMode = activeLayoutView === "saved" && isSelectableNodeId(selectedNodeId);
      const buckets = supported
        ? (
            savedSingleNodeMode
              ? collectSavedNodeHeatmapBuckets(nodes, profile)
              : collectSignalHeatmapBuckets(nodes, profile)
          )
        : [];
      const pointsCount = supported
        ? buckets.reduce((acc, pts) => acc + (Array.isArray(pts) ? pts.length : 0), 0)
        : 0;
      updateSignalHeatmapControl(pointsCount, supported, profile.label || "");
      if (!supported) {{
        return;
      }}
      const baseVisual = resolveSignalHeatVisualOptions(pointsCount);
      const shouldShow = !(forceHide && !savedSingleNodeMode)
        && signalHeatmapEnabled
        && pointsCount > 0;

      for (let i = 0; i < layers.length; i++) {{
        const layer = layers[i];
        if (savedSingleNodeMode && i > 0) {{
          layer.setLatLngs([]);
          if (map.hasLayer(layer)) {{
            map.removeLayer(layer);
          }}
          continue;
        }}
        const bucket = signalHeatBucketDefs[i] || {{}};
        const signalGain = clampUnitInterval(signalHeatDevKnobs.radiusSignalGain);
        const baseRadiusMul = Number(bucket.radiusMul);
        const baseBlurMul = Number(bucket.blurMul);
        const radiusMul = 1 + ((Number.isFinite(baseRadiusMul) ? baseRadiusMul : 1) - 1) * signalGain;
        const blurMul = 1 + ((Number.isFinite(baseBlurMul) ? baseBlurMul : 1) - 1) * signalGain;
        const visual = savedSingleNodeMode
          ? {{
              radius: clampNumber(
                Math.round(baseVisual.radius * 1.3),
                10,
                160,
                baseVisual.radius
              ),
              blur: clampNumber(
                Math.round(baseVisual.blur * 1.2),
                8,
                140,
                baseVisual.blur
              ),
              minOpacity: Math.max(baseVisual.minOpacity, 0.42),
            }}
          : {{
              radius: clampNumber(
                Math.round(baseVisual.radius * radiusMul),
                10,
                160,
                baseVisual.radius
              ),
              blur: clampNumber(
                Math.round(baseVisual.blur * blurMul),
                8,
                140,
                baseVisual.blur
              ),
              minOpacity: baseVisual.minOpacity,
            }};
        if (typeof layer.setOptions === "function") {{
          layer.setOptions(visual);
        }}
        layer.setLatLngs((buckets[i] || []));
        if (shouldShow) {{
          if (!map.hasLayer(layer)) {{
            layer.addTo(map);
          }}
          forceHeatLayerPointerPassthrough(layer);
        }} else if (map.hasLayer(layer)) {{
          map.removeLayer(layer);
        }}
      }}
    }}

    function isMapWheelGuardEnabled() {{
      // Wheel-zoom gating was causing confusion (and can feel like "zoom is broken").
      // Keep scroll wheel zoom enabled everywhere for reliability.
      return false;
    }}

    function setMapWheelZoomActive(active) {{
      const guardEnabled = isMapWheelGuardEnabled();
      const next = guardEnabled ? !!active : true;
      if (mapWheelZoomActive === next) {{
        return;
      }}
      mapWheelZoomActive = next;
      if (!mapWheelZoomActive || !guardEnabled) {{
        mapWheelJustArmed = false;
        if (mapWheelLease !== null) {{
          clearTimeout(mapWheelLease);
          mapWheelLease = null;
        }}
      }}
      if (mapWheelZoomActive) {{
        map.scrollWheelZoom.enable();
      }} else {{
        map.scrollWheelZoom.disable();
      }}
      if (mapFrameElement) {{
        if (guardEnabled) {{
          mapFrameElement.classList.toggle("map-wheel-active", mapWheelZoomActive);
          mapFrameElement.setAttribute(
            "title",
            mapWheelZoomActive
              ? "Map wheel zoom active. Click outside map (or press Esc) to return wheel scrolling to page."
              : "Click map to enable wheel zoom."
          );
        }} else {{
          mapFrameElement.classList.remove("map-wheel-active");
          mapFrameElement.setAttribute("title", "Scroll wheel zoom is enabled.");
        }}
      }}
    }}

    function touchMapWheelLease() {{
      if (!mapWheelZoomActive || !isMapWheelGuardEnabled()) {{
        return;
      }}
      if (mapWheelLease !== null) {{
        clearTimeout(mapWheelLease);
      }}
      mapWheelLease = window.setTimeout(() => {{
        setMapWheelZoomActive(false);
      }}, wheelActivationLeaseMs);
    }}

    function bindMapWheelActivation() {{
      if (!mapFrameElement || mapFrameElement.dataset.wheelMapBound === "1") {{
        return;
      }}
      mapFrameElement.dataset.wheelMapBound = "1";
      setMapWheelZoomActive(activeLayoutView === "network" || activeLayoutView === "saved");

      mapFrameElement.addEventListener("pointerdown", (ev) => {{
        if (!isMapWheelGuardEnabled()) {{
          return;
        }}
        if (!(ev.target instanceof Element)) {{
          return;
        }}
        if (ev.target.closest(".leaflet-control")) {{
          return;
        }}
        if (!mapWheelZoomActive) {{
          mapWheelJustArmed = true;
        }}
        setMapWheelZoomActive(true);
        touchMapWheelLease();
      }});

      mapFrameElement.addEventListener("wheel", () => {{
        touchMapWheelLease();
      }}, {{ passive: true }});

      document.addEventListener("pointerdown", (ev) => {{
        if (!isMapWheelGuardEnabled()) {{
          return;
        }}
        if (!(ev.target instanceof Element)) {{
          setMapWheelZoomActive(false);
          return;
        }}
        if (!mapFrameElement.contains(ev.target)) {{
          setMapWheelZoomActive(false);
        }}
      }});
      document.addEventListener("keydown", (ev) => {{
        if (!isMapWheelGuardEnabled()) {{
          return;
        }}
        if (ev.key === "Escape") {{
          setMapWheelZoomActive(false);
        }}
      }});
    }}

    function bindWheelPassthrough() {{
      const isWheelPassthroughEnabled = () => (
        activeLayoutView !== "chat" && activeLayoutView !== "network" && activeLayoutView !== "saved"
      );

      const refreshWheelPaneHints = () => {{
        const enabled = isWheelPassthroughEnabled();
        if (!enabled && activeWheelPane instanceof HTMLElement) {{
          activeWheelPane.classList.remove("wheel-scroll-active");
          activeWheelPane = null;
        }}
        if (!enabled && activeWheelPaneLease !== null) {{
          clearTimeout(activeWheelPaneLease);
          activeWheelPaneLease = null;
        }}
        for (const el of document.querySelectorAll(wheelPaneSelector)) {{
          if (!(el instanceof HTMLElement)) continue;
          if (enabled) {{
            if (!el.getAttribute("title")) {{
              el.setAttribute("title", "Click panel to wheel-scroll inside it. Auto-releases after a brief pause.");
              el.dataset.wheelHintOwned = "1";
            }}
          }} else if (el.dataset.wheelHintOwned === "1") {{
            el.removeAttribute("title");
            delete el.dataset.wheelHintOwned;
          }}
        }}
      }};

      const clearWheelPaneLease = () => {{
        if (activeWheelPaneLease !== null) {{
          clearTimeout(activeWheelPaneLease);
          activeWheelPaneLease = null;
        }}
      }};

      const touchWheelPaneLease = () => {{
        if (!(activeWheelPane instanceof HTMLElement)) {{
          clearWheelPaneLease();
          return;
        }}
        clearWheelPaneLease();
        activeWheelPaneLease = window.setTimeout(() => {{
          setActiveWheelPane(null);
        }}, wheelActivationLeaseMs);
      }};

      const setActiveWheelPane = (next) => {{
        if (activeWheelPane === next) {{
          if (activeWheelPane instanceof HTMLElement) {{
            touchWheelPaneLease();
          }}
          return;
        }}
        if (activeWheelPane instanceof HTMLElement) {{
          activeWheelPane.classList.remove("wheel-scroll-active");
        }}
        activeWheelPane = next instanceof HTMLElement ? next : null;
        if (activeWheelPane) {{
          activeWheelPane.classList.add("wheel-scroll-active");
          if (document.activeElement !== activeWheelPane) {{
            activeWheelPane.focus({{ preventScroll: true }});
          }}
          touchWheelPaneLease();
        }} else {{
          clearWheelPaneLease();
        }}
      }};

      const canScrollInDirection = (el, delta) => {{
        if (!(el instanceof HTMLElement)) {{
          return false;
        }}
        const max = el.scrollHeight - el.clientHeight;
        if (max <= 1) {{
          return false;
        }}
        if (delta > 0) {{
          return el.scrollTop < (max - 1);
        }}
        if (delta < 0) {{
          return el.scrollTop > 1;
        }}
        return false;
      }};

      const routeWheelToPage = (delta) => {{
        window.scrollBy({{ top: delta, behavior: "auto" }});
      }};

      for (const el of document.querySelectorAll(wheelPaneSelector)) {{
        if (!(el instanceof HTMLElement) || el.dataset.wheelPassBound === "1") {{
          continue;
        }}
        el.dataset.wheelPassBound = "1";
        if (!el.hasAttribute("tabindex")) {{
          el.tabIndex = 0;
        }}
        el.addEventListener("pointerdown", () => {{
          if (!isWheelPassthroughEnabled()) {{
            return;
          }}
          setActiveWheelPane(el);
        }});
        el.addEventListener("focusin", () => {{
          if (!isWheelPassthroughEnabled()) {{
            return;
          }}
          setActiveWheelPane(el);
        }});
        el.addEventListener(
          "wheel",
          (ev) => {{
            if (!isWheelPassthroughEnabled()) {{
              return;
            }}
            if (ev.defaultPrevented || ev.ctrlKey || ev.metaKey) {{
              return;
            }}
            const delta = Math.abs(ev.deltaY) >= Math.abs(ev.deltaX) ? ev.deltaY : ev.deltaX;
            if (!Number.isFinite(delta) || delta === 0) {{
              return;
            }}

            const paneIsActive = activeWheelPane === el;
            if (!paneIsActive) {{
              ev.preventDefault();
              routeWheelToPage(delta);
              return;
            }}

            if (canScrollInDirection(el, delta)) {{
              touchWheelPaneLease();
              return;
            }}

            ev.preventDefault();
            routeWheelToPage(delta);
            setActiveWheelPane(null);
          }},
          {{ passive: false }}
        );
      }}
      refreshWheelPaneHints();

      if (document.body.dataset.wheelPassDocBound !== "1") {{
        document.body.dataset.wheelPassDocBound = "1";
        document.addEventListener("pointerdown", (ev) => {{
          if (!(ev.target instanceof Element)) {{
            setActiveWheelPane(null);
            return;
          }}
          if (!ev.target.closest(wheelPaneSelector)) {{
            setActiveWheelPane(null);
          }}
        }});
        document.addEventListener("keydown", (ev) => {{
          if (ev.key === "Escape") {{
            setActiveWheelPane(null);
          }}
        }});
      }}

      // Expose a tiny hook so view changes can toggle wheel hints/behavior.
      window.meshRefreshWheelHints = refreshWheelPaneHints;
    }}

    map.whenReady(() => {{
      requestMapResize();
      bindMapContainerObserver();
      bindMapWheelActivation();
      map.on("movestart", () => {{
        if ((Number.isFinite(Number(programmaticMapMoveDepth)) ? programmaticMapMoveDepth : 0) > 0) return;
        pendingMapHistoryFocus = false;
      }});
      map.on("zoomstart", () => {{
        if ((Number.isFinite(Number(programmaticMapMoveDepth)) ? programmaticMapMoveDepth : 0) > 0) return;
        pendingMapHistoryFocus = false;
        // Avoid odd canvas artifacts while zooming (leaflet.heat can look glitchy mid-zoom).
        const nodes = latestState && Array.isArray(latestState.nodes) ? latestState.nodes : [];
        syncSignalHeatmapLayer(nodes, true);
      }});
      map.on("zoomend", () => {{
        const nodes = latestState && Array.isArray(latestState.nodes) ? latestState.nodes : [];
        syncSignalHeatmapLayer(nodes, activeLayoutView === "saved");
        if (mapOfflineFallbackActive || mapBasemapMode === "offline") {{
          syncOfflineCityVisibility();
        }}
      }});
      map.on("moveend", () => {{
        const nodes = latestState && Array.isArray(latestState.nodes) ? latestState.nodes : [];
        if (signalHeatDevKnobs.geoRadiusLock >= 0.5) {{
          syncSignalHeatmapLayer(nodes, activeLayoutView === "saved");
        }}
        if (mapOfflineFallbackActive || mapBasemapMode === "offline") {{
          syncOfflineCityVisibility();
        }}
      }});
    }});
    window.addEventListener("resize", () => {{
      requestTopbarLayoutMetricsSync();
      setTimeout(() => {{
        syncMapSize();
        requestTopbarLayoutMetricsSync();
      }}, 120);
    }});

    function setText(id, value) {{
      const el = document.getElementById(id);
      if (!el) return;
      el.textContent = value == null ? "n/a" : String(value);
    }}

    function formatTickerNumber(value, digits = 0) {{
      const numeric = Number(value);
      if (!Number.isFinite(numeric)) return "n/a";
      const fixedDigits = Math.max(0, Math.min(2, Math.floor(Number(digits) || 0)));
      return fixedDigits > 0 ? numeric.toFixed(fixedDigits) : `${{Math.round(numeric)}}`;
    }}

    function derivePacketsPerMinuteFromTotals(points) {{
      const series = Array.isArray(points) ? points : [];
      if (series.length < 2) return 0;
      const latestPoint = series[series.length - 1] || null;
      const previousPoint = series[series.length - 2] || null;
      const latestTotal = Number(latestPoint && latestPoint.value);
      const previousTotal = Number(previousPoint && previousPoint.value);
      if (!Number.isFinite(latestTotal) || !Number.isFinite(previousTotal)) {{
        return 0;
      }}
      const latestMs = Number(latestPoint && latestPoint.ms);
      const previousMs = Number(previousPoint && previousPoint.ms);
      const spanMinutes = (Number.isFinite(latestMs) && Number.isFinite(previousMs) && latestMs > previousMs)
        ? Math.max(1 / 60, (latestMs - previousMs) / 60000)
        : 1;
      const delta = latestTotal - previousTotal;
      if (!Number.isFinite(delta) || delta <= 0) return 0;
      return delta / spanMinutes;
    }}

    function derivePacketsPerMinuteSeriesFromTotals(points) {{
      const series = Array.isArray(points) ? points : [];
      if (series.length < 2) return [];
      const output = [];
      for (let i = 1; i < series.length; i += 1) {{
        const previousPoint = series[i - 1] || null;
        const currentPoint = series[i] || null;
        const previousTotal = Number(previousPoint && previousPoint.value);
        const currentTotal = Number(currentPoint && currentPoint.value);
        if (!Number.isFinite(previousTotal) || !Number.isFinite(currentTotal)) continue;
        const previousMs = Number(previousPoint && previousPoint.ms);
        const currentMs = Number(currentPoint && currentPoint.ms);
        const spanMinutes = (Number.isFinite(previousMs) && Number.isFinite(currentMs) && currentMs > previousMs)
          ? Math.max(1 / 60, (currentMs - previousMs) / 60000)
          : 1;
        const delta = currentTotal - previousTotal;
        const rate = Number.isFinite(delta) && delta > 0 ? (delta / spanMinutes) : 0;
        output.push({{
          ms: Number.isFinite(currentMs) ? currentMs : Date.now(),
          value: rate,
        }});
      }}
      return output;
    }}

    function trimMetricTickerPoints(points, cutoffMs) {{
      while (points.length > 0) {{
        const firstMs = Number(points[0] && points[0].ms);
        if (Number.isFinite(firstMs) && firstMs >= cutoffMs) {{
          break;
        }}
        points.shift();
      }}
      while (points.length > metricTickerMaxPoints) {{
        points.shift();
      }}
    }}

    function metricTickerLatestValue(metricKey) {{
      const cleanKey = String(metricKey || "").trim();
      if (!cleanKey) return null;
      const points = metricTickerSeries.get(cleanKey);
      if (!Array.isArray(points) || points.length === 0) return null;
      const latest = Number(points[points.length - 1] && points[points.length - 1].value);
      return Number.isFinite(latest) ? latest : null;
    }}

    function maybeResetMetricTickerSeries(livePacketTotal) {{
      const latestLiveTotal = metricTickerLatestValue("live_packets");
      const nextLiveTotal = Number(livePacketTotal);
      if (!Number.isFinite(latestLiveTotal) || !Number.isFinite(nextLiveTotal)) {{
        return false;
      }}
      // live_packet_count is monotonic within a runtime session. If it moves
      // backward, assume a tracker/runtime reset and restart ticker history so
      // scales don't stay anchored to the previous session.
      if (nextLiveTotal + 1 < latestLiveTotal) {{
        metricTickerSeries.clear();
        return true;
      }}
      return false;
    }}

    function sliceSummaryPointsAfterLiveCounterReset(points) {{
      const rows = Array.isArray(points) ? points : [];
      if (!resetTickerScaleOnRestart || rows.length < 2) {{
        return rows;
      }}
      let previousTotal = null;
      let resetStartIndex = 0;
      for (let i = 0; i < rows.length; i += 1) {{
        const currentTotal = Number(rows[i] && rows[i].live_packet_count);
        if (!Number.isFinite(currentTotal)) continue;
        if (Number.isFinite(previousTotal) && (currentTotal + 1 < previousTotal)) {{
          // Keep the newest segment when the monotonic live counter rolls over.
          resetStartIndex = i;
        }}
        previousTotal = currentTotal;
      }}
      return resetStartIndex > 0 ? rows.slice(resetStartIndex) : rows;
    }}

    function appendMetricTickerPoint(metricKey, rawValue, nowMs = Date.now()) {{
      const cleanKey = String(metricKey || "").trim();
      const value = Number(rawValue);
      if (!cleanKey || !Number.isFinite(value)) return [];
      const bucketMs = Math.floor(nowMs / 60000) * 60000;
      const points = metricTickerSeries.get(cleanKey) || [];
      const last = points.length ? points[points.length - 1] : null;
      if (last && Number(last.ms) === bucketMs) {{
        last.value = value;
      }} else {{
        points.push({{ ms: bucketMs, value }});
      }}
      trimMetricTickerPoints(points, bucketMs - metricTickerWindowMs);
      metricTickerSeries.set(cleanKey, points);
      return points;
    }}

    function buildMetricTickerPath(points, width = 72, height = 16, pad = 1.5) {{
      if (!Array.isArray(points) || points.length === 0) return "";
      const values = points
        .map((point) => Number(point && point.value))
        .filter((value) => Number.isFinite(value));
      if (values.length === 0) return "";
      const widthPx = Math.max(4, Number(width) || 72);
      const heightPx = Math.max(4, Number(height) || 16);
      const padPx = Math.max(0, Number(pad) || 0);
      const top = padPx;
      const bottom = Math.max(top + 1, heightPx - padPx);
      const usableHeight = Math.max(1, bottom - top);
      const minValue = Math.min(...values);
      const maxValue = Math.max(...values);
      const xSpan = Math.max(1, values.length - 1);
      let d = "";
      for (let idx = 0; idx < values.length; idx += 1) {{
        const x = values.length === 1 ? (widthPx / 2) : ((idx / xSpan) * widthPx);
        const normalized = maxValue === minValue
          ? 0.5
          : ((values[idx] - minValue) / (maxValue - minValue));
        const y = bottom - (normalized * usableHeight);
        d += `${{idx === 0 ? "M" : "L"}}${{x.toFixed(2)}} ${{y.toFixed(2)}} `;
      }}
      if (values.length === 1) {{
        const x = widthPx / 2;
        const y = (top + bottom) / 2;
        d += `L${{x.toFixed(2)}} ${{y.toFixed(2)}}`;
      }}
      return d.trim();
    }}

    function updateMetricTicker(metricKey, rawValue, config = {{}}) {{
      const container = document.getElementById(config.containerId || "");
      const deltaEl = document.getElementById(config.deltaId || "");
      const chart = document.getElementById(config.chartId || "");
      const rateEl = document.getElementById(config.rateId || "");
      if (!(container instanceof HTMLElement) || !(deltaEl instanceof HTMLElement) || !(chart instanceof SVGElement)) {{
        return;
      }}
      const value = Number(rawValue);
      if (!Number.isFinite(value)) {{
        container.hidden = true;
        return;
      }}
      const points = appendMetricTickerPoint(metricKey, value);
      if (!Array.isArray(points) || points.length === 0) {{
        container.hidden = true;
        return;
      }}

      const latest = Number(points[points.length - 1] && points[points.length - 1].value);
      const baseline = Number(points[0] && points[0].value);
      const delta = latest - baseline;
      const flatThreshold = Number(config.flatThreshold);
      const epsilon = Number.isFinite(flatThreshold) ? Math.max(0, flatThreshold) : 0;
      let trend = "flat";
      if (delta > epsilon) trend = "up";
      else if (delta < -epsilon) trend = "down";

      const deltaAbsText = formatTickerNumber(Math.abs(delta), config.digits);
      const pct = baseline !== 0 ? ((delta / Math.abs(baseline)) * 100) : null;
      const pctText = Number.isFinite(pct)
        ? ` (${{pct > 0 ? "+" : ""}}${{Number(pct).toFixed(1)}}%)`
        : "";
      let deltaText = "";
      if (trend === "flat") {{
        deltaText = `0${{pctText}}`;
      }} else {{
        const sign = trend === "up" ? "+" : "-";
        deltaText = `${{sign}}${{deltaAbsText}}${{pctText}}`;
      }}
      deltaEl.textContent = deltaText;

      container.classList.remove("trend-up", "trend-down", "trend-flat");
      container.classList.add(`trend-${{trend}}`);
      container.hidden = false;

      chart.innerHTML = "";
      const expandedTickerView = topbarElement instanceof HTMLElement && topbarElement.classList.contains("ticker-expanded");
      const chartWidth = expandedTickerView ? 184 : 72;
      const chartHeight = expandedTickerView ? 44 : 16;
      const chartPad = expandedTickerView ? 3 : 1.5;
      chart.setAttribute("viewBox", `0 0 ${{chartWidth}} ${{chartHeight}}`);
      const pathData = buildMetricTickerPath(points, chartWidth, chartHeight, chartPad);
      if (pathData) {{
        const path = document.createElementNS("http://www.w3.org/2000/svg", "path");
        path.setAttribute("d", pathData);
        chart.appendChild(path);
      }}

      const firstMs = Number(points[0] && points[0].ms);
      const rangeMinutes = Number.isFinite(firstMs)
        ? Math.max(1, Math.round((Date.now() - firstMs) / 60000))
        : Math.max(1, Math.round(metricTickerWindowMs / 60000));
      const rangeHours = Math.max(1 / 60, rangeMinutes / 60);
      const ratePerHour = delta / rangeHours;
      const rateAbsText = formatTickerNumber(Math.abs(ratePerHour), Number.isFinite(Number(config.rateDigits)) ? Number(config.rateDigits) : 1);
      const rateSign = ratePerHour > 0 ? "+" : (ratePerHour < 0 ? "-" : "");
      const rateText = `${{rateSign}}${{rateAbsText}}/h`;
      if (rateEl instanceof HTMLElement) {{
        rateEl.textContent = rateText;
        rateEl.title = `Rate of change per hour across a ${{rangeMinutes}}m window`;
      }}
      const fromText = formatTickerNumber(baseline, config.digits);
      const toText = formatTickerNumber(latest, config.digits);
      container.title = `Trend (${{rangeMinutes}}m): ${{fromText}} -> ${{toText}}; delta ${{deltaText}}; rate ${{rateText}}`;
    }}

    function compactTargetMetric(value, maxLen = 44) {{
      const text = String(value == null ? "n/a" : value).replace(/\\s+/g, " ").trim();
      if (!text) return "n/a";
      const serialPrefix = "/dev/serial/by-id/";
      const compactBase = text.startsWith(serialPrefix) ? text.slice(serialPrefix.length) : text;
      if (compactBase.length <= maxLen) return compactBase;
      const suffixLen = Math.max(12, Math.floor(maxLen * 0.45));
      const prefixLen = Math.max(8, maxLen - suffixLen - 3);
      return `${{compactBase.slice(0, prefixLen)}}...${{compactBase.slice(-suffixLen)}}`;
    }}

    function syncUptimeBase(uptimeSeconds) {{
      const clean = Number(uptimeSeconds);
      if (!Number.isFinite(clean)) return;
      uptimeBaseSeconds = Math.max(0, Math.floor(clean));
      uptimeBaseMs = Date.now();
    }}

    function formatUptimeHms(totalSeconds) {{
      const safe = Math.max(0, Math.floor(Number(totalSeconds) || 0));
      const hours = Math.floor(safe / 3600);
      const minutes = Math.floor((safe % 3600) / 60);
      const seconds = safe % 60;
      return `${{String(hours).padStart(2, "0")}}:${{String(minutes).padStart(2, "0")}}:${{String(seconds).padStart(2, "0")}}`;
    }}

    function updateUptimeDisplay() {{
      if (typeof uptimeBaseSeconds !== "number" || !Number.isFinite(uptimeBaseSeconds)) {{
        return;
      }}
      const delta = Math.max(0, (Date.now() - (uptimeBaseMs || 0)) / 1000);
      setText("m-uptime", formatUptimeHms(uptimeBaseSeconds + delta));
    }}

    function normalizeThemeMode(raw) {{
      const clean = String(raw || "").trim().toLowerCase();
      return themeAcceptedModes.has(clean) ? clean : "auto";
    }}

    function normalizeThemeTokens(rawTokens) {{
      if (!rawTokens || typeof rawTokens !== "object" || Array.isArray(rawTokens)) {{
        return null;
      }}
      const normalized = {{}};
      for (const [key, value] of Object.entries(rawTokens)) {{
        const cleanKey = String(key || "").trim();
        if (!cleanKey.startsWith("--")) {{
          continue;
        }}
        normalized[cleanKey] = String(value ?? "");
      }}
      return Object.keys(normalized).length > 0 ? normalized : null;
    }}

    function normalizeThemePreset(rawPreset) {{
      if (!rawPreset || typeof rawPreset !== "object" || Array.isArray(rawPreset)) {{
        return null;
      }}
      const light = normalizeThemeTokens(rawPreset.light);
      const dark = normalizeThemeTokens(rawPreset.dark);
      if (!light || !dark) {{
        return null;
      }}
      return {{ light, dark }};
    }}

    function normalizeThemePresetCatalog(rawCatalog) {{
      const normalized = {{}};
      if (rawCatalog && typeof rawCatalog === "object" && !Array.isArray(rawCatalog)) {{
        for (const [name, rawPreset] of Object.entries(rawCatalog)) {{
          const cleanName = String(name || "").trim();
          if (!cleanName) continue;
          const preset = normalizeThemePreset(rawPreset);
          if (!preset) continue;
          normalized[cleanName] = preset;
        }}
      }}
      if (!Object.prototype.hasOwnProperty.call(normalized, "default")) {{
        normalized.default = {{ light: {{}}, dark: {{}} }};
      }}
      return normalized;
    }}

    function normalizeThemePresetName(rawName, catalog = themePresetCatalog) {{
      const clean = String(rawName || "").trim();
      if (clean && Object.prototype.hasOwnProperty.call(catalog, clean)) {{
        return clean;
      }}
      return "default";
    }}

    function orderedThemePresetNames(rawNames, catalog) {{
      const seen = new Set();
      const ordered = [];
      if (Array.isArray(rawNames)) {{
        for (const name of rawNames) {{
          const clean = String(name || "").trim();
          if (!clean || seen.has(clean) || !Object.prototype.hasOwnProperty.call(catalog, clean)) {{
            continue;
          }}
          seen.add(clean);
          ordered.push(clean);
        }}
      }}
      for (const name of Object.keys(catalog)) {{
        if (seen.has(name)) continue;
        seen.add(name);
        ordered.push(name);
      }}
      ordered.sort((a, b) => {{
        if (a === "default") return -1;
        if (b === "default") return 1;
        return a.localeCompare(b);
      }});
      return ordered;
    }}

    function applyThemePresetTokens(resolvedTheme) {{
      const selected = normalizeThemePresetName(themePresetSelected, themePresetCatalog);
      const preset = themePresetCatalog[selected] || themePresetCatalog.default || {{ light: {{}}, dark: {{}} }};
      const tokenMap = resolvedTheme === "dark" ? (preset.dark || {{}}) : (preset.light || {{}});
      const nextKeys = new Set(Object.keys(tokenMap));
      for (const key of themePresetAppliedKeys) {{
        if (!nextKeys.has(key)) {{
          document.documentElement.style.removeProperty(key);
        }}
      }}
      for (const [key, value] of Object.entries(tokenMap)) {{
        document.documentElement.style.setProperty(key, String(value));
      }}
      themePresetAppliedKeys.clear();
      for (const key of nextKeys) {{
        themePresetAppliedKeys.add(key);
      }}
    }}

    function updateThemePresetControl(availablePresets = null) {{
      const select = document.getElementById("theme-preset-select");
      if (!(select instanceof HTMLSelectElement)) {{
        return;
      }}
      const names = orderedThemePresetNames(
        availablePresets,
        themePresetCatalog,
      );
      const selected = normalizeThemePresetName(themePresetSelected, themePresetCatalog);
      select.innerHTML = "";
      for (const name of names) {{
        const option = document.createElement("option");
        option.value = name;
        option.textContent = name;
        select.appendChild(option);
      }}
      select.value = selected;
      select.disabled = names.length <= 1;
      select.title = names.length > 1
        ? "Select runtime color preset"
        : "Only one preset is available";
    }}

    function applyThemeSettingsPayload(payload) {{
      if (!payload || typeof payload !== "object" || Array.isArray(payload)) {{
        return false;
      }}
      const normalizedCatalog = normalizeThemePresetCatalog(payload.presets);
      themePresetCatalog = normalizedCatalog;
      themePresetSelected = normalizeThemePresetName(payload.selected_preset, normalizedCatalog);
      updateThemePresetControl(payload.available_presets);
      applyThemePreference(themePreference, false);
      return true;
    }}

    async function loadThemeSettingsFromServer(logErrors = true) {{
      try {{
        const resp = await fetch(themeSettingsEndpoint, {{ cache: "no-store" }});
        if (!resp.ok) {{
          throw new Error(`API ${{resp.status}}`);
        }}
        const payload = await resp.json();
        if (!payload || payload.ok === false) {{
          const message = payload && payload.error ? payload.error : "Invalid theme settings payload";
          throw new Error(String(message));
        }}
        return applyThemeSettingsPayload(payload);
      }} catch (err) {{
        if (logErrors) {{
          const msg = err instanceof Error ? err.message : String(err || "unknown error");
          appendConsoleLine(`theme-settings-load|${{Date.now()}}|${{msg}}`, `[theme settings] load failed: ${{msg}}`);
        }}
      }}
      return false;
    }}

    async function saveThemePresetSelection(presetName) {{
      const clean = String(presetName || "").trim();
      if (!clean) {{
        return false;
      }}
      try {{
        const resp = await fetch(themeSettingsEndpoint, {{
          method: "POST",
          headers: {{ "Content-Type": "application/json" }},
          body: JSON.stringify({{ preset_name: clean }}),
        }});
        const payload = await resp.json().catch(() => ({{ ok: false, error: `API ${{resp.status}}` }}));
        if (!resp.ok || !payload || payload.ok === false) {{
          const message = payload && payload.error ? payload.error : `API ${{resp.status}}`;
          throw new Error(String(message));
        }}
        return applyThemeSettingsPayload(payload);
      }} catch (err) {{
        const msg = err instanceof Error ? err.message : String(err || "unknown error");
        appendConsoleLine(`theme-settings-save|${{Date.now()}}|${{msg}}`, `[theme settings] save failed: ${{msg}}`);
        updateThemePresetControl();
      }}
      return false;
    }}

    function bindThemePresetSelector() {{
      const select = document.getElementById("theme-preset-select");
      if (!(select instanceof HTMLSelectElement)) {{
        return;
      }}
      if (select.dataset.bound === "1") {{
        return;
      }}
      select.dataset.bound = "1";
      updateThemePresetControl();
      select.addEventListener("change", async () => {{
        const selected = String(select.value || "").trim();
        if (!selected) {{
          updateThemePresetControl();
          return;
        }}
        select.disabled = true;
        await saveThemePresetSelection(selected);
        updateThemePresetControl();
      }});
    }}

