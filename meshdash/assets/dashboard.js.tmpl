    function renderSummary(state) {{
      const s = state.summary || {{}};
      let targetValue = s.target || "n/a";
      let updatedValue = state.generated_at || "n/a";
      let updatedFreshnessStatus = "";
      let updatedFreshnessLabel = "";
      if (activeLayoutView === "saved") {{
        const selectedId = normalizeNodeId(selectedNodeId || "");
        if (isSelectableNodeId(selectedId)) {{
          const nodes = Array.isArray(state.nodes) ? state.nodes : [];
          const node = nodes.find((entry) => normalizeNodeId(entry && entry.id) === selectedId) || null;
          const historyCapsById = new Map(
            Object.entries((state.history_caps && typeof state.history_caps === "object") ? state.history_caps : {{}})
              .map(([rawNodeId, caps]) => [normalizeNodeId(rawNodeId), caps])
              .filter(([nodeId, caps]) => isSelectableNodeId(nodeId) && caps && typeof caps === "object")
          );
          const caps = historyCapsById.get(selectedId) || null;
          const traffic = (state.traffic && typeof state.traffic === "object") ? state.traffic : {{}};
          const chatMessages = Array.isArray(traffic.recent_chat) ? traffic.recent_chat : [];
          const latestChatTouchByNode = mapLatestChatTouchInfo(chatMessages);
          const freshness = resolveNodeFreshness(node, caps, null, latestChatTouchByNode.get(selectedId) || null);
          const status = freshnessStatus(freshness.unix, Math.floor(Date.now() / 1000));
          updatedValue = savedDetailText(freshness.text, state.generated_at || "n/a");
          updatedFreshnessStatus = status;
          updatedFreshnessLabel = status === "online"
            ? "Fresh"
            : (status === "warn" ? "Aging" : (status === "stale" ? "Stale" : "Unknown"));
        }}
      }}
      const targetDisplay = compactTargetMetric(targetValue);
      setText("m-target", targetDisplay);
      const targetMetric = document.getElementById("m-target");
      if (targetMetric instanceof HTMLElement) {{
        const fullTarget = String(targetValue == null ? "" : targetValue).trim();
        targetMetric.title = fullTarget || "n/a";
      }}
      renderTargetRadioStatus(state);
      setText("m-nodes", s.node_count ?? 0);
      setText("m-pos-nodes", s.nodes_with_position ?? 0);
      const rawLivePacketTotal = Number(s.live_packet_count);
      const livePacketTotal = Number.isFinite(rawLivePacketTotal) ? rawLivePacketTotal : 0;
      if (resetTickerScaleOnRestart) {{
        maybeResetMetricTickerSeries(livePacketTotal);
      }}
      const realLinks = s.real_edge_count ?? s.edge_count ?? 0;
      setText("m-links", realLinks);
      updateMetricTicker("nodes", s.node_count ?? 0, {{
        containerId: "ticker-nodes",
        deltaId: "ticker-delta-nodes",
        rateId: "ticker-rate-nodes",
        chartId: "ticker-chart-nodes",
        digits: 0,
      }});
      updateMetricTicker("pos_nodes", s.nodes_with_position ?? 0, {{
        containerId: "ticker-pos-nodes",
        deltaId: "ticker-delta-pos-nodes",
        rateId: "ticker-rate-pos-nodes",
        chartId: "ticker-chart-pos-nodes",
        digits: 0,
      }});
      appendMetricTickerPoint("live_packets", livePacketTotal);
      const livePacketSeries = metricTickerSeries.get("live_packets") || [];
      const packetsPerMinuteSeries = derivePacketsPerMinuteSeriesFromTotals(livePacketSeries);
      const latestPacketsPerMinute = packetsPerMinuteSeries.length
        ? Number(packetsPerMinuteSeries[packetsPerMinuteSeries.length - 1].value)
        : 0;
      updateMetricTicker("live_packets_per_min", latestPacketsPerMinute, {{
        containerId: "ticker-live-packets",
        deltaId: "ticker-delta-live-packets",
        rateId: "ticker-rate-live-packets",
        chartId: "ticker-chart-live-packets",
        digits: 1,
      }});
      const packetsPerMinute = derivePacketsPerMinuteFromTotals(livePacketSeries);
      setText("m-live-packets", formatTickerNumber(packetsPerMinute, 1));
      const livePacketsMetric = document.getElementById("m-live-packets");
      if (livePacketsMetric instanceof HTMLElement) {{
        livePacketsMetric.title = `Packets per minute (derived). Total packets in background: ${{formatTickerNumber(livePacketTotal, 0)}}`;
      }}
      updateMetricTicker("real_links", realLinks, {{
        containerId: "ticker-links",
        deltaId: "ticker-delta-links",
        rateId: "ticker-rate-links",
        chartId: "ticker-chart-links",
        digits: 0,
      }});
      setText("m-modem-preset", formatModemPresetLabel(s.modem_preset, "n/a"));
      syncUptimeBase(s.uptime_seconds);
      updateUptimeDisplay();
      setText("updated-at", updatedValue);
      const updatedFreshness = document.getElementById("updated-freshness");
      if (updatedFreshness instanceof HTMLElement) {{
        updatedFreshness.classList.remove("status-online", "status-warn", "status-stale", "status-unknown");
        if (activeLayoutView === "saved" && updatedFreshnessLabel) {{
          updatedFreshness.hidden = false;
          updatedFreshness.textContent = updatedFreshnessLabel;
          updatedFreshness.classList.add(`status-${{updatedFreshnessStatus || "unknown"}}`);
        }} else {{
          updatedFreshness.hidden = true;
          updatedFreshness.textContent = "";
        }}
      }}
      const err = document.getElementById("local-state-error");
      if (err) {{
        const parts = [];
        if (state.local_state_error) {{
          parts.push(`Local state error: ${{trimInlineError(state.local_state_error)}}`);
        }}
        if (state.tracker_error) {{
          parts.push(`Tracker error: ${{trimInlineError(state.tracker_error)}}`);
        }}
        err.textContent = parts.length > 0 ? `  ${{parts.join(" | ")}}` : "";
      }}

      const revision = s.revision || {{}};
      const revisionText = document.getElementById("revision-text");
      if (revisionText) {{
        const fallbackLabel = String(revision.label || "").trim();
        const version = String(revision.version || "").trim();
        const commit = String(revision.commit || "").trim();
        if (fallbackLabel) {{
          revisionText.textContent = fallbackLabel;
        }} else if (version || commit) {{
          const versionText = version ? `v${{version}}` : "unknown";
          const commitText = commit || "nogit";
          revisionText.textContent = `Rev: ${{versionText}} (${{commitText}})`;
        }}
        const title = String(revision.title || "").trim();
        if (title) {{
          revisionText.title = title;
        }}
      }}

      const disk = s.disk || {{}};
      const diskLabel = document.getElementById("disk-label");
      const diskFill = document.getElementById("disk-fill");
      const diskMeter = document.getElementById("disk-meter");
      const freePctRaw = Number(disk.free_pct);
      if (!Number.isFinite(freePctRaw)) {{
        if (diskLabel) {{
          diskLabel.textContent = "Disk free: n/a";
        }}
        if (diskFill) {{
          diskFill.style.width = "0%";
          diskFill.classList.remove("warn", "danger");
        }}
        if (diskMeter) {{
          const detail = disk.error ? ` (${{disk.error}})` : "";
          diskMeter.title = `Disk free on dashboard host${{detail}}`;
        }}
        requestTopbarLayoutMetricsSync();
        return;
      }}

      const freePct = Math.max(0, Math.min(100, freePctRaw));
      if (diskLabel) {{
        diskLabel.textContent = `Disk free: ${{freePct.toFixed(1)}}%`;
      }}
      if (diskFill) {{
        diskFill.style.width = `${{freePct.toFixed(1)}}%`;
        diskFill.classList.remove("warn", "danger");
        if (freePct < 15) {{
          diskFill.classList.add("danger");
        }} else if (freePct < 30) {{
          diskFill.classList.add("warn");
        }}
      }}
      if (diskMeter) {{
        const freeGiB = bytesToGiB(disk.free_bytes);
        const totalGiB = bytesToGiB(disk.total_bytes);
        const freeText = freeGiB == null ? "n/a" : freeGiB.toFixed(1);
        const totalText = totalGiB == null ? "n/a" : totalGiB.toFixed(1);
        diskMeter.title = `Disk free on dashboard host (${{freeText}} GiB / ${{totalText}} GiB, path: ${{disk.path || "n/a"}})`;
      }}
      requestTopbarLayoutMetricsSync();
    }}

    function hashTrailSignature(nodeHistory, selection) {{
      let hash = 2166136261;
      let pointCount = 0;
      const historyNodeId = normalizeNodeId((nodeHistory && nodeHistory.node_id) || "");
      hash = hashMixStr(hash, historyNodeId);
      if (!(historyNodeId && historyNodeId === selection)) {{
        hash = hashMixInt(hash, -1);
        return {{ hash: hash >>> 0, count: 0 }};
      }}

      const rawTrail = Array.isArray(nodeHistory && nodeHistory.positions)
        ? nodeHistory.positions
        : [];
      for (const point of rawTrail) {{
        const lat = Number(point && point.lat);
        const lon = Number(point && point.lon);
        if (!isValidMapCoord(lat, lon)) continue;
        pointCount += 1;
        hash = hashMixInt(hash, Math.round(lat * 100000));
        hash = hashMixInt(hash, Math.round(lon * 100000));
        const when = Number(point && point.time_unix);
        hash = hashMixInt(hash, Number.isFinite(when) ? Math.round(when) : 0);
      }}
      hash = hashMixInt(hash, pointCount);
      return {{ hash: hash >>> 0, count: pointCount }};
    }}

    function buildMapGraphSignature(nodes, edges) {{
      let hash = 2166136261;
      let nodeCount = 0;
      let nodeXor = 0;
      let nodeSum = 0;
      for (const node of (nodes || [])) {{
        if (typeof node.lat !== "number" || typeof node.lon !== "number") continue;
        let itemHash = 2166136261;
        itemHash = hashMixStr(itemHash, normalizeNodeId(node.id));
        itemHash = hashMixInt(itemHash, Math.round(node.lat * 100000));
        itemHash = hashMixInt(itemHash, Math.round(node.lon * 100000));
        nodeXor ^= itemHash;
        nodeSum = (nodeSum + itemHash) >>> 0;
        nodeCount += 1;
      }}
      hash = hashMixInt(hash, nodeCount);
      hash = hashMixInt(hash, nodeXor);
      hash = hashMixInt(hash, nodeSum);

      let edgeCount = 0;
      let edgeXor = 0;
      let edgeSum = 0;
      for (const edge of (edges || [])) {{
        const lifetimeCount = Number(edge && (edge.lifetime_count ?? edge.count ?? 0));
        const lastHops = Number(edge && edge.last_hops);
        let itemHash = 2166136261;
        itemHash = hashMixStr(itemHash, normalizeNodeId(edge && edge.from));
        itemHash = hashMixStr(itemHash, normalizeNodeId(edge && edge.to));
        itemHash = hashMixInt(itemHash, Number.isFinite(lifetimeCount) ? Math.trunc(lifetimeCount) : 0);
        itemHash = hashMixStr(itemHash, edge && edge.last_rx_time);
        itemHash = hashMixInt(itemHash, Number.isFinite(lastHops) ? Math.trunc(lastHops) : -1);
        itemHash = hashMixInt(itemHash, edge && edge.is_real ? 1 : 0);
        edgeXor ^= itemHash;
        edgeSum = (edgeSum + itemHash) >>> 0;
        edgeCount += 1;
      }}
      hash = hashMixInt(hash, edgeCount);
      hash = hashMixInt(hash, edgeXor);
      hash = hashMixInt(hash, edgeSum);

      return `graph:${{(hash >>> 0).toString(16)}}:${{nodeCount}}:${{edgeCount}}`;
    }}

    function buildMapSignatures(nodes, edges, nodeHistory) {{
      const selection = isSelectableNodeId(selectedNodeId) ? normalizeNodeId(selectedNodeId) : "";
      const savedSelectionMode = activeLayoutView === "saved" && !!selection;
      const networkSelectionMode = activeLayoutView === "network" && !!selection;

      if (savedSelectionMode) {{
        let hash = 2166136261;
        hash = hashMixStr(hash, "saved");
        hash = hashMixStr(hash, selection);
        const selectedNode = selectedNodeFrom(nodes);
        if (
          selectedNode &&
          typeof selectedNode.lat === "number" &&
          typeof selectedNode.lon === "number"
        ) {{
          hash = hashMixInt(hash, Math.round(selectedNode.lat * 100000));
          hash = hashMixInt(hash, Math.round(selectedNode.lon * 100000));
        }} else {{
          hash = hashMixInt(hash, -2147483648);
        }}
        const trailSig = hashTrailSignature(nodeHistory, selection);
        hash = hashMixInt(hash, trailSig.hash);
        hash = hashMixInt(hash, trailSig.count);
        return {{
          signature: `saved:${{(hash >>> 0).toString(16)}}:${{trailSig.hash.toString(16)}}:${{trailSig.count}}`,
          graphSignature: "",
          selection,
          savedSelectionMode: true,
          networkSelectionMode: false,
        }};
      }}

      const graphSignature = buildMapGraphSignature(nodes, edges);
      if (networkSelectionMode) {{
        const trailSig = hashTrailSignature(nodeHistory, selection);
        return {{
          signature: `${{graphSignature}}:network:${{selection}}:${{trailSig.hash.toString(16)}}:${{trailSig.count}}`,
          graphSignature,
          selection,
          savedSelectionMode: false,
          networkSelectionMode: true,
        }};
      }}
      return {{
        signature: `${{graphSignature}}:all`,
        graphSignature,
        selection,
        savedSelectionMode: false,
        networkSelectionMode: false,
      }};
    }}


    function isValidMapCoord(lat, lon) {{
      if (!Number.isFinite(lat) || !Number.isFinite(lon)) return false;
      if (lat < -90 || lat > 90) return false;
      if (lon < -180 || lon > 180) return false;
      // Many devices report (0,0) before GPS lock. Treat that as "unknown" for overview fitting.
      if (Math.abs(lat) < 1e-9 && Math.abs(lon) < 1e-9) return false;
      return true;
    }}

    function collectTrailPoints(nodeHistory, selectionId) {{
      const selection = normalizeNodeId(selectionId || "");
      if (!selection) return [];
      const historyNodeId = normalizeNodeId((nodeHistory && nodeHistory.node_id) || "");
      if (!historyNodeId || historyNodeId !== selection) return [];
      const rawTrail = Array.isArray(nodeHistory && nodeHistory.positions)
        ? nodeHistory.positions
        : [];
      const points = [];
      for (const point of rawTrail) {{
        const lat = Number(point && point.lat);
        const lon = Number(point && point.lon);
        if (!isValidMapCoord(lat, lon)) continue;
        const timeUnix = Number(point && point.time_unix);
        points.push({{
          lat,
          lon,
          time_unix: Number.isFinite(timeUnix) ? Math.round(timeUnix) : null,
          time: point && point.time ? String(point.time) : null,
        }});
      }}
      return points;
    }}

    function collectNodeLatLngs(nodes) {{
      const pts = [];
      for (const node of (nodes || [])) {{
        const lat = Number(node && node.lat);
        const lon = Number(node && node.lon);
        if (!isValidMapCoord(lat, lon)) continue;
        pts.push([lat, lon]);
      }}
      return pts;
    }}

    function computeTrimmedBounds(points, trimFrac = 0.05) {{
      if (!Array.isArray(points) || points.length === 0) return null;
      if (points.length === 1) {{
        return L.latLngBounds(points[0], points[0]);
      }}
      const n = points.length;
      const trimCount = Math.max(0, Math.floor(n * trimFrac));
      const lats = points.map((p) => p[0]).slice().sort((a, b) => a - b);
      const lons = points.map((p) => p[1]).slice().sort((a, b) => a - b);
      const lo = Math.min(trimCount, Math.floor((n - 1) / 2));
      const hi = n - 1 - lo;
      const latMin = lats[lo];
      const latMax = lats[hi];
      const lonMin = lons[lo];
      const lonMax = lons[hi];
      const bounds = L.latLngBounds([latMin, lonMin], [latMax, lonMax]);
      return bounds && bounds.isValid() ? bounds : null;
    }}

    function fitMapToMostNodes(nodes, opts = {{}}) {{
      const points = collectNodeLatLngs(nodes);
      if (!points.length) return false;

      // If we only have one point, zoom in enough to be useful.
      if (points.length === 1) {{
        map.setView(points[0], Math.max(map.getZoom(), 12), {{ animate: false }});
        requestMapResize();
        return true;
      }}

      const trimFrac = points.length >= 14 ? 0.05 : 0;
      let bounds = computeTrimmedBounds(points, trimFrac);
      if (!bounds) {{
        bounds = L.latLngBounds(points);
      }}
      if (!bounds || !bounds.isValid()) return false;

      const pad = Number.isFinite(Number(opts.pad)) ? Number(opts.pad) : 0.18;
      const maxZoom = Number.isFinite(Number(opts.maxZoom)) ? Number(opts.maxZoom) : 13;
      map.fitBounds(bounds.pad(pad), {{ animate: false, maxZoom }});
      requestMapResize();
      return true;
    }}

    function bindMapResetControl() {{
      const btn = document.getElementById("map-reset-view-btn");
      if (!(btn instanceof HTMLButtonElement) || btn.dataset.bound === "1") return;
      btn.dataset.bound = "1";
      btn.addEventListener("click", () => {{
        map.closePopup();
        pendingMapHistoryFocus = false;
        if (latestState) {{
          const nodes = Array.isArray(latestState.nodes) ? latestState.nodes : [];
          fitMapToMostNodes(nodes, {{ pad: 0.18, maxZoom: 13 }});
        }}
      }});
    }}

    function resolveMapPositionBadge(node, caps = null, nowUnix = Math.floor(Date.now() / 1000)) {{
      const lat = Number(node && node.lat);
      const lon = Number(node && node.lon);
      if (!isValidMapCoord(lat, lon)) {{
        return {{
          label: "No Position",
          className: "unknown",
          title: "No usable position is available for this node.",
        }};
      }}

      const heardRaw = Number(node && node.last_heard_unix);
      const heardUnix = Number.isFinite(heardRaw) && heardRaw > 0
        ? Math.trunc(heardRaw)
        : null;
      const capsPosRaw = Number(caps && caps.last_position_unix);
      const capsPosUnix = Number.isFinite(capsPosRaw) && capsPosRaw > 0
        ? Math.trunc(capsPosRaw)
        : null;

      const heardAgeSeconds = Number.isFinite(heardUnix)
        ? Math.max(0, nowUnix - heardUnix)
        : null;
      const recentlyHeard = Number.isFinite(heardAgeSeconds) && heardAgeSeconds <= chatWarnWindowSeconds;
      const positionNearLastHeard = Number.isFinite(heardUnix)
        && Number.isFinite(capsPosUnix)
        && Math.abs(heardUnix - capsPosUnix) <= 120;
      const positionRecentlyUpdated = Number.isFinite(capsPosUnix)
        && (nowUnix - capsPosUnix) <= chatWarnWindowSeconds;

      if (positionNearLastHeard || (recentlyHeard && (positionRecentlyUpdated || !Number.isFinite(capsPosUnix)))) {{
        return {{
          label: "Live GPS",
          className: "live",
          title: "Position appears to be from a recent live GPS update.",
        }};
      }}

      return {{
        label: "History/Fixed",
        className: "history",
        title: "Position appears to be fixed or from an older saved location.",
      }};
    }}

    function renderNetworkTrailOverlay(nodeHistory, selectionId) {{
      trailLayer.clearLayers();
      const trailPoints = collectTrailPoints(nodeHistory, selectionId);
      if (trailPoints.length >= 2) {{
        const line = L.polyline(
          trailPoints.map((point) => [point.lat, point.lon]),
          {{
            color: "#d06a1b",
            opacity: 0.72,
            weight: 3,
            lineCap: "round",
            lineJoin: "round",
          }}
        );
        line.bindTooltip(`Selected node trail (${{trailPoints.length}} points)`, {{ sticky: true, opacity: 0.9 }});
        line.addTo(trailLayer);
      }}
      if (trailPoints.length > 0) {{
        const endPoint = trailPoints[trailPoints.length - 1];
        for (let i = 0; i < trailPoints.length; i += 1) {{
          const point = trailPoints[i];
          const isLatestPoint = i === (trailPoints.length - 1);
          const ratio = trailPoints.length <= 1 ? 1 : (i / (trailPoints.length - 1));
          const marker = L.circleMarker([point.lat, point.lon], {{
            radius: isLatestPoint ? 4.8 : (i === 0 ? 3.4 : 2.4),
            color: isLatestPoint ? "#f97316" : "#2f855a",
            fillColor: isLatestPoint ? "#f97316" : "#63d297",
            fillOpacity: isLatestPoint ? 0.92 : (0.2 + (ratio * 0.45)),
            weight: isLatestPoint ? 1.8 : 1,
            bubblingMouseEvents: false,
          }});
          const pointTime = point.time || "n/a";
          marker.bindTooltip(
            isLatestPoint
              ? `Selected trail newest point: ${{pointTime}}`
              : `Selected trail point ${{i + 1}}/${{trailPoints.length}}: ${{pointTime}}`,
            {{ sticky: true, opacity: 0.88 }}
          );
          marker.addTo(trailLayer);
        }}

        const latestHalo = L.circleMarker([endPoint.lat, endPoint.lon], {{
          radius: 8,
          color: "#f97316",
          fillColor: "#f97316",
          fillOpacity: 0.14,
          weight: 2,
          bubblingMouseEvents: false,
        }});
        latestHalo.bindTooltip(`Selected trail latest: ${{endPoint.time || "n/a"}}`, {{ sticky: true, opacity: 0.9 }});
        latestHalo.addTo(trailLayer);
      }}
    }}

    function renderMap(nodes, edges, nodeHistory = null) {{
      ensureMapSizeSync();
      const hideHeatmap = activeLayoutView === "saved";
      const signatures = buildMapSignatures(nodes, edges, nodeHistory);
      const signature = signatures.signature;
      const graphSignature = signatures.graphSignature;
      const savedSelectionMode = signatures.savedSelectionMode;
      const networkSelectionMode = signatures.networkSelectionMode;
      const selectionId = signatures.selection;

      syncSignalHeatmapLayer(nodes, hideHeatmap);
      refreshMapCardTitle();

      if (savedSelectionMode) {{
        if (signature === lastMapSignature && lastMapRenderMode === "saved") {{
          ensureMapSizeSync();
          updateMapSelection(false);
          return;
        }}

        nodeLayer.clearLayers();
        edgeLayer.clearLayers();
        trailLayer.clearLayers();
        nodeMarkers.clear();
        nodeMarkerMeta.clear();
        edgeLines.clear();
        edgeLineMeta.clear();

        const historyCapsById = new Map(
          Object.entries((latestState && latestState.history_caps && typeof latestState.history_caps === "object") ? latestState.history_caps : {{}})
            .map(([rawNodeId, caps]) => [normalizeNodeId(rawNodeId), caps])
            .filter(([nodeId, caps]) => isSelectableNodeId(nodeId) && caps && typeof caps === "object")
        );
        const nowUnix = Math.floor(Date.now() / 1000);
        const selectedNode = selectedNodeFrom(nodes);
        const selectedNodeIdNormalized = normalizeNodeId((selectedNode && selectedNode.id) || "");
        const hasSelectedPosition = !!selectedNode
          && typeof selectedNode.lat === "number"
          && typeof selectedNode.lon === "number";
        const trailPoints = collectTrailPoints(nodeHistory, selectionId);

        if (trailPoints.length >= 2) {{
          const line = L.polyline(
            trailPoints.map((point) => [point.lat, point.lon]),
            {{
              color: "#d06a1b",
              opacity: 0.78,
              weight: 4,
              lineCap: "round",
              lineJoin: "round",
            }}
          );
          line.bindTooltip(`Location trail (${{trailPoints.length}} points)`, {{ sticky: true, opacity: 0.9 }});
          line.addTo(trailLayer);
        }}
        if (trailPoints.length > 0) {{
          const endPoint = trailPoints[trailPoints.length - 1];
          for (let i = 0; i < trailPoints.length; i += 1) {{
            const point = trailPoints[i];
            const isLatestPoint = i === (trailPoints.length - 1);
            const ratio = trailPoints.length <= 1 ? 1 : (i / (trailPoints.length - 1));
            const marker = L.circleMarker([point.lat, point.lon], {{
              radius: isLatestPoint ? 5.8 : (i === 0 ? 3.6 : 2.6),
              color: isLatestPoint ? "#f97316" : "#2f855a",
              fillColor: isLatestPoint ? "#f97316" : "#63d297",
              fillOpacity: isLatestPoint ? 0.96 : (0.2 + (ratio * 0.5)),
              weight: isLatestPoint ? 2 : 1,
              bubblingMouseEvents: false,
            }});
            const pointTime = point.time || "n/a";
            marker.bindTooltip(
              isLatestPoint
                ? `Newest trail point: ${{pointTime}}`
                : `Trail point ${{i + 1}}/${{trailPoints.length}}: ${{pointTime}}`,
              {{ sticky: true, opacity: 0.88 }}
            );
            marker.addTo(trailLayer);
          }}

          const latestHalo = L.circleMarker([endPoint.lat, endPoint.lon], {{
            radius: 10,
            color: "#f97316",
            fillColor: "#f97316",
            fillOpacity: 0.16,
            weight: 2,
            bubblingMouseEvents: false,
          }});
          latestHalo.bindTooltip(`Newest trail point: ${{endPoint.time || "n/a"}}`, {{ sticky: true, opacity: 0.9 }});
          latestHalo.addTo(trailLayer);
        }}

        if (hasSelectedPosition) {{
          const trailPointsCount = trailPoints.length;
          const trailLast = trailPointsCount > 0
            ? (trailPoints[trailPointsCount - 1].time || "n/a")
            : "n/a";
          const selectedCaps = historyCapsById.get(selectionId) || null;
          const posBadge = resolveMapPositionBadge(selectedNode, selectedCaps, nowUnix);
          const marker = L.circleMarker(
            [selectedNode.lat, selectedNode.lon],
            markerStyle(true)
          );
          marker.bindPopup(`
            <b>${{nodeLabel(selectedNode)}}</b><br/>
            ${{selectedNodeIdNormalized || selectedNode.id}}<br/>
            Num: ${{selectedNode.num ?? "n/a"}}<br/>
            SNR: ${{selectedNode.snr ?? "n/a"}}<br/>
            RSSI: ${{selectedNode.rssi ?? "n/a"}}<br/>
            Position: <span class="map-position-badge ${{posBadge.className}}" title="${{escAttr(posBadge.title)}}">${{escAttr(posBadge.label)}}</span><br/>
            Last: ${{selectedNode.last_heard || "n/a"}}<br/>
            Trail points: ${{trailPointsCount}}<br/>
            Trail latest: ${{trailLast}}
          `);
          marker.on("click", () => {{
            selectNode(normalizeNodeId(selectedNode.id || ""), false);
          }});
          marker.addTo(nodeLayer);
          nodeMarkers.set(normalizeNodeId(selectedNode.id || ""), marker);
          if (trailPoints.length > 1) {{
            const trailBounds = L.latLngBounds(trailPoints.map((point) => [point.lat, point.lon]));
            trailBounds.extend([selectedNode.lat, selectedNode.lon]);
            if (trailBounds.isValid()) {{
              map.fitBounds(trailBounds.pad(0.2), {{ animate: false, maxZoom: 16 }});
            }}
          }} else {{
            map.setView([selectedNode.lat, selectedNode.lon], Math.max(map.getZoom(), 11), {{ animate: false }});
          }}
          marker.openPopup();
        }} else if (trailPoints.length > 0) {{
          const trailBounds = L.latLngBounds(trailPoints.map((point) => [point.lat, point.lon]));
          if (trailBounds.isValid()) {{
            map.fitBounds(trailBounds.pad(0.2), {{ animate: false, maxZoom: 16 }});
          }}
        }} else {{
          map.closePopup();
        }}

        lastMapSignature = signature;
        lastMapGraphSignature = "";
        lastMapRenderMode = "saved";
        requestMapResize();
        return;
      }}

      const graphChanged = lastMapRenderMode !== "graph" || graphSignature !== lastMapGraphSignature;
      if (!graphChanged && signature === lastMapSignature) {{
        ensureMapSizeSync();
        if (activeLayoutView === "network" && !fitDone) {{
          // View-switch fast path: still run initial network auto-fit even when map data is unchanged.
          const didFit = fitMapToMostNodes(nodes, {{ pad: 0.18, maxZoom: 13 }});
          if (didFit) {{
            fitDone = true;
          }} else {{
            requestMapResize();
          }}
        }}
        updateMapSelection(false);
        return;
      }}

      if (graphChanged) {{
        const byId = Object.create(null);
        for (const node of (nodes || [])) {{
          byId[normalizeNodeId(node && node.id)] = node;
        }}
        const historyCapsById = new Map(
          Object.entries((latestState && latestState.history_caps && typeof latestState.history_caps === "object") ? latestState.history_caps : {{}})
            .map(([rawNodeId, caps]) => [normalizeNodeId(rawNodeId), caps])
            .filter(([nodeId, caps]) => isSelectableNodeId(nodeId) && caps && typeof caps === "object")
        );
        const nowUnix = Math.floor(Date.now() / 1000);
        const seenNodeIds = new Set();

        for (const node of (nodes || [])) {{
          if (typeof node.lat !== "number" || typeof node.lon !== "number") continue;
          const normalizedId = normalizeNodeId(node.id || "");
          const isSelected = !!selectedNodeId && normalizedId === selectedNodeId;
          const nodeCaps = historyCapsById.get(normalizedId) || null;
          const posBadge = resolveMapPositionBadge(node, nodeCaps, nowUnix);
          let markerHash = 2166136261;
          markerHash = hashMixStr(markerHash, "network-node");
          markerHash = hashMixStr(markerHash, normalizedId);
          markerHash = hashMixInt(markerHash, Math.round(node.lat * 100000));
          markerHash = hashMixInt(markerHash, Math.round(node.lon * 100000));
          markerHash = hashMixInt(markerHash, isSelected ? 1 : 0);
          markerHash = hashMixStr(markerHash, node && (node.num ?? ""));
          markerHash = hashMixStr(markerHash, node && (node.snr ?? ""));
          markerHash = hashMixStr(markerHash, node && (node.rssi ?? ""));
          markerHash = hashMixStr(markerHash, node && (node.last_heard || ""));
          markerHash = hashMixStr(markerHash, posBadge.className);
          const existingMarker = nodeMarkers.get(normalizedId);
          const prevMarkerHash = nodeMarkerMeta.get(normalizedId);
          seenNodeIds.add(normalizedId);
          if (existingMarker && prevMarkerHash === markerHash) {{
            continue;
          }}
          if (existingMarker) {{
            nodeLayer.removeLayer(existingMarker);
            nodeMarkers.delete(normalizedId);
          }}
          const marker = L.circleMarker([node.lat, node.lon], markerStyle(isSelected));
          marker.bindPopup(`
            <b>${{nodeLabel(node)}}</b><br/>
            ${{normalizedId || node.id}}<br/>
            Num: ${{node.num ?? "n/a"}}<br/>
            SNR: ${{node.snr ?? "n/a"}}<br/>
            RSSI: ${{node.rssi ?? "n/a"}}<br/>
            Position: <span class="map-position-badge ${{posBadge.className}}" title="${{escAttr(posBadge.title)}}">${{escAttr(posBadge.label)}}</span><br/>
            Last: ${{node.last_heard || "n/a"}}
          `);
          marker.on("click", () => {{
            selectNode(normalizedId, false);
          }});
          marker.addTo(nodeLayer);
          nodeMarkers.set(normalizedId, marker);
          nodeMarkerMeta.set(normalizedId, markerHash);
        }}

        for (const [nodeId, marker] of Array.from(nodeMarkers.entries())) {{
          if (seenNodeIds.has(nodeId)) continue;
          nodeLayer.removeLayer(marker);
          nodeMarkers.delete(nodeId);
          nodeMarkerMeta.delete(nodeId);
        }}

        const seenEdgeKeys = new Set();
        const edgeKeyCounts = new Map();
        for (const edge of (edges || [])) {{
          const fromId = normalizeNodeId(edge && edge.from);
          const toId = normalizeNodeId(edge && edge.to);
          const src = byId[fromId];
          const dst = byId[toId];
          if (!src || !dst) continue;
          if (typeof src.lat !== "number" || typeof src.lon !== "number") continue;
          if (typeof dst.lat !== "number" || typeof dst.lon !== "number") continue;
          const baseKey = `${{fromId}}>${{toId}}`;
          const duplicateIdx = edgeKeyCounts.get(baseKey) || 0;
          edgeKeyCounts.set(baseKey, duplicateIdx + 1);
          const edgeKey = duplicateIdx === 0 ? baseKey : `${{baseKey}}#${{duplicateIdx}}`;
          seenEdgeKeys.add(edgeKey);

          const lifetimeCount = edge.lifetime_count ?? edge.count ?? 0;
          const sessionCount = edge.session_count ?? edge.count ?? 0;
          const isReal = !!edge.is_real;
          let edgeHash = 2166136261;
          edgeHash = hashMixStr(edgeHash, "network-edge");
          edgeHash = hashMixStr(edgeHash, edgeKey);
          edgeHash = hashMixInt(edgeHash, Math.round(src.lat * 100000));
          edgeHash = hashMixInt(edgeHash, Math.round(src.lon * 100000));
          edgeHash = hashMixInt(edgeHash, Math.round(dst.lat * 100000));
          edgeHash = hashMixInt(edgeHash, Math.round(dst.lon * 100000));
          edgeHash = hashMixInt(edgeHash, Number(lifetimeCount) || 0);
          edgeHash = hashMixInt(edgeHash, Number(sessionCount) || 0);
          edgeHash = hashMixInt(edgeHash, isReal ? 1 : 0);
          edgeHash = hashMixStr(edgeHash, edge && (edge.confidence || ""));
          edgeHash = hashMixStr(edgeHash, edge && (edge.first_rx_time || ""));
          edgeHash = hashMixStr(edgeHash, edge && (edge.last_rx_time || ""));
          edgeHash = hashMixStr(edgeHash, edge && (edge.avg_hops ?? ""));
          edgeHash = hashMixStr(edgeHash, edge && (edge.last_hops ?? ""));
          const ports = Array.isArray(edge && edge.portnums) ? edge.portnums : [];
          for (const port of ports) {{
            edgeHash = hashMixStr(edgeHash, port);
          }}

          const existingLine = edgeLines.get(edgeKey);
          const prevEdgeHash = edgeLineMeta.get(edgeKey);
          if (existingLine && prevEdgeHash === edgeHash) {{
            continue;
          }}
          if (existingLine) {{
            edgeLayer.removeLayer(existingLine);
            edgeLines.delete(edgeKey);
          }}

          const hopsLabel = edge.avg_hops == null
            ? "n/a"
            : `avg ${{edge.avg_hops}}${{edge.last_hops == null ? "" : ` (last ${{edge.last_hops}})`}}`;
          const line = L.polyline([[src.lat, src.lon], [dst.lat, dst.lon]], {{
            color: isReal ? "#bf1f43" : "#b7791f",
            dashArray: isReal ? null : "6 6",
            opacity: isReal ? 0.74 : 0.52,
            weight: Math.min(8, 2 + lifetimeCount),
            bubblingMouseEvents: false,
          }});
          line.bindTooltip(`
            <b>${{edge.from}} -> ${{edge.to}}</b><br/>
            Status: ${{edge.confidence || (isReal ? "confirmed" : "observed")}}<br/>
            Packets: ${{lifetimeCount}}<br/>
            Hops: ${{hopsLabel}}
          `, {{ sticky: true, opacity: 0.92 }});
          line.bindPopup(`
            <b>${{edge.from}} -> ${{edge.to}}</b><br/>
            Status: ${{edge.confidence || (isReal ? "confirmed" : "observed")}}<br/>
            Session packets: ${{sessionCount}}<br/>
            Lifetime packets: ${{lifetimeCount}}<br/>
            First: ${{edge.first_rx_time || "n/a"}}<br/>
            Last: ${{edge.last_rx_time || "n/a"}}<br/>
            Hops: ${{hopsLabel}}<br/>
            Ports: ${{ports.join(", ") || "n/a"}}
          `);
          line.addTo(edgeLayer);
          edgeLines.set(edgeKey, line);
          edgeLineMeta.set(edgeKey, edgeHash);
        }}

        for (const [edgeKey, line] of Array.from(edgeLines.entries())) {{
          if (seenEdgeKeys.has(edgeKey)) continue;
          edgeLayer.removeLayer(line);
          edgeLines.delete(edgeKey);
          edgeLineMeta.delete(edgeKey);
        }}
      }}

      if (networkSelectionMode) {{
        renderNetworkTrailOverlay(nodeHistory, selectionId);
      }} else {{
        trailLayer.clearLayers();
      }}

      if (!fitDone) {{
        // Network overview: fit to the densest footprint and ignore obvious outliers (e.g., 0,0 before GPS lock).
        const didFit = fitMapToMostNodes(nodes, {{ pad: 0.18, maxZoom: 13 }});
        if (didFit) {{
          fitDone = true;
        }}
      }}
      updateMapSelection(false);
      lastMapSignature = signature;
      lastMapGraphSignature = graphSignature;
      lastMapRenderMode = "graph";
    }}

    function fillTable(tableId, rowsHtml) {{
      const tbody = document.querySelector(`#${{tableId}} tbody`);
      if (!tbody) return;
      tbody.innerHTML = rowsHtml.join("");
      if (sortableTables.has(tableId)) {{
        bindSortableHeader(tableId);
        // The nodes list is pre-sorted during render; avoid expensive DOM sorting on every poll.
        if (tableId !== "nodes-table") {{
          sortTableRows(tableId);
        }} else {{
          updateSortIndicators(tableId);
        }}
      }}
    }}

    function hashMixInt(hash, value) {{
      const v = (Number.isFinite(Number(value)) ? Math.trunc(Number(value)) : 0) | 0;
      hash ^= v;
      hash = Math.imul(hash, 16777619);
      return hash >>> 0;
    }}

    function hashMixStr(hash, value) {{
      const text = String(value == null ? "" : value);
      for (let i = 0; i < text.length; i += 1) {{
        hash ^= text.charCodeAt(i);
        hash = Math.imul(hash, 16777619);
      }}
      return hash >>> 0;
    }}

    function buildNodesTableModel(nodes, query) {{
      const sourceNodes = Array.isArray(nodes) ? nodes : [];
      const entries = [];
      const state = tableSortState["nodes-table"] || {{ index: 0, dir: "desc" }};
      const sortIndex = Number.isFinite(Number(state.index)) ? Math.trunc(Number(state.index)) : 0;
      const sortDir = state.dir === "asc" ? "asc" : "desc";

      let h = 2166136261;
      h = hashMixStr(h, query || "");
      h = hashMixInt(h, sortIndex);
      h = hashMixStr(h, sortDir);

      for (const node of sourceNodes) {{
        const nodeId = normalizeNodeId(node && node.id);
        const name = nodeLabel(node);
        if (!matchesIdOrNameQuery(nodeId, name, query)) continue;

        entries.push({{ node, nodeId, name }});

        h = hashMixStr(h, nodeId);
        h = hashMixStr(h, name);
        h = hashMixStr(h, node && (node.hardware_model || ""));
        h = hashMixInt(h, node && (node.last_heard_unix ?? node.last_heard_epoch ?? 0));
        const snr = Number(node && node.snr);
        h = hashMixInt(h, Number.isFinite(snr) ? Math.round(snr * 10) : 0);
        h = hashMixInt(h, node && (node.hops_away ?? 0));
        h = hashMixInt(h, node && (node.battery_level ?? 0));
        h = hashMixInt(h, node && (node.saved_packets ?? 0));
        const lat = Number(node && node.lat);
        const lon = Number(node && node.lon);
        h = hashMixInt(h, Number.isFinite(lat) ? Math.round(lat * 1e4) : 0);
        h = hashMixInt(h, Number.isFinite(lon) ? Math.round(lon * 1e4) : 0);
      }}
      h = hashMixInt(h, entries.length);
      return {{ entries, hash: h >>> 0 }};
    }}

    function renderNodesPlaceholder(message = "Waiting for first state snapshot...") {{
      const text = String(message == null ? "" : message).trim() || "Waiting for first state snapshot...";
      fillTable("nodes-table", [`<tr><td colspan="10">${{escAttr(text)}}</td></tr>`]);
    }}

    function nodesTableSortRaw(entry, colIndex) {{
      const node = (entry && typeof entry === "object" && entry.node) ? entry.node : entry;
      if (!node) return "";
      const nodeId = normalizeNodeId((entry && entry.nodeId) || node.id || "");
      const name = (entry && typeof entry.name === "string") ? entry.name : nodeLabel(node);
      switch (colIndex) {{
        case 0:
          return Number(node.last_heard_unix ?? node.last_heard_epoch ?? 0) || 0;
        case 1:
          return nodeId;
        case 2:
          return name;
        case 3:
          return String(node.hardware_model || "");
        case 4:
          return Number(node.snr);
        case 5:
          return Number(node.hops_away);
        case 6:
          return Number(node.battery_level);
        case 7:
          return Number(node.saved_packets);
        case 8:
          return (Number.isFinite(Number(node.lat)) && Number.isFinite(Number(node.lon)))
            ? Number(node.lat)
            : "";
        case 9:
          return isFavoriteNode(nodeId) ? 1 : 0;
        default:
          return "";
      }}
    }}

    function sortNodesForTable(nodes) {{
      const state = tableSortState["nodes-table"] || {{ index: 0, dir: "desc" }};
      const col = Number.isFinite(Number(state.index)) ? Math.trunc(Number(state.index)) : 0;
      const dir = state.dir === "asc" ? "asc" : "desc";
      if (nodes.length <= 1) return nodes;
      // The server already returns nodes sorted by last-heard descending.
      if (col === 0 && dir === "desc") return nodes;
      nodes.sort((a, b) => {{
        const aValue = normalizeSortValue(nodesTableSortRaw(a, col));
        const bValue = normalizeSortValue(nodesTableSortRaw(b, col));
        const cmp = compareSortValues(aValue, bValue);
        if (cmp !== 0) return dir === "asc" ? cmp : -cmp;
        const aNode = (a && typeof a === "object" && a.node) ? a.node : a;
        const bNode = (b && typeof b === "object" && b.node) ? b.node : b;
        const aHeard = Number(aNode && (aNode.last_heard_unix ?? aNode.last_heard_epoch ?? 0)) || 0;
        const bHeard = Number(bNode && (bNode.last_heard_unix ?? bNode.last_heard_epoch ?? 0)) || 0;
        if (aHeard !== bHeard) return bHeard - aHeard;
        const aId = normalizeNodeId((a && a.nodeId) || (aNode && aNode.id));
        const bId = normalizeNodeId((b && b.nodeId) || (bNode && bNode.id));
        return String(aId).localeCompare(String(bId));
      }});
      return nodes;
    }}

    function renderNodes(nodes) {{
      const query = normalizeSearchQuery(nodesSearchQuery);
      const model = buildNodesTableModel(nodes || [], query);
      const computedHash = model.hash;
      if (computedHash === nodesTableLastHash && query === nodesTableLastQuery) {{
        return;
      }}
      nodesTableLastHash = computedHash;
      nodesTableLastQuery = query;

      const filteredNodes = model.entries;

      sortNodesForTable(filteredNodes);

      const nowUnix = Math.floor(Date.now() / 1000);

      const rows = [];
      for (const entry of filteredNodes) {{
          const node = entry.node;
          const nodeId = entry.nodeId;
          const name = entry.name;
          const selectable = isSelectableNodeId(nodeId);
          const selectedClass = (selectedNodeId && nodeId === selectedNodeId) ? " selected-node" : "";
          const lastUnix = nodeLastHeardUnix(node);
          const status = freshnessStatus(lastUnix, nowUnix);
          const statusClass = ` status-${{status || "unknown"}}`;
          const pos = (typeof node.lat === "number" && typeof node.lon === "number")
            ? `${{node.lat.toFixed(5)}}, ${{node.lon.toFixed(5)}}`
            : "n/a";
          const savedPackets = Number.isFinite(Number(node.saved_packets))
            ? Number(node.saved_packets)
            : 0;
          const savedPoints = Number.isFinite(Number(node.saved_points))
            ? Number(node.saved_points)
            : 0;
          const savedTitle = savedPoints > 0
            ? `${{savedPackets}} packets across ${{savedPoints}} minute buckets`
            : "No saved history yet";
          const lastHeardText = node.last_heard ?? "n/a";
          const lastSort = Number.isFinite(Number(node.last_heard_unix))
            ? Number(node.last_heard_unix)
            : (Number.isFinite(Number(lastUnix)) ? Number(lastUnix) : 0);
          rows.push(`<tr data-node-id="${{escAttr(nodeId)}}" class="${{selectable ? "node-selectable" : ""}}${{selectedClass}}${{statusClass}}">
          <td data-sort="${{escAttr(lastSort)}}" title="${{escAttr(lastHeardText)}}"><span class="node-status-dot status-${{escAttr(status || "unknown")}}">●</span>${{lastHeardText}}</td>
          <td class="mono" data-sort="${{escAttr(nodeId)}}" title="${{escAttr(String(node.id || nodeId || ""))}}">${{nodeId || "n/a"}}</td>
          <td data-sort="${{escAttr(name)}}">
            <span class="node-name-row">
              <span class="node-name-label">${{name}}</span>
            </span>
          </td>
          <td data-sort="${{escAttr(node.hardware_model ?? "")}}">${{node.hardware_model ?? "n/a"}}</td>
          <td data-sort="${{escAttr(node.snr ?? "")}}">${{node.snr ?? "n/a"}}</td>
          <td data-sort="${{escAttr(node.hops_away ?? "")}}">${{node.hops_away ?? "n/a"}}</td>
          <td data-sort="${{escAttr(node.battery_level ?? "")}}">${{node.battery_level ?? "n/a"}}</td>
          <td data-sort="${{escAttr(savedPackets)}}" title="${{escAttr(savedTitle)}}">${{savedPackets}}</td>
          <td data-sort="${{escAttr(pos)}}">${{pos}}</td>
          <td data-sort="${{escAttr(isFavoriteNode(nodeId) ? 1 : 0)}}">${{favoriteToggleButtonHtml(nodeId, "node-favorite-btn")}}</td>
        </tr>`);
      }}
      if (rows.length === 0) {{
        rows.push('<tr><td colspan="10">No nodes match this search.</td></tr>');
      }}

      const table = document.getElementById("nodes-table");
      const scroller = table ? table.closest(".scroll") : null;
      const scrollTop = scroller && "scrollTop" in scroller ? scroller.scrollTop : null;
      fillTable("nodes-table", rows);
      if (scrollTop != null && scroller) {{
        scroller.scrollTop = scrollTop;
      }}
      if (pendingSelectionScroll) {{
        scrollSelectionIntoView();
      }}
    }}

    function savedDetailText(value, fallback = "n/a") {{
      const text = String(value == null ? "" : value).trim();
      if (text) return text;
      return String(fallback == null ? "n/a" : fallback);
    }}

    function savedDetailPercent(value, decimals = 1) {{
      const num = Number(value);
      if (!Number.isFinite(num)) return "n/a";
      return `${{num.toFixed(decimals)}}%`;
    }}

    function savedDetailCoord(lat, lon) {{
      const latNum = Number(lat);
      const lonNum = Number(lon);
      if (!Number.isFinite(latNum) || !Number.isFinite(lonNum)) return "n/a";
      return `${{latNum.toFixed(5)}}, ${{lonNum.toFixed(5)}}`;
    }}

    function savedDetailDurationHours(startUnix, endUnix) {{
      const start = Number(startUnix);
      const end = Number(endUnix);
      if (!Number.isFinite(start) || !Number.isFinite(end) || end < start) return "n/a";
      const hours = (end - start) / 3600;
      return `${{hours.toFixed(1)}}h`;
    }}

    function savedDetailAge(unix, nowUnix = Math.floor(Date.now() / 1000)) {{
      const ts = Number(unix);
      if (!Number.isFinite(ts) || ts <= 0) return "n/a";
      const ageSec = Math.max(0, Math.floor(nowUnix - ts));
      if (ageSec < 90) return `${{ageSec}}s ago`;
      const ageMin = ageSec / 60;
      if (ageMin < 90) return `${{Math.round(ageMin)}}m ago`;
      const ageHr = ageMin / 60;
      if (ageHr < 48) return `${{ageHr.toFixed(ageHr < 10 ? 1 : 0)}}h ago`;
      const ageDay = ageHr / 24;
      return `${{ageDay.toFixed(ageDay < 10 ? 1 : 0)}}d ago`;
    }}

    function savedDetailSectionHtml(title, items, note = "") {{
      const rows = items.map(([label, value]) => (
        `<div class="saved-node-stat">
          <div class="saved-node-stat-k">${{escAttr(label)}}</div>
          <div class="saved-node-stat-v">${{escAttr(savedDetailText(value))}}</div>
        </div>`
      )).join("");
      const noteHtml = note
        ? `<div class="saved-node-note">${{escAttr(note)}}</div>`
        : "";
      return `<section class="saved-node-section">
        <h3 class="saved-node-section-title">${{escAttr(title)}}</h3>
        <div class="saved-node-grid">${{rows}}</div>
        ${{noteHtml}}
      </section>`;
    }}

    function computeSavedChatStats(nodeId, messages) {{
      const stats = {{
        touches: 0,
        sent: 0,
        received: 0,
        broadcastSent: 0,
        directSent: 0,
        reactionsSent: 0,
        peers: new Set(),
        lastChatText: "n/a",
        lastChatUnix: null,
      }};
      for (const msg of (messages || [])) {{
        const fromId = normalizeNodeId(msg && msg.from);
        const toId = normalizeNodeId(msg && msg.to);
        const isTouch = fromId === nodeId || toId === nodeId;
        if (!isTouch) continue;
        stats.touches += 1;

        const timeText = String((msg && (msg.rx_time || msg.captured_at)) || "").trim();
        const timeUnix = latestUnixTimestamp(msg && msg.rx_time, msg && msg.captured_at);
        if (Number.isFinite(timeUnix) && (!Number.isFinite(stats.lastChatUnix) || timeUnix > stats.lastChatUnix)) {{
          stats.lastChatUnix = timeUnix;
          stats.lastChatText = timeText || "n/a";
        }}

        const replyId = Number(msg && (msg.reply_id ?? msg.replyId));
        const emoji = String((msg && msg.emoji) || "").trim();
        const isReaction = msg && msg.is_reaction === true
          ? true
          : (Number.isFinite(replyId) && replyId > 0 && !!emoji);

        if (fromId === nodeId) {{
          stats.sent += 1;
          if (isReaction) stats.reactionsSent += 1;
          if (classifyMessageChannel(msg) === "direct") {{
            stats.directSent += 1;
          }} else {{
            stats.broadcastSent += 1;
          }}
          if (isSelectableNodeId(toId)) {{
            stats.peers.add(toId);
          }}
        }}
        if (toId === nodeId) {{
          stats.received += 1;
          if (isSelectableNodeId(fromId)) {{
            stats.peers.add(fromId);
          }}
        }}
      }}
      return stats;
    }}

    function mapLatestChatTouchInfo(messages) {{
      const latestByNodeId = new Map();
      const updateTouch = (rawNodeId, timeUnix, timeText) => {{
        const nodeId = normalizeNodeId(rawNodeId);
        if (!isSelectableNodeId(nodeId)) return;
        if (!Number.isFinite(timeUnix) || timeUnix <= 0) return;
        const existing = latestByNodeId.get(nodeId);
        if (!existing || timeUnix > existing.unix) {{
          latestByNodeId.set(nodeId, {{
            unix: Math.trunc(timeUnix),
            text: String(timeText || "").trim() || "n/a",
          }});
        }}
      }};

      for (const msg of (messages || [])) {{
        const timeUnix = latestUnixTimestamp(msg && msg.rx_time, msg && msg.captured_at);
        const timeText = String((msg && (msg.rx_time || msg.captured_at)) || "").trim();
        updateTouch(msg && msg.from, timeUnix, timeText);
        updateTouch(msg && msg.to, timeUnix, timeText);
      }}
      return latestByNodeId;
    }}

    function resolveNodeFreshness(node, caps, historySummary = null, chatTouch = null) {{
      const candidates = [];
      const liveLastSeenUnix = nodeLastHeardUnix(node);
      if (Number.isFinite(liveLastSeenUnix) && liveLastSeenUnix > 0) {{
        candidates.push({{
          unix: Math.trunc(liveLastSeenUnix),
          text: String((node && node.last_heard) || "").trim(),
          source: "live",
        }});
      }}

      const capsLastSeenUnix = Number(caps && caps.last_seen_unix);
      if (Number.isFinite(capsLastSeenUnix) && capsLastSeenUnix > 0) {{
        candidates.push({{
          unix: Math.trunc(capsLastSeenUnix),
          text: String((caps && (caps.last_seen || caps.last_position_time)) || "").trim(),
          source: "caps",
        }});
      }}

      const historyLastSeenUnix = parseDashboardTimeToUnix(historySummary && historySummary.last_seen);
      if (Number.isFinite(historyLastSeenUnix) && historyLastSeenUnix > 0) {{
        candidates.push({{
          unix: Math.trunc(historyLastSeenUnix),
          text: String((historySummary && historySummary.last_seen) || "").trim(),
          source: "history",
        }});
      }}

      const chatLastSeenUnix = Number(chatTouch && chatTouch.unix);
      if (Number.isFinite(chatLastSeenUnix) && chatLastSeenUnix > 0) {{
        candidates.push({{
          unix: Math.trunc(chatLastSeenUnix),
          text: String((chatTouch && chatTouch.text) || "").trim(),
          source: "chat",
        }});
      }}

      if (candidates.length === 0) {{
        return {{ unix: null, text: "n/a", source: "unknown" }};
      }}
      candidates.sort((a, b) => b.unix - a.unix);
      const freshest = candidates[0];
      return {{
        unix: freshest.unix,
        text: freshest.text || "n/a",
        source: freshest.source,
      }};
    }}

    function nodeFreshnessSourceLabel(source) {{
      const key = String(source || "").toLowerCase();
      if (key === "chat") return "Chat traffic";
      if (key === "live") return "Live node state";
      if (key === "caps") return "History capabilities";
      if (key === "history") return "History summary";
      return "Unknown";
    }}

    function computeSavedLinkStats(nodeId, edges) {{
      const stats = {{
        links: 0,
        peers: new Set(),
        lifetimePackets: 0,
        sessionPackets: 0,
        hopsWeighted: 0,
        hopsWeight: 0,
        lastSeenText: "n/a",
        lastSeenUnix: null,
        ports: new Set(),
        topPeer: "",
        topPeerPackets: 0,
      }};
      for (const edge of (edges || [])) {{
        const fromId = normalizeNodeId(edge && edge.from);
        const toId = normalizeNodeId(edge && edge.to);
        if (fromId !== nodeId && toId !== nodeId) continue;
        stats.links += 1;

        const peerId = fromId === nodeId ? toId : fromId;
        if (isSelectableNodeId(peerId)) {{
          stats.peers.add(peerId);
        }}

        const lifetimeCount = Number(edge && (edge.lifetime_count ?? edge.count));
        const sessionCount = Number(edge && (edge.session_count ?? edge.count));
        if (Number.isFinite(lifetimeCount) && lifetimeCount > 0) {{
          stats.lifetimePackets += lifetimeCount;
          if (lifetimeCount > stats.topPeerPackets && isSelectableNodeId(peerId)) {{
            stats.topPeerPackets = lifetimeCount;
            stats.topPeer = peerId;
          }}
        }}
        if (Number.isFinite(sessionCount) && sessionCount > 0) {{
          stats.sessionPackets += sessionCount;
        }}

        const avgHops = Number(edge && edge.avg_hops);
        const hopsWeight = Number.isFinite(lifetimeCount) && lifetimeCount > 0 ? lifetimeCount : 1;
        if (Number.isFinite(avgHops)) {{
          stats.hopsWeighted += avgHops * hopsWeight;
          stats.hopsWeight += hopsWeight;
        }}

        const lastText = String((edge && edge.last_rx_time) || "").trim();
        const lastUnix = parseDashboardTimeToUnix(lastText);
        if (Number.isFinite(lastUnix) && (!Number.isFinite(stats.lastSeenUnix) || lastUnix > stats.lastSeenUnix)) {{
          stats.lastSeenUnix = lastUnix;
          stats.lastSeenText = lastText || "n/a";
        }}

        for (const port of (edge && Array.isArray(edge.portnums) ? edge.portnums : [])) {{
          const cleanPort = String(port || "").trim();
          if (cleanPort) stats.ports.add(cleanPort);
        }}
      }}
      return stats;
    }}

    function renderSavedNodeDetails(state, nodeHistory = null, loadingNodeId = "") {{
      const host = document.getElementById("saved-node-details");
      if (!(host instanceof HTMLElement)) return;
      const previousMainScroll = host.querySelector(".saved-node-main-scroll");
      const previousNodeId = normalizeNodeId(host.dataset.nodeId || "");
      const previousScrollTop = (
        previousMainScroll instanceof HTMLElement
        && Number.isFinite(previousMainScroll.scrollTop)
      ) ? previousMainScroll.scrollTop : 0;
      const previousScrollHeight = (
        previousMainScroll instanceof HTMLElement
        && Number.isFinite(previousMainScroll.scrollHeight)
      ) ? previousMainScroll.scrollHeight : 0;
      const previousClientHeight = (
        previousMainScroll instanceof HTMLElement
        && Number.isFinite(previousMainScroll.clientHeight)
      ) ? previousMainScroll.clientHeight : 0;
      const dockedHistoryPanel = document.getElementById("map-data-node");
      const mapDataBody = document.getElementById("map-data-body");
      // Preserve the shared history panel node before replacing host.innerHTML.
      if (
        dockedHistoryPanel instanceof HTMLElement
        && mapDataBody instanceof HTMLElement
        && host.contains(dockedHistoryPanel)
      ) {{
        mapDataBody.appendChild(dockedHistoryPanel);
      }}

      const safeState = (state && typeof state === "object") ? state : {{}};
      const nodeId = normalizeNodeId(selectedNodeId || "");
      const loadingId = normalizeNodeId(loadingNodeId || "");

      if (!isSelectableNodeId(nodeId)) {{
        host.dataset.nodeId = "";
        host.innerHTML = favoriteNodeIds.size === 0
          ? '<div class="saved-node-details-empty">Select any node to view history and summary here. Star nodes to build your Saved Nodes subsection.</div>'
          : '<div class="saved-node-details-empty">Select any node to view history and summary, or pick one from Saved Nodes.</div>';
        syncNodeHistoryDock();
        return;
      }}

      const nodes = Array.isArray(safeState.nodes) ? safeState.nodes : [];
      const node = nodes.find((entry) => normalizeNodeId(entry.id || "") === nodeId) || null;
      const historyCapsById = new Map(
        Object.entries((safeState.history_caps && typeof safeState.history_caps === "object") ? safeState.history_caps : {{}})
          .map(([rawNodeId, caps]) => [normalizeNodeId(rawNodeId), caps])
          .filter(([entryNodeId, caps]) => isSelectableNodeId(entryNodeId) && caps && typeof caps === "object")
      );
      const caps = historyCapsById.get(nodeId) || null;

      const requestedHistory = (
        nodeHistory
        && typeof nodeHistory === "object"
        && normalizeNodeId(nodeHistory.node_id || "") === nodeId
      ) ? nodeHistory : null;
      const cachedEntry = nodeHistoryCache.get(nodeId);
      const cachedHistory = (
        cachedEntry
        && cachedEntry.data
        && normalizeNodeId(cachedEntry.data.node_id || "") === nodeId
      ) ? cachedEntry.data : null;
      const history = requestedHistory || cachedHistory;
      const historySummary = (history && typeof history.summary === "object") ? history.summary : {{}};
      const historyPoints = Array.isArray(history && history.points) ? history.points : [];
      const historyPositions = Array.isArray(history && history.positions) ? history.positions : [];
      const historyLoading = loadingId === nodeId && !history;
      const traffic = (safeState.traffic && typeof safeState.traffic === "object") ? safeState.traffic : {{}};
      const chatMessages = Array.isArray(traffic.recent_chat) ? traffic.recent_chat : [];
      const edges = Array.isArray(traffic.edges) ? traffic.edges : [];
      const chatStats = computeSavedChatStats(nodeId, chatMessages);
      const chatTouch = Number.isFinite(chatStats.lastChatUnix)
        ? {{ unix: Math.trunc(chatStats.lastChatUnix), text: chatStats.lastChatText }}
        : null;
      const linkStats = computeSavedLinkStats(nodeId, edges);

      const freshness = resolveNodeFreshness(node, caps, historySummary, chatTouch);
      const freshnessSource = nodeFreshnessSourceLabel(freshness.source);
      const nowUnix = Math.floor(Date.now() / 1000);

      const batteryRaw = Number(
        (node && node.battery_level != null)
          ? node.battery_level
          : NaN
      );
      const capsBatteryRaw = Number(caps && caps.battery_level);
      const batteryValue = Number.isFinite(batteryRaw)
        ? batteryRaw
        : (Number.isFinite(capsBatteryRaw) ? capsBatteryRaw : null);
      const batteryText = Number.isFinite(batteryValue)
        ? `${{Math.max(0, Math.min(100, Math.round(batteryValue)))}}%`
        : "n/a";
      const hopsRaw = Number(
        (node && node.hops_away != null)
          ? node.hops_away
          : NaN
      );
      const capsHopsRaw = Number(caps && caps.last_hops);
      const hopsValue = Number.isFinite(hopsRaw)
        ? hopsRaw
        : (Number.isFinite(capsHopsRaw) ? capsHopsRaw : null);
      const hopsText = Number.isFinite(hopsValue) && hopsValue >= 0 ? String(Math.trunc(hopsValue)) : "n/a";

      const livePosText = (
        node
        && Number.isFinite(Number(node.lat))
        && Number.isFinite(Number(node.lon))
      )
        ? savedDetailCoord(node.lat, node.lon)
        : "n/a";
      const voltageValue = (
        node
        && node.voltage != null
        && Number.isFinite(Number(node.voltage))
      ) ? Number(node.voltage) : null;
      const channelUtilValue = (
        node
        && node.channel_utilization != null
        && Number.isFinite(Number(node.channel_utilization))
      ) ? Number(node.channel_utilization) : null;
      const airUtilTxValue = (
        node
        && node.air_util_tx != null
        && Number.isFinite(Number(node.air_util_tx))
      ) ? Number(node.air_util_tx) : null;
      const latestTrail = historyPositions.length
        ? historyPositions[historyPositions.length - 1]
        : null;
      const latestTrailAltitude = (
        latestTrail
        && latestTrail.altitude != null
        && Number.isFinite(Number(latestTrail.altitude))
      ) ? Number(latestTrail.altitude) : null;
      const latestTrailSats = (
        latestTrail
        && latestTrail.sats_in_view != null
        && Number.isFinite(Number(latestTrail.sats_in_view))
      ) ? Number(latestTrail.sats_in_view) : null;
      const latestTrailPos = latestTrail ? savedDetailCoord(latestTrail.lat, latestTrail.lon) : "n/a";
      const livePositionAvailable = livePosText !== "n/a";
      const historyPositionAvailable = latestTrailPos !== "n/a";
      const latestPosText = livePositionAvailable ? livePosText : latestTrailPos;
      const capsPosUnixRaw = Number(caps && caps.last_position_unix);
      const capsPosUnix = Number.isFinite(capsPosUnixRaw) && capsPosUnixRaw > 0
        ? Math.trunc(capsPosUnixRaw)
        : null;
      const trailPosUnix = (
        latestTrail
        && Number.isFinite(Number(latestTrail.time_unix))
        && Number(latestTrail.time_unix) > 0
      ) ? Math.trunc(Number(latestTrail.time_unix)) : null;
      const latestPosTimeUnix = livePositionAvailable
        ? (Number.isFinite(capsPosUnix) ? capsPosUnix : trailPosUnix)
        : trailPosUnix;
      const latestPosTimeText = livePositionAvailable
        ? savedDetailText((caps && caps.last_position_time) || (latestTrail && latestTrail.time))
        : savedDetailText(latestTrail && latestTrail.time);
      const latestPosAgeText = savedDetailAge(latestPosTimeUnix, nowUnix);
      const positionSource = livePositionAvailable
        ? ((Number.isFinite(capsPosUnix) && (nowUnix - capsPosUnix) <= 300)
          ? "Live (recent)"
          : (Number.isFinite(capsPosUnix) ? "Live (stale)" : "Live (time unknown)"))
        : (historyPositionAvailable ? "History trail" : "n/a");
      const positionCapable = (caps && caps.has_position === true) || latestTrailPos !== "n/a"
        ? "Yes"
        : "No";

      const historyWindowHours = Number(history && history.window_hours);
      const historyWindowText = Number.isFinite(historyWindowHours) && historyWindowHours > 0
        ? `${{Math.round(historyWindowHours)}}h`
        : `${{nodeHistoryHours}}h`;
      const historyPointCount = Number.isFinite(Number(historySummary.points))
        ? Number(historySummary.points)
        : historyPoints.length;
      const historyTotalPackets = Number.isFinite(Number(historySummary.total_packets))
        ? Number(historySummary.total_packets)
        : historyPoints.reduce((sum, point) => sum + Math.max(0, Number(point && point.packet_count) || 0), 0);
      const activeMinutes = historyPoints.reduce((sum, point) => (
        sum + ((Number(point && point.packet_count) || 0) > 0 ? 1 : 0)
      ), 0);
      const activeHoursText = `${{(activeMinutes / 60).toFixed(1)}}h`;
      const firstPointUnix = historyPoints.length
        ? Number(historyPoints[0] && historyPoints[0].bucket_unix)
        : null;
      const lastPointUnix = historyPoints.length
        ? Number(historyPoints[historyPoints.length - 1] && historyPoints[historyPoints.length - 1].bucket_unix)
        : null;
      const coveredHoursText = savedDetailDurationHours(firstPointUnix, lastPointUnix);
      const peakPacketsPerMinute = historyPoints.reduce((peak, point) => {{
        const count = Number(point && point.packet_count);
        if (!Number.isFinite(count)) return peak;
        return Math.max(peak, count);
      }}, 0);

      let snrWeighted = 0;
      let snrWeight = 0;
      let rssiWeighted = 0;
      let rssiWeight = 0;
      let hopsWeighted = 0;
      let hopsWeight = 0;
      for (const point of historyPoints) {{
        const weight = Math.max(1, Number(point && point.packet_count) || 0);
        const snr = Number(point && point.avg_snr);
        const rssi = Number(point && point.avg_rssi);
        const hops = Number(point && point.avg_hops);
        if (Number.isFinite(snr)) {{
          snrWeighted += snr * weight;
          snrWeight += weight;
        }}
        if (Number.isFinite(rssi)) {{
          rssiWeighted += rssi * weight;
          rssiWeight += weight;
        }}
        if (Number.isFinite(hops)) {{
          hopsWeighted += hops * weight;
          hopsWeight += weight;
        }}
      }}
      const snrAvg = snrWeight > 0 ? (snrWeighted / snrWeight) : null;
      const rssiAvg = rssiWeight > 0 ? (rssiWeighted / rssiWeight) : null;
      const hopsAvg = hopsWeight > 0 ? (hopsWeighted / hopsWeight) : null;
      const snrRange = `${{formatMetricValue(historySummary.snr_min, 1)}} to ${{formatMetricValue(historySummary.snr_max, 1)}} dB`;
      const rssiRange = `${{formatMetricValue(historySummary.rssi_min, 0)}} to ${{formatMetricValue(historySummary.rssi_max, 0)}} dBm`;

      const linkAvgHops = linkStats.hopsWeight > 0
        ? formatMetricValue(linkStats.hopsWeighted / linkStats.hopsWeight, 2)
        : "n/a";

      const nodeSection = savedDetailSectionHtml("Node", [
        ["Node ID", nodeId],
        ["Node Num", node && node.num != null ? String(node.num) : "n/a"],
        ["Hardware", (node && node.hardware_model) || "n/a"],
        ["Role", (node && node.role) || "n/a"],
        ["Freshness Source", freshnessSource],
        ["Battery", batteryText],
        ["Hops Away", hopsText],
        ["Voltage", Number.isFinite(voltageValue) ? `${{voltageValue.toFixed(2)}}V` : "n/a"],
        ["Channel Util", Number.isFinite(channelUtilValue) ? savedDetailPercent(channelUtilValue) : "n/a"],
        ["Air Util TX", Number.isFinite(airUtilTxValue) ? savedDetailPercent(airUtilTxValue) : "n/a"],
        ["GPS Capable", positionCapable],
        ["Last Position Ping", savedDetailText((caps && caps.last_position_time) || (latestTrail && latestTrail.time))],
      ]);

      const historySection = savedDetailSectionHtml("History", [
        ["Window", historyWindowText],
        ["Samples (1m)", String(historyPointCount)],
        ["Active Hours", activeHoursText],
        ["Covered Range", coveredHoursText],
        ["Total Packets", String(historyTotalPackets)],
        ["Peak Packets/min", String(Math.round(peakPacketsPerMinute || 0))],
        ["First Bucket", savedDetailText(historySummary.first_bucket)],
        ["Last Bucket", savedDetailText(historySummary.last_bucket)],
        ["History Last Seen", savedDetailText(historySummary.last_seen)],
        ["Avg SNR", Number.isFinite(snrAvg) ? `${{formatMetricValue(snrAvg, 2)}} dB` : "n/a"],
        ["SNR Range", snrRange],
        ["Avg RSSI", Number.isFinite(rssiAvg) ? `${{formatMetricValue(rssiAvg, 1)}} dBm` : "n/a"],
        ["RSSI Range", rssiRange],
        ["Avg Hops", Number.isFinite(hopsAvg) ? formatMetricValue(hopsAvg, 2) : "n/a"],
        ["Trail Points", String(Number.isFinite(Number(historySummary.trail_points)) ? Number(historySummary.trail_points) : historyPositions.length)],
      ], historyLoading ? "Historical points are loading for this node." : "");

      const locationSection = savedDetailSectionHtml("Location", [
        ["Last Broadcast Position", latestPosText],
        ["Position Source", positionSource],
        ["Position Age", latestPosAgeText],
        ["Latest Position Time", latestPosTimeText],
        ["Altitude", Number.isFinite(latestTrailAltitude) ? `${{formatMetricValue(latestTrailAltitude, 0)}} m` : "n/a"],
        ["Satellites", Number.isFinite(latestTrailSats) ? String(Math.round(latestTrailSats)) : "n/a"],
        ["Trail Start", savedDetailText(historySummary.trail_start)],
        ["Trail End", savedDetailText(historySummary.trail_end)],
      ], "Radio screens can show a newer local GPS fix before that fix is broadcast to this dashboard.");

      const chatSection = savedDetailSectionHtml("Chat (Recent Buffer)", [
        ["Messages Touching Node", String(chatStats.touches)],
        ["Sent", String(chatStats.sent)],
        ["Received", String(chatStats.received)],
        ["Broadcast Sent", String(chatStats.broadcastSent)],
        ["Direct Sent", String(chatStats.directSent)],
        ["Reactions Sent", String(chatStats.reactionsSent)],
        ["Active Peers", String(chatStats.peers.size)],
        ["Last Chat", savedDetailText(chatStats.lastChatText)],
      ], `Based on current in-memory chat buffer (${{chatMessages.length}} messages).`);

      const linksSection = savedDetailSectionHtml("Links", [
        ["Directed Links", String(linkStats.links)],
        ["Linked Peers", String(linkStats.peers.size)],
        ["Lifetime Packets", String(Math.round(linkStats.lifetimePackets))],
        ["Session Packets", String(Math.round(linkStats.sessionPackets))],
        ["Avg Link Hops", linkAvgHops],
        ["Last Link Activity", savedDetailText(linkStats.lastSeenText)],
        ["Top Peer", savedDetailText(linkStats.topPeer)],
        ["Top Peer Packets", linkStats.topPeer ? String(Math.round(linkStats.topPeerPackets)) : "n/a"],
        ["Seen Ports", linkStats.ports.size > 0 ? Array.from(linkStats.ports).slice(0, 10).join(", ") : "n/a"],
      ]);

      host.innerHTML = `
        <div class="saved-node-stack">
          <div class="saved-node-main-scroll">
            <div class="saved-node-sections">
              ${{nodeSection}}
              ${{historySection}}
              ${{locationSection}}
              ${{chatSection}}
              ${{linksSection}}
            </div>
          </div>
          <div id="saved-node-history-splitter" class="saved-node-history-splitter" title="Drag to resize node info and history panels"></div>
          <div id="saved-node-history-host" class="saved-node-history-host"></div>
        </div>
      `;
      host.dataset.nodeId = nodeId;
      bindSavedNodeHistorySplitter();
      syncNodeHistoryDock();
      if (previousNodeId === nodeId) {{
        const restoreMainScroll = () => {{
          const nextMainScroll = host.querySelector(".saved-node-main-scroll");
          if (!(nextMainScroll instanceof HTMLElement)) return;
          const prevMax = Math.max(0, previousScrollHeight - previousClientHeight);
          const nextMax = Math.max(0, nextMainScroll.scrollHeight - nextMainScroll.clientHeight);
          if (prevMax <= 0) {{
            nextMainScroll.scrollTop = 0;
            return;
          }}
          const nearBottom = (prevMax - previousScrollTop) <= 2;
          if (nearBottom) {{
            nextMainScroll.scrollTop = nextMax;
            return;
          }}
          const ratio = previousScrollTop / prevMax;
          nextMainScroll.scrollTop = Math.max(0, Math.min(nextMax, Math.round(ratio * nextMax)));
        }};
        // Run once immediately, then once after layout settles (history dock + flex sizing).
        restoreMainScroll();
        window.requestAnimationFrame(() => {{
          if (normalizeNodeId(host.dataset.nodeId || "") !== nodeId) return;
          restoreMainScroll();
        }});
      }}
    }}

    function renderFavorites(state, nodeHistory = null, loadingNodeId = "") {{
      const safeState = (state && typeof state === "object") ? state : {{}};
      renderSavedNodeDetails(safeState, nodeHistory, loadingNodeId);
      renderSavedNodeSearchDropdown(safeState);
      renderStarredNodeSelect(safeState);
      const list = document.getElementById("favorites-list");
      const caption = document.getElementById("favorites-caption");
      if (!(list instanceof HTMLElement)) return;
      const nodes = Array.isArray(safeState.nodes) ? safeState.nodes : [];
      const nodesById = new Map(nodes.map((node) => [normalizeNodeId(node.id || ""), node]));
      const historyCapsById = new Map(
        Object.entries((safeState.history_caps && typeof safeState.history_caps === "object") ? safeState.history_caps : {{}})
          .map(([rawNodeId, caps]) => [normalizeNodeId(rawNodeId), caps])
          .filter(([nodeId, caps]) => isSelectableNodeId(nodeId) && caps && typeof caps === "object")
      );
      const traffic = (safeState.traffic && typeof safeState.traffic === "object") ? safeState.traffic : {{}};
      const chatMessages = Array.isArray(traffic.recent_chat) ? traffic.recent_chat : [];
      const latestChatTouchByNode = mapLatestChatTouchInfo(chatMessages);

      const nowUnix = Math.floor(Date.now() / 1000);
      const entries = Array.from(favoriteNodeIds)
        .map((nodeId) => {{
          const node = nodesById.get(nodeId);
          const caps = historyCapsById.get(nodeId);
          const name = preferredNodeName(node) || nodeNameCache.get(nodeId) || `Node ${{nodeId}}`;
          const freshness = resolveNodeFreshness(node, caps, null, latestChatTouchByNode.get(nodeId) || null);
          const status = freshnessStatus(freshness.unix, nowUnix);
          const lastSeenText = savedDetailText(freshness.text);
          const batteryRaw = Number(
            (node && node.battery_level != null)
              ? node.battery_level
              : (caps && caps.battery_level)
          );
          const battery = Number.isFinite(batteryRaw) ? `${{Math.max(0, Math.min(100, Math.round(batteryRaw)))}}%` : "n/a";
          const hopsRaw = Number(
            (node && node.hops_away != null)
              ? node.hops_away
              : (caps && caps.last_hops)
          );
          const hops = Number.isFinite(hopsRaw) && hopsRaw >= 0 ? String(Math.trunc(hopsRaw)) : "n/a";
          const pos = (
            node
            && typeof node.lat === "number"
            && Number.isFinite(node.lat)
            && typeof node.lon === "number"
            && Number.isFinite(node.lon)
          )
            ? `${{node.lat.toFixed(5)}}, ${{node.lon.toFixed(5)}}`
            : ((caps && caps.has_position === true) ? "history" : "n/a");
          const searchable = `${{normalizeSearchQuery(nodeId)}} ${{normalizeSearchQuery(name)}}`;
          return {{
            id: nodeId,
            name,
            status,
            lastSeenText,
            battery,
            hops,
            pos,
            searchable,
          }};
        }})
        .sort((a, b) => {{
          const rankDiff = statusRank(a.status) - statusRank(b.status);
          if (rankDiff !== 0) return rankDiff;
          return String(a.name || a.id).localeCompare(String(b.name || b.id));
        }});

      const query = normalizeSearchQuery(favoritesSearchQuery);
      const filtered = query
        ? entries.filter((entry) => entry.searchable.includes(query))
        : entries;
      const onlineCount = entries.filter((entry) => entry.status === "online").length;
      const warnCount = entries.filter((entry) => entry.status === "warn").length;
      const staleCount = entries.filter((entry) => entry.status === "stale").length;
      if (caption) {{
        caption.textContent = `Saved subsection: ${{entries.length}} total (${{onlineCount}} online, ${{warnCount}} aging, ${{staleCount}} stale)`;
      }}

      if (entries.length === 0) {{
        list.innerHTML = '<div class="favorites-empty">No saved nodes yet. Click ☆ next to a node name to add it to this subsection.</div>';
        return;
      }}
      if (filtered.length === 0) {{
        list.innerHTML = '<div class="favorites-empty">No saved nodes match this search.</div>';
        return;
      }}

      list.innerHTML = filtered.map((entry) => (
        `<div class="favorite-node-item status-${{entry.status}}${{selectedNodeId === entry.id ? " selected-node" : ""}}" data-node-id="${{escAttr(entry.id)}}" title="${{escAttr(`${{entry.name}} (${{entry.id}})` )}}">
          <div class="favorite-node-main">
            <div class="favorite-node-name-row">
              <span class="favorite-node-name">${{escAttr(entry.name)}}</span>
              <span class="favorite-node-id">${{escAttr(entry.id)}}</span>
            </div>
            <div class="favorite-node-meta">
              <span>Last: ${{escAttr(entry.lastSeenText)}}</span>
              <span>Batt: ${{escAttr(entry.battery)}}</span>
              <span>Hops: ${{escAttr(entry.hops)}}</span>
              <span>Pos: ${{escAttr(entry.pos)}}</span>
            </div>
          </div>
          ${{favoriteToggleButtonHtml(entry.id, "favorites-card-star")}}
        </div>`
      )).join("");

      for (const item of list.querySelectorAll(".favorite-node-item")) {{
        if (!(item instanceof HTMLElement)) continue;
        item.addEventListener("click", (ev) => {{
          const target = ev.target;
          if (target instanceof Element && target.closest(".favorite-toggle-btn")) {{
            return;
          }}
          selectNode(item.dataset.nodeId || "", true, false);
        }});
      }}
      refreshFavoriteToggleButtons();
    }}

    function formatMetricValue(value, decimals = 2, suffix = "") {{
      const num = Number(value);
      if (!Number.isFinite(num)) return "n/a";
      return `${{num.toFixed(decimals)}}${{suffix}}`;
    }}

    function clampUnit(value) {{
      const num = Number(value);
      if (!Number.isFinite(num)) return 0;
      if (num < 0) return 0;
      if (num > 1) return 1;
      return num;
    }}

    function signalZoomMinSpan(totalPoints) {{
      const total = Math.max(0, Math.floor(Number(totalPoints) || 0));
      if (total <= 2) return 1;
      const minPoints = Math.max(2, Math.min(total, signalZoomMinPoints));
      return Math.max(1 / Math.max(1, total - 1), (minPoints - 1) / Math.max(1, total - 1));
    }}

    function normalizeSignalZoomWindow(totalPoints) {{
      const minSpan = signalZoomMinSpan(totalPoints);
      let start = clampUnit(signalChartZoomStart);
      let end = clampUnit(signalChartZoomEnd);
      if (end <= start) {{
        end = Math.min(1, start + minSpan);
      }}
      let span = end - start;
      if (span < minSpan) {{
        const center = start + (span / 2);
        span = minSpan;
        start = center - (span / 2);
        end = center + (span / 2);
      }}
      if (start < 0) {{
        end = Math.min(1, end - start);
        start = 0;
      }}
      if (end > 1) {{
        start = Math.max(0, start - (end - 1));
        end = 1;
      }}
      span = end - start;
      if (span < minSpan) {{
        start = Math.max(0, end - minSpan);
        end = Math.min(1, start + minSpan);
      }}
      signalChartZoomStart = clampUnit(start);
      signalChartZoomEnd = clampUnit(end);
    }}

    function resetSignalChartZoom(nodeId = "") {{
      signalChartZoomNodeId = normalizeNodeId(nodeId || "");
      signalChartZoomStart = 0;
      signalChartZoomEnd = 1;
      signalChartPointerDrag = null;
    }}

    function setSignalChartZoomWindow(start, end, totalPoints) {{
      const prevStart = signalChartZoomStart;
      const prevEnd = signalChartZoomEnd;
      signalChartZoomStart = start;
      signalChartZoomEnd = end;
      normalizeSignalZoomWindow(totalPoints);
      return Math.abs(signalChartZoomStart - prevStart) > 1e-6
        || Math.abs(signalChartZoomEnd - prevEnd) > 1e-6;
    }}

    function getSignalChartAxisBounds(svg) {{
      const rect = svg.getBoundingClientRect();
      const axisStartPx = rect.left + ((signalChartLayout.padLeft / signalChartLayout.width) * rect.width);
      const axisEndPx = rect.left + (((signalChartLayout.width - signalChartLayout.padRight) / signalChartLayout.width) * rect.width);
      const axisWidthPx = Math.max(1, axisEndPx - axisStartPx);
      return {{ axisStartPx, axisEndPx, axisWidthPx }};
    }}

    function getVisibleSignalRows(rows) {{
      const allRows = Array.isArray(rows) ? rows : [];
      const total = allRows.length;
      if (total <= 1) {{
        return {{
          rows: allRows,
          startIndex: 0,
          endIndex: Math.max(0, total - 1),
          zoomed: false,
        }};
      }}
      normalizeSignalZoomWindow(total);
      const span = total - 1;
      let startIndex = Math.max(0, Math.min(span, Math.floor(signalChartZoomStart * span)));
      let endIndex = Math.max(startIndex + 1, Math.min(span, Math.ceil(signalChartZoomEnd * span)));
      const minPoints = Math.max(2, Math.min(total, signalZoomMinPoints));
      if ((endIndex - startIndex + 1) < minPoints) {{
        endIndex = Math.min(span, startIndex + minPoints - 1);
        if ((endIndex - startIndex + 1) < minPoints) {{
          startIndex = Math.max(0, endIndex - minPoints + 1);
        }}
      }}
      const visible = allRows.slice(startIndex, endIndex + 1);
      return {{
        rows: visible,
        startIndex,
        endIndex,
        zoomed: startIndex > 0 || endIndex < span,
      }};
    }}

    function rerenderSignalChartFromCache() {{
      if (!Array.isArray(signalChartPoints)) return;
      renderSignalChart(signalChartPoints);
    }}

    function bindSignalChartZoom() {{
      const svg = document.getElementById("signal-chart");
      if (!(svg instanceof SVGElement) || svg.dataset.zoomBound === "1") return;
      svg.dataset.zoomBound = "1";
      svg.setAttribute("tabindex", "0");

      svg.addEventListener("wheel", (ev) => {{
        const total = signalChartPoints.length;
        if (total < 3) return;
        const {{ axisStartPx, axisEndPx, axisWidthPx }} = getSignalChartAxisBounds(svg);
        if (ev.clientX < axisStartPx || ev.clientX > axisEndPx) return;
        ev.preventDefault();
        const anchorRatio = clampUnit((ev.clientX - axisStartPx) / axisWidthPx);
        const currentSpan = Math.max(1e-6, signalChartZoomEnd - signalChartZoomStart);
        const zoomFactor = ev.deltaY < 0 ? 0.84 : 1.19;
        const minSpan = signalZoomMinSpan(total);
        const nextSpan = Math.max(minSpan, Math.min(1, currentSpan * zoomFactor));
        const anchor = signalChartZoomStart + (anchorRatio * currentSpan);
        const nextStart = anchor - (anchorRatio * nextSpan);
        const nextEnd = nextStart + nextSpan;
        if (setSignalChartZoomWindow(nextStart, nextEnd, total)) {{
          rerenderSignalChartFromCache();
        }}
      }}, {{ passive: false }});

      svg.addEventListener("dblclick", (ev) => {{
        ev.preventDefault();
        if (setSignalChartZoomWindow(0, 1, signalChartPoints.length || 2)) {{
          rerenderSignalChartFromCache();
        }}
      }});

      svg.addEventListener("pointerdown", (ev) => {{
        if (ev.button !== 0 || signalChartPoints.length < 3) return;
        const {{ axisStartPx, axisEndPx }} = getSignalChartAxisBounds(svg);
        if (ev.clientX < axisStartPx || ev.clientX > axisEndPx) return;
        signalChartPointerDrag = {{
          pointerId: ev.pointerId,
          startClientX: ev.clientX,
          startZoomStart: signalChartZoomStart,
          startZoomEnd: signalChartZoomEnd,
        }};
        svg.classList.add("chart-dragging");
        try {{
          svg.setPointerCapture(ev.pointerId);
        }} catch (_err) {{
        }}
        ev.preventDefault();
      }});

      svg.addEventListener("pointermove", (ev) => {{
        if (!signalChartPointerDrag || signalChartPointerDrag.pointerId !== ev.pointerId) return;
        const total = signalChartPoints.length;
        if (total < 3) return;
        const {{ axisWidthPx }} = getSignalChartAxisBounds(svg);
        const deltaRatio = (ev.clientX - signalChartPointerDrag.startClientX) / axisWidthPx;
        const dragSpan = signalChartPointerDrag.startZoomEnd - signalChartPointerDrag.startZoomStart;
        const nextStart = signalChartPointerDrag.startZoomStart - (deltaRatio * dragSpan);
        const nextEnd = signalChartPointerDrag.startZoomEnd - (deltaRatio * dragSpan);
        if (setSignalChartZoomWindow(nextStart, nextEnd, total)) {{
          rerenderSignalChartFromCache();
        }}
      }});

      const clearDrag = (ev) => {{
        if (!signalChartPointerDrag) return;
        if (ev && signalChartPointerDrag.pointerId !== ev.pointerId) return;
        signalChartPointerDrag = null;
        svg.classList.remove("chart-dragging");
        if (ev) {{
          try {{
            svg.releasePointerCapture(ev.pointerId);
          }} catch (_err) {{
          }}
        }}
      }};
      svg.addEventListener("pointerup", clearDrag);
      svg.addEventListener("pointercancel", clearDrag);
      svg.addEventListener("lostpointercapture", clearDrag);
      svg.addEventListener("keydown", (ev) => {{
        if (ev.key !== "Escape") return;
        if (setSignalChartZoomWindow(0, 1, signalChartPoints.length || 2)) {{
          rerenderSignalChartFromCache();
        }}
      }});
    }}

    function historyTrendZoomMinSpan(totalPoints) {{
      const total = Math.max(0, Math.floor(Number(totalPoints) || 0));
      if (total <= 2) return 1;
      const minPoints = Math.max(2, Math.min(total, historyTrendZoomMinPoints));
      return Math.max(1 / Math.max(1, total - 1), (minPoints - 1) / Math.max(1, total - 1));
    }}

    function normalizeHistoryTrendZoomWindow(chartState, totalPoints) {{
      if (!chartState || typeof chartState !== "object") return;
      const minSpan = historyTrendZoomMinSpan(totalPoints);
      let start = clampUnit(chartState.zoomStart);
      let end = clampUnit(chartState.zoomEnd);
      if (end <= start) {{
        end = Math.min(1, start + minSpan);
      }}
      let span = end - start;
      if (span < minSpan) {{
        const center = start + (span / 2);
        span = minSpan;
        start = center - (span / 2);
        end = center + (span / 2);
      }}
      if (start < 0) {{
        end = Math.min(1, end - start);
        start = 0;
      }}
      if (end > 1) {{
        start = Math.max(0, start - (end - 1));
        end = 1;
      }}
      span = end - start;
      if (span < minSpan) {{
        start = Math.max(0, end - minSpan);
        end = Math.min(1, start + minSpan);
      }}
      chartState.zoomStart = clampUnit(start);
      chartState.zoomEnd = clampUnit(end);
    }}

    function setHistoryTrendZoomWindow(chartState, start, end, totalPoints) {{
      if (!chartState || typeof chartState !== "object") return false;
      const prevStart = chartState.zoomStart;
      const prevEnd = chartState.zoomEnd;
      chartState.zoomStart = start;
      chartState.zoomEnd = end;
      normalizeHistoryTrendZoomWindow(chartState, totalPoints);
      return Math.abs(chartState.zoomStart - prevStart) > 1e-6
        || Math.abs(chartState.zoomEnd - prevEnd) > 1e-6;
    }}

    function resetHistoryTrendZoom(chartState) {{
      if (!chartState || typeof chartState !== "object") return;
      chartState.zoomStart = 0;
      chartState.zoomEnd = 1;
      chartState.pointerDrag = null;
    }}

    function getHistoryTrendAxisBounds(svg) {{
      const rect = svg.getBoundingClientRect();
      const axisStartPx = rect.left + ((historyTrendChartLayout.padLeft / historyTrendChartLayout.width) * rect.width);
      const axisEndPx = rect.left + (((historyTrendChartLayout.width - historyTrendChartLayout.padRight) / historyTrendChartLayout.width) * rect.width);
      const axisWidthPx = Math.max(1, axisEndPx - axisStartPx);
      return {{ axisStartPx, axisEndPx, axisWidthPx }};
    }}

    function getVisibleHistoryTrendRows(chartState, rows) {{
      const allRows = Array.isArray(rows) ? rows : [];
      const total = allRows.length;
      if (total <= 1) {{
        return {{
          rows: allRows,
          startIndex: 0,
          endIndex: Math.max(0, total - 1),
          zoomed: false,
        }};
      }}
      normalizeHistoryTrendZoomWindow(chartState, total);
      const span = total - 1;
      let startIndex = Math.max(0, Math.min(span, Math.floor(chartState.zoomStart * span)));
      let endIndex = Math.max(startIndex + 1, Math.min(span, Math.ceil(chartState.zoomEnd * span)));
      const minPoints = Math.max(2, Math.min(total, historyTrendZoomMinPoints));
      if ((endIndex - startIndex + 1) < minPoints) {{
        endIndex = Math.min(span, startIndex + minPoints - 1);
        if ((endIndex - startIndex + 1) < minPoints) {{
          startIndex = Math.max(0, endIndex - minPoints + 1);
        }}
      }}
      return {{
        rows: allRows.slice(startIndex, endIndex + 1),
        startIndex,
        endIndex,
        zoomed: startIndex > 0 || endIndex < span,
      }};
    }}

    function bindHistoryTrendChartZoom(chartState, rerenderFn, chartLabel = "Trend chart") {{
      if (!chartState || typeof chartState !== "object") return;
      const svg = document.getElementById(chartState.svgId);
      if (!(svg instanceof SVGElement) || svg.dataset.zoomBound === "1") return;
      svg.dataset.zoomBound = "1";
      svg.setAttribute("tabindex", "0");

      svg.addEventListener("wheel", (ev) => {{
        const total = Array.isArray(chartState.points) ? chartState.points.length : 0;
        if (total < 3) return;
        const {{ axisStartPx, axisEndPx, axisWidthPx }} = getHistoryTrendAxisBounds(svg);
        if (ev.clientX < axisStartPx || ev.clientX > axisEndPx) return;
        ev.preventDefault();
        const anchorRatio = clampUnit((ev.clientX - axisStartPx) / axisWidthPx);
        const currentSpan = Math.max(1e-6, chartState.zoomEnd - chartState.zoomStart);
        const zoomFactor = ev.deltaY < 0 ? 0.84 : 1.19;
        const minSpan = historyTrendZoomMinSpan(total);
        const nextSpan = Math.max(minSpan, Math.min(1, currentSpan * zoomFactor));
        const anchor = chartState.zoomStart + (anchorRatio * currentSpan);
        const nextStart = anchor - (anchorRatio * nextSpan);
        const nextEnd = nextStart + nextSpan;
        if (setHistoryTrendZoomWindow(chartState, nextStart, nextEnd, total)) {{
          rerenderFn();
        }}
      }}, {{ passive: false }});

      svg.addEventListener("dblclick", (ev) => {{
        ev.preventDefault();
        if (setHistoryTrendZoomWindow(chartState, 0, 1, (chartState.points || []).length || 2)) {{
          rerenderFn();
        }}
      }});

      svg.addEventListener("pointerdown", (ev) => {{
        if (ev.button !== 0 || (chartState.points || []).length < 3) return;
        const {{ axisStartPx, axisEndPx }} = getHistoryTrendAxisBounds(svg);
        if (ev.clientX < axisStartPx || ev.clientX > axisEndPx) return;
        chartState.pointerDrag = {{
          pointerId: ev.pointerId,
          startClientX: ev.clientX,
          startZoomStart: chartState.zoomStart,
          startZoomEnd: chartState.zoomEnd,
        }};
        svg.classList.add("chart-dragging");
        try {{
          svg.setPointerCapture(ev.pointerId);
        }} catch (_err) {{
        }}
        ev.preventDefault();
      }});

      svg.addEventListener("pointermove", (ev) => {{
        if (!chartState.pointerDrag || chartState.pointerDrag.pointerId !== ev.pointerId) return;
        const total = (chartState.points || []).length;
        if (total < 3) return;
        const {{ axisWidthPx }} = getHistoryTrendAxisBounds(svg);
        const deltaRatio = (ev.clientX - chartState.pointerDrag.startClientX) / axisWidthPx;
        const dragSpan = chartState.pointerDrag.startZoomEnd - chartState.pointerDrag.startZoomStart;
        const nextStart = chartState.pointerDrag.startZoomStart - (deltaRatio * dragSpan);
        const nextEnd = chartState.pointerDrag.startZoomEnd - (deltaRatio * dragSpan);
        if (setHistoryTrendZoomWindow(chartState, nextStart, nextEnd, total)) {{
          rerenderFn();
        }}
      }});

      const clearDrag = (ev) => {{
        if (!chartState.pointerDrag) return;
        if (ev && chartState.pointerDrag.pointerId !== ev.pointerId) return;
        chartState.pointerDrag = null;
        svg.classList.remove("chart-dragging");
        if (ev) {{
          try {{
            svg.releasePointerCapture(ev.pointerId);
          }} catch (_err) {{
          }}
        }}
      }};
      svg.addEventListener("pointerup", clearDrag);
      svg.addEventListener("pointercancel", clearDrag);
      svg.addEventListener("lostpointercapture", clearDrag);
      svg.addEventListener("keydown", (ev) => {{
        if (ev.key !== "Escape") return;
        if (setHistoryTrendZoomWindow(chartState, 0, 1, (chartState.points || []).length || 2)) {{
          rerenderFn();
        }}
      }});

      svg.setAttribute(
        "title",
        `${{chartLabel}}. Wheel to zoom, drag to pan, double-click or Esc to reset.`
      );
    }}

    function setHistoryTrendChartTitle(svg, chartLabel, zoomed) {{
      if (!(svg instanceof SVGElement)) return;
      svg.classList.toggle("zoomed", !!zoomed);
      svg.setAttribute(
        "title",
        zoomed
          ? `${{chartLabel}} zoomed. Wheel to zoom, drag to pan, double-click or Esc to reset.`
          : `${{chartLabel}}. Wheel to zoom, drag to pan, double-click or Esc to reset.`
      );
    }}

    function timelinePointUnix(
      point,
      bucketUnixKey = "bucket_unix",
      bucketTextKeys = ["bucket_time", "bucket_local"]
    ) {{
      const direct = Number(point && point[bucketUnixKey]);
      if (Number.isFinite(direct) && direct > 0) {{
        return Math.trunc(direct);
      }}
      let stamp = "";
      for (const key of bucketTextKeys) {{
        const value = String((point && point[key]) || "").trim();
        if (value) {{
          stamp = value;
          break;
        }}
      }}
      if (!stamp) return null;
      const normalized = stamp.includes("T")
        ? stamp
        : stamp.replace(" ", "T");
      const parsed = Date.parse(normalized);
      if (Number.isFinite(parsed)) {{
        return Math.trunc(parsed / 1000);
      }}
      return null;
    }}

    function formatTimelineLabel(unixTs, includeDate) {{
      if (!Number.isFinite(unixTs)) return "";
      const dt = new Date(unixTs * 1000);
      if (Number.isNaN(dt.getTime())) return "";
      const hh = String(dt.getHours()).padStart(2, "0");
      const mm = String(dt.getMinutes()).padStart(2, "0");
      const timeLabel = `${{hh}}:${{mm}}`;
      if (!includeDate) return timeLabel;
      const mon = String(dt.getMonth() + 1).padStart(2, "0");
      const day = String(dt.getDate()).padStart(2, "0");
      return `${{mon}}/${{day}} ${{timeLabel}}`;
    }}

    function setTimelineMessage(timelineId, message) {{
      const timeline = document.getElementById(String(timelineId || "").trim());
      if (!(timeline instanceof HTMLElement)) return;
      timeline.innerHTML = "";
      const text = String(message || "").trim();
      if (!text) return;
      const note = document.createElement("div");
      note.className = "signal-timeline-empty";
      note.textContent = text;
      timeline.appendChild(note);
    }}

    function renderTimeline(timelineId, rows, padLeft, padRight, width, resolveUnix) {{
      const timeline = document.getElementById(String(timelineId || "").trim());
      if (!(timeline instanceof HTMLElement)) return;

      const total = Array.isArray(rows) ? rows.length : 0;
      if (!total) {{
        setTimelineMessage(timelineId, "Timeline available when history points are present.");
        return;
      }}

      const pointUnixResolver = typeof resolveUnix === "function"
        ? resolveUnix
        : ((row) => timelinePointUnix(row));
      const timestamps = rows.map((row) => pointUnixResolver(row));
      const valid = timestamps.filter((ts) => Number.isFinite(ts));
      if (!valid.length) {{
        setTimelineMessage(timelineId, "Timeline unavailable (missing timestamps).");
        return;
      }}

      const axisStartPct = Math.max(0, Math.min(100, (padLeft / width) * 100));
      const axisEndPct = Math.max(axisStartPct, Math.min(100, ((width - padRight) / width) * 100));
      const axisWidthPct = axisEndPct - axisStartPct;
      const startUnix = valid[0];
      const endUnix = valid[valid.length - 1];
      const spanCrossesDay = Math.floor(startUnix / 86400) !== Math.floor(endUnix / 86400);

      const maxTicks = 5;
      const desired = Math.max(2, Math.min(maxTicks, total));
      const indexSet = new Set();
      for (let i = 0; i < desired; i += 1) {{
        const idx = Math.round((i * (total - 1)) / Math.max(1, desired - 1));
        indexSet.add(Math.max(0, Math.min(total - 1, idx)));
      }}
      indexSet.add(0);
      indexSet.add(total - 1);
      const indices = Array.from(indexSet).sort((a, b) => a - b);

      timeline.innerHTML = "";
      const track = document.createElement("div");
      track.className = "signal-timeline-track";
      track.style.left = `${{axisStartPct.toFixed(3)}}%`;
      track.style.right = `${{(100 - axisEndPct).toFixed(3)}}%`;
      timeline.appendChild(track);

      for (let i = 0; i < indices.length; i += 1) {{
        const idx = indices[i];
        const pointUnix = timestamps[idx];
        const ratio = (total <= 1) ? 0 : (idx / (total - 1));
        const leftPct = axisStartPct + (ratio * axisWidthPct);
        const mark = document.createElement("div");
        mark.className = "signal-timeline-mark";
        if (i === 0) mark.classList.add("edge-start");
        if (i === indices.length - 1) mark.classList.add("edge-end");
        mark.style.left = `${{leftPct.toFixed(3)}}%`;

        const tick = document.createElement("div");
        tick.className = "signal-timeline-tick";
        mark.appendChild(tick);

        const label = document.createElement("div");
        label.className = "signal-timeline-label";
        const includeDate = spanCrossesDay && (i === 0 || i === indices.length - 1);
        label.textContent = formatTimelineLabel(pointUnix, includeDate);
        if (Number.isFinite(pointUnix)) {{
          label.title = new Date(pointUnix * 1000).toLocaleString();
        }}
        mark.appendChild(label);
        timeline.appendChild(mark);
      }}
    }}

    function setSignalTimelineMessage(message) {{
      setTimelineMessage("signal-timeline", message);
    }}

    function signalPointUnix(point) {{
      return timelinePointUnix(point, "bucket_unix", ["bucket_time", "bucket_local"]);
    }}

    function renderSignalTimeline(rows, padLeft, padRight, width) {{
      renderTimeline("signal-timeline", rows, padLeft, padRight, width, (row) => signalPointUnix(row));
    }}

    function renderSignalChart(points) {{
      const svg = document.getElementById("signal-chart");
      const empty = document.getElementById("signal-empty");
      if (!(svg instanceof SVGElement) || !(empty instanceof HTMLElement)) return;

      bindSignalChartZoom();

      const rows = Array.isArray(points) ? points : [];
      signalChartPoints = rows;
      const currentNodeId = normalizeNodeId(selectedNodeId || "");
      if (currentNodeId !== signalChartZoomNodeId) {{
        resetSignalChartZoom(currentNodeId);
      }}
      const visible = getVisibleSignalRows(rows);
      const plotRows = visible.rows;

      const width = signalChartLayout.width;
      const height = signalChartLayout.height;
      const padLeft = signalChartLayout.padLeft;
      const padRight = signalChartLayout.padRight;
      const padTop = signalChartLayout.padTop;
      const padBottom = signalChartLayout.padBottom;
      const plotW = width - padLeft - padRight;
      const plotH = height - padTop - padBottom;

      svg.classList.toggle("zoomed", visible.zoomed);
      svg.setAttribute(
        "title",
        visible.zoomed
          ? "Signal chart zoomed. Wheel to zoom, drag to pan, double-click or Esc to reset."
          : "Signal chart. Wheel to zoom, drag to pan, double-click or Esc to reset."
      );

      const snrVals = plotRows.map((p) => Number(p.avg_snr)).filter((v) => Number.isFinite(v));
      const rssiVals = plotRows.map((p) => Number(p.avg_rssi)).filter((v) => Number.isFinite(v));
      if (snrVals.length === 0 && rssiVals.length === 0) {{
        svg.innerHTML = "";
        empty.hidden = false;
        empty.textContent = "No historical signal points yet for this node.";
        renderSignalTimeline(plotRows, padLeft, padRight, width);
        return;
      }}
      empty.hidden = true;

      const withSpread = (vals, fallbackMin, fallbackMax) => {{
        if (!vals.length) return [fallbackMin, fallbackMax];
        let lo = Math.min(...vals);
        let hi = Math.max(...vals);
        if (Math.abs(hi - lo) < 0.001) {{
          lo -= 1;
          hi += 1;
        }}
        return [lo, hi];
      }};

      const [snrMin, snrMax] = withSpread(snrVals, -20, 20);
      const [rssiMin, rssiMax] = withSpread(rssiVals, -130, -60);
      const xAt = (idx, total) => (
        padLeft + ((Math.max(0, idx) / Math.max(1, total - 1)) * plotW)
      );
      const yFrom = (value, minVal, maxVal) => (
        padTop + ((maxVal - value) / (maxVal - minVal)) * plotH
      );

      const buildPath = (metricKey, minVal, maxVal) => {{
        const n = plotRows.length;
        let d = "";
        let started = false;
        for (let i = 0; i < n; i += 1) {{
          const raw = Number(plotRows[i][metricKey]);
          if (!Number.isFinite(raw)) continue;
          const x = xAt(i, n);
          const y = yFrom(raw, minVal, maxVal);
          d += `${{started ? " L " : "M "}}${{x.toFixed(2)}} ${{y.toFixed(2)}}`;
          started = true;
        }}
        return d;
      }};

      const snrPath = buildPath("avg_snr", snrMin, snrMax);
      const rssiPath = buildPath("avg_rssi", rssiMin, rssiMax);
      const midY = padTop + (plotH / 2);
      const darkTheme = document.documentElement.getAttribute("data-theme") === "dark";
      const chartPalette = darkTheme
        ? {{
            grid: "#324152",
            snr: "#58c878",
            rssi: "#79c0ff",
            snrLabel: "#88e8a5",
            rssiLabel: "#a4d0ff",
          }}
        : {{
            grid: "#dce8df",
            snr: "#1f6f53",
            rssi: "#265d7b",
            snrLabel: "#1f6f53",
            rssiLabel: "#265d7b",
          }};

      svg.setAttribute("viewBox", `0 0 ${{width}} ${{height}}`);
      svg.innerHTML = `
        <rect x="0" y="0" width="${{width}}" height="${{height}}" fill="none"></rect>
        <line x1="${{padLeft}}" y1="${{midY.toFixed(2)}}" x2="${{width - padRight}}" y2="${{midY.toFixed(2)}}" stroke="${{chartPalette.grid}}" stroke-width="1"></line>
        <line x1="${{padLeft}}" y1="${{padTop}}" x2="${{padLeft}}" y2="${{height - padBottom}}" stroke="${{chartPalette.grid}}" stroke-width="1"></line>
        <line x1="${{width - padRight}}" y1="${{padTop}}" x2="${{width - padRight}}" y2="${{height - padBottom}}" stroke="${{chartPalette.grid}}" stroke-width="1"></line>
        ${{snrPath ? `<path d="${{snrPath}}" fill="none" stroke="${{chartPalette.snr}}" stroke-width="2"></path>` : ""}}
        ${{rssiPath ? `<path d="${{rssiPath}}" fill="none" stroke="${{chartPalette.rssi}}" stroke-width="2"></path>` : ""}}
        <text x="${{padLeft - 4}}" y="${{padTop + 10}}" font-size="10" text-anchor="end" fill="${{chartPalette.snrLabel}}">${{formatMetricValue(snrMax, 1)}}</text>
        <text x="${{padLeft - 4}}" y="${{height - padBottom + 11}}" font-size="10" text-anchor="end" fill="${{chartPalette.snrLabel}}">${{formatMetricValue(snrMin, 1)}}</text>
        <text x="${{width - padRight + 4}}" y="${{padTop + 10}}" font-size="10" text-anchor="start" fill="${{chartPalette.rssiLabel}}">${{formatMetricValue(rssiMax, 0)}}</text>
        <text x="${{width - padRight + 4}}" y="${{height - padBottom + 11}}" font-size="10" text-anchor="start" fill="${{chartPalette.rssiLabel}}">${{formatMetricValue(rssiMin, 0)}}</text>
      `;
      renderSignalTimeline(plotRows, padLeft, padRight, width);
    }}

    function rerenderOnlineActivityChartFromCache() {{
      const chartState = historyTrendCharts.online;
      const points = chartState && Array.isArray(chartState.points) ? chartState.points : [];
      renderOnlineActivityChart(points);
    }}

    function rerenderWeeklySummaryChartFromCache() {{
      const chartState = historyTrendCharts.weekly;
      const rows = chartState && Array.isArray(chartState.points) ? chartState.points : [];
      const metricKey = normalizeWeeklySummaryMetric(weeklySummaryMetric);
      const metricMeta = weeklySummaryMetricCatalog.get(metricKey) || {{
        label: "Metric",
        decimals: 0,
      }};
      const emptyMessage = metricKey === "live_packet_count"
        ? "Need at least two saved samples to estimate packets/min."
        : "No weekly summary history yet.";
      renderWeeklySummaryChartRows(rows, metricMeta, emptyMessage);
    }}

    function renderOnlineActivityLoading() {{
      setMapDataMode("activity");
      historyTrendCharts.online.points = [];
      historyTrendCharts.online.pointerDrag = null;
      const caption = document.getElementById("online-activity-caption");
      if (caption) {{
        caption.textContent = "Loading online-node activity history...";
      }}
      const overview = document.getElementById("online-activity-overview");
      if (overview) {{
        overview.innerHTML = "";
      }}
      const svg = document.getElementById("online-activity-chart");
      if (svg instanceof SVGElement) {{
        svg.innerHTML = "";
        svg.classList.remove("zoomed", "chart-dragging");
      }}
      const empty = document.getElementById("online-activity-empty");
      if (empty) {{
        empty.hidden = false;
        empty.textContent = "Loading historical online activity...";
      }}
      setTimelineMessage("online-activity-timeline", "Loading timeline...");
    }}

    function renderOnlineActivityError(message) {{
      setMapDataMode("activity");
      historyTrendCharts.online.points = [];
      resetHistoryTrendZoom(historyTrendCharts.online);
      const caption = document.getElementById("online-activity-caption");
      if (caption) {{
        caption.textContent = `Online activity error: ${{message || "unknown error"}}`;
      }}
      const overview = document.getElementById("online-activity-overview");
      if (overview) {{
        overview.innerHTML = "";
      }}
      const svg = document.getElementById("online-activity-chart");
      if (svg instanceof SVGElement) {{
        svg.innerHTML = "";
        svg.classList.remove("zoomed", "chart-dragging");
      }}
      const empty = document.getElementById("online-activity-empty");
      if (empty) {{
        empty.hidden = false;
        empty.textContent = "Unable to load online-activity history.";
      }}
      setTimelineMessage("online-activity-timeline", "Timeline unavailable due to online-activity error.");
    }}

    function renderOnlineActivityChart(points) {{
      const svg = document.getElementById("online-activity-chart");
      const empty = document.getElementById("online-activity-empty");
      if (!(svg instanceof SVGElement) || !(empty instanceof HTMLElement)) return;

      const chartState = historyTrendCharts.online;
      bindHistoryTrendChartZoom(
        chartState,
        () => rerenderOnlineActivityChartFromCache(),
        "Online activity chart"
      );

      const rows = Array.isArray(points) ? points : [];
      chartState.points = rows;
      const visible = getVisibleHistoryTrendRows(chartState, rows);
      const plotRows = visible.rows;
      setHistoryTrendChartTitle(svg, "Online activity chart", visible.zoomed);

      const values = plotRows.map((p) => Number(p.online_nodes)).filter((v) => Number.isFinite(v));
      if (values.length === 0) {{
        svg.innerHTML = "";
        empty.hidden = false;
        empty.textContent = "No historical online-activity points yet.";
        renderTimeline(
          chartState.timelineId,
          plotRows,
          historyTrendChartLayout.padLeft,
          historyTrendChartLayout.padRight,
          historyTrendChartLayout.width,
          (row) => timelinePointUnix(row, "bucket_unix", ["bucket_local", "bucket_time"])
        );
        return;
      }}
      empty.hidden = true;

      const width = historyTrendChartLayout.width;
      const height = historyTrendChartLayout.height;
      const padLeft = historyTrendChartLayout.padLeft;
      const padRight = historyTrendChartLayout.padRight;
      const padTop = historyTrendChartLayout.padTop;
      const padBottom = historyTrendChartLayout.padBottom;
      const plotW = width - padLeft - padRight;
      const plotH = height - padTop - padBottom;

      let minVal = Math.min(0, ...values);
      let maxVal = Math.max(...values);
      if ((maxVal - minVal) < 1) {{
        maxVal = minVal + 1;
      }}

      const xAt = (idx, total) => (
        padLeft + ((Math.max(0, idx) / Math.max(1, total - 1)) * plotW)
      );
      const yFrom = (value, minValue, maxValue) => (
        padTop + ((maxValue - value) / (maxValue - minValue)) * plotH
      );

      const n = plotRows.length;
      const pointsXY = [];
      for (let i = 0; i < n; i += 1) {{
        const raw = Number(plotRows[i].online_nodes);
        if (!Number.isFinite(raw)) continue;
        pointsXY.push({{
          x: xAt(i, n),
          y: yFrom(raw, minVal, maxVal),
        }});
      }}
      if (!pointsXY.length) {{
        svg.innerHTML = "";
        empty.hidden = false;
        empty.textContent = "No historical online-activity points yet.";
        renderTimeline(
          chartState.timelineId,
          plotRows,
          padLeft,
          padRight,
          width,
          (row) => timelinePointUnix(row, "bucket_unix", ["bucket_local", "bucket_time"])
        );
        return;
      }}

      const path = pointsXY.map((pt, idx) => (
