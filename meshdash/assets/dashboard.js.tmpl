    bindSavedNodeSplitter();
    bindSavedNodeHistorySplitter();
    bindHistoryActivitySplitter();
    bindSelectionControls();
    bindStarredNodeControl();
    bindFavoriteToggleControls();
    bindFavoritesControls();
    bindSavedNodeSearchControls();
    bindNodeListSearchControls();
    bindNodeRowClicks();
