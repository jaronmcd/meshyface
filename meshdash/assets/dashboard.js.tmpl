    async function copyTextToClipboard(text) {{
      const value = String(text || "");
      if (!value) return false;

      try {{
        if (navigator.clipboard && typeof navigator.clipboard.writeText === "function") {{
          await navigator.clipboard.writeText(value);
          return true;
        }}
      }} catch (_err) {{
        // Fallback below.
      }}

      try {{
        const textarea = document.createElement("textarea");
        textarea.value = value;
        textarea.setAttribute("readonly", "true");
        textarea.style.position = "fixed";
        textarea.style.left = "-9999px";
        textarea.style.top = "0";
        document.body.appendChild(textarea);
        textarea.select();
        const ok = document.execCommand("copy");
        document.body.removeChild(textarea);
        return !!ok;
      }} catch (_err) {{
        return false;
      }}
    }}

    function renderChannelsTable(localState) {{
      const tbody = document.getElementById("settings-channels-tbody");
      if (!(tbody instanceof HTMLElement)) return;

      const channels = localState && Array.isArray(localState.channels) ? localState.channels : null;
      tbody.innerHTML = "";

      if (!channels || !channels.length) {{
        const tr = document.createElement("tr");
        const td = document.createElement("td");
        td.colSpan = 7;
        td.className = "settings-channels-empty";
        td.textContent = "No channel data. Click “Fetch settings” to load channels from the radio.";
        tr.appendChild(td);
        tbody.appendChild(tr);
        return;
      }}

      const sorted = [...channels].sort((a, b) => {{
        const ai = Number(a && a.index != null ? a.index : 0);
        const bi = Number(b && b.index != null ? b.index : 0);
        return ai - bi;
      }});

      for (const ch of sorted) {{
        const idx = Number(ch && ch.index != null ? ch.index : 0);
        const role = String(ch && ch.role != null ? ch.role : "");
        const settings = ch && typeof ch.settings === "object" && ch.settings ? ch.settings : {{}};

        const nameValue = String(settings.name || "");
        const uplinkEnabled = !!settings.uplink_enabled;
        const downlinkEnabled = !!settings.downlink_enabled;

        const tr = document.createElement("tr");
        tr.dataset.channelIndex = String(idx);
        tr.dataset.channelRole = role;

        const tdIndex = document.createElement("td");
        tdIndex.textContent = String(idx);
        tr.appendChild(tdIndex);

        const tdRole = document.createElement("td");
        tdRole.textContent = role || "";
        tr.appendChild(tdRole);

        const tdName = document.createElement("td");
        const nameInput = document.createElement("input");
        nameInput.type = "text";
        nameInput.className = "settings-input";
        nameInput.value = nameValue;
        nameInput.placeholder = role === "DISABLED" ? "New channel name" : "";
        nameInput.dataset.field = "name";
        tdName.appendChild(nameInput);
        tr.appendChild(tdName);

        const tdUplink = document.createElement("td");
        const uplink = document.createElement("input");
        uplink.type = "checkbox";
        uplink.checked = uplinkEnabled;
        uplink.dataset.field = "uplink_enabled";
        tdUplink.appendChild(uplink);
        tr.appendChild(tdUplink);

        const tdDownlink = document.createElement("td");
        const downlink = document.createElement("input");
        downlink.type = "checkbox";
        downlink.checked = downlinkEnabled;
        downlink.dataset.field = "downlink_enabled";
        tdDownlink.appendChild(downlink);
        tr.appendChild(tdDownlink);

        const tdPsk = document.createElement("td");
        const psk = document.createElement("input");
        psk.type = "text";
        psk.className = "settings-input";
        psk.value = "";
        const pskHint = (settings.psk && String(settings.psk) === "<redacted>") ? "<redacted>" : "leave blank to keep";
        psk.placeholder = pskHint;
        psk.dataset.field = "psk";
        tdPsk.appendChild(psk);
        tr.appendChild(tdPsk);

        const tdActions = document.createElement("td");
        const actions = document.createElement("div");
        actions.className = "settings-channels-actions";

        const saveBtn = document.createElement("button");
        saveBtn.type = "button";
        saveBtn.className = "btn btn-secondary";
        saveBtn.dataset.channelAction = "save";
        saveBtn.dataset.channelIndex = String(idx);
        saveBtn.textContent = role === "DISABLED" ? "Add" : "Save";
        actions.appendChild(saveBtn);

        if (idx > 0 && role !== "DISABLED") {{
          const disableBtn = document.createElement("button");
          disableBtn.type = "button";
