    function focusChatFeedItem(item) {{
      if (!(item instanceof HTMLElement)) return;
      clearChatFeedChangeFocus();
      item.classList.add("change-focus");
      chatChangeFocusTimer = window.setTimeout(() => {{
        item.classList.remove("change-focus");
        chatChangeFocusTimer = null;
      }}, 1600);
    }}

    function bindChatChangeSummaryControls() {{
      const btn = document.getElementById("chat-change-toggle-btn");
      if (btn instanceof HTMLButtonElement && btn.dataset.bound !== "1") {{
        btn.dataset.bound = "1";
        btn.addEventListener("click", (ev) => {{
          ev.preventDefault();
          ev.stopPropagation();
          setChatChangeMenuOpen(!chatChangeMenuOpen);
          if (chatChangeMenuOpen) {{
            // Opening the bell acknowledges current alerts without clearing history.
            markChatChangeAlertsAcknowledged();
            renderChatChangeSummary();
            bindChatChangeSummaryControls();
          }}
        }});
      }}

      if (document.body.dataset.chatChangeMenuDocBound !== "1") {{
        document.body.dataset.chatChangeMenuDocBound = "1";
        document.addEventListener("pointerdown", (ev) => {{
          if (!chatChangeMenuOpen) return;
          const target = ev.target;
          if (!(target instanceof Element)) {{
            setChatChangeMenuOpen(false);
            return;
          }}
          if (target.closest("#chat-change-toggle-btn") || target.closest("#chat-change-summary")) {{
            return;
          }}
          setChatChangeMenuOpen(false);
        }});
        document.addEventListener("keydown", (ev) => {{
          if (ev.key !== "Escape" || !chatChangeMenuOpen) return;
          setChatChangeMenuOpen(false);
        }});
      }}

      const panel = document.getElementById("chat-change-summary");
      if (!(panel instanceof HTMLElement) || panel.hidden) return;
      const clearBtn = panel.querySelector("#chat-change-clear-btn");
      if (clearBtn instanceof HTMLButtonElement) {{
        clearBtn.addEventListener("click", (ev) => {{
          ev.preventDefault();
          clearChatChangeNotices(activeChatChannel);
          clearChatFeedChangeFocus();
          if (latestState) {{
            renderChat(latestState);
          }} else {{
            renderChatChangeSummary();
          }}
        }});
      }}
      for (const itemBtn of panel.querySelectorAll(".chat-change-item")) {{
        if (!(itemBtn instanceof HTMLButtonElement)) continue;
        itemBtn.addEventListener("click", (ev) => {{
          ev.preventDefault();
          const focusKey = String(itemBtn.dataset.changeFocusKey || "").trim();
          if (!focusKey) return;
          const target = findChatFeedItemByMessageKey(focusKey);
          if (!(target instanceof HTMLElement)) {{
            setChatSendStatus("Change is older than the visible chat window.", true);
            return;
          }}
          setChatChangeMenuOpen(false);
          target.scrollIntoView({{ behavior: "smooth", block: "center" }});
          focusChatFeedItem(target);
        }});
      }}
    }}

    function chatSenderLabelFromMessage(msg, nodesById) {{
      if (!msg || typeof msg !== "object") return "Unknown node";
      const senderId = normalizeNodeId(msg.from || "");
      if (senderId === "^all") return "All";
      if (senderId === "local") return "Local";
      const explicitName = String(msg.from_name ?? msg.fromName ?? "").trim();
      if (explicitName) return explicitName;
      const node = nodesById.get(senderId);
      const preferred = preferredNodeName(node);
      if (preferred) return preferred;
      return senderId || "Unknown node";
    }}

    function collectChatMessageEntries(state) {{
      const safeState = state && typeof state === "object" ? state : {{}};
      const nodes = Array.isArray(safeState.nodes) ? safeState.nodes : [];
      const traffic = safeState.traffic && typeof safeState.traffic === "object"
        ? safeState.traffic
        : {{}};
      const recentChat = Array.isArray(traffic.recent_chat) ? traffic.recent_chat : [];
      const localNodeId = normalizeNodeId(resolveLocalNodeId(safeState) || "");
      const hasLocalNodeId = isCanonicalNodeId(localNodeId);
      const nodesById = new Map(
        nodes.map((node) => [normalizeNodeId(node && node.id ? node.id : ""), node])
      );
      const messageSenderById = new Map();
      for (const msg of recentChat) {{
        if (!messageMatchesActiveMeshChannel(msg)) continue;
        if (!msg || typeof msg !== "object") continue;
        const msgId = Number(msg.message_id ?? msg.messageId ?? msg.packet_id ?? msg.packetId);
        if (!Number.isInteger(msgId) || msgId <= 0) continue;
        const fromId = normalizeNodeId(msg.from || "");
        if (!fromId) continue;
        messageSenderById.set(String(msgId), fromId);
      }}
      const entries = [];
      for (const msg of recentChat) {{
        if (!messageMatchesActiveMeshChannel(msg)) continue;
        const key = chatMessageKey(msg);
        if (!key) continue;
        const channel = classifyMessageChannel(msg);
        const isReaction = isReactionLikeChatMessage(msg);
        const fromId = normalizeNodeId(msg && msg.from ? msg.from : "");
        const toId = normalizeNodeId(msg && (msg.to || msg.destination) ? (msg.to || msg.destination) : "");
        const replyIdRaw = Number(msg && (msg.reply_id ?? msg.replyId));
        const replyId = Number.isInteger(replyIdRaw) && replyIdRaw > 0
          ? Math.trunc(replyIdRaw)
          : null;
        const replyTargetSenderId = replyId != null
          ? normalizeNodeId(messageSenderById.get(String(replyId)) || "")
          : "";
        const senderIsSelf = hasLocalNodeId && fromId === localNodeId;
        const directToSelf = hasLocalNodeId && channel === "direct" && toId === localNodeId;
        const referencesSelfMessage = hasLocalNodeId && !!replyId && replyTargetSenderId === localNodeId;
        const selfRelevant = hasLocalNodeId && !senderIsSelf && (directToSelf || referencesSelfMessage);
        entries.push({{
          key,
          focusKey: isReaction ? chatChangeFocusKeyFromMessage(msg, key) : key,
          channel,
          sender: chatSenderLabelFromMessage(msg, nodesById),
          preview: chatChangePreviewFromMessage(msg, isReaction),
          kind: isReaction ? "reaction" : "message",
          countsUnread: !isReaction,
          selfRelevant,
          unix: latestUnixTimestamp(msg && msg.rx_time, msg && msg.captured_at),
        }});
      }}
      return entries;
    }}

    function entryMatchesNotificationScope(entry) {{
      const scope = normalizeChatNotificationScope(chatNotificationScope);
      if (scope === "all") return true;
      return !!(entry && entry.selfRelevant === true);
    }}

    function isTabInactiveForNotifications() {{
      return document.hidden || !tabHasFocus;
    }}

    function syncChatUnreadFromEntries(entries, options = {{}}) {{
      const clearActiveWhenInChat = options.clearActiveWhenInChat !== false;
      const keyedMessages = Array.isArray(entries) ? entries : [];
      const catchupNoticeArmed = chatChangeCatchupArmed;
      chatChangeCatchupArmed = false;
      const tabInactive = isTabInactiveForNotifications();
      if (!chatUnreadInitialized) {{
        for (const entry of keyedMessages) {{
          rememberSeenChatMessage(entry.key);
        }}
        chatUnreadInitialized = true;
        syncChatRailUnread();
        return;
      }}

      const freshByChannel = {{ all: 0, direct: 0 }};
      const latestSenderByChannel = {{ all: "", direct: "" }};
      for (const entry of keyedMessages) {{
        if (!rememberSeenChatMessage(entry.key)) continue;
        const key = entry.channel === "direct" ? "direct" : "all";
        const scopeMatch = entryMatchesNotificationScope(entry);
        const shouldNotify = catchupNoticeArmed || tabInactive;
        if (shouldNotify && scopeMatch) {{
          trackChatChangeNotice({{
            key: entry.key,
            focusKey: entry.focusKey || entry.key,
            channel: key,
            sender: entry.sender,
            preview: entry.preview,
            kind: entry.kind,
            selfRelevant: entry.selfRelevant === true,
            unix: entry.unix,
          }});
        }}
        if (!shouldNotify || entry.countsUnread === false || !scopeMatch) continue;
        freshByChannel[key] += 1;
        latestSenderByChannel[key] = String(entry.sender || "").trim();
      }}

      if (activeLayoutView === "chat" && clearActiveWhenInChat) {{
        const otherKey = activeChatChannel === "direct" ? "all" : "direct";
        if (freshByChannel[otherKey] > 0) {{
          setChatChannelUnread(
            otherKey,
            Number(chatUnreadByChannel[otherKey] || 0) + freshByChannel[otherKey]
          );
          setChatChannelUnreadLatest(
            otherKey,
            latestSenderByChannel[otherKey] || chatUnreadLatestByChannel[otherKey] || ""
          );
        }}
        setChatChannelUnread(activeChatChannel, 0);
        setChatChannelUnreadLatest(activeChatChannel, "");
      }} else {{
        if (freshByChannel.all > 0) {{
          setChatChannelUnread("all", Number(chatUnreadByChannel.all || 0) + freshByChannel.all);
          setChatChannelUnreadLatest("all", latestSenderByChannel.all || chatUnreadLatestByChannel.all || "");
        }}
        if (freshByChannel.direct > 0) {{
          setChatChannelUnread("direct", Number(chatUnreadByChannel.direct || 0) + freshByChannel.direct);
          setChatChannelUnreadLatest("direct", latestSenderByChannel.direct || chatUnreadLatestByChannel.direct || "");
        }}
      }}
      syncChatRailUnread();
    }}

    function syncChatUnreadFromState(state, options = {{}}) {{
      syncChatUnreadFromEntries(collectChatMessageEntries(state), options);
    }}

    function rememberSeenChatMessage(key) {{
      if (!key || chatSeenMessageKeys.has(key)) return false;
      chatSeenMessageKeys.add(key);
      chatSeenMessageOrder.push(key);
      if (chatSeenMessageOrder.length > 6000) {{
        while (chatSeenMessageOrder.length > 4500) {{
          const stale = chatSeenMessageOrder.shift();
          if (stale) chatSeenMessageKeys.delete(stale);
        }}
      }}
      return true;
    }}

    function setChatChannelUnread(channelKey, count) {{
      const key = normalizeChatChannel(channelKey);
      const safe = Math.max(0, Math.min(999, Math.trunc(Number(count) || 0)));
      chatUnreadByChannel[key] = safe;
    }}

    function setChatChannelUnreadLatest(channelKey, name) {{
      const key = normalizeChatChannel(channelKey);
      const clean = String(name || "").replace(/\\s+/g, " ").trim();
      chatUnreadLatestByChannel[key] = clean;
    }}

    function totalChatUnread() {{
      return Math.max(0, Number(chatUnreadByChannel.all || 0))
        + Math.max(0, Number(chatUnreadByChannel.direct || 0));
    }}

    function totalChatChangeNotices() {{
      const allCount = chatChangeUnacknowledgedCountForChannel("all");
      const directCount = chatChangeUnacknowledgedCountForChannel("direct");
      return allCount + directCount;
    }}

    function syncChatRailUnread() {{
      chatUnreadCount = Math.min(999, totalChatUnread());
      setChatRailUnread(chatUnreadCount);
    }}

    function syncDocumentUnreadTitle(count) {{
      const unreadCount = Math.max(0, Math.trunc(Number(count) || 0));
      const missedCount = Math.max(0, Math.trunc(Number(totalChatChangeNotices()) || 0));
      const safeCount = Math.max(unreadCount, missedCount);
      const badge = safeCount > 99 ? "99+" : String(safeCount);
      const nextTitle = safeCount > 0
        ? `(${{badge}}) ${{baseDocumentTitle}}`
        : baseDocumentTitle;
      if (document.title !== nextTitle) {{
        document.title = nextTitle;
      }}
    }}

    function setChatRailUnread(count) {{
      const unreadCount = Math.max(0, Math.trunc(Number(count) || 0));
      const missedCount = Math.max(0, Math.trunc(Number(totalChatChangeNotices()) || 0));
      const safeCount = Math.max(unreadCount, missedCount);
      syncDocumentUnreadTitle(safeCount);
      const btn = document.querySelector('.teams-rail .rail-btn[data-view="chat"]');
      if (!(btn instanceof HTMLButtonElement)) return;
      if (!btn.dataset.baseTitle) {{
        btn.dataset.baseTitle = btn.getAttribute("title") || "Teams-style chat workspace";
      }}
      const labelCount = safeCount > 99 ? "99+" : String(safeCount);
      btn.textContent = safeCount > 0 ? `Chat (${{labelCount}})` : "Chat";
      btn.classList.toggle("has-unread", safeCount > 0);
      const baseTitle = btn.dataset.baseTitle || "Teams-style chat workspace";
      btn.title = safeCount > 0
        ? `${{baseTitle}}. ${{safeCount}} unread update${{safeCount === 1 ? "" : "s"}}.`
        : baseTitle;
      btn.setAttribute("aria-label", btn.title);
    }}

    function clearChatUnread(channelKey = null) {{
      if (channelKey == null) {{
        setChatChannelUnread("all", 0);
        setChatChannelUnread("direct", 0);
        setChatChannelUnreadLatest("all", "");
        setChatChannelUnreadLatest("direct", "");
      }} else {{
        setChatChannelUnread(channelKey, 0);
        setChatChannelUnreadLatest(channelKey, "");
      }}
      syncChatRailUnread();
    }}

    function persistSplitState() {{
      try {{
        window.localStorage.setItem(
          splitStorageKey,
          JSON.stringify({{
            col_pct: splitPct,
            top_px: splitTopPx,
            mid_px: splitMidPx,
            low_px: splitLowPx,
          }})
        );
      }} catch (_err) {{
      }}
    }}

    function normalizeLayoutView(raw) {{
      const clean = String(raw || "").trim().toLowerCase();
      return knownLayoutViews.has(clean) ? clean : "chat";
    }}

    function isMapVisibleLayoutView(viewName) {{
      const view = normalizeLayoutView(viewName);
      return view === "network" || view === "saved";
    }}

    function syncNodeHistoryDock() {{
      const nodeHistoryPanel = document.getElementById("map-data-node");
      const mapDataBody = document.getElementById("map-data-body");
      const networkHost = document.getElementById("network-node-history-host");
      const savedHost = document.getElementById("saved-node-history-host");
      const nodesTitle = document.getElementById("nodes-card-title");
      if (!(nodeHistoryPanel instanceof HTMLElement)) return;
      if (!(mapDataBody instanceof HTMLElement)) return;
      if (!(networkHost instanceof HTMLElement)) return;

      const dockInSaved = activeLayoutView === "saved" && (savedHost instanceof HTMLElement);
      const target = dockInSaved ? savedHost : mapDataBody;
      if (nodeHistoryPanel.parentElement !== target) {{
        target.appendChild(nodeHistoryPanel);
      }}

      networkHost.hidden = true;
      networkHost.classList.remove("empty");
      if (nodesTitle instanceof HTMLElement) {{
        nodesTitle.textContent = activeLayoutView === "network" ? "Network Explorer" : "Nodes";
      }}
    }}

    function applyLayoutView(viewName, persist = true) {{
      const layout = document.getElementById("dashboard-layout");
      if (!(layout instanceof HTMLElement)) return;
      const shell = document.querySelector(".workspace-shell");
      const chatLeftPanel = document.getElementById("chat-left-panel");
      const next = normalizeLayoutView(viewName);
      activeLayoutView = next;
      for (const name of knownLayoutViews) {{
        layout.classList.remove(`view-${{name}}`);
      }}
      layout.classList.add(`view-${{next}}`);

      // Keep rail selection in sync even if any later view-specific setup throws.
      for (const btn of document.querySelectorAll(".teams-rail .rail-btn")) {{
        if (!(btn instanceof HTMLButtonElement)) continue;
        const isActive = normalizeLayoutView(btn.dataset.view || "") === next;
        btn.classList.toggle("active", isActive);
        btn.setAttribute("aria-current", isActive ? "page" : "false");
      }}

      const chatPanelOpen = next === "chat";
      if (shell instanceof HTMLElement) {{
        shell.classList.toggle("chat-panel-open", chatPanelOpen);
      }}
      if (chatLeftPanel instanceof HTMLElement) {{
        chatLeftPanel.hidden = !chatPanelOpen;
      }}
      refreshMapCardTitle();
      const mapResetBtn = document.getElementById("map-reset-view-btn");
      if (mapResetBtn instanceof HTMLButtonElement) {{
        mapResetBtn.hidden = next === "saved" || next === "history";
      }}

      const mapNodes = latestState && Array.isArray(latestState.nodes) ? latestState.nodes : [];
      try {{
        syncSignalHeatmapLayer(mapNodes, next === "saved");
      }} catch (_err) {{
      }}
      try {{
        setMapWheelZoomActive(next === "network" || next === "saved");
      }} catch (_err) {{
      }}
      if (chatPanelOpen) {{
        if (activeWheelPane instanceof HTMLElement) {{
          activeWheelPane.classList.remove("wheel-scroll-active");
        }}
        activeWheelPane = null;
        if (activeWheelPaneLease !== null) {{
          clearTimeout(activeWheelPaneLease);
          activeWheelPaneLease = null;
        }}
        // Entering Chat should clear any stale rail badge regardless of which
        // sub-channel (Everyone vs Peer-to-peer) previously accumulated it.
        clearChatUnread();
      }}
      syncChatRailUnread();
      if (typeof window.meshRefreshWheelHints === "function") {{
        try {{
          window.meshRefreshWheelHints();
        }} catch (_err) {{
        }}
      }}

      if (persist) {{
        try {{
          window.localStorage.setItem(layoutViewStorageKey, next);
        }} catch (_err) {{
        }}
      }}

      if (next === "history") {{
        mapDataFocus = "activity";
      }}
      if (next === "network" && mapDataFocus === "activity") {{
        mapDataFocus = "auto";
      }}
      if (next === "network") {{
        fitDone = false;
      }}
      if (next === "network" && isSelectableNodeId(selectedNodeId)) {{
        pendingSelectionScroll = true;
        highlightNodeSelection();
        window.requestAnimationFrame(() => {{
          scrollSelectionIntoView();
        }});
      }}
      syncNodeHistoryDock();
      if (latestState) {{
        let cachedNodeHistory = null;
        if ((next === "saved" || next === "network") && isSelectableNodeId(selectedNodeId)) {{
          const cached = nodeHistoryCache.get(selectedNodeId);
          if (cached && cached.data) {{
            cachedNodeHistory = cached.data;
          }}
        }}
        // Render visible UI from cached state immediately on view switches.
        // This prevents "blank" panes when the server legitimately returns 304s.
        renderSummary(latestState);
        if (next === "saved" || next === "network") {{
          renderMap(latestState.nodes || [], (latestState.traffic || {{}}).edges || [], cachedNodeHistory);
        }}
        if (next === "network") {{
          renderNodes(latestState.nodes || []);
        }}
        renderTraffic(latestState.traffic || {{}}, latestState.nodes || [], cachedNodeHistory, null);
        if (next === "chat") {{
          renderChat(latestState);
        }}
        if (next === "history") {{
          renderHistoryChat(latestState.traffic || {{}});
          setMapDataMode("activity");
          void refreshHistoryPanels(false);
        }}
        if (next === "saved") {{
          renderFavorites(latestState, cachedNodeHistory);
        }} else {{
          renderSavedNodeDetails(latestState, cachedNodeHistory);
        }}
        if (next === "settings") {{
          renderSettings(latestState);
        }}
        if (next === "packets") {{
          renderPackets(latestState.traffic || {{}});
        }}
        if (next === "console") {{
          renderConsole(latestState.traffic || {{}});
        }}
      }} else if (next === "network") {{
        renderNodesPlaceholder("Syncing nodes...");
      }} else if (next === "history") {{
        setMapDataMode("activity");
        renderOnlineActivityLoading();
        renderWeeklySummaryLoading();
        renderHistoryChat({{}});
      }}
      if (next === "console") {{
        window.requestAnimationFrame(() => {{
          focusConsoleCommandInput(false);
        }});
      }}
      if (next !== "saved") {{
        closeSavedNodeSearchDropdown();
      }}
      renderSavedNodeSearchDropdown(latestState);
      // Ensure node history loads immediately when switching into the map views.
      void refreshSelectedNodeHistory(false);
      if (next === "chat" || next === "history" || next === "network" || next === "saved") {{
        requestImmediatePoll(0);
      }}
      if (isMapVisibleLayoutView(next)) {{
        requestMapResizeStabilized();
      }} else {{
        clearMapResizeStabilizeTimers();
      }}
    }}

    function loadLayoutView() {{
      let preferred = "chat";
      try {{
        preferred = normalizeLayoutView(window.localStorage.getItem(layoutViewStorageKey) || "chat");
      }} catch (_err) {{
      }}
      applyLayoutView(preferred, false);
    }}

    function bindLayoutNav() {{
      for (const btn of document.querySelectorAll(".teams-rail .rail-btn")) {{
        if (!(btn instanceof HTMLButtonElement) || btn.dataset.bound === "1") continue;
        btn.dataset.bound = "1";
        btn.addEventListener("click", () => {{
          applyLayoutView(btn.dataset.view || "chat", true);
        }});
      }}
    }}

    function bindSplitters() {{
      const layout = document.querySelector(".layout");
      if (!(layout instanceof HTMLElement)) return;

      for (const splitter of document.querySelectorAll(".splitter, .hsplitter")) {{
        if (!(splitter instanceof HTMLElement) || splitter.dataset.bound === "1") continue;
        splitter.dataset.bound = "1";

        splitter.addEventListener("pointerdown", (ev) => {{
          if (window.matchMedia("(max-width: 1100px)").matches) return;
          ev.preventDefault();
          splitter.classList.add("active");
          const isHorizontal = splitter.classList.contains("hsplitter");
          document.body.classList.add(isHorizontal ? "resizing-panels-y" : "resizing-panels-x");
          splitter.setPointerCapture(ev.pointerId);
          const rect = layout.getBoundingClientRect();
          const startY = ev.clientY;
          const target = splitter.dataset.target || "";
          const startTop = splitTopPx;
          const startMid = splitMidPx;
          const startLow = splitLowPx;

          const onMove = (moveEv) => {{
            if (isHorizontal) {{
              const deltaY = moveEv.clientY - startY;
              if (target === "top") {{
                splitTopPx = clampTopSplitPx(startTop + deltaY);
              }} else if (target === "mid") {{
                splitMidPx = clampMidSplitPx(startMid + deltaY);
              }} else if (target === "low") {{
                if (activeLayoutView === "packets" || activeLayoutView === "data") {{
                  splitTopPx = clampTopSplitPx(startTop + deltaY);
                }} else {{
                  splitLowPx = clampLowSplitPx(startLow + deltaY);
                }}
              }}
            }} else {{
              const pct = clampSplitPct(((moveEv.clientX - rect.left) / rect.width) * 100);
              splitPct = pct;
            }}
            applySplitState();
            requestMapResize();
          }};

          const onUp = () => {{
            splitter.classList.remove("active");
            document.body.classList.remove("resizing-panels-x", "resizing-panels-y");
            persistSplitState();
            requestMapResize();
            splitter.removeEventListener("pointermove", onMove);
            splitter.removeEventListener("pointerup", onUp);
            splitter.removeEventListener("pointercancel", onUp);
          }};

          splitter.addEventListener("pointermove", onMove);
          splitter.addEventListener("pointerup", onUp);
          splitter.addEventListener("pointercancel", onUp);
        }});
      }}
    }}

    function bindNetworkNodeSplitter() {{
      const splitter = document.getElementById("network-node-splitter");
      if (!(splitter instanceof HTMLElement) || splitter.dataset.bound === "1") return;
      const stack = splitter.closest(".network-node-stack");
      if (!(stack instanceof HTMLElement)) return;
      splitter.dataset.bound = "1";

      splitter.addEventListener("pointerdown", (ev) => {{
        if (window.matchMedia("(max-width: 1100px)").matches) return;
        ev.preventDefault();
        splitter.classList.add("active");
        document.body.classList.add("resizing-panels-y");
        splitter.setPointerCapture(ev.pointerId);

        const tablePane = stack.querySelector(".nodes-table-scroll");
        if (!(tablePane instanceof HTMLElement)) {{
          splitter.classList.remove("active");
          document.body.classList.remove("resizing-panels-y");
          return;
        }}

        const updateFromClientY = (clientY) => {{
          const rect = stack.getBoundingClientRect();
          if (rect.height < 80) return;
          const relativeY = clientY - rect.top;
          const pct = clampNetworkNodesListPct((relativeY / rect.height) * 100);
          networkNodesListPct = pct;
          applyNetworkNodesSplitState();
        }};

        updateFromClientY(ev.clientY);

        const onMove = (moveEv) => {{
          updateFromClientY(moveEv.clientY);
        }};

        const onUp = () => {{
          splitter.classList.remove("active");
          document.body.classList.remove("resizing-panels-y");
          persistNetworkNodesSplitState();
          splitter.removeEventListener("pointermove", onMove);
          splitter.removeEventListener("pointerup", onUp);
          splitter.removeEventListener("pointercancel", onUp);
        }};

        splitter.addEventListener("pointermove", onMove);
        splitter.addEventListener("pointerup", onUp);
        splitter.addEventListener("pointercancel", onUp);
      }});
    }}

    function bindSavedNodeSplitter() {{
      const handles = [
        document.getElementById("saved-map-splitter"),
        document.getElementById("saved-map-splitter-head"),
      ].filter((el) => el instanceof HTMLElement);
      if (!handles.length) return;
      const pane = document.querySelector(".card.map .body");
      if (!(pane instanceof HTMLElement)) return;

      const setActive = (active) => {{
        for (const handle of handles) {{
          handle.classList.toggle("active", !!active);
        }}
      }};

      for (const splitter of handles) {{
        if (!(splitter instanceof HTMLElement) || splitter.dataset.bound === "1") continue;
        splitter.dataset.bound = "1";

        splitter.addEventListener("pointerdown", (ev) => {{
          if (activeLayoutView !== "saved") return;
          if (window.matchMedia("(max-width: 1100px)").matches) return;
          ev.preventDefault();
          setActive(true);
          document.body.classList.add("resizing-panels-x");
          splitter.setPointerCapture(ev.pointerId);

          const updateFromClientX = (clientX) => {{
            const rect = pane.getBoundingClientRect();
            if (rect.width < 120) return;
            const relativeX = clientX - rect.left;
            const pct = clampSavedNodePanePct((relativeX / rect.width) * 100);
            savedNodePanePct = pct;
            applySavedNodeSplitState();
            requestMapResize();
          }};

          updateFromClientX(ev.clientX);

          const onMove = (moveEv) => {{
            updateFromClientX(moveEv.clientX);
          }};

          const onUp = () => {{
            setActive(false);
            document.body.classList.remove("resizing-panels-x");
            persistSavedNodeSplitState();
            requestMapResize();
            splitter.removeEventListener("pointermove", onMove);
            splitter.removeEventListener("pointerup", onUp);
            splitter.removeEventListener("pointercancel", onUp);
          }};

