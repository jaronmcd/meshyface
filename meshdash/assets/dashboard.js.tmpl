    function ensureSignalHeatmapLayers() {{
      if (!supportsSignalHeatmap()) {{
        return [];
      }}
      if (Array.isArray(signalHeatmapLayers) && signalHeatmapLayers.length > 0) {{
        return signalHeatmapLayers;
      }}
      let pane = map.getPane(signalHeatmapPaneName);
      if (!pane) {{
        pane = map.createPane(signalHeatmapPaneName);
      }}
      if (pane) {{
        pane.style.zIndex = "430";
        pane.style.pointerEvents = "none";
      }}
      const baseRadius = signalHeatDevKnobs.radius;
      const baseBlur = signalHeatDevKnobs.blur;
      const baseOpacity = signalHeatDevKnobs.minOpacity;
      const signalGain = clampUnitInterval(signalHeatDevKnobs.radiusSignalGain);

      signalHeatmapLayers = signalHeatBucketDefs.map((bucket) => {{
        const baseRadiusMul = Number(bucket.radiusMul) || 1;
        const baseBlurMul = Number(bucket.blurMul) || 1;
        const radiusMul = 1 + ((baseRadiusMul - 1) * signalGain);
        const blurMul = 1 + ((baseBlurMul - 1) * signalGain);
        const radius = clampNumber(
          Math.round(baseRadius * radiusMul),
          10,
          160,
          baseRadius
        );
        const blur = clampNumber(
          Math.round(baseBlur * blurMul),
          8,
          140,
          baseBlur
        );
        return L.heatLayer(
          [],
          Object.assign(
            {{ pane: signalHeatmapPaneName }},
            signalHeatmapLayerOptions,
            {{ radius, blur, minOpacity: baseOpacity }}
          )
        );
      }});
      return signalHeatmapLayers;
