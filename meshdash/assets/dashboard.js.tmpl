        if (!raw) return;
        const parsed = JSON.parse(raw);
        if (!Array.isArray(parsed)) return;
        if (parsed.length !== 10) return;
        applyNodesTableColPcts(parsed);
      }} catch (_err) {{
      }}
    }}

    function bindNodesTableColResizers() {{
      const table = document.getElementById("nodes-table");
      if (!(table instanceof HTMLTableElement) || table.dataset.colResizeBound === "1") return;
      table.dataset.colResizeBound = "1";

      const cols = Array.from(document.querySelectorAll("#nodes-table-cols col"));
      const handles = Array.from(table.querySelectorAll("thead .col-resizer"));
      if (!cols.length || !handles.length) return;

      const minWidthPxByIndex = {{
        0: 92,  // Last Heard
        1: 78,  // ID
        2: 120, // Name
        3: 80,  // HW
        4: 54,  // SNR
        5: 54,  // Hops
        6: 64,  // Battery
        7: 72,  // Saved
        8: 110, // Pos
        9: 34,  // Star
      }};

      handles.forEach((handle) => {{
        if (!(handle instanceof HTMLElement)) return;
        handle.addEventListener("mousedown", (ev) => {{
          ev.preventDefault();
          ev.stopPropagation();
          const colIndexRaw = Number(handle.dataset.col);
          const colIndex = Number.isFinite(colIndexRaw) ? Math.trunc(colIndexRaw) : -1;
          if (colIndex < 0 || colIndex >= cols.length) return;

          // Resize this column + its right neighbor (or left neighbor for the last column).
          const leftIndex = colIndex === cols.length - 1 ? colIndex - 1 : colIndex;
          const rightIndex = colIndex === cols.length - 1 ? colIndex : colIndex + 1;
          if (leftIndex < 0 || rightIndex >= cols.length) return;

          const leftCol = cols[leftIndex];
          const rightCol = cols[rightIndex];
          const headerRow = table.tHead && table.tHead.rows && table.tHead.rows[0] ? table.tHead.rows[0] : null;
          if (!headerRow || !headerRow.cells || headerRow.cells.length <= rightIndex) return;
          const startLeft = headerRow.cells[leftIndex].getBoundingClientRect().width;
          const startRight = headerRow.cells[rightIndex].getBoundingClientRect().width;
          const total = startLeft + startRight;
          if (!Number.isFinite(total) || total <= 10) return;

          const startX = ev.clientX;
          const minLeft = minWidthPxByIndex[leftIndex] || 48;
          const minRight = minWidthPxByIndex[rightIndex] || 48;

          const onMove = (moveEv) => {{
            moveEv.preventDefault();
            const dx = moveEv.clientX - startX;
            let newLeft = startLeft + dx;
            newLeft = Math.max(minLeft, Math.min(total - minRight, newLeft));
            const newRight = total - newLeft;
            leftCol.style.width = `${{newLeft}}px`;
            rightCol.style.width = `${{newRight}}px`;
          }};

          const onUp = () => {{
            document.removeEventListener("mousemove", onMove);
            document.removeEventListener("mouseup", onUp);
            // Convert to percentages so it survives window resizes nicely.
            const pcts = readNodesTableColPctsFromDom();
            if (pcts) {{
              applyNodesTableColPcts(pcts);
              persistNodesTableColPcts();
            }}
          }};

          document.addEventListener("mousemove", onMove);
          document.addEventListener("mouseup", onUp);
        }});

        handle.addEventListener("click", (ev) => {{
          // Prevent triggering sort on header click.
          ev.stopPropagation();
        }});
      }});
    }}

