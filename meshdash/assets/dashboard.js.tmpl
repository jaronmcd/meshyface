        if (!isValidLatLonRange(lat, lon)) return null;
        const altRaw = toFiniteNumberOrNull(node && (node.alt ?? node.altitude ?? node.altitudeM));
        return {{
          lat: Number(lat),
          lon: Number(lon),
          alt: Number.isFinite(altRaw) ? Math.trunc(altRaw) : null,
        }};
      }}
      return null;
    }}

    function syncSettingsPositionSourceUi(options = {{}}) {{
