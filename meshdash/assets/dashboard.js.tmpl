    function bindSavedNodeSearchControls() {{
      const input = document.getElementById("saved-node-search-input");
      const dropdown = document.getElementById("saved-node-search-dropdown");
      if (!(input instanceof HTMLInputElement) || !(dropdown instanceof HTMLElement)) return;

      if (input.dataset.bound !== "1") {{
        input.dataset.bound = "1";
        const openSavedNodeSearch = () => {{
          if (savedNodeSearchBlurTimer !== null) {{
            clearTimeout(savedNodeSearchBlurTimer);
            savedNodeSearchBlurTimer = null;
          }}
          savedNodeSearchQuery = normalizeSearchQuery(input.value);
          savedNodeSearchOpen = true;
          renderSavedNodeSearchDropdown(latestState);
        }};
        input.addEventListener("focus", openSavedNodeSearch);
        // Clicking an already-focused input does not fire "focus" again.
        // Reopen on click so the list pops every time the user clicks it.
        input.addEventListener("click", openSavedNodeSearch);
        input.addEventListener("input", () => {{
          savedNodeSearchQuery = normalizeSearchQuery(input.value);
          savedNodeSearchOpen = true;
          renderSavedNodeSearchDropdown(latestState);
        }});
        input.addEventListener("keydown", (ev) => {{
          if (ev.key === "Escape") {{
            ev.preventDefault();
            closeSavedNodeSearchDropdown();
          }}
        }});
        input.addEventListener("blur", () => {{
          if (savedNodeSearchBlurTimer !== null) {{
            clearTimeout(savedNodeSearchBlurTimer);
          }}
          savedNodeSearchBlurTimer = window.setTimeout(() => {{
            savedNodeSearchBlurTimer = null;
            closeSavedNodeSearchDropdown();
          }}, 120);
        }});
      }}
      input.value = savedNodeSearchQuery;

      if (dropdown.dataset.bound !== "1") {{
        dropdown.dataset.bound = "1";
        dropdown.addEventListener("mousedown", (ev) => {{
          ev.preventDefault();
          if (savedNodeSearchBlurTimer !== null) {{
            clearTimeout(savedNodeSearchBlurTimer);
            savedNodeSearchBlurTimer = null;
          }}
        }});
        dropdown.addEventListener("click", (ev) => {{
          const target = ev.target;
          if (!(target instanceof Element)) return;
          const item = target.closest(".node-search-item");
          if (!(item instanceof HTMLButtonElement)) return;
          const nodeId = normalizeNodeId(item.dataset.nodeId || "");
          if (!isSelectableNodeId(nodeId)) return;
          selectNode(nodeId, true, false);
          closeSavedNodeSearchDropdown();
        }});
      }}

      if (document.body.dataset.savedNodeSearchOutsideBound !== "1") {{
        document.body.dataset.savedNodeSearchOutsideBound = "1";
        document.addEventListener("pointerdown", (ev) => {{
          const inputEl = document.getElementById("saved-node-search-input");
          const dropdownEl = document.getElementById("saved-node-search-dropdown");
          if (!(inputEl instanceof HTMLInputElement) || !(dropdownEl instanceof HTMLElement)) return;
          const target = ev.target;
          if (!(target instanceof Node)) return;
          if (inputEl.contains(target) || dropdownEl.contains(target)) return;
          closeSavedNodeSearchDropdown();
        }});
      }}
      renderSavedNodeSearchDropdown(latestState);
    }}

