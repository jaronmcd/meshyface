    function bytesToGiB(value) {{
      const num = Number(value);
      if (!Number.isFinite(num) || num < 0) return null;
      return num / (1024 ** 3);
    }}

    function formatModemPresetLabel(value, fallback = "unknown") {{
      const raw = String(value == null ? "" : value).trim();
      if (!raw) return fallback;
      const enumMap = new Map([
        ["0", "LONG_FAST"],
        ["1", "LONG_SLOW"],
        ["2", "VERY_LONG_SLOW"],
        ["3", "MEDIUM_SLOW"],
        ["4", "MEDIUM_FAST"],
        ["5", "SHORT_SLOW"],
        ["6", "SHORT_FAST"],
        ["7", "LONG_MODERATE"],
        ["8", "SHORT_TURBO"],
        ["9", "LONG_TURBO"],
      ]);
      const canonicalRaw = enumMap.get(raw) || raw;
      return canonicalRaw
        .split(/[_\\s]+/)
        .filter((token) => !!token)
        .map((token) => `${{token.slice(0, 1).toUpperCase()}}${{token.slice(1).toLowerCase()}}`)
        .join(" ");
    }}

    function parseDashboardTimeToUnix(value) {{
      const numericRaw = Number(value);
      if (Number.isFinite(numericRaw) && numericRaw > 0) {{
        // Accept either Unix seconds or milliseconds.
        return Math.floor(numericRaw > 1e12 ? (numericRaw / 1000) : numericRaw);
      }}
      const text = String(value == null ? "" : value).trim();
      if (!text) return null;
      const iso = text.includes("T") ? text : text.replace(" ", "T");
      const parsed = Date.parse(iso);
      if (!Number.isFinite(parsed)) return null;
      return Math.floor(parsed / 1000);
    }}

    function latestUnixTimestamp(...values) {{
      let latest = 0;
      for (const value of values) {{
        const ts = parseDashboardTimeToUnix(value);
        if (ts && ts > latest) latest = ts;
      }}
      return latest > 0 ? latest : null;
    }}

    function nodeLastHeardUnix(node) {{
      if (!node || typeof node !== "object") return null;
      const raw = Number(node.last_heard_unix);
      if (Number.isFinite(raw) && raw > 0) {{
        return Math.floor(raw);
      }}
      return parseDashboardTimeToUnix(node.last_heard);
    }}

    function freshnessStatus(lastSeenUnix, nowUnix = Math.floor(Date.now() / 1000)) {{
      const ts = Number(lastSeenUnix);
      if (!Number.isFinite(ts) || ts <= 0) return "unknown";
      const age = Math.max(0, nowUnix - ts);
      if (age <= chatWarnWindowSeconds) return "online";
      if (age <= chatStaleWindowSeconds) return "warn";
      return "stale";
    }}

    function statusRank(status) {{
      const key = String(status || "unknown");
      if (key === "online") return 0;
      if (key === "warn") return 1;
      if (key === "stale") return 2;
      return 3;
    }}

    function normalizeFreshnessKey(status) {{
      const key = String(status || "").trim().toLowerCase();
      if (key === "online" || key === "warn" || key === "stale") return key;
      return "unknown";
    }}

    function applyFreshnessClass(el, status) {{
      if (!(el instanceof HTMLElement)) return;
      const key = normalizeFreshnessKey(status);
      if (el.dataset.freshness === key) return;
      el.dataset.freshness = key;
      el.classList.remove("status-online", "status-warn", "status-stale", "status-unknown");
      el.classList.add(`status-${{key}}`);
    }}

    function trimInlineError(value, maxLen = 120) {{
      const text = String(value == null ? "" : value).replace(/\\s+/g, " ").trim();
      if (!text) return "";
      const limit = Math.max(24, Math.floor(Number(maxLen) || 120));
      if (text.length <= limit) return text;
      return `${{text.slice(0, limit - 1)}}…`;
    }}

    function buildRadioTrafficSnapshot(traffic, localNodeId, nowUnix = Math.floor(Date.now() / 1000), windowSec = 120) {{
      const packets = Array.isArray(traffic && traffic.recent_packets) ? traffic.recent_packets : [];
      let rxRecent = 0;
      let txRecent = 0;
      let lastPacketUnix = null;
      const windowSeconds = Math.max(30, Math.floor(Number(windowSec) || 120));
      for (const packet of packets) {{
        const summary = (packet && typeof packet.summary === "object") ? packet.summary : packet;
        const packetUnix = latestUnixTimestamp(
          summary && summary.captured_at,
          summary && summary.rx_time,
          summary && summary.time,
          packet && packet.captured_at,
          packet && packet.rx_time,
          packet && packet.time,
        );
        if (Number.isFinite(packetUnix) && packetUnix > 0) {{
          if (!Number.isFinite(lastPacketUnix) || packetUnix > lastPacketUnix) {{
            lastPacketUnix = packetUnix;
          }}
        }}
        if (!Number.isFinite(packetUnix) || packetUnix <= 0) continue;
        if ((nowUnix - packetUnix) > windowSeconds) continue;

        const fromId = normalizeNodeId(
          summary && (summary.from_id ?? summary.fromId ?? summary.from)
        );
        const toId = normalizeNodeId(
          summary && (summary.to_id ?? summary.toId ?? summary.to)
        );
        const isLocalTx = isCanonicalNodeId(localNodeId) && fromId === localNodeId;
        const isDirectToLocal = isCanonicalNodeId(localNodeId) && toId === localNodeId;
        const heardFromPeer = isCanonicalNodeId(fromId) && (!isCanonicalNodeId(localNodeId) || fromId !== localNodeId);
        if (isLocalTx) {{
          txRecent += 1;
        }} else if (isDirectToLocal || heardFromPeer) {{
          rxRecent += 1;
        }}
      }}
      return {{
        rxRecent,
        txRecent,
        lastPacketUnix,
        windowSeconds,
      }};
    }}

    function buildTargetRadioStatus(state = latestState) {{
      const safeState = (state && typeof state === "object") ? state : {{}};
      const nowUnix = Math.floor(Date.now() / 1000);
      const localStateError = trimInlineError(safeState.local_state_error || "");
      const trackerError = trimInlineError(safeState.tracker_error || "");
      const pollError = trimInlineError(lastPollError || "");
      const pollErrorActive = !!pollError
        && Number.isFinite(lastPollErrorUnix)
        && lastPollErrorUnix > 0
        && (nowUnix - lastPollErrorUnix) <= Math.max(120, Math.round((refreshMs / 1000) * 6));
      const pollSuccessAge = Number.isFinite(lastPollSuccessUnix) && lastPollSuccessUnix > 0
        ? Math.max(0, nowUnix - lastPollSuccessUnix)
        : null;
      const pollLikelyLost = pollErrorActive
        && (!Number.isFinite(pollSuccessAge) || pollSuccessAge > Math.max(20, Math.round((refreshMs / 1000) * 4)));

      const localId = resolveLocalNodeId(safeState);
      const traffic = (safeState.traffic && typeof safeState.traffic === "object") ? safeState.traffic : {{}};
      const trafficSnap = buildRadioTrafficSnapshot(traffic, localId, nowUnix, 120);
      const trafficText = `RX ${{trafficSnap.rxRecent}} / TX ${{trafficSnap.txRecent}} (2m)`;
      const trafficCompactText = `RX ${{trafficSnap.rxRecent}} TX ${{trafficSnap.txRecent}}`;
      const lastActivityText = Number.isFinite(trafficSnap.lastPacketUnix)
        ? savedDetailAge(trafficSnap.lastPacketUnix, nowUnix)
        : "n/a";
      const lastActivityCompact = String(lastActivityText).replace(/\s+ago$/, "");
      const activityText = `last activity ${{lastActivityText}}`;

      const errors = [];
      if (localStateError) errors.push(`local state: ${{localStateError}}`);
      if (trackerError) errors.push(`tracker: ${{trackerError}}`);
      if (pollErrorActive) errors.push(`poll: ${{pollError}}`);
      const errorSummary = errors.join(" | ");
      const trackerReportsLost = /radio link lost/i.test(trackerError);

      if (!isCanonicalNodeId(localId)) {{
        const detail = errorSummary || "local radio id unavailable";
        return {{
          key: "lost",
          text: `Lost · ${{lastActivityCompact}} · ${{trafficCompactText}}`,
          title: `Local radio unavailable. ${{detail}}`,
        }};
      }}

      const nodes = Array.isArray(safeState.nodes) ? safeState.nodes : [];
      const selfNode = nodes.find((node) => normalizeNodeId(node && node.id) === localId) || null;
      const historyCapsById = new Map(
        Object.entries((safeState.history_caps && typeof safeState.history_caps === "object") ? safeState.history_caps : {{}})
          .map(([rawNodeId, caps]) => [normalizeNodeId(rawNodeId), caps])
          .filter(([nodeId, caps]) => isSelectableNodeId(nodeId) && caps && typeof caps === "object")
      );
      const caps = historyCapsById.get(localId) || null;
      const chatMessages = Array.isArray(traffic.recent_chat) ? traffic.recent_chat : [];
      const latestChatTouchByNode = mapLatestChatTouchInfo(chatMessages);
      const freshness = resolveNodeFreshness(selfNode, caps, null, latestChatTouchByNode.get(localId) || null);
      const freshnessKey = normalizeFreshnessKey(freshnessStatus(freshness.unix, nowUnix));
      if (pollLikelyLost) {{
        const detail = errorSummary || "state polling failed";
        return {{
          key: "lost",
          text: `Lost · ${{lastActivityCompact}} · ${{trafficCompactText}}`,
          title: `Dashboard polling is stale (${{
            Number.isFinite(pollSuccessAge) ? `${{pollSuccessAge}}s since last success` : "no successful poll yet"
          }}). ${{detail}} | ${{trafficText}} | ${{activityText}}`,
        }};
      }}
      if (trackerReportsLost) {{
        const detail = errorSummary || trackerError;
        return {{
          key: "lost",
          text: `Lost · ${{lastActivityCompact}} · ${{trafficCompactText}}`,
          title: `Meshtastic interface reported radio disconnect. ${{detail || "radio link lost"}} | ${{trafficText}} | ${{activityText}}`,
        }};
      }}

      let key = freshnessKey;
      let label = "Unknown";
      if (freshnessKey === "online") label = "Active";
      else if (freshnessKey === "warn") label = "Aging";
      else if (freshnessKey === "stale") label = "Stale";

      const text = `${{label}} · ${{lastActivityCompact}} · ${{trafficCompactText}}`;
      const lastSeenTitle = Number.isFinite(freshness.unix)
        ? `last seen ${{savedDetailAge(freshness.unix, nowUnix)}}`
        : "last seen n/a";
      return {{
        key,
        text,
        title: `${{localId}} | ${{label}} | ${{activityText}} | ${{trafficText}} | ${{lastSeenTitle}}${{errorSummary ? ` | ${{errorSummary}}` : ""}}`,
      }};
    }}

    function renderTargetRadioStatus(state = latestState) {{
      const el = document.getElementById("m-target-radio-status");
      if (!(el instanceof HTMLElement)) return;
      const status = buildTargetRadioStatus(state);
      const cleanKey = String(status && status.key ? status.key : "unknown").toLowerCase();
      const allowed = new Set(["online", "warn", "stale", "lost", "unknown"]);
      const key = allowed.has(cleanKey) ? cleanKey : "unknown";
      let toneKey = "warn";
      if (key === "online") toneKey = "online";
      else if (key === "lost") toneKey = "lost";
      el.classList.remove("status-online", "status-warn", "status-stale", "status-lost", "status-unknown");
      el.classList.add(`status-${{toneKey}}`);
      el.textContent = status && status.text ? String(status.text) : "n/a";
      el.title = status && status.title ? String(status.title) : "Radio status unavailable";
    }}

    function computeNodeFreshnessUnix(node, caps = null, chatTouch = null) {{
      const candidates = [];
      const live = nodeLastHeardUnix(node);
      if (Number.isFinite(live) && live > 0) {{
        candidates.push(Math.trunc(live));
      }}
      const capsUnix = Number(caps && caps.last_seen_unix);
      if (Number.isFinite(capsUnix) && capsUnix > 0) {{
        candidates.push(Math.trunc(capsUnix));
      }}
      const chatUnix = Number(chatTouch && chatTouch.unix);
      if (Number.isFinite(chatUnix) && chatUnix > 0) {{
        candidates.push(Math.trunc(chatUnix));
      }}
      if (candidates.length === 0) return null;
      return Math.max(...candidates);
    }}

    function tickFreshnessUI(state = latestState) {{
      if (!state || typeof state !== "object") return;
      const nodes = Array.isArray(state.nodes) ? state.nodes : [];
      const nodesById = new Map(
        nodes.map((node) => [normalizeNodeId(node && node.id), node])
      );
      const capsById = new Map(
        Object.entries((state.history_caps && typeof state.history_caps === "object") ? state.history_caps : {{}})
          .map(([rawNodeId, caps]) => [normalizeNodeId(rawNodeId), caps])
          .filter(([nodeId, caps]) => isSelectableNodeId(nodeId) && caps && typeof caps === "object")
      );
      const traffic = (state.traffic && typeof state.traffic === "object") ? state.traffic : {{}};
      const chatMessages = Array.isArray(traffic.recent_chat) ? traffic.recent_chat : [];
      const latestChatTouchByNode = mapLatestChatTouchInfo(chatMessages);

      const nowUnix = Math.floor(Date.now() / 1000);

      // Network explorer table freshness dots.
      const table = document.getElementById("nodes-table");
      if (table) {{
        for (const row of table.querySelectorAll("tbody tr[data-node-id]")) {{
          if (!(row instanceof HTMLElement)) continue;
          const nodeId = normalizeNodeId(row.dataset.nodeId || "");
          if (!isSelectableNodeId(nodeId)) continue;
          const node = nodesById.get(nodeId);
          const caps = capsById.get(nodeId);
          const chatTouch = latestChatTouchByNode.get(nodeId) || null;
          const lastSeenUnix = computeNodeFreshnessUnix(node, caps, chatTouch);
          const status = freshnessStatus(lastSeenUnix, nowUnix);
          applyFreshnessClass(row, status);
          const dot = row.querySelector(".node-status-dot");
          if (dot instanceof HTMLElement) {{
            applyFreshnessClass(dot, status);
          }}
        }}
      }}

      // Chat roster freshness + counts.
      const rosterList = document.getElementById("chat-room-list");
      let chatOnlineCount = 0;
      let chatWarnCount = 0;
      let chatStaleCount = 0;
      const rosterModel = Array.isArray(chatRosterModel) ? chatRosterModel : [];
      if (rosterModel.length > 0) {{
        for (const entry of rosterModel) {{
          const nodeId = normalizeNodeId(entry && entry.id);
          if (!isSelectableNodeId(nodeId)) continue;
          const node = nodesById.get(nodeId);
          const caps = capsById.get(nodeId);
          const chatTouch = latestChatTouchByNode.get(nodeId) || null;
          const lastSeenUnix = computeNodeFreshnessUnix(node, caps, chatTouch);
          const status = freshnessStatus(lastSeenUnix, nowUnix);
          const key = normalizeFreshnessKey(status);
          if (key === "online") chatOnlineCount += 1;
          else if (key === "warn") chatWarnCount += 1;
          else if (key === "stale") chatStaleCount += 1;
        }}
      }}

      if (rosterList) {{
        // Refresh the visible DOM list's status chips, but compute the counts from the
        // canonical roster model (so search filters don't skew the totals).
        let fallbackOnline = 0;
        let fallbackWarn = 0;
        let fallbackStale = 0;
        const useFallbackCounts = rosterModel.length === 0;
        for (const item of rosterList.querySelectorAll(".chat-member-item[data-node-id]")) {{
          if (!(item instanceof HTMLElement)) continue;
          const nodeId = normalizeNodeId(item.dataset.nodeId || "");
          if (!isSelectableNodeId(nodeId)) continue;
          const node = nodesById.get(nodeId);
          const caps = capsById.get(nodeId);
          const chatTouch = latestChatTouchByNode.get(nodeId) || null;
          const lastSeenUnix = computeNodeFreshnessUnix(node, caps, chatTouch);
          const status = freshnessStatus(lastSeenUnix, nowUnix);
          const key = normalizeFreshnessKey(status);
          if (useFallbackCounts) {{
            if (key === "online") fallbackOnline += 1;
            else if (key === "warn") fallbackWarn += 1;
            else if (key === "stale") fallbackStale += 1;
          }}

          applyFreshnessClass(item, key);
          const statusEl = item.querySelector(".chat-member-status");
          if (statusEl instanceof HTMLElement) applyFreshnessClass(statusEl, key);
          const nameEl = item.querySelector(".chat-member-name");
          if (nameEl instanceof HTMLElement) applyFreshnessClass(nameEl, key);
        }}
        if (useFallbackCounts) {{
          chatOnlineCount = fallbackOnline;
          chatWarnCount = fallbackWarn;
          chatStaleCount = fallbackStale;
        }}
      }}

      const leftSub = document.getElementById("chat-left-sub");
      if (leftSub) {{
        leftSub.textContent = `Scope: ${{channelLabel(activeChatChannel)}} • Mesh: ${{meshChannelLabelForIndex(activeMeshChannelIndex)}} • ${{chatOnlineCount}} online, ${{chatWarnCount}} aging, ${{chatStaleCount}} stale`;
      }}
      const caption = document.getElementById("chat-caption");
      if (caption) {{
        const preset = formatModemPresetLabel(
          (state.summary && state.summary.modem_preset) ? state.summary.modem_preset : "",
          "unknown"
        );
        caption.textContent = `LoRa preset: ${{preset}}. Scope: ${{channelLabel(activeChatChannel)}}. Mesh: ${{meshChannelLabelForIndex(activeMeshChannelIndex, {{ verbose: true }})}}. ${{chatOnlineCount}} online, ${{chatWarnCount}} aging, ${{chatStaleCount}} stale.`;
      }}

      // Saved nodes list freshness.
      const favList = document.getElementById("favorites-list");
      if (favList) {{
        for (const item of favList.querySelectorAll(".favorite-node-item[data-node-id]")) {{
          if (!(item instanceof HTMLElement)) continue;
          const nodeId = normalizeNodeId(item.dataset.nodeId || "");
          if (!isSelectableNodeId(nodeId)) continue;
          const node = nodesById.get(nodeId);
          const caps = capsById.get(nodeId);
          const chatTouch = latestChatTouchByNode.get(nodeId) || null;
          const lastSeenUnix = computeNodeFreshnessUnix(node, caps, chatTouch);
          const status = freshnessStatus(lastSeenUnix, nowUnix);
          applyFreshnessClass(item, status);
        }}

        const caption = document.getElementById("favorites-caption");
        if (caption) {{
          let onlineCount = 0;
          let warnCount = 0;
          let staleCount = 0;
          for (const nodeId of favoriteNodeIds) {{
            if (!isSelectableNodeId(nodeId)) continue;
            const node = nodesById.get(nodeId);
            const caps = capsById.get(nodeId);
            const chatTouch = latestChatTouchByNode.get(nodeId) || null;
            const lastSeenUnix = computeNodeFreshnessUnix(node, caps, chatTouch);
            const status = freshnessStatus(lastSeenUnix, nowUnix);
            const key = normalizeFreshnessKey(status);
            if (key === "online") onlineCount += 1;
            else if (key === "warn") warnCount += 1;
            else if (key === "stale") staleCount += 1;
          }}
          caption.textContent = `Saved subsection: ${{favoriteNodeIds.size}} total (${{onlineCount}} online, ${{warnCount}} aging, ${{staleCount}} stale)`;
        }}
      }}

      // Saved view summary freshness chip should age even if state is cached.
      // Also: when the user clears selection, we must hide/reset it (304 responses would
      // otherwise skip renderSummary() and the chip can get "stuck" stale).
      const savedChip = document.getElementById("updated-freshness");
      if (savedChip instanceof HTMLElement) {{
        if (activeLayoutView === "saved" && isSelectableNodeId(selectedNodeId)) {{
          const node = nodesById.get(selectedNodeId);
          const caps = capsById.get(selectedNodeId);
          const chatTouch = latestChatTouchByNode.get(selectedNodeId) || null;
          const lastSeenUnix = computeNodeFreshnessUnix(node, caps, chatTouch);
          const status = freshnessStatus(lastSeenUnix, nowUnix);
          const key = normalizeFreshnessKey(status);
          savedChip.textContent = key === "online"
            ? "Fresh"
            : (key === "warn" ? "Aging" : (key === "stale" ? "Stale" : "Unknown"));
          applyFreshnessClass(savedChip, key);
          savedChip.hidden = false;
        }} else {{
          savedChip.textContent = "";
          savedChip.hidden = true;
          applyFreshnessClass(savedChip, "unknown");
        }}
      }}
    }}


    function normalizeChatChannel(raw) {{
      const clean = String(raw || "").trim().toLowerCase();
      if (knownChatChannels.has(clean)) return clean;
      if (clean.startsWith("room:")) {{
        const slug = clean.slice(5).trim();
        if (roomSlugRe.test(slug)) return `room:${{slug}}`;
      }}
      return "all";
    }}

    function channelLabel(key) {{
      if (key === "direct") return "Peer-to-peer";
      if (typeof key === "string" && key.startsWith("room:")) return `#${{key.slice(5)}}`;
      return "Everyone";
    }}

    function normalizeDeliveryState(raw) {{
      const clean = String(raw || "").trim().toLowerCase();
      return knownDeliveryStates.has(clean) ? clean : "";
    }}

    function deliveryStateLabel(state) {{
      const clean = normalizeDeliveryState(state);
      if (clean === "pending") return "Pending";
      if (clean === "acked") return "Delivered";
      if (clean === "nak") return "Failed";
      if (clean === "timeout") return "Timed out";
      if (clean === "error") return "Error";
      if (clean === "sent") return "Sent";
      return "";
    }}

    function deliveryStateTitle(state, errorText = "") {{
      const clean = normalizeDeliveryState(state);
      const detail = String(errorText || "").trim();
      if (!clean) return "";
      if (detail) return `${{deliveryStateLabel(clean)}}. ${{detail}}`;
      if (clean === "pending") return "Awaiting mesh ACK";
      if (clean === "acked") return "ACK received";
      if (clean === "nak") return "NAK received";
      if (clean === "timeout") return "No ACK received before timeout";
      if (clean === "error") return "Delivery status error";
      return "Message sent";
    }}

    function isRetryableDeliveryState(state) {{
      const clean = normalizeDeliveryState(state);
      return clean === "nak" || clean === "timeout" || clean === "error";
    }}

    function reactionPopoverElement() {{
      const popover = document.getElementById("chat-reaction-popover");
      return popover instanceof HTMLElement ? popover : null;
    }}

    function clearReactionPopoverHideTimer() {{
      if (chatReactionPopoverHideTimer !== null) {{
        clearTimeout(chatReactionPopoverHideTimer);
        chatReactionPopoverHideTimer = null;
      }}
    }}

    function scheduleReactionPopoverHide(delayMs = 120) {{
      clearReactionPopoverHideTimer();
      chatReactionPopoverHideTimer = window.setTimeout(() => {{
        closeReactionPopover(true);
      }}, Math.max(0, Number(delayMs) || 0));
    }}

    function normalizeReactionName(value) {{
      const clean = String(value == null ? "" : value).replace(/\\s+/g, " ").trim();
      if (!clean) return "Unknown node";
      return clean;
    }}

    function reactionNameInitials(value) {{
      const clean = normalizeReactionName(value).replace(/[^A-Za-z0-9 ]+/g, " ").trim();
      if (!clean) return "?";
      const parts = clean.split(/\\s+/).filter(Boolean);
      if (parts.length <= 1) {{
        return parts[0].slice(0, 2).toUpperCase();
      }}
      return `${{parts[0][0] || ""}}${{parts[1][0] || ""}}`.toUpperCase() || "?";
    }}

    function parseReactionChipNames(chip) {{
      if (!(chip instanceof HTMLButtonElement)) return [];
      const raw = String(chip.dataset.reactors || "").trim();
      if (!raw) return [];
      try {{
        const parsed = JSON.parse(raw);
        if (!Array.isArray(parsed)) return [];
        return parsed
          .map((item) => normalizeReactionName(item))
          .filter((name, idx, arr) => !!name && arr.indexOf(name) === idx);
      }} catch (_err) {{
        return [];
      }}
    }}

    function positionReactionPopover(anchor, popover) {{
      if (!(anchor instanceof HTMLElement) || !(popover instanceof HTMLElement) || popover.hidden) {{
        return;
      }}
      const anchorRect = anchor.getBoundingClientRect();
      const margin = 8;
      const width = popover.offsetWidth || 240;
      const height = popover.offsetHeight || 140;
      const viewportWidth = window.innerWidth || document.documentElement.clientWidth || 1280;
      const viewportHeight = window.innerHeight || document.documentElement.clientHeight || 720;

      let left = anchorRect.left + (anchorRect.width / 2) - (width / 2);
      if (left < margin) left = margin;
      if ((left + width) > (viewportWidth - margin)) {{
        left = Math.max(margin, viewportWidth - width - margin);
      }}

      let top = anchorRect.top - height - 10;
      if (top < margin) {{
        top = anchorRect.bottom + 10;
      }}
      if ((top + height) > (viewportHeight - margin)) {{
        top = Math.max(margin, viewportHeight - height - margin);
      }}

      popover.style.left = `${{Math.round(left)}}px`;
      popover.style.top = `${{Math.round(top)}}px`;
    }}

    function openReactionPopoverForChip(chip) {{
      if (!(chip instanceof HTMLButtonElement)) return;
      const popover = reactionPopoverElement();
      if (!(popover instanceof HTMLElement)) return;

      const emoji = String(chip.dataset.emoji || "").trim() || "🙂";
      const names = parseReactionChipNames(chip);
      const rawCount = Number(chip.dataset.reactorCount || "");
      const count = Number.isFinite(rawCount) && rawCount > 0 ? Math.trunc(rawCount) : names.length;
      const shownNames = names.slice(0, reactionPopoverMaxNames);
      const listRows = shownNames.map((name) => (
        `<div class="chat-reaction-popover-row">
          <span class="chat-reaction-popover-avatar">${{escAttr(reactionNameInitials(name))}}</span>
          <span class="chat-reaction-popover-name">${{escAttr(name)}}</span>
        </div>`
      )).join("");
      const unknownCount = Math.max(0, count - shownNames.length);

      popover.innerHTML = `
        <div class="chat-reaction-popover-head">
          <span><span class="chat-reaction-popover-emoji">${{escAttr(emoji)}}</span> Reactions</span>
          <span class="chat-reaction-popover-count">${{count}}</span>
        </div>
        <div class="chat-reaction-popover-list">
          ${{listRows || `<div class="chat-reaction-popover-row"><span class="chat-reaction-popover-name">No named reactors yet</span></div>`}}
        </div>
        ${{unknownCount > 0 ? `<div class="chat-reaction-popover-more">+${{unknownCount}} more</div>` : ""}}
      `;
      popover.hidden = false;
      chatReactionPopoverAnchor = chip;
      positionReactionPopover(chip, popover);
    }}

    function closeReactionPopover(force = false) {{
      const popover = reactionPopoverElement();
      if (!(popover instanceof HTMLElement)) return;
      if (!force && popover.hidden) return;
      clearReactionPopoverHideTimer();
      popover.hidden = true;
      popover.innerHTML = "";
      chatReactionPopoverAnchor = null;
    }}

    function bindReactionPopover() {{
      const popover = reactionPopoverElement();
      if (!(popover instanceof HTMLElement) || popover.dataset.bound === "1") return;
      popover.dataset.bound = "1";

      popover.addEventListener("pointerenter", () => {{
        clearReactionPopoverHideTimer();
      }});
      popover.addEventListener("pointerleave", () => {{
        scheduleReactionPopoverHide(120);
      }});

      document.addEventListener("pointerdown", (ev) => {{
        const target = ev.target;
        if (!(target instanceof Element)) {{
          closeReactionPopover(true);
          return;
        }}
        if (target.closest(".chat-reaction-chip") || target.closest("#chat-reaction-popover")) {{
          return;
        }}
        closeReactionPopover(true);
      }});

      document.addEventListener("keydown", (ev) => {{
        if (ev.key === "Escape") {{
          closeReactionPopover(true);
        }}
      }});

      window.addEventListener("resize", () => {{
        const el = reactionPopoverElement();
        if (!(el instanceof HTMLElement) || el.hidden) return;
        if (!(chatReactionPopoverAnchor instanceof HTMLElement)) {{
          closeReactionPopover(true);
          return;
        }}
        positionReactionPopover(chatReactionPopoverAnchor, el);
      }});
      window.addEventListener("scroll", () => {{
        const el = reactionPopoverElement();
        if (!(el instanceof HTMLElement) || el.hidden) return;
        if (!(chatReactionPopoverAnchor instanceof HTMLElement)) {{
          closeReactionPopover(true);
          return;
        }}
        positionReactionPopover(chatReactionPopoverAnchor, el);
      }}, true);
    }}

    function compactInlineMessage(value, maxLen = 88) {{
      const text = String(value == null ? "" : value).replace(/\\s+/g, " ").trim();
      if (!text) return "(no text)";
      if (text.length <= maxLen) return text;
      return `${{text.slice(0, Math.max(8, maxLen - 1)).trimEnd()}}…`;
    }}

    function renderChatReplyContext() {{
      const context = document.getElementById("chat-reply-context");
      const top = document.querySelector(".chat-composer-top");
      const label = document.getElementById("chat-reply-label");
      if (!(context instanceof HTMLElement) || !(label instanceof HTMLElement)) return;
      const replyId = Number(chatReplyTargetId);
      if (!Number.isInteger(replyId) || replyId <= 0) {{
        context.hidden = true;
        if (top instanceof HTMLElement) {{
          top.classList.remove("has-reply");
        }}
        label.textContent = "";
        return;
      }}
      const fromName = String(chatReplyTargetName || "Unknown node").trim() || "Unknown node";
      const snippet = compactInlineMessage(chatReplyTargetText, 96);
      label.textContent = `Replying to ${{fromName}}: ${{snippet}}`;
      context.hidden = false;
      if (top instanceof HTMLElement) {{
        top.classList.add("has-reply");
      }}
    }}

    function clearChatReplyTarget() {{
      chatReplyTargetId = null;
      chatReplyTargetName = "";
      chatReplyTargetText = "";
      renderChatReplyContext();
    }}

    function setChatReplyTarget(replyId, fromName, text) {{
      const parsed = Number(replyId);
      if (!Number.isInteger(parsed) || parsed <= 0) {{
        setChatSendStatus("Cannot reply: target message id is missing.", true);
        return;
      }}
      chatReplyTargetId = parsed;
      chatReplyTargetName = String(fromName || "Unknown node").trim() || "Unknown node";
      chatReplyTargetText = String(text || "");
      renderChatReplyContext();
      const input = document.getElementById("chat-input");
      if (input instanceof HTMLInputElement) {{
        input.focus({{ preventScroll: true }});
      }}
      setChatSendStatus(`Reply target set: ${{chatReplyTargetName}}`, false);
    }}

    function applyChatChannel(channelKey, persist = true) {{
      const nextChannel = normalizeChatChannel(channelKey);
      const changed = activeChatChannel !== nextChannel;
      activeChatChannel = nextChannel;
      if (activeLayoutView === "chat") {{
        clearChatUnread(activeChatChannel);
      }}
      if (persist) {{
        try {{
          window.localStorage.setItem(chatChannelStorageKey, activeChatChannel);
        }} catch (_err) {{
        }}
      }}
      const usersTitle = document.getElementById("chat-users-title");
      if (usersTitle) {{
        usersTitle.textContent = activeChatChannel === "direct" ? "Users (Peer-to-peer)" : "Users (Everyone)";
      }}
      const input = document.getElementById("chat-input");
      if (input instanceof HTMLInputElement) {{
        if (activeChatChannel === "direct") {{
          input.placeholder = isSelectableNodeId(selectedNodeId)
            ? `Direct message to ${{selectedNodeId}}...`
            : "Select a user to direct message...";
        }} else {{
          input.placeholder = "Message the room (^all)...";
        }}
      }}
      if (activeChatChannel !== "direct") {{
        chatPeerAddPanelOpen = false;
      }}
      renderChatPeerAddPanel(latestState);
      if (changed) {{
        clearChatReplyTarget();
      }} else {{
        renderChatReplyContext();
      }}
      if (latestState) {{
        renderChat(latestState);
      }}
      requestImmediatePoll(0);
    }}

    function loadChatChannel() {{
      let preferred = "all";
      try {{
        preferred = normalizeChatChannel(window.localStorage.getItem(chatChannelStorageKey) || "all");
      }} catch (_err) {{
      }}
      applyChatChannel(preferred, false);
    }}

    function normalizeChatNotificationScope(value) {{
      const clean = String(value || "").trim().toLowerCase();
      return knownChatNotificationScopes.has(clean) ? clean : "all";
    }}

    function chatNotificationScopeLabel(scopeValue = chatNotificationScope) {{
      const scope = normalizeChatNotificationScope(scopeValue);
      return scope === "self" ? "Self only" : "All activity";
    }}

    function syncChatNotificationScopeControl() {{
      const select = document.getElementById("chat-change-scope");
      if (!(select instanceof HTMLSelectElement)) return;
      const scope = normalizeChatNotificationScope(chatNotificationScope);
      if (select.value !== scope) {{
        select.value = scope;
      }}
      if (scope === "self") {{
        select.title = "Notify only for direct messages to you, replies to your messages, and reactions to your messages.";
      }} else {{
        select.title = "Notify for all chat activity.";
      }}
    }}

    function applyChatNotificationScope(scopeValue, persist = true) {{
      const scope = normalizeChatNotificationScope(scopeValue);
      const changed = chatNotificationScope !== scope;
      chatNotificationScope = scope;
      syncChatNotificationScopeControl();
      if (persist) {{
        try {{
          window.localStorage.setItem(chatNotificationScopeStorageKey, scope);
        }} catch (_err) {{
        }}
      }}
      if (!changed) return;
      // Avoid stale message-unread counters when switching scope modes.
      clearChatUnread();
      renderChatChangeSummary();
      if (latestState) {{
        renderChat(latestState);
      }}
    }}

    function loadChatNotificationScope() {{
      let preferred = "all";
      try {{
        preferred = normalizeChatNotificationScope(
          window.localStorage.getItem(chatNotificationScopeStorageKey) || "all"
        );
      }} catch (_err) {{
      }}
      applyChatNotificationScope(preferred, false);
    }}

    function bindChatNotificationScopeControl() {{
      const select = document.getElementById("chat-change-scope");
      if (!(select instanceof HTMLSelectElement) || select.dataset.bound === "1") return;
      select.dataset.bound = "1";
      syncChatNotificationScopeControl();
      select.addEventListener("change", () => {{
        applyChatNotificationScope(select.value, true);
      }});
    }}

    // Meshtastic has its own notion of "channels" (0..N) which are distinct from this UI's
    // chat scopes (Everyone vs Peer-to-peer).
    //
    // We expose a lightweight selector so outgoing chat packets can be sent on a user-chosen
    // channel index. Default is channel 0.

    function normalizeMeshChannelIndex(value, options = {{}}) {{
      const allowAll = !!(options && options.allowAll);
      const text = String(value == null ? "" : value).trim().toLowerCase();
      if (allowAll && (text === "all" || text === "*")) {{
        return meshChannelAllIndex;
      }}
      const num = Number(value);
      if (!Number.isFinite(num)) return 0;
      const idx = Math.trunc(num);
      if (allowAll && idx === meshChannelAllIndex) {{
        return meshChannelAllIndex;
      }}
      if (!Number.isInteger(idx) || idx < 0) return 0;
      return idx;
    }}

    function meshChannelOptionLabel(opt) {{
      if (!opt || typeof opt !== "object") return "";
      const idx = Number(opt.index);
      if (!Number.isInteger(idx) || idx < 0) return "";
      const name = typeof opt.name === "string" ? opt.name.trim() : "";
      const role = typeof opt.role === "string" ? opt.role.trim() : "";
      if (name) return `Ch ${{idx}}: ${{name}}`;
      if (role) return `Ch ${{idx}} (${{role}})`;
      return `Ch ${{idx}}`;
    }}

    function meshChannelLabelForIndex(rawIndex, {{ verbose = false, compact = false, allowAll = true }} = {{}}) {{
      const idx = normalizeMeshChannelIndex(rawIndex, {{ allowAll }});
      if (idx === meshChannelAllIndex) {{
        return compact ? "All" : "All channels";
      }}
      const match = Array.isArray(meshChannelOptions)
        ? meshChannelOptions.find((opt) => Number(opt && opt.index) === idx)
        : null;
      const name = match && typeof match.name === "string" ? match.name.trim() : "";
      if (compact) return `Ch ${{idx}}`;
      if (verbose && name) return `Ch ${{idx}} (${{name}})`;
      return `Ch ${{idx}}`;
    }}

    function activeMeshChannelFilterIndex() {{
      return normalizeMeshChannelIndex(activeMeshChannelIndex, {{ allowAll: true }});
    }}

    function meshChannelSendContext() {{
      const activeIdx = activeMeshChannelFilterIndex();
      const sendIndex = activeIdx >= 0 ? activeIdx : 0;
      return {{
        sendIndex,
        allSelected: activeIdx === meshChannelAllIndex,
      }};
    }}

    function buildMeshChannelOptionsFromLocalState(localState) {{
      const root = (localState && typeof localState === "object") ? localState : {{}};
      const rawChannels = Array.isArray(root.channels) ? root.channels : [];
      const byIndex = new Map();

      for (let i = 0; i < rawChannels.length; i++) {{
        const ch = rawChannels[i];
        if (!ch || typeof ch !== "object") continue;

        const idxRaw = ch.index ?? ch.channel_index ?? ch.channelIndex ?? i;
        const idxNum = Math.trunc(Number(idxRaw));
        const index = Number.isInteger(idxNum) && idxNum >= 0 ? idxNum : i;

        const roleRaw = ch.role ?? ch.channel_role ?? ch.channelRole;
        const role = typeof roleRaw === "string" ? roleRaw.trim() : (roleRaw != null ? String(roleRaw) : "");
        const roleUpper = role.toUpperCase();
        const disabled = roleUpper === "DISABLED" || roleUpper === "CHANNEL_ROLE_DISABLED";

        const settings = (ch.settings && typeof ch.settings === "object") ? ch.settings
          : (ch.channel_settings && typeof ch.channel_settings === "object") ? ch.channel_settings
          : (ch.channelSettings && typeof ch.channelSettings === "object") ? ch.channelSettings
          : null;
        const nameRaw = (
          settings && typeof settings.name === "string" ? settings.name
          : settings && typeof settings.channel_name === "string" ? settings.channel_name
          : settings && typeof settings.short_name === "string" ? settings.short_name
          : typeof ch.name === "string" ? ch.name
          : typeof ch.channel_name === "string" ? ch.channel_name
          : ""
        );
        const name = typeof nameRaw === "string" ? nameRaw.trim() : "";

        const opt = {{ index, name, role, disabled }};
        if (!byIndex.has(index)) {{
          byIndex.set(index, opt);
        }} else {{
          const prev = byIndex.get(index);
          if (prev && typeof prev === "object") {{
            if (!prev.name && name) prev.name = name;
            if (!prev.role && role) prev.role = role;
            prev.disabled = prev.disabled && disabled;
          }}
        }}
      }}

      const fallbackCount = Math.max(8, rawChannels.length || 0);
      for (let i = 0; i < fallbackCount; i++) {{
        if (!byIndex.has(i)) {{
          byIndex.set(i, {{ index: i, name: "", role: "", disabled: false }});
        }}
      }}

      const options = Array.from(byIndex.values())
        .filter((opt) => opt && Number.isInteger(Number(opt.index)) && Number(opt.index) >= 0)
        .sort((a, b) => Number(a.index) - Number(b.index));

      return options.length ? options : [{{ index: 0, name: "", role: "", disabled: false }}];
    }}

    function renderMeshChannelSelect(options) {{
      const select = document.getElementById("mesh-channel-select");
      if (!(select instanceof HTMLSelectElement)) return;

      const normalized = Array.isArray(options) ? options : [];
      select.innerHTML = "";
      const allOption = document.createElement("option");
      allOption.value = String(meshChannelAllIndex);
      allOption.textContent = "All channels (view)";
      allOption.title = "Show chat from all mesh channels. Outgoing sends use Ch 0 while this is selected.";
      select.appendChild(allOption);
      for (const opt of normalized) {{
        const idx = normalizeMeshChannelIndex(opt && opt.index);
        const optionEl = document.createElement("option");
        optionEl.value = String(idx);
        optionEl.textContent = meshChannelOptionLabel({{ ...opt, index: idx }}) || `Ch ${{idx}}`;
        optionEl.disabled = !!(opt && opt.disabled);
        if (opt && opt.role) {{
          optionEl.title = String(opt.role);
        }}
        select.appendChild(optionEl);
      }}

      // Pick an enabled value.
      const desired = String(normalizeMeshChannelIndex(activeMeshChannelIndex, {{ allowAll: true }}));
      const desiredOpt = Array.from(select.options).find((o) => o.value === desired && !o.disabled);
      if (desiredOpt) {{
        select.value = desired;
        return;
      }}
      const firstEnabled = Array.from(select.options).find((o) => !o.disabled);
      const nextValue = firstEnabled ? firstEnabled.value : "0";
      select.value = nextValue;
      activeMeshChannelIndex = normalizeMeshChannelIndex(nextValue, {{ allowAll: true }});
      try {{
        window.localStorage.setItem(meshChannelIndexStorageKey, String(activeMeshChannelIndex));
      }} catch (_err) {{}}
    }}

    async function hydrateMeshChannelOptions(force = false) {{
      const nowMs = Date.now();
      const ttlMs = 60000;

      let localState = (settingsLocalStateCache && typeof settingsLocalStateCache === "object")
        ? settingsLocalStateCache
        : null;
      const stale = !settingsLocalStateFetchedAt || (nowMs - settingsLocalStateFetchedAt) > ttlMs;
      if (force || !localState || stale || !Array.isArray(localState.channels)) {{
        try {{
          const data = await fetchRawJson("/api/raw/local_state", rawDataCache.localState, ttlMs);
          const obj = (data && typeof data === "object") ? data : null;
          if (obj) {{
            settingsLocalStateCache = obj;
            settingsLocalStateFetchedAt = nowMs;
            localState = obj;
          }}
        }} catch (_err) {{}}
      }}

      const options = buildMeshChannelOptionsFromLocalState(localState);
      meshChannelOptions = options;
      renderMeshChannelSelect(options);
      return options;
    }}

    function applyMeshChannelIndex(rawIndex, persist = true) {{
      const idx = normalizeMeshChannelIndex(rawIndex, {{ allowAll: true }});
      const changed = idx !== activeMeshChannelIndex;
      activeMeshChannelIndex = idx;

      const select = document.getElementById("mesh-channel-select");
      if (select instanceof HTMLSelectElement) {{
        select.value = String(activeMeshChannelIndex);
      }}

      if (persist) {{
        try {{
          window.localStorage.setItem(meshChannelIndexStorageKey, String(activeMeshChannelIndex));
        }} catch (_err) {{}}
      }}

      if (changed && latestState && activeLayoutView === "chat") {{
        renderChat(latestState);
      }}
    }}

    function loadMeshChannelIndex() {{
      let preferred = 0;
      try {{
        preferred = normalizeMeshChannelIndex(
          window.localStorage.getItem(meshChannelIndexStorageKey) || "0",
          {{ allowAll: true }}
        );
      }} catch (_err) {{}}
      activeMeshChannelIndex = preferred;
    }}

    function bindMeshChannelControl() {{
      const select = document.getElementById("mesh-channel-select");
      if (!(select instanceof HTMLSelectElement) || select.dataset.bound === "1") return;
      select.dataset.bound = "1";

      select.addEventListener("change", () => {{
        applyMeshChannelIndex(select.value, true);
      }});

      // Seed fast fallback so the control is usable before the radio query returns.
      const fallback = buildMeshChannelOptionsFromLocalState({{ channels: [] }});
      meshChannelOptions = fallback;
      renderMeshChannelSelect(fallback);
      select.value = String(activeMeshChannelIndex);

      void hydrateMeshChannelOptions(false);
    }}


    function requestImmediatePoll(delayMs = 0) {{
      const waitMs = Math.max(0, Math.trunc(Number(delayMs) || 0));
      if (chatImmediatePollTimer !== null) {{
        clearTimeout(chatImmediatePollTimer);
        chatImmediatePollTimer = null;
      }}
      chatImmediatePollTimer = window.setTimeout(() => {{
        chatImmediatePollTimer = null;
        if (document.hidden) return;
        if (typeof pollOnce === "function") {{
          void pollOnce();
          return;
        }}
        void poll();
      }}, waitMs);
    }}

    function persistManualDirectPeers() {{
      try {{
        const ids = Array.from(manualDirectPeerIds)
          .map((entry) => normalizeNodeId(entry))
          .filter((entry) => isCanonicalNodeId(entry))
          .sort((a, b) => a.localeCompare(b));
        window.localStorage.setItem(chatDirectPeersStorageKey, JSON.stringify(ids));
      }} catch (_err) {{
      }}
    }}

    function loadManualDirectPeers() {{
      manualDirectPeerIds.clear();
      try {{
        const raw = window.localStorage.getItem(chatDirectPeersStorageKey);
        if (!raw) return;
        const parsed = JSON.parse(raw);
        if (!Array.isArray(parsed)) return;
        for (const entry of parsed) {{
          const nodeId = normalizeNodeId(entry);
          if (!isCanonicalNodeId(nodeId)) continue;
          manualDirectPeerIds.add(nodeId);
        }}
      }} catch (_err) {{
      }}
    }}

    function addManualDirectPeer(rawNodeId, options = null) {{
      const opts = (options && typeof options === "object") ? options : {{}};
      const shouldSelect = opts.select !== false;
      const nodeId = normalizeNodeId(rawNodeId);
      if (!nodeId) {{
        return {{ ok: false, error: "Enter a node ID to add." }};
      }}
      if (!isCanonicalNodeId(nodeId)) {{
        return {{ ok: false, error: "Use a node ID like !49b54790." }};
      }}
      if (isSelfNodeId(nodeId)) {{
        return {{ ok: false, error: "Cannot add your own radio to peer-to-peer list." }};
      }}
      const added = !manualDirectPeerIds.has(nodeId);
      manualDirectPeerIds.add(nodeId);
      persistManualDirectPeers();
      if (shouldSelect) {{
        selectNode(nodeId, true, false);
      }} else if (latestState) {{
        renderChat(latestState);
      }}
      return {{ ok: true, added, id: nodeId }};
    }}

    function removeManualDirectPeer(rawNodeId) {{
      const nodeId = normalizeNodeId(rawNodeId);
      if (!isCanonicalNodeId(nodeId)) return false;
      if (!manualDirectPeerIds.delete(nodeId)) return false;
      persistManualDirectPeers();
      if (selectedNodeId && normalizeNodeId(selectedNodeId) === nodeId) {{
        clearNodeSelection();
      }} else if (latestState) {{
        renderChat(latestState);
      }}
      return true;
    }}

    function detectedPeerCandidates(state = latestState) {{
      const safeState = (state && typeof state === "object") ? state : {{}};
      const nodes = Array.isArray(safeState.nodes) ? safeState.nodes : [];
      const selfId = resolveLocalNodeId(safeState);
      const unique = new Map();
      for (const node of nodes) {{
        const nodeId = normalizeNodeId(node && node.id);
        if (isCanonicalNodeId(selfId) && nodeId === selfId) continue;
        if (!isCanonicalNodeId(nodeId) || unique.has(nodeId)) continue;
        const name = preferredNodeName(node) || nodeNameCache.get(nodeId) || nodeId;
        const lastSeenUnix = nodeLastHeardUnix(node);
        unique.set(nodeId, {{ id: nodeId, name, lastSeenUnix }});
      }}
      return Array.from(unique.values()).sort((a, b) => {{
        const aSeen = Number(a.lastSeenUnix) || 0;
        const bSeen = Number(b.lastSeenUnix) || 0;
        if (aSeen !== bSeen) return bSeen - aSeen;
        const nameDiff = String(a.name || "").localeCompare(String(b.name || ""));
        if (nameDiff !== 0) return nameDiff;
        return String(a.id || "").localeCompare(String(b.id || ""));
      }});
    }}

    function renderChatPeerAddPanel(state = latestState) {{
      const toggleBtn = document.getElementById("chat-peer-add-toggle-btn");
      const panel = document.getElementById("chat-peer-add-panel");
      const detectedSelect = document.getElementById("chat-peer-detected-select");
      const detectedAddBtn = document.getElementById("chat-peer-add-detected-btn");
      const manualInput = document.getElementById("chat-peer-manual-input");
      const manualAddBtn = document.getElementById("chat-peer-add-manual-btn");
      const savedList = document.getElementById("chat-peer-saved-list");
      const directMode = activeChatChannel === "direct";
      if (toggleBtn instanceof HTMLButtonElement) {{
        toggleBtn.hidden = !directMode;
        toggleBtn.setAttribute("aria-expanded", directMode && chatPeerAddPanelOpen ? "true" : "false");
      }}
      if (panel instanceof HTMLElement) {{
        panel.hidden = !(directMode && chatPeerAddPanelOpen);
      }}

      const candidates = detectedPeerCandidates(state);
      if (detectedSelect instanceof HTMLSelectElement) {{
        const previousValue = normalizeNodeId(detectedSelect.value || "");
        const options = ['<option value="">Detected nodes...</option>'];
        for (const entry of candidates) {{
          const savedSuffix = manualDirectPeerIds.has(entry.id) ? " (saved)" : "";
          const label = `${{entry.name}} (${{entry.id}})${{savedSuffix}}`;
          options.push(`<option value="${{escAttr(entry.id)}}">${{escAttr(label)}}</option>`);
        }}
        detectedSelect.innerHTML = options.join("");
        if (previousValue && candidates.some((entry) => entry.id === previousValue)) {{
          detectedSelect.value = previousValue;
        }} else if (isCanonicalNodeId(selectedNodeId) && candidates.some((entry) => entry.id === selectedNodeId)) {{
          detectedSelect.value = normalizeNodeId(selectedNodeId);
        }} else {{
          detectedSelect.value = "";
        }}
        detectedSelect.disabled = !directMode || candidates.length === 0;
      }}
      if (detectedAddBtn instanceof HTMLButtonElement) {{
        const hasChoice = detectedSelect instanceof HTMLSelectElement
          && isCanonicalNodeId(detectedSelect.value || "");
        detectedAddBtn.disabled = !directMode || !hasChoice;
      }}
      if (manualInput instanceof HTMLInputElement) {{
        manualInput.disabled = !directMode;
      }}
      if (manualAddBtn instanceof HTMLButtonElement) {{
        manualAddBtn.disabled = !directMode;
      }}

      if (savedList instanceof HTMLElement) {{
        const safeState = (state && typeof state === "object") ? state : {{}};
        const selfId = resolveLocalNodeId(safeState);
        const nodes = Array.isArray(safeState.nodes) ? safeState.nodes : [];
        const nodesById = new Map(
          nodes.map((node) => [normalizeNodeId(node && node.id), node])
        );
        const savedPeers = Array.from(manualDirectPeerIds)
          .map((entry) => normalizeNodeId(entry))
          .filter((entry) => isCanonicalNodeId(entry))
          .filter((entry) => !(isCanonicalNodeId(selfId) && entry === selfId))
          .map((entry) => {{
            const node = nodesById.get(entry);
            const name = preferredNodeName(node) || nodeNameCache.get(entry) || entry;
            return {{ id: entry, name }};
          }})
          .sort((a, b) => String(a.name || a.id).localeCompare(String(b.name || b.id)));
        if (savedPeers.length === 0) {{
          savedList.innerHTML = '<div class="chat-peer-saved-empty">No saved peers yet.</div>';
        }} else {{
          savedList.innerHTML = savedPeers.map((entry) => (
            `<div class="chat-peer-saved-item">
              <span class="chat-peer-saved-main">
                <span class="chat-peer-saved-name">${{escAttr(entry.name)}}</span>
                <span class="chat-peer-saved-id">${{escAttr(entry.id)}}</span>
              </span>
              <button type="button" class="chat-peer-saved-remove-btn" data-node-id="${{escAttr(entry.id)}}" title="Remove ${{escAttr(entry.id)}} from peer-to-peer list" aria-label="Remove ${{escAttr(entry.id)}} from peer-to-peer list">&times;</button>
            </div>`
          )).join("");
        }}
      }}
    }}

    function bindChatPeerControls() {{
      const toggleBtn = document.getElementById("chat-peer-add-toggle-btn");
      const detectedSelect = document.getElementById("chat-peer-detected-select");
      const detectedAddBtn = document.getElementById("chat-peer-add-detected-btn");
      const manualInput = document.getElementById("chat-peer-manual-input");
      const manualAddBtn = document.getElementById("chat-peer-add-manual-btn");
      const savedList = document.getElementById("chat-peer-saved-list");

      if (toggleBtn instanceof HTMLButtonElement && toggleBtn.dataset.bound !== "1") {{
        toggleBtn.dataset.bound = "1";
        toggleBtn.addEventListener("click", () => {{
          if (activeChatChannel !== "direct") return;
          chatPeerAddPanelOpen = !chatPeerAddPanelOpen;
          renderChatPeerAddPanel(latestState);
          if (chatPeerAddPanelOpen && manualInput instanceof HTMLInputElement) {{
            manualInput.focus({{ preventScroll: true }});
          }}
        }});
      }}

      if (detectedAddBtn instanceof HTMLButtonElement && detectedAddBtn.dataset.bound !== "1") {{
        detectedAddBtn.dataset.bound = "1";
        detectedAddBtn.addEventListener("click", () => {{
          const chosenId = normalizeNodeId(
            detectedSelect instanceof HTMLSelectElement ? detectedSelect.value : ""
          );
          const result = addManualDirectPeer(chosenId, {{ select: true }});
          if (!result.ok) {{
            setChatSendStatus(result.error || "Unable to add peer.", true);
            return;
          }}
          setChatSendStatus(
            result.added
              ? `Peer ${{result.id}} added to peer-to-peer list.`
              : `Peer ${{result.id}} is already in your peer-to-peer list.`
          );
          renderChatPeerAddPanel(latestState);
        }});
      }}

      if (detectedSelect instanceof HTMLSelectElement && detectedSelect.dataset.bound !== "1") {{
        detectedSelect.dataset.bound = "1";
        detectedSelect.addEventListener("change", () => {{
          renderChatPeerAddPanel(latestState);
        }});
      }}

      const submitManualPeer = () => {{
        const raw = manualInput instanceof HTMLInputElement ? manualInput.value : "";
        const result = addManualDirectPeer(raw, {{ select: true }});
        if (!result.ok) {{
          setChatSendStatus(result.error || "Unable to add peer.", true);
          if (manualInput instanceof HTMLInputElement) {{
            manualInput.focus({{ preventScroll: true }});
          }}
          return;
        }}
        if (manualInput instanceof HTMLInputElement) {{
          manualInput.value = "";
          manualInput.focus({{ preventScroll: true }});
        }}
        setChatSendStatus(
          result.added
            ? `Peer ${{result.id}} added to peer-to-peer list.`
            : `Peer ${{result.id}} is already in your peer-to-peer list.`
        );
        renderChatPeerAddPanel(latestState);
      }};

      if (manualAddBtn instanceof HTMLButtonElement && manualAddBtn.dataset.bound !== "1") {{
        manualAddBtn.dataset.bound = "1";
        manualAddBtn.addEventListener("click", () => {{
          submitManualPeer();
        }});
      }}

      if (manualInput instanceof HTMLInputElement && manualInput.dataset.bound !== "1") {{
        manualInput.dataset.bound = "1";
        manualInput.addEventListener("keydown", (ev) => {{
          if (ev.key !== "Enter") return;
          ev.preventDefault();
          submitManualPeer();
        }});
      }}

      if (savedList instanceof HTMLElement && savedList.dataset.bound !== "1") {{
        savedList.dataset.bound = "1";
        savedList.addEventListener("click", (ev) => {{
          const target = ev.target;
          if (!(target instanceof Element)) return;
          const removeBtn = target.closest(".chat-peer-saved-remove-btn");
          if (!(removeBtn instanceof HTMLButtonElement)) return;
          ev.preventDefault();
          ev.stopPropagation();
          const nodeId = normalizeNodeId(removeBtn.dataset.nodeId || "");
          if (!isCanonicalNodeId(nodeId)) return;
          const removed = removeManualDirectPeer(nodeId);
          if (!removed) return;
          setChatSendStatus(`Peer ${{nodeId}} removed from peer-to-peer list.`);
          renderChatPeerAddPanel(latestState);
        }});
      }}

      renderChatPeerAddPanel(latestState);
    }}

    function normalizeChatEmojiGroup(raw) {{
      const clean = String(raw || "").trim().toLowerCase();
      if (!clean || clean === "all") return "all";
      return chatEmojiGroupsById.has(clean) ? clean : "all";
    }}

    function normalizeChatEmojiSearchQuery(raw) {{
      return String(raw || "").trim().toLowerCase();
    }}

    function tokenizeChatEmojiSearchQuery(rawQuery) {{
      return normalizeChatEmojiSearchQuery(rawQuery)
        .split(/[^a-z0-9+_-]+/g)
        .map((part) => part.trim())
        .filter((part) => part.length > 0);
    }}

    const reactionEmojiIgnoredCodepoints = new Set([0xFE0E, 0xFE0F]);

    function reactionEmojiCodepoint(rawEmoji) {{
      const text = String(rawEmoji == null ? "" : rawEmoji).trim();
      if (!text) return null;
      let baseCodepoint = null;
      for (const ch of text) {{
        const cp = ch.codePointAt(0);
        if (!Number.isInteger(cp)) continue;
        if (reactionEmojiIgnoredCodepoints.has(cp)) continue;
        if (baseCodepoint !== null) {{
          return null;
        }}
        baseCodepoint = cp;
      }}
      return Number.isInteger(baseCodepoint) && baseCodepoint > 0 ? baseCodepoint : null;
    }}

    function isReactionCompatibleEmoji(rawEmoji) {{
      return Number.isInteger(reactionEmojiCodepoint(rawEmoji));
    }}

    function reactionCompatibleEmojiChoices(rawChoices) {{
      const list = Array.isArray(rawChoices) ? rawChoices : [];
      const deduped = [];
      const seen = new Set();
      for (const emoji of list) {{
        const clean = String(emoji || "").trim();
        if (!clean || seen.has(clean)) continue;
        seen.add(clean);
        if (!isReactionCompatibleEmoji(clean)) continue;
        deduped.push(clean);
      }}
      return deduped;
    }}

    function chatEmojiChoicesForGroup(groupId) {{
      const key = normalizeChatEmojiGroup(groupId);
      if (key === "all") return chatEmojiAllChoices;
      const group = chatEmojiGroupsById.get(key);
      if (group && Array.isArray(group.emojis)) {{
        return group.emojis;
      }}
      return chatEmojiAllChoices;
    }}

    function chatEmojiChoicesForSearch(rawQuery) {{
      const query = normalizeChatEmojiSearchQuery(rawQuery);
      if (!query) return [];
      const cached = chatEmojiSearchCache.get(query);
      if (Array.isArray(cached)) {{
        return cached;
      }}

      const parts = tokenizeChatEmojiSearchQuery(query);
      if (!parts.length) return [];
      const matches = [];
      const seen = new Set();
      for (const emoji of chatEmojiAllChoices) {{
        if (seen.has(emoji)) continue;
        seen.add(emoji);
        const haystack = `${{emoji}} ${{String(chatEmojiSearchMetaByEmoji.get(emoji) || "")}}`;
        const allPartsMatch = parts.every((part) => haystack.includes(part));
        if (allPartsMatch || haystack.includes(query)) {{
          matches.push(emoji);
        }}
      }}
      chatEmojiSearchCache.set(query, matches);
      return matches;
    }}

    function buildChatEmojiNode(emoji, extraClass = "") {{
      const btn = document.createElement("button");
      btn.type = "button";
      btn.className = extraClass ? `chat-emoji-item ${{extraClass}}` : "chat-emoji-item";
      btn.setAttribute("data-emoji", emoji);
      btn.setAttribute("title", emoji);
      btn.textContent = emoji;
      return btn;
    }}

    function chatEmojiNodesForGroup(groupId) {{
      const key = normalizeChatEmojiGroup(groupId);
      const cached = chatEmojiNodesByGroup.get(key);
      if (Array.isArray(cached)) {{
        return cached;
      }}
      const nodes = [];
      for (const emoji of chatEmojiChoicesForGroup(key)) {{
        nodes.push(buildChatEmojiNode(emoji));
      }}
      chatEmojiNodesByGroup.set(key, nodes);
      return nodes;
    }}

    function chatEmojiUsageEntries() {{
      return Array.from(chatEmojiUsageCounts.entries())
        .filter(([emoji, count]) => chatEmojiChoiceSet.has(emoji) && Number.isFinite(count) && count > 0)
        .sort((a, b) => (b[1] - a[1]) || String(a[0]).localeCompare(String(b[0])));
    }}

    function chatEmojiTopChoices() {{
      const picked = [];
      const used = new Set();
      for (const [emoji] of chatEmojiUsageEntries()) {{
        if (used.has(emoji)) continue;
        used.add(emoji);
        picked.push(emoji);
        if (picked.length >= chatEmojiTopUsageCount) {{
          return picked;
        }}
      }}
      for (const emoji of chatEmojiPopularDefaults) {{
        if (!chatEmojiChoiceSet.has(emoji) || used.has(emoji)) continue;
        used.add(emoji);
        picked.push(emoji);
        if (picked.length >= chatEmojiTopUsageCount) {{
          break;
        }}
      }}
      return picked;
    }}

    function persistChatEmojiUsage() {{
      try {{
        const entries = chatEmojiUsageEntries().slice(0, chatEmojiUsagePersistMax);
        const payload = {{}};
        for (const [emoji, count] of entries) {{
          payload[emoji] = count;
        }}
        window.localStorage.setItem(chatEmojiUsageStorageKey, JSON.stringify(payload));
      }} catch (_err) {{
      }}
    }}

    function loadChatEmojiUsage() {{
      const next = new Map();
      try {{
        const raw = window.localStorage.getItem(chatEmojiUsageStorageKey);
        if (raw) {{
          const parsed = JSON.parse(raw);
          if (parsed && typeof parsed === "object" && !Array.isArray(parsed)) {{
            for (const [emojiRaw, countRaw] of Object.entries(parsed)) {{
              const emoji = String(emojiRaw || "").trim();
              const count = Math.floor(Number(countRaw));
              if (!emoji || !chatEmojiChoiceSet.has(emoji) || !Number.isFinite(count) || count <= 0) {{
                continue;
              }}
              next.set(emoji, count);
            }}
          }}
        }}
      }} catch (_err) {{
      }}
      chatEmojiUsageCounts = next;
    }}

    function noteChatEmojiUsage(rawEmoji) {{
      const emoji = String(rawEmoji || "").trim();
      if (!emoji || !chatEmojiChoiceSet.has(emoji)) return;
      const nextCount = (chatEmojiUsageCounts.get(emoji) || 0) + 1;
      chatEmojiUsageCounts.set(emoji, nextCount);
      persistChatEmojiUsage();
    }}

    function persistChatEmojiPickerState() {{
      try {{
        window.localStorage.setItem(
          chatEmojiPickerStateStorageKey,
          JSON.stringify({{
            group: chatEmojiPickerGroup,
          }})
        );
      }} catch (_err) {{
      }}
    }}

    function loadChatEmojiPickerState() {{
      let preferredGroup = chatEmojiDefaultGroup;
      try {{
        const raw = window.localStorage.getItem(chatEmojiPickerStateStorageKey);
        if (raw) {{
          const parsed = JSON.parse(raw);
          if (parsed && typeof parsed === "object" && !Array.isArray(parsed)) {{
            const storedGroup = String(parsed.group || "").trim();
            if (storedGroup) {{
              const normalized = normalizeChatEmojiGroup(storedGroup);
              preferredGroup = (
                normalized === "all" && storedGroup.toLowerCase() !== "all"
              ) ? chatEmojiDefaultGroup : normalized;
            }}
          }}
        }}
      }} catch (_err) {{
      }}
      chatEmojiPickerGroup = preferredGroup;
    }}

    function classifyMessageChannel(msg) {{
      if (!msg || typeof msg !== "object") return "all";
      const toId = normalizeNodeId(msg.to || msg.destination || "");
      if (!toId || toId === "^all" || toId === "all" || toId === "broadcast") {{
        return "all";
      }}
      if (typeof msg.scope === "string" && msg.scope.trim()) {{
        return normalizeChatChannel(msg.scope);
      }}
      return "direct";
    }}

    function messageMeshChannelIndex(msg) {{
      if (!msg || typeof msg !== "object") return 0;
      const raw = msg.channel_index ?? msg.channelIndex ?? msg.channel;
      const num = Number(raw);
      return Number.isInteger(num) && num >= 0 ? num : 0;
    }}

    function messageMatchesActiveMeshChannel(msg) {{
      const activeIdx = activeMeshChannelFilterIndex();
      if (activeIdx === meshChannelAllIndex) return true;
      return messageMeshChannelIndex(msg) === activeIdx;
    }}

    function setChatSendStatus(message, isError = false) {{
      const el = document.getElementById("chat-send-status");
      if (!(el instanceof HTMLElement)) return;
      el.textContent = message ? String(message) : "";
      el.classList.toggle("error", !!isError);
    }}

    function setChatSendBusy(isBusy) {{
      chatSendInFlight = !!isBusy;
      const btn = document.getElementById("chat-send-btn");
      const emojiBtn = document.getElementById("chat-emoji-btn");
      const replyClearBtn = document.getElementById("chat-reply-clear-btn");
      const input = document.getElementById("chat-input");
      if (btn instanceof HTMLButtonElement) {{
        btn.disabled = chatSendInFlight;
        btn.textContent = chatSendInFlight ? "Sending..." : "Send";
      }}
      if (emojiBtn instanceof HTMLButtonElement) {{
        emojiBtn.disabled = chatSendInFlight;
      }}
      if (replyClearBtn instanceof HTMLButtonElement) {{
        replyClearBtn.disabled = chatSendInFlight;
      }}
      if (input instanceof HTMLInputElement) {{
        input.disabled = chatSendInFlight;
      }}
      if (chatSendInFlight) {{
        closeChatEmojiPanel();
      }}
    }}

    async function sendChatPayload(body, successMessage) {{
      if (chatSendInFlight) return null;
      setChatSendBusy(true);
      setChatSendStatus("Sending...");
      try {{
        const resp = await fetch("/api/chat/send", {{
          method: "POST",
          headers: {{ "Content-Type": "application/json" }},
          body: JSON.stringify(body || {{}}),
        }});
        const payload = await resp.json().catch(() => ({{}}));
        if (!resp.ok || !payload.ok) {{
          const msg = payload && payload.error ? payload.error : `send failed (${{resp.status}})`;
          throw new Error(msg);
        }}
        setChatSendStatus(successMessage || `Sent at ${{payload.sent_at || "now"}}`);
        await poll();
        return payload;
      }} catch (err) {{
        setChatSendStatus(`Send error: ${{err.message || err}}`, true);
        return null;
      }} finally {{
        setChatSendBusy(false);
      }}
    }}

    async function sendChatMessage() {{
      const input = document.getElementById("chat-input");
      if (!(input instanceof HTMLInputElement)) return;
      const text = input.value.trim();
      if (!text) {{
        setChatSendStatus("Enter a message before sending.", true);
        return;
      }}
      let destination = "^all";
      if (activeChatChannel === "direct") {{
        if (!isSelectableNodeId(selectedNodeId)) {{
          setChatSendStatus("Select a user before sending a peer-to-peer message.", true);
          return;
        }}
        destination = selectedNodeId;
        if (isSelfNodeId(destination)) {{
          setChatSendStatus("Cannot send peer-to-peer message to your own radio.", true);
          return;
        }}
      }}
      const replyId = Number(chatReplyTargetId);
      const sendCtx = meshChannelSendContext();
      const requestBody = {{
        text,
        destination,
        channel_index: sendCtx.sendIndex,
      }};
      if (Number.isInteger(replyId) && replyId > 0) {{
        requestBody.reply_id = replyId;
      }}
      const payload = await sendChatPayload(
        requestBody,
        null
      );
      if (payload && payload.ok) {{
        input.value = "";
        const replied = Number.isInteger(replyId) && replyId > 0;
        clearChatReplyTarget();
        if (destination === "^all") {{
          const allNote = sendCtx.allSelected ? " (All channels view selected)" : "";
          setChatSendStatus(`${{replied ? "Reply sent" : "Sent"}} to Everyone on Ch ${{sendCtx.sendIndex}} at ${{payload.sent_at || "now"}}${{allNote}}`);
        }} else {{
          const awaitingAck = payload.ack_requested === true && normalizeDeliveryState(payload.delivery_state) === "pending";
          const allNote = sendCtx.allSelected ? " (All channels view selected)" : "";
          if (awaitingAck) {{
            setChatSendStatus(`${{replied ? "Reply sent direct" : "Sent direct"}} to ${{destination}} on Ch ${{sendCtx.sendIndex}} at ${{payload.sent_at || "now"}} (awaiting ACK)${{allNote}}`);
          }} else {{
            setChatSendStatus(`${{replied ? "Reply sent direct" : "Sent direct"}} to ${{destination}} on Ch ${{sendCtx.sendIndex}} at ${{payload.sent_at || "now"}}${{allNote}}`);
          }}
        }}
      }}
    }}

    async function sendChatReaction(replyId, emoji) {{
      const replyNum = Number(replyId);
      const cleanEmoji = String(emoji || "").trim();
      if (!Number.isInteger(replyNum) || replyNum <= 0) {{
        setChatSendStatus("Cannot react: target message id is missing.", true);
        return;
      }}
      if (!cleanEmoji) {{
        setChatSendStatus("Choose an emoji reaction.", true);
        return;
      }}
      if (!isReactionCompatibleEmoji(cleanEmoji)) {{
        setChatSendStatus("Choose a single-codepoint emoji for reactions.", true);
        return;
      }}
      let destination = "^all";
      const sendCtx = meshChannelSendContext();
      if (activeChatChannel === "direct" && isSelectableNodeId(selectedNodeId)) {{
        destination = selectedNodeId;
        if (isSelfNodeId(destination)) {{
          setChatSendStatus("Cannot react in peer-to-peer mode to your own radio.", true);
          return;
        }}
      }}
      const payload = await sendChatPayload(
        {{
          destination,
          channel_index: sendCtx.sendIndex,
          reply_id: replyNum,
          emoji: cleanEmoji,
        }},
        null
      );
      if (payload && payload.ok) {{
        const allNote = sendCtx.allSelected ? " (All channels view selected)" : "";
        setChatSendStatus(`Reacted ${{cleanEmoji}} on Ch ${{sendCtx.sendIndex}} at ${{payload.sent_at || "now"}}${{allNote}}`);
      }}
    }}

    async function retryChatMessage(options) {{
      const text = String((options && options.text) || "").trim();
      if (!text) {{
        setChatSendStatus("Cannot retry: message text is empty.", true);
        return;
      }}

      let destination = String((options && options.destination) || "^all").trim() || "^all";
      if (destination.toLowerCase() === "all" || destination.toLowerCase() === "broadcast") {{
        destination = "^all";
      }}
      if (!(destination === "^all" || destination.startsWith("!"))) {{
        setChatSendStatus("Cannot retry: destination is invalid.", true);
        return;
      }}

      const channelRaw = Number(options && options.channel_index);
      const channelIndex = Number.isInteger(channelRaw) && channelRaw >= 0 ? channelRaw : 0;
      const replyRaw = Number(options && options.reply_id);
      const retryOfRaw = Number(options && options.retry_of);

      const body = {{
        text,
        destination,
        channel_index: channelIndex,
      }};
      if (Number.isInteger(replyRaw) && replyRaw > 0) {{
        body.reply_id = replyRaw;
      }}
      if (Number.isInteger(retryOfRaw) && retryOfRaw > 0) {{
        body.retry_of = retryOfRaw;
      }}

      const payload = await sendChatPayload(body, null);
      if (payload && payload.ok) {{
        const destLabel = destination === "^all" ? "Everyone" : destination;
        setChatSendStatus(`Retried to ${{destLabel}} at ${{payload.sent_at || "now"}}`);
      }}
    }}

    function renderChatEmojiTopRow() {{
      const topGrid = document.getElementById("chat-emoji-top-grid");
      if (!(topGrid instanceof HTMLElement)) return;

      const sourceChoices = chatEmojiTopChoices();
      const choices = chatEmojiMode === "react"
        ? reactionCompatibleEmojiChoices(sourceChoices)
        : sourceChoices;
      const signature = `${{chatEmojiMode}}:${{choices.join("\u0000")}}`;
      if ((topGrid.dataset.signature || "") === signature) {{
        return;
      }}
      if (!choices.length) {{
        const empty = document.createElement("div");
        empty.className = "chat-emoji-top-empty";
        empty.textContent = chatEmojiMode === "react"
          ? "No compatible reaction emojis in your top list yet."
          : "Use emojis and your top 8 will appear here.";
        topGrid.replaceChildren(empty);
        topGrid.dataset.signature = signature;
        return;
      }}
      const nodes = choices.map((emoji) => buildChatEmojiNode(emoji, "chat-emoji-top-item"));
      topGrid.replaceChildren(...nodes);
      topGrid.dataset.signature = signature;
    }}

    function renderChatEmojiPickerPanel() {{
      const groupSelect = document.getElementById("chat-emoji-group-select");
      const searchInput = document.getElementById("chat-emoji-search");
      const grid = document.getElementById("chat-emoji-grid");
      const meta = document.getElementById("chat-emoji-meta");
      if (!(grid instanceof HTMLElement)) return;

      const selectedSearch = normalizeChatEmojiSearchQuery(
        (searchInput instanceof HTMLInputElement)
          ? searchInput.value
          : chatEmojiSearchQuery
      );
      chatEmojiSearchQuery = selectedSearch;
      if (searchInput instanceof HTMLInputElement && searchInput.value !== selectedSearch) {{
        searchInput.value = selectedSearch;
      }}

      const selectedGroup = normalizeChatEmojiGroup(
        (groupSelect instanceof HTMLSelectElement)
          ? groupSelect.value
          : chatEmojiPickerGroup
      );
      const previousGroup = chatEmojiPickerGroup;
      chatEmojiPickerGroup = selectedGroup;
      if (groupSelect instanceof HTMLSelectElement && groupSelect.value !== selectedGroup) {{
        groupSelect.value = selectedGroup;
      }}

      const searchActive = !!selectedSearch;
      const sourceChoices = searchActive
        ? chatEmojiChoicesForSearch(selectedSearch)
        : chatEmojiChoicesForGroup(selectedGroup);
      const choices = chatEmojiMode === "react"
        ? reactionCompatibleEmojiChoices(sourceChoices)
        : sourceChoices;
      const groupLabel = searchActive
        ? `Search all: "${{selectedSearch}}"`
        : (selectedGroup === "all"
          ? "All groups"
          : ((chatEmojiGroupsById.get(selectedGroup) || {{}}).label || "All groups"));
      if (meta instanceof HTMLElement) {{
        const countText = chatEmojiMode === "react"
          ? `${{choices.length}} / ${{sourceChoices.length}} compatible`
          : `${{choices.length}} / ${{chatEmojiTotalChoices}}`;
        meta.textContent = `${{groupLabel}} · ${{countText}}`;
        meta.title = `Unicode Emoji ${{chatEmojiDataVersion}} (${{
          chatEmojiDataDate
        }})`;
      }}
      const renderModeKey = chatEmojiMode === "react" ? "react" : "compose";
      const renderKey = searchActive
        ? `${{renderModeKey}}:search:${{selectedSearch}}`
        : `${{renderModeKey}}:group:${{selectedGroup}}`;
      if ((grid.dataset.key || "") !== renderKey) {{
        if (choices.length) {{
          const shouldUseCachedGroupNodes = !searchActive && chatEmojiMode !== "react";
          const nodes = shouldUseCachedGroupNodes
            ? chatEmojiNodesForGroup(selectedGroup)
            : choices.map((emoji) => buildChatEmojiNode(emoji));
          grid.replaceChildren(...nodes);
        }} else {{
          const empty = document.createElement("div");
          empty.className = "chat-emoji-empty";
          empty.textContent = chatEmojiMode === "react"
            ? "No compatible single-codepoint emojis matched."
            : "No emojis matched your search.";
          grid.replaceChildren(empty);
        }}
        grid.dataset.key = renderKey;
        grid.scrollTop = 0;
      }}
      if (previousGroup !== selectedGroup) {{
        persistChatEmojiPickerState();
      }}
      renderChatEmojiTopRow();
    }}

    function openChatEmojiPanel(mode = "compose", reactionTargetId = null) {{
      const panel = document.getElementById("chat-emoji-panel");
      const btn = document.getElementById("chat-emoji-btn");
      if (!(panel instanceof HTMLElement)) return;
      chatEmojiMode = mode === "react" ? "react" : "compose";
      const parsedTarget = Number(reactionTargetId);
      chatReactionTargetId = (
        chatEmojiMode === "react" && Number.isInteger(parsedTarget) && parsedTarget > 0
      ) ? parsedTarget : null;
      renderChatEmojiPickerPanel();
      panel.hidden = false;
      if (btn instanceof HTMLButtonElement) {{
        btn.setAttribute("aria-expanded", "true");
      }}
      if (chatEmojiMode === "react") {{
        setChatSendStatus("Pick a single-codepoint reaction emoji...");
      }}
    }}

    function closeChatEmojiPanel() {{
      const panel = document.getElementById("chat-emoji-panel");
      const btn = document.getElementById("chat-emoji-btn");
      chatEmojiMode = "compose";
      chatReactionTargetId = null;
      chatEmojiSearchQuery = "";
      if (panel instanceof HTMLElement) {{
        panel.hidden = true;
      }}
      const searchInput = document.getElementById("chat-emoji-search");
      if (searchInput instanceof HTMLInputElement) {{
        searchInput.value = "";
      }}
      if (btn instanceof HTMLButtonElement) {{
        btn.setAttribute("aria-expanded", "false");
      }}
    }}

    function insertEmojiAtCursor(emoji) {{
      const input = document.getElementById("chat-input");
      if (!(input instanceof HTMLInputElement)) return;
      const value = input.value || "";
      const start = Number.isFinite(input.selectionStart) ? input.selectionStart : value.length;
      const end = Number.isFinite(input.selectionEnd) ? input.selectionEnd : value.length;
      input.value = value.slice(0, start) + emoji + value.slice(end);
      const next = start + emoji.length;
      input.focus({{ preventScroll: true }});
      input.setSelectionRange(next, next);
    }}

    function bindEmojiPicker() {{
      const panel = document.getElementById("chat-emoji-panel");
      const btn = document.getElementById("chat-emoji-btn");
      if (!(panel instanceof HTMLElement) || !(btn instanceof HTMLButtonElement)) return;

      if (panel.dataset.init !== "1") {{
        const groupOptions = [
          `<option value="all">All groups (${{chatEmojiTotalChoices}})</option>`,
          ...chatEmojiGroups.map((group) => (
            `<option value="${{escAttr(group.id)}}">${{escAttr(group.label)}} (${{group.emojis.length}})</option>`
          )),
        ].join("");
        panel.innerHTML = `<div id="chat-emoji-top-grid" class="chat-emoji-top-grid" aria-label="Top used emojis"></div>
        <div class="chat-emoji-toolbar chat-emoji-search-row">
          <input
            id="chat-emoji-search"
            class="chat-emoji-filter chat-emoji-search"
            type="search"
            placeholder="Search all categories..."
            aria-label="Search emojis across all categories"
            autocomplete="off"
            spellcheck="false"
          />
        </div>
