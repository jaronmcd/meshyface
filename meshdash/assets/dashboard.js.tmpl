    async function fetchNodeHistory(nodeId, opts = null) {{
      if (!isSelectableNodeId(nodeId)) return null;
      const options = (opts && typeof opts === "object") ? opts : {{}};
      const force = options.force === true;
      const signal = options.signal || undefined;
      const cached = nodeHistoryCache.get(nodeId);
      const nowMs = Date.now();
      // Node history changes much slower than live state; avoid hammering the DB.
      const ttlMs = Math.max(refreshMs * 2, 8000);
      if (!force && cached && (nowMs - (cached.fetchedAt || 0)) < ttlMs) {{
        return cached.data;
      }}
      const url = `/api/history/node?node_id=${{encodeURIComponent(nodeId)}}&hours=${{nodeHistoryHours}}&points=${{nodeHistoryMaxPoints}}`;
      const resp = await fetch(url, {{ cache: "no-store", signal }});
      if (!resp.ok) throw new Error(`history API ${{resp.status}}`);
      const data = await resp.json();
      nodeHistoryCache.set(nodeId, {{ fetchedAt: nowMs, data }});
      return data;
    }}

    function cachedNodeHistory(nodeId) {{
      const clean = normalizeNodeId(nodeId || "");
      if (!isSelectableNodeId(clean)) return null;
      const cached = nodeHistoryCache.get(clean);
      if (!cached || !cached.data) return null;
      const dataId = normalizeNodeId(cached.data.node_id || "");
      if (dataId && dataId !== clean) return null;
      return cached.data;
    }}

    function abortNodeHistoryFetch() {{
      if (nodeHistoryFetchAbort) {{
        try {{
          nodeHistoryFetchAbort.abort();
        }} catch (_err) {{
        }}
      }}
      nodeHistoryFetchAbort = null;
      nodeHistoryFetchNodeId = "";
    }}

    function applyNodeHistoryToView(nodeHistory) {{
      const state = latestState;
      if (!state) return;
      const nodes = state.nodes || [];
      const traffic = (state.traffic || {{}});
      const edges = traffic.edges || [];

      if (activeLayoutView === "saved" || activeLayoutView === "network") {{
        renderMap(nodes, edges, nodeHistory);
      }}

      if (activeLayoutView === "network" && pendingMapHistoryFocus) {{
        const historyNodeId = normalizeNodeId((nodeHistory && nodeHistory.node_id) || "");
        const selectionId = normalizeNodeId(selectedNodeId || "");
        if (historyNodeId && selectionId && historyNodeId === selectionId) {{
          focusSelectedNodeOnMap(nodeHistory);
          pendingMapHistoryFocus = false;
        }}
      }}

      // The signal plot lives in the map-data panel, rendered by renderTraffic.
      if (activeLayoutView === "saved" || activeLayoutView === "network") {{
        renderTraffic(traffic, nodes, nodeHistory, null);
      }}

      if (activeLayoutView === "saved") {{
        renderSavedNodeDetails(state, nodeHistory);
      }}
    }}

    async function refreshSelectedNodeHistory(force = false) {{
      const nodeId = normalizeNodeId(selectedNodeId || "");
      if (!isSelectableNodeId(nodeId)) {{
        abortNodeHistoryFetch();
        return null;
      }}
      if (!(activeLayoutView === "saved" || activeLayoutView === "network")) {{
        // No need to load node history unless the map views that can use it are visible.
        abortNodeHistoryFetch();
        return null;
      }}
      if (mapDataFocus === "activity") {{
        // When showing online activity, keep node history idle.
        abortNodeHistoryFetch();
        return null;
      }}

      const nowMs = Date.now();
      const ttlMs = Math.max(refreshMs * 2, 8000);
      const cached = nodeHistoryCache.get(nodeId);
      const cachedData = cached && cached.data ? cached.data : null;
      const cacheFresh = !!cachedData && (nowMs - (cached.fetchedAt || 0)) < ttlMs;

      if (!force && cacheFresh) {{
        // Ensure the UI is actually showing the cached history (selection changes can
        // switch the UI into a loading state without re-rendering the chart).
        applyNodeHistoryToView(cachedData);
        return cachedData;
      }}

      if (!force && nodeHistoryFetchAbort && nodeHistoryFetchNodeId === nodeId) {{
        return null;
      }}

      abortNodeHistoryFetch();
      nodeHistoryFetchSeq += 1;
      const seq = nodeHistoryFetchSeq;
      nodeHistoryFetchNodeId = nodeId;
      nodeHistoryFetchAbort = new AbortController();
      const signal = nodeHistoryFetchAbort.signal;

      if (!cachedData && activeLayoutView === "saved") {{
        renderNodeHistoryLoading(nodeId);
      }}

      try {{
        const data = await fetchNodeHistory(nodeId, {{ force: true, signal }});
        if (seq !== nodeHistoryFetchSeq) return null;
        if (normalizeNodeId(selectedNodeId || "") !== nodeId) return null;
        if (!(activeLayoutView === "saved" || activeLayoutView === "network")) return null;
        if (mapDataFocus === "activity") return null;
        applyNodeHistoryToView(data);
        return data;
      }} catch (err) {{
        if (err && err.name === "AbortError") return null;
        if (seq !== nodeHistoryFetchSeq) return null;
        const msg = err instanceof Error ? err.message : String(err || "unknown error");
        const caption = document.getElementById("node-history-caption");
        if (caption && activeLayoutView === "saved") {{
          caption.textContent = `History error for ${{nodeId}}: ${{msg}}`;
        }}
        return null;
      }} finally {{
        if (seq === nodeHistoryFetchSeq) {{
          nodeHistoryFetchAbort = null;
          nodeHistoryFetchNodeId = "";
        }}
      }}
    }}

    async function fetchOnlineActivity(hoursOverride = nodeHistoryHours) {{
      const cleanHours = Math.max(1, Math.round(Number(hoursOverride) || nodeHistoryHours));
      const cacheKey = String(cleanHours);
      const cached = onlineActivityCache.get(cacheKey);
      const nowMs = Date.now();
      // Online activity is an aggregate rollup; refresh less frequently.
      if (cached && (nowMs - (cached.fetchedAt || 0)) < Math.max(refreshMs * 5, 30000)) {{
        return cached.data;
      }}
      const url = `/api/history/online?hours=${{encodeURIComponent(cleanHours)}}`;
      const resp = await fetch(url, {{ cache: "no-store" }});
      if (!resp.ok) throw new Error(`online activity API ${{resp.status}}`);
      const data = await resp.json();
      onlineActivityCache.set(cacheKey, {{ fetchedAt: nowMs, data }});
      return data;
    }}

    async function fetchSummaryMetrics(hoursOverride = nodeHistoryHours) {{
      const cleanHours = Math.max(1, Math.round(Number(hoursOverride) || nodeHistoryHours));
      const cacheKey = String(cleanHours);
      const cached = summaryMetricsCache.get(cacheKey);
      const nowMs = Date.now();
      if (cached && (nowMs - (cached.fetchedAt || 0)) < Math.max(refreshMs * 10, 60000)) {{
        return cached.data;
      }}
      const url = `/api/history/summary?hours=${{encodeURIComponent(cleanHours)}}`;
      const resp = await fetch(url, {{ cache: "no-store" }});
      if (!resp.ok) throw new Error(`summary metrics API ${{resp.status}}`);
      const data = await resp.json();
      summaryMetricsCache.set(cacheKey, {{ fetchedAt: nowMs, data }});
      return data;
    }}

    function hydrateTickerSeriesFromSummaryMetrics(historyPayload) {{
      const payload = (historyPayload && typeof historyPayload === "object") ? historyPayload : {{}};
      const points = sliceSummaryPointsAfterLiveCounterReset(payload.points);
      const byKey = new Map([
        ["nodes", []],
        ["pos_nodes", []],
        ["live_packets", []],
        ["live_packets_per_min", []],
        ["real_links", []],
      ]);
      for (const point of points) {{
        if (!point || typeof point !== "object") continue;
        const bucketUnix = Number(point.bucket_unix);
        if (!Number.isFinite(bucketUnix) || bucketUnix <= 0) continue;
        const bucketMs = Math.floor(bucketUnix) * 1000;
        const nodeCount = Number(point.node_count);
        const posCount = Number(point.nodes_with_position);
        const livePackets = Number(point.live_packet_count);
        const realLinks = Number(point.real_edge_count);
        if (Number.isFinite(nodeCount)) {{
          byKey.get("nodes").push({{ ms: bucketMs, value: nodeCount }});
        }}
        if (Number.isFinite(posCount)) {{
          byKey.get("pos_nodes").push({{ ms: bucketMs, value: posCount }});
        }}
        if (Number.isFinite(livePackets)) {{
          byKey.get("live_packets").push({{ ms: bucketMs, value: livePackets }});
        }}
        if (Number.isFinite(realLinks)) {{
          byKey.get("real_links").push({{ ms: bucketMs, value: realLinks }});
        }}
      }}

      const livePacketTotals = byKey.get("live_packets") || [];
      const livePacketRates = derivePacketsPerMinuteSeriesFromTotals(livePacketTotals);
      if (livePacketRates.length > 0) {{
        byKey.set("live_packets_per_min", livePacketRates);
      }}

      const cutoffMs = Date.now() - metricTickerWindowMs;
      for (const [metricKey, series] of byKey.entries()) {{
        if (!Array.isArray(series) || series.length === 0) continue;
        series.sort((a, b) => Number(a.ms) - Number(b.ms));
        trimMetricTickerPoints(series, cutoffMs);
        metricTickerSeries.set(metricKey, series);
      }}
    }}

    async function hydrateSummaryMetricTickers(hoursOverride = Math.max(2, Math.min(24, nodeHistoryHours))) {{
      try {{
        const data = await fetchSummaryMetrics(hoursOverride);
        hydrateTickerSeriesFromSummaryMetrics(data);
        summaryMetricsHydrated = true;
        if (latestState) {{
          renderSummary(latestState);
        }}
      }} catch (_err) {{
        summaryMetricsHydrated = false;
      }}
    }}

    async function refreshHistoryPanels(force = false) {{
      if (activeLayoutView !== "history") return;
      setMapDataMode("activity");
      const onlineKey = String(Math.max(1, Math.round(Number(nodeHistoryHours) || nodeHistoryHours)));
      const weeklyKey = String(weeklySummaryHours);
      if (force) {{
        onlineActivityCache.delete(onlineKey);
        summaryMetricsCache.delete(weeklyKey);
      }}
      const cachedOnline = onlineActivityCache.get(onlineKey);
      if (cachedOnline && cachedOnline.data) {{
        renderOnlineActivity(cachedOnline.data);
      }} else {{
        renderOnlineActivityLoading();
      }}
      const cachedWeekly = summaryMetricsCache.get(weeklyKey);
      if (cachedWeekly && cachedWeekly.data) {{
        renderWeeklySummary(cachedWeekly.data);
      }} else {{
        renderWeeklySummaryLoading();
      }}

      const [onlineResult, weeklyResult] = await Promise.allSettled([
        fetchOnlineActivity(nodeHistoryHours),
        fetchSummaryMetrics(weeklySummaryHours),
      ]);
      if (activeLayoutView !== "history") return;

      if (onlineResult.status === "fulfilled") {{
        renderOnlineActivity(onlineResult.value);
      }} else {{
        const reason = onlineResult.reason;
        const message = reason instanceof Error ? reason.message : String(reason || "unknown error");
        renderOnlineActivityError(message);
      }}

      if (weeklyResult.status === "fulfilled") {{
        renderWeeklySummary(weeklyResult.value);
      }} else {{
        const reason = weeklyResult.reason;
        const message = reason instanceof Error ? reason.message : String(reason || "unknown error");
        renderWeeklySummaryError(message);
      }}
    }}

    function renderTraffic(traffic, nodes, nodeHistory, onlineActivity) {{
      if (mapDataFocus === "activity") {{
        if (onlineActivity && !onlineActivity.error) {{
          renderOnlineActivity(onlineActivity);
        }} else if (onlineActivity && onlineActivity.error) {{
          renderOnlineActivityError(onlineActivity.error);
        }} else {{
          renderOnlineActivityLoading();
        }}
        return;
      }}

      const showNodeHistory = activeLayoutView === "saved" && isSelectableNodeId(selectedNodeId);
      if (showNodeHistory) {{
        if (nodeHistory && normalizeNodeId(nodeHistory.node_id) === selectedNodeId) {{
          renderNodeHistory(nodeHistory, nodes);
        }} else {{
          renderNodeHistoryLoading(selectedNodeId);
        }}
        return;
      }}

      setMapDataMode("live");
      const ports = (traffic.port_counts || []).slice(0, 30).map((item) => (
        `<tr><td data-sort="${{escAttr(item.portnum ?? "")}}">${{item.portnum}}</td><td data-sort="${{escAttr(item.count ?? "")}}">${{item.count}}</td></tr>`
      ));
      fillTable("ports-table", ports);

      const links = (traffic.edges || []).slice(0, 60).map((edge) => (
        `<tr>
          <td data-sort="${{escAttr(edge.from ?? "")}}">${{edge.from}}</td>
          <td data-sort="${{escAttr(edge.to ?? "")}}">${{edge.to}}</td>
          <td data-sort="${{escAttr(edge.lifetime_count ?? edge.count ?? 0)}}">${{edge.lifetime_count ?? edge.count ?? 0}}</td>
          <td data-sort="${{escAttr(edge.avg_hops ?? "")}}">${{edge.avg_hops == null ? "n/a" : edge.avg_hops}}</td>
          <td data-sort="${{escAttr(edge.confidence || (edge.is_real ? "confirmed" : "observed"))}}">${{edge.confidence || (edge.is_real ? "confirmed" : "observed")}}</td>
          <td data-sort="${{escAttr(edge.last_rx_time ?? "")}}">${{edge.last_rx_time || "n/a"}}</td>
        </tr>`
      ));
      fillTable("links-table", links);
    }}

    function renderChat(state) {{
      const chatRenderStartMs = (
        chatPerfEnabled
        && typeof window.performance !== "undefined"
        && typeof window.performance.now === "function"
      ) ? window.performance.now() : 0;
      const traffic = state.traffic || {{}};
      const s = state.summary || {{}};
      const chatScroller = getChatScroller();
      const shouldStickBottom = !!(chatScroller && (chatStickToBottom || isNearBottom(chatScroller)));
      const nodes = Array.isArray(state.nodes) ? state.nodes : [];
      const historyCapsObj = (state && state.history_caps && typeof state.history_caps === "object")
        ? state.history_caps
        : null;
      updateNodeNameCache(nodes);
      const nowUnix = Math.floor(Date.now() / 1000);
      const localNodeId = resolveLocalNodeId(state);
      const nodesById = new Map(
        nodes.map((node) => [normalizeNodeId(node.id || ""), node])
      );
      const nodeIdByNum = new Map();
      for (const node of nodes) {{
        const nodeNum = parseNodeNum(node && node.num);
        const nodeId = normalizeNodeId(node && node.id);
        if (!Number.isInteger(nodeNum) || nodeNum < 0) continue;
        if (!isCanonicalNodeId(nodeId)) continue;
        if (!nodeIdByNum.has(nodeNum)) {{
          nodeIdByNum.set(nodeNum, nodeId);
        }}
      }}
      const historyCapsById = new Map(
        Object.entries(historyCapsObj || {{}})
          .map(([rawNodeId, caps]) => [normalizeNodeId(rawNodeId), caps])
          .filter(([nodeId, caps]) => isSelectableNodeId(nodeId) && caps && typeof caps === "object")
      );
      const latestChatTouchByNode = mapLatestChatTouchInfo(traffic.recent_chat || []);
      const freshnessSnapshotCache = new Map();
      const nodeIdentityCache = new Map();
      const endpointPartsCache = new Map();

      function resolveChatNodeFreshness(nodeId) {{
        const clean = normalizeNodeId(nodeId);
        if (!clean || !isSelectableNodeId(clean)) {{
          return {{
            id: "",
            node: null,
            historyCaps: null,
            lastSeenUnix: null,
            status: "unknown",
          }};
        }}
        if (freshnessSnapshotCache.has(clean)) {{
          return freshnessSnapshotCache.get(clean);
        }}
        const node = nodesById.get(clean);
        const historyCaps = historyCapsById.get(clean);
        const chatTouch = latestChatTouchByNode.get(clean) || null;
        const lastSeenUnix = computeNodeFreshnessUnix(node, historyCaps, chatTouch);
        const snapshot = {{
          id: clean,
          node,
          historyCaps,
          lastSeenUnix,
          status: freshnessStatus(lastSeenUnix, nowUnix),
        }};
        freshnessSnapshotCache.set(clean, snapshot);
        return snapshot;
      }}

      const nodeIdentityMeta = (nodeId) => {{
        const snapshot = resolveChatNodeFreshness(nodeId);
        const clean = snapshot.id;
        if (!clean) {{
          return {{ html: "", title: "" }};
        }}
        if (nodeIdentityCache.has(clean)) {{
          return nodeIdentityCache.get(clean);
        }}
        const node = snapshot.node;
        const historyCaps = snapshot.historyCaps;
        if ((!node || typeof node !== "object") && (!historyCaps || typeof historyCaps !== "object")) {{
          return {{ html: "", title: "" }};
        }}
        const chipStateClass = snapshot.status === "online" ? "online" : "offline";

        const chips = [];
        const titleParts = [];
        const liveHasPosition = !!node
          && typeof node.lat === "number"
          && Number.isFinite(node.lat)
          && typeof node.lon === "number"
          && Number.isFinite(node.lon);
        const historyHasPosition = !!historyCaps && historyCaps.has_position === true;
        if (liveHasPosition || historyHasPosition) {{
          chips.push(`<span class="chat-name-chip gps ${{chipStateClass}}" title="GPS position available">&#x1F4CD;</span>`);
          titleParts.push(liveHasPosition ? "GPS available" : "GPS last known");
        }}

        const batteryRaw = Number(
          (node && node.battery_level != null)
            ? node.battery_level
            : (historyCaps && historyCaps.battery_level)
        );
        if (Number.isFinite(batteryRaw)) {{
          const batteryPct = Math.max(0, Math.min(100, Math.round(batteryRaw)));
          chips.push(`<span class="chat-name-chip battery ${{chipStateClass}}" title="Battery level">${{batteryPct}}%</span>`);
          titleParts.push(
            (node && node.battery_level != null)
              ? `Battery ${{batteryPct}}%`
              : `Battery last known ${{batteryPct}}%`
          );
        }}

        const hopsRaw = Number(
          (node && node.hops_away != null)
            ? node.hops_away
          : (historyCaps && historyCaps.last_hops)
        );
        if (Number.isFinite(hopsRaw) && hopsRaw >= 0) {{
          const hops = Math.trunc(hopsRaw);
          chips.push(`<span class="chat-name-chip hops ${{chipStateClass}}" title="Hops away">${{hops}}h</span>`);
          titleParts.push(
            (node && node.hops_away != null)
              ? `${{hops}} hop${{hops === 1 ? "" : "s"}} away`
              : `${{hops}} hop${{hops === 1 ? "" : "s"}} last known`
          );
        }}

        const identity = {{
          html: chips.join(""),
          title: titleParts.join(", "),
        }};
        nodeIdentityCache.set(clean, identity);
        return identity;
      }};

      const chatEndpointParts = (nodeId, _messageUnixHint = null) => {{
        const clean = normalizeNodeId(nodeId);
        if (!clean) {{
          return {{ label: "n/a", idTag: "", title: "n/a", status: "unknown", metaHtml: "", lastSeenUnix: null }};
        }}
        if (endpointPartsCache.has(clean)) {{
          return endpointPartsCache.get(clean);
        }}
        let endpoint = null;
        if (clean === "^all") {{
          endpoint = {{ label: "All", idTag: "", title: "^all", status: "unknown", metaHtml: "", lastSeenUnix: null }};
        }} else if (clean === "local") {{
          endpoint = {{ label: "Local", idTag: "", title: "local", status: "online", metaHtml: "", lastSeenUnix: nowUnix }};
        }} else {{
          const snapshot = resolveChatNodeFreshness(clean);
          const node = snapshot.node;
          const name = preferredNodeName(node) || nodeNameCache.get(clean) || "Unknown node";
          const meta = nodeIdentityMeta(clean);
          endpoint = {{
            label: name,
            idTag: clean,
            title: `${{name}} (${{clean}})${{meta.title ? ` - ${{meta.title}}` : ""}}`,
            status: snapshot.status,
            metaHtml: meta.html,
            lastSeenUnix: snapshot.lastSeenUnix,
          }};
        }}
        endpointPartsCache.set(clean, endpoint);
        return endpoint;
      }};

      const resolveMessageNodeId = (value) => {{
        const clean = normalizeNodeId(value);
        if (!clean) return "";
        if (isCanonicalNodeId(clean)) return clean;
        if (clean === "^all" || clean === "local" || clean === "Unknown" || clean === "n/a") {{
          return clean;
        }}
        const nodeNum = parseNodeNum(value);
        if (Number.isInteger(nodeNum) && nodeIdByNum.has(nodeNum)) {{
          return nodeIdByNum.get(nodeNum) || clean;
        }}
        return clean;
      }};

      const participants = new Map();
      const touchParticipant = (meta, msgTimeUnix) => {{
        if (!meta || !meta.idTag || !isSelectableNodeId(meta.idTag)) return;
        if (activeChatChannel === "direct" && isCanonicalNodeId(localNodeId) && meta.idTag === localNodeId) {{
          return;
        }}
        const messageUnix = parseDashboardTimeToUnix(msgTimeUnix);
        const existing = participants.get(meta.idTag);
        if (!existing) {{
          participants.set(meta.idTag, {{
            id: meta.idTag,
            name: meta.label || meta.idTag,
            // Keep status tied to node freshness only (not chat message recency),
            // so selection/channel rerenders cannot flip roster colors.
            status: freshnessStatus(meta.lastSeenUnix, nowUnix),
            lastSeenUnix: meta.lastSeenUnix,
            lastMessageUnix: messageUnix || null,
          }});
          return;
        }}
        if (meta.label && meta.label !== "Unknown node") {{
          existing.name = meta.label;
        }}
        existing.lastSeenUnix = latestUnixTimestamp(existing.lastSeenUnix, meta.lastSeenUnix);
        existing.status = freshnessStatus(existing.lastSeenUnix, nowUnix);
        if (messageUnix && (!existing.lastMessageUnix || messageUnix > existing.lastMessageUnix)) {{
          existing.lastMessageUnix = messageUnix;
        }}
      }};

      const touchNodeById = (nodeId, msgTimeUnix = null) => {{
        const clean = normalizeNodeId(nodeId);
        if (!isSelectableNodeId(clean)) return;
        if (activeChatChannel === "direct" && isCanonicalNodeId(localNodeId) && clean === localNodeId) {{
          return;
        }}
        const snapshot = resolveChatNodeFreshness(clean);
        const node = snapshot.node;
        const name = preferredNodeName(node) || nodeNameCache.get(clean) || clean;
        const messageUnix = parseDashboardTimeToUnix(msgTimeUnix);
        const existing = participants.get(clean);
        if (!existing) {{
          participants.set(clean, {{
            id: clean,
            name,
            status: snapshot.status,
            lastSeenUnix: snapshot.lastSeenUnix,
            lastMessageUnix: messageUnix || null,
          }});
          return;
        }}
        if (name && name !== "Unknown node") {{
          existing.name = name;
        }}
        existing.lastSeenUnix = latestUnixTimestamp(existing.lastSeenUnix, snapshot.lastSeenUnix);
        existing.status = freshnessStatus(existing.lastSeenUnix, nowUnix);
        if (messageUnix && (!existing.lastMessageUnix || messageUnix > existing.lastMessageUnix)) {{
          existing.lastMessageUnix = messageUnix;
        }}
      }};

      const parseMessageId = (value) => {{
        const num = Number(value);
        if (!Number.isFinite(num) || num <= 0) return null;
        return Math.trunc(num);
      }};

      const messageIdOf = (msg) => {{
        if (!msg || typeof msg !== "object") return null;
        return parseMessageId(msg.message_id ?? msg.messageId ?? msg.packet_id ?? msg.packetId);
      }};

      const replyIdOf = (msg) => {{
        if (!msg || typeof msg !== "object") return null;
        return parseMessageId(msg.reply_id ?? msg.replyId);
      }};

      const emojiFromCodepointValue = (value) => {{
        const codepoint = Number(value);
        if (!Number.isInteger(codepoint) || codepoint <= 0) return "";
        // Ignore plain ASCII so reply text can't be interpreted as reactions.
        if (codepoint <= 0x7F) return "";
        try {{
          const glyph = String.fromCodePoint(codepoint);
          // Filter non-printable control chars (often bad legacy payload values).
          for (const ch of glyph) {{
            const cp = ch.codePointAt(0);
            if (!Number.isInteger(cp)) continue;
            if ((cp >= 0 && cp <= 0x1f) || (cp >= 0x7f && cp <= 0x9f)) {{
              return "";
            }}
          }}
          return glyph;
        }} catch (_err) {{
          return "";
        }}
      }};

      const reactionVariationSelectors = new Set([0xFE0E, 0xFE0F]);

      const emojiFromAny = (rawValue) => {{
        if (rawValue == null) return "";
        if (typeof rawValue === "number") {{
          return emojiFromCodepointValue(rawValue);
        }}
        const raw = String(rawValue).trim();
        if (!raw) return "";

        // Decimal codepoint payloads (int or int-as-string).
        if (/^\\d+$/.test(raw)) {{
          return emojiFromCodepointValue(raw);
        }}
        // Hex codepoint payloads like "U+1F44D" or "1F44D".
        const hex = raw.toUpperCase().replace(/^U\\+/, "");
        if (/^[0-9A-F]{4,8}$/.test(hex)) {{
          return emojiFromCodepointValue(parseInt(hex, 16));
        }}

        // Already a glyph/text payload; reject control chars.
        for (const ch of raw) {{
          const cp = ch.codePointAt(0);
          if (!Number.isInteger(cp)) continue;
          if ((cp >= 0 && cp <= 0x1f) || (cp >= 0x7f && cp <= 0x9f)) {{
            return "";
          }}
        }}
        return raw;
      }};

      const canonicalReactionEmoji = (rawValue) => {{
        const glyph = emojiFromAny(rawValue);
        if (!glyph) return "";
        // Preserve keycap sequences (e.g. 3️⃣, #️⃣, *️⃣) as-is.
        const keycapMatch = glyph.match(/^([0-9#*])(?:\uFE0F)?\u20E3$/u);
        if (keycapMatch) {{
          return `${{keycapMatch[1]}}\uFE0F\u20E3`;
        }}
        for (const ch of glyph) {{
          const cp = ch.codePointAt(0);
          if (!Number.isInteger(cp)) continue;
          if (reactionVariationSelectors.has(cp)) continue;
          return emojiFromCodepointValue(cp);
        }}
        return "";
      }};

      const emojiFromTextPayload = (rawValue) => {{
        const text = String(rawValue == null ? "" : rawValue).trim();
        if (!text) return "";
        // Do not treat regular chat text as emoji fallback.
        if (text.length > 8 || /\\s/.test(text)) return "";
        if (/^[0-9A-Za-z.,;:!?'"`~_\\-]+$/.test(text)) return "";
        const glyph = canonicalReactionEmoji(text);
        if (!glyph) return "";
        // Keep fallback conservative: one emoji (optionally with variation/joiners).
        const clusters = Array.from(glyph);
        if (clusters.length > 4) return "";
        return glyph;
      }};

      const emojiOf = (msg) => {{
        if (!msg || typeof msg !== "object") return "";
        // Prefer explicit numeric codepoint when present, matching Meshtastic's
        // Data.emoji reaction field semantics.
        const fromCodepoint = canonicalReactionEmoji(msg.emoji_codepoint ?? msg.emojiCodepoint);
        if (fromCodepoint) return fromCodepoint;
        const direct = canonicalReactionEmoji(msg.emoji);
        if (direct) return direct;
        return emojiFromTextPayload(msg.text ?? msg.decoded_text ?? msg.payload_text);
      }};

      const isReactionMessage = (msg) => {{
        if (!msg || typeof msg !== "object") return false;
        if (msg.is_reaction === true) return true;
        const replyId = replyIdOf(msg);
        const emoji = emojiOf(msg);
        return !!(replyId && emoji);
      }};

      const rawMessages = Array.isArray(traffic.recent_chat) ? traffic.recent_chat : [];
      const computeMessageEndpoints = (msg) => {{
        const fromId = resolveMessageNodeId(msg && msg.from);
        const toId = resolveMessageNodeId((msg && msg.to) || (msg && msg.destination));
        return {{ fromId, toId }};
      }};
      let derived = null;
      if (chatDerivedCache
        && chatDerivedCache.rawMessagesRef === rawMessages
        && chatDerivedCache.nodesRef === nodes
        && chatDerivedCache.historyCapsRef === historyCapsObj
        && chatDerivedCache.localNodeId === localNodeId
        && chatDerivedCache.meshChannelIndex === normalizeMeshChannelIndex(activeMeshChannelIndex)) {{
        derived = chatDerivedCache;
      }}
      if (!derived) {{
        const reactionBucketsLocal = new Map();
        const baseMessagesLocal = [];
        const messageIndexLocal = new Map();
        const messageEndpointsLocal = new WeakMap();
        const channelCountsLocal = {{ all: 0, direct: 0 }};
        const channelMessagesLocal = {{ all: [], direct: [] }};
        const directMessagesByPeerLocal = new Map();

        const endpointsForBuild = (msg) => {{
          if (!msg || typeof msg !== "object") return {{ fromId: "", toId: "" }};
          const cached = messageEndpointsLocal.get(msg);
          if (cached) return cached;
          const resolved = computeMessageEndpoints(msg);
          messageEndpointsLocal.set(msg, resolved);
          return resolved;
        }};

        for (const msg of rawMessages) {{
          if (!messageMatchesActiveMeshChannel(msg)) {{
            continue;
          }}
          if (isReactionMessage(msg)) {{
            const replyId = replyIdOf(msg);
            const emoji = emojiOf(msg);
            if (!replyId || !emoji) continue;

            const key = String(replyId);
            let perMessage = reactionBucketsLocal.get(key);
            if (!(perMessage instanceof Map)) {{
              perMessage = new Map();
              reactionBucketsLocal.set(key, perMessage);
            }}

            let bucket = perMessage.get(emoji);
            if (!bucket) {{
              bucket = {{
                emoji,
                count: 0,
                reactors: new Set(),
                names: [],
                lastUnix: 0,
              }};
              perMessage.set(emoji, bucket);
            }}

            const reactorId = resolveMessageNodeId(msg.from || "");
            const reactorMeta = chatEndpointParts(reactorId);
            const reactorName = reactorMeta.label || reactorId || "Unknown node";
            const dedupeKey = reactorId || `${{reactorName}}:${{msg.rx_time || msg.captured_at || bucket.count}}`;
            if (!bucket.reactors.has(dedupeKey)) {{
              bucket.reactors.add(dedupeKey);
              bucket.count += 1;
              bucket.names.push(reactorName);
            }}
            const reactionTime = latestUnixTimestamp(msg.rx_time, msg.captured_at);
            if (reactionTime && reactionTime > bucket.lastUnix) {{
              bucket.lastUnix = reactionTime;
            }}
            continue;
          }}

          baseMessagesLocal.push(msg);
          const msgId = messageIdOf(msg);
          if (msgId) {{
            messageIndexLocal.set(String(msgId), msg);
          }}
          const endpoints = endpointsForBuild(msg);
          const key = classifyMessageChannel(msg) === "direct" ? "direct" : "all";
          channelCountsLocal[key] += 1;
          channelMessagesLocal[key].push(msg);
          if (key === "direct") {{
            const peers = [];
            if (isCanonicalNodeId(endpoints.fromId)) peers.push(endpoints.fromId);
            if (isCanonicalNodeId(endpoints.toId) && endpoints.toId !== endpoints.fromId) {{
              peers.push(endpoints.toId);
            }}
            for (const peerId of peers) {{
              let bucket = directMessagesByPeerLocal.get(peerId);
              if (!Array.isArray(bucket)) {{
                bucket = [];
                directMessagesByPeerLocal.set(peerId, bucket);
              }}
              bucket.push(msg);
            }}
          }}
        }}

        derived = {{
          rawMessagesRef: rawMessages,
          nodesRef: nodes,
          historyCapsRef: historyCapsObj,
          localNodeId,
          meshChannelIndex: normalizeMeshChannelIndex(activeMeshChannelIndex),
          reactionBuckets: reactionBucketsLocal,
          baseMessages: baseMessagesLocal,
          messageIndex: messageIndexLocal,
          messageEndpoints: messageEndpointsLocal,
          channelCounts: channelCountsLocal,
          channelMessages: channelMessagesLocal,
          directMessagesByPeer: directMessagesByPeerLocal,
        }};
        chatDerivedCache = derived;
      }}
      const reactionBuckets = derived.reactionBuckets;
      const baseMessages = derived.baseMessages;
      const messageIndex = derived.messageIndex;
      const messageEndpoints = derived.messageEndpoints;
      const channelCounts = derived.channelCounts;
      const channelMessages = derived.channelMessages;
      const directMessagesByPeer = derived.directMessagesByPeer;
      const endpointsForMessage = (msg) => {{
        if (!msg || typeof msg !== "object") return {{ fromId: "", toId: "" }};
        const cached = messageEndpoints.get(msg);
        if (cached) return cached;
        const resolved = computeMessageEndpoints(msg);
        messageEndpoints.set(msg, resolved);
        return resolved;
      }};
      const keyedMessages = rawMessages
        .map((msg) => {{
          if (!messageMatchesActiveMeshChannel(msg)) return null;
          const key = chatMessageKey(msg);
          if (!key) return null;
          const isReaction = isReactionMessage(msg);
          const endpoints = endpointsForMessage(msg);
          return {{
            key,
            focusKey: isReaction ? chatChangeFocusKeyFromMessage(msg, key) : key,
            channel: classifyMessageChannel(msg),
            sender: chatEndpointParts(endpoints.fromId).label || "Unknown node",
            preview: chatChangePreviewFromMessage(msg, isReaction),
            kind: isReaction ? "reaction" : "message",
            countsUnread: !isReaction,
            unix: latestUnixTimestamp(msg && msg.rx_time, msg && msg.captured_at),
          }};
        }})
        .filter((entry) => !!entry && !!entry.key);
      syncChatUnreadFromEntries(keyedMessages, {{ clearActiveWhenInChat: true }});

      const channelList = document.getElementById("chat-channel-list");
      if (channelList) {{
        channelList.innerHTML = [
          {{ key: "all", label: "Everyone", count: channelCounts.all }},
          {{ key: "direct", label: "Peer-to-peer", count: channelCounts.direct }},
        ].map((entry) => {{
          const unread = Math.max(0, Number(chatUnreadByChannel[entry.key] || 0));
          const unreadLabel = unread > 99 ? "99+" : String(unread);
          const unreadFrom = String(chatUnreadLatestByChannel[entry.key] || "").trim();
          const unreadFromLine = (unread > 0 && unreadFrom)
            ? `<span class="chat-channel-unread-from" title="Latest unread from ${{escAttr(unreadFrom)}}">new: ${{escAttr(unreadFrom)}}</span>`
            : "";
          return `<button type="button" class="chat-channel-item${{activeChatChannel === entry.key ? " active" : ""}}" data-channel="${{entry.key}}">
            <span class="chat-channel-main">
              <span class="chat-channel-name">${{entry.label}}</span>
              ${{unreadFromLine}}
            </span>
            <span class="chat-channel-meta-wrap">
              <span class="chat-channel-meta">${{entry.count}}</span>
              ${{unread > 0 ? `<span class="chat-channel-unread" title="${{unread}} unread">${{unreadLabel}}</span>` : ""}}
            </span>
          </button>`;
        }}).join("");
        for (const btn of channelList.querySelectorAll(".chat-channel-item")) {{
          if (!(btn instanceof HTMLButtonElement)) continue;
          btn.addEventListener("click", () => {{
            applyChatChannel(btn.dataset.channel || "all", true);
          }});
        }}
      }}

      const directSelectedId = (
        activeChatChannel === "direct" && isCanonicalNodeId(selectedNodeId)
      ) ? normalizeNodeId(selectedNodeId) : "";
      const activeChannelMessages = (
        activeChatChannel === "direct" ? channelMessages.direct : channelMessages.all
      );
      const messages = (() => {{
        if (activeChatChannel !== "direct") {{
          return activeChannelMessages;
        }}
        if (!isCanonicalNodeId(directSelectedId)) {{
          return [];
        }}
        const directMessages = directMessagesByPeer.get(directSelectedId);
        return Array.isArray(directMessages) ? directMessages : [];
      }})();
      const visibleMessages = messages.length > chatFeedMaxEntries
        ? messages.slice(-chatFeedMaxEntries)
        : messages;
      const showMeshBadge = activeMeshChannelFilterIndex() === meshChannelAllIndex;
      const activeChangeFocusKeys = chatChangeFocusKeysForChannel(activeChatChannel);
      const participantSourceMessages = (activeChatChannel === "direct")
        ? channelMessages.direct
        : messages;
      for (const msg of participantSourceMessages) {{
        const endpoints = endpointsForMessage(msg);
        const sourceNode = endpoints.fromId;
        const fallbackNode = endpoints.toId;
        const msgTimeUnix = latestUnixTimestamp(msg && msg.rx_time, msg && msg.captured_at);
        const fromMeta = chatEndpointParts(sourceNode, msgTimeUnix);
        const toMeta = chatEndpointParts(fallbackNode, msgTimeUnix);
        touchParticipant(fromMeta, msgTimeUnix);
        if (activeChatChannel === "direct") {{
          touchParticipant(toMeta, msgTimeUnix);
          touchNodeById(sourceNode, msgTimeUnix);
          touchNodeById(fallbackNode, msgTimeUnix);
        }}
      }}
      const feedItems = visibleMessages.map((msg) => {{
        const endpoints = endpointsForMessage(msg);
        const sourceNode = endpoints.fromId;
        const fallbackNode = endpoints.toId;
        const primarySelectable = isSelectableNodeId(sourceNode) ? sourceNode : "";
        const fallbackSelectable = isSelectableNodeId(fallbackNode) ? fallbackNode : "";
        const nodeId = primarySelectable || fallbackSelectable;
        const selectableClass = nodeId ? "chat-selectable" : "";
        const msgTimeUnix = latestUnixTimestamp(msg.rx_time, msg.captured_at);
        const fromMeta = chatEndpointParts(sourceNode, msgTimeUnix);
        const toMeta = chatEndpointParts(fallbackNode, msgTimeUnix);
        const timeText = msg.rx_time || msg.captured_at || "n/a";
        const textHtml = chatPlainTextToHtml(msg.text || "", true);
        const textCompact = compactInlineMessage(msg.text || "", 140);
        const hopNum = Number(msg.hops);
        const hasHop = Number.isFinite(hopNum) && hopNum >= 0;
        const meshIdx = messageMeshChannelIndex(msg);
        const meshBadge = showMeshBadge
          ? `<span class="chat-feed-mesh" title="${{escAttr(meshChannelLabelForIndex(meshIdx, {{ verbose: true, allowAll: false }}))}}">${{escAttr(meshChannelLabelForIndex(meshIdx, {{ compact: true, allowAll: false }}))}}</span>`
          : "";
        const hopStart = Number(msg.hop_start ?? msg.hopStart);
        const hopLimit = Number(msg.hop_limit ?? msg.hopLimit);
        const hopLabel = hasHop
          ? `${{Math.trunc(hopNum)}} hop${{Math.trunc(hopNum) === 1 ? "" : "s"}}`
          : "";
        const hopTitle = (
          Number.isFinite(hopStart) && Number.isFinite(hopLimit)
            ? `hopStart=${{Math.trunc(hopStart)}}, hopLimit=${{Math.trunc(hopLimit)}}`
            : "Hop count"
        );
        const messageId = messageIdOf(msg);
        const canReply = Number.isInteger(messageId) && messageId > 0;
        const replyToId = replyIdOf(msg);
        let replyPreview = "";
        if (Number.isInteger(replyToId) && replyToId > 0) {{
          const parentMsg = messageIndex.get(String(replyToId));
          if (parentMsg) {{
            const parentFromMeta = chatEndpointParts(endpointsForMessage(parentMsg).fromId);
            const parentText = compactInlineMessage(parentMsg.text || "", 110);
            replyPreview = `<div class="chat-reply-inline" title="Reply to packet #${{replyToId}}">
              <span class="chat-reply-inline-label">Replying to ${{escAttr(parentFromMeta.label || "Unknown node")}}</span>
              <span class="chat-reply-inline-text">${{escAttr(parentText)}}</span>
            </div>`;
          }} else {{
            replyPreview = `<div class="chat-reply-inline missing" title="Reply to packet #${{replyToId}}">
              <span class="chat-reply-inline-label">Replying to packet #${{replyToId}}</span>
            </div>`;
          }}
        }}
        const messageReactions = messageId ? reactionBuckets.get(String(messageId)) : null;
        const reactionChips = messageReactions
          ? Array.from(messageReactions.values())
              .sort((a, b) => (b.count - a.count) || String(a.emoji).localeCompare(String(b.emoji)))
              .map((bucket) => {{
                const reactorNames = Array.from(new Set(bucket.names)).slice(0, 40);
                const aria = `${{bucket.emoji}} reaction, ${{bucket.count}} total`;
                return `<button type="button" class="chat-reaction-chip" data-reply-id="${{escAttr(messageId)}}" data-emoji="${{escAttr(bucket.emoji)}}" data-reactor-count="${{escAttr(bucket.count)}}" data-reactors="${{escAttr(JSON.stringify(reactorNames))}}" aria-label="${{escAttr(aria)}}">
                  <span class="chat-reaction-emoji">${{escAttr(bucket.emoji)}}</span><span class="chat-reaction-count">${{bucket.count}}</span>
                </button>`;
              }})
              .join("")
          : "";
        const isLocalEcho = msg.local_echo === true || msg.localEcho === true;
        const deliveryState = normalizeDeliveryState(msg.delivery_state ?? msg.deliveryState);
        const deliveryError = String(msg.delivery_error ?? msg.deliveryError ?? "").trim();
        const deliveryLabel = isLocalEcho ? deliveryStateLabel(deliveryState) : "";
        const deliveryTitle = isLocalEcho ? deliveryStateTitle(deliveryState, deliveryError) : "";
        const deliveryChip = (isLocalEcho && deliveryLabel)
          ? `<span class="chat-delivery-pill state-${{escAttr(deliveryState)}}" title="${{escAttr(deliveryTitle)}}">${{escAttr(deliveryLabel)}}</span>`
          : "";
        const retryReplyId = Number.isInteger(replyToId) && replyToId > 0 ? replyToId : "";
        const replyButton = canReply
          ? `<button type="button" class="chat-reply-btn" data-message-id="${{escAttr(messageId)}}" title="Reply to this message">Reply</button>`
          : "";
        const hasReactions = !!reactionChips;
        const reactButton = messageId
          ? `<button type="button" class="chat-react-btn${{hasReactions ? " has-reactions" : ""}}" data-reply-id="${{escAttr(messageId)}}" title="Add reaction" aria-label="Add reaction">+</button>`
          : "";
        const hopBadge = hasHop
          ? `<span class="chat-feed-hops" title="${{escAttr(hopTitle)}}">${{escAttr(hopLabel)}}</span>`
          : "";
        const retryButton = (
          isLocalEcho
          && isRetryableDeliveryState(deliveryState)
          && String(msg.text || "").trim()
        )
          ? `<button type="button" class="chat-retry-btn" data-retry-text="${{escAttr(String(msg.text || ""))}}" data-retry-destination="${{escAttr(String(msg.to || "^all"))}}" data-retry-channel="${{escAttr(msg.channel ?? 0)}}" data-retry-reply-id="${{escAttr(retryReplyId)}}" data-retry-of="${{escAttr(messageId || "")}}" title="Retry this message">Retry</button>`
          : "";
        const reactionRowParts = [];
        if (reactButton) reactionRowParts.push(reactButton);
        if (reactionChips) reactionRowParts.push(`<span class="chat-reaction-stack">${{reactionChips}}</span>`);
        if (replyButton) reactionRowParts.push(`<span class="chat-reply-tail">${{replyButton}}</span>`);
        const reactionRow = reactionRowParts.length > 0
          ? `<div class="chat-reaction-row">${{reactionRowParts.join("")}}</div>`
          : "";
        const selectedFeedClass = (selectedNodeId && nodeId === selectedNodeId) ? " selected-node" : "";
        const messageKey = chatMessageKey(msg);
        const hasChangeMarker = !!messageKey && activeChangeFocusKeys.has(messageKey);
        const changeClass = hasChangeMarker ? " has-change-marker" : "";
        const changeBadge = hasChangeMarker
          ? '<span class="chat-feed-new-pill" title="Changed while you were away">NEW</span>'
          : "";
        return `<div data-node-id="${{escAttr(nodeId)}}" data-message-id="${{escAttr(messageId || "")}}" data-message-key="${{escAttr(messageKey || "")}}" data-reply-name="${{escAttr(fromMeta.label || "Unknown node")}}" data-reply-text="${{escAttr(textCompact)}}" class="chat-feed-item ${{selectableClass}}${{selectedFeedClass}}${{changeClass}}">
          <div class="chat-feed-meta">
            <span class="chat-endpoint" title="${{escAttr(fromMeta.title)}}">
              <span class="chat-name status-${{fromMeta.status}}">${{escAttr(fromMeta.label)}}</span>
              ${{fromMeta.idTag ? `<span class="chat-id-bg status-${{fromMeta.status}}">${{escAttr(fromMeta.idTag)}}</span>` : ""}}
            </span>
            <span class="chat-feed-arrow">&rarr;</span>
            <span class="chat-endpoint" title="${{escAttr(toMeta.title)}}">
              <span class="chat-name status-${{toMeta.status}}">${{escAttr(toMeta.label)}}</span>
              ${{toMeta.idTag ? `<span class="chat-id-bg status-${{toMeta.status}}">${{escAttr(toMeta.idTag)}}</span>` : ""}}
            </span>
            <span class="chat-feed-actions">${{changeBadge}}${{meshBadge}}${{hopBadge}}${{retryButton}}</span>
            ${{deliveryChip}}
            <span class="chat-feed-time">${{escAttr(timeText)}}</span>
          </div>
          ${{replyPreview}}
          <div class="chat-feed-text">${{textHtml || "&nbsp;"}}</div>
          ${{reactionRow}}
        </div>`;
      }});
      if (activeChatChannel === "all" && participants.size === 0) {{
        for (const msg of baseMessages) {{
          if (classifyMessageChannel(msg) !== "all") continue;
          touchNodeById(msg.from, latestUnixTimestamp(msg.rx_time, msg.captured_at));
        }}
      }}
      if (activeChatChannel === "direct") {{
        for (const peerId of manualDirectPeerIds) {{
          if (!isCanonicalNodeId(peerId)) continue;
          if (isCanonicalNodeId(localNodeId) && peerId === localNodeId) continue;
          const snapshot = resolveChatNodeFreshness(peerId);
          const node = snapshot.node;
          const name = preferredNodeName(node) || nodeNameCache.get(peerId) || peerId;
          const existing = participants.get(peerId);
          if (!existing) {{
            participants.set(peerId, {{
              id: peerId,
              name,
              status: snapshot.status,
              lastSeenUnix: snapshot.lastSeenUnix,
              lastMessageUnix: null,
              p2pPinned: true,
            }});
            continue;
          }}
          existing.p2pPinned = true;
          if (name && name !== "Unknown node") {{
            existing.name = name;
          }}
          existing.lastSeenUnix = latestUnixTimestamp(existing.lastSeenUnix, snapshot.lastSeenUnix);
          existing.status = freshnessStatus(existing.lastSeenUnix, nowUnix);
        }}
      }}
      if (activeChatChannel === "direct" && isCanonicalNodeId(selectedNodeId)) {{
        touchNodeById(selectedNodeId);
      }}
      const feed = document.getElementById("chat-feed");
      if (feed) {{
        const emptyText = (activeChatChannel === "direct" && !isCanonicalNodeId(directSelectedId))
          ? "Select a user to view peer-to-peer messages."
          : `No ${{channelLabel(activeChatChannel).toLowerCase()}} messages yet.`;
        closeReactionPopover(true);
        feed.innerHTML = feedItems.length > 0
          ? feedItems.join("")
          : `<div class="chat-feed-empty">${{emptyText}}</div>`;
      }}
      renderChatChangeSummary(nowUnix);

      const roomList = document.getElementById("chat-room-list");
      const roster = Array.from(participants.values())
        .sort((a, b) => {{
          const pinDiff = Number(!!b.p2pPinned) - Number(!!a.p2pPinned);
          if (pinDiff !== 0) return pinDiff;
          const rankDiff = statusRank(a.status) - statusRank(b.status);
          if (rankDiff !== 0) return rankDiff;
          const aTime = a.lastMessageUnix || 0;
          const bTime = b.lastMessageUnix || 0;
          if (aTime !== bTime) return bTime - aTime;
          return String(a.name || a.id).localeCompare(String(b.name || b.id));
        }})
        .slice(0, chatRosterMaxEntries);
      // Preserve the full (unfiltered) roster so tickFreshnessUI() can compute canonical
      // online/aging/stale counts even when the user is search-filtering the roster DOM.
      chatRosterModel = roster;
      const rosterQuery = normalizeSearchQuery(chatUserSearchQuery);
      const rosterFiltered = roster.filter((item) => (
        matchesIdOrNameQuery(item.id, item.name, rosterQuery)
      ));
      const onlineCount = roster.filter((item) => item.status === "online").length;
      const warnCount = roster.filter((item) => item.status === "warn").length;
      const staleCount = roster.filter((item) => item.status === "stale").length;
      if (roomList) {{
        roomList.innerHTML = rosterFiltered.length > 0
          ? rosterFiltered.map((item) => (
              (() => {{
                const meta = nodeIdentityMeta(item.id);
                const memberTitle = `${{item.name}} (${{item.id}})${{meta.title ? ` - ${{meta.title}}` : ""}}`;
                const peerBadge = item.p2pPinned
                  ? '<span class="chat-member-peer-badge" title="Saved peer-to-peer target">saved</span>'
                  : "";
                const removeBtn = (activeChatChannel === "direct" && item.p2pPinned)
                  ? `<button type="button" class="chat-peer-remove-btn" data-node-id="${{escAttr(item.id)}}" title="Remove from peer-to-peer list" aria-label="Remove ${{escAttr(item.id)}} from peer-to-peer list">&times;</button>`
                  : "";
                return `<div class="chat-member-item status-${{item.status}}${{selectedNodeId === item.id ? " selected-node" : ""}}" data-node-id="${{escAttr(item.id)}}" title="${{escAttr(memberTitle)}}">
                <span class="chat-member-status status-${{item.status}}">●</span>
                <span class="chat-member-main">
                  <span class="chat-member-name-row">
                    <span class="chat-member-name-left">
                      <span class="chat-member-name status-${{item.status}}">${{escAttr(item.name)}}</span>
                      ${{meta.html ? `<span class="chat-name-meta">${{meta.html}}</span>` : ""}}
                      ${{peerBadge}}
                    </span>
                    <span class="chat-member-actions">
                      ${{favoriteToggleButtonHtml(item.id, "chat-favorite-btn")}}
                      ${{removeBtn}}
                    </span>
                  </span>
                  <span class="chat-member-id">${{escAttr(item.id)}}</span>
                </span>
              </div>`;
              }})()
            )).join("")
          : (rosterQuery
              ? '<div class="chat-member-empty">No users match this search.</div>'
              : "");
        for (const member of roomList.querySelectorAll(".chat-member-item")) {{
          member.addEventListener("click", () => {{
            selectNode(member.dataset.nodeId || "", true);
          }});
        }}
        for (const removeBtn of roomList.querySelectorAll(".chat-peer-remove-btn")) {{
          if (!(removeBtn instanceof HTMLButtonElement)) continue;
          removeBtn.addEventListener("click", (ev) => {{
            ev.preventDefault();
            ev.stopPropagation();
            const nodeId = normalizeNodeId(removeBtn.dataset.nodeId || "");
            if (!isCanonicalNodeId(nodeId)) return;
            const removed = removeManualDirectPeer(nodeId);
            if (!removed) return;
            setChatSendStatus(`Peer ${{nodeId}} removed from peer-to-peer list.`);
            renderChatPeerAddPanel(latestState);
          }});
        }}
      }}
      const leftSub = document.getElementById("chat-left-sub");
      if (leftSub) {{
        leftSub.textContent = `Scope: ${{channelLabel(activeChatChannel)}} • Mesh: ${{meshChannelLabelForIndex(activeMeshChannelIndex)}} • ${{onlineCount}} online, ${{warnCount}} aging, ${{staleCount}} stale`;
      }}

      renderChatReplyContext();
      bindChatAutoScroll();
      bindChatFeedClicks();
      bindChatReactionControls();
      bindChatRetryControls();
      bindChatChangeSummaryControls();
      renderChatPeerAddPanel(state);
      highlightNodeSelection();
      if (pendingSelectionScroll) {{
        scrollSelectionIntoView();
      }} else if (chatScroller instanceof HTMLElement && shouldStickBottom) {{
        requestAnimationFrame(() => {{
          chatScroller.scrollTop = chatScroller.scrollHeight;
          chatStickToBottom = true;
        }});
      }}
      const chatRenderElapsedMs = (
        chatRenderStartMs > 0
        && typeof window.performance !== "undefined"
        && typeof window.performance.now === "function"
      ) ? Math.max(0, window.performance.now() - chatRenderStartMs) : 0;
      recordChatPerfSample(chatRenderElapsedMs, feedItems.length, rosterFiltered.length);

      const caption = document.getElementById("chat-caption");
      if (caption) {{
        const preset = formatModemPresetLabel(s.modem_preset, "unknown");
        const directTargetText = (() => {{
          if (activeChatChannel !== "direct") return "";
          if (!isCanonicalNodeId(directSelectedId)) return " Target: none selected.";
          const node = nodesById.get(directSelectedId);
          const targetName = preferredNodeName(node) || nodeNameCache.get(directSelectedId) || directSelectedId;
          return ` Target: ${{targetName}} (${{directSelectedId}}).`;
        }})();
        const perfSuffix = chatPerfEnabled
          ? ` Render: ${{chatPerfStats.lastMs.toFixed(1)}}ms (ema ${{chatPerfStats.emaMs.toFixed(1)}}ms, rows ${{chatPerfStats.lastFeedCount}}/${{chatPerfStats.lastRosterCount}}).`
          : "";
        caption.textContent = `LoRa preset: ${{preset}}. Scope: ${{channelLabel(activeChatChannel)}}.${{directTargetText}} Mesh: ${{meshChannelLabelForIndex(activeMeshChannelIndex, {{ verbose: true }})}}. ${{onlineCount}} online, ${{warnCount}} aging, ${{staleCount}} stale.${{perfSuffix}}`;
        if (chatPerfEnabled) {{
          caption.title = `Chat render avg ${{chatPerfStats.avgMs.toFixed(1)}}ms, max ${{chatPerfStats.maxMs.toFixed(1)}}ms, samples ${{chatPerfStats.samples}}`;
        }} else {{
          caption.removeAttribute("title");
        }}
      }}
      const chatTitle = document.getElementById("chat-title");
      if (chatTitle instanceof HTMLElement) {{
        const titlePreset = formatModemPresetLabel(s.modem_preset, "Mesh");
        chatTitle.textContent = `${{titlePreset}} Chat`;
      }}
    }}

    function renderPackets(traffic) {{
      const packets = (traffic.recent_packets || []).slice().reverse().slice(0, 120);
      const rows = packets.map((entry) => {{
        const s = entry.summary || {{}};
        const text = s.decoded_text == null ? "" : String(s.decoded_text);
        return `<tr>
          <td data-sort="${{escAttr(s.captured_at || "")}}">${{s.captured_at || "n/a"}}</td>
          <td data-sort="${{escAttr(s.from || "")}}">${{s.from || "n/a"}}</td>
          <td data-sort="${{escAttr(s.to || "")}}">${{s.to || "n/a"}}</td>
          <td data-sort="${{escAttr(s.portnum || "")}}">${{s.portnum || "n/a"}}</td>
          <td data-sort="${{escAttr(s.rx_snr ?? "")}}">${{s.rx_snr ?? "n/a"}}</td>
          <td data-sort="${{escAttr(s.rx_rssi ?? "")}}">${{s.rx_rssi ?? "n/a"}}</td>
          <td data-sort="${{escAttr(text)}}">${{text}}</td>
        </tr>`;
      }});
      fillTable("packets-table", rows);
    }}

    function setRaw(id, value) {{
      const el = document.getElementById(id);
      if (!el) return;
      const details = el.closest && el.closest("details");
      if (details && !details.open) return;
      el.textContent = JSON.stringify(value, null, 2);
    }}

    const rawDataCache = {{
      myInfo: {{ fetchedAt: 0, data: null }},
      metadata: {{ fetchedAt: 0, data: null }},
      localState: {{ fetchedAt: 0, data: null }},
      nodesFull: {{ fetchedAt: 0, data: null }},
    }};

    async function fetchRawJson(url, cacheEntry, ttlMs = 30000) {{
      const nowMs = Date.now();
      if (cacheEntry && cacheEntry.data != null && (nowMs - (cacheEntry.fetchedAt || 0)) < ttlMs) {{
        return cacheEntry.data;
      }}
      const resp = await fetch(url, {{ cache: "no-store" }});
      if (!resp.ok) throw new Error(`raw API ${{resp.status}}`);
      const data = await resp.json();
      if (cacheEntry) {{
        cacheEntry.fetchedAt = nowMs;
        cacheEntry.data = data;
      }}
      return data;
    }}

    async function loadRawMyInfo() {{
      const data = await fetchRawJson("/api/raw/my_info", rawDataCache.myInfo, 60000);
      setRaw("raw-my-info", data);
      return data;
    }}

    async function loadRawMetadata() {{
      const data = await fetchRawJson("/api/raw/metadata", rawDataCache.metadata, 60000);
      setRaw("raw-metadata", data);
      return data;
    }}

    async function loadRawLocalState() {{
      const data = await fetchRawJson("/api/raw/local_state", rawDataCache.localState, 60000);
      const obj = (data && typeof data === "object") ? data : {{}};
      setRaw("raw-local-config", obj.local_config);
      setRaw("raw-module-config", obj.module_config);
      setRaw("raw-channels", obj.channels);
      return data;
    }}

    async function loadRawNodesFull() {{
      const data = await fetchRawJson("/api/raw/nodes_full", rawDataCache.nodesFull, 60000);
      setRaw("raw-nodes-full", data);
      return data;
    }}

    function bindRawDataFetch() {{
      const pairs = [
        ["raw-my-info", loadRawMyInfo],
        ["raw-metadata", loadRawMetadata],
        ["raw-local-config", loadRawLocalState],
        ["raw-module-config", loadRawLocalState],
        ["raw-channels", loadRawLocalState],
        ["raw-nodes-full", loadRawNodesFull],
      ];
      for (const [preId, loader] of pairs) {{
        const pre = document.getElementById(preId);
        if (!pre) continue;
        const details = pre.closest && pre.closest("details");
        if (!details) continue;
        details.addEventListener("toggle", () => {{
          if (!details.open) return;
          void loader().catch((err) => {{
            const msg = err instanceof Error ? err.message : String(err || "unknown error");
            setRaw(preId, {{ error: msg }});
          }});
        }});

        if (details.open) {{
          void loader().catch(() => {{}});
        }}
      }}
    }}

    async function poll() {{
      try {{
        const stateUrlBase = "/api/state?lite=1";
        const stateUrl = forceStateReloadOnce
          ? `${{stateUrlBase}}&_=${{Date.now()}}`
          : stateUrlBase;
        forceStateReloadOnce = false;
        const headers = {{}};
        if (stateEtag && stateUrl === stateUrlBase) {{
          headers["If-None-Match"] = stateEtag;
        }}
        const resp = await fetch(stateUrl, {{ cache: "no-store", headers }});
        if (resp.status === 304) {{
          if (!latestState || typeof latestState !== "object") {{
            // Rare startup edge: conditional/cached response before we have any local snapshot.
            // Force one cache-busted retry so sidebar panels can hydrate immediately.
            if (activeLayoutView === "network") {{
              renderNodesPlaceholder("Syncing nodes...");
            }}
            stateEtag = "";
            forceStateReloadOnce = true;
            requestImmediatePoll(20);
            return;
          }}
          // Nothing changed; keep the existing state and skip expensive DOM work.
          // Still allow an on-demand node-history fetch if the user just changed selection.
          lastPollSuccessUnix = Math.floor(Date.now() / 1000);
          lastPollError = "";
          lastPollErrorUnix = 0;
          renderSelfRadioPill(latestState);
          const mapVisible304 = activeLayoutView === "saved" || activeLayoutView === "network";
          const trafficVisible304 = mapVisible304 || activeLayoutView === "history";
          const historyRelevant304 = (activeLayoutView === "saved" || activeLayoutView === "network")
            && mapDataFocus !== "activity"
            && isSelectableNodeId(selectedNodeId);
          const cachedHistory304 = historyRelevant304 ? cachedNodeHistory(selectedNodeId) : null;
          const nodes304 = Array.isArray(latestState.nodes) ? latestState.nodes : [];
          const traffic304 = (latestState.traffic && typeof latestState.traffic === "object")
            ? latestState.traffic
            : {{}};
          renderSummary(latestState);
          if (mapVisible304) {{
            renderMap(nodes304, traffic304.edges || [], cachedHistory304);
          }}
          if (activeLayoutView === "network") {{
            renderNodes(nodes304);
          }}
          if (trafficVisible304) {{
            renderTraffic(traffic304, nodes304, cachedHistory304, null);
          }}
          if (activeLayoutView === "history") {{
            renderHistoryChat(traffic304);
            void refreshHistoryPanels(false);
          }}
          if (activeLayoutView === "saved") {{
            const loadingId304 = (activeLayoutView === "saved" && historyRelevant304 && !cachedHistory304)
              ? selectedNodeId
              : null;
            renderFavorites(latestState, cachedHistory304, loadingId304);
          }}
          if ((activeLayoutView === "saved" || activeLayoutView === "network")
            && mapDataFocus !== "activity"
            && isSelectableNodeId(selectedNodeId)) {{
            const cached = nodeHistoryCache.get(selectedNodeId);
            const nowMs = Date.now();
            const ttlMs = Math.max(refreshMs * 2, 8000);
            const stale = !(cached && cached.data) || (nowMs - (cached.fetchedAt || 0)) >= ttlMs;
            if (stale) {{
              void refreshSelectedNodeHistory(false);
            }}
          }}
          tickFreshnessUI(latestState);
          return;
        }}
        if (!resp.ok) throw new Error(`API ${{resp.status}}`);
        const newEtag = resp.headers && resp.headers.get ? resp.headers.get("ETag") : null;
        if (newEtag) {{
          stateEtag = String(newEtag);
        }}
        const state = await resp.json();
        latestState = state;
        lastPollSuccessUnix = Math.floor(Date.now() / 1000);
        lastPollError = "";
        lastPollErrorUnix = 0;
        const nextLocalNodeId = resolveLocalNodeId(state);
        if (isCanonicalNodeId(nextLocalNodeId)) {{
          resolvedLocalNodeId = nextLocalNodeId;
        }}
        pruneSelfFromManualDirectPeers(state);
        renderSelfRadioPill(state);
        if (!summaryMetricsHydrated && !summaryMetricsHydrateInFlight) {{
          summaryMetricsHydrateInFlight = hydrateSummaryMetricTickers()
            .finally(() => {{
              summaryMetricsHydrateInFlight = null;
            }});
        }}

        const mapVisible = activeLayoutView === "saved" || activeLayoutView === "network";
        const trafficVisible = mapVisible || activeLayoutView === "history";
        const historyRelevant = (activeLayoutView === "saved" || activeLayoutView === "network")
          && mapDataFocus !== "activity"
          && isSelectableNodeId(selectedNodeId);
        const cachedHistory = historyRelevant ? cachedNodeHistory(selectedNodeId) : null;

        if (mapVisible && !mapBootstrapFocusDone) {{
          const bootstrap = applyMapBootstrapFocus(state.nodes || [], state);
          if (bootstrap.didFocus) {{
            mapBootstrapFocusDone = true;
            if (activeLayoutView === "network" && (bootstrap.source === "selected" || bootstrap.source === "local")) {{
              // Keep focus anchored on explicit interest targets instead of immediately re-fitting.
              fitDone = true;
            }}
            // Let the map paint at the location-of-interest before heavier render work.
            await nextAnimationFrame();
          }}
        }}

        let onlineActivity = null;
        if (activeLayoutView === "history" || (mapVisible && mapDataFocus === "activity")) {{
          try {{
            onlineActivity = await fetchOnlineActivity(nodeHistoryHours);
          }} catch (activityErr) {{
            onlineActivity = {{
              error: activityErr instanceof Error
                ? activityErr.message
                : String(activityErr || "unknown error"),
            }};
          }}
        }}
        let weeklySummary = null;
        if (activeLayoutView === "history") {{
          try {{
            weeklySummary = await fetchSummaryMetrics(weeklySummaryHours);
          }} catch (summaryErr) {{
            weeklySummary = {{
              error: summaryErr instanceof Error
                ? summaryErr.message
                : String(summaryErr || "unknown error"),
            }};
          }}
        }}
        // Summary metrics now live in the global header ticker row, so keep them
        // refreshed for every active view.
        renderSummary(state);

        if (mapVisible) {{
          renderMap(state.nodes || [], (state.traffic || {{}}).edges || [], cachedHistory);
        }}

        if (activeLayoutView === "network") {{
          renderNodes(state.nodes || []);
        }}

        if (trafficVisible) {{
          renderTraffic(state.traffic || {{}}, state.nodes || [], cachedHistory, onlineActivity);
        }}
        if (activeLayoutView === "history") {{
          renderHistoryChat(state.traffic || {{}});
          if (weeklySummary && !weeklySummary.error) {{
            renderWeeklySummary(weeklySummary);
          }} else if (weeklySummary && weeklySummary.error) {{
            renderWeeklySummaryError(weeklySummary.error);
          }} else {{
            renderWeeklySummaryLoading();
          }}
        }}

        if (activeLayoutView === "chat") {{
          renderChat(state);
        }} else {{
          syncChatUnreadFromState(state, {{ clearActiveWhenInChat: false }});
        }}

        if (activeLayoutView === "saved") {{
          const loadingId = (activeLayoutView === "saved" && historyRelevant && !cachedHistory)
            ? selectedNodeId
            : null;
          renderFavorites(state, cachedHistory, loadingId);
        }}

        if (activeLayoutView === "packets") {{
          renderPackets(state.traffic || {{}});
        }}

        if (activeLayoutView === "settings") {{
          renderSettings(state);
        }}

        if (activeLayoutView === "console") {{
          renderConsole(state.traffic || {{}});
        }}

        if (historyRelevant) {{
          const cached = nodeHistoryCache.get(selectedNodeId);
          const nowMs = Date.now();
          const ttlMs = Math.max(refreshMs * 2, 8000);
          const stale = !(cached && cached.data) || (nowMs - (cached.fetchedAt || 0)) >= ttlMs;
          if (stale) {{
            void refreshSelectedNodeHistory(false);
          }}
        }}


        tickFreshnessUI(state);
      }} catch (err) {{
        const msg = err instanceof Error ? err.message : String(err || "unknown error");
        lastPollError = msg;
        lastPollErrorUnix = Math.floor(Date.now() / 1000);
        setText("updated-at", `error: ${{msg}}`);
        renderTargetRadioStatus(latestState || {{}});
        appendConsoleLine(`error|${{Date.now()}}|${{msg}}`, `[poll error] ${{msg}}`);
      }}
    }}

    loadStoredSelection();
    loadNodeNameCache();
    requestTopbarLayoutMetricsSync();
    renderSelfRadioPill();
    loadFavoriteNodes();
    loadSplitState();
    loadNetworkNodesSplitState();
    loadSavedNodeSplitState();
    loadSavedNodeHistorySplitState();
    loadHistoryActivitySplitState();
    loadNodesTableColPcts();
