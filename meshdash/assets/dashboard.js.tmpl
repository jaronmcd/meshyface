    function chatMessageKey(msg) {{
      if (!msg || typeof msg !== "object") return "";
      const msgId = Number(msg.message_id ?? msg.messageId ?? msg.packet_id ?? msg.packetId);
      if (Number.isInteger(msgId) && msgId > 0) {{
        return `id:${{msgId}}`;
      }}
      const from = normalizeNodeId(msg.from || "");
      const to = normalizeNodeId(msg.to || "");
      const rx = String(msg.rx_time || msg.captured_at || "").trim();
      const text = String(msg.text || "");
      const channel = String(msg.channel ?? "");
      if (!from && !to && !rx && !text) {{
        return "";
      }}
      return `sig:${{from}}|${{to}}|${{rx}}|${{channel}}|${{text}}`;
    }}

    function isLikelyReactionPayloadText(rawValue) {{
      const text = String(rawValue == null ? "" : rawValue).trim();
      if (!text) return false;
      if (text.length > 8 || /\s/.test(text)) return false;
      if (/^[0-9A-Za-z.,;:!?'"`~_\-]+$/.test(text)) return false;
      return true;
    }}

    function isReactionLikeChatMessage(msg) {{
      if (!msg || typeof msg !== "object") return false;
      if (msg.is_reaction === true) return true;
      const replyId = Number(msg.reply_id ?? msg.replyId);
      if (!Number.isFinite(replyId) || replyId <= 0) return false;
      if (reactionEmojiPreviewFromMessage(msg)) return true;
      return isLikelyReactionPayloadText(msg.text ?? msg.decoded_text ?? msg.payload_text);
    }}

    function compactChatChangePreview(rawValue, maxLen = 72) {{
      const text = String(rawValue == null ? "" : rawValue).replace(/\\s+/g, " ").trim();
      if (!text) return "";
      return compactInlineMessage(text, maxLen);
    }}

    function reactionEmojiPreviewFromMessage(msg) {{
      if (!msg || typeof msg !== "object") return "";
      const cpRaw = msg.emoji_codepoint ?? msg.emojiCodepoint;
      const cp = Number(cpRaw);
      if (Number.isInteger(cp) && cp > 0x7f && cp <= 0x10ffff) {{
        try {{
          return String.fromCodePoint(cp);
        }} catch (_err) {{
        }}
      }}
      const direct = String(msg.emoji == null ? "" : msg.emoji).trim();
      if (isLikelyReactionPayloadText(direct)) return direct;
      const textPayload = String(msg.text ?? msg.decoded_text ?? msg.payload_text ?? "").trim();
      if (isLikelyReactionPayloadText(textPayload)) return textPayload;
      return "";
    }}

    function chatChangePreviewFromMessage(msg, isReaction) {{
      const textPayload = compactChatChangePreview(msg && (msg.text ?? msg.decoded_text ?? msg.payload_text), 78);
      if (!isReaction) {{
        return textPayload || "(no text)";
      }}
      const emoji = reactionEmojiPreviewFromMessage(msg);
      if (emoji) return `reacted ${{emoji}}`;
      const replyId = Number(msg && (msg.reply_id ?? msg.replyId));
      if (Number.isInteger(replyId) && replyId > 0) {{
        return `reaction on #${{replyId}}`;
      }}
      return textPayload || "reaction update";
    }}

    function chatChangeFocusKeyFromMessage(msg, fallbackKey = "") {{
      const cleanFallback = String(fallbackKey || "").trim();
      const replyId = Number(msg && (msg.reply_id ?? msg.replyId));
      if (Number.isInteger(replyId) && replyId > 0) {{
        return `id:${{replyId}}`;
      }}
      return cleanFallback;
    }}

    function trackChatChangeNotice(entry) {{
      if (!entry || typeof entry !== "object") return;
      const channel = normalizeChatChannel(entry.channel);
      const key = String(entry.key || "").trim();
      if (!key) return;
      const keySet = chatChangeNoticeKeysByChannel[channel];
      const list = chatChangeNoticesByChannel[channel];
      const ackSet = chatChangeAcknowledgedKeysByChannel[channel];
      if (!(keySet instanceof Set) || !Array.isArray(list)) return;
      if (keySet.has(key)) return;
      const sender = String(entry.sender || "Unknown node").replace(/\\s+/g, " ").trim() || "Unknown node";
      const previewRaw = compactChatChangePreview(entry.preview, 96);
      const kind = entry.kind === "reaction" ? "reaction" : "message";
      const preview = previewRaw || (kind === "reaction" ? "reaction update" : "(no text)");
      const focusKey = String(entry.focusKey || key).trim() || key;
      const unixRaw = Number(entry.unix);
      const unix = Number.isFinite(unixRaw) && unixRaw > 0 ? Math.trunc(unixRaw) : null;
      const selfRelevant = entry.selfRelevant === true;
      list.push({{
        key,
        focusKey,
        sender,
        preview,
        kind,
        selfRelevant,
        unix,
      }});
      keySet.add(key);
      while (list.length > chatChangeNoticeMaxEntries) {{
        const dropped = list.shift();
        if (dropped && dropped.key) {{
          keySet.delete(String(dropped.key));
          if (ackSet instanceof Set) {{
            ackSet.delete(String(dropped.key));
          }}
        }}
      }}
      // Title badge should include missed reaction updates too.
      syncDocumentUnreadTitle(chatUnreadCount);
    }}

    function chatChangeAcknowledgedKeySetForChannel(channelKey) {{
      const key = normalizeChatChannel(channelKey);
      const set = chatChangeAcknowledgedKeysByChannel[key];
      return set instanceof Set ? set : null;
    }}

    function markChatChangeAlertsAcknowledged(channelKey = null) {{
      const markOne = (key) => {{
        const ackSet = chatChangeAcknowledgedKeySetForChannel(key);
        if (!(ackSet instanceof Set)) return;
        for (const notice of chatChangeNoticesForChannel(key)) {{
          const noticeKey = String(notice && notice.key ? notice.key : "").trim();
          if (!noticeKey) continue;
          ackSet.add(noticeKey);
        }}
      }};
      if (channelKey == null) {{
        markOne("all");
        markOne("direct");
      }} else {{
        markOne(channelKey);
      }}
      syncDocumentUnreadTitle(chatUnreadCount);
    }}

    function chatChangeUnacknowledgedCountForChannel(channelKey) {{
      const notices = chatChangeNoticesForChannel(channelKey);
      if (!notices.length) return 0;
      const ackSet = chatChangeAcknowledgedKeySetForChannel(channelKey);
      if (!(ackSet instanceof Set)) return notices.length;
      let count = 0;
      for (const notice of notices) {{
        const noticeKey = String(notice && notice.key ? notice.key : "").trim();
        if (!noticeKey) continue;
        if (!ackSet.has(noticeKey)) {{
          count += 1;
        }}
      }}
      return count;
    }}

    function noticeMatchesNotificationScope(notice) {{
      const scope = normalizeChatNotificationScope(chatNotificationScope);
      if (scope === "all") return true;
      return !!(notice && notice.selfRelevant === true);
    }}

    function clearChatChangeNotices(channelKey = null) {{
      const clearOne = (key) => {{
        const normalized = normalizeChatChannel(key);
        const list = chatChangeNoticesByChannel[normalized];
        const keySet = chatChangeNoticeKeysByChannel[normalized];
        const ackSet = chatChangeAcknowledgedKeysByChannel[normalized];
        if (Array.isArray(list)) {{
          list.length = 0;
        }}
        if (keySet instanceof Set) {{
          keySet.clear();
        }}
        if (ackSet instanceof Set) {{
          ackSet.clear();
        }}
      }};
      if (channelKey == null) {{
        clearOne("all");
        clearOne("direct");
        syncDocumentUnreadTitle(chatUnreadCount);
        return;
      }}
      clearOne(channelKey);
      syncDocumentUnreadTitle(chatUnreadCount);
    }}

    function chatChangeNoticesForChannel(channelKey) {{
      const key = normalizeChatChannel(channelKey);
      const list = chatChangeNoticesByChannel[key];
      if (!Array.isArray(list)) return [];
      return list.filter((notice) => noticeMatchesNotificationScope(notice));
    }}

    function chatChangeFocusKeysForChannel(channelKey) {{
      const keys = new Set();
      for (const notice of chatChangeNoticesForChannel(channelKey)) {{
        const focusKey = String((notice && (notice.focusKey || notice.key)) || "").trim();
        if (focusKey) {{
          keys.add(focusKey);
        }}
      }}
      return keys;
    }}

    function setChatChangeMenuOpen(open) {{
      chatChangeMenuOpen = !!open;
      const panel = document.getElementById("chat-change-summary");
      if (panel instanceof HTMLElement) {{
        panel.hidden = !chatChangeMenuOpen;
      }}
      const btn = document.getElementById("chat-change-toggle-btn");
      if (btn instanceof HTMLButtonElement) {{
        btn.setAttribute("aria-expanded", chatChangeMenuOpen ? "true" : "false");
      }}
    }}

    function updateChatChangeBadge(count) {{
      const safeCount = Math.max(0, Math.floor(Number(count) || 0));
      const scopeLabel = chatNotificationScopeLabel();
      const btn = document.getElementById("chat-change-toggle-btn");
      if (btn instanceof HTMLButtonElement) {{
        btn.classList.toggle("has-unread", safeCount > 0);
        const countLabel = safeCount > 99 ? "99+" : String(safeCount);
        btn.title = safeCount > 0
          ? `${{countLabel}} missed update${{safeCount === 1 ? "" : "s"}} (${{scopeLabel}})`
          : `No missed updates (${{scopeLabel}})`;
        btn.setAttribute(
          "aria-label",
          safeCount > 0
            ? `Missed updates (${{countLabel}}, ${{scopeLabel}})`
            : `Missed updates (${{scopeLabel}})`
        );
      }}
      const badge = document.getElementById("chat-change-badge");
      if (badge instanceof HTMLElement) {{
        if (safeCount > 0) {{
          badge.hidden = false;
          badge.textContent = safeCount > 99 ? "99+" : String(safeCount);
        }} else {{
          badge.hidden = true;
          badge.textContent = "0";
        }}
      }}
    }}

    function renderChatChangeSummary(nowUnix = Math.floor(Date.now() / 1000)) {{
      const panel = document.getElementById("chat-change-summary");
      if (!(panel instanceof HTMLElement)) return;
      const notices = chatChangeNoticesForChannel(activeChatChannel);
      const count = notices.length;
      const alertCount = chatChangeUnacknowledgedCountForChannel(activeChatChannel);
      const scopeLabel = chatNotificationScopeLabel();
      updateChatChangeBadge(alertCount);
      if (!notices.length) {{
        panel.innerHTML = `<div class="chat-change-empty">No missed ${{scopeLabel.toLowerCase()}} updates while you were away.</div>`;
        panel.hidden = !chatChangeMenuOpen;
        return;
      }}
      const recent = notices.slice(-chatChangeSummaryMaxRows).reverse();
      const rows = recent.map((notice) => {{
        const sender = escAttr(String(notice && notice.sender ? notice.sender : "Unknown node"));
        const preview = escAttr(String(notice && notice.preview ? notice.preview : "update"));
        const kind = notice && notice.kind === "reaction" ? "reaction" : "message";
        const kindLabel = kind === "reaction" ? "Reaction" : "Message";
        const kindClass = kind === "reaction" ? "reaction" : "message";
        const focusKey = escAttr(String((notice && (notice.focusKey || notice.key)) || ""));
        const when = notice && Number.isFinite(Number(notice.unix))
          ? savedDetailAge(Number(notice.unix), nowUnix)
          : "just now";
        return `<button type="button" class="chat-change-item" data-change-focus-key="${{focusKey}}" title="Jump to this changed message">
          <span class="chat-change-item-main">
            <span class="chat-change-kind ${{kindClass}}">${{kindLabel}}</span>
            <span class="chat-change-item-text"><strong>${{sender}}</strong>: ${{preview}}</span>
          </span>
          <span class="chat-change-item-age">${{escAttr(when)}}</span>
        </button>`;
      }}).join("");
      const headline = `${{count}} update${{count === 1 ? "" : "s"}} while you were away (${{scopeLabel}})`;
      panel.innerHTML = `<div class="chat-change-head">
        <div class="chat-change-title">${{escAttr(headline)}}</div>
        <button type="button" id="chat-change-clear-btn" class="chat-change-clear-btn">Mark seen</button>
      </div>
      <div class="chat-change-list">${{rows}}</div>`;
      panel.hidden = !chatChangeMenuOpen;
    }}

    function findChatFeedItemByMessageKey(messageKey) {{
      const key = String(messageKey || "").trim();
      if (!key) return null;
      for (const item of document.querySelectorAll("#chat-feed .chat-feed-item")) {{
        if (!(item instanceof HTMLElement)) continue;
        if (String(item.dataset.messageKey || "") === key) {{
          return item;
        }}
      }}
      return null;
    }}

    function clearChatFeedChangeFocus() {{
      for (const item of document.querySelectorAll("#chat-feed .chat-feed-item.change-focus")) {{
        if (!(item instanceof HTMLElement)) continue;
        item.classList.remove("change-focus");
      }}
      if (chatChangeFocusTimer !== null) {{
