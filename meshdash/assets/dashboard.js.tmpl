      const overrideFreq = document.getElementById("settings-lora-override-frequency");
      const ignoreMqtt = document.getElementById("settings-lora-ignore-mqtt");
      const okMqtt = document.getElementById("settings-lora-config-ok-to-mqtt");
      const overrideDuty = document.getElementById("settings-lora-override-duty-cycle");
      const boosted = document.getElementById("settings-lora-sx126x-rx-boosted-gain");
      const paFan = document.getElementById("settings-lora-pa-fan-disabled");
      const ownerShortInput = document.getElementById("settings-owner-short-name");
      const ownerLongInput = document.getElementById("settings-owner-long-name");
      const fixedLatInput = document.getElementById("settings-fixed-latitude");
      const fixedLonInput = document.getElementById("settings-fixed-longitude");
      const fixedAltInput = document.getElementById("settings-fixed-altitude");

      setFormValue(region, lora.region);
      setFormValue(preset, lora.modem_preset);
      setFormChecked(usePreset, lora.use_preset);
      setFormValue(hop, lora.hop_limit);
      setFormValue(txPower, lora.tx_power);
      setFormValue(chanNum, lora.channel_num);
      setFormChecked(txEnabled, lora.tx_enabled);
      setFormValue(bw, lora.bandwidth);
      setFormValue(sf, lora.spread_factor);
      setFormValue(cr, lora.coding_rate);
      setFormValue(freqOff, lora.frequency_offset);
      setFormValue(overrideFreq, lora.override_frequency);
      setFormChecked(ignoreMqtt, lora.ignore_mqtt);
      setFormChecked(okMqtt, lora.config_ok_to_mqtt);
      setFormChecked(overrideDuty, lora.override_duty_cycle);
      setFormChecked(boosted, lora.sx126x_rx_boosted_gain);
      setFormChecked(paFan, lora.pa_fan_disabled);
      const owner = localNodeUserFromState(state);
      setFormValue(ownerShortInput, owner && owner.short_name ? owner.short_name : "");
      setFormValue(ownerLongInput, owner && owner.long_name ? owner.long_name : "");

      const fixedFromState = fixedPositionFromState(state);
      if (fixedFromState) {{
        persistSettingsFixedPositionCache(fixedFromState);
      }}
      const fixedFromLocalNode = localNodePositionCandidate(state);
      const fixedForForm = fixedFromState || settingsFixedPositionCache || fixedFromLocalNode;
      if (!fixedFromState && !settingsFixedPositionCache && fixedFromLocalNode) {{
        persistSettingsFixedPositionCache(fixedFromLocalNode);
      }}
      if (fixedForForm) {{
        setFormValue(fixedLatInput, Number(fixedForForm.lat).toFixed(6));
        setFormValue(fixedLonInput, Number(fixedForForm.lon).toFixed(6));
        if (Number.isFinite(Number(fixedForForm.alt))) {{
          setFormValue(fixedAltInput, String(Math.trunc(Number(fixedForForm.alt))));
        }}
      }}
      const sourceFromRadio = radioPositionSourceFromState(state);
      const shouldAutoCenterFixed = (
        activeLayoutView === "settings"
        && !!fixedForForm
        && !settingsFixedMapAutoCenteredOnce
      );

      syncLoraManualFieldsDisabled();
      syncSettingsPositionSourceUi({{
