    function recordChatPerfSample(renderMs, feedCount, rosterCount) {{
      if (!chatPerfEnabled) return;
      const ms = Math.max(0, Number(renderMs) || 0);
      chatPerfStats.samples += 1;
      chatPerfStats.lastMs = ms;
      chatPerfStats.avgMs = chatPerfStats.samples <= 1
        ? ms
        : ((chatPerfStats.avgMs * (chatPerfStats.samples - 1)) + ms) / chatPerfStats.samples;
      chatPerfStats.emaMs = chatPerfStats.samples <= 1
        ? ms
        : (chatPerfStats.emaMs * (1 - chatPerfEmaAlpha)) + (ms * chatPerfEmaAlpha);
      chatPerfStats.maxMs = Math.max(chatPerfStats.maxMs, ms);
      chatPerfStats.lastFeedCount = Math.max(0, Math.trunc(Number(feedCount) || 0));
      chatPerfStats.lastRosterCount = Math.max(0, Math.trunc(Number(rosterCount) || 0));
      chatPerfStats.lastChannel = activeChatChannel;
    }}

