      }}
      if (replyClearBtn instanceof HTMLButtonElement) {{
        replyClearBtn.disabled = chatSendInFlight;
      }}
      if (sendChannelSelect instanceof HTMLSelectElement) {{
        sendChannelSelect.disabled = chatSendInFlight;
      }}
      if (sendChannelBtn instanceof HTMLButtonElement) {{
