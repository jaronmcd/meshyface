    function syncMeshChannelMismatchWarning() {{
      const wrap = document.querySelector(".chat-send-channel-wrap");
      const warningEl = document.getElementById("chat-channel-mismatch-warning");
      if (!(wrap instanceof HTMLElement)) return;

      const viewIdx = activeMeshChannelFilterIndex();
      const sendIdx = activeMeshChannelSendIndex();
      const mismatched = viewIdx !== meshChannelAllIndex && sendIdx !== viewIdx;
      const warningText = mismatched
        ? `Sending on ${{currentMeshChannelSendLabel()}} while viewing ${{currentMeshChannelViewLabel()}}. You may send something you cannot see here.`
        : "";

      wrap.classList.toggle("mismatch", mismatched);
      wrap.title = mismatched
        ? warningText
        : "Choose which configured message channel to use for outgoing chat. This sets the encryption group used for sends and does NOT change your LoRa frequency slot.";
      wrap.setAttribute("aria-label", mismatched ? warningText : "Outgoing chat channel");

      if (warningEl instanceof HTMLElement) {{
        warningEl.hidden = !mismatched;
        warningEl.textContent = warningText;
