    function localNodePositionCandidate(state = latestState) {{
      const safeState = state && typeof state === "object" ? state : {};
      const nodes = Array.isArray(safeState.nodes) ? safeState.nodes : [];
      if (!nodes.length) return null;

      const localId = normalizeNodeId(resolveLocalNodeId(safeState) || "");
      if (!isCanonicalNodeId(localId)) return null;
      for (const node of nodes) {{
        if (normalizeNodeId(node && node.id) !== localId) continue;
        const nodePos = node && node.position && typeof node.position === "object" ? node.position : null;
        const lat = coordinateValueFromSpecs(node, [
          {{ key: "lat" }},
          {{ key: "latitude" }},
          {{ key: "latitude_i", scale: 1e-7 }},
          {{ key: "latitudeI", scale: 1e-7 }},
