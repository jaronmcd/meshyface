    function looksLikeMeshtasticChannelUrl(rawValue) {{
      const text = String(rawValue == null ? "" : rawValue).trim();
      if (!text) return false;
      if (!text.includes("#")) return false;
      return /^https?:\/\//i.test(text) || /^meshtastic:\/\//i.test(text);
    }}

    async function handleChannelImportUrl(addOnly) {{
      const input = document.getElementById("settings-channels-import-url");
      if (!(input instanceof HTMLInputElement)) return;
      const url = String(input.value || "").trim();
      if (!url) {{
        setChannelsStatusText("Paste a Meshtastic channel URL first.");
        return;
      }}
      if (!looksLikeMeshtasticChannelUrl(url)) {{
        setChannelsStatusText("That does not look like a Meshtastic channel URL (expected ...#...).");
        return;
      }}

      const add = !!addOnly;
      const warning = add
        ? "Add channels from this URL?\n\nThis STILL applies LoRa settings from the URL (region/preset/frequency slot) and may reboot the radio.\n\nOnly proceed if you trust the source."
        : "Join from this URL?\n\nThis replaces your channel settings and applies LoRa settings from the URL (region/preset/frequency slot). The radio may reboot.\n\nOnly proceed if you trust the source.";
      if (!window.confirm(warning)) return;

      const payload = {{
        action: "import_url",
        url,
        add_only: add,
      }};
      const pending = add ? "Adding channels from URL…" : "Joining from URL…";
      const success = add ? "Channel URL applied (add-only)" : "Channel URL applied";
      const res = await postChannelSettingsPayload(payload, pending, success);
      if (res.ok) {{
        input.value = "";
        setTimeout(() => {{
          void fetchSettingsFromRadio();
        }}, 900);
      }}
    }}

