    bindSignalHeatDevApi();
    bindSignalHeatmapControl();
    bindChatAutoScroll();
    bindRawDataFetch();
    bindSettingsPanel();
    bindHistoryTabs();
    bindWheelPassthrough();
    renderSelectionStatus();
    if (activeLayoutView === "saved" && isSelectableNodeId(selectedNodeId)) {{
      renderNodeHistoryLoading(selectedNodeId);
    }} else {{
      setMapDataMode(mapDataFocus === "activity" ? "activity" : "live");
    }}
    renderFavorites({{}});
    requestMapResize();
    void loadThemeSettingsFromServer();

    let pollInFlight = false;
    let pollQueued = false;
    async function pollOnce() {{
      if (pollInFlight) {{
        pollQueued = true;
        return;
      }}
      pollInFlight = true;
      try {{
        await poll();
      }} finally {{
        pollInFlight = false;
        if (pollQueued) {{
          pollQueued = false;
          void pollOnce();
        }}
      }}
    }}

    document.addEventListener("visibilitychange", () => {{
      if (document.hidden) {{
        tabHasFocus = false;
        chatChangeCatchupArmed = true;
        return;
      }}
      tabHasFocus = (typeof document.hasFocus === "function") ? !!document.hasFocus() : true;
      void pollOnce();
    }});
    window.addEventListener("blur", () => {{
      tabHasFocus = false;
      chatChangeCatchupArmed = true;
    }});
    window.addEventListener("focus", () => {{
      tabHasFocus = true;
      void pollOnce();
    }});

    void pollOnce();
    setInterval(pollOnce, refreshMs);
    // Keep the uptime label moving even when the server returns cached/304 state.
    setInterval(() => {{
      if (!document.hidden) updateUptimeDisplay();
    }}, 1000);
    setInterval(() => {{
      void loadThemeSettingsFromServer(false);
    }}, 60000);
