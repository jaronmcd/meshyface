    function applyConsoleFontSizePreference() {{
      const pre = document.getElementById("live-console");
      const key = normalizeConsoleFontSize(consoleFontSize);
      const px = Number(consoleFontSizePxByKey[key]) || 12;
      if (pre instanceof HTMLElement) {{
        pre.style.fontSize = `${{px}}px`;
      }}
      const input = document.getElementById("console-command-input");
      if (input instanceof HTMLInputElement) {{
        input.style.fontSize = `${{px}}px`;
      }}
      const prompt = document.getElementById("console-prompt-label");
      if (prompt instanceof HTMLElement) {{
        prompt.style.fontSize = `${{px}}px`;
      }}
      const runBtn = document.getElementById("console-command-run-btn");
      if (runBtn instanceof HTMLButtonElement) {{
        runBtn.style.fontSize = `${{Math.max(10, px - 1)}}px`;
      }}
      consoleFontSize = key;
    }}

    function normalizeConsoleInteractiveSession(raw) {{
      const payload = (raw && typeof raw === "object") ? raw : {{}};
      const mode = String(payload.mode || "").trim().toLowerCase();
      if (mode === "standalone") {{
        const sessionId = String(payload.sessionId ?? payload.session_id ?? "").trim();
        if (!sessionId) return null;
        return {{
          name: "zork",
          mode: "standalone",
          sessionId,
        }};
      }}
      if (mode !== "remote") return null;
      const targetNodeId = normalizeNodeId(payload.targetNodeId ?? payload.target_node_id ?? "");
      if (!isCanonicalNodeId(targetNodeId)) return null;
      const channelIndex = normalizeMeshChannelIndex(payload.channelIndex ?? payload.channel_index ?? 0);
      const channelLabel = String(payload.channelLabel || payload.channel_label || "").trim()
        || meshChannelLabelForIndex(channelIndex);
      const seenKeysRaw = Array.isArray(payload.seenKeys) ? payload.seenKeys : [];
      const seenKeys = new Set(
        seenKeysRaw
          .map((value) => String(value == null ? "" : value).trim())
          .filter((value) => !!value)
          .slice(-4000)
      );
      return {{
        name: String(payload.name || "zork-remote").trim() || "zork-remote",
        mode: "remote",
        targetNodeId,
        targetLabel: String(payload.targetLabel || payload.target_label || "").trim(),
        channelIndex,
        channelLabel,
        seenKeys,
      }};
    }}

    function persistConsoleSessionState() {{
      try {{
        const storage = window.sessionStorage;
        if (!storage) return;
        let interactiveSession = null;
        if (consoleInteractiveSession && typeof consoleInteractiveSession === "object") {{
          const mode = String(consoleInteractiveSession.mode || "").trim().toLowerCase();
          if (mode === "standalone") {{
            const sessionId = String(consoleInteractiveSession.sessionId || "").trim();
            if (sessionId) {{
              interactiveSession = {{
                name: "zork",
                mode: "standalone",
                sessionId,
              }};
            }}
          }} else if (mode === "remote") {{
            const targetNodeId = normalizeNodeId(consoleInteractiveSession.targetNodeId || "");
            if (isCanonicalNodeId(targetNodeId)) {{
              interactiveSession = {{
                name: String(consoleInteractiveSession.name || "zork-remote").trim() || "zork-remote",
                mode: "remote",
                targetNodeId,
                targetLabel: String(consoleInteractiveSession.targetLabel || "").trim(),
                channelIndex: normalizeMeshChannelIndex(consoleInteractiveSession.channelIndex),
                channelLabel: String(consoleInteractiveSession.channelLabel || "").trim(),
                seenKeys: Array.from(consoleInteractiveSession.seenKeys || []).slice(-4000),
              }};
            }}
          }}
        }}
        const payload = {{
          lines: consoleLines.slice(-consoleMaxLines),
          commandHistory: consoleCommandHistory.slice(-consoleCommandHistoryMax),
          autoscroll: !!consoleAutoscroll,
          interactiveSession,
          eventCounter: Math.max(0, Math.trunc(Number(consoleEventCounter) || 0)),
        }};
        storage.setItem(consoleSessionStorageKey, JSON.stringify(payload));
      }} catch (_err) {{
      }}
    }}

    function loadConsoleSessionState() {{
      try {{
        const storage = window.sessionStorage;
        if (!storage) return;
        const raw = storage.getItem(consoleSessionStorageKey);
        if (!raw) return;
        const parsed = JSON.parse(raw);
        const payload = (parsed && typeof parsed === "object") ? parsed : {{}};
        const lines = Array.isArray(payload.lines)
          ? payload.lines
            .map((value) => String(value == null ? "" : value))
            .filter((value) => !!value)
            .slice(-consoleMaxLines)
          : [];
        consoleLines.length = 0;
        consoleLines.push(...lines);
        consoleKeyQueue.length = 0;
        consoleSeen.clear();
        lines.forEach((_line, index) => {{
          const key = `restored|${{index}}`;
          consoleKeyQueue.push(key);
          consoleSeen.add(key);
        }});
        consoleCommandHistory = Array.isArray(payload.commandHistory)
          ? payload.commandHistory
            .map((value) => String(value == null ? "" : value).trim())
            .filter((value) => !!value)
            .slice(-consoleCommandHistoryMax)
          : [];
        consoleCommandHistoryCursor = -1;
        consoleCommandDraft = "";
        consoleAutoscroll = payload.autoscroll !== false;
        consoleInteractiveSession = normalizeConsoleInteractiveSession(payload.interactiveSession);
        consoleEventCounter = Math.max(0, Math.trunc(Number(payload.eventCounter) || 0));
      }} catch (_err) {{
      }}
    }}

    function isStandaloneConsoleSessionExpiredMessage(value) {{
      const text = String(value == null ? "" : value).trim();
      if (!text) return false;
      return /no active standalone zork session/i.test(text);
    }}

    function wildcardPatternToRegExp(pattern) {{
      const clean = String(pattern == null ? "" : pattern).trim();
      if (!clean || clean === "*") return /^.*$/i;
      let escaped = "";
      for (const ch of clean) {{
        if ("\\^$+?.()|{{}}[]".includes(ch)) {{
          escaped += `\\${{ch}}`;
        }} else {{
          escaped += ch;
        }}
      }}
      const regexBody = escaped.replace(/\*/g, ".*").replace(/\?/g, ".");
      return new RegExp(`^${{regexBody}}$`, "i");
    }}

    function wildcardMatches(pattern, value) {{
      const cleanPattern = String(pattern == null ? "" : pattern).trim();
      if (!cleanPattern) return true;
      const target = String(value == null ? "" : value).trim();
      try {{
        return wildcardPatternToRegExp(cleanPattern).test(target);
      }} catch (_err) {{
        return false;
      }}
    }}

    function normalizeWildcardPattern(value) {{
      const clean = String(value == null ? "" : value).trim();
      if (!clean) return "";
      if (clean.includes("*") || clean.includes("?")) return clean;
      return `*${{clean}}*`;
    }}

    function parseConsoleTokens(line) {{
      const input = String(line == null ? "" : line);
      const tokens = [];
      let buf = "";
      let quote = "";
      let escaped = false;
      for (let i = 0; i < input.length; i += 1) {{
        const ch = input[i];
        if (escaped) {{
          buf += ch;
          escaped = false;
          continue;
        }}
        if (ch === "\\") {{
          escaped = true;
          continue;
        }}
        if (quote) {{
          if (ch === quote) {{
            quote = "";
          }} else {{
            buf += ch;
          }}
          continue;
        }}
        if (ch === "'" || ch === "\"") {{
          quote = ch;
          continue;
        }}
        if (/\s/.test(ch)) {{
          if (buf) {{
            tokens.push(buf);
            buf = "";
          }}
          continue;
        }}
        buf += ch;
      }}
      if (escaped) buf += "\\";
      if (quote) {{
        return {{ tokens: [], error: `Unterminated quote (${{quote}})` }};
      }}
      if (buf) tokens.push(buf);
      return {{ tokens, error: "" }};
    }}

    function parseConsoleCommandLine(line) {{
      const parsedTokens = parseConsoleTokens(line);
      if (parsedTokens.error) {{
        return {{ command: "", args: [], options: {{}}, comparisons: [], error: parsedTokens.error }};
      }}
      const tokens = parsedTokens.tokens || [];
      if (!tokens.length) {{
        return {{ command: "", args: [], options: {{}}, comparisons: [], error: "Empty command" }};
      }}
      const command = String(tokens[0] || "").trim().toLowerCase();
      if (!command) {{
        return {{ command: "", args: [], options: {{}}, comparisons: [], error: "Missing command name" }};
      }}
      const args = [];
      const options = {{}};
      const comparisons = [];
      for (let i = 1; i < tokens.length; i += 1) {{
        const token = String(tokens[i] || "");
        if (!token) continue;
        const nextTokenRaw = (i + 1) < tokens.length ? String(tokens[i + 1] || "").trim() : "";
        const valueTokenRaw = (i + 2) < tokens.length ? String(tokens[i + 2] || "").trim() : "";
        const keyLike = /^[a-zA-Z_][a-zA-Z0-9_-]*$/.test(token);
        if (keyLike && (nextTokenRaw === "=" || nextTokenRaw === "<" || nextTokenRaw === ">" || nextTokenRaw === "<=" || nextTokenRaw === ">=") && valueTokenRaw) {{
          const cmpKey = token.trim().toLowerCase();
          if (nextTokenRaw === "=") {{
            options[cmpKey] = valueTokenRaw;
          }} else {{
            comparisons.push({{ key: cmpKey, op: nextTokenRaw, value: valueTokenRaw }});
          }}
          i += 2;
          continue;
        }}
        if (token.startsWith("--")) {{
          const body = token.slice(2).trim();
          if (!body) continue;
          if (body.startsWith("no-") && body.length > 3) {{
            options[body.slice(3).toLowerCase()] = false;
            continue;
          }}
          const eqIdx = body.indexOf("=");
          if (eqIdx > 0) {{
            const key = body.slice(0, eqIdx).trim().toLowerCase();
            const value = body.slice(eqIdx + 1).trim();
            if (key) options[key] = value;
            continue;
          }}
          options[body.toLowerCase()] = true;
          continue;
        }}
        const cmpMatch = token.match(/^([a-zA-Z_][a-zA-Z0-9_-]*)(<=|>=|<|>)(.+)$/);
        if (cmpMatch) {{
          const cmpKey = String(cmpMatch[1] || "").trim().toLowerCase();
          const cmpOp = String(cmpMatch[2] || "").trim();
          const cmpValue = String(cmpMatch[3] || "").trim();
          if (cmpKey && cmpOp && cmpValue) {{
            comparisons.push({{ key: cmpKey, op: cmpOp, value: cmpValue }});
            continue;
          }}
        }}
        const eqIdx = token.indexOf("=");
        if (eqIdx > 0) {{
          const key = token.slice(0, eqIdx).trim().toLowerCase();
          const value = token.slice(eqIdx + 1).trim();
          if (key) options[key] = value;
          continue;
        }}
        args.push(token);
      }}
      return {{ command, args, options, comparisons, error: "" }};
    }}

    function pushConsoleHistoryEntry(commandLine) {{
      const clean = String(commandLine == null ? "" : commandLine).trim();
      if (!clean) return;
      if (!consoleCommandHistory.length || consoleCommandHistory[consoleCommandHistory.length - 1] !== clean) {{
        consoleCommandHistory.push(clean);
      }}
      if (consoleCommandHistory.length > consoleCommandHistoryMax) {{
        consoleCommandHistory = consoleCommandHistory.slice(-consoleCommandHistoryMax);
      }}
      consoleCommandHistoryCursor = -1;
      consoleCommandDraft = "";
      persistConsoleSessionState();
    }}

    function navigateConsoleHistory(direction, inputEl) {{
      if (!(inputEl instanceof HTMLInputElement)) return;
      if (!Array.isArray(consoleCommandHistory) || !consoleCommandHistory.length) return;
      const step = Number(direction);
      if (!Number.isFinite(step) || step === 0) return;
      if (step < 0) {{
        if (consoleCommandHistoryCursor < 0) {{
          consoleCommandDraft = inputEl.value;
          consoleCommandHistoryCursor = consoleCommandHistory.length - 1;
        }} else if (consoleCommandHistoryCursor > 0) {{
          consoleCommandHistoryCursor -= 1;
        }}
      }} else {{
        if (consoleCommandHistoryCursor < 0) return;
        if (consoleCommandHistoryCursor < consoleCommandHistory.length - 1) {{
          consoleCommandHistoryCursor += 1;
        }} else {{
          consoleCommandHistoryCursor = -1;
          inputEl.value = consoleCommandDraft;
          inputEl.setSelectionRange(inputEl.value.length, inputEl.value.length);
          return;
        }}
      }}
      if (consoleCommandHistoryCursor < 0 || consoleCommandHistoryCursor >= consoleCommandHistory.length) return;
      const nextValue = String(consoleCommandHistory[consoleCommandHistoryCursor] || "");
      inputEl.value = nextValue;
      inputEl.setSelectionRange(nextValue.length, nextValue.length);
    }}

    function syncConsoleCommandInputState() {{
      const input = document.getElementById("console-command-input");
      const runBtn = document.getElementById("console-command-run-btn");
      const prompt = document.getElementById("console-prompt-label");
      const runningName = consoleRunningCommand && consoleRunningCommand.name
        ? String(consoleRunningCommand.name)
        : "";
      const interactiveName = consoleInteractiveSession && consoleInteractiveSession.name
        ? String(consoleInteractiveSession.name)
        : "";
      const promptLabel = runningName
        ? `${{runningName.replace(/[^a-z0-9_-]+/gi, "").slice(0, 10) || "busy"}}>`
        : interactiveName
          ? `${{interactiveName.replace(/[^a-z0-9_-]+/gi, "").slice(0, 10) || "session"}}>`
          : ">";
      const placeholder = runningName
        ? `ctrl+c to stop ${{runningName}}`
        : interactiveName
          ? `enter ${{interactiveName}} command  /help for console`
          : "enter command or type help";
      if (prompt instanceof HTMLElement) {{
        prompt.textContent = promptLabel;
        prompt.classList.toggle("is-running", !!runningName);
      }}
      if (input instanceof HTMLInputElement) {{
        input.placeholder = placeholder;
        input.classList.toggle("is-running", !!runningName || !!interactiveName);
      }}
      if (runBtn instanceof HTMLButtonElement) {{
        runBtn.textContent = runningName ? "Busy" : interactiveName ? "Send" : "Run";
      }}
      persistConsoleSessionState();
    }}

    function focusConsoleCommandInput(select = false) {{
      const input = document.getElementById("console-command-input");
      if (!(input instanceof HTMLInputElement)) return;
      try {{
        input.focus({{ preventScroll: true }});
      }} catch (_err) {{
        input.focus();
      }}
      if (select) {{
        input.select();
      }} else {{
        const len = input.value.length;
        input.setSelectionRange(len, len);
      }}
    }}

    function selectionIntersectsElement(selection, element) {{
      if (!(element instanceof HTMLElement)) return false;
      if (!selection || typeof selection.rangeCount !== "number" || selection.rangeCount < 1) {{
        return false;
      }}
      try {{
        const range = selection.getRangeAt(0);
        const container = range.commonAncestorContainer;
        if (container instanceof Node) {{
          return element.contains(container);
        }}
      }} catch (_err) {{
      }}
      return false;
    }}

    async function copySelectionToClipboardWithin(element) {{
      if (!(element instanceof HTMLElement)) return false;
      const selection = window.getSelection ? window.getSelection() : null;
      if (!selectionIntersectsElement(selection, element)) return false;
      const text = String(selection ? selection.toString() : "").trim();
      if (!text) return false;
      try {{
        if (!navigator.clipboard || typeof navigator.clipboard.writeText !== "function") {{
          return false;
        }}
        await navigator.clipboard.writeText(text);
        selection.removeAllRanges();
        return true;
      }} catch (_err) {{
        return false;
      }}
    }}

    async function copyConsoleSelectionToClipboard() {{
      const pre = document.getElementById("live-console");
      return copySelectionToClipboardWithin(pre instanceof HTMLElement ? pre : null);
    }}

    async function copyChatSelectionToClipboard() {{
      const feed = document.getElementById("chat-feed");
      return copySelectionToClipboardWithin(feed instanceof HTMLElement ? feed : null);
    }}

    function startConsoleRunningCommand(name, onStop = null) {{
      const clean = String(name == null ? "" : name).trim().toLowerCase() || "command";
      consoleRunningCommand = {{
        name: clean,
        stop: typeof onStop === "function" ? onStop : null,
      }};
      syncConsoleCommandInputState();
    }}

    function stopConsoleRunningCommand(reason = "stopped", emitStatus = true) {{
      if (!consoleRunningCommand) return false;
      const active = consoleRunningCommand;
      consoleRunningCommand = null;
      syncConsoleCommandInputState();
      if (typeof active.stop === "function") {{
        try {{
          active.stop(reason, !!emitStatus);
        }} catch (_err) {{
        }}
      }}
      return true;
    }}

    function stopConsoleInteractiveSession(reason = "stopped", emitStatus = true) {{
      if (!consoleInteractiveSession) return false;
      const active = consoleInteractiveSession;
      consoleInteractiveSession = null;
      syncConsoleCommandInputState();
      if (emitStatus) {{
        const targetLabel = String(active.targetLabel || active.targetNodeId || "session");
        appendConsoleEventLine(`[${{String(active.name || "session")}}] stopped (${{String(reason || "done")}}) with ${{targetLabel}}.`);
      }}
      return true;
    }}

    function preferredConsoleTargetLabel(nodeId, state = latestState) {{
      const clean = normalizeNodeId(nodeId || "");
      if (!isSelectableNodeId(clean)) return "";
      const nodes = Array.isArray(state && state.nodes) ? state.nodes : [];
      const node = nodes.find((entry) => normalizeNodeId(entry && entry.id) === clean) || null;
      return preferredNodeName(node) || nodeNameCache.get(clean) || clean;
    }}

    function resolveConsoleGameTarget(ctx = null) {{
      const state = (ctx && ctx.state && typeof ctx.state === "object") ? ctx.state : latestState;
      const options = (ctx && ctx.options && typeof ctx.options === "object") ? ctx.options : {{}};
      const args = Array.isArray(ctx && ctx.args) ? ctx.args : [];
      const rawTarget = String(options.node ?? options.id ?? options.peer ?? args[0] ?? "").trim();
      let nodeId = normalizeNodeId(rawTarget || selectedNodeId || "");
      if (!isSelectableNodeId(nodeId)) {{
        return {{ ok: false, error: "Select a peer-to-peer user first or pass node=!xxxxxxxx." }};
      }}
      if (!isCanonicalNodeId(nodeId)) {{
        return {{ ok: false, error: `Invalid peer target: ${{nodeId}}` }};
      }}
      if (isSelfNodeId(nodeId, state)) {{
        return {{ ok: false, error: "Cannot start a console game session against your own radio." }};
      }}
      let channelIndex = activeMeshChannelSendIndex();
      if (Object.prototype.hasOwnProperty.call(options, "channel")) {{
        const parsedChannel = normalizeMeshChannelIndex(options.channel);
        channelIndex = parsedChannel;
      }}
      const channelLabel = meshChannelLabelForIndex(channelIndex);
      return {{
        ok: true,
        nodeId,
        targetLabel: preferredConsoleTargetLabel(nodeId, state),
        channelIndex,
        channelLabel,
      }};
    }}

    function consoleInteractiveChatKey(msg) {{
      const base = chatMessageKey(msg);
      if (base) return base;
      return "";
    }}

    function consoleInteractiveChatTimestampMs(msg) {{
      const unix = latestUnixTimestamp(
        msg && (msg.rx_time ?? msg.rxTime),
        msg && (msg.captured_at ?? msg.capturedAt),
        msg && (msg.sent_at ?? msg.sentAt)
      );
      return Number.isFinite(unix) && unix > 0 ? unix * 1000 : Date.now();
    }}

    function consoleInteractiveChatText(msg) {{
      return String(
        (msg && (msg.text ?? msg.decoded_text ?? msg.payload_text)) || ""
      ).replace(/\s+/g, " ").trim();
    }}

    function syncConsoleInteractiveSessionMessages(state = latestState) {{
      const session = consoleInteractiveSession;
      if (!session || !state || typeof state !== "object") return;
      if (String(session.mode || "") !== "remote") return;
      const traffic = (state.traffic && typeof state.traffic === "object") ? state.traffic : {{}};
      const messages = Array.isArray(traffic.recent_chat) ? traffic.recent_chat : [];
      const localNodeId = resolveLocalNodeId(state);
      const targetNodeId = normalizeNodeId(session.targetNodeId || "");
      if (!isCanonicalNodeId(localNodeId) || !isCanonicalNodeId(targetNodeId)) return;
      for (const msg of messages) {{
        if (!msg || typeof msg !== "object") continue;
        const text = consoleInteractiveChatText(msg);
        if (!text) continue;
        const fromId = normalizeNodeId(msg.from || "");
        const toId = normalizeNodeId((msg.to || msg.destination || ""));
        const isTranscriptMessage = (
          (fromId === targetNodeId && toId === localNodeId)
          || (fromId === localNodeId && toId === targetNodeId)
        );
        if (!isTranscriptMessage) continue;
        const key = consoleInteractiveChatKey(msg);
        if (!key || session.seenKeys.has(key)) continue;
        session.seenKeys.add(key);
        const fromLabel = fromId === localNodeId
          ? "you"
          : (preferredConsoleTargetLabel(fromId, state) || fromId || "peer");
        appendConsoleLine(
          `interactive|${{String(session.name || "session")}}|${{key}}`,
          `${{fromLabel}}: ${{text}}`,
          consoleInteractiveChatTimestampMs(msg)
        );
      }}
    }}

    async function sendConsoleInteractiveSessionLine(rawLine) {{
      const session = consoleInteractiveSession;
      if (!session) {{
        return "[console] no interactive session is active.";
      }}
      const text = String(rawLine == null ? "" : rawLine).trim();
      if (!text) return "";
      if (String(session.mode || "") === "standalone") {{
        const payload = await postStandaloneZorkCommand(text, session.sessionId || "");
        const nextSessionId = String(payload && payload.session_id ? payload.session_id : session.sessionId || "").trim();
        if (nextSessionId) {{
          session.sessionId = nextSessionId;
          persistConsoleSessionState();
        }}
        const replyText = String(payload && payload.reply_text ? payload.reply_text : "").trim();
        if (replyText) {{
          const receivedAtMs = Date.now();
          appendConsoleLine(
            `interactive|standalone|${{String(session.sessionId || "session")}}|${{receivedAtMs}}`,
            `zork: ${{replyText}}`,
            receivedAtMs,
            true
          );
        }}
        if (payload && payload.active_session === false) {{
          stopConsoleInteractiveSession("game ended", false);
        }}
        return "";
      }}
      const body = {{
        text,
        destination: session.targetNodeId,
        channel_index: session.channelIndex,
      }};
      const payload = await sendChatPayload(body, null);
      if (!(payload && payload.ok)) {{
        throw new Error("send failed");
      }}
      const messageId = messageIdOfChatPacket(payload || {{}});
      if (messageId) {{
        session.seenKeys.add(`id:${{messageId}}`);
      }}
      requestImmediatePoll(80);
      return "";
    }}

    async function executeConsoleCommand(parsed, line) {{
      ensureConsoleCommandsRegistered();
      const commandDef = consoleCommandRegistry.get(parsed.command);
      if (!commandDef) {{
        appendConsoleEventLine(`[console] unknown command: ${{parsed.command}} (try "help")`);
        return;
      }}
      try {{
        const result = await commandDef.run({{
          line,
          command: parsed.command,
          args: parsed.args,
          options: parsed.options,
          comparisons: parsed.comparisons,
          state: latestState,
          wildcardMatches,
          append: (msg) => appendConsoleEventLine(msg),
        }});
        if (Array.isArray(result)) {{
          for (const lineOut of result) {{
            const text = String(lineOut == null ? "" : lineOut).trimEnd();
            if (text) appendConsoleEventLine(text);
          }}
          return;
        }}
        if (result && typeof result === "object") {{
          if (typeof result.message === "string" && result.message.trim()) {{
            appendConsoleEventLine(result.message.trim());
            return;
          }}
          try {{
            appendConsoleEventLine(JSON.stringify(result));
            return;
          }} catch (_err) {{
            return;
          }}
        }}
        const text = String(result == null ? "" : result).trim();
        if (text) {{
          appendConsoleEventLine(text);
        }}
      }} catch (err) {{
        const msg = err instanceof Error ? err.message : String(err || "unknown error");
        appendConsoleEventLine(`[${{parsed.command}}] error: ${{msg}}`);
      }}
    }}

    function registerConsoleCommand(commandDef) {{
      if (!commandDef || typeof commandDef !== "object") return;
      const name = String(commandDef.name || "").trim().toLowerCase();
      if (!name) return;
      const run = typeof commandDef.run === "function"
        ? commandDef.run
        : () => `[${{name}}] not implemented`;
      consoleCommandRegistry.set(name, {{
        name,
        usage: String(commandDef.usage || name).trim() || name,
        description: String(commandDef.description || "").trim(),
        run,
      }});
    }}

    function formatConsoleListTime(unixSeconds) {{
      const ts = Number(unixSeconds);
      if (!Number.isFinite(ts) || ts <= 0) return "n/a";
      try {{
        return new Date(Math.floor(ts) * 1000).toISOString().replace("T", " ").replace(".000Z", "Z");
      }} catch (_err) {{
        return "n/a";
      }}
    }}

    function collectConsoleNodePortMap(state = latestState) {{
      const safeState = (state && typeof state === "object") ? state : {{}};
      const traffic = (safeState.traffic && typeof safeState.traffic === "object") ? safeState.traffic : {{}};
      const packets = Array.isArray(traffic.recent_packets) ? traffic.recent_packets : [];
      const byNodeId = new Map();
      const addPort = (nodeId, portValue) => {{
        const cleanId = normalizeNodeId(nodeId || "");
        const cleanPort = String(portValue == null ? "" : portValue).trim();
        if (!cleanId || !cleanPort || cleanId === "^all") return;
        let bucket = byNodeId.get(cleanId);
        if (!(bucket instanceof Set)) {{
          bucket = new Set();
          byNodeId.set(cleanId, bucket);
        }}
        bucket.add(cleanPort);
      }};
      for (const entry of packets) {{
        const summary = (entry && typeof entry.summary === "object") ? entry.summary : {{}};
        const packet = (entry && typeof entry.packet === "object") ? entry.packet : {{}};
        const port = summary.portnum ?? packet.portnum ?? "";
        if (!String(port == null ? "" : port).trim()) continue;
        addPort(summary.from ?? packet.from ?? "", port);
        addPort(summary.to ?? packet.to ?? "", port);
      }}
      return byNodeId;
    }}

    function formatConsolePortSummary(ports, maxPorts = 3) {{
      const list = Array.isArray(ports) ? ports.filter((port) => !!String(port || "").trim()) : [];
      if (!list.length) return "n/a";
      const cap = Math.max(1, Math.floor(Number(maxPorts) || 3));
      const head = list.slice(0, cap).join(",");
      if (list.length <= cap) return head;
      return `${{head}} +${{list.length - cap}}`;
    }}

    function collectConsoleNodeRows(state = latestState) {{
      const safeState = (state && typeof state === "object") ? state : {{}};
      const nodes = Array.isArray(safeState.nodes) ? safeState.nodes : [];
      const portsByNodeId = collectConsoleNodePortMap(safeState);
      const nowUnix = Math.floor(Date.now() / 1000);
      const rows = [];
      for (const node of nodes) {{
        if (!node || typeof node !== "object") continue;
        const nodeId = normalizeNodeId(node.id || node.node_id || node.nodeId || "");
        if (!nodeId) continue;
        const nodeName = preferredNodeName(node) || String(nodeLabel(node) || "Unknown");
        const lastSeenUnix = nodeLastHeardUnix(node);
        const status = freshnessStatus(lastSeenUnix, nowUnix);
        const hopsNum = Number(node.hops_away);
        const ports = Array.from(portsByNodeId.get(nodeId) || [])
          .map((port) => String(port == null ? "" : port).trim())
          .filter((port) => !!port)
          .sort((a, b) => a.localeCompare(b));
        rows.push({{
          id: nodeId,
          name: nodeName,
          status,
          hops: Number.isFinite(hopsNum) ? Math.trunc(hopsNum) : null,
          lastSeenUnix: Number.isFinite(lastSeenUnix) ? Math.trunc(lastSeenUnix) : null,
          ports,
          raw: node,
        }});
      }}
      rows.sort((a, b) => {{
        const statusCmp = statusRank(a.status) - statusRank(b.status);
        if (statusCmp !== 0) return statusCmp;
        const aLast = Number(a.lastSeenUnix || 0);
        const bLast = Number(b.lastSeenUnix || 0);
        if (aLast !== bLast) return bLast - aLast;
        return String(a.name || "").localeCompare(String(b.name || ""));
      }});
      return rows;
    }}

    function ensureConsoleCommandsRegistered() {{
      if (consoleCommandRegistry.size > 0) return;
      registerConsoleCommand({{
        name: "help",
        usage: "help",
        description: "Show available console commands.",
        run: () => {{
          const defs = Array.from(consoleCommandRegistry.values())
            .sort((a, b) => a.name.localeCompare(b.name));
          const lines = ["[help] commands:"];
          for (const def of defs) {{
            const details = def.description ? ` - ${{def.description}}` : "";
            lines.push(`  ${{def.usage}}${{details}}`);
          }}
          lines.push("[help] Ctrl+C stops running commands.");
          return lines;
        }},
      }});
      registerConsoleCommand({{
        name: "clear",
        usage: "clear",
        description: "Clear console output.",
        run: () => {{
          clearConsoleOutput({{ renderNow: false }});
          return "[console] cleared.";
        }},
      }});
      registerConsoleCommand({{
        name: "live",
        usage: "live [-v|-vv|-vvv|-vvvv]",
        description: "Stream live packet lines until Ctrl+C with optional extra detail.",
        run: (ctx) => {{
          const args = Array.isArray(ctx && ctx.args) ? ctx.args : [];
          const verbosityTokens = args.filter((token) => /^-v{1,4}$/i.test(String(token || "").trim()));
          const invalidArgs = args.filter((token) => !/^-v{1,4}$/i.test(String(token || "").trim()));
          if (invalidArgs.length) {{
            return `[live] unknown argument(s): ${{invalidArgs.join(", ")}}`;
          }}
          const verbosity = verbosityTokens.reduce((max, token) => {{
            const count = String(token || "").trim().length - 1;
            return Math.max(max, Math.min(4, Math.max(0, count)));
          }}, 0);
          if (consoleLiveModeActive) {{
            return "[live] already running. Press Ctrl+C to stop.";
          }}
          consoleLiveVerbosity = verbosity;
          consoleLiveModeActive = true;
          startConsoleRunningCommand("live", (reason, emitStatus) => {{
            consoleLiveModeActive = false;
            consoleLiveVerbosity = 0;
            if (emitStatus) {{
              appendConsoleEventLine(`[live] stopped (${{String(reason || "done")}}).`);
            }}
            renderConsoleBuffer(true);
          }});
          renderConsole((latestState && latestState.traffic) || {{}});
          const verbosityLabel = verbosity > 0 ? ` verbosity=-${{"v".repeat(verbosity)}}` : "";
          return `[live] streaming packet traffic.${{verbosityLabel}} Press Ctrl+C to stop.`;
        }},
      }});
      registerConsoleCommand({{
        name: "list",
        usage: "list [pattern] [name=<wildcard>] [id=<wildcard>] [status=<wildcard>] [port=<wildcard>] [hops=<n>] [hops>n] [hops<n] [limit=<n>]",
        description: "List nodes from current state with wildcard filters.",
        run: (ctx) => {{
          const options = (ctx && ctx.options && typeof ctx.options === "object")
            ? ctx.options
            : {{}};
          const comparisons = Array.isArray(ctx && ctx.comparisons) ? ctx.comparisons : [];
          const args = Array.isArray(ctx && ctx.args) ? ctx.args : [];
          const freePattern = normalizeWildcardPattern(args[0] || "");
          const idPattern = normalizeWildcardPattern(options.id || "");
          const namePattern = normalizeWildcardPattern(options.name || "");
          const statusPattern = normalizeWildcardPattern(options.status || "");
          const portPattern = normalizeWildcardPattern(options.port ?? options.p ?? "");
          const hopsComparators = [];
          const pushHopsComparator = (op, rawValue) => {{
            const numeric = Number(rawValue);
            if (!Number.isFinite(numeric)) {{
              return false;
            }}
            hopsComparators.push({{ op: String(op || "="), value: numeric }});
            return true;
          }};
          if (Object.prototype.hasOwnProperty.call(options, "hops")) {{
            if (!pushHopsComparator("=", options.hops)) {{
              return `[list] invalid hops value: ${{String(options.hops)}}`;
            }}
          }}
          for (const cmp of comparisons) {{
            if (!cmp || typeof cmp !== "object") continue;
            const cmpKey = String(cmp.key || "").trim().toLowerCase();
            if (cmpKey !== "hops" && cmpKey !== "hop") continue;
            const cmpOp = String(cmp.op || "").trim();
            if (!["<", ">", "<=", ">="].includes(cmpOp)) continue;
            if (!pushHopsComparator(cmpOp, cmp.value)) {{
              return `[list] invalid hops comparator: ${{cmpKey}}${{cmpOp}}${{String(cmp.value || "")}}`;
            }}
          }}
          const limitRaw = Number(options.limit ?? options.n ?? 50);
          const limit = Math.min(500, Math.max(1, Math.floor(Number.isFinite(limitRaw) ? limitRaw : 50)));
          const rows = collectConsoleNodeRows(ctx && ctx.state);
          const filtered = rows.filter((row) => {{
            if (freePattern) {{
              const freeHit = wildcardMatches(freePattern, row.id) || wildcardMatches(freePattern, row.name);
              if (!freeHit) return false;
            }}
            if (idPattern && !wildcardMatches(idPattern, row.id)) return false;
            if (namePattern && !wildcardMatches(namePattern, row.name)) return false;
            if (statusPattern && !wildcardMatches(statusPattern, row.status)) return false;
            if (portPattern) {{
              const hasPortMatch = Array.isArray(row.ports)
                && row.ports.some((portValue) => wildcardMatches(portPattern, portValue));
              if (!hasPortMatch) return false;
            }}
            if (hopsComparators.length) {{
              const hopsValue = Number(row.hops);
              if (!Number.isFinite(hopsValue)) return false;
              for (const cmp of hopsComparators) {{
                const target = Number(cmp.value);
                if (cmp.op === ">" && !(hopsValue > target)) return false;
                if (cmp.op === "<" && !(hopsValue < target)) return false;
                if (cmp.op === ">=" && !(hopsValue >= target)) return false;
                if (cmp.op === "<=" && !(hopsValue <= target)) return false;
                if (cmp.op === "=" && !(hopsValue === target)) return false;
              }}
            }}
            return true;
          }});
          const show = filtered.slice(0, limit);
          const lines = [
            `[list] matched ${{filtered.length}} node(s); showing ${{show.length}}.`,
          ];
          for (const row of show) {{
            const hopsLabel = row.hops == null ? "n/a" : String(row.hops);
            const portsLabel = formatConsolePortSummary(row.ports, 3);
            lines.push(
              `${{row.id}} | ${{row.name}} | status=${{row.status}} | hops=${{hopsLabel}} | ports=${{portsLabel}} | last=${{formatConsoleListTime(row.lastSeenUnix)}}`
            );
          }}
          if (!show.length) {{
            lines.push("[list] no matches. Try list * or list name=*pattern*");
          }} else if (filtered.length > show.length) {{
            lines.push(`[list] truncated. Use limit=<n> up to 500.`);
          }}
          return lines;
        }},
      }});
      registerConsoleCommand({{
        name: "zork",
        usage: "zork",
        description: "Start a standalone local Zork session in Console.",
        run: async (ctx) => {{
          if (consoleInteractiveSession) {{
            return "[zork] already running. Press Ctrl+C to stop.";
          }}
          const payload = await postStandaloneZorkCommand("zork");
          consoleInteractiveSession = {{
            name: "zork",
            mode: "standalone",
            sessionId: String(payload && payload.session_id ? payload.session_id : "").trim(),
          }};
          syncConsoleCommandInputState();
          const lines = [
            "[zork] standalone session started. Type game commands directly here. Use /help for console commands. Press Ctrl+C to stop this console session.",
          ];
          const replyText = String(payload && payload.reply_text ? payload.reply_text : "").trim();
          if (replyText) {{
            lines.push(`zork: ${{replyText}}`);
          }}
          if (payload && payload.active_session === false) {{
            stopConsoleInteractiveSession("game ended", false);
          }}
          return lines;
        }},
      }});
      registerConsoleCommand({{
        name: "zork-remote",
        usage: "zork-remote [node=!xxxxxxxx] [channel=<n>]",
        description: "Start an interactive Zork session against a selected direct peer over the mesh.",
        run: async (ctx) => {{
          if (consoleInteractiveSession) {{
            return "[zork-remote] another interactive session is already running. Press Ctrl+C to stop.";
          }}
          const target = resolveConsoleGameTarget(ctx);
          if (!target.ok) {{
            return `[zork-remote] ${{target.error}}`;
          }}
          const body = {{
            text: "zork",
            destination: target.nodeId,
            channel_index: target.channelIndex,
          }};
          const payload = await sendChatPayload(body, null);
          if (!(payload && payload.ok)) {{
            throw new Error("failed to start remote session");
          }}
          const seenKeys = new Set();
          const messageId = messageIdOfChatPacket(payload || {{}});
          if (messageId) {{
            seenKeys.add(`id:${{messageId}}`);
          }}
          consoleInteractiveSession = {{
            name: "zork-remote",
            mode: "remote",
            targetNodeId: target.nodeId,
            targetLabel: target.targetLabel || target.nodeId,
            channelIndex: target.channelIndex,
            channelLabel: target.channelLabel,
            seenKeys,
          }};
          syncConsoleCommandInputState();
          requestImmediatePoll(80);
          return [
            `[zork-remote] started with ${{target.targetLabel || target.nodeId}} on ${{target.channelLabel}}.`,
            "[zork-remote] type game commands directly here. Use /help for console commands. Press Ctrl+C to stop this console session.",
          ];
        }},
      }});
    }}

    function formatConsoleLine(entry, verbosity = 0) {{
      const s = entry.summary || {{}};
      const packet = entry && entry.packet && typeof entry.packet === "object"
        ? entry.packet
        : {{}};
      const hops = (s.hop_start != null && s.hop_limit != null)
        ? Number(s.hop_start) - Number(s.hop_limit)
        : "n/a";
      const packetId = packet.id ?? packet.packet_id ?? packet.message_id ?? s.packet_id ?? "";
      const channel = packet.channel ?? s.channel ?? "";
      const textSnippetRaw = String(
        s.text ?? s.decoded_text ?? s.payload_text ?? packet.text ?? ""
      ).trim();
      const textSnippet = textSnippetRaw ? compactInlineMessage(textSnippetRaw, 88) : "";
      const sanitizeConsolePreviewValue = (value, depth = 0) => {{
        if (depth > 4) return "[depth-limit]";
        if (Array.isArray(value)) {{
          const limited = value.slice(0, 6).map((item) => sanitizeConsolePreviewValue(item, depth + 1));
          if (value.length > limited.length) {{
            limited.push(`... +${{value.length - limited.length}} items`);
          }}
          return limited;
        }}
        if (value && typeof value === "object") {{
          const out = {{}};
          for (const [key, rawVal] of Object.entries(value)) {{
            const keyLower = String(key || "").toLowerCase();
            if (keyLower === "raw") continue;
            out[key] = sanitizeConsolePreviewValue(rawVal, depth + 1);
          }}
          return out;
        }}
        if (typeof value === "string") {{
          const squashed = value
            .replace(/\r\n/g, "\n")
            .replace(/\r/g, "\n")
            .replace(/\\r\\n|\\n|\\r/g, " ")
            .replace(/\s+/g, " ")
            .trim();
          return squashed.length > 96
            ? `${{squashed.slice(0, 96)}}... (+${{squashed.length - 96}} chars)`
            : squashed;
        }}
        return value;
      }};
      const compactConsoleFragment = (value, maxChars = consolePacketPreviewMaxChars) => {{
        const text = String(value == null ? "" : value)
          .replace(/\\r\\n|\\n|\\r/g, " ")
          .replace(/\s+/g, " ")
          .trim();
        if (text.length <= maxChars) return text;
        const keep = Math.max(72, maxChars - 1);
        const hidden = Math.max(0, text.length - keep);
        return `${{text.slice(0, keep).trimEnd()}}… (+${{hidden}} chars)`;
      }};
      const packetPreview = (() => {{
        try {{
          const cleaned = sanitizeConsolePreviewValue(packet);
          const json = JSON.stringify(cleaned || {{}});
          return compactConsoleFragment(json);
        }} catch (_err) {{
          return "";
        }}
      }})();
      const summaryPreview = (() => {{
        try {{
          const cleaned = sanitizeConsolePreviewValue(s);
          const json = JSON.stringify(cleaned || {{}});
          return compactConsoleFragment(json);
        }} catch (_err) {{
          return "";
        }}
      }})();
      const parts = [
        `${{s.from || "n/a"}} -> ${{s.to || "n/a"}}`,
        `port=${{s.portnum || "n/a"}}`,
        `snr=${{s.rx_snr ?? "n/a"}}`,
        `rssi=${{s.rx_rssi ?? "n/a"}}`,
        `hops=${{hops}}`,
      ];
      if (channel !== "") parts.push(`ch=${{channel}}`);
      if (packetId !== "") parts.push(`id=${{packetId}}`);
      if (textSnippet) parts.push(`text=\"${{textSnippet.replace(/\"/g, "'")}}\"`);
      const lines = [parts.join(" ")];
      if (verbosity >= 1 && packetPreview) {{
        lines.push(`  pkt=${{packetPreview}}`);
      }}
      if (verbosity >= 2 && summaryPreview) {{
        lines.push(`  summary=${{summaryPreview}}`);
        const rawPayload = String(s.payload_hex ?? packet.payload ?? "").trim();
        const routeParts = [];
        if (s.hop_start != null) routeParts.push(`hop_start=${{s.hop_start}}`);
        if (s.hop_limit != null) routeParts.push(`hop_limit=${{s.hop_limit}}`);
        if (s.priority != null) routeParts.push(`priority=${{s.priority}}`);
        if (s.want_ack != null) routeParts.push(`want_ack=${{s.want_ack}}`);
        if (routeParts.length) {{
          lines.push(`  route=${{routeParts.join(" ")}}`);
        }}
        if (rawPayload) {{
          lines.push(`  payload=${{compactConsoleFragment(rawPayload, 220)}}`);
        }}
      }}
      if (verbosity >= 3) {{
        let prettyJson = "";
        try {{
          prettyJson = JSON.stringify(sanitizeConsolePreviewValue(entry ?? {{}}), null, 2) || "";
        }} catch (_err) {{
          try {{
            prettyJson = JSON.stringify(sanitizeConsolePreviewValue(s ?? {{}}), null, 2) || "";
          }} catch (_err2) {{
            prettyJson = "";
          }}
        }}
        if (prettyJson) {{
          lines.push("  json=");
          for (const jsonLine of String(prettyJson).split("\n")) {{
            lines.push(`    ${{jsonLine}}`);
          }}
        }}
      }}
      if (verbosity >= 4) {{
        let rawJson = "";
        try {{
          rawJson = JSON.stringify(entry ?? {{}}, null, 2) || "";
        }} catch (_err) {{
          rawJson = "";
        }}
        if (rawJson) {{
          lines.push("  raw=");
          for (const jsonLine of String(rawJson).split("\n")) {{
            lines.push(`    ${{jsonLine}}`);
          }}
        }}
      }}
      return lines;
    }}

    function formatConsoleTimestamp(msValue) {{
      const ms = Number(msValue);
      const dt = Number.isFinite(ms) ? new Date(ms) : new Date();
      if (!Number.isFinite(dt.getTime())) {{
        return "n/a";
      }}
      const pad2 = (value) => String(Math.trunc(Math.max(0, Number(value) || 0))).padStart(2, "0");
      const hour = pad2(dt.getHours());
      const minute = pad2(dt.getMinutes());
      const second = pad2(dt.getSeconds());
      return `${{hour}}:${{minute}}:${{second}}`;
    }}

    function appendConsoleLine(key, line, loggedAtMs = Date.now(), renderNow = false) {{
      if (!key || consoleSeen.has(key)) return;
      consoleSeen.add(key);
      consoleKeyQueue.push(key);
      const timestamp = formatConsoleTimestamp(loggedAtMs);
      const body = String(line == null ? "" : line);
      consoleLines.push(`[${{timestamp}}] > ${{body}}`);

      while (consoleLines.length > consoleMaxLines) {{
        consoleLines.shift();
        const oldKey = consoleKeyQueue.shift();
        if (oldKey) {{
          consoleSeen.delete(oldKey);
        }}
      }}
      persistConsoleSessionState();
      if (renderNow) {{
        renderConsoleBuffer();
      }}
    }}

    async function runConsoleCommandLine(rawLine) {{
      const line = String(rawLine == null ? "" : rawLine).trim();
      if (!line) return;
      appendConsoleEventLine(`$ ${{line}}`);
      pushConsoleHistoryEntry(line);
      if (consoleRunningCommand) {{
        appendConsoleEventLine(
          `[console] "${{consoleRunningCommand.name}}" is running. Press Ctrl+C to stop before starting a new command.`
        );
        return;
      }}
      if (consoleInteractiveSession) {{
        const consoleEscape = line.startsWith("/") ? String(line.slice(1) || "").trim() : "";
        if (consoleEscape) {{
          const parsedEscape = parseConsoleCommandLine(consoleEscape);
          if (parsedEscape.error) {{
            appendConsoleEventLine(`[console] parse error: ${{parsedEscape.error}}`);
            return;
          }}
          await executeConsoleCommand(parsedEscape, consoleEscape);
          return;
        }}
        try {{
          const result = await sendConsoleInteractiveSessionLine(line);
          const text = String(result == null ? "" : result).trim();
          if (text) {{
            appendConsoleEventLine(text);
          }}
        }} catch (err) {{
          const msg = err instanceof Error ? err.message : String(err || "unknown error");
          const activeSession = consoleInteractiveSession;
          if (
            activeSession
            && String(activeSession.mode || "") === "standalone"
            && isStandaloneConsoleSessionExpiredMessage(msg)
          ) {{
            stopConsoleInteractiveSession("server session expired", false);
            appendConsoleEventLine("[zork] session expired on server. Console mode restored. Type \"zork\" to start again.");
            const retryParsed = parseConsoleCommandLine(line);
            if (!retryParsed.error) {{
              ensureConsoleCommandsRegistered();
              if (consoleCommandRegistry.has(retryParsed.command)) {{
                await executeConsoleCommand(retryParsed, line);
              }}
            }}
            return;
          }}
          appendConsoleEventLine(`[${{String((activeSession && activeSession.name) || "session")}}] error: ${{msg}}`);
        }}
        return;
      }}
      const parsed = parseConsoleCommandLine(line);
      if (parsed.error) {{
        appendConsoleEventLine(`[console] parse error: ${{parsed.error}}`);
        return;
      }}
      await executeConsoleCommand(parsed, line);
    }}

    function bindConsoleControls() {{
      ensureConsoleCommandsRegistered();
      const clearBtn = document.getElementById("console-clear-btn");
      if (clearBtn instanceof HTMLButtonElement && clearBtn.dataset.bound !== "1") {{
        clearBtn.dataset.bound = "1";
        clearBtn.addEventListener("click", () => {{
          clearConsoleOutput();
        }});
      }}

      const auto = document.getElementById("console-autoscroll");
      if (auto instanceof HTMLInputElement && auto.dataset.bound !== "1") {{
        auto.dataset.bound = "1";
        auto.checked = !!consoleAutoscroll;
        auto.addEventListener("change", () => {{
          consoleAutoscroll = auto.checked;
          persistConsoleSessionState();
          if (consoleAutoscroll) {{
            renderConsoleBuffer(true);
          }}
        }});
      }}
      const fontSizeSelect = document.getElementById("console-font-size-select");
      if (fontSizeSelect instanceof HTMLSelectElement) {{
        fontSizeSelect.value = normalizeConsoleFontSize(consoleFontSize);
        if (fontSizeSelect.dataset.bound !== "1") {{
          fontSizeSelect.dataset.bound = "1";
          fontSizeSelect.addEventListener("change", () => {{
            consoleFontSize = normalizeConsoleFontSize(fontSizeSelect.value);
            fontSizeSelect.value = consoleFontSize;
            persistConsoleFontSizePreference();
            applyConsoleFontSizePreference();
            renderConsoleBuffer(false);
          }});
        }}
      }}
      const pre = document.getElementById("live-console");
      if (pre instanceof HTMLElement && pre.dataset.scrollBound !== "1") {{
        pre.dataset.scrollBound = "1";
        pre.addEventListener("scroll", () => {{
          const maxTop = Math.max(0, pre.scrollHeight - pre.clientHeight);
          const remaining = Math.max(0, maxTop - pre.scrollTop);
          const atBottom = remaining <= 3;
          if (consoleAutoscroll !== atBottom) {{
            consoleAutoscroll = atBottom;
          }}
          const autoBox = document.getElementById("console-autoscroll");
          if (autoBox instanceof HTMLInputElement && autoBox.checked !== consoleAutoscroll) {{
            autoBox.checked = consoleAutoscroll;
          }}
        }});
        pre.addEventListener("mouseup", () => {{
          void copyConsoleSelectionToClipboard();
        }});
      }}
      const terminalScreen = document.getElementById("console-terminal-screen");
      if (terminalScreen instanceof HTMLElement && terminalScreen.dataset.bound !== "1") {{
        terminalScreen.dataset.bound = "1";
        terminalScreen.addEventListener("click", (ev) => {{
          const target = ev.target;
          if (target instanceof HTMLElement && target.closest("#live-console")) return;
          if (target instanceof HTMLInputElement || target instanceof HTMLButtonElement) return;
          focusConsoleCommandInput(false);
        }});
      }}
      applyConsoleFontSizePreference();
      const form = document.getElementById("console-command-form");
      const input = document.getElementById("console-command-input");
      if (form instanceof HTMLFormElement && input instanceof HTMLInputElement && form.dataset.bound !== "1") {{
        form.dataset.bound = "1";
        form.addEventListener("submit", (ev) => {{
          ev.preventDefault();
          const cmdLine = input.value;
          input.value = "";
          consoleCommandHistoryCursor = -1;
          consoleCommandDraft = "";
          void runConsoleCommandLine(cmdLine);
          focusConsoleCommandInput(false);
        }});
      }}
      if (input instanceof HTMLInputElement && input.dataset.bound !== "1") {{
        input.dataset.bound = "1";
        input.addEventListener("keydown", (ev) => {{
          if ((ev.ctrlKey || ev.metaKey) && !ev.shiftKey && !ev.altKey && String(ev.key || "").toLowerCase() === "c") {{
            if (consoleRunningCommand || consoleInteractiveSession) {{
              ev.preventDefault();
              appendConsoleEventLine("^C");
              if (!stopConsoleRunningCommand("interrupted", true)) {{
                stopConsoleInteractiveSession("interrupted", true);
              }}
              input.value = "";
              consoleCommandHistoryCursor = -1;
              consoleCommandDraft = "";
            }}
            return;
          }}
          if (ev.key === "ArrowUp" && !ev.shiftKey && !ev.ctrlKey && !ev.metaKey && !ev.altKey) {{
            ev.preventDefault();
            navigateConsoleHistory(-1, input);
            return;
          }}
          if (ev.key === "ArrowDown" && !ev.shiftKey && !ev.ctrlKey && !ev.metaKey && !ev.altKey) {{
            ev.preventDefault();
            navigateConsoleHistory(1, input);
          }}
        }});
      }}
      syncConsoleCommandInputState();
      if (!consoleLines.length) {{
        appendConsoleEventLine("[console] type \"help\" for commands. Start standalone Zork with \"zork\". Start live stream with \"live\", \"live -v\", \"live -vv\", \"live -vvv\", or \"live -vvvv\".");
      }} else {{
        renderConsoleBuffer(false);
      }}
    }}

    function renderConsole(traffic) {{
      if (consoleLiveModeActive) {{
        const packets = Array.isArray(traffic && traffic.recent_packets) ? traffic.recent_packets : [];
        for (const entry of packets) {{
          const key = packetConsoleKey(entry);
          const summary = entry && entry.summary && typeof entry.summary === "object" ? entry.summary : {{}};
          const packetUnix = latestUnixTimestamp(summary.captured_at, summary.rx_time);
          const packetMs = Number.isFinite(packetUnix) && packetUnix > 0
            ? packetUnix * 1000
            : Date.now();
          const lines = formatConsoleLine(entry, consoleLiveVerbosity);
          const lineList = Array.isArray(lines) ? lines : [String(lines == null ? "" : lines)];
          lineList.forEach((line, index) => {{
            appendConsoleLine(`${{key}}|${{index}}`, line, packetMs);
          }});
        }}
      }}
      syncConsoleInteractiveSessionMessages(latestState);
      renderConsoleBuffer();
    }}

