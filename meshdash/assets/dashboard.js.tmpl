    function renderNodeHistoryLoading(nodeId) {{
      setMapDataMode("node");
      resetSignalChartZoom(nodeId || "");
      signalChartPoints = [];
      const caption = document.getElementById("node-history-caption");
      if (caption) {{
        caption.textContent = `Loading history for ${{nodeId}}...`;
      }}
