    function collectNewNodeFirstSeenUnix(state = latestState) {{
      const safeState = (state && typeof state === "object") ? state : {{}};
      const firstSeenByNodeId = new Map();
      const rememberFirstSeen = (nodeIdRaw, firstSeenRaw) => {{
        const nodeId = normalizeNodeId(nodeIdRaw);
        if (!isSelectableNodeId(nodeId)) return;
        const firstSeenUnix = Number(firstSeenRaw);
        if (!Number.isFinite(firstSeenUnix) || firstSeenUnix <= 0) return;
        const cleanFirstSeen = Math.trunc(firstSeenUnix);
        const existing = Number(firstSeenByNodeId.get(nodeId));
        if (!Number.isFinite(existing) || cleanFirstSeen < existing) {{
          firstSeenByNodeId.set(nodeId, cleanFirstSeen);
        }}
      }};

      const historyCapsRaw = (safeState.history_caps && typeof safeState.history_caps === "object")
        ? safeState.history_caps
        : {{}};
      for (const rawNodeId of Object.keys(historyCapsRaw)) {{
        const caps = historyCapsRaw[rawNodeId];
        rememberFirstSeen(rawNodeId, caps && caps.first_seen_unix);
      }}

      const nodes = Array.isArray(safeState.nodes) ? safeState.nodes : [];
      for (const node of nodes) {{
        rememberFirstSeen(node && node.id, node && node.first_seen_unix);
      }}

      return Array.from(firstSeenByNodeId.values())
        .filter((value) => Number.isFinite(value) && value > 0)
        .sort((left, right) => Number(left) - Number(right));
    }}

    function countNewNodesFirstSeenInWindow(firstSeenUnixValues, bucketUnix, windowSeconds = 24 * 60 * 60) {{
      const safeBucketUnix = Number(bucketUnix);
      if (!Number.isFinite(safeBucketUnix) || safeBucketUnix <= 0) return null;
      const safeWindowSeconds = Math.max(1, Math.trunc(Number(windowSeconds) || (24 * 60 * 60)));
      const windowStartUnix = safeBucketUnix - safeWindowSeconds;
      const values = Array.isArray(firstSeenUnixValues) ? firstSeenUnixValues : [];
      let count = 0;
      for (const firstSeenUnixRaw of values) {{
        const firstSeenUnix = Number(firstSeenUnixRaw);
        if (!Number.isFinite(firstSeenUnix) || firstSeenUnix <= 0) continue;
        if (firstSeenUnix > safeBucketUnix) break;
        if (firstSeenUnix >= windowStartUnix) count += 1;
      }}
      return count;
    }}

    function buildWeeklySummaryChartRows(summaryHistory, metricKey, options = {{}}) {{
      const normalizedMetric = normalizeWeeklySummaryMetric(metricKey);
      const opts = (options && typeof options === "object") ? options : {{}};
      const payload = (summaryHistory && typeof summaryHistory === "object") ? summaryHistory : {{}};
      const points = Array.isArray(payload.points) ? payload.points : [];
      const rows = [];
      const packetRateMetric = normalizedMetric === "packets";
      const nodesMetric = normalizedMetric === "nodes";
      const linksMetric = normalizedMetric === "links";
      const linkMode = normalizeNetworkOverviewLinkMode(opts.linkMode || "history");
      const packetSeries = (opts.packetSeries && typeof opts.packetSeries === "object")
        ? normalizeNetworkOverviewPacketSeries(opts.packetSeries)
        : null;
      const packetSeriesPayload = (payload.packet_series && typeof payload.packet_series === "object")
        ? payload.packet_series
        : null;
      const packetSeriesByKey = (
        packetSeriesPayload
        && packetSeriesPayload.series
        && typeof packetSeriesPayload.series === "object"
      ) ? packetSeriesPayload.series : null;
      const packetSeriesMetric = (
        packetRateMetric
        && !!packetSeries
        && !!packetSeriesByKey
        && packetSeriesPayload.available === true
      );
      let prevPacketBucketUnix = null;
      let prevPacketTotal = null;
      let prevLiveCounter = null;
      let packetPendingBreak = false;
      const continuitySeries = new Set(["real_edge_count"]);
      const continuityStateBySeries = new Map();
      const restartGaugeSeries = new Set(["known_nodes", "saved_nodes", "position_nodes"]);
      const restartGaugeStateBySeries = new Map();
      const newNodesWindowSeconds = 24 * 60 * 60;
      const newNodeFirstSeenUnixValues = nodesMetric
        ? collectNewNodeFirstSeenUnix(opts.state || latestState)
        : [];
      const continuityAdjustedValue = (seriesKey, rawValue, resetBreak) => {{
        const numeric = Number(rawValue);
        if (!Number.isFinite(numeric)) return null;
        if (!continuitySeries.has(seriesKey)) return numeric;
        let state = continuityStateBySeries.get(seriesKey);
        if (!(state && typeof state === "object")) {{
          state = {{ offset: 0, lastAdjusted: null }};
          continuityStateBySeries.set(seriesKey, state);
        }}
        if (
          resetBreak
          && Number.isFinite(state.lastAdjusted)
          && (numeric + 1 < Number(state.lastAdjusted))
        ) {{
          state.offset = Number(state.lastAdjusted) - numeric;
        }}
        const adjusted = numeric + Number(state.offset || 0);
        state.lastAdjusted = adjusted;
        return adjusted;
      }};
      const stabilizedRestartGaugeValue = (seriesKey, rawValue, resetBreak) => {{
        const numeric = Number(rawValue);
        if (!Number.isFinite(numeric)) return null;
        if (!restartGaugeSeries.has(seriesKey)) return numeric;
        let state = restartGaugeStateBySeries.get(seriesKey);
        if (!(state && typeof state === "object")) {{
          state = {{ floor: null, lastStable: null }};
          restartGaugeStateBySeries.set(seriesKey, state);
        }}
        if (
          resetBreak
          && Number.isFinite(state.lastStable)
          && (numeric + 1 < Number(state.lastStable))
        ) {{
          state.floor = Number(state.lastStable);
        }}
        const floor = Number(state.floor);
        let stable = numeric;
        if (Number.isFinite(floor) && numeric < floor) {{
          stable = floor;
        }} else if (Number.isFinite(floor) && numeric >= floor) {{
          state.floor = null;
        }}
        state.lastStable = stable;
        return stable;
      }};

      for (const point of points) {{
        if (!point || typeof point !== "object") continue;
        const bucketUnix = Number(point.bucket_unix);
        const bucketText = String(point.bucket_time || "").trim();
        const liveCounter = Number(point.live_packet_count);
        const resetBreak = hasLiveCounterReset(prevLiveCounter, liveCounter);
        if (Number.isFinite(liveCounter)) {{
          prevLiveCounter = liveCounter;
        }}
        if (packetRateMetric) {{
          if (packetSeriesMetric) {{
            continue;
          }}
          const packetTotal = liveCounter;
          if (!Number.isFinite(bucketUnix) || !Number.isFinite(packetTotal) || bucketUnix <= 0) continue;
          if (Number.isFinite(prevPacketBucketUnix) && Number.isFinite(prevPacketTotal) && bucketUnix > prevPacketBucketUnix) {{
            if (hasLiveCounterReset(prevPacketTotal, packetTotal)) {{
              packetPendingBreak = true;
              prevPacketBucketUnix = bucketUnix;
              prevPacketTotal = packetTotal;
              continue;
            }}
            const spanMinutes = Math.max(1 / 60, (bucketUnix - prevPacketBucketUnix) / 60);
            const packetRate = Math.max(0, (packetTotal - prevPacketTotal) / spanMinutes);
            rows.push({{
              value: packetRate,
              totalValue: packetTotal,
              bucketText,
              bucketUnix,
              breakBefore: packetPendingBreak,
            }});
            packetPendingBreak = false;
          }}
          prevPacketBucketUnix = bucketUnix;
          prevPacketTotal = packetTotal;
          continue;
        }}
        if (linksMetric) {{
          const historyValue = Number(point.edge_count);
          const liveValue = continuityAdjustedValue("real_edge_count", point.real_edge_count, resetBreak);
          const seriesValues = {{}};
          if (linkMode !== "live" && Number.isFinite(historyValue)) {{
            seriesValues.links = historyValue;
          }}
          if (linkMode !== "history" && Number.isFinite(liveValue)) {{
            seriesValues.real_links = liveValue;
          }}
          const value = linkMode === "live"
            ? liveValue
            : (linkMode === "both"
              ? (Number.isFinite(liveValue) ? liveValue : historyValue)
              : historyValue);
          if (!Number.isFinite(value) || !Object.keys(seriesValues).length) continue;
          rows.push({{
            value,
            series: seriesValues,
            linkCount: Number.isFinite(historyValue) ? historyValue : null,
            realLinkCount: Number.isFinite(liveValue) ? liveValue : null,
            bucketText,
            bucketUnix: Number.isFinite(bucketUnix) && bucketUnix > 0 ? bucketUnix : null,
          }});
          continue;
        }}
        if (!nodesMetric) {{
          continue;
        }}
        const onlineValue = Number(point.online_node_count);
        const knownRawValue = Number(point.node_count);
        const savedRawValue = Number(point.saved_node_count);
        const positionRawValue = Number(point.nodes_with_position);
        const knownObservedValue = Number.isFinite(knownRawValue) && Number.isFinite(savedRawValue)
          ? Math.max(knownRawValue, savedRawValue)
          : (Number.isFinite(knownRawValue) ? knownRawValue : savedRawValue);
        const knownValue = stabilizedRestartGaugeValue("known_nodes", knownObservedValue, resetBreak);
        const savedValue = stabilizedRestartGaugeValue("saved_nodes", savedRawValue, resetBreak);
        const positionValue = stabilizedRestartGaugeValue("position_nodes", positionRawValue, resetBreak);
        const bucketUnixForNew = Number.isFinite(bucketUnix) && bucketUnix > 0 ? bucketUnix : null;
        const newNodesValue = countNewNodesFirstSeenInWindow(
          newNodeFirstSeenUnixValues,
          bucketUnixForNew,
          newNodesWindowSeconds
        );
        const primaryValue = Number.isFinite(onlineValue) ? onlineValue : knownValue;
        if (!Number.isFinite(primaryValue)) continue;
        const seriesValues = {{}};
        if (Number.isFinite(onlineValue)) seriesValues.online_nodes = onlineValue;
        if (Number.isFinite(newNodesValue)) seriesValues.new_nodes = newNodesValue;
        if (Number.isFinite(knownValue)) seriesValues.known_nodes = knownValue;
        if (Number.isFinite(savedValue)) seriesValues.saved_nodes = savedValue;
        if (Number.isFinite(positionValue)) seriesValues.position_nodes = positionValue;
        rows.push({{
          value: primaryValue,
          series: seriesValues,
          newNodeCount: Number.isFinite(newNodesValue) ? newNodesValue : null,
          knownNodeCount: Number.isFinite(knownValue) ? knownValue : null,
          savedNodeCount: Number.isFinite(savedValue) ? savedValue : null,
          positionNodeCount: Number.isFinite(positionValue) ? positionValue : null,
          bucketText,
          bucketUnix: Number.isFinite(bucketUnix) && bucketUnix > 0 ? bucketUnix : null,
        }});
      }}

      if (packetSeriesMetric) {{
        const bucketSeconds = Math.max(1, Number(payload.bucket_seconds) || 60);
        const packetRateScale = 60 / bucketSeconds;
        const selectedPacketSeriesKeys = networkOverviewPacketSeriesOrder.filter((key) => packetSeries[key]);
        const packetSeriesLookups = new Map();
        const bucketPointMap = new Map();
        for (const point of points) {{
          if (!point || typeof point !== "object") continue;
          const bucketUnix = Number(point.bucket_unix);
          if (!Number.isFinite(bucketUnix) || bucketUnix <= 0) continue;
          bucketPointMap.set(bucketUnix, point);
        }}
        for (const key of networkOverviewPacketSeriesOrder) {{
          const lookup = new Map();
          const seriesRows = Array.isArray(packetSeriesByKey[key]) ? packetSeriesByKey[key] : [];
          for (const row of seriesRows) {{
            if (!row || typeof row !== "object") continue;
            const bucketUnix = Number(row.bucket_unix);
            const packetCount = Number(row.packet_count);
            if (!Number.isFinite(bucketUnix) || bucketUnix <= 0) continue;
            if (!Number.isFinite(packetCount) || packetCount <= 0) continue;
            lookup.set(bucketUnix, packetCount);
            if (!bucketPointMap.has(bucketUnix)) {{
              bucketPointMap.set(bucketUnix, {{
                bucket_unix: bucketUnix,
                bucket_time: "",
              }});
            }}
          }}
          packetSeriesLookups.set(key, lookup);
        }}
        const orderedPacketPoints = Array.from(bucketPointMap.values())
          .slice()
          .sort((left, right) => Number(left.bucket_unix) - Number(right.bucket_unix));
        for (const point of orderedPacketPoints) {{
          if (!point || typeof point !== "object") continue;
          const bucketUnix = Number(point.bucket_unix);
          if (!Number.isFinite(bucketUnix) || bucketUnix <= 0) continue;
          const bucketText = String(point.bucket_time || "").trim();
          const liveCounter = Number(point.live_packet_count);
          const seriesValues = {{}};
          let primaryValue = null;
          for (const key of selectedPacketSeriesKeys) {{
            const lookup = packetSeriesLookups.get(key);
            const packetCount = lookup instanceof Map ? Number(lookup.get(bucketUnix) || 0) : 0;
            const packetRate = Math.max(0, packetCount) * packetRateScale;
            seriesValues[key] = packetRate;
            if (primaryValue === null) {{
              primaryValue = packetRate;
            }}
          }}
          if (primaryValue === null) continue;
          rows.push({{
            value: primaryValue,
            series: seriesValues,
            totalValue: Number.isFinite(liveCounter) ? liveCounter : null,
            bucketText,
            bucketUnix,
          }});
        }}
      }}

      let chartRows = rows;
      if (nodesMetric && rows.length > 0) {{
        const firstPositiveIndex = rows.findIndex((row) => Number(row && row.value) > 0);
        if (firstPositiveIndex > 0) {{
          chartRows = rows.slice(firstPositiveIndex);
        }}
      }}

      return {{
        payload,
        chartRows,
        packetRateMetric,
        packetSeriesMetric,
        nodesMetric,
        linksMetric,
      }};
    }}

    function renderWeeklySummaryForTarget(summaryHistory, options = {{}}) {{
      const opts = (options && typeof options === "object") ? options : {{}};
      const target = resolveWeeklySummaryRenderTarget(opts.targetKey || "network-overview");
      const metricKey = normalizeWeeklySummaryMetric(opts.metricKey || networkOverviewMetric);
      const nodeSeries = normalizeWeeklySummaryNodeSeries(
        opts.nodeSeries || networkOverviewNodeSeriesEnabled
      );
      const packetSeries = (opts.packetSeries && typeof opts.packetSeries === "object")
        ? normalizeNetworkOverviewPacketSeries(opts.packetSeries)
        : null;
      const metricMeta = resolveWeeklySummaryMetricMeta(metricKey, nodeSeries, packetSeries, opts.linkMode);
      const built = buildWeeklySummaryChartRows(summaryHistory, metricKey, {{
        targetKey: target.key,
        packetSeries,
        linkMode: opts.linkMode,
      }});
      const chartRows = built.chartRows;
      const payload = built.payload;
      const packetRateMetric = built.packetRateMetric;
      const packetSeriesMetric = built.packetSeriesMetric;
      const nodesMetric = built.nodesMetric;
      const linksMetric = built.linksMetric;

      const caption = document.getElementById(target.captionId);
      const overview = document.getElementById(target.overviewId);
      const svg = document.getElementById(target.svgId);
      const empty = document.getElementById(target.emptyId);
      if (!(svg instanceof SVGElement) || !(empty instanceof HTMLElement)) return;
      if (!(overview instanceof HTMLElement)) return;

      const emptyMessage = packetSeriesMetric
        ? "No packet activity yet in this window."
        : (packetRateMetric
          ? "Need at least two saved samples to estimate packets/min."
          : "No weekly summary history yet.");
      const captionPrefix = String(target.captionPrefix || "Weekly trend for").trim();

      if (chartRows.length === 0) {{
        overview.innerHTML = "";
        renderWeeklySummaryChartRows([], metricMeta, emptyMessage, {{ targetKey: target.key }});
        if (caption) {{
          caption.textContent = `${{captionPrefix}} ${{metricMeta.label}}. ${{emptyMessage}}`;
        }}
        return;
      }}

      const rendered = renderWeeklySummaryChartRows(
        chartRows,
        metricMeta,
        emptyMessage,
        {{ targetKey: target.key }}
      );
      if (!rendered) {{
        overview.innerHTML = "";
        if (caption) {{
          caption.textContent = `${{captionPrefix}} ${{metricMeta.label}}. ${{emptyMessage}}`;
        }}
        return;
      }}

      const firstValue = Number(chartRows[0].value);
      const lastValue = Number(chartRows[chartRows.length - 1].value);
      const delta = lastValue - firstValue;
      const values = chartRows
        .map((row) => Number(row.value))
        .filter((value) => Number.isFinite(value));
      const avg = values.reduce((sum, value) => sum + value, 0) / Math.max(1, values.length);
      const averageDecimals = metricKey === "nodes" || metricKey === "links"
        ? Math.max(1, Number(metricMeta.decimals) || 0)
        : metricMeta.decimals;
      const windowHours = Number(payload.window_hours);
      const startLabel = chartRows[0].bucketText || "";
      const endLabel = chartRows[chartRows.length - 1].bucketText || "";
      if (caption) {{
        const selectedNodeSeriesLabels = Array.isArray(metricMeta && metricMeta.seriesOrder)
          ? metricMeta.seriesOrder.map((seriesKey) => (
            String((metricMeta.seriesLabels && metricMeta.seriesLabels[seriesKey]) || seriesKey)
          ))
          : [];
        const compareNote = nodesMetric
          ? (selectedNodeSeriesLabels.length > 1
            ? ` Showing lines: ${{selectedNodeSeriesLabels.join(", ")}}.`
            : ` Showing ${{selectedNodeSeriesLabels[0] || "Online Nodes"}} line.`)
          : (packetSeriesMetric
            ? (selectedNodeSeriesLabels.length > 1
              ? ` Showing lines: ${{selectedNodeSeriesLabels.join(", ")}}.`
              : ` Showing ${{selectedNodeSeriesLabels[0] || "All Packets"}} line.`)
            : (linksMetric && selectedNodeSeriesLabels.length
              ? (selectedNodeSeriesLabels.length > 1
                ? ` Showing lines: ${{selectedNodeSeriesLabels.join(", ")}}.`
                : ` Showing ${{selectedNodeSeriesLabels[0] || "Links"}} line.`)
              : ""));
        caption.textContent = `${{captionPrefix}} ${{metricMeta.label}}. Window: ${{Number.isFinite(windowHours) ? windowHours : networkOverviewWindowHours}}h, samples: ${{chartRows.length}}.${{compareNote}}`;
      }}

      const items = [
        ["Metric", metricMeta.label],
        ["Window", `${{Number.isFinite(windowHours) ? Math.round(windowHours) : networkOverviewWindowHours}}h`],
        ["Samples", String(chartRows.length)],
        ["Latest", formatMetricValue(lastValue, metricMeta.decimals)],
        ["Delta", formatMetricValue(delta, metricMeta.decimals)],
        ["Average", formatMetricValue(avg, averageDecimals)],
        ["Peak", formatMetricValue(Math.max(...values), metricMeta.decimals)],
        ["Range", `${{startLabel || "n/a"}} to ${{endLabel || "n/a"}}`],
      ];
      if (packetRateMetric) {{
        const latestTotal = Number(chartRows[chartRows.length - 1] && chartRows[chartRows.length - 1].totalValue);
        if (Number.isFinite(latestTotal)) {{
          items.push(["Total Packets", formatMetricValue(latestTotal, 0)]);
        }}
      }} else if (nodesMetric) {{
        const latestRow = chartRows[chartRows.length - 1] || null;
        const latestKnownNodes = Number(latestRow && latestRow.knownNodeCount);
        const latestSavedNodes = Number(latestRow && latestRow.savedNodeCount);
        const latestPositionNodes = Number(latestRow && latestRow.positionNodeCount);
        const latestNewNodes = Number(latestRow && latestRow.newNodeCount);
        if (Number.isFinite(latestNewNodes)) {{
          items.push(["New Nodes (24h)", formatMetricValue(latestNewNodes, 0)]);
        }}
        if (Number.isFinite(latestKnownNodes)) {{
          items.push(["Known Nodes (Radio)", formatMetricValue(latestKnownNodes, 0)]);
        }}
        if (Number.isFinite(latestSavedNodes)) {{
          items.push(["Saved Nodes (DB)", formatMetricValue(latestSavedNodes, 0)]);
        }}
        if (Number.isFinite(latestPositionNodes)) {{
          items.push(["Nodes With Position", formatMetricValue(latestPositionNodes, 0)]);
        }}
        if (Number.isFinite(latestSavedNodes) && Number.isFinite(latestKnownNodes)) {{
          if (latestKnownNodes > 0) {{
            const ratioPercent = (latestSavedNodes / latestKnownNodes) * 100;
            items.push(["Saved / Known", `${{formatMetricValue(ratioPercent, 1)}}%`]);
          }} else {{
            items.push(["Saved / Known", "n/a"]);
          }}
        }}
      }} else if (linksMetric) {{
        const latestRow = chartRows[chartRows.length - 1] || null;
        const latestHistoryLinks = Number(latestRow && latestRow.linkCount);
        const latestLiveLinks = Number(latestRow && latestRow.realLinkCount);
        if (Number.isFinite(latestHistoryLinks)) {{
          items.push(["History Links", formatMetricValue(latestHistoryLinks, 0)]);
        }}
        if (Number.isFinite(latestLiveLinks)) {{
          items.push(["Live Links", formatMetricValue(latestLiveLinks, 0)]);
        }}
      }}
      const hiddenOverviewKeys = new Set(["Metric", "Window", "Range"]);
      overview.innerHTML = items
        .filter(([key]) => !hiddenOverviewKeys.has(String(key || "").trim()))
        .map(([k, v]) => (
          `<div class="overview-item"><div class="k">${{k}}</div><div class="v">${{v}}</div></div>`
        )).join("");
    }}

    function renderNetworkOverviewSummary(summaryHistory) {{
      renderWeeklySummaryForTarget(summaryHistory, {{
        targetKey: "network-overview",
        metricKey: normalizeNetworkOverviewMetric(networkOverviewMetric),
        nodeSeries: networkOverviewNodeSeriesEnabled,
        packetSeries: networkOverviewPacketSeriesEnabled,
        linkMode: networkOverviewLinkMode,
      }});
    }}
