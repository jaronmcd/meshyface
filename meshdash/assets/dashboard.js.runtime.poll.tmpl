          scheduleFileTransferMaintenance(state);
          markPollPerfPhase(pollPerfRun, "hidden-maintenance");
          pollPerfStatus = "hidden";
          pollPerfExtra = {{ httpStatus: resp.status, profile: pollProfile }};
          return;
        }}
        if (!summaryMetricsHydrated && !summaryMetricsHydrateInFlight) {{
          summaryMetricsHydrateInFlight = hydrateSummaryMetricTickers()
            .finally(() => {{
              summaryMetricsHydrateInFlight = null;
            }});
        }}
        if (
          activeLayoutView === "network"
          && !networkSubviewUsesMap(activeNetworkSubview)
          && typeof renderChatNodeNavigatorList === "function"
        ) {{
          renderChatNodeNavigatorList(state);
        }}
        markPollPerfPhase(pollPerfRun, "pre-render");

        const networkMapActive = activeLayoutView === "network" && networkSubviewUsesMap(activeNetworkSubview);
        const mapVisible = activeLayoutView === "saved" || networkMapActive;
        const trafficVisible = mapVisible || activeLayoutView === "history";
        const drawerHistoryVisible = (
          typeof isChatNodeDetailsDrawerExpanded === "function"
          && isChatNodeDetailsDrawerExpanded()
        );
        const historyTargetId = activeLayoutView === "saved"
          ? resolveSavedViewNodeId(state)
          : normalizeNodeId(selectedNodeId || "");
        const historyRelevant = (activeLayoutView === "saved" || networkMapActive || drawerHistoryVisible)
          && (mapDataFocus !== "activity" || drawerHistoryVisible)
          && isSelectableNodeId(historyTargetId);
        const cachedHistory = historyRelevant ? cachedNodeHistory(historyTargetId) : null;
        const networkGraphActive = activeLayoutView === "network" && activeNetworkSubview === "graph" && !networkSubviewUsesMap(activeNetworkSubview);
        const networkOverviewActive = activeLayoutView === "network" && activeNetworkSubview === "overview";
        const networkRoutesActive = activeLayoutView === "network" && activeNetworkSubview === "routes";
        const networkTopNodesActive = activeLayoutView === "network" && activeNetworkSubview === "top10";
        const networkNodesTableActive = activeLayoutView === "network" && (networkMapActive || networkOverviewActive);

        if (mapVisible && !mapBootstrapFocusDone) {{
          const bootstrap = applyMapBootstrapFocus(state.nodes || [], state);
          if (bootstrap.didFocus) {{
            mapBootstrapFocusDone = true;
            if (activeLayoutView === "network") {{
              // Network view should start from the broadest useful overview and not
              // immediately fight that bootstrap focus with a second auto-fit.
              fitDone = true;
            }}
            // Let the map paint at the initial focus target before heavier render work.
            await nextAnimationFrame();
          }}
        }}
        markPollPerfPhase(pollPerfRun, "map-bootstrap");

        const activeSummaryWindowHours = activeLayoutView === "network"
          ? networkOverviewWindowHours
          : weeklySummaryWindowHours;
        const activeSummaryIncludePacketSeries = activeLayoutView === "history"
          ? historySummaryNeedsPacketSeries()
          : networkOverviewSummaryNeedsPacketSeries();
        const weeklySummaryPromise = (
          activeLayoutView === "history"
          || networkOverviewActive
        )
          ? fetchSummaryMetrics(activeSummaryWindowHours, {{
              includePacketSeries: activeSummaryIncludePacketSeries,
            }}).catch((summaryErr) => ({{
              error: summaryErr instanceof Error
                ? summaryErr.message
                : String(summaryErr || "unknown error"),
            }}))
          : null;
        // Summary metrics now live in the global header ticker row, so keep them
        // refreshed for every active view.
        renderSummary(state);
        markPollPerfPhase(pollPerfRun, "render-summary", {{
          weeklySummary: !!weeklySummaryPromise,
        }});

        if (mapVisible) {{
          renderMap(state.nodes || [], (state.traffic || {{}}).edges || [], cachedHistory);
        }}
        if (
          mapLiveActivityEnabled
          && typeof isNetworkMapActivityFlashVisible === "function"
          && isNetworkMapActivityFlashVisible()
        ) {{
          syncNetworkMapPacketActivity(state);
        }}
        markPollPerfPhase(pollPerfRun, "render-map", {{ mapVisible }});

        if (activeLayoutView === "network") {{
          if (networkNodesTableActive) {{
            renderNodes(state.nodes || []);
          }} else if (typeof clearHiddenNodesTable === "function") {{
            clearHiddenNodesTable();
          }}
          if (networkGraphActive && typeof renderNetworkGraphView === "function") {{
            renderNetworkGraphView(state);
          }}
          if (networkRoutesActive && typeof renderNetworkRoutes === "function") {{
            renderNetworkRoutes(state);
          }}
          if (networkTopNodesActive && typeof renderNetworkTopNodes === "function") {{
            renderNetworkTopNodes(state);
          }}
        }}
        markPollPerfPhase(pollPerfRun, "render-network", {{
          networkGraphActive,
          networkMapActive,
        }});

        let weeklySummary = null;
        if (weeklySummaryPromise) {{
          weeklySummary = await weeklySummaryPromise;
        }}
        markPollPerfPhase(pollPerfRun, "summary-wait", {{
          weeklySummary: !!weeklySummaryPromise,
          summaryError: !!(weeklySummary && weeklySummary.error),
        }});

        if (trafficVisible) {{
          renderTraffic(state.traffic || {{}}, state.nodes || [], cachedHistory);
        }}
        if (activeLayoutView === "files") {{
          renderFilesView(state);
        }}
        if (activeLayoutView === "history") {{
          renderHistoryChat(state.traffic || {{}});
          renderEncription(state.traffic || {{}});
          if (weeklySummary && !weeklySummary.error) {{
            renderWeeklySummary(weeklySummary);
          }} else if (weeklySummary && weeklySummary.error) {{
            renderWeeklySummaryError(weeklySummary.error);
          }} else {{
            renderWeeklySummaryLoading();
          }}
        }}
        if (networkOverviewActive) {{
          if (weeklySummary && !weeklySummary.error) {{
            renderNetworkOverviewSummary(weeklySummary);
          }} else if (weeklySummary && weeklySummary.error) {{
            renderNetworkOverviewSummaryError(weeklySummary.error);
          }} else {{
            renderNetworkOverviewSummaryLoading();
          }}
        }}
        markPollPerfPhase(pollPerfRun, "render-view-data", {{
          trafficVisible,
          view: activeLayoutView,
          subview: activeNetworkSubview,
        }});

        const chatEntries = runPollStep("collectChatMessageEntries", () => collectChatMessageEntries(state), []);
        markPollPerfPhase(pollPerfRun, "chat-entries", {{
          entries: Array.isArray(chatEntries) ? chatEntries.length : 0,
        }});
        const hasFreshDirectEntry = chatEntries.some((entry) => {{
          if (!entry || entry.channel !== "direct") return false;
          if (entry.countsUnread === false) return false;
          const key = String(entry.key || "").trim();
          if (!key) return false;
          return !chatSeenMessageKeys.has(key);
        }});
        const shouldBackgroundRenderDirectChat = (
          !isChatWorkspaceLayoutView(activeLayoutView)
          && (
            hasFreshDirectEntry
            || isCanonicalNodeId(peerDmActivePeerId || "")
          )
        );
        let chatRenderedThisPoll = false;
        if (shouldBackgroundRenderDirectChat) {{
          runPollStep("renderChat.background", () => renderChat(state));
          chatRenderedThisPoll = true;
        }}

        if (
          !isChatWorkspaceLayoutView(activeLayoutView)
          && runPollStep("shouldHydrateNodeNavigatorRoster", () => shouldHydrateNodeNavigatorRoster(state), false)
        ) {{
          if (typeof renderChatNodeNavigatorList === "function") {{
            runPollStep("renderChatNodeNavigatorList.background", () => renderChatNodeNavigatorList(state));
          }} else {{
            if (!chatRenderedThisPoll) {{
              runPollStep("renderChat.backgroundFallback", () => renderChat(state));
              chatRenderedThisPoll = true;
            }}
          }}
        }}

        if (isChatWorkspaceLayoutView(activeLayoutView)) {{
          if (!chatRenderedThisPoll) {{
            runPollStep("renderChat.workspace", () => renderChat(state, {{ allowPollSkip: true }}));
            chatRenderedThisPoll = true;
          }}
          if (activeLayoutView === "chatlabs") {{
            runPollStep("renderChatLabsView", () => renderChatLabsView(state));
          }}
        }} else if (activeLayoutView === "bbs") {{
          runPollStep("renderBbsView", () => renderBbsView(state));
        }} else if (activeLayoutView === "bots") {{
          runPollStep("renderBotsView", () => renderBotsView(state));
        }} else if (activeLayoutView === "games") {{
          runPollStep("renderGamesView", () => renderGamesView(state));
        }} else if (activeLayoutView === "remote") {{
          runPollStep("renderRemoteView", () => renderRemoteView(state));
          if (!chatRenderedThisPoll) {{
            runPollStep("syncChatUnreadFromState.remote", () => syncChatUnreadFromState(state, {{ clearActiveWhenInChat: false }}));
          }}
          runPollStep("renderChatChangeSummary.remote", () => renderChatChangeSummary());
          runPollStep("bindChatChangeSummaryControls.remote", () => bindChatChangeSummaryControls());
        }} else {{
          if (!chatRenderedThisPoll) {{
            runPollStep("syncChatUnreadFromState.default", () => syncChatUnreadFromState(state, {{ clearActiveWhenInChat: false }}));
          }}
          runPollStep("renderChatChangeSummary.default", () => renderChatChangeSummary());
          runPollStep("bindChatChangeSummaryControls.default", () => bindChatChangeSummaryControls());
        }}
        markPollPerfPhase(pollPerfRun, "render-chat-block", {{
          chatRendered: chatRenderedThisPoll,
          backgroundDirect: shouldBackgroundRenderDirectChat,
        }});
        if (
          !chatRenderedThisPoll
          &&
          typeof syncChatNodeDetailsDrawer === "function"
          && typeof isChatNodeDetailsDrawerExpanded === "function"
          && isChatNodeDetailsDrawerExpanded()
        ) {{
          syncChatNodeDetailsDrawer(state, {{
            // Keep node-details history tabs live across non-chat screens too.
            fetchHistory: true,
          }});
        }}

        if (activeLayoutView === "saved") {{
          const loadingId = (activeLayoutView === "saved" && historyRelevant && !cachedHistory)
            ? historyTargetId
            : null;
          renderFavorites(state, cachedHistory, loadingId);
        }}

        if (
          activeLayoutView === "environment"
          || (activeLayoutView === "network" && activeNetworkSubview === "sensors")
        ) {{
          void renderEnvironmentMetricsView(false);
        }}

        if (activeLayoutView === "settings") {{
          renderSettings(state);
          if (activeSettingsTab === "channels") {{
            renderChannelsView(state);
          }} else if (activeSettingsTab === "nodes") {{
            renderNodeVisibilityListsUi(latestRawState || state || {{}});
          }}
        }}

        if (activeLayoutView === "console") {{
          renderConsole(state.traffic || {{}});
        }}
        markPollPerfPhase(pollPerfRun, "render-secondary-views", {{
          view: activeLayoutView,
          settingsTab: activeLayoutView === "settings" ? activeSettingsTab : "",
        }});

        if (historyRelevant) {{
          const cached = nodeHistoryCache.get(historyTargetId);
          const nowMs = Date.now();
          const ttlMs = Math.max(refreshMs * 2, 8000);
          const stale = !(cached && cached.data) || (nowMs - (cached.fetchedAt || 0)) >= ttlMs;
          if (stale) {{
            void refreshSelectedNodeHistory(false);
          }}
        }}


        scheduleFileTransferMaintenance(state);
        const freshnessTicked = maybeTickFreshnessUIForPoll(state, {{
          stateKey: responseStateEtag || stateEtag,
          force: !responseStateEtag || responseStateEtag !== previousStateEtag,
        }});
        markPollPerfPhase(pollPerfRun, "maintenance", {{
          historyRelevant,
          profile: pollProfile,
          freshnessTicked,
        }});
        pollPerfStatus = "ok";
        pollPerfExtra = {{ httpStatus: resp.status, profile: pollProfile }};
      }} catch (err) {{
        const msg = err instanceof Error ? err.message : String(err || "unknown error");
        pollPerfStatus = "error";
        pollPerfExtra = {{ message: msg }};
        lastPollError = msg;
        lastPollErrorUnix = Math.floor(Date.now() / 1000);
        setText("updated-at", `error: ${{msg}}`);
        renderRadioStatus(latestState || {{}});
        appendConsoleLine(`error|${{Date.now()}}|${{msg}}`, `[poll error] ${{msg}}`);
      }} finally {{
        finishPollPerfRun(pollPerfRun, pollPerfStatus, pollPerfExtra);
      }}
    }}
