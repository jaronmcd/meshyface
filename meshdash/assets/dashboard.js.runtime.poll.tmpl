    function shouldHydrateNodeNavigatorRoster(state = latestState) {{
      if (isChatWorkspaceLayoutView(activeLayoutView)) return false;
      const safeState = (state && typeof state === "object") ? state : null;
      if (!safeState) return false;
      const query = (typeof globalNodeSearchQuery === "function")
        ? String(globalNodeSearchQuery() || "").trim()
        : "";
      if (query) return false;
      const nodes = Array.isArray(safeState.nodes) ? safeState.nodes : [];
      if (nodes.length <= 0) return false;
      const roomList = (typeof document !== "undefined")
        ? document.getElementById("chat-room-list")
        : null;
      const visibleRosterCount = roomList instanceof HTMLElement
        ? roomList.querySelectorAll(".chat-member-item[data-node-id]").length
        : 0;
      if (visibleRosterCount <= 0) return true;
      const rosterModel = Array.isArray(chatRosterModel) ? chatRosterModel : [];
      if (rosterModel.length <= 0) return true;
      return activeChatChannel === "all" && nodes.length > rosterModel.length;
    }}

    function reportPollStepError(stepName, err) {{
      const message = err instanceof Error ? (err.message || String(err)) : String(err || "unknown error");
      if (typeof appendConsoleLine === "function") {{
        appendConsoleLine(`poll-step|${{Date.now()}}|${{stepName}}`, `[poll step error] ${{stepName}}: ${{message}}`);
      }}
      if (typeof console !== "undefined" && console && typeof console.error === "function") {{
        console.error(`[poll step error] ${{stepName}}`, err);
      }}
      if (typeof setText === "function") {{
        setText("updated-at", `poll warning: ${{stepName}}: ${{message}}`);
      }}
    }}

    function runPollStep(stepName, callback, fallbackValue = undefined) {{
      try {{
        return callback();
      }} catch (err) {{
        reportPollStepError(stepName, err);
        return fallbackValue;
      }}
    }}

    function statePollProfile() {{
      const drawerLinksActive = (
        typeof isChatNodeDetailsDrawerExpanded === "function"
        && isChatNodeDetailsDrawerExpanded()
        && typeof normalizeChatNodeDetailsDrawerTab === "function"
        && normalizeChatNodeDetailsDrawerTab(chatNodeDetailsDrawerTab) === "links"
      );
      if (isChatWorkspaceLayoutView(activeLayoutView) && !drawerLinksActive) {{
        return "chat";
      }}
      if (activeLayoutView === "network") {{
        return "network";
      }}
      return "default";
    }}

    async function poll() {{
      try {{
        const pollProfile = statePollProfile();
        const stateUrlBase = pollProfile === "chat"
          ? "/api/state?lite=1&profile=chat"
          : (pollProfile === "network"
            ? "/api/state?lite=1&profile=network"
            : "/api/state?lite=1");
        const stateUrl = forceStateReloadOnce
          ? `${{stateUrlBase}}&_=${{Date.now()}}`
          : stateUrlBase;
        forceStateReloadOnce = false;
        const headers = {{}};
        if (stateEtag && stateUrl === stateUrlBase) {{
          headers["If-None-Match"] = stateEtag;
        }}
        const resp = await fetch(stateUrl, {{ cache: "no-store", headers }});
        if (resp.status === 304) {{
          if (!latestState || typeof latestState !== "object") {{
            // Rare startup edge: conditional/cached response before we have any local snapshot.
            // Force one cache-busted retry so sidebar panels can hydrate immediately.
            if (activeLayoutView === "network") {{
              renderNodesPlaceholder("Syncing nodes...");
            }}
            stateEtag = "";
            forceStateReloadOnce = true;
            requestImmediatePoll(20);
            return;
          }}
          // Nothing changed; keep the existing state and skip expensive DOM work.
          // Still allow an on-demand node-history fetch if the user just changed selection.
          lastPollSuccessUnix = Math.floor(Date.now() / 1000);
          lastPollError = "";
          lastPollErrorUnix = 0;
          renderSelfRadioPill(latestState);
          const hidden304 = (typeof document !== "undefined") && !!document.hidden;
          const drawerHistoryVisible304 = (
            typeof isChatNodeDetailsDrawerExpanded === "function"
            && isChatNodeDetailsDrawerExpanded()
          );
          const historyTargetId304 = activeLayoutView === "saved"
            ? resolveSavedViewNodeId(latestState)
            : normalizeNodeId(selectedNodeId || "");
          const historyRelevant304 = (activeLayoutView === "saved" || activeLayoutView === "network" || drawerHistoryVisible304)
            && (mapDataFocus !== "activity" || drawerHistoryVisible304)
            && isSelectableNodeId(historyTargetId304);
          const cachedHistory304 = historyRelevant304 ? cachedNodeHistory(historyTargetId304) : null;
          const nodes304 = Array.isArray(latestState.nodes) ? latestState.nodes : [];
          const traffic304 = (latestState.traffic && typeof latestState.traffic === "object")
            ? latestState.traffic
            : {{}};
          if (hidden304) {{
            scheduleFileTransferMaintenance(latestState);
            return;
          }}
          if (
            activeLayoutView === "network"
            && activeNetworkSubview !== "map"
            && typeof renderChatNodeNavigatorList === "function"
          ) {{
            renderChatNodeNavigatorList(latestState);
          }}
          renderSummary(latestState);
          const networkMapActive304 = activeLayoutView === "network" && activeNetworkSubview === "map";
          const mapVisible304 = activeLayoutView === "saved" || networkMapActive304;
          const trafficVisible304 = mapVisible304 || activeLayoutView === "history";
          if (mapVisible304) {{
            renderMap(nodes304, traffic304.edges || [], cachedHistory304);
          }}
          const networkGraphActive304 = activeLayoutView === "network" && activeNetworkSubview === "graph";
          if (activeLayoutView === "network") {{
            renderNodes(nodes304);
            if (networkGraphActive304 && typeof renderNetworkGraphView === "function") {{
              renderNetworkGraphView(latestState);
            }}
          }}
          if (trafficVisible304) {{
            renderTraffic(traffic304, nodes304, cachedHistory304);
          }}
          if (activeLayoutView === "files") {{
            renderFilesView(latestState);
          }}
          if (activeLayoutView === "bbs") {{
            renderBbsView(latestState);
          }}
          if (activeLayoutView === "history") {{
            renderHistoryChat(traffic304);
            renderEncription(traffic304);
            void refreshHistoryPanels(false);
          }}
          if (activeLayoutView === "settings" && activeSettingsTab === "channels") {{
            renderChannelsView(latestState);
          }}
          if (activeLayoutView === "settings" && activeSettingsTab === "lists") {{
            renderNodeVisibilityListsUi(latestRawState || latestState || {{}});
          }}
          if (
            activeLayoutView === "environment"
            || (
              activeLayoutView === "network"
              && activeNetworkSubview === "overview"
              && typeof normalizeWeeklySummaryMetric === "function"
              && normalizeWeeklySummaryMetric(networkOverviewMetric) === "sensors"
            )
          ) {{
            void renderEnvironmentMetricsView(false);
          }}
          if (activeLayoutView === "bots") {{
            renderBotsView(latestState);
          }}
          if (activeLayoutView === "games") {{
            renderGamesView(latestState);
          }}
          if (activeLayoutView === "remote") {{
            renderRemoteView(latestState);
          }}
          if (activeLayoutView === "saved") {{
            const loadingId304 = (activeLayoutView === "saved" && historyRelevant304 && !cachedHistory304)
              ? historyTargetId304
              : null;
            renderFavorites(latestState, cachedHistory304, loadingId304);
          }}
          let chatRenderedThisPoll304 = false;
          if (isChatWorkspaceLayoutView(activeLayoutView)) {{
            renderChat(latestState, {{ allowPollSkip: true }});
            chatRenderedThisPoll304 = true;
            if (activeLayoutView === "chatlabs") {{
              renderChatLabsView(latestState);
            }}
          }} else if (shouldHydrateNodeNavigatorRoster(latestState)) {{
            renderChat(latestState);
            chatRenderedThisPoll304 = true;
          }}
          if (
            !chatRenderedThisPoll304
            &&
            typeof syncChatNodeDetailsDrawer === "function"
            && typeof isChatNodeDetailsDrawerExpanded === "function"
            && isChatNodeDetailsDrawerExpanded()
          ) {{
            syncChatNodeDetailsDrawer(latestState, {{
              // Allow the drawer to refresh its node history even when the active
              // screen is not a chat workspace. refreshSelectedNodeHistory()
              // already applies its own cache/TTL guards.
              fetchHistory: true,
            }});
          }}
          if (historyRelevant304) {{
            const cached = nodeHistoryCache.get(historyTargetId304);
            const nowMs = Date.now();
            const ttlMs = Math.max(refreshMs * 2, 8000);
            const stale = !(cached && cached.data) || (nowMs - (cached.fetchedAt || 0)) >= ttlMs;
            if (stale) {{
              void refreshSelectedNodeHistory(false);
            }}
          }}
          scheduleFileTransferMaintenance(latestState);
          tickFreshnessUI(latestState);
          return;
        }}
        if (!resp.ok) throw new Error(`API ${{resp.status}}`);
        const newEtag = resp.headers && resp.headers.get ? resp.headers.get("ETag") : null;
        if (newEtag) {{
          stateEtag = String(newEtag);
        }}
        const rawState = await resp.json();
        latestRawState = rawState;
        updateNodeNameCache((rawState && rawState.nodes) || []);
        const state = applyNodeVisibilityFiltersToState(rawState);
        latestState = state;
        syncSelectedNodeWithVisibilityFilters();
        if (mapLiveActivityEnabled) {{
          syncNetworkMapPacketActivity(state);
        }}
        lastPollSuccessUnix = Math.floor(Date.now() / 1000);
        lastPollError = "";
        lastPollErrorUnix = 0;
        applyServerBotSettingsFromState(state);
        syncBackendBotRequestHistory(state);
        const nextLocalNodeId = resolveLocalNodeId(state);
        if (isCanonicalNodeId(nextLocalNodeId)) {{
          resolvedLocalNodeId = nextLocalNodeId;
        }}
        pruneSelfFromManualDirectPeers(state);
        syncBotRequestHistoryWithMessages((state.traffic || {{}}).recent_chat || [], state);
        syncReversiNetworkState(state);
        syncBoardGameNetworkState("checkers", state);
        syncBoardGameNetworkState("chess", state);
        syncBoardGameNetworkState("wallchess", state);
        syncBbsNetworkState(state);
        syncAppsLauncherNotifications(state);
        renderSelfRadioPill(state);
        const hiddenStatePoll = (typeof document !== "undefined") && !!document.hidden;
        if (hiddenStatePoll) {{
          // Keep background bookkeeping current without paying the full render cost
          // while the tab is not visible.
          chatChangeCatchupArmed = true;
          syncChatUnreadFromState(state, {{ clearActiveWhenInChat: false }});
          scheduleFileTransferMaintenance(state);
          return;
        }}
        if (!summaryMetricsHydrated && !summaryMetricsHydrateInFlight) {{
          summaryMetricsHydrateInFlight = hydrateSummaryMetricTickers()
            .finally(() => {{
              summaryMetricsHydrateInFlight = null;
            }});
        }}
        if (
          activeLayoutView === "network"
          && activeNetworkSubview !== "map"
          && typeof renderChatNodeNavigatorList === "function"
        ) {{
          renderChatNodeNavigatorList(state);
        }}

        const networkMapActive = activeLayoutView === "network" && activeNetworkSubview === "map";
        const mapVisible = activeLayoutView === "saved" || networkMapActive;
        const trafficVisible = mapVisible || activeLayoutView === "history";
        const drawerHistoryVisible = (
          typeof isChatNodeDetailsDrawerExpanded === "function"
          && isChatNodeDetailsDrawerExpanded()
        );
        const historyTargetId = activeLayoutView === "saved"
          ? resolveSavedViewNodeId(state)
          : normalizeNodeId(selectedNodeId || "");
        const historyRelevant = (activeLayoutView === "saved" || activeLayoutView === "network" || drawerHistoryVisible)
          && (mapDataFocus !== "activity" || drawerHistoryVisible)
          && isSelectableNodeId(historyTargetId);
        const cachedHistory = historyRelevant ? cachedNodeHistory(historyTargetId) : null;
        const networkGraphActive = activeLayoutView === "network" && activeNetworkSubview === "graph";

        if (mapVisible && !mapBootstrapFocusDone) {{
          const bootstrap = applyMapBootstrapFocus(state.nodes || [], state);
          if (bootstrap.didFocus) {{
            mapBootstrapFocusDone = true;
            if (activeLayoutView === "network") {{
              // Network view should start from the broadest useful overview and not
              // immediately fight that bootstrap focus with a second auto-fit.
              fitDone = true;
            }}
            // Let the map paint at the initial focus target before heavier render work.
            await nextAnimationFrame();
          }}
        }}

        const weeklySummaryPromise = (activeLayoutView === "history" || activeLayoutView === "network")
          ? fetchSummaryMetrics(weeklySummaryHours).catch((summaryErr) => ({{
              error: summaryErr instanceof Error
                ? summaryErr.message
                : String(summaryErr || "unknown error"),
            }}))
          : null;
        // Summary metrics now live in the global header ticker row, so keep them
        // refreshed for every active view.
        renderSummary(state);

        if (mapVisible) {{
          renderMap(state.nodes || [], (state.traffic || {{}}).edges || [], cachedHistory);
        }}

        if (activeLayoutView === "network") {{
          renderNodes(state.nodes || []);
          if (networkGraphActive && typeof renderNetworkGraphView === "function") {{
            renderNetworkGraphView(state);
          }}
        }}

        let weeklySummary = null;
        if (weeklySummaryPromise) {{
          weeklySummary = await weeklySummaryPromise;
        }}

        if (trafficVisible) {{
          renderTraffic(state.traffic || {{}}, state.nodes || [], cachedHistory);
        }}
        if (activeLayoutView === "files") {{
          renderFilesView(state);
        }}
        if (activeLayoutView === "history") {{
          renderHistoryChat(state.traffic || {{}});
          renderEncription(state.traffic || {{}});
          if (weeklySummary && !weeklySummary.error) {{
            renderWeeklySummary(weeklySummary);
          }} else if (weeklySummary && weeklySummary.error) {{
            renderWeeklySummaryError(weeklySummary.error);
          }} else {{
            renderWeeklySummaryLoading();
          }}
        }}
        if (activeLayoutView === "network") {{
          const networkOverviewUsesSensors = (
            typeof normalizeWeeklySummaryMetric === "function"
            && normalizeWeeklySummaryMetric(networkOverviewMetric) === "sensors"
          );
          if (networkOverviewUsesSensors) {{
            void renderEnvironmentMetricsView(false);
          }} else if (weeklySummary && !weeklySummary.error) {{
            renderNetworkOverviewSummary(weeklySummary);
          }} else if (weeklySummary && weeklySummary.error) {{
            renderNetworkOverviewSummaryError(weeklySummary.error);
          }} else {{
            renderNetworkOverviewSummaryLoading();
          }}
        }}

        const chatEntries = runPollStep("collectChatMessageEntries", () => collectChatMessageEntries(state), []);
        const hasFreshDirectEntry = chatEntries.some((entry) => {{
          if (!entry || entry.channel !== "direct") return false;
          const key = String(entry.key || "").trim();
          if (!key) return false;
          return !chatSeenMessageKeys.has(key);
        }});
        const shouldBackgroundRenderDirectChat = (
          !isChatWorkspaceLayoutView(activeLayoutView)
          && (
            hasFreshDirectEntry
            || isCanonicalNodeId(peerDmActivePeerId || "")
          )
        );
        let chatRenderedThisPoll = false;
        if (shouldBackgroundRenderDirectChat) {{
          runPollStep("renderChat.background", () => renderChat(state));
          chatRenderedThisPoll = true;
        }}

        if (
          !isChatWorkspaceLayoutView(activeLayoutView)
          && runPollStep("shouldHydrateNodeNavigatorRoster", () => shouldHydrateNodeNavigatorRoster(state), false)
        ) {{
          if (typeof renderChatNodeNavigatorList === "function") {{
            runPollStep("renderChatNodeNavigatorList.background", () => renderChatNodeNavigatorList(state));
          }} else {{
            if (!chatRenderedThisPoll) {{
              runPollStep("renderChat.backgroundFallback", () => renderChat(state));
              chatRenderedThisPoll = true;
            }}
          }}
        }}

        if (isChatWorkspaceLayoutView(activeLayoutView)) {{
          if (!chatRenderedThisPoll) {{
            runPollStep("renderChat.workspace", () => renderChat(state, {{ allowPollSkip: true }}));
            chatRenderedThisPoll = true;
          }}
          if (activeLayoutView === "chatlabs") {{
            runPollStep("renderChatLabsView", () => renderChatLabsView(state));
          }}
        }} else if (activeLayoutView === "bbs") {{
          runPollStep("renderBbsView", () => renderBbsView(state));
        }} else if (activeLayoutView === "bots") {{
          runPollStep("renderBotsView", () => renderBotsView(state));
        }} else if (activeLayoutView === "games") {{
          runPollStep("renderGamesView", () => renderGamesView(state));
        }} else if (activeLayoutView === "remote") {{
          runPollStep("renderRemoteView", () => renderRemoteView(state));
          if (!chatRenderedThisPoll) {{
            runPollStep("syncChatUnreadFromState.remote", () => syncChatUnreadFromState(state, {{ clearActiveWhenInChat: false }}));
          }}
          runPollStep("renderChatChangeSummary.remote", () => renderChatChangeSummary());
          runPollStep("bindChatChangeSummaryControls.remote", () => bindChatChangeSummaryControls());
        }} else {{
          if (!chatRenderedThisPoll) {{
            runPollStep("syncChatUnreadFromState.default", () => syncChatUnreadFromState(state, {{ clearActiveWhenInChat: false }}));
          }}
          runPollStep("renderChatChangeSummary.default", () => renderChatChangeSummary());
          runPollStep("bindChatChangeSummaryControls.default", () => bindChatChangeSummaryControls());
        }}
        if (
          !chatRenderedThisPoll
          &&
          typeof syncChatNodeDetailsDrawer === "function"
          && typeof isChatNodeDetailsDrawerExpanded === "function"
          && isChatNodeDetailsDrawerExpanded()
        ) {{
          syncChatNodeDetailsDrawer(state, {{
            // Keep node-details history tabs live across non-chat screens too.
            fetchHistory: true,
          }});
        }}

        if (activeLayoutView === "saved") {{
          const loadingId = (activeLayoutView === "saved" && historyRelevant && !cachedHistory)
            ? historyTargetId
            : null;
          renderFavorites(state, cachedHistory, loadingId);
        }}

        if (
          activeLayoutView === "environment"
          || (
            activeLayoutView === "network"
            && activeNetworkSubview === "overview"
            && typeof normalizeWeeklySummaryMetric === "function"
            && normalizeWeeklySummaryMetric(networkOverviewMetric) === "sensors"
          )
        ) {{
          void renderEnvironmentMetricsView(false);
        }}

        if (activeLayoutView === "settings") {{
          renderSettings(state);
          if (activeSettingsTab === "channels") {{
            renderChannelsView(state);
          }} else if (activeSettingsTab === "lists") {{
            renderNodeVisibilityListsUi(latestRawState || state || {{}});
          }}
        }}

        if (activeLayoutView === "console") {{
          renderConsole(state.traffic || {{}});
        }}

        if (historyRelevant) {{
          const cached = nodeHistoryCache.get(historyTargetId);
          const nowMs = Date.now();
          const ttlMs = Math.max(refreshMs * 2, 8000);
          const stale = !(cached && cached.data) || (nowMs - (cached.fetchedAt || 0)) >= ttlMs;
          if (stale) {{
            void refreshSelectedNodeHistory(false);
          }}
        }}


        scheduleFileTransferMaintenance(state);
        tickFreshnessUI(state);
      }} catch (err) {{
        const msg = err instanceof Error ? err.message : String(err || "unknown error");
        lastPollError = msg;
        lastPollErrorUnix = Math.floor(Date.now() / 1000);
        setText("updated-at", `error: ${{msg}}`);
        renderTargetRadioStatus(latestState || {{}});
        appendConsoleLine(`error|${{Date.now()}}|${{msg}}`, `[poll error] ${{msg}}`);
      }}
    }}
