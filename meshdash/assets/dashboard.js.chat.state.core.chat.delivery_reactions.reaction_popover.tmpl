    function reactionPopoverElement() {{
      const popover = document.getElementById("chat-reaction-popover");
      if (!(popover instanceof HTMLElement)) return null;
      if (popover.parentElement !== document.body) {{
        document.body.appendChild(popover);
      }}
      return popover;
    }}

    function clearReactionPopoverHideTimer() {{
      if (chatReactionPopoverHideTimer !== null) {{
        clearTimeout(chatReactionPopoverHideTimer);
        chatReactionPopoverHideTimer = null;
      }}
    }}

    function scheduleReactionPopoverHide(delayMs = 120) {{
      clearReactionPopoverHideTimer();
      chatReactionPopoverHideTimer = window.setTimeout(() => {{
        closeReactionPopover(true);
      }}, Math.max(0, Number(delayMs) || 0));
    }}

    function normalizeReactionName(value) {{
      const clean = String(value == null ? "" : value).replace(/\\s+/g, " ").trim();
      if (!clean) return "Unknown node";
      return clean;
    }}

    function reactionNameInitials(value) {{
      const clean = normalizeReactionName(value).replace(/[^A-Za-z0-9 ]+/g, " ").trim();
      if (!clean) return "?";
      const parts = clean.split(/\\s+/).filter(Boolean);
      if (parts.length <= 1) {{
        return parts[0].slice(0, 2).toUpperCase();
      }}
      return `${{parts[0][0] || ""}}${{parts[1][0] || ""}}`.toUpperCase() || "?";
    }}

    function parseReactionChipNames(chip) {{
      if (!(chip instanceof HTMLButtonElement)) return [];
      const raw = String(chip.dataset.reactors || "").trim();
      if (!raw) return [];
      try {{
        const parsed = JSON.parse(raw);
        if (!Array.isArray(parsed)) return [];
        return parsed
          .map((item) => normalizeReactionName(item))
          .filter((name, idx, arr) => !!name && arr.indexOf(name) === idx);
      }} catch (_err) {{
        return [];
      }}
    }}

    function parseReactionSummaryGroups(button) {{
      if (!(button instanceof HTMLButtonElement)) return [];
      const raw = String(button.dataset.reactionSummary || "").trim();
      if (!raw) return [];
      try {{
        const parsed = JSON.parse(raw);
        if (!Array.isArray(parsed)) return [];
        return parsed
          .map((item) => {{
            if (!item || typeof item !== "object") return null;
            const emoji = String(item.emoji || "").trim();
            const count = Number(item.count || 0);
            const names = Array.isArray(item.names)
              ? item.names
                  .map((name) => normalizeReactionName(name))
                  .filter((name, idx, arr) => !!name && arr.indexOf(name) === idx)
              : [];
            if (!emoji || !Number.isFinite(count) || count <= 0) return null;
            return {{
              emoji,
              count: Math.trunc(count),
              names,
            }};
          }})
          .filter((item) => !!item);
      }} catch (_err) {{
        return [];
      }}
    }}

    function reactionSummaryTargetId(button) {{
      if (!(button instanceof HTMLButtonElement)) return null;
      const parsed = Number(button.dataset.replyId || button.dataset.messageId || "");
      return Number.isInteger(parsed) && parsed > 0 ? parsed : null;
    }}

    function reactionQuickChoices(groups = []) {{
      const out = [];
      const used = new Set();
      const pushChoice = (value) => {{
        const emoji = String(value || "").trim();
        if (!emoji || used.has(emoji)) return;
        if (typeof isReactionCompatibleEmoji === "function" && !isReactionCompatibleEmoji(emoji)) {{
          return;
        }}
        used.add(emoji);
        out.push(emoji);
      }};

      if (typeof chatEmojiTopChoices === "function") {{
        try {{
          const preferred = chatEmojiTopChoices();
          for (const emoji of (Array.isArray(preferred) ? preferred : [])) {{
            pushChoice(emoji);
          }}
        }} catch (_err) {{
        }}
      }}

      for (const group of (Array.isArray(groups) ? groups : [])) {{
        pushChoice(group && group.emoji);
      }}

      for (const emoji of ["👍", "❤️", "😂", "😮", "😢", "🙏", "🔥", "✅"]) {{
        pushChoice(emoji);
      }}

      return out.slice(0, 6);
    }}

    function reactionQuickButtons(row) {{
      if (!(row instanceof HTMLElement)) return [];
      return Array.from(row.querySelectorAll(".chat-reaction-popover-quick-btn"))
        .filter((node) => node instanceof HTMLButtonElement);
    }}

    function reactionQuickCurrentOrder(row) {{
      return reactionQuickButtons(row)
        .map((node) => String(node.dataset.emoji || "").trim())
        .filter(Boolean);
    }}

    function reactionQuickInsertionIndex(row, clientX, draggedEmoji = "") {{
      let index = 0;
      const source = String(draggedEmoji || "").trim();
      for (const item of reactionQuickButtons(row)) {{
        if (String(item.dataset.emoji || "").trim() === source) continue;
        const rect = item.getBoundingClientRect();
        if (rect.width <= 0) continue;
        if (Number(clientX) > rect.left + (rect.width / 2)) {{
          index += 1;
        }}
      }}
      return index;
    }}

    function reactionQuickNextOrder(sourceEmoji, insertionIndex, currentOrder = []) {{
      const source = String(sourceEmoji || "").trim();
      if (!source) return [];
      const visible = normalizeChatEmojiPinnedChoices(currentOrder, 6);
      const working = visible.filter((emoji) => emoji !== source);
      const sourceInVisible = working.length !== visible.length;
      let insertAt = Math.max(0, Math.min(working.length, Math.trunc(Number(insertionIndex) || 0)));
      if (!sourceInVisible && insertAt >= 6) {{
        insertAt = 5;
      }}
      working.splice(insertAt, 0, source);
      const next = working.slice(0, 6);
      return chatEmojiTopOrdersEqual(next, visible) ? [] : next;
    }}

    function applyReactionQuickPreviewOrder(row, nextOrder) {{
      if (!(row instanceof HTMLElement) || !Array.isArray(nextOrder) || !nextOrder.length) {{
        return false;
      }}
      const currentOrder = reactionQuickCurrentOrder(row);
      if (chatEmojiTopOrdersEqual(currentOrder, nextOrder)) {{
        return false;
      }}
      const nodesByEmoji = new Map();
      for (const node of reactionQuickButtons(row)) {{
        const emoji = String(node.dataset.emoji || "").trim();
        if (emoji && !nodesByEmoji.has(emoji)) {{
          nodesByEmoji.set(emoji, node);
        }}
      }}
      const moreBtn = row.querySelector(".chat-reaction-popover-more-btn");
      const fragment = document.createDocumentFragment();
      for (const emoji of nextOrder) {{
        const node = nodesByEmoji.get(emoji);
        if (node) {{
          fragment.appendChild(node);
        }}
      }}
      row.insertBefore(fragment, moreBtn instanceof HTMLElement ? moreBtn : null);
      return true;
    }}

    function reactionQuickCommitOrder(visibleOrder) {{
      const nextVisible = normalizeChatEmojiPinnedChoices(visibleOrder, 6);
      if (!nextVisible.length) return false;
      const currentTop = typeof chatEmojiTopChoices === "function" ? chatEmojiTopChoices() : [];
      const next = [];
      const used = new Set();
      const push = (value) => {{
        const emoji = String(value || "").trim();
        if (!emoji || used.has(emoji) || !chatEmojiChoiceSet.has(emoji)) return;
        if (typeof isReactionCompatibleEmoji === "function" && !isReactionCompatibleEmoji(emoji)) return;
        used.add(emoji);
        next.push(emoji);
      }};
      for (const emoji of nextVisible) push(emoji);
      for (const emoji of (Array.isArray(currentTop) ? currentTop : [])) push(emoji);
      for (const emoji of chatEmojiPopularDefaults) push(emoji);
      return setChatEmojiTopPinnedChoices(next.slice(0, chatEmojiTopUsageCount), true);
    }}

    function finishReactionQuickPointerDrag(ev, commit = false) {{
      const drag = chatReactionQuickPointerDrag;
      if (drag && drag.source instanceof HTMLElement) {{
        try {{
          if (drag.source.hasPointerCapture && drag.source.hasPointerCapture(drag.pointerId)) {{
            drag.source.releasePointerCapture(drag.pointerId);
          }}
        }} catch (err) {{}}
      }}
      const wasActive = !!(drag && drag.active);
      let changed = false;
      if (wasActive && drag && drag.row instanceof HTMLElement) {{
        const row = drag.row;
        const rect = row.getBoundingClientRect();
        const droppedOnRow = !!(
          commit
          && Number(ev.clientX) >= rect.left - 10
          && Number(ev.clientX) <= rect.right + 10
          && Number(ev.clientY) >= rect.top - 10
          && Number(ev.clientY) <= rect.bottom + 10
        );
        if (droppedOnRow) {{
          const insertionIndex = reactionQuickInsertionIndex(row, ev.clientX, drag.emoji);
          const next = reactionQuickNextOrder(drag.emoji, insertionIndex, reactionQuickCurrentOrder(row));
          if (next.length) {{
            applyReactionQuickPreviewOrder(row, next);
          }}
          changed = reactionQuickCommitOrder(reactionQuickCurrentOrder(row));
        }} else if (Array.isArray(drag.startOrder) && drag.startOrder.length) {{
          applyReactionQuickPreviewOrder(row, drag.startOrder);
        }}
      }}
      if (wasActive) {{
        chatReactionQuickSuppressClickUntilMs = Date.now() + 260;
        if (typeof dismissChatEmojiDragGhost === "function") {{
          dismissChatEmojiDragGhost(null);
        }}
      }}
      if (drag && drag.source instanceof HTMLElement) {{
        drag.source.classList.remove("dragging");
      }}
      const popover = reactionPopoverElement();
      if (popover instanceof HTMLElement) {{
        popover.classList.remove("is-emoji-dragging");
        for (const item of popover.querySelectorAll(".chat-reaction-popover-quick-btn.dragging")) {{
          if (item instanceof HTMLElement) item.classList.remove("dragging");
        }}
      }}
      chatReactionQuickPointerDrag = null;
      if (changed) {{
        if (chatReactionPopoverAnchor instanceof HTMLButtonElement) {{
          openReactionPopoverForSummary(chatReactionPopoverAnchor);
        }}
        if (typeof renderChatEmojiTopRow === "function") {{
          renderChatEmojiTopRow();
        }}
        if (typeof setChatSendStatus === "function") {{
          setChatSendStatus("Updated quick reaction shortcuts.", false);
        }}
      }}
      return changed;
    }}

    function buildReactionQuickRowHtml(targetMessageId, groups) {{
      const replyId = Number(targetMessageId);
      if (!Number.isInteger(replyId) || replyId <= 0) return "";
      const quickChoices = reactionQuickChoices(groups);
      const quickButtons = quickChoices.map((emoji) => (
        `<button type="button" class="chat-reaction-popover-quick-btn" data-reply-id="${{escAttr(replyId)}}" data-emoji="${{escAttr(emoji)}}" aria-label="${{escAttr(`React ${{emoji}}`)}}" title="${{escAttr(`React ${{emoji}}`)}}">${{escAttr(emoji)}}</button>`
      )).join("");
      return `<div class="chat-reaction-popover-quick-shell">
        <div class="chat-reaction-popover-section-label">Quick react</div>
        <div class="chat-reaction-popover-quick-row">
          ${{quickButtons}}
          <button type="button" class="chat-reaction-popover-more-btn" data-reply-id="${{escAttr(replyId)}}" aria-label="Open full reaction picker" title="More reactions">More reactions</button>
        </div>
      </div>`;
    }}

    function positionReactionPopover(anchor, popover) {{
      if (!(anchor instanceof HTMLElement) || !(popover instanceof HTMLElement) || popover.hidden) {{
        return;
      }}
      const anchorRect = anchor.getBoundingClientRect();
      const margin = 8;
      const width = popover.offsetWidth || 240;
      const height = popover.offsetHeight || 140;
      const viewportWidth = window.innerWidth || document.documentElement.clientWidth || 1280;
      const viewportHeight = window.innerHeight || document.documentElement.clientHeight || 720;

      let left = anchorRect.left + (anchorRect.width / 2) - (width / 2);
      if (left < margin) left = margin;
      if ((left + width) > (viewportWidth - margin)) {{
        left = Math.max(margin, viewportWidth - width - margin);
      }}

      let top = anchorRect.top - height - 10;
      if (top < margin) {{
        top = anchorRect.bottom + 10;
      }}
      if ((top + height) > (viewportHeight - margin)) {{
        top = Math.max(margin, viewportHeight - height - margin);
      }}

      popover.style.left = `${{Math.round(left)}}px`;
      popover.style.top = `${{Math.round(top)}}px`;
    }}

    function openReactionPopoverForChip(chip) {{
      if (!(chip instanceof HTMLButtonElement)) return;
      const popover = reactionPopoverElement();
      if (!(popover instanceof HTMLElement)) return;

      const emoji = String(chip.dataset.emoji || "").trim() || "🙂";
      const names = parseReactionChipNames(chip);
      const rawCount = Number(chip.dataset.reactorCount || "");
      const count = Number.isFinite(rawCount) && rawCount > 0 ? Math.trunc(rawCount) : names.length;
      const shownNames = names.slice(0, reactionPopoverMaxNames);
      const listRows = shownNames.map((name) => (
        `<div class="chat-reaction-popover-row">
          <span class="chat-reaction-popover-avatar">${{escAttr(reactionNameInitials(name))}}</span>
          <span class="chat-reaction-popover-name">${{escAttr(name)}}</span>
        </div>`
      )).join("");
      const unknownCount = Math.max(0, count - shownNames.length);

      popover.innerHTML = `
        <div class="chat-reaction-popover-head">
          <span><span class="chat-reaction-popover-emoji">${{escAttr(emoji)}}</span> Reactions</span>
          <span class="chat-reaction-popover-count">${{count}}</span>
        </div>
        <div class="chat-reaction-popover-list">
          ${{listRows || `<div class="chat-reaction-popover-row"><span class="chat-reaction-popover-name">No named reactors yet</span></div>`}}
        </div>
        ${{unknownCount > 0 ? `<div class="chat-reaction-popover-more">+${{unknownCount}} more</div>` : ""}}
      `;
      popover.hidden = false;
      chatReactionPopoverAnchor = chip;
      positionReactionPopover(chip, popover);
    }}

    function openReactionPopoverForSummary(button) {{
      if (!(button instanceof HTMLButtonElement)) return;
      const popover = reactionPopoverElement();
      if (!(popover instanceof HTMLElement)) return;

      const groups = parseReactionSummaryGroups(button);
      const targetMessageId = reactionSummaryTargetId(button);
      const quickRow = buildReactionQuickRowHtml(targetMessageId, groups);
      const total = groups.reduce((sum, group) => sum + Math.max(0, Number(group.count || 0)), 0);
      const listRows = groups.map((group) => {{
        const shownNames = group.names.slice(0, 4);
        const shownText = shownNames.length ? shownNames.join(", ") : "No named reactors yet";
        const remaining = Math.max(0, group.count - shownNames.length);
        const detail = remaining > 0 ? `${{shownText}} +${{remaining}}` : shownText;
        return `<div class="chat-reaction-popover-row">
          <span class="chat-reaction-popover-emoji">${{escAttr(group.emoji)}}</span>
          <span class="chat-reaction-popover-name">${{escAttr(`${{group.count}} • ${{detail}}`)}}</span>
        </div>`;
      }}).join("");

      popover.innerHTML = `
        <div class="chat-reaction-popover-head">
          <span>${{groups.length ? "React to message" : "Add reaction"}}</span>
          ${{groups.length ? `<span class="chat-reaction-popover-count">${{total}}</span>` : ""}}
        </div>
        ${{quickRow}}
        ${{groups.length
          ? `<div class="chat-reaction-popover-section-label">Current reactions</div>
             <div class="chat-reaction-popover-list">${{listRows}}</div>`
          : '<div class="chat-reaction-popover-empty">No reactions yet. Use a quick reaction above or open the full picker.</div>'}}
      `;
      popover.hidden = false;
      chatReactionPopoverAnchor = button;
      positionReactionPopover(button, popover);
    }}

    function closeReactionPopover(force = false) {{
      const popover = reactionPopoverElement();
      if (!(popover instanceof HTMLElement)) return;
      if (!force && popover.hidden) return;
      if (chatReactionQuickPointerDrag) {{
        finishReactionQuickPointerDrag({{ clientX: -9999, clientY: -9999, pointerId: chatReactionQuickPointerDrag.pointerId }}, false);
      }}
      clearReactionPopoverHideTimer();
      popover.hidden = true;
      popover.innerHTML = "";
      chatReactionPopoverAnchor = null;
    }}

    function bindReactionPopover() {{
      const popover = reactionPopoverElement();
      if (!(popover instanceof HTMLElement) || popover.dataset.bound === "1") return;
      popover.dataset.bound = "1";

      popover.addEventListener("pointerenter", () => {{
        clearReactionPopoverHideTimer();
      }});
      popover.addEventListener("pointerleave", () => {{
        if (chatReactionQuickPointerDrag && chatReactionQuickPointerDrag.active) return;
        scheduleReactionPopoverHide(120);
      }});
      popover.addEventListener("pointerdown", (ev) => {{
        if (ev.button !== 0) return;
        const target = ev.target;
        if (!(target instanceof Element)) return;
        const quickBtn = target.closest(".chat-reaction-popover-quick-btn");
        if (!(quickBtn instanceof HTMLButtonElement) || !popover.contains(quickBtn)) return;
        const row = quickBtn.closest(".chat-reaction-popover-quick-row");
        if (!(row instanceof HTMLElement) || reactionQuickButtons(row).length < 2) return;
        const emoji = String(quickBtn.dataset.emoji || "").trim();
        if (!emoji) return;
        chatReactionQuickPointerDrag = {{
          active: false,
          emoji,
          pointerId: ev.pointerId,
          row,
          source: quickBtn,
          startOrder: reactionQuickCurrentOrder(row),
          startX: ev.clientX,
          startY: ev.clientY,
        }};
        try {{
          quickBtn.setPointerCapture(ev.pointerId);
        }} catch (err) {{}}
      }});
      popover.addEventListener("pointermove", (ev) => {{
        const drag = chatReactionQuickPointerDrag;
        if (!drag || drag.pointerId !== ev.pointerId) return;
        const row = drag.row instanceof HTMLElement ? drag.row : null;
        if (!(row instanceof HTMLElement)) {{
          finishReactionQuickPointerDrag(ev, false);
          return;
        }}
        const distance = Math.hypot(ev.clientX - drag.startX, ev.clientY - drag.startY);
        if (!drag.active && distance < 5) return;
        if (!drag.active) {{
          drag.active = true;
          clearReactionPopoverHideTimer();
          const quickBtn = drag.source instanceof HTMLElement ? drag.source : null;
          if (quickBtn instanceof HTMLElement) quickBtn.classList.add("dragging");
          popover.classList.add("is-emoji-dragging");
          if (typeof createChatEmojiDragGhost === "function") {{
            createChatEmojiDragGhost(drag.emoji);
          }}
        }}
        ev.preventDefault();
        if (typeof moveChatEmojiDragGhost === "function") {{
          moveChatEmojiDragGhost(ev.clientX, ev.clientY);
        }}
        const rect = row.getBoundingClientRect();
        const overRow = (
          Number(ev.clientX) >= rect.left - 10
          && Number(ev.clientX) <= rect.right + 10
          && Number(ev.clientY) >= rect.top - 10
          && Number(ev.clientY) <= rect.bottom + 10
        );
        if (overRow) {{
          const insertionIndex = reactionQuickInsertionIndex(row, ev.clientX, drag.emoji);
          const next = reactionQuickNextOrder(drag.emoji, insertionIndex, reactionQuickCurrentOrder(row));
          if (next.length) {{
            applyReactionQuickPreviewOrder(row, next);
          }}
        }} else if (Array.isArray(drag.startOrder) && drag.startOrder.length) {{
          applyReactionQuickPreviewOrder(row, drag.startOrder);
        }}
      }});
      popover.addEventListener("pointerup", (ev) => {{
        const drag = chatReactionQuickPointerDrag;
        if (!drag || drag.pointerId !== ev.pointerId) return;
        if (drag.active) {{
          ev.preventDefault();
          ev.stopPropagation();
        }}
        finishReactionQuickPointerDrag(ev, true);
      }});
      popover.addEventListener("pointercancel", (ev) => {{
        const drag = chatReactionQuickPointerDrag;
        if (!drag || drag.pointerId !== ev.pointerId) return;
        finishReactionQuickPointerDrag(ev, false);
      }});
      popover.addEventListener("click", (ev) => {{
        if (chatReactionQuickSuppressClickUntilMs && Date.now() < chatReactionQuickSuppressClickUntilMs) {{
          ev.preventDefault();
          ev.stopPropagation();
          return;
        }}
        const target = ev.target;
        if (!(target instanceof Element)) return;
        const quickBtn = target.closest(".chat-reaction-popover-quick-btn");
        if (quickBtn instanceof HTMLButtonElement && popover.contains(quickBtn)) {{
          ev.preventDefault();
          ev.stopPropagation();
          const replyId = Number(quickBtn.dataset.replyId || "");
          const emoji = String(quickBtn.dataset.emoji || "").trim();
          if (typeof noteChatEmojiUsage === "function") {{
            noteChatEmojiUsage(emoji);
          }}
          closeReactionPopover(true);
          if (typeof sendChatReaction === "function") {{
            void sendChatReaction(replyId, emoji);
          }}
          return;
        }}
        const moreBtn = target.closest(".chat-reaction-popover-more-btn");
        if (moreBtn instanceof HTMLButtonElement && popover.contains(moreBtn)) {{
          ev.preventDefault();
          ev.stopPropagation();
          const replyId = Number(moreBtn.dataset.replyId || "");
          const anchor = chatReactionPopoverAnchor instanceof HTMLElement
            ? chatReactionPopoverAnchor
            : moreBtn;
          closeReactionPopover(true);
          if (typeof openChatEmojiPanel === "function") {{
            openChatEmojiPanel("react", replyId, anchor, true);
          }}
        }}
      }});

      document.addEventListener("pointerdown", (ev) => {{
        const target = ev.target;
        if (!(target instanceof Element)) {{
          closeReactionPopover(true);
          return;
        }}
        if (target.closest(".chat-reaction-chip") || target.closest(".chat-reaction-summary") || target.closest("#chat-reaction-popover")) {{
          return;
        }}
        closeReactionPopover(true);
      }});

      document.addEventListener("keydown", (ev) => {{
        if (ev.key === "Escape") {{
          closeReactionPopover(true);
        }}
      }});

      window.addEventListener("resize", () => {{
        const el = reactionPopoverElement();
        if (!(el instanceof HTMLElement) || el.hidden) return;
        if (!(chatReactionPopoverAnchor instanceof HTMLElement)) {{
          closeReactionPopover(true);
          return;
        }}
        positionReactionPopover(chatReactionPopoverAnchor, el);
      }});
      window.addEventListener("scroll", () => {{
        const el = reactionPopoverElement();
        if (!(el instanceof HTMLElement) || el.hidden) return;
        if (!(chatReactionPopoverAnchor instanceof HTMLElement)) {{
          closeReactionPopover(true);
          return;
        }}
        positionReactionPopover(chatReactionPopoverAnchor, el);
      }}, true);
    }}
