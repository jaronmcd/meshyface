    async function regenerateNodeId() {{
      if (settingsApplyInFlight) return;
      const localNodeId = normalizeNodeId(resolveLocalNodeId(latestState));
      const idSuffix = isCanonicalNodeId(localNodeId) ? ` (current: ${{localNodeId}})` : "";

      const confirmed = window.confirm(
        `Regenerate radio node ID${{idSuffix}}? This sends FULL FACTORY RESET to the radio, erases config/channels/keys, and reboots.`
      );
      if (!confirmed) return;

      const typed = window.prompt("Type REGEN to confirm full factory reset and node ID regeneration:");
      if (String(typed || "").trim().toUpperCase() !== "REGEN") {{
        setText("settings-apply-status", "Canceled: confirmation token did not match.");
        return;
      }}

      const ok = await postRadioSettingsPayload(
        {{ actions: {{ regenerate_node_id: true }} }},
        "Regenerating node ID (full factory reset)… radio will reboot.",
        "node ID regeneration requested"
      );
      if (ok) {{
        setTimeout(() => {{
          void fetchSettingsFromRadio();
        }}, 3000);
      }}
    }}

