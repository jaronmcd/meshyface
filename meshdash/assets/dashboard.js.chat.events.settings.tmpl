            enabled: readCheckboxValue("settings-ext-notify-enabled"),
            alert_message: readCheckboxValue("settings-ext-notify-alert-message"),
            alert_bell: readCheckboxValue("settings-ext-notify-alert-bell"),
            active: readCheckboxValue("settings-ext-notify-active-high"),
            use_pwm: readCheckboxValue("settings-ext-notify-use-pwm"),
            output_ms: readNumberValue("settings-ext-notify-output-ms"),
            output: readNumberValue("settings-ext-notify-output-pin"),
            nag_timeout: readNumberValue("settings-ext-notify-nag-timeout"),
          }},
        }},
      }};
      for (const [key, value] of Object.entries(payload.module.external_notification)) {{
        if (value == null) delete payload.module.external_notification[key];
      }}
      if (!Object.keys(payload.module.external_notification).length) {{
        setText("settings-apply-status", "No external notification fields to apply.");
        return;
      }}

      const ok = await postRadioSettingsPayload(
        payload,
        "Applying external notification settings…",
        "external notification settings saved"
      );
      if (ok) {{
        setTimeout(() => {{
          void fetchSettingsFromRadio();
        }}, 600);
      }}
    }}

    async function applyPositionConfigSettings() {{
      if (settingsApplyInFlight) return;
      const smartEnabled = !!readCheckboxValue("settings-position-smart-enabled");
      const positionBroadcastSecs = readNumberValue("settings-position-broadcast-secs");
      const gpsUpdateIntervalSecs = readNumberValue("settings-position-gps-update-secs");
      if (!Number.isFinite(positionBroadcastSecs) || Number(positionBroadcastSecs) < 60) {{
        setText("settings-apply-status", "Position broadcast interval must be at least 60 seconds.");
        return;
      }}
      if (!Number.isFinite(gpsUpdateIntervalSecs) || Number(gpsUpdateIntervalSecs) < 60) {{
        setText("settings-apply-status", "GPS update interval must be at least 60 seconds.");
        return;
      }}

      const belowRecommended = (
        Number(positionBroadcastSecs) < recommendedPositionBroadcastSecs
        || Number(gpsUpdateIntervalSecs) < recommendedGpsUpdateSecs
      );
      if (
        belowRecommended
        && !window.confirm("Position intervals are below recommended (12h broadcast, 1h GPS update). Apply anyway?")
      ) {{
        return;
      }}

      const ok = await postRadioSettingsPayload(
        {{
          local: {{
            position: {{
              position_broadcast_smart_enabled: smartEnabled,
              position_broadcast_secs: Math.trunc(Number(positionBroadcastSecs)),
              gps_update_interval: Math.trunc(Number(gpsUpdateIntervalSecs)),
            }},
          }},
        }},
        "Applying position settings…",
        "position settings saved"
      );
      if (ok) {{
        setTimeout(() => {{
          void fetchSettingsFromRadio();
        }}, 600);
      }}
    }}

    async function applyTelemetrySettings() {{
      if (settingsApplyInFlight) return;
      const deviceEnabled = !!readCheckboxValue("settings-telemetry-device-enabled");
      const environmentEnabled = !!readCheckboxValue("settings-telemetry-environment-enabled");
      const airQualityEnabled = !!readCheckboxValue("settings-telemetry-air-quality-enabled");
      const powerEnabled = !!readCheckboxValue("settings-telemetry-power-enabled");
      const healthEnabled = !!readCheckboxValue("settings-telemetry-health-enabled");
      const environmentScreenEnabled = !!readCheckboxValue("settings-telemetry-environment-screen-enabled");
      const environmentFahrenheit = !!readCheckboxValue("settings-telemetry-environment-fahrenheit");
      const powerScreenEnabled = !!readCheckboxValue("settings-telemetry-power-screen-enabled");
      const healthScreenEnabled = !!readCheckboxValue("settings-telemetry-health-screen-enabled");
      const airQualityScreenEnabled = !!readCheckboxValue("settings-telemetry-air-quality-screen-enabled");
      let deviceInterval = readNumberValue("settings-telemetry-device-interval-secs");
      let environmentInterval = readNumberValue("settings-telemetry-environment-interval-secs");
      let airQualityInterval = readNumberValue("settings-telemetry-air-quality-interval-secs");
      let powerInterval = readNumberValue("settings-telemetry-power-interval-secs");
      let healthInterval = readNumberValue("settings-telemetry-health-interval-secs");
      if (!Number.isFinite(deviceInterval) || Number(deviceInterval) < 0) {{
        setText("settings-apply-status", "Telemetry device interval must be 0 or more.");
        return;
      }}
      if (!Number.isFinite(environmentInterval) || Number(environmentInterval) < 0) {{
        setText("settings-apply-status", "Telemetry environment interval must be 0 or more.");
        return;
      }}
      if (!Number.isFinite(airQualityInterval) || Number(airQualityInterval) < 0) {{
        setText("settings-apply-status", "Telemetry air quality interval must be 0 or more.");
        return;
      }}
      if (!Number.isFinite(powerInterval) || Number(powerInterval) < 0) {{
        setText("settings-apply-status", "Telemetry power interval must be 0 or more.");
        return;
      }}
      if (!Number.isFinite(healthInterval) || Number(healthInterval) < 0) {{
        setText("settings-apply-status", "Telemetry health interval must be 0 or more.");
        return;
      }}

      const telemetryDisabled = !deviceEnabled && !environmentEnabled && !airQualityEnabled && !powerEnabled && !healthEnabled;
      if (telemetryDisabled) {{
        deviceInterval = 0;
        environmentInterval = 0;
        airQualityInterval = 0;
        powerInterval = 0;
        healthInterval = 0;
      }}

      const ok = await postRadioSettingsPayload(
        {{
          module: {{
            telemetry: {{
              device_telemetry_enabled: deviceEnabled,
              environment_measurement_enabled: environmentEnabled,
              air_quality_enabled: airQualityEnabled,
              power_measurement_enabled: powerEnabled,
              health_measurement_enabled: healthEnabled,
              environment_screen_enabled: telemetryDisabled ? false : environmentScreenEnabled,
              environment_display_fahrenheit: telemetryDisabled ? false : environmentFahrenheit,
              power_screen_enabled: telemetryDisabled ? false : powerScreenEnabled,
              health_screen_enabled: telemetryDisabled ? false : healthScreenEnabled,
              air_quality_screen_enabled: telemetryDisabled ? false : airQualityScreenEnabled,
              device_update_interval: Math.trunc(Number(deviceInterval)),
              environment_update_interval: Math.trunc(Number(environmentInterval)),
              air_quality_interval: Math.trunc(Number(airQualityInterval)),
              power_update_interval: Math.trunc(Number(powerInterval)),
              health_update_interval: Math.trunc(Number(healthInterval)),
            }},
          }},
        }},
        "Applying telemetry settings…",
        telemetryDisabled ? "telemetry disabled" : "telemetry settings saved"
      );
      if (ok) {{
        setTimeout(() => {{
          void fetchSettingsFromRadio();
        }}, 600);
      }}
    }}

