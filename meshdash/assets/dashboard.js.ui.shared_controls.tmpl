      dashboardColorPickerSyncHost(input, clean);
      if (dashboardColorPickerState.input === input && dashboardColorPickerState.root instanceof HTMLElement && !dashboardColorPickerState.root.hidden) {{
        dashboardColorPickerSetStateFromHex(clean, fallback);
        dashboardColorPickerApplyState({{ syncInput: false, redrawWheel: true }});
