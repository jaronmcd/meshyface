      const fallback = String(opts.fallback || input.dataset.colorPickerFallback || dashboardColorPickerState.fallback || "#ffffff");
      const clean = dashboardColorPickerNormalizeHex(hex, fallback);
      const previous = String(input.value == null ? "" : input.value);
      if (previous !== clean) {{
        input.value = clean;
      }}
      dashboardColorPickerSyncHost(input, clean);
      if (opts.dispatchInput === true && previous !== clean) {{
        input.dispatchEvent(new Event("input", {{ bubbles: true }}));
      }}
      if (opts.dispatchChange === true) {{
        input.dispatchEvent(new Event("change", {{ bubbles: true }}));
      }}
      return clean;
    }}

    function syncDashboardColorPickerInput(inputOrId, options = {{}}) {{
