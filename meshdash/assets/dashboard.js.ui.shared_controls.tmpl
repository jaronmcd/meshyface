    function dashboardColorPickerDrawWheel() {{
      const controls = dashboardColorPickerState.controls || {{}};
      const canvas = controls.canvas;
      if (!(canvas instanceof HTMLCanvasElement)) return;
      const rect = canvas.getBoundingClientRect();
      const cssSize = Math.max(128, Math.round(Math.min(rect.width || 184, rect.height || 184)));
      const ratio = Math.max(1, Math.min(2, Number(window.devicePixelRatio) || 1));
      const pixelSize = Math.max(128, Math.round(cssSize * ratio));
      if (canvas.width !== pixelSize || canvas.height !== pixelSize) {{
        canvas.width = pixelSize;
        canvas.height = pixelSize;
      }}
      const ctx = canvas.getContext("2d");
      if (!ctx) return;
      const image = ctx.createImageData(pixelSize, pixelSize);
      const data = image.data;
      const center = pixelSize / 2;
      const radius = Math.max(1, center - ratio);
      const value = Math.round(dashboardColorPickerClamp(dashboardColorPickerState.v, 0, 100));
      for (let y = 0; y < pixelSize; y += 1) {{
        for (let x = 0; x < pixelSize; x += 1) {{
          const dx = (x + 0.5) - center;
          const dy = (y + 0.5) - center;
          const distance = Math.sqrt((dx * dx) + (dy * dy));
          const idx = ((y * pixelSize) + x) * 4;
          if (distance > radius) {{
            data[idx + 3] = 0;
            continue;
          }}
          let hue = Math.atan2(dy, dx) * 180 / Math.PI;
          if (hue < 0) hue += 360;
          const saturation = Math.max(0, Math.min(100, (distance / radius) * 100));
          const rgb = dashboardColorPickerHsvToRgb(hue, saturation, value);
          data[idx] = rgb.r;
          data[idx + 1] = rgb.g;
          data[idx + 2] = rgb.b;
          data[idx + 3] = 255;
        }}
      }}
      ctx.putImageData(image, 0, 0);
    }}

    function dashboardColorPickerUpdateCursor() {{
      const controls = dashboardColorPickerState.controls || {{}};
      const canvas = controls.canvas;
      const cursor = controls.cursor;
      if (!(canvas instanceof HTMLCanvasElement) || !(cursor instanceof HTMLElement)) return;
      const rect = canvas.getBoundingClientRect();
      const size = Math.max(128, Math.min(rect.width || 184, rect.height || 184));
      const radius = Math.max(1, (size / 2) - 1);
      const sat = dashboardColorPickerClamp(dashboardColorPickerState.s, 0, 100) / 100;
      const hueRad = dashboardColorPickerClamp(dashboardColorPickerState.h, 0, 359) * Math.PI / 180;
      const x = (size / 2) + Math.cos(hueRad) * radius * sat;
      const y = (size / 2) + Math.sin(hueRad) * radius * sat;
      cursor.style.left = x.toFixed(1) + "px";
      cursor.style.top = y.toFixed(1) + "px";
    }}

    function dashboardColorPickerApplyState(options = {{}}) {{
      const opts = options && typeof options === "object" ? options : {{}};
      const controls = dashboardColorPickerState.controls || {{}};
      const rgb = dashboardColorPickerHsvToRgb(
        dashboardColorPickerState.h,
        dashboardColorPickerState.s,
        dashboardColorPickerState.v
      );
      const hex = dashboardColorPickerRgbToHex(rgb.r, rgb.g, rgb.b);
      if (controls.title instanceof HTMLElement) {{
        controls.title.textContent = String(dashboardColorPickerState.title || "Color");
      }}
      if (controls.preview instanceof HTMLElement) {{
        controls.preview.style.setProperty("--dashboard-color-picker-value", hex);
      }}
      if (controls.hexInput instanceof HTMLInputElement && opts.syncHexInput !== false) {{
        controls.hexInput.value = hex;
      }}
      if (controls.brightRange instanceof HTMLInputElement) {{
        controls.brightRange.value = String(Math.round(dashboardColorPickerState.v));
      }}
      if (controls.brightValue instanceof HTMLOutputElement) {{
        controls.brightValue.value = String(Math.round(dashboardColorPickerState.v));
        controls.brightValue.textContent = String(Math.round(dashboardColorPickerState.v));
      }}
      if (controls.hueInput instanceof HTMLInputElement) controls.hueInput.value = String(Math.round(dashboardColorPickerState.h));
      if (controls.satInput instanceof HTMLInputElement) controls.satInput.value = String(Math.round(dashboardColorPickerState.s));
      if (controls.valInput instanceof HTMLInputElement) controls.valInput.value = String(Math.round(dashboardColorPickerState.v));
      if (controls.redInput instanceof HTMLInputElement) controls.redInput.value = String(rgb.r);
      if (controls.greenInput instanceof HTMLInputElement) controls.greenInput.value = String(rgb.g);
      if (controls.blueInput instanceof HTMLInputElement) controls.blueInput.value = String(rgb.b);
      if (dashboardColorPickerState.input instanceof HTMLInputElement && opts.syncInput !== false) {{
        dashboardColorPickerWriteInput(dashboardColorPickerState.input, hex, {{
          dispatchInput: opts.dispatchInput === true,
          dispatchChange: opts.dispatchChange === true,
          fallback: dashboardColorPickerState.fallback,
        }});
      }}
      if (opts.redrawWheel === true) {{
        dashboardColorPickerDrawWheel();
      }}
      dashboardColorPickerUpdateCursor();
      return hex;
    }}

    function dashboardColorPickerPickFromCanvas(ev, dispatchInput = true, dispatchChange = false) {{
      const controls = dashboardColorPickerState.controls || {{}};
      const canvas = controls.canvas;
      if (!(canvas instanceof HTMLCanvasElement)) return;
      const rect = canvas.getBoundingClientRect();
      const width = Math.max(1, rect.width || 184);
      const height = Math.max(1, rect.height || 184);
      const centerX = width / 2;
      const centerY = height / 2;
      let dx = Number(ev.clientX) - rect.left - centerX;
      let dy = Number(ev.clientY) - rect.top - centerY;
      const radius = Math.max(1, Math.min(width, height) / 2 - 1);
      const distance = Math.sqrt((dx * dx) + (dy * dy));
      const clampedDistance = Math.min(radius, distance);
      if (distance > radius && distance > 0) {{
        const scale = radius / distance;
        dx *= scale;
        dy *= scale;
      }}
      if (clampedDistance > 1) {{
        let hue = Math.atan2(dy, dx) * 180 / Math.PI;
        if (hue < 0) hue += 360;
        dashboardColorPickerState.h = Math.round(hue);
      }}
      dashboardColorPickerState.s = Math.round((clampedDistance / radius) * 100);
      dashboardColorPickerApplyState({{ dispatchInput, dispatchChange }});
    }}

    function positionDashboardColorPicker(anchor) {{
      const root = ensureDashboardColorPickerPanel();
      if (!(root instanceof HTMLElement) || !(anchor instanceof HTMLElement)) return;
      const margin = 8;
      const rect = anchor.getBoundingClientRect();
      const viewportWidth = Math.max(document.documentElement.clientWidth || 0, window.innerWidth || 0);
      const viewportHeight = Math.max(document.documentElement.clientHeight || 0, window.innerHeight || 0);
      const panelWidth = Math.max(260, root.offsetWidth || 300);
      const panelHeight = Math.max(420, root.offsetHeight || 460);
      let left = rect.left;
      let top = rect.bottom + margin;
      if (left + panelWidth + margin > viewportWidth) {{
        left = Math.max(margin, viewportWidth - panelWidth - margin);
      }}
      if (top + panelHeight + margin > viewportHeight) {{
        top = rect.top - panelHeight - margin;
      }}
      if (top < margin) top = margin;
      root.style.left = Math.round(left) + "px";
      root.style.top = Math.round(top) + "px";
    }}

    function dashboardColorPickerDocumentPointerDown(ev) {{
      const root = dashboardColorPickerState.root;
      if (!(root instanceof HTMLElement) || root.hidden) return;
      const target = ev.target;
      if (target instanceof Node && root.contains(target)) return;
      const anchor = dashboardColorPickerState.anchor;
      if (anchor instanceof HTMLElement && target instanceof Node && anchor.contains(target)) return;
      closeDashboardColorPicker({{ commit: true }});
    }}

    function dashboardColorPickerDocumentKeyDown(ev) {{
      if (String(ev.key || "") !== "Escape") return;
      const root = dashboardColorPickerState.root;
      if (!(root instanceof HTMLElement) || root.hidden) return;
      ev.preventDefault();
      closeDashboardColorPicker({{ commit: false }});
    }}

    function dashboardColorPickerReposition() {{
      const root = dashboardColorPickerState.root;
      if (!(root instanceof HTMLElement) || root.hidden) return;
      positionDashboardColorPicker(dashboardColorPickerState.anchor);
    }}

    function openDashboardColorPicker(inputOrId, options = {{}}) {{
      const input = typeof inputOrId === "string"
        ? document.getElementById(inputOrId)
        : inputOrId;
      if (!(input instanceof HTMLInputElement)) return null;
      const opts = options && typeof options === "object" ? options : {{}};
      const root = ensureDashboardColorPickerPanel();
      const fallback = dashboardColorPickerNormalizeHex(opts.fallback || input.dataset.colorPickerFallback || input.value || "#ffffff", "#ffffff");
      const anchor = opts.anchor instanceof HTMLElement
        ? opts.anchor
        : (dashboardColorPickerButtonForInput(input) || input);
      const title = String(opts.title || opts.label || input.getAttribute("aria-label") || "Color").trim() || "Color";
      const currentHex = dashboardColorPickerNormalizeHex(input.value, fallback);
      dashboardColorPickerState.input = input;
      dashboardColorPickerState.anchor = anchor;
      dashboardColorPickerState.initialHex = currentHex;
      dashboardColorPickerState.fallback = fallback;
      dashboardColorPickerState.title = title;
      dashboardColorPickerSetStateFromHex(currentHex, fallback);
      root.hidden = false;
      root.classList.add("is-open");
      dashboardColorPickerApplyState({{ syncInput: false, redrawWheel: true }});
      positionDashboardColorPicker(anchor);
      document.addEventListener("pointerdown", dashboardColorPickerDocumentPointerDown, true);
      document.addEventListener("keydown", dashboardColorPickerDocumentKeyDown, true);
      window.addEventListener("resize", dashboardColorPickerReposition);
      window.addEventListener("scroll", dashboardColorPickerReposition, true);
      try {{
        root.focus({{ preventScroll: true }});
      }} catch (_err) {{
        root.focus();
      }}
      return root;
    }}

    function closeDashboardColorPicker(options = {{}}) {{
      const opts = options && typeof options === "object" ? options : {{}};
      const root = dashboardColorPickerState.root;
      const input = dashboardColorPickerState.input;
      const commit = opts.commit !== false;
      if (input instanceof HTMLInputElement) {{
        if (commit) {{
          dashboardColorPickerApplyState({{ dispatchChange: true }});
        }} else {{
          dashboardColorPickerWriteInput(input, dashboardColorPickerState.initialHex, {{
            dispatchInput: true,
            dispatchChange: true,
            fallback: dashboardColorPickerState.fallback,
          }});
        }}
      }}
      if (root instanceof HTMLElement) {{
        root.hidden = true;
        root.classList.remove("is-open");
      }}
      dashboardColorPickerState.input = null;
      dashboardColorPickerState.anchor = null;
      dashboardColorPickerState.dragging = false;
      document.removeEventListener("pointerdown", dashboardColorPickerDocumentPointerDown, true);
      document.removeEventListener("keydown", dashboardColorPickerDocumentKeyDown, true);
      window.removeEventListener("resize", dashboardColorPickerReposition);
      window.removeEventListener("scroll", dashboardColorPickerReposition, true);
    }}

    function attachDashboardColorPicker(inputOrId, options = {{}}) {{
      const input = typeof inputOrId === "string"
        ? document.getElementById(inputOrId)
        : inputOrId;
      if (!(input instanceof HTMLInputElement)) return null;
      const opts = options && typeof options === "object" ? options : {{}};
      const fallback = dashboardColorPickerNormalizeHex(opts.fallback || input.value || "#ffffff", "#ffffff");
      input.dataset.colorPickerFallback = fallback;
      input.classList.add("dashboard-color-picker-input");
      if (opts.textInput !== false) {{
        try {{
          input.type = "text";
        }} catch (_err) {{
        }}
        input.maxLength = 7;
        input.inputMode = "text";
        input.autocomplete = "off";
        input.spellcheck = false;
      }}

      const host = dashboardColorPickerControlHostForInput(input, true);
      let button = dashboardColorPickerButtonForInput(input);
      if (!(button instanceof HTMLButtonElement) && host instanceof HTMLElement) {{
        button = document.createElement("button");
        button.type = "button";
        button.className = "dashboard-color-picker-swatch";
        button.setAttribute("data-color-picker-button", String(input.id || ""));
        host.insertBefore(button, input);
      }}
      if (button instanceof HTMLButtonElement) {{
        button.setAttribute("aria-label", String(opts.buttonLabel || opts.label || input.getAttribute("aria-label") || "Pick color"));
        button.setAttribute("title", String(opts.buttonTitle || opts.buttonLabel || opts.label || "Pick color"));
      }}

      syncDashboardColorPickerInput(input, {{ fallback }});
      if (input.dataset.dashboardColorPickerBound === "1") return button;
      input.dataset.dashboardColorPickerBound = "1";

      if (button instanceof HTMLButtonElement) {{
        button.addEventListener("click", (ev) => {{
          ev.preventDefault();
          const root = dashboardColorPickerState.root;
          if (dashboardColorPickerState.input === input && root instanceof HTMLElement && !root.hidden) {{
            closeDashboardColorPicker({{ commit: true }});
            return;
          }}
          openDashboardColorPicker(input, {{
            anchor: button,
            fallback,
            label: opts.label,
            title: opts.title,
          }});
        }});
      }}

      input.addEventListener("input", () => {{
        if (dashboardColorPickerIsCompleteHex(input.value)) {{
          syncDashboardColorPickerInput(input, {{ fallback }});
        }} else {{
          dashboardColorPickerSyncHost(input, fallback);
        }}
      }});
      input.addEventListener("change", () => {{
        syncDashboardColorPickerInput(input, {{ fallback }});
      }});
      input.addEventListener("keydown", (ev) => {{
        const key = String(ev.key || "");
        if (key === "ArrowDown" && ev.altKey) {{
          ev.preventDefault();
          openDashboardColorPicker(input, {{
            anchor: button instanceof HTMLElement ? button : input,
            fallback,
            label: opts.label,
            title: opts.title,
          }});
        }}
      }});
      return button;
    }}

    function renderSortableListboxTable(tableId, rowModels, options = {{}}) {{
      const rows = Array.isArray(rowModels) ? rowModels : [];
      const emptyTextRaw = options && options.emptyText != null
        ? String(options.emptyText)
        : "No rows.";
      const emptyText = emptyTextRaw.trim() || "No rows.";
      const emptyColspan = Math.max(1, Math.trunc(Number(options && options.emptyColspan) || 1));
      if (!rows.length) {{
        fillTable(tableId, [`<tr><td colspan="${{emptyColspan}}">${{escAttr(emptyText)}}</td></tr>`]);
        return;
      }}

      const renderedRows = rows.map((row) => {{
        const rowModel = (row && typeof row === "object") ? row : {{}};
        const cells = Array.isArray(rowModel.cells) ? rowModel.cells : [];
        const className = String(rowModel.className || "").trim();
        const dataset = (rowModel.dataset && typeof rowModel.dataset === "object")
          ? rowModel.dataset
          : {{}};

        const attrs = [];
        if (className) {{
          attrs.push(`class="${{escAttr(className)}}"`);
        }}
        for (const [rawKey, rawValue] of Object.entries(dataset)) {{
          const key = String(rawKey || "").trim().replace(/[^a-zA-Z0-9_-]/g, "");
          if (!key) continue;
          attrs.push(`data-${{key}}="${{escAttr(String(rawValue == null ? "" : rawValue))}}"`);
        }}

        const renderedCells = cells.map((cell) => {{
          const cellModel = (cell && typeof cell === "object") ? cell : {{}};
          const sortValue = String(cellModel.sort == null ? "" : cellModel.sort);
          const titleValue = String(cellModel.title == null ? "" : cellModel.title);
          const cellClass = String(cellModel.className || "").trim();
          const content = cellModel.html != null
            ? String(cellModel.html)
            : escAttr(String(cellModel.text == null ? "" : cellModel.text));
          const tdAttrs = [`data-sort="${{escAttr(sortValue)}}"`];
          if (titleValue) {{
            tdAttrs.push(`title="${{escAttr(titleValue)}}"`);
          }}
          if (cellClass) {{
            tdAttrs.push(`class="${{escAttr(cellClass)}}"`);
          }}
          return `<td ${{tdAttrs.join(" ")}}>${{content}}</td>`;
        }});

        return `<tr ${{attrs.join(" ")}}>${{renderedCells.join("")}}</tr>`;
      }});

      fillTable(tableId, renderedRows);
    }}
