        button.dataset.bound = "1";
        button.addEventListener("mousedown", (ev) => {{
          ev.preventDefault();
        }});
        button.addEventListener("click", (ev) => {{
          ev.preventDefault();
          ev.stopPropagation();
          if (input.disabled || input.readOnly) return;
          if (String(input.value == null ? "" : input.value) !== "") {{
            input.value = "";
            syncSearchTextInputClearButton(input);
            input.dispatchEvent(new Event("input", {{ bubbles: true }}));
          }}
          try {{
            input.focus({{ preventScroll: true }});
          }} catch (_err) {{
            input.focus();
          }}
        }});
      }}

      if (input.dataset.clearButtonStateBound !== "1") {{
        input.dataset.clearButtonStateBound = "1";
        input.addEventListener("input", () => {{
          syncSearchTextInputClearButton(input);
        }});
      }}

      syncSearchTextInputClearButton(input);
      return button;
    }}

    function bindSearchTextInput(inputId, options = {{}}) {{
      const input = document.getElementById(inputId);
      if (!(input instanceof HTMLInputElement)) return null;

      const normalize = typeof options.normalize === "function"
        ? options.normalize
        : ((value) => String(value == null ? "" : value));
      const onInput = typeof options.onInput === "function"
        ? options.onInput
        : null;

      if (input.dataset.bound !== "1") {{
        input.dataset.bound = "1";
        if (onInput) {{
          input.addEventListener("input", () => {{
            const rawValue = String(input.value == null ? "" : input.value);
            onInput(normalize(rawValue), rawValue, input);
          }});
        }}
      }}

      if (Object.prototype.hasOwnProperty.call(options || {{}}, "value")) {{
        const valueText = String(options.value == null ? "" : options.value);
        if (input.value !== valueText) {{
          input.value = valueText;
        }}
      }}

      if (options.clearable === true) {{
        ensureSearchTextInputClearButton(input, options);
      }} else {{
        syncSearchTextInputClearButton(input);
      }}

      return input;
    }}

    const dashboardColorPickerState = {{
      root: null,
      input: null,
      anchor: null,
      initialHex: "#ffffff",
      fallback: "#ffffff",
      h: 0,
      s: 0,
      v: 100,
      dragging: false,
      controls: {{}},
    }};

    function dashboardColorPickerClamp(value, minValue, maxValue) {{
      const raw = Number(value);
      const min = Number(minValue);
      const max = Number(maxValue);
      const safeMin = Number.isFinite(min) ? min : 0;
      const safeMax = Number.isFinite(max) ? max : safeMin;
      if (!Number.isFinite(raw)) return safeMin;
      return Math.max(safeMin, Math.min(safeMax, raw));
    }}

    function dashboardColorPickerNormalizeHex(value, fallback = "#ffffff") {{
      const fallbackText = String(fallback == null ? "" : fallback).trim().toLowerCase();
      const fallbackColor = /^#[0-9a-f]{6}$/i.test(fallbackText) ? fallbackText : "#ffffff";
      let text = String(value == null ? "" : value).trim().toLowerCase();
      if (!text) return fallbackColor;
      if (text[0] !== "#") text = "#" + text;
      if (/^#[0-9a-f]{3}$/i.test(text)) {{
        return "#" + text[1] + text[1] + text[2] + text[2] + text[3] + text[3];
      }}
      if (/^#[0-9a-f]{6}$/i.test(text)) return text;
      return fallbackColor;
    }}

    function dashboardColorPickerIsCompleteHex(value) {{
      let text = String(value == null ? "" : value).trim();
      if (!text) return false;
      if (text[0] !== "#") text = "#" + text;
      return /^#[0-9a-f]{3}$/i.test(text) || /^#[0-9a-f]{6}$/i.test(text);
    }}

    function dashboardColorPickerHexToRgb(value, fallback = "#ffffff") {{
      const hex = dashboardColorPickerNormalizeHex(value, fallback);
      return {{
        r: parseInt(hex.slice(1, 3), 16),
        g: parseInt(hex.slice(3, 5), 16),
        b: parseInt(hex.slice(5, 7), 16),
      }};
    }}

    function dashboardColorPickerRgbToHex(r, g, b) {{
      const part = (value) => {{
        const clean = Math.round(dashboardColorPickerClamp(value, 0, 255));
        return clean.toString(16).padStart(2, "0");
      }};
      return "#" + part(r) + part(g) + part(b);
    }}

    function dashboardColorPickerRgbToHsv(r, g, b) {{
      const red = dashboardColorPickerClamp(r, 0, 255) / 255;
      const green = dashboardColorPickerClamp(g, 0, 255) / 255;
      const blue = dashboardColorPickerClamp(b, 0, 255) / 255;
      const max = Math.max(red, green, blue);
      const min = Math.min(red, green, blue);
      const delta = max - min;
      let hue = 0;
      if (delta > 0) {{
        if (max === red) {{
          hue = 60 * (((green - blue) / delta) % 6);
        }} else if (max === green) {{
          hue = 60 * (((blue - red) / delta) + 2);
        }} else {{
          hue = 60 * (((red - green) / delta) + 4);
        }}
      }}
      while (hue < 0) hue += 360;
      while (hue >= 360) hue -= 360;
      const saturation = max <= 0 ? 0 : (delta / max) * 100;
      return {{
        h: Math.round(hue),
        s: Math.round(saturation),
        v: Math.round(max * 100),
      }};
    }}

    function dashboardColorPickerHsvToRgb(h, s, v) {{
      let hue = Number(h);
      if (!Number.isFinite(hue)) hue = 0;
      hue = ((hue % 360) + 360) % 360;
      const saturation = dashboardColorPickerClamp(s, 0, 100) / 100;
      const value = dashboardColorPickerClamp(v, 0, 100) / 100;
      const chroma = value * saturation;
      const segment = hue / 60;
      const x = chroma * (1 - Math.abs((segment % 2) - 1));
      const m = value - chroma;
      let red = 0;
      let green = 0;
      let blue = 0;
      if (segment >= 0 && segment < 1) {{
        red = chroma; green = x; blue = 0;
      }} else if (segment >= 1 && segment < 2) {{
        red = x; green = chroma; blue = 0;
      }} else if (segment >= 2 && segment < 3) {{
        red = 0; green = chroma; blue = x;
      }} else if (segment >= 3 && segment < 4) {{
        red = 0; green = x; blue = chroma;
      }} else if (segment >= 4 && segment < 5) {{
        red = x; green = 0; blue = chroma;
      }} else {{
        red = chroma; green = 0; blue = x;
      }}
      return {{
        r: Math.round((red + m) * 255),
        g: Math.round((green + m) * 255),
        b: Math.round((blue + m) * 255),
      }};
    }}

    function dashboardColorPickerSetStateFromHex(hex, fallback = dashboardColorPickerState.fallback) {{
      const rgb = dashboardColorPickerHexToRgb(hex, fallback);
      const hsv = dashboardColorPickerRgbToHsv(rgb.r, rgb.g, rgb.b);
      dashboardColorPickerState.h = hsv.h;
      dashboardColorPickerState.s = hsv.s;
      dashboardColorPickerState.v = hsv.v;
      return dashboardColorPickerNormalizeHex(hex, fallback);
    }}

    function dashboardColorPickerControlHostForInput(input, create = false) {{
