    function sortedChatPollNodeIdList(values) {{
      const source = values && typeof values[Symbol.iterator] === "function"
        ? Array.from(values)
        : [];
      return source
        .map((value) => normalizeNodeId(value))
        .filter((value) => !!value)
        .sort();
    }}

    function sortedChatPollStringList(values) {{
      const source = values && typeof values[Symbol.iterator] === "function"
        ? Array.from(values)
        : [];
      return source
        .map((value) => String(value == null ? "" : value).trim())
        .filter((value) => !!value)
        .sort();
    }}

    function normalizeChatPollNoticeRows(channel) {{
      const notices = (typeof chatChangeNoticesForChannel === "function")
        ? chatChangeNoticesForChannel(channel)
        : [];
      if (!Array.isArray(notices)) return [];
      return notices
        .map((notice) => [
          String((notice && notice.key) || "").trim(),
          normalizeNodeId(notice && notice.peerNodeId),
          String((notice && (notice.focusKey || notice.key)) || "").trim(),
          normalizeChatChannel((notice && (notice.targetChatChannel || notice.channel)) || channel),
          String((notice && notice.targetView) || "").trim(),
        ])
        .sort((left, right) => JSON.stringify(left).localeCompare(JSON.stringify(right)));
    }}

    function buildChatPollStructuralSignature(state = latestState) {{
      const safeState = state && typeof state === "object" ? state : {{}};
      const safeTraffic = (safeState.traffic && typeof safeState.traffic === "object")
        ? safeState.traffic
        : {{}};
      const nodes = Array.isArray(safeState.nodes) ? safeState.nodes : [];
      const historyCapsObj = (safeState.history_caps && typeof safeState.history_caps === "object")
        ? safeState.history_caps
        : {{}};
      const recentChat = Array.isArray(safeTraffic.recent_chat) ? safeTraffic.recent_chat : [];
      const recentFiles = Array.isArray(safeTraffic.recent_files) ? safeTraffic.recent_files : [];
      const activeMeshFilterIndex = (typeof activeMeshChannelFilterIndex === "function")
        ? activeMeshChannelFilterIndex()
        : meshChannelAllIndex;
      const macrosPreviewRows = Array.isArray(macrosPreviewLines)
        ? macrosPreviewLines.slice(-120).map((line) => String(line == null ? "" : line))
        : [];
      const historyCapsRows = Object.entries(historyCapsObj)
        .sort(([leftId], [rightId]) => String(leftId).localeCompare(String(rightId)))
        .map(([rawNodeId, caps]) => {{
          const safeCaps = caps && typeof caps === "object" ? caps : {{}};
          return [
            normalizeNodeId(rawNodeId),
            safeCaps.has_position === true || safeCaps.hasPosition === true ? 1 : 0,
          ];
        }});
      const nodesRows = nodes.map((node) => {{
        const safeNode = node && typeof node === "object" ? node : {{}};
        return [
          normalizeNodeId(safeNode.id),
          String(
            safeNode.short_name
            ?? safeNode.shortName
            ?? (safeNode.user && (safeNode.user.short_name || safeNode.user.shortName))
            ?? ""
          ),
          String(
            safeNode.long_name
            ?? safeNode.longName
            ?? (safeNode.user && (safeNode.user.long_name || safeNode.user.longName))
            ?? ""
          ),
          String(safeNode.hardware_model ?? safeNode.hardwareModel ?? ""),
          String(safeNode.role ?? ""),
        ];
      }});
      const messageRows = recentChat.map((msg) => {{
        const safeMsg = msg && typeof msg === "object" ? msg : {{}};
        return [
          Number(
            safeMsg.message_id
            ?? safeMsg.messageId
            ?? safeMsg.id
            ?? 0
          ) || 0,
          Number(safeMsg.reply_id ?? safeMsg.replyId ?? 0) || 0,
          normalizeNodeId(
            safeMsg.from
            ?? safeMsg.from_id
            ?? safeMsg.fromId
            ?? safeMsg.source
            ?? safeMsg.source_id
            ?? safeMsg.sourceId
          ),
          normalizeNodeId(
            safeMsg.to
            ?? safeMsg.to_id
            ?? safeMsg.toId
            ?? safeMsg.destination
            ?? safeMsg.dest
            ?? safeMsg.dest_id
            ?? safeMsg.destId
          ),
          String(safeMsg.scope ?? ""),
          String(safeMsg.channel ?? ""),
          String(safeMsg.rx_time ?? safeMsg.rxTime ?? ""),
          String(safeMsg.captured_at ?? safeMsg.capturedAt ?? ""),
          String(safeMsg.text ?? ""),
          safeMsg.local_echo === true || safeMsg.localEcho === true ? 1 : 0,
          String(safeMsg.delivery_state ?? safeMsg.deliveryState ?? ""),
          Number(safeMsg.delivery_updated_unix ?? safeMsg.deliveryUpdatedUnix ?? 0) || 0,
          String(safeMsg.delivery_updated_at ?? safeMsg.deliveryUpdatedAt ?? ""),
        ];
      }});
      const fileRows = recentFiles.map((entry) => {{
        const safeEntry = entry && typeof entry === "object" ? entry : {{}};
        return [
          normalizeNodeId(
            safeEntry.peer_node_id
            ?? safeEntry.peerNodeId
            ?? safeEntry.to
            ?? safeEntry.destination
          ),
          String(safeEntry.file_name ?? safeEntry.fileName ?? ""),
          String(safeEntry.phase ?? ""),
          Number(safeEntry.percent ?? safeEntry.progress_percent ?? safeEntry.progressPercent ?? 0) || 0,
          Number(safeEntry.updated_unix ?? safeEntry.updatedUnix ?? 0) || 0,
        ];
      }});
      return JSON.stringify({{
        activeLayoutView: String(activeLayoutView || "").trim(),
        activeChatChannel: normalizeChatChannel(activeChatChannel || "all"),
        selectedNodeId: normalizeNodeId(selectedNodeId || ""),
        chatDirectActivePeerId: normalizeNodeId(chatDirectActivePeerId || ""),
        peerDmActivePeerId: normalizeNodeId(peerDmActivePeerId || ""),
        activeMeshFilterIndex: normalizeMeshChannelIndex(activeMeshFilterIndex),
        chatViewMode: String(chatViewMode || "default").trim(),
        rosterQuery: (typeof globalNodeSearchQuery === "function")
          ? String(globalNodeSearchQuery() || "")
          : "",
        sortKey: normalizeChatNodeNavigatorSortKeyPref(chatNodeNavigatorSortKey),
        sortDir: normalizeChatNodeNavigatorSortDirPref(chatNodeNavigatorSortDir),
        metaFieldIds: Array.isArray(chatNodeNavigatorMetaFieldIds)
          ? chatNodeNavigatorMetaFieldIds.slice()
          : [],
        pinDirectHistory: !!chatNodeNavigatorPinDirectHistory,
        showIdle: !!chatNodeNavigatorShowIdle,
        showPacketDirection: !!chatNodeNavigatorShowPacketDirection,
        localNodeId: normalizeNodeId(resolveLocalNodeId(safeState) || ""),
        chatLocalInfoVersion,
        favorites: sortedChatPollNodeIdList(favoriteNodeIds),
        muted: sortedChatPollNodeIdList(mutedNodeIds),
        pinned: sortedChatPollNodeIdList(pinnedNodeIds),
        whitelist: sortedChatPollNodeIdList(nodeVisibilityWhitelistIds),
        blacklist: sortedChatPollNodeIdList(nodeVisibilityBlacklistIds),
        manualDirectPeers: sortedChatPollNodeIdList(manualDirectPeerIds),
        nodeNotes: sortedChatPollNodeIdList(nodeNotesById instanceof Map ? nodeNotesById.keys() : []),
        acknowledgedAll: sortedChatPollStringList(
          typeof chatChangeAcknowledgedKeySetForChannel === "function"
            ? chatChangeAcknowledgedKeySetForChannel("all")
            : []
        ),
        acknowledgedDirect: sortedChatPollStringList(
          typeof chatChangeAcknowledgedKeySetForChannel === "function"
            ? chatChangeAcknowledgedKeySetForChannel("direct")
            : []
        ),
        noticesAll: normalizeChatPollNoticeRows("all"),
        noticesDirect: normalizeChatPollNoticeRows("direct"),
        macrosLeftViewMode: String(macrosLeftViewMode || "").trim(),
        macrosPreviewSourceLabel: String(macrosPreviewSourceLabel || "").trim(),
        macrosPreviewUpdatedAtUnix: Number(macrosPreviewUpdatedAtUnix || 0) || 0,
        macrosPreviewRows,
        nodesRows,
        historyCapsRows,
        messageRows,
        fileRows,
      }});
    }}

    function chatHistoryMessageKey(msg) {{
      const key = (typeof chatMessageKey === "function") ? String(chatMessageKey(msg) || "") : "";
      if (key) return key;
      const historyId = Number(msg && (msg._history_id ?? msg.history_id));
      if (Number.isInteger(historyId) && historyId > 0) return `history:${{historyId}}`;
      return "";
    }}

    function mergedChatMessagesForRender(liveMessages) {{
      const liveRows = Array.isArray(liveMessages) ? liveMessages : [];
      if (chatHistoryRows.length <= 0) return liveRows;
      if (
        chatHistoryMergedMessagesCache
        && chatHistoryMergedMessagesCache.liveRef === liveRows
        && chatHistoryMergedMessagesCache.version === chatHistoryRowsVersion
      ) {{
        return chatHistoryMergedMessagesCache.rows;
      }}
      const keyedRows = new Map();
      const unkeyedRows = [];
      const addRow = (row) => {{
        if (!(row && typeof row === "object")) return;
        const key = chatHistoryMessageKey(row);
        if (key) {{
          keyedRows.set(key, row);
        }} else {{
          unkeyedRows.push(row);
        }}
      }};
      for (const row of chatHistoryRows) addRow(row);
      for (const row of liveRows) addRow(row);
      const rows = Array.from(keyedRows.values()).concat(unkeyedRows);
      chatHistoryMergedMessagesCache = {{
        liveRef: liveRows,
        version: chatHistoryRowsVersion,
        rows,
      }};
      return rows;
    }}

    function chatHistoryViewKeyFor(channel, peerId = "") {{
      const scope = String(channel || "").trim().toLowerCase() === "direct" ? "direct" : "all";
      const meshIdx = (typeof activeMeshChannelFilterIndex === "function")
        ? activeMeshChannelFilterIndex()
        : meshChannelAllIndex;
      const meshKey = Number.isInteger(meshIdx) ? String(meshIdx) : "all";
      if (scope === "direct") {{
        const cleanPeerId = normalizeNodeId(peerId || chatDirectActivePeerId || selectedNodeId || "");
        return isCanonicalNodeId(cleanPeerId) ? `direct:${{cleanPeerId}}:${{meshKey}}` : `direct::${{meshKey}}`;
      }}
      return `all:${{meshKey}}`;
    }}

    function chatHistoryVisibleLimitForView(viewKey) {{
      const cleanKey = String(viewKey || "").trim();
      const current = Number(chatHistoryVisibleLimitByView.get(cleanKey));
      if (Number.isInteger(current) && current > 0) {{
        return Math.max(chatFeedMaxEntries, current);
      }}
      return chatFeedMaxEntries;
    }}

    function increaseChatHistoryVisibleLimit(viewKey, amount = chatHistoryPageSize) {{
      const cleanKey = String(viewKey || "").trim();
      if (!cleanKey) return;
      const current = chatHistoryVisibleLimitForView(cleanKey);
      const delta = Math.max(1, Math.trunc(Number(amount) || chatHistoryPageSize));
      chatHistoryVisibleLimitByView.set(cleanKey, current + delta);
    }}

    function rememberChatHistoryCursorForView(viewKey, messages) {{
      const cleanKey = String(viewKey || "").trim();
      if (!cleanKey) return;
      const rows = Array.isArray(messages) ? messages : [];
      if (rows.length <= 0) {{
        chatHistoryCursorByView.delete(cleanKey);
        return;
      }}
      const oldest = rows[0];
      const historyId = Number(oldest && (oldest._history_id ?? oldest.history_id));
      const beforeId = Number.isInteger(historyId) && historyId > 0 ? historyId : null;
      const beforeUnix = latestUnixTimestamp(
        oldest && oldest._history_created_unix,
        oldest && oldest.rx_time_unix,
        oldest && oldest.created_unix,
        oldest && oldest.rx_time,
        oldest && oldest.captured_at
      );
      chatHistoryCursorByView.set(cleanKey, {{
        beforeId,
        beforeUnix: Number.isFinite(beforeUnix) && beforeUnix > 0 ? Math.floor(beforeUnix) : null,
      }});
    }}

    function buildChatHistoryLoadControlHtml({{ viewKey, hiddenOlderCount, totalCount, visibleCount }}) {{
      const cleanKey = String(viewKey || "").trim();
      if (!cleanKey) return "";
      const hiddenCount = Math.max(0, Math.trunc(Number(hiddenOlderCount) || 0));
      const exhausted = chatHistoryExhaustedByView.has(cleanKey);
      const canLoad = hiddenCount > 0 || !exhausted;
      if (!canLoad) return "";
      const loading = !!chatHistoryLoadInFlight;
      const label = loading
        ? "Loading older..."
        : (hiddenCount > 0 ? "Show older" : "Load older");
      const detail = chatHistoryLoadError
        ? `<span class="chat-history-load-error">${{escAttr(chatHistoryLoadError)}}</span>`
        : `<span>${{escAttr(String(visibleCount || 0))}} of ${{escAttr(String(totalCount || 0))}} shown</span>`;
      return `<div class="chat-history-load-row" data-history-view-key="${{escAttr(cleanKey)}}">
        <button type="button" class="chat-history-load-btn" data-history-view-key="${{escAttr(cleanKey)}}" data-hidden-count="${{escAttr(String(hiddenCount))}}"${{loading ? " disabled" : ""}}>${{escAttr(label)}}</button>
        <span class="chat-history-load-detail">${{detail}}</span>
      </div>`;
    }}

    function captureChatHistoryScrollRestore() {{
      const scroller = getChatScroller();
      if (!(scroller instanceof HTMLElement)) return null;
      return {{
        top: scroller.scrollTop,
        height: scroller.scrollHeight,
      }};
    }}

    function restoreChatHistoryScrollPosition() {{
      const restore = chatHistoryScrollRestore;
      chatHistoryScrollRestore = null;
      const scroller = getChatScroller();
      if (!(scroller instanceof HTMLElement) || !restore) return;
      const oldTop = Number(restore.top) || 0;
      const oldHeight = Number(restore.height) || 0;
      window.requestAnimationFrame(() => {{
        const delta = Math.max(0, scroller.scrollHeight - oldHeight);
        scroller.scrollTop = oldTop + delta;
        chatStickToBottom = false;
      }});
    }}

    function appendChatHistoryRows(rows) {{
      const source = Array.isArray(rows) ? rows : [];
      let added = 0;
      for (const row of source) {{
        if (!(row && typeof row === "object")) continue;
        const key = chatHistoryMessageKey(row);
        if (key && chatHistoryRowKeys.has(key)) continue;
        if (key) chatHistoryRowKeys.add(key);
        chatHistoryRows.push(row);
        added += 1;
      }}
      while (chatHistoryRows.length > chatHistoryLoadedMaxEntries) {{
        const removed = chatHistoryRows.shift();
        const key = chatHistoryMessageKey(removed);
        if (key) chatHistoryRowKeys.delete(key);
      }}
      if (added > 0) {{
        chatHistoryRowsVersion += 1;
        chatHistoryMergedMessagesCache = null;
        chatDerivedCache = null;
      }}
      return added;
    }}

    async function loadOlderChatMessagesForCurrentView() {{
      if (chatHistoryLoadInFlight) return;
      const viewKey = chatHistoryViewKeyFor(activeChatChannel, chatDirectActivePeerId);
      const cursor = chatHistoryCursorByView.get(viewKey) || {{}};
      const feed = document.getElementById("chat-feed");
      const escapedViewKey = (window.CSS && typeof window.CSS.escape === "function")
        ? window.CSS.escape(viewKey)
        : viewKey.replace(/["\\]/g, "\\$&");
      const loadRow = feed instanceof HTMLElement
        ? feed.querySelector(`.chat-history-load-row[data-history-view-key="${{escapedViewKey}}"]`)
        : null;
      const hiddenCount = loadRow instanceof HTMLElement
        ? Math.max(0, Math.trunc(Number(loadRow.querySelector(".chat-history-load-btn")?.dataset.hiddenCount || 0) || 0))
        : 0;

      chatHistoryScrollRestore = captureChatHistoryScrollRestore();
      chatStickToBottom = false;
      if (hiddenCount > 0) {{
        increaseChatHistoryVisibleLimit(viewKey, Math.min(chatHistoryPageSize, hiddenCount));
        if (latestState) renderChat(latestState);
        return;
      }}

      const params = new URLSearchParams();
      params.set("limit", String(chatHistoryPageSize));
      params.set("scope", activeChatChannel === "direct" ? "direct" : "all");
      if (activeChatChannel === "direct" && isCanonicalNodeId(chatDirectActivePeerId)) {{
        params.set("peer_id", chatDirectActivePeerId);
      }}
      const beforeId = Number(cursor.beforeId);
      const beforeUnix = Number(cursor.beforeUnix);
      if (Number.isInteger(beforeId) && beforeId > 0) {{
        params.set("before_id", String(beforeId));
      }} else if (Number.isFinite(beforeUnix) && beforeUnix > 0) {{
        params.set("before_unix", String(Math.floor(beforeUnix)));
      }}

      chatHistoryLoadInFlight = true;
      chatHistoryLoadError = "";
      if (latestState) renderChat(latestState);
      try {{
        const resp = await fetch(`/api/history/chat?${{params.toString()}}`, {{ cache: "no-store" }});
        const payload = await resp.json();
        if (!resp.ok || !payload || payload.ok !== true) {{
          throw new Error((payload && payload.error) || `history request failed (${{resp.status}})`);
        }}
        const rows = Array.isArray(payload.messages) ? payload.messages : [];
        const added = appendChatHistoryRows(rows);
        if (rows.length < chatHistoryPageSize || payload.has_more === false) {{
          chatHistoryExhaustedByView.add(viewKey);
        }}
        if (added > 0) {{
          increaseChatHistoryVisibleLimit(viewKey, Math.max(chatHistoryPageSize, added));
        }}
      }} catch (err) {{
        chatHistoryLoadError = err instanceof Error ? (err.message || String(err)) : String(err || "history request failed");
      }} finally {{
        chatHistoryLoadInFlight = false;
        if (latestState) renderChat(latestState);
      }}
    }}

    function chatReplyJumpFrame() {{
      return new Promise((resolve) => {{
        window.requestAnimationFrame(() => resolve());
      }});
    }}

    function findChatFeedItemByMessageId(messageIdRaw) {{
      const messageId = parsePositiveMessageId(messageIdRaw);
      if (!messageId) return null;
      const feed = document.getElementById("chat-feed");
      if (!(feed instanceof HTMLElement)) return null;
      const messageIdText = String(messageId);
      const escapedId = (window.CSS && typeof window.CSS.escape === "function")
        ? window.CSS.escape(messageIdText)
        : messageIdText.replace(/["\\]/g, "\\$&");
      const item = feed.querySelector(`.chat-feed-item[data-message-id="${{escapedId}}"]`);
      return item instanceof HTMLElement ? item : null;
    }}

    function focusChatFeedItemByMessageId(messageIdRaw) {{
      const messageId = parsePositiveMessageId(messageIdRaw);
      if (!messageId) return false;
      let item = findChatFeedItemByMessageId(messageId);
      if (!(item instanceof HTMLElement)) return false;
      if (item.hidden || item.classList.contains("chat-feed-search-hidden")) {{
        chatFeedSearchQuery = "";
        if (typeof applyChatFeedSearchFilter === "function") {{
          applyChatFeedSearchFilter();
        }}
        item = findChatFeedItemByMessageId(messageId);
      }}
      if (!(item instanceof HTMLElement) || item.hidden) return false;
      chatStickToBottom = false;
      item.scrollIntoView({{ behavior: "smooth", block: "center" }});
      if (typeof focusChatFeedItem === "function") {{
        focusChatFeedItem(item);
      }} else {{
        item.classList.add("change-focus");
        window.setTimeout(() => item.classList.remove("change-focus"), 1600);
      }}
      return true;
    }}

    async function jumpToOriginalChatMessage(messageIdRaw) {{
      const messageId = parsePositiveMessageId(messageIdRaw);
      if (!messageId) return false;
      if (chatReplyJumpInFlight) {{
        if (typeof setChatSendStatus === "function") {{
          setChatSendStatus("Already finding an original chat message.");
        }}
        return false;
      }}
      if (focusChatFeedItemByMessageId(messageId)) return true;

      chatReplyJumpInFlight = true;
      if (typeof setChatSendStatus === "function") {{
        setChatSendStatus(`Finding original packet #${{messageId}}...`);
      }}
      try {{
        for (let attempt = 0; attempt < 12; attempt += 1) {{
          const viewKey = chatHistoryViewKeyFor(activeChatChannel, chatDirectActivePeerId);
          const beforeRows = chatHistoryRows.length;
          const beforeLimit = chatHistoryVisibleLimitForView(viewKey);
          const beforeExhausted = chatHistoryExhaustedByView.has(viewKey);
          await loadOlderChatMessagesForCurrentView();
          await chatReplyJumpFrame();
          if (focusChatFeedItemByMessageId(messageId)) {{
            if (typeof setChatSendStatus === "function") {{
              setChatSendStatus(`Opened original packet #${{messageId}}.`);
            }}
            return true;
          }}
          const afterRows = chatHistoryRows.length;
          const afterLimit = chatHistoryVisibleLimitForView(viewKey);
          const afterExhausted = chatHistoryExhaustedByView.has(viewKey);
          const noProgress = (
            beforeRows === afterRows
            && beforeLimit === afterLimit
            && beforeExhausted === afterExhausted
          );
          if (afterExhausted && noProgress) break;
          if (chatHistoryLoadError) break;
        }}
      }} finally {{
        chatReplyJumpInFlight = false;
      }}
      if (typeof setChatSendStatus === "function") {{
        const errorSuffix = chatHistoryLoadError ? ` ${{chatHistoryLoadError}}` : "";
        setChatSendStatus(`Original packet #${{messageId}} is not in the loaded chat view.${{errorSuffix}}`, true);
      }}
      return false;
    }}

    function renderChat(state, options = null) {{
      syncTopbarChatContext(state);
      const renderOptions = options && typeof options === "object" ? options : {{}};
      const allowPollSkip = !!renderOptions.allowPollSkip;
      let renderChatPhase = "init";
      const chatRenderPerfEnabled = !!chatPerfEnabled;
      const chatRenderStartMs = chatRenderPerfEnabled ? chatPerfNowMs() : 0;
      let chatRenderLastPhaseMs = chatRenderStartMs;
      const chatRenderPhases = [];
      const markRenderChatPhase = (phase) => {{
        const clean = String(phase || "").trim();
        if (clean) {{
          renderChatPhase = clean;
          if (chatRenderPerfEnabled && chatRenderStartMs > 0) {{
            const nowMs = chatPerfNowMs();
            chatRenderPhases.push({{
              name: clean,
              deltaMs: roundChatPerfMs(nowMs - chatRenderLastPhaseMs),
              atMs: roundChatPerfMs(nowMs - chatRenderStartMs),
            }});
            chatRenderLastPhaseMs = nowMs;
          }}
        }}
      }};
      const finishChatRenderStats = (status, extra = null) => {{
        if (!chatRenderPerfEnabled || chatRenderStartMs <= 0) return;
        const stats = {{
          status: String(status || "complete"),
          totalMs: roundChatPerfMs(chatPerfNowMs() - chatRenderStartMs),
          phases: chatRenderPhases.slice(),
        }};
        if (extra && typeof extra === "object") {{
          Object.assign(stats, extra);
        }}
        recordChatRenderStats(stats);
      }};
      const handleRenderChatFailure = (err) => {{
        const message = err instanceof Error ? (err.message || String(err)) : String(err || "unknown error");
        const detail = `Chat render failed at ${{renderChatPhase}}: ${{message}}`;
        try {{
          if (typeof appendConsoleLine === "function") {{
            appendConsoleLine(`render-chat-error|${{Date.now()}}|${{renderChatPhase}}`, `[chat render error] ${{detail}}`);
          }}
        }} catch (_appendErr) {{
        }}
        try {{
          if (typeof console !== "undefined" && console && typeof console.error === "function") {{
            console.error(`[chat render error] ${{renderChatPhase}}`, err);
          }}
        }} catch (_consoleErr) {{
        }}
        try {{
          if (typeof document !== "undefined" && document && document.body instanceof HTMLElement) {{
            document.body.dataset.chatRenderErrorPhase = renderChatPhase;
          }}
        }} catch (_datasetErr) {{
        }}
        const safeDetail = (typeof trimInlineError === "function")
          ? trimInlineError(detail, 180)
          : detail;
        const feed = (typeof document !== "undefined")
          ? document.getElementById("chat-feed")
          : null;
        if (feed instanceof HTMLElement) {{
          feed.innerHTML = `<div class="chat-feed-empty">${{escAttr(safeDetail)}}</div>`;
        }}
        const roomList = (typeof document !== "undefined")
          ? document.getElementById("chat-room-list")
          : null;
        if (roomList instanceof HTMLElement) {{
          roomList.innerHTML = `<div class="chat-member-empty">${{escAttr(safeDetail)}}</div>`;
        }}
      }};
      try {{
      if (typeof document !== "undefined" && document && document.body instanceof HTMLElement) {{
        document.body.dataset.chatRenderEntered = "1";
      }}
      const traffic = state.traffic || {{}};
      const s = state.summary || {{}};
      const activePollProfile = String(latestStatePollProfile || "").trim();
      if (
        isChatWorkspaceLayoutView(activeLayoutView)
        && activePollProfile
        && activePollProfile !== "chat"
        && activePollProfile !== "default"
      ) {{
        markRenderChatPhase("profile-wait");
        const feed = (typeof document !== "undefined")
          ? document.getElementById("chat-feed")
          : null;
        if (
          feed instanceof HTMLElement
          && !feed.querySelector(".chat-feed-item")
        ) {{
          feed.innerHTML = '<div class="chat-feed-empty">Loading chat...</div>';
        }}
        const waitUnix = Math.floor(Date.now() / 1000);
        renderChatChangeSummary(waitUnix);
        bindChatChangeSummaryControls();
        finishChatRenderStats("profile-wait", {{
          profile: activePollProfile,
          rawMessages: Array.isArray(traffic.recent_chat) ? traffic.recent_chat.length : 0,
        }});
        return;
      }}
      const chatScroller = getChatScroller();
      const shouldStickBottom = !!(chatScroller && (chatStickToBottom || isNearBottom(chatScroller)));
      const nodes = Array.isArray(state.nodes) ? state.nodes : [];
      const historyCapsObj = (state && state.history_caps && typeof state.history_caps === "object")
        ? state.history_caps
        : null;
      updateNodeNameCache(nodes, historyCapsObj);
      const nowUnix = Math.floor(Date.now() / 1000);
      const pollStructuralSignature = allowPollSkip
        ? buildChatPollStructuralSignature(state)
        : "";
      const pollStructuralAgeMs = Math.max(
        0,
        Date.now() - (Number(chatPollStructuralRenderedAtMs) || 0)
      );
      if (
        allowPollSkip
        && pollStructuralSignature
        && pollStructuralSignature === chatPollStructuralSignature
        && pollStructuralAgeMs < chatPollStructuralRefreshMs
      ) {{
        markRenderChatPhase("poll-skip");
        renderChatChangeSummary(nowUnix);
        bindChatChangeSummaryControls();
        syncChatChangeAutoDismiss();
        if (
          typeof syncChatNodeDetailsDrawer === "function"
          && typeof isChatNodeDetailsDrawerExpanded === "function"
          && isChatNodeDetailsDrawerExpanded()
        ) {{
          syncChatNodeDetailsDrawer(state, {{
            fetchHistory: false,
          }});
        }}
        finishChatRenderStats("poll-skip", {{
          rawMessages: Array.isArray(traffic.recent_chat) ? traffic.recent_chat.length : 0,
          rawPackets: Array.isArray(traffic.recent_packets) ? traffic.recent_packets.length : 0,
          nodes: nodes.length,
          allowPollSkip: true,
          pollStructuralAgeMs: roundChatPerfMs(pollStructuralAgeMs),
          pollStructuralRefreshMs: Math.max(0, Math.trunc(Number(chatPollStructuralRefreshMs) || 0)),
        }});
        return;
      }}
      const localNodeId = resolveLocalNodeId(state);
      const nodesById = new Map(
        nodes.map((node) => [normalizeNodeId(node.id || ""), node])
      );
      const nodeIdByNum = new Map();
      for (const node of nodes) {{
        const nodeNum = parseNodeNum(node && node.num);
        const nodeId = normalizeNodeId(node && node.id);
        if (!Number.isInteger(nodeNum) || nodeNum < 0) continue;
        if (!isCanonicalNodeId(nodeId)) continue;
        if (!nodeIdByNum.has(nodeNum)) {{
          nodeIdByNum.set(nodeNum, nodeId);
        }}
      }}
      const historyCapsById = new Map(
        Object.entries(historyCapsObj || {{}})
          .map(([rawNodeId, caps]) => [normalizeNodeId(rawNodeId), caps])
          .filter(([nodeId, caps]) => isSelectableNodeId(nodeId) && caps && typeof caps === "object")
      );
      const latestChatTouchByNode = mapLatestChatTouchInfo(traffic.recent_chat || []);
      const freshnessSnapshotCache = new Map();
      const nodeIdentityCache = new Map();
      const endpointPartsCache = new Map();
      const buildMacrosPreviewFeedItems = (previewLines) => {{
        const lines = Array.isArray(previewLines) ? previewLines.slice(0, 120) : [];
        if (lines.length <= 0) return [];
        let renderedLines = lines;
        let sendViewSuffix = " · send view";
        if (typeof encodeAsciiMacroLineForSend === "function") {{
          const sendSettings = (typeof macrosAsciiSettingsFromInputs === "function")
            ? macrosAsciiSettingsFromInputs()
            : null;
          const useSpaceReplacement = !!(
            sendSettings
            && typeof sendSettings === "object"
            && sendSettings.useSpaceReplacement
          );
          const replacementChar = (
            sendSettings
            && typeof sendSettings === "object"
            && sendSettings.spaceReplacementChar != null
          )
            ? String(sendSettings.spaceReplacementChar)
            : "";
          renderedLines = lines.map((line) => encodeAsciiMacroLineForSend(line, {{
            useSpaceReplacement,
            spaceReplacementChar: replacementChar,
          }}));
          if (useSpaceReplacement && replacementChar) {{
            sendViewSuffix = ` · send view: spaces→${{replacementChar}}`;
          }}
        }}
        const previewUnix = Number.isFinite(macrosPreviewUpdatedAtUnix) && macrosPreviewUpdatedAtUnix > 0
          ? Math.floor(macrosPreviewUpdatedAtUnix)
          : nowUnix;
        const previewRawTime = new Date(previewUnix * 1000).toISOString();
        const previewTimeText = formatLocalChatTime(previewUnix, previewRawTime, nowUnix);
        const previewTitle = macrosPreviewSourceLabel
          ? `ASCII macro preview${{sendViewSuffix}} · ${{macrosPreviewSourceLabel}}`
          : `ASCII macro preview${{sendViewSuffix}}`;
        const selfNodeId = resolveLocalNodeId(state);
        const senderShort = selfRadioProfileShortLabel(selfNodeId || "macr").slice(0, 4) || "macr";
        const senderShortHtml = escAttr(String(senderShort)).replace(/ /g, "&nbsp;");
        return renderedLines.map((line, idx) => {{
          const safeLine = String(line == null ? "" : line);
          const copyHtml = escAttr(safeLine)
            .replace(/\t/g, "&nbsp;&nbsp;")
            .replace(/ /g, "&nbsp;");
          const title = `${{previewTitle}} · line ${{idx + 1}}`;
          return `<div class="chat-feed-item chat-feed-item-monitor-exact chat-feed-item-macro-preview" data-macro-line="${{escAttr(idx + 1)}}" title="${{escAttr(title)}}"><span class="chat-entry-msg"><span class="chat-monitor-prefix">[${{escAttr(previewTimeText)}}]</span><span class="chat-monitor-network-tag">[ ][MF]</span><span class="short-name status-online" style="background:#bcef75" title="${{escAttr(previewTitle)}}">${{senderShortHtml}}</span><span class="chat-entry-copy chat-monitor-text">${{copyHtml || "&nbsp;"}}</span></span></div>`;
        }});
      }};

      function resolveChatNodeFreshness(nodeId) {{
        const clean = normalizeNodeId(nodeId);
        if (!clean || !isSelectableNodeId(clean)) {{
          return {{
            id: "",
            node: null,
            historyCaps: null,
            lastSeenUnix: null,
            status: "unknown",
          }};
        }}
        if (freshnessSnapshotCache.has(clean)) {{
          return freshnessSnapshotCache.get(clean);
        }}
        const node = nodesById.get(clean);
        const historyCaps = historyCapsById.get(clean);
        const chatTouch = latestChatTouchByNode.get(clean) || null;
        const lastSeenUnix = computeNodeFreshnessUnix(node, historyCaps, chatTouch);
        const snapshot = {{
          id: clean,
          node,
          historyCaps,
          lastSeenUnix,
          status: freshnessStatus(lastSeenUnix, nowUnix),
        }};
        freshnessSnapshotCache.set(clean, snapshot);
        return snapshot;
      }}

      const preferredHistoryNodeName = (historyCaps, nodeIdRaw = "", cachedNameRaw = "") => {{
        if (!historyCaps || typeof historyCaps !== "object") return "";
        const nodeId = normalizeNodeId(nodeIdRaw || "");
        const cachedName = String(cachedNameRaw || "").trim();
        const longName = String(historyCaps.last_long_name || "").trim();
        const shortName = String(historyCaps.last_short_name || "").trim();
        const candidate = longName || shortName;
        if (!candidate) return "";
        if (
          cachedName
          && typeof isGenericNodeCacheLabel === "function"
          && !isGenericNodeCacheLabel(cachedName, nodeId)
          && isGenericNodeCacheLabel(candidate, nodeId)
        ) {{
          return "";
        }}
        return candidate;
      }};

      const preferredChatNodeName = (nodeId, node, historyCaps, fallbackName = "") => {{
        const clean = normalizeNodeId(nodeId || "");
        const cached = clean ? String(nodeNameCache.get(clean) || "").trim() : "";
        return preferredNodeName(node) || preferredHistoryNodeName(historyCaps, clean, cached) || cached || fallbackName;
      }};

      const nodeIdentityMeta = (nodeId, options = {{}}) => {{
        const showHops = !(options && options.showHops === false);
        const snapshot = resolveChatNodeFreshness(nodeId);
        const clean = snapshot.id;
        if (!clean) {{
          return {{ html: "", title: "" }};
        }}
        const cacheKey = `${{clean}}|hops:${{showHops ? "1" : "0"}}`;
        if (nodeIdentityCache.has(cacheKey)) {{
          return nodeIdentityCache.get(cacheKey);
        }}
        const node = snapshot.node;
        const historyCaps = snapshot.historyCaps;
        if ((!node || typeof node !== "object") && (!historyCaps || typeof historyCaps !== "object")) {{
          return {{ html: "", title: "" }};
        }}
        const chipStateClass = snapshot.status === "online" ? "online" : "offline";

        const chips = [];
        const titleParts = [];
        const liveHasPosition = !!node
          && typeof node.lat === "number"
          && Number.isFinite(node.lat)
          && typeof node.lon === "number"
          && Number.isFinite(node.lon);
        const historyHasPosition = !!historyCaps && historyCaps.has_position === true;
        if (liveHasPosition || historyHasPosition) {{
          chips.push(`<span class="chat-name-chip gps ${{chipStateClass}}" title="GPS position available">&#x1F4CD;</span>`);
          titleParts.push(liveHasPosition ? "GPS available" : "GPS last known");
        }}

        const batteryRaw = Number(
          (node && node.battery_level != null)
            ? node.battery_level
            : (historyCaps && historyCaps.battery_level)
        );
        if (Number.isFinite(batteryRaw)) {{
          const batteryPct = Math.max(0, Math.min(100, Math.round(batteryRaw)));
          chips.push(`<span class="chat-name-chip battery ${{chipStateClass}}" title="Battery level">${{batteryPct}}%</span>`);
          titleParts.push(
            (node && node.battery_level != null)
              ? `Battery ${{batteryPct}}%`
              : `Battery last known ${{batteryPct}}%`
          );
        }}

        if (showHops) {{
          const hopsRaw = Number(
            (node && node.hops_away != null)
              ? node.hops_away
            : (historyCaps && historyCaps.last_hops)
          );
          if (Number.isFinite(hopsRaw) && hopsRaw >= 0) {{
            const hops = Math.trunc(hopsRaw);
            chips.push(`<span class="chat-name-chip hops ${{chipStateClass}}" title="Hops away">${{hops}}h</span>`);
            titleParts.push(
              (node && node.hops_away != null)
                ? `${{hops}} hop${{hops === 1 ? "" : "s"}} away`
                : `${{hops}} hop${{hops === 1 ? "" : "s"}} last known`
            );
          }}
        }}

        const identity = {{
          html: chips.join(""),
          title: titleParts.join(", "),
        }};
        nodeIdentityCache.set(cacheKey, identity);
        return identity;
      }};

      const chatEndpointParts = (nodeId, _messageUnixHint = null) => {{
        const clean = normalizeNodeId(nodeId);
        if (!clean) {{
          return {{ label: "n/a", idTag: "", title: "n/a", status: "unknown", metaHtml: "", lastSeenUnix: null }};
        }}
        if (endpointPartsCache.has(clean)) {{
          return endpointPartsCache.get(clean);
        }}
        let endpoint = null;
        if (clean === "^all") {{
          endpoint = {{ label: "All", idTag: "", title: "^all", status: "unknown", metaHtml: "", lastSeenUnix: null }};
        }} else if (clean === "local") {{
          endpoint = {{ label: "Local", idTag: "", title: "local", status: "online", metaHtml: "", lastSeenUnix: nowUnix }};
        }} else {{
          const snapshot = resolveChatNodeFreshness(clean);
          const node = snapshot.node;
          const fallbackName = isCanonicalNodeId(clean) ? `Meshtastic ${{clean.slice(-4)}}` : "Unknown node";
          const name = preferredChatNodeName(clean, node, snapshot.historyCaps, fallbackName);
          const meta = nodeIdentityMeta(clean);
          endpoint = {{
            label: name,
            idTag: clean,
            title: `${{name}} (${{clean}})${{meta.title ? ` - ${{meta.title}}` : ""}}`,
            status: snapshot.status,
            metaHtml: meta.html,
            lastSeenUnix: snapshot.lastSeenUnix,
          }};
        }}
        endpointPartsCache.set(clean, endpoint);
        return endpoint;
      }};

      const resolveMessageNodeId = (value) => {{
        const clean = normalizeNodeId(value);
        if (!clean) return "";
        if (isCanonicalNodeId(clean)) return clean;
        if (clean === "^all" || clean === "local" || clean === "Unknown" || clean === "n/a") {{
          return clean;
        }}
        const nodeNum = parseNodeNum(value);
        if (Number.isInteger(nodeNum) && nodeIdByNum.has(nodeNum)) {{
          return nodeIdByNum.get(nodeNum) || clean;
        }}
        return clean;
      }};

      const participants = new Map();
      const touchParticipant = (meta, msgTimeUnix) => {{
        if (!meta || !meta.idTag || !isSelectableNodeId(meta.idTag)) return;
        if (activeChatChannel === "direct" && isCanonicalNodeId(localNodeId) && meta.idTag === localNodeId) {{
          return;
        }}
        const messageUnix = parseDashboardTimeToUnix(msgTimeUnix);
        const existing = participants.get(meta.idTag);
        if (!existing) {{
          participants.set(meta.idTag, {{
            id: meta.idTag,
            name: meta.label || meta.idTag,
            // Keep status tied to node freshness only (not chat message recency),
            // so selection/channel rerenders cannot flip roster colors.
            status: freshnessStatus(meta.lastSeenUnix, nowUnix),
            lastSeenUnix: meta.lastSeenUnix,
            lastMessageUnix: messageUnix || null,
          }});
          return;
        }}
        if (meta.label && meta.label !== "Unknown node") {{
          existing.name = meta.label;
        }}
        existing.lastSeenUnix = latestUnixTimestamp(existing.lastSeenUnix, meta.lastSeenUnix);
        existing.status = freshnessStatus(existing.lastSeenUnix, nowUnix);
        if (messageUnix && (!existing.lastMessageUnix || messageUnix > existing.lastMessageUnix)) {{
          existing.lastMessageUnix = messageUnix;
        }}
      }};

      const touchNodeById = (nodeId, msgTimeUnix = null) => {{
        const clean = normalizeNodeId(nodeId);
        if (!isSelectableNodeId(clean)) return;
        if (!isNodeVisibleByLists(clean)) return;
        if (activeChatChannel === "direct" && isCanonicalNodeId(localNodeId) && clean === localNodeId) {{
          return;
        }}
        const snapshot = resolveChatNodeFreshness(clean);
        const node = snapshot.node;
        const name = preferredChatNodeName(clean, node, snapshot.historyCaps, clean);
        const messageUnix = parseDashboardTimeToUnix(msgTimeUnix);
        const existing = participants.get(clean);
        if (!existing) {{
          participants.set(clean, {{
            id: clean,
            name,
            status: snapshot.status,
            lastSeenUnix: snapshot.lastSeenUnix,
            lastMessageUnix: messageUnix || null,
          }});
          return;
        }}
        if (name && name !== "Unknown node") {{
          existing.name = name;
        }}
        existing.lastSeenUnix = latestUnixTimestamp(existing.lastSeenUnix, snapshot.lastSeenUnix);
        existing.status = freshnessStatus(existing.lastSeenUnix, nowUnix);
        if (messageUnix && (!existing.lastMessageUnix || messageUnix > existing.lastMessageUnix)) {{
          existing.lastMessageUnix = messageUnix;
        }}
      }};

      const messageIdOf = messageIdOfChatPacket;
      const replyIdOf = replyIdOfChatPacket;

      const emojiFromCodepointValue = (value) => {{
        const codepoint = Number(value);
        if (!Number.isInteger(codepoint) || codepoint <= 0) return "";
        // Ignore plain ASCII so reply text can't be interpreted as reactions.
        if (codepoint <= 0x7F) return "";
        try {{
          const glyph = String.fromCodePoint(codepoint);
          // Filter non-printable control chars (often bad legacy payload values).
          for (const ch of glyph) {{
            const cp = ch.codePointAt(0);
            if (!Number.isInteger(cp)) continue;
            if ((cp >= 0 && cp <= 0x1f) || (cp >= 0x7f && cp <= 0x9f)) {{
              return "";
            }}
          }}
          return glyph;
        }} catch (_err) {{
          return "";
        }}
      }};

      const reactionVariationSelectors = new Set([0xFE0E, 0xFE0F]);

      const emojiFromAny = (rawValue) => {{
        if (rawValue == null) return "";
        if (typeof rawValue === "number") {{
          return emojiFromCodepointValue(rawValue);
        }}
        const raw = String(rawValue).trim();
        if (!raw) return "";

        // Decimal codepoint payloads (int or int-as-string).
        if (/^\\d+$/.test(raw)) {{
          return emojiFromCodepointValue(raw);
        }}
        // Hex codepoint payloads like "U+1F44D" or "1F44D".
        const hex = raw.toUpperCase().replace(/^U\\+/, "");
        if (/^[0-9A-F]{4,8}$/.test(hex)) {{
          return emojiFromCodepointValue(parseInt(hex, 16));
        }}

        // Already a glyph/text payload; reject control chars.
        for (const ch of raw) {{
          const cp = ch.codePointAt(0);
          if (!Number.isInteger(cp)) continue;
          if ((cp >= 0 && cp <= 0x1f) || (cp >= 0x7f && cp <= 0x9f)) {{
            return "";
          }}
        }}
        return raw;
      }};

      const canonicalReactionEmoji = (rawValue) => {{
        const glyph = emojiFromAny(rawValue);
        if (!glyph) return "";
        // Preserve keycap sequences (e.g. 3️⃣, #️⃣, *️⃣) as-is.
        const keycapMatch = glyph.match(/^([0-9#*])(?:\uFE0F)?\u20E3$/u);
        if (keycapMatch) {{
          return `${{keycapMatch[1]}}\uFE0F\u20E3`;
        }}
        for (const ch of glyph) {{
          const cp = ch.codePointAt(0);
          if (!Number.isInteger(cp)) continue;
          if (reactionVariationSelectors.has(cp)) continue;
          return emojiFromCodepointValue(cp);
        }}
        return "";
      }};

      const emojiFromTextPayload = (rawValue) => {{
        const text = String(rawValue == null ? "" : rawValue).trim();
        if (!text) return "";
        // Do not treat regular chat text as emoji fallback.
        if (text.length > 8 || /\\s/.test(text)) return "";
        if (/^[0-9A-Za-z.,;:!?'"`~_\\-]+$/.test(text)) return "";
        const glyph = canonicalReactionEmoji(text);
        if (!glyph) return "";
        // Keep fallback conservative: one emoji (optionally with variation/joiners).
        const clusters = Array.from(glyph);
        if (clusters.length > 4) return "";
        return glyph;
      }};

      const emojiOf = (msg) => {{
        if (!msg || typeof msg !== "object") return "";
        // Prefer explicit numeric codepoint when present, matching Meshtastic's
        // Data.emoji reaction field semantics.
        const fromCodepoint = canonicalReactionEmoji(msg.emoji_codepoint ?? msg.emojiCodepoint);
        if (fromCodepoint) return fromCodepoint;
        const direct = canonicalReactionEmoji(msg.emoji);
        if (direct) return direct;
        return emojiFromTextPayload(msg.text ?? msg.decoded_text ?? msg.payload_text);
      }};

      const isReactionMessage = (msg) => {{
        if (!msg || typeof msg !== "object") return false;
        if (msg.is_reaction === true) return true;
        const replyId = replyIdOf(msg);
        const emoji = emojiOf(msg);
        return !!(replyId && emoji);
      }};
