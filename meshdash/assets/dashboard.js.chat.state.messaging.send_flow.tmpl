      const lowered = text.toLowerCase();
      if (lowered === "//macros" || lowered === "//help") {{
        return {{
          kind: "help",
          text: "",
          source: lowered,
        }};
      }}
      const mapped = chatTextMacroMap[lowered];
      if (mapped) {{
        return {{
          kind: "replace",
          text: mapped,
          source: lowered,
        }};
      }}
      const transformMatch = text.match(/^\/\/(1337|backwards|scrambled|upsidedown|disemvowel|glyph)(?:\s+([\s\S]+))?$/i);
      if (!transformMatch) return null;
      const transformId = String(transformMatch[1] || "").toLowerCase();
      const payload = String(transformMatch[2] == null ? "" : transformMatch[2]);
      let transformedText = payload;
      if (transformId === "1337") {{
        transformedText = toLeetSpeak(payload);
      }} else if (transformId === "backwards") {{
        transformedText = toBackwards(payload);
      }} else if (transformId === "scrambled") {{
        transformedText = toScrambled(payload);
      }} else if (transformId === "upsidedown") {{
        transformedText = toUpsideDown(payload);
      }} else if (transformId === "disemvowel") {{
        transformedText = toDisemvowel(payload);
      }} else if (transformId === "glyph") {{
        transformedText = toSpecialChars(payload);
      }}
      return {{
        kind: "transform",
        text: transformedText,
        source: `//${{transformId}}`,
        inputText: payload,
        transform: transformId,
      }};
    }}

