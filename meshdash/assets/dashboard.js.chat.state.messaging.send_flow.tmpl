        const empty = document.createElement("div");
        empty.className = "chat-macro-help-empty";
        const emptyToken = filter || String(firstToken || "").replace(/^\/+/, "") || "";
        empty.textContent = `No commands match "//${{emptyToken}}"`;
        list.appendChild(empty);
