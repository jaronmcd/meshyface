        if (!(entry && typeof entry === "object")) continue;
        const label = String(entry.label || "").trim();
        const command = String(entry.command || "").trim();
        if (!label || !command) continue;
        const commandToken = command.toLowerCase().replace(/^\/+/, "");
        const labelToken = label.toLowerCase().replace(/^\/+/, "");
        if (filter && !commandToken.startsWith(filter) && !labelToken.startsWith(filter)) {{
