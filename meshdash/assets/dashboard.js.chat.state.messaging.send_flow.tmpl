    function normalizeMacrosAsciiRamp(rawRamp) {{
      const fallback = MACROS_ASCII_RAMP_FALLBACK;
      const value = String(rawRamp == null ? "" : rawRamp);
      const chars = [];
      const seen = new Set();
      for (const char of value) {{
        if (char === "\n" || char === "\r") continue;
        if (seen.has(char)) continue;
        chars.push(char);
        seen.add(char);
      }}
      const ramp = chars.join("");
      return ramp.length >= 2 ? ramp : fallback;
    }}

    function findMacrosAsciiPalettePresetByRamp(rawRamp) {{
      const normalized = normalizeMacrosAsciiRamp(rawRamp);
      for (const preset of MACROS_ASCII_PALETTE_PRESETS) {{
        if (normalizeMacrosAsciiRamp(preset.ramp) === normalized) {{
          return preset;
        }}
      }}
      return null;
    }}

