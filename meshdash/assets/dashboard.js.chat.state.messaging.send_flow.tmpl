    function appendLocalInfoChatRow(rawText, options = null) {{
      const text = String(rawText == null ? "" : rawText).trim();
      if (!text) return null;
      const opts = (options && typeof options === "object") ? options : {{}};
      const explicitChannel = Number(opts.channel_index);
      const sendCtx = meshChannelSendContext();
      const channelIndex = Number.isInteger(explicitChannel) && explicitChannel >= 0
        ? explicitChannel
        : sendCtx.sendIndex;
      const nowIso = new Date().toISOString();
      chatLocalInfoSeq += 1;
      const row = {{
        kind: "status",
        from: "local",
        to: "^all",
        text,
        rx_time: nowIso,
        captured_at: nowIso,
        channel_index: channelIndex,
        local_only: true,
        local_info_seq: chatLocalInfoSeq,
      }};
      chatLocalInfoRows.push(row);
      const maxRows = Math.max(6, Math.trunc(Number(chatLocalInfoMaxRows) || 24));
      if (chatLocalInfoRows.length > maxRows) {{
        chatLocalInfoRows.splice(0, chatLocalInfoRows.length - maxRows);
      }}
      chatLocalInfoVersion += 1;
      chatDerivedCache = null;
      if (latestState && typeof latestState === "object") {{
        renderChat(latestState);
      }}
      return row;
    }}

    async function sendChatPayload(body, successMessage, options = null) {{
      const opts = (options && typeof options === "object") ? options : {{}};
      const statusFn = (typeof opts.statusFn === "function") ? opts.statusFn : setChatSendStatus;
      const showSendingStatus = opts.showSendingStatus !== false;
      const showSuccessStatus = opts.showSuccessStatus !== false;
      const showErrorStatus = opts.showErrorStatus !== false;
      if (chatSendInFlight) return null;
      setChatSendBusy(true);
      if (showSendingStatus) {{
        statusFn("Sending...");
      }}
      try {{
        const resp = await fetch("/api/chat/send", {{
          method: "POST",
          headers: {{ "Content-Type": "application/json" }},
          body: JSON.stringify(body || {{}}),
        }});
        const payload = await resp.json().catch(() => ({{}}));
        if (!resp.ok || !payload.ok) {{
          const msg = payload && payload.error ? payload.error : `send failed (${{resp.status}})`;
          throw new Error(msg);
        }}
        if (showSuccessStatus) {{
          statusFn(successMessage || `Sent at ${{payload.sent_at || "now"}}`);
        }}
        await poll();
        return payload;
      }} catch (err) {{
        if (showErrorStatus) {{
          statusFn(`Send error: ${{err.message || err}}`, true);
        }}
        return null;
      }} finally {{
        setChatSendBusy(false);
        flushQueuedComposerSend();
      }}
    }}

