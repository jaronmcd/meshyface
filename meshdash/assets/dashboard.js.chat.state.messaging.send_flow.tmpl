    function macrosLineSendGapMsForDestination(destinationId) {{
      const baseGapMs = defaultMacrosLineSendGapMs();
      if (isMacrosBroadcastDestination(destinationId)) {{
        const scaled = Math.round(baseGapMs * MACROS_SEND_BROADCAST_GAP_MULTIPLIER);
        const floorMs = Math.max(420, Math.trunc(baseGapMs * 2));
        return clampMacrosLineSendGapMs(scaled, floorMs);
      }}
      const normalizedDest = normalizeNodeId(destinationId || "");
      if (!isCanonicalNodeId(normalizedDest)) {{
        return baseGapMs;
      }}
      const scaled = Math.round(baseGapMs * MACROS_SEND_DIRECT_GAP_MULTIPLIER);
      const floorMs = Math.max(MACROS_SEND_LINE_GAP_MIN_MS, Math.trunc(baseGapMs * 0.65));
      return clampMacrosLineSendGapMs(
        scaled,
        floorMs,
      );
    }}

    function waitMacrosLineSendGap(rawDelayMs = null) {{
      const fallbackGapMs = defaultMacrosLineSendGapMs();
      const delayMs = rawDelayMs == null
        ? fallbackGapMs
        : clampMacrosLineSendGapMs(rawDelayMs, fallbackGapMs);
      if (delayMs <= 0) return Promise.resolve();
      return new Promise((resolve) => {{
        window.setTimeout(resolve, delayMs);
