    }}

    function isMacrosAsciiBlankChar(rawChar, fillChar = " ") {{
      const char = String(rawChar == null ? "" : rawChar).slice(0, 1);
      if (!char) return true;
      if (char === " " || char === "\t" || char === "\u00A0" || char === "\u2800") {{
        return true;
      }}
      const fill = String(fillChar == null ? "" : fillChar).slice(0, 1);
      return !!fill && char === fill;
    }}

    function isMacrosAsciiBlankLine(rawLine, fillChar = " ") {{
      const line = String(rawLine == null ? "" : rawLine);
      if (!line) return true;
      for (const char of line) {{
        if (!isMacrosAsciiBlankChar(char, fillChar)) return false;
      }}
      return true;
    }}

    function cropMacrosAsciiHorizontalMargins(rawRows, fillChar = " ") {{
      const rows = Array.isArray(rawRows)
        ? rawRows.map((line) => String(line == null ? "" : line))
        : [];
      if (rows.length <= 0) return [];
      let left = Number.POSITIVE_INFINITY;
      let right = -1;
      for (const row of rows) {{
        for (let idx = 0; idx < row.length; idx += 1) {{
          if (!isMacrosAsciiBlankChar(row.charAt(idx), fillChar)) {{
            left = Math.min(left, idx);
            break;
          }}
        }}
        for (let idx = row.length - 1; idx >= 0; idx -= 1) {{
          if (!isMacrosAsciiBlankChar(row.charAt(idx), fillChar)) {{
            right = Math.max(right, idx);
            break;
          }}
        }}
      }}
      if (!Number.isFinite(left) || right < left) {{
        return [];
      }}
      return rows.map((row) => row.slice(left, right + 1));
    }}

    function parseMacrosAsciiLines(rawText, options = null) {{
      const opts = (options && typeof options === "object") ? options : {{}};
      const fillChar = String(opts.fillChar == null ? "" : opts.fillChar).slice(0, 1) || " ";
      const cropWhitespace = opts.cropWhitespace !== false;
      const normalized = String(rawText == null ? "" : rawText).replace(/\r\n?/g, "\n");
      const rows = normalized.split("\n").slice(0, 120).map((line) => String(line || "").slice(0, 280));
      if (!cropWhitespace) {{
        return rows;
      }}
      let start = 0;
      let end = rows.length - 1;
      while (start <= end && isMacrosAsciiBlankLine(rows[start], fillChar)) {{
        start += 1;
      }}
      while (end >= start && isMacrosAsciiBlankLine(rows[end], fillChar)) {{
        end -= 1;
      }}
      if (start > end) {{
        return [];
      }}
      const verticallyTrimmedRows = rows.slice(start, end + 1);
      return cropMacrosAsciiHorizontalMargins(verticallyTrimmedRows, fillChar);
    }}

    function macrosAsciiSettingsFromInputs() {{
      const widthInput = document.getElementById("macros-ascii-width");
      const heightInput = document.getElementById("macros-ascii-height");
      const rampInput = document.getElementById("macros-ascii-ramp");
      const invertInput = document.getElementById("macros-ascii-invert");
      const cropWhitespaceInput = document.getElementById("macros-ascii-crop-whitespace");
      const useSpaceReplacementInput = document.getElementById("macros-ascii-space-replace-enabled");
      const spaceReplacementCharInput = document.getElementById("macros-ascii-space-replace-char");
      return {{
        width: clampMacrosAsciiDimension(widthInput && widthInput.value, 16, 8, 96),
        height: clampMacrosAsciiDimension(heightInput && heightInput.value, 16, 8, 96),
        ramp: normalizeMacrosAsciiRamp(rampInput && rampInput.value),
        invert: !!(invertInput && invertInput.checked),
        cropWhitespace: !cropWhitespaceInput || !!cropWhitespaceInput.checked,
        useSpaceReplacement: !!(
          useSpaceReplacementInput
          && useSpaceReplacementInput.checked
        ),
        spaceReplacementChar: normalizeMacrosSpaceReplacementChar(
          spaceReplacementCharInput && spaceReplacementCharInput.value
        ),
      }};
    }}

    function setMacrosStatus(rawText, isError = false) {{
      const status = document.getElementById("macros-status");
      if (!(status instanceof HTMLElement)) return;
      status.textContent = String(rawText == null ? "" : rawText);
      status.classList.toggle("is-error", !!isError);
    }}

    function updateMacrosLineCount(lineCount) {{
      const label = document.getElementById("macros-line-count");
      if (!(label instanceof HTMLElement)) return;
      const count = Math.max(0, Math.trunc(Number(lineCount) || 0));
      label.textContent = `${{count}} line${{count === 1 ? "" : "s"}}`;
    }}

    function applyMacrosPreviewLines(lines, sourceLabel = "") {{
      const normalizedLines = Array.isArray(lines)
        ? lines.slice(0, 120).map((line) => String(line == null ? "" : line).slice(0, 280))
        : [];
      macrosPreviewLines = normalizedLines;
      macrosPreviewSourceLabel = String(sourceLabel || "");
      macrosPreviewUpdatedAtUnix = Math.floor(Date.now() / 1000);
      updateMacrosLineCount(normalizedLines.length);
      if (latestState && typeof latestState === "object" && activeLayoutView === "macros") {{
        renderChat(latestState);
      }}
    }}

    function syncMacrosPreviewFromOutput(sourceLabel = "") {{
      const output = document.getElementById("macros-ascii-output");
      if (!(output instanceof HTMLTextAreaElement)) {{
        applyMacrosPreviewLines([], sourceLabel);
        return [];
      }}
      const settings = macrosAsciiSettingsFromInputs();
      const fillChar = macrosAsciiBackgroundFillChar(settings && settings.ramp);
      const rows = parseMacrosAsciiLines(output.value, {{
        fillChar,
        cropWhitespace: settings && settings.cropWhitespace,
      }});
      applyMacrosPreviewLines(rows, sourceLabel);
      return rows;
    }}

    function macrosImageDataToAsciiLines(imageData, width, height, ramp, invert = false) {{
      const safeWidth = clampMacrosAsciiDimension(width, 16, 8, 96);
      const safeHeight = clampMacrosAsciiDimension(height, 16, 8, 96);
      const chars = normalizeMacrosAsciiRamp(ramp);
      const maxIndex = Math.max(0, chars.length - 1);
      const lines = [];
      const pixels = imageData && imageData.data ? imageData.data : null;
      if (!pixels) return lines;

      for (let y = 0; y < safeHeight; y += 1) {{
        let row = "";
        for (let x = 0; x < safeWidth; x += 1) {{
          const idx = ((y * safeWidth) + x) * 4;
          const r = Number(pixels[idx] || 0);
          const g = Number(pixels[idx + 1] || 0);
          const b = Number(pixels[idx + 2] || 0);
          const a = Number(pixels[idx + 3] || 0) / 255;
          const luminance = ((0.2126 * r) + (0.7152 * g) + (0.0722 * b)) * a + (255 * (1 - a));
          const normalized = Math.max(0, Math.min(1, (invert ? (255 - luminance) : luminance) / 255));
          const rampIndex = Math.max(0, Math.min(maxIndex, Math.round(normalized * maxIndex)));
          row += chars.charAt(rampIndex) || " ";
        }}
        lines.push(row);
      }}
      return lines;
    }}

    function buildScaledImageDataFromElement(imageElement, width, height) {{
      if (!(imageElement instanceof HTMLImageElement)) return null;
      const safeWidth = clampMacrosAsciiDimension(width, 16, 8, 96);
      const safeHeight = clampMacrosAsciiDimension(height, 16, 8, 96);
      const canvas = document.createElement("canvas");
      canvas.width = safeWidth;
      canvas.height = safeHeight;
      const ctx = canvas.getContext("2d", {{ willReadFrequently: true }});
      if (!ctx) return null;
      ctx.imageSmoothingEnabled = true;
      ctx.fillStyle = "#ffffff";
      ctx.fillRect(0, 0, safeWidth, safeHeight);
      ctx.drawImage(imageElement, 0, 0, safeWidth, safeHeight);
      return ctx.getImageData(0, 0, safeWidth, safeHeight);
    }}

    function buildTextRenderImageData(rawText, settings, fontFamily = "monospace", fontWeight = "700") {{
      const text = String(rawText == null ? "" : rawText).replace(/\r\n?/g, "\n");
      const lines = text.split("\n").map((line) => line.trimEnd()).filter((line) => line.length > 0);
      if (lines.length <= 0) return null;
      const widthChars = clampMacrosAsciiDimension(settings.width, 16, 8, 96);
      const heightChars = clampMacrosAsciiDimension(settings.height, 16, 8, 96);
      const pixelWidth = Math.max(64, widthChars * 8);
      const pixelHeight = Math.max(40, heightChars * 14);
      const canvas = document.createElement("canvas");
      canvas.width = pixelWidth;
      canvas.height = pixelHeight;
      const ctx = canvas.getContext("2d", {{ willReadFrequently: true }});
      if (!ctx) return null;
      ctx.fillStyle = "#ffffff";
      ctx.fillRect(0, 0, pixelWidth, pixelHeight);
      ctx.fillStyle = "#000000";

      let fontPx = Math.max(12, Math.floor(pixelHeight / Math.max(1, lines.length) * 0.74));
      const family = String(fontFamily || "monospace").replace(/[^A-Za-z0-9\-\s,]/g, "").trim() || "monospace";
      const weight = String(fontWeight || "700").replace(/[^0-9]/g, "").trim() || "700";

      const setFont = () => {{
        ctx.font = `${{weight}} ${{fontPx}}px ${{family}}`;
      }};
      setFont();

      const maxTextWidth = () => lines.reduce((largest, line) => (
        Math.max(largest, ctx.measureText(line).width || 0)
      ), 0);

      let measuredWidth = maxTextWidth();
      let guard = 0;
      while (measuredWidth > (pixelWidth * 0.92) && fontPx > 8 && guard < 12) {{
        fontPx = Math.max(8, Math.floor(fontPx * 0.88));
        setFont();
        measuredWidth = maxTextWidth();
        guard += 1;
      }}

      const lineHeight = Math.max(10, Math.floor(fontPx * 1.12));
      const blockHeight = lineHeight * lines.length;
      const startY = Math.floor((pixelHeight - blockHeight) / 2) + Math.floor(lineHeight / 2);
      ctx.textAlign = "center";
      ctx.textBaseline = "middle";
      lines.forEach((line, idx) => {{
        ctx.fillText(line, pixelWidth / 2, startY + (idx * lineHeight));
      }});

      const outputCanvas = document.createElement("canvas");
      outputCanvas.width = widthChars;
      outputCanvas.height = heightChars;
      const outputCtx = outputCanvas.getContext("2d", {{ willReadFrequently: true }});
      if (!outputCtx) return null;
      outputCtx.imageSmoothingEnabled = true;
      outputCtx.fillStyle = "#ffffff";
      outputCtx.fillRect(0, 0, widthChars, heightChars);
      outputCtx.drawImage(canvas, 0, 0, widthChars, heightChars);
      return outputCtx.getImageData(0, 0, widthChars, heightChars);
    }}

    async function readImageFileAsElement(file) {{
      if (!(file instanceof File)) return null;
      const objectUrl = URL.createObjectURL(file);
      try {{
        const img = await new Promise((resolve, reject) => {{
          const node = new Image();
          node.addEventListener("load", () => resolve(node), {{ once: true }});
          node.addEventListener("error", () => reject(new Error("image decode failed")), {{ once: true }});
          node.src = objectUrl;
        }});
        return img instanceof HTMLImageElement ? img : null;
      }} finally {{
        URL.revokeObjectURL(objectUrl);
      }}
    }}

    function updateMacrosImageMeta() {{
      const label = document.getElementById("macros-image-meta");
      if (!(label instanceof HTMLElement)) return;
      if (!(macrosImageSourceElement instanceof HTMLImageElement)) {{
        label.textContent = "No image loaded.";
        return;
      }}
      const name = macrosImageSourceName || "image";
      const width = Math.max(0, Math.trunc(macrosImageSourceWidth || macrosImageSourceElement.naturalWidth || 0));
      const height = Math.max(0, Math.trunc(macrosImageSourceHeight || macrosImageSourceElement.naturalHeight || 0));
      label.textContent = `${{name}} · ${{width}}x${{height}}`;
    }}

    function writeMacrosOutput(lines, sourceLabel = "") {{
      const output = document.getElementById("macros-ascii-output");
      if (!(output instanceof HTMLTextAreaElement)) return;
      const text = Array.isArray(lines) ? lines.join("\n") : "";
      output.value = text;
      macrosRegenSourceLabel = String(sourceLabel || "");
      const previewLines = syncMacrosPreviewFromOutput(sourceLabel);
      setMacrosStatus(`Preview updated: ${{previewLines.length}} line${{previewLines.length === 1 ? "" : "s"}}.`);
    }}

    async function generateMacrosAsciiFromImage() {{
      if (!(macrosImageSourceElement instanceof HTMLImageElement)) {{
        setMacrosStatus("Load an image first.", true);
        return;
      }}
      const settings = macrosAsciiSettingsFromInputs();
      const imageData = buildScaledImageDataFromElement(macrosImageSourceElement, settings.width, settings.height);
      if (!imageData) {{
        setMacrosStatus("Could not process image pixels.", true);
        return;
      }}
      const lines = macrosImageDataToAsciiLines(
        imageData,
        settings.width,
        settings.height,
        settings.ramp,
        settings.invert,
      );
      writeMacrosOutput(lines, `image:${{macrosImageSourceName || "image"}}`);
    }}

    function generateMacrosAsciiFromText() {{
      const textInput = document.getElementById("macros-text-input");
      const fontSelect = document.getElementById("macros-text-font");
      const weightSelect = document.getElementById("macros-text-weight");
      const rawText = textInput instanceof HTMLInputElement ? String(textInput.value || "") : "";
      const trimmed = rawText.trim();
      if (!trimmed) {{
        setMacrosStatus("Enter text first.", true);
        return [];
      }}
      const settings = macrosAsciiSettingsFromInputs();
      const fontFamily = fontSelect instanceof HTMLSelectElement ? String(fontSelect.value || "monospace") : "monospace";
      const fontWeight = weightSelect instanceof HTMLSelectElement ? String(weightSelect.value || "700") : "700";
      const imageData = buildTextRenderImageData(trimmed, settings, fontFamily, fontWeight);
      if (!imageData) {{
        setMacrosStatus("Could not render text to image data.", true);
        return [];
      }}
      const lines = macrosImageDataToAsciiLines(
        imageData,
        settings.width,
        settings.height,
        settings.ramp,
        settings.invert,
      );
      writeMacrosOutput(lines, `text:${{trimmed.slice(0, 36)}}`);
      return lines;
    }}

    function encodeAsciiMacroLineForSend(line, options = null) {{
      const opts = (options && typeof options === "object") ? options : {{}};
      const useSpaceReplacement = !!opts.useSpaceReplacement;
      const spaceReplacementChar = normalizeMacrosSpaceReplacementChar(opts.spaceReplacementChar);
      const raw = String(line == null ? "" : line);
      if (!raw) {{
        if (useSpaceReplacement) return spaceReplacementChar;
        return "\u00A0";
      }}
      const normalized = raw.replace(/\t/g, "  ").slice(0, 280);
      if (useSpaceReplacement) {{
        return normalized.replace(/ /g, spaceReplacementChar);
      }}
      return normalized.replace(/ /g, "\u00A0");
    }}

    function buildMacrosSendLinesFromRawText(rawText, settings = null) {{
      const sendSettings = (settings && typeof settings === "object")
        ? settings
        : macrosAsciiSettingsFromInputs();
      const fillChar = macrosAsciiBackgroundFillChar(sendSettings && sendSettings.ramp);
      const parsedLines = parseMacrosAsciiLines(rawText, {{
        fillChar,
        cropWhitespace: sendSettings && sendSettings.cropWhitespace,
      }});
      const sendLines = parsedLines.map((line) => encodeAsciiMacroLineForSend(line, {{
        useSpaceReplacement: sendSettings && sendSettings.useSpaceReplacement,
        spaceReplacementChar: sendSettings && sendSettings.spaceReplacementChar,
      }}));
      return {{
        parsedLines,
        sendLines,
        settings: sendSettings,
      }};
    }}

    function setMacrosSendBusy(isBusy) {{
      const sendBtn = document.getElementById("macros-send-lines-btn");
      if (!(sendBtn instanceof HTMLButtonElement)) return;
      sendBtn.disabled = !!isBusy;
      sendBtn.textContent = isBusy ? "Sending..." : "Send Macro";
    }}

    async function sendMacrosPreviewAsLines() {{
      if (macrosSendInFlight || chatSendInFlight) {{
        setMacrosStatus("Wait for the current send to finish.", true);
        return;
      }}
      const output = document.getElementById("macros-ascii-output");
      if (!(output instanceof HTMLTextAreaElement)) {{
        setMacrosStatus("ASCII output box not found.", true);
        return;
      }}
      const settings = macrosAsciiSettingsFromInputs();
      const prepared = buildMacrosSendLinesFromRawText(output.value, settings);
      const lines = prepared && Array.isArray(prepared.parsedLines)
        ? prepared.parsedLines
        : [];
      const sendLines = prepared && Array.isArray(prepared.sendLines)
        ? prepared.sendLines
        : [];
      if (lines.length <= 0) {{
        setMacrosStatus("Generate or paste ASCII lines first.", true);
        return;
      }}
      if (lines.length > 120) {{
        setMacrosStatus("Limit preview to 120 lines before sending.", true);
        return;
      }}
      let destination = "^all";
      if (chatMainDirectModeEnabled && activeChatChannel === "direct") {{
        const directPeer = resolvedDirectPeerForComposer();
        if (!isCanonicalNodeId(directPeer)) {{
          setMacrosStatus("Select a direct peer before sending in P2P mode.", true);
          return;
        }}
        destination = directPeer;
        if (isSelfNodeId(destination)) {{
          setMacrosStatus("Cannot send direct macros to your own radio.", true);
          return;
        }}
      }}
      const sendCtx = meshChannelSendContext();
      const isBroadcastSend = isMacrosBroadcastDestination(destination);
      const lineGapMs = macrosLineSendGapMsForDestination(destination);
      macrosSendInFlight = true;
      setMacrosSendBusy(true);
      let sentCount = 0;
      try {{
        for (let lineIdx = 0; lineIdx < sendLines.length; lineIdx += 1) {{
          const line = sendLines[lineIdx];
          setMacrosStatus(`Sending line ${{sentCount + 1}} / ${{lines.length}}...`);
          const payload = await sendChatPayload(
            {{
              text: line,
              destination,
              channel_index: sendCtx.sendIndex,
            }},
            null,
            {{
              showSendingStatus: false,
              showSuccessStatus: false,
              showErrorStatus: false,
              statusFn: () => {{}},
            }},
          );
          if (!payload || !payload.ok) {{
            throw new Error(`send failed at line ${{sentCount + 1}}`);
          }}
          sentCount += 1;
          if ((lineIdx + 1) < sendLines.length) {{
            let gapMs = lineGapMs;
            if (
              isBroadcastSend
              && MACROS_SEND_BROADCAST_BURST_SIZE > 0
              && ((lineIdx + 1) % MACROS_SEND_BROADCAST_BURST_SIZE) === 0
            ) {{
              gapMs += Math.max(0, Math.trunc(Number(MACROS_SEND_BROADCAST_BURST_EXTRA_GAP_MS) || 0));
            }}
            await waitMacrosLineSendGap(gapMs);
          }}
        }}
        setMacrosStatus(`Sent ${{sentCount}} ASCII line${{sentCount === 1 ? "" : "s"}} on ${{sendCtx.sendLabel}}.`);
      }} catch (err) {{
        setMacrosStatus(`Send error: ${{err && err.message ? err.message : err}}`, true);
      }} finally {{
        macrosSendInFlight = false;
        setMacrosSendBusy(false);
      }}
    }}

    function bindMacrosStudioControls() {{
      const panel = document.getElementById("macros-right-pane");
      if (!(panel instanceof HTMLElement) || panel.dataset.bound === "1") return;
      panel.dataset.bound = "1";

      const imageInput = document.getElementById("macros-image-input");
      const imageBtn = document.getElementById("macros-image-generate-btn");
      const textBtn = document.getElementById("macros-text-generate-btn");
      const output = document.getElementById("macros-ascii-output");
      const previewBtn = document.getElementById("macros-preview-apply-btn");
      const clearBtn = document.getElementById("macros-clear-btn");
      const copyBtn = document.getElementById("macros-copy-btn");
      const sendBtn = document.getElementById("macros-send-lines-btn");
      const textInput = document.getElementById("macros-text-input");
      const rampInput = document.getElementById("macros-ascii-ramp");
      const cropWhitespaceInput = document.getElementById("macros-ascii-crop-whitespace");
      const spaceReplacementEnabledInput = document.getElementById("macros-ascii-space-replace-enabled");
      const spaceReplacementCharInput = document.getElementById("macros-ascii-space-replace-char");
      const paletteSelect = document.getElementById("macros-ascii-palette");
      const paletteNote = document.getElementById("macros-ascii-palette-note");
      const leftViewPreviewBtn = document.getElementById("macros-left-view-preview-btn");
      const leftViewLiveBtn = document.getElementById("macros-left-view-live-btn");

      const setPaletteNote = (rawText) => {{
        if (!(paletteNote instanceof HTMLElement)) return;
        paletteNote.textContent = String(rawText == null ? "" : rawText).trim() || "Using custom ramp.";
      }};

      const syncMacrosLeftViewToggleUi = () => {{
        const mode = normalizeMacrosLeftViewMode(macrosLeftViewMode);
        macrosLeftViewMode = mode;
        if (leftViewPreviewBtn instanceof HTMLButtonElement) {{
          const isActive = mode === MACROS_LEFT_VIEW_MODE_PREVIEW;
          leftViewPreviewBtn.classList.toggle("is-active", isActive);
          leftViewPreviewBtn.setAttribute("aria-pressed", isActive ? "true" : "false");
        }}
        if (leftViewLiveBtn instanceof HTMLButtonElement) {{
          const isActive = mode === MACROS_LEFT_VIEW_MODE_LIVE;
          leftViewLiveBtn.classList.toggle("is-active", isActive);
          leftViewLiveBtn.setAttribute("aria-pressed", isActive ? "true" : "false");
        }}
      }};

      const applyMacrosLeftViewMode = (rawMode, persist = true, announce = false) => {{
        const nextMode = normalizeMacrosLeftViewMode(rawMode);
        const changed = macrosLeftViewMode !== nextMode;
        macrosLeftViewMode = nextMode;
        syncMacrosLeftViewToggleUi();
        if (activeLayoutView === "macros" && typeof applyChatViewMode === "function") {{
          // Keep MACROS left-pane rendering WYSIWYG and consistent for both modes.
          applyChatViewMode("monitor", false);
        }}
        if (persist) {{
          try {{
            window.localStorage.setItem(MACROS_LEFT_VIEW_MODE_STORAGE_KEY, nextMode);
          }} catch (_err) {{
          }}
        }}
        if (changed && latestState && typeof latestState === "object" && activeLayoutView === "macros") {{
          renderChat(latestState);
        }}
        if (announce) {{
          setMacrosStatus(
            nextMode === MACROS_LEFT_VIEW_MODE_LIVE
              ? "Left panel mode: live chat (macro style)."
              : "Left panel mode: macro preview."
          );
        }}
      }};

      let paletteSyncLocked = false;
      const syncPalettePresetFromRamp = () => {{
        if (!(paletteSelect instanceof HTMLSelectElement) || !(rampInput instanceof HTMLInputElement)) {{
          setPaletteNote("Using custom ramp.");
          return;
        }}
        const preset = findMacrosAsciiPalettePresetByRamp(rampInput.value);
        paletteSyncLocked = true;
        paletteSelect.value = preset ? preset.id : MACROS_ASCII_PALETTE_CUSTOM_ID;
        paletteSyncLocked = false;
        setPaletteNote(preset ? preset.note : "Using custom ramp.");
      }};

      const macrosOutputHasRows = () => (
        output instanceof HTMLTextAreaElement
        && String(output.value || "").length > 0
      );

      const refreshMacrosOutputForRampChange = async () => {{
        const sourceLabel = String(macrosRegenSourceLabel || macrosPreviewSourceLabel || "").toLowerCase();
        if (sourceLabel.startsWith("image:") && macrosImageSourceElement instanceof HTMLImageElement) {{
          await generateMacrosAsciiFromImage();
          return true;
        }}
        if (sourceLabel.startsWith("text:")) {{
          const textValue = textInput instanceof HTMLInputElement
            ? String(textInput.value || "").trim()
            : "";
          if (!textValue) return false;
          const lines = generateMacrosAsciiFromText();
          return Array.isArray(lines) && lines.length > 0;
        }}
        return false;
      }};

      const refreshMacrosPreviewSendView = () => {{
        if (!macrosOutputHasRows()) return 0;
        const lines = syncMacrosPreviewFromOutput("edited");
        return Array.isArray(lines) ? lines.length : 0;
      }};

      if (paletteSelect instanceof HTMLSelectElement) {{
        paletteSelect.innerHTML = "";
        const customOption = document.createElement("option");
        customOption.value = MACROS_ASCII_PALETTE_CUSTOM_ID;
        customOption.textContent = "Custom";
        paletteSelect.appendChild(customOption);
        for (const preset of MACROS_ASCII_PALETTE_PRESETS) {{
          const option = document.createElement("option");
          option.value = preset.id;
          option.textContent = preset.label;
          paletteSelect.appendChild(option);
        }}
      }}

      if (paletteSelect instanceof HTMLSelectElement && rampInput instanceof HTMLInputElement) {{
        paletteSelect.addEventListener("change", () => {{
          if (paletteSyncLocked) return;
          const selected = findMacrosAsciiPalettePresetById(paletteSelect.value);
          if (!selected) {{
            setPaletteNote("Using custom ramp.");
            if (macrosOutputHasRows()) {{
              syncMacrosPreviewFromOutput("edited");
            }}
            return;
          }}
          const normalized = normalizeMacrosAsciiRamp(selected.ramp);
          rampInput.value = normalized;
          setPaletteNote(selected.note);
          if (macrosOutputHasRows()) {{
            void refreshMacrosOutputForRampChange().then((didRegenerate) => {{
              if (!didRegenerate) {{
                syncMacrosPreviewFromOutput("edited");
              }}
            }});
          }}
        }});

        rampInput.addEventListener("input", () => {{
          if (paletteSyncLocked) return;
          syncPalettePresetFromRamp();
          if (!macrosOutputHasRows()) return;
          void refreshMacrosOutputForRampChange().then((didRegenerate) => {{
            if (!didRegenerate) {{
              syncMacrosPreviewFromOutput("edited");
            }}
          }});
        }});
      }}

      if (leftViewPreviewBtn instanceof HTMLButtonElement) {{
        leftViewPreviewBtn.addEventListener("click", () => {{
          applyMacrosLeftViewMode(MACROS_LEFT_VIEW_MODE_PREVIEW, true, true);
        }});
      }}
      if (leftViewLiveBtn instanceof HTMLButtonElement) {{
        leftViewLiveBtn.addEventListener("click", () => {{
          applyMacrosLeftViewMode(MACROS_LEFT_VIEW_MODE_LIVE, true, true);
        }});
      }}

      if (cropWhitespaceInput instanceof HTMLInputElement) {{
