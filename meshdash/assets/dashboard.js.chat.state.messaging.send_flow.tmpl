      }}
      const rows = parseMacrosAsciiLines(output.value);
      applyMacrosPreviewLines(rows, sourceLabel);
      return rows;
    }}

    function macrosImageDataToAsciiLines(imageData, width, height, ramp, invert = false) {{
      const safeWidth = clampMacrosAsciiDimension(width, 16, 8, 96);
      const safeHeight = clampMacrosAsciiDimension(height, 16, 8, 96);
      const chars = normalizeMacrosAsciiRamp(ramp);
      const maxIndex = Math.max(0, chars.length - 1);
      const lines = [];
      const pixels = imageData && imageData.data ? imageData.data : null;
      if (!pixels) return lines;

      for (let y = 0; y < safeHeight; y += 1) {{
        let row = "";
        for (let x = 0; x < safeWidth; x += 1) {{
          const idx = ((y * safeWidth) + x) * 4;
          const r = Number(pixels[idx] || 0);
          const g = Number(pixels[idx + 1] || 0);
          const b = Number(pixels[idx + 2] || 0);
          const a = Number(pixels[idx + 3] || 0) / 255;
          const luminance = ((0.2126 * r) + (0.7152 * g) + (0.0722 * b)) * a + (255 * (1 - a));
          const normalized = Math.max(0, Math.min(1, (invert ? (255 - luminance) : luminance) / 255));
          const rampIndex = Math.max(0, Math.min(maxIndex, Math.round(normalized * maxIndex)));
          row += chars.charAt(rampIndex) || " ";
        }}
        lines.push(row);
      }}
      return lines;
    }}

    function buildScaledImageDataFromElement(imageElement, width, height) {{
      if (!(imageElement instanceof HTMLImageElement)) return null;
      const safeWidth = clampMacrosAsciiDimension(width, 16, 8, 96);
      const safeHeight = clampMacrosAsciiDimension(height, 16, 8, 96);
      const canvas = document.createElement("canvas");
      canvas.width = safeWidth;
      canvas.height = safeHeight;
      const ctx = canvas.getContext("2d", {{ willReadFrequently: true }});
      if (!ctx) return null;
      ctx.imageSmoothingEnabled = true;
      ctx.fillStyle = "#ffffff";
      ctx.fillRect(0, 0, safeWidth, safeHeight);
      ctx.drawImage(imageElement, 0, 0, safeWidth, safeHeight);
      return ctx.getImageData(0, 0, safeWidth, safeHeight);
    }}

    function buildTextRenderImageData(rawText, settings, fontFamily = "monospace", fontWeight = "700") {{
      const text = String(rawText == null ? "" : rawText).replace(/\r\n?/g, "\n");
      const lines = text.split("\n").map((line) => line.trimEnd()).filter((line) => line.length > 0);
      if (lines.length <= 0) return null;
      const widthChars = clampMacrosAsciiDimension(settings.width, 16, 8, 96);
      const heightChars = clampMacrosAsciiDimension(settings.height, 16, 8, 96);
      const pixelWidth = Math.max(64, widthChars * 8);
      const pixelHeight = Math.max(40, heightChars * 14);
      const canvas = document.createElement("canvas");
      canvas.width = pixelWidth;
      canvas.height = pixelHeight;
      const ctx = canvas.getContext("2d", {{ willReadFrequently: true }});
      if (!ctx) return null;
      ctx.fillStyle = "#ffffff";
      ctx.fillRect(0, 0, pixelWidth, pixelHeight);
      ctx.fillStyle = "#000000";

      let fontPx = Math.max(12, Math.floor(pixelHeight / Math.max(1, lines.length) * 0.74));
      const family = String(fontFamily || "monospace").replace(/[^A-Za-z0-9\-\s,]/g, "").trim() || "monospace";
      const weight = String(fontWeight || "700").replace(/[^0-9]/g, "").trim() || "700";

      const setFont = () => {{
        ctx.font = `${{weight}} ${{fontPx}}px ${{family}}`;
      }};
      setFont();

      const maxTextWidth = () => lines.reduce((largest, line) => (
        Math.max(largest, ctx.measureText(line).width || 0)
      ), 0);

      let measuredWidth = maxTextWidth();
      let guard = 0;
      while (measuredWidth > (pixelWidth * 0.92) && fontPx > 8 && guard < 12) {{
        fontPx = Math.max(8, Math.floor(fontPx * 0.88));
        setFont();
        measuredWidth = maxTextWidth();
        guard += 1;
      }}

      const lineHeight = Math.max(10, Math.floor(fontPx * 1.12));
      const blockHeight = lineHeight * lines.length;
      const startY = Math.floor((pixelHeight - blockHeight) / 2) + Math.floor(lineHeight / 2);
      ctx.textAlign = "center";
      ctx.textBaseline = "middle";
      lines.forEach((line, idx) => {{
        ctx.fillText(line, pixelWidth / 2, startY + (idx * lineHeight));
      }});

      const outputCanvas = document.createElement("canvas");
      outputCanvas.width = widthChars;
      outputCanvas.height = heightChars;
      const outputCtx = outputCanvas.getContext("2d", {{ willReadFrequently: true }});
      if (!outputCtx) return null;
      outputCtx.imageSmoothingEnabled = true;
      outputCtx.fillStyle = "#ffffff";
      outputCtx.fillRect(0, 0, widthChars, heightChars);
      outputCtx.drawImage(canvas, 0, 0, widthChars, heightChars);
      return outputCtx.getImageData(0, 0, widthChars, heightChars);
    }}

    async function readImageFileAsElement(file) {{
      if (!(file instanceof File)) return null;
      const objectUrl = URL.createObjectURL(file);
      try {{
        const img = await new Promise((resolve, reject) => {{
          const node = new Image();
          node.addEventListener("load", () => resolve(node), {{ once: true }});
          node.addEventListener("error", () => reject(new Error("image decode failed")), {{ once: true }});
          node.src = objectUrl;
        }});
        return img instanceof HTMLImageElement ? img : null;
      }} finally {{
        URL.revokeObjectURL(objectUrl);
      }}
    }}

    function updateMacrosImageMeta() {{
      const label = document.getElementById("macros-image-meta");
      if (!(label instanceof HTMLElement)) return;
      if (!(macrosImageSourceElement instanceof HTMLImageElement)) {{
        label.textContent = "No image loaded.";
        return;
      }}
      const name = macrosImageSourceName || "image";
      const width = Math.max(0, Math.trunc(macrosImageSourceWidth || macrosImageSourceElement.naturalWidth || 0));
      const height = Math.max(0, Math.trunc(macrosImageSourceHeight || macrosImageSourceElement.naturalHeight || 0));
      label.textContent = `${{name}} · ${{width}}x${{height}}`;
    }}

    function writeMacrosOutput(lines, sourceLabel = "") {{
      const output = document.getElementById("macros-ascii-output");
      if (!(output instanceof HTMLTextAreaElement)) return;
      const text = Array.isArray(lines) ? lines.join("\n") : "";
      output.value = text;
      const previewLines = syncMacrosPreviewFromOutput(sourceLabel);
      setMacrosStatus(`Preview updated: ${{previewLines.length}} line${{previewLines.length === 1 ? "" : "s"}}.`);
    }}

    async function generateMacrosAsciiFromImage() {{
      if (!(macrosImageSourceElement instanceof HTMLImageElement)) {{
        setMacrosStatus("Load an image first.", true);
        return;
      }}
      const settings = macrosAsciiSettingsFromInputs();
      const imageData = buildScaledImageDataFromElement(macrosImageSourceElement, settings.width, settings.height);
      if (!imageData) {{
        setMacrosStatus("Could not process image pixels.", true);
        return;
      }}
      const lines = macrosImageDataToAsciiLines(imageData, settings.width, settings.height, settings.ramp, settings.invert);
      writeMacrosOutput(lines, `image:${{macrosImageSourceName || "image"}}`);
    }}

    function generateMacrosAsciiFromText() {{
      const textInput = document.getElementById("macros-text-input");
      const fontSelect = document.getElementById("macros-text-font");
      const weightSelect = document.getElementById("macros-text-weight");
      const rawText = textInput instanceof HTMLInputElement ? String(textInput.value || "") : "";
      const trimmed = rawText.trim();
      if (!trimmed) {{
        setMacrosStatus("Enter text first.", true);
        return [];
      }}
      const settings = macrosAsciiSettingsFromInputs();
      const fontFamily = fontSelect instanceof HTMLSelectElement ? String(fontSelect.value || "monospace") : "monospace";
      const fontWeight = weightSelect instanceof HTMLSelectElement ? String(weightSelect.value || "700") : "700";
      const imageData = buildTextRenderImageData(trimmed, settings, fontFamily, fontWeight);
      if (!imageData) {{
        setMacrosStatus("Could not render text to image data.", true);
        return [];
      }}
      const lines = macrosImageDataToAsciiLines(imageData, settings.width, settings.height, settings.ramp, settings.invert);
      writeMacrosOutput(lines, `text:${{trimmed.slice(0, 36)}}`);
      return lines;
    }}

    function encodeAsciiMacroLineForSend(line) {{
      const raw = String(line == null ? "" : line);
      if (!raw) return "\u00A0";
      const normalized = raw.replace(/\t/g, "  ").slice(0, 280);
      return normalized.replace(/ /g, "\u00A0");
    }}

    function setMacrosSendBusy(isBusy) {{
      const sendBtn = document.getElementById("macros-send-lines-btn");
      if (!(sendBtn instanceof HTMLButtonElement)) return;
      sendBtn.disabled = !!isBusy;
      sendBtn.textContent = isBusy ? "Sending..." : "Send As Lines";
    }}

    async function sendMacrosPreviewAsLines() {{
      if (macrosSendInFlight || chatSendInFlight) {{
        setMacrosStatus("Wait for the current send to finish.", true);
        return;
      }}
      const output = document.getElementById("macros-ascii-output");
      if (!(output instanceof HTMLTextAreaElement)) {{
        setMacrosStatus("ASCII output box not found.", true);
        return;
      }}
      const lines = parseMacrosAsciiLines(output.value);
      if (lines.length <= 0) {{
        setMacrosStatus("Generate or paste ASCII lines first.", true);
        return;
      }}
      if (lines.length > 120) {{
        setMacrosStatus("Limit preview to 120 lines before sending.", true);
        return;
      }}
      let destination = "^all";
      if (chatMainDirectModeEnabled && activeChatChannel === "direct") {{
        const directPeer = resolvedDirectPeerForComposer();
        if (!isCanonicalNodeId(directPeer)) {{
          setMacrosStatus("Select a direct peer before sending in P2P mode.", true);
          return;
        }}
        destination = directPeer;
        if (isSelfNodeId(destination)) {{
          setMacrosStatus("Cannot send direct macros to your own radio.", true);
          return;
        }}
      }}
      const sendCtx = meshChannelSendContext();
      macrosSendInFlight = true;
      setMacrosSendBusy(true);
      let sentCount = 0;
      try {{
        for (const line of lines) {{
          setMacrosStatus(`Sending line ${{sentCount + 1}} / ${{lines.length}}...`);
          const payload = await sendChatPayload(
            {{
              text: encodeAsciiMacroLineForSend(line),
              destination,
              channel_index: sendCtx.sendIndex,
            }},
            null,
            {{
              showSendingStatus: false,
              showSuccessStatus: false,
              showErrorStatus: false,
              statusFn: () => {{}},
            }},
          );
          if (!payload || !payload.ok) {{
            throw new Error(`send failed at line ${{sentCount + 1}}`);
          }}
          sentCount += 1;
        }}
        setMacrosStatus(`Sent ${{sentCount}} ASCII line${{sentCount === 1 ? "" : "s"}} on ${{sendCtx.sendLabel}}.`);
      }} catch (err) {{
        setMacrosStatus(`Send error: ${{err && err.message ? err.message : err}}`, true);
      }} finally {{
        macrosSendInFlight = false;
        setMacrosSendBusy(false);
      }}
    }}

    function bindMacrosStudioControls() {{
      const panel = document.getElementById("macros-right-pane");
      if (!(panel instanceof HTMLElement) || panel.dataset.bound === "1") return;
      panel.dataset.bound = "1";

      const imageInput = document.getElementById("macros-image-input");
      const imageBtn = document.getElementById("macros-image-generate-btn");
      const textBtn = document.getElementById("macros-text-generate-btn");
      const textSendBtn = document.getElementById("macros-text-send-btn");
      const output = document.getElementById("macros-ascii-output");
      const previewBtn = document.getElementById("macros-preview-apply-btn");
      const clearBtn = document.getElementById("macros-clear-btn");
      const copyBtn = document.getElementById("macros-copy-btn");
      const sendBtn = document.getElementById("macros-send-lines-btn");
      const textInput = document.getElementById("macros-text-input");
      const rampInput = document.getElementById("macros-ascii-ramp");
      const paletteSelect = document.getElementById("macros-ascii-palette");
      const paletteNote = document.getElementById("macros-ascii-palette-note");

      const setPaletteNote = (rawText) => {{
        if (!(paletteNote instanceof HTMLElement)) return;
        paletteNote.textContent = String(rawText == null ? "" : rawText).trim() || "Using custom ramp.";
      }};

      let paletteSyncLocked = false;
      const syncPalettePresetFromRamp = () => {{
        if (!(paletteSelect instanceof HTMLSelectElement) || !(rampInput instanceof HTMLInputElement)) {{
          setPaletteNote("Using custom ramp.");
          return;
        }}
        const preset = findMacrosAsciiPalettePresetByRamp(rampInput.value);
        paletteSyncLocked = true;
        paletteSelect.value = preset ? preset.id : MACROS_ASCII_PALETTE_CUSTOM_ID;
        paletteSyncLocked = false;
        setPaletteNote(preset ? preset.note : "Using custom ramp.");
      }};

      if (paletteSelect instanceof HTMLSelectElement) {{
        paletteSelect.innerHTML = "";
        const customOption = document.createElement("option");
        customOption.value = MACROS_ASCII_PALETTE_CUSTOM_ID;
        customOption.textContent = "Custom";
        paletteSelect.appendChild(customOption);
        for (const preset of MACROS_ASCII_PALETTE_PRESETS) {{
          const option = document.createElement("option");
          option.value = preset.id;
          option.textContent = preset.label;
          paletteSelect.appendChild(option);
        }}
      }}

      if (paletteSelect instanceof HTMLSelectElement && rampInput instanceof HTMLInputElement) {{
        paletteSelect.addEventListener("change", () => {{
          if (paletteSyncLocked) return;
          const selected = findMacrosAsciiPalettePresetById(paletteSelect.value);
          if (!selected) {{
            setPaletteNote("Using custom ramp.");
            return;
          }}
          const normalized = normalizeMacrosAsciiRamp(selected.ramp);
          rampInput.value = normalized;
          setPaletteNote(selected.note);
          if (output instanceof HTMLTextAreaElement && String(output.value || "").trim()) {{
            syncMacrosPreviewFromOutput("edited");
          }}
        }});

        rampInput.addEventListener("input", () => {{
          if (paletteSyncLocked) return;
          syncPalettePresetFromRamp();
        }});
      }}

      if (imageInput instanceof HTMLInputElement) {{
        imageInput.addEventListener("change", async () => {{
          const file = imageInput.files && imageInput.files[0];
          if (!(file instanceof File)) {{
            macrosImageSourceElement = null;
            macrosImageSourceName = "";
            macrosImageSourceWidth = 0;
            macrosImageSourceHeight = 0;
            updateMacrosImageMeta();
            setMacrosStatus("No image selected.", true);
            return;
          }}
          try {{
            const img = await readImageFileAsElement(file);
            if (!(img instanceof HTMLImageElement)) {{
              throw new Error("image decode failed");
            }}
            macrosImageSourceElement = img;
            macrosImageSourceName = String(file.name || "image");
            macrosImageSourceWidth = Math.trunc(Number(img.naturalWidth) || 0);
            macrosImageSourceHeight = Math.trunc(Number(img.naturalHeight) || 0);
            updateMacrosImageMeta();
            setMacrosStatus(`Loaded image ${{macrosImageSourceName}}.`);
          }} catch (err) {{
            macrosImageSourceElement = null;
            macrosImageSourceName = "";
            macrosImageSourceWidth = 0;
            macrosImageSourceHeight = 0;
            updateMacrosImageMeta();
            setMacrosStatus(`Image load failed: ${{err && err.message ? err.message : err}}`, true);
          }}
        }});
      }}

      if (imageBtn instanceof HTMLButtonElement) {{
        imageBtn.addEventListener("click", () => {{
          void generateMacrosAsciiFromImage();
        }});
      }}

      if (textBtn instanceof HTMLButtonElement) {{
        textBtn.addEventListener("click", () => {{
          generateMacrosAsciiFromText();
        }});
      }}
      if (textSendBtn instanceof HTMLButtonElement) {{
        textSendBtn.addEventListener("click", () => {{
          const lines = generateMacrosAsciiFromText();
          if (!Array.isArray(lines) || lines.length <= 0) return;
          void sendMacrosPreviewAsLines();
        }});
      }}

      if (textInput instanceof HTMLInputElement) {{
        textInput.addEventListener("keydown", (ev) => {{
          if (ev.key === "Enter" && !ev.shiftKey) {{
            ev.preventDefault();
            generateMacrosAsciiFromText();
          }}
        }});
      }}

      if (previewBtn instanceof HTMLButtonElement) {{
        previewBtn.addEventListener("click", () => {{
          const lines = syncMacrosPreviewFromOutput("manual");
          setMacrosStatus(`Preview refreshed: ${{lines.length}} line${{lines.length === 1 ? "" : "s"}}.`);
        }});
      }}

      if (output instanceof HTMLTextAreaElement) {{
        output.addEventListener("input", () => {{
          syncMacrosPreviewFromOutput("edited");
        }});
      }}

      if (clearBtn instanceof HTMLButtonElement) {{
        clearBtn.addEventListener("click", () => {{
          if (output instanceof HTMLTextAreaElement) {{
            output.value = "";
          }}
          applyMacrosPreviewLines([], "");
          setMacrosStatus("Cleared preview.");
        }});
      }}

      if (copyBtn instanceof HTMLButtonElement) {{
        copyBtn.addEventListener("click", async () => {{
          if (!(output instanceof HTMLTextAreaElement) || !String(output.value || "").trim()) {{
            setMacrosStatus("Nothing to copy yet.", true);
            return;
          }}
          try {{
            await navigator.clipboard.writeText(output.value);
            setMacrosStatus("Copied ASCII output.");
          }} catch (err) {{
            setMacrosStatus(`Copy failed: ${{err && err.message ? err.message : err}}`, true);
          }}
        }});
      }}

      if (sendBtn instanceof HTMLButtonElement) {{
        sendBtn.addEventListener("click", () => {{
          void sendMacrosPreviewAsLines();
        }});
      }}

      updateMacrosImageMeta();
      syncPalettePresetFromRamp();
      syncMacrosPreviewFromOutput("init");
      setMacrosStatus("Load an image or type text to build a macro.");
    }}

    function appendLocalInfoChatRow(rawText, options = null) {{
      const text = String(rawText == null ? "" : rawText).trim();
      if (!text) return null;
      const opts = (options && typeof options === "object") ? options : {{}};
      const explicitChannel = Number(opts.channel_index);
      const sendCtx = meshChannelSendContext();
      const channelIndex = Number.isInteger(explicitChannel) && explicitChannel >= 0
        ? explicitChannel
        : sendCtx.sendIndex;
      const nowIso = new Date().toISOString();
      chatLocalInfoSeq += 1;
      const row = {{
        kind: "status",
        from: "local",
        to: "^all",
        text,
        rx_time: nowIso,
        captured_at: nowIso,
        channel_index: channelIndex,
        local_only: true,
        local_info_seq: chatLocalInfoSeq,
      }};
      chatLocalInfoRows.push(row);
      const maxRows = Math.max(6, Math.trunc(Number(chatLocalInfoMaxRows) || 24));
      if (chatLocalInfoRows.length > maxRows) {{
        chatLocalInfoRows.splice(0, chatLocalInfoRows.length - maxRows);
      }}
      chatLocalInfoVersion += 1;
      chatDerivedCache = null;
      if (latestState && typeof latestState === "object") {{
        renderChat(latestState);
      }}
      return row;
    }}

    async function sendChatPayload(body, successMessage, options = null) {{
      const opts = (options && typeof options === "object") ? options : {{}};
      const statusFn = (typeof opts.statusFn === "function") ? opts.statusFn : setChatSendStatus;
      const showSendingStatus = opts.showSendingStatus !== false;
      const showSuccessStatus = opts.showSuccessStatus !== false;
      const showErrorStatus = opts.showErrorStatus !== false;
      if (chatSendInFlight) return null;
      setChatSendBusy(true);
      if (showSendingStatus) {{
        statusFn("Sending...");
      }}
      try {{
        const resp = await fetch("/api/chat/send", {{
          method: "POST",
          headers: {{ "Content-Type": "application/json" }},
          body: JSON.stringify(body || {{}}),
        }});
        const payload = await resp.json().catch(() => ({{}}));
        if (!resp.ok || !payload.ok) {{
          const msg = payload && payload.error ? payload.error : `send failed (${{resp.status}})`;
          throw new Error(msg);
        }}
        if (showSuccessStatus) {{
          statusFn(successMessage || `Sent at ${{payload.sent_at || "now"}}`);
        }}
        await poll();
        return payload;
      }} catch (err) {{
        if (showErrorStatus) {{
          statusFn(`Send error: ${{err.message || err}}`, true);
        }}
        return null;
      }} finally {{
        setChatSendBusy(false);
        flushQueuedComposerSend();
      }}
    }}

    async function postStandaloneZorkCommand(text, sessionId = "") {{
      const body = {{
        text: String(text == null ? "" : text),
      }};
      const cleanSessionId = String(sessionId == null ? "" : sessionId).trim();
      if (cleanSessionId) {{
        body.session_id = cleanSessionId;
      }}
      const resp = await fetch("/api/games/zork", {{
        method: "POST",
        headers: {{ "Content-Type": "application/json" }},
        body: JSON.stringify(body),
      }});
      const payload = await resp.json().catch(() => ({{}}));
      if (!resp.ok || !payload.ok) {{
        const msg = payload && payload.error ? payload.error : `standalone zork failed (${{resp.status}})`;
        throw new Error(msg);
      }}
      return payload;
    }}

    function restoreChatInputFocus(input) {{
      if (!(input instanceof HTMLInputElement)) return;
      window.requestAnimationFrame(() => {{
        if (input.disabled) return;
        input.focus({{ preventScroll: true }});
        const tail = input.value.length;
        input.setSelectionRange(tail, tail);
      }});
    }}

    function flushQueuedComposerSend() {{
      if (!queuedComposerSend || chatSendInFlight) return;
      const input = document.getElementById("chat-input");
      const hasText = input instanceof HTMLInputElement && String(input.value || "").trim().length > 0;
      const preserveFocus = !!queuedComposerFocus;
      queuedComposerSend = false;
      queuedComposerFocus = false;
      if (!hasText) return;
      window.setTimeout(() => {{
        void sendChatMessage({{ preserveFocus }});
      }}, 0);
    }}

    async function sendChatMessage(options = null) {{
      const input = document.getElementById("chat-input");
      if (!(input instanceof HTMLInputElement)) return;
      const preserveFocus = !!(options && options.preserveFocus);
      const hadFocus = preserveFocus && document.activeElement === input;
      if (chatSendInFlight) {{
        const queuedText = String(input.value || "").trim();
        if (queuedText) {{
          queuedComposerSend = true;
          if (preserveFocus || document.activeElement === input) {{
            queuedComposerFocus = true;
          }}
          setChatSendStatus("Send in progress. Queued your message...");
        }}
        return;
      }}
      const rawText = input.value.trim();
      if (!rawText) {{
        setChatSendStatus("Enter a message before sending.", true);
        if (hadFocus) {{
          restoreChatInputFocus(input);
        }}
        return;
      }}
      const macro = parseChatTextMacro(rawText);
      if (macro && macro.kind === "help") {{
        appendLocalInfoChatRow(chatMacroHelpText());
        input.value = "";
        if (hadFocus) {{
          restoreChatInputFocus(input);
        }}
        return;
      }}
      const text = (macro && macro.kind === "replace")
        ? macro.text
        : rawText;
      let destination = "^all";
      if (chatMainDirectModeEnabled && activeChatChannel === "direct") {{
        const directPeer = resolvedDirectPeerForComposer();
        if (!isCanonicalNodeId(directPeer)) {{
          setChatSendStatus("Select a user before sending a peer-to-peer message.", true);
          if (hadFocus) {{
            restoreChatInputFocus(input);
          }}
          return;
        }}
        destination = directPeer;
        if (isSelfNodeId(destination)) {{
          setChatSendStatus("Cannot send peer-to-peer message to your own radio.", true);
          if (hadFocus) {{
            restoreChatInputFocus(input);
          }}
          return;
        }}
      }}
      const replyId = Number(chatReplyTargetId);
      const sendCtx = meshChannelSendContext();
      const requestBody = {{
        text,
        destination,
        channel_index: sendCtx.sendIndex,
      }};
      if (Number.isInteger(replyId) && replyId > 0) {{
        requestBody.reply_id = replyId;
      }}
      const payload = await sendChatPayload(
        requestBody,
        null
      );
      if (payload && payload.ok) {{
        recordBotRequestHistoryFromSend(requestBody, payload);
        input.value = "";
        const replied = Number.isInteger(replyId) && replyId > 0;
        clearChatReplyTarget();
        if (macro && macro.kind === "replace") {{
          if (destination === "^all") {{
            setChatSendStatus(`Sent macro ${{macro.source}} on ${{sendCtx.sendLabel}} at ${{payload.sent_at || "now"}}`);
          }} else {{
            setChatSendStatus(`Sent macro ${{macro.source}} to ${{destination}} on ${{sendCtx.sendLabel}} at ${{payload.sent_at || "now"}}`);
          }}
        }} else if (destination === "^all") {{
          setChatSendStatus(`${{replied ? "Reply sent" : "Sent"}} to Everyone on ${{sendCtx.sendLabel}} at ${{payload.sent_at || "now"}}`);
        }} else {{
          const awaitingAck = payload.ack_requested === true && normalizeDeliveryState(payload.delivery_state) === "pending";
          const messageId = Number(payload && payload.message_id);
          if (awaitingAck && Number.isInteger(messageId) && messageId > 0) {{
            chatPendingDirectAck = {{
              messageId,
              destination,
              channelIndex: sendCtx.sendIndex,
              sentUnix: latestUnixTimestamp(
                payload && payload.sent_unix,
                payload && payload.sent_at,
                Math.floor(Date.now() / 1000)
              ),
            }};
          }} else {{
            chatPendingDirectAck = null;
          }}
          if (awaitingAck) {{
            setChatSendStatus(`${{replied ? "Reply sent direct" : "Sent direct"}} to ${{destination}} on ${{sendCtx.sendLabel}} at ${{payload.sent_at || "now"}} (awaiting ACK)`);
          }} else {{
            setChatSendStatus(`${{replied ? "Reply sent direct" : "Sent direct"}} to ${{destination}} on ${{sendCtx.sendLabel}} at ${{payload.sent_at || "now"}}`);
          }}
        }}
      }}
      if (hadFocus) {{
        restoreChatInputFocus(input);
      }}
    }}

    async function sendChatReaction(replyId, emoji) {{
      const replyNum = Number(replyId);
      const cleanEmoji = String(emoji || "").trim();
      if (!Number.isInteger(replyNum) || replyNum <= 0) {{
        setChatSendStatus("Cannot react: target message id is missing.", true);
        return;
      }}
      if (!cleanEmoji) {{
        setChatSendStatus("Choose an emoji reaction.", true);
        return;
      }}
      if (!isReactionCompatibleEmoji(cleanEmoji)) {{
        setChatSendStatus("Choose a single-codepoint emoji for reactions.", true);
        return;
      }}
      let destination = "^all";
      const sendCtx = meshChannelSendContext();
      if (chatMainDirectModeEnabled && activeChatChannel === "direct") {{
        const directPeer = resolvedDirectPeerForComposer();
        if (isCanonicalNodeId(directPeer)) {{
          destination = directPeer;
        }}
        if (isSelfNodeId(destination)) {{
          setChatSendStatus("Cannot react in peer-to-peer mode to your own radio.", true);
          return;
        }}
      }}
      const payload = await sendChatPayload(
        {{
          destination,
          channel_index: sendCtx.sendIndex,
          reply_id: replyNum,
          emoji: cleanEmoji,
        }},
        null
      );
      if (payload && payload.ok) {{
        setChatSendStatus(`Reacted ${{cleanEmoji}} on ${{sendCtx.sendLabel}} at ${{payload.sent_at || "now"}}`);
      }}
    }}

    async function sendChatAck(options = null) {{
      if (chatSendInFlight) return null;
      const ackActionStartMs = Date.now();
      const replyId = Number(options && options.reply_id);
      if (!Number.isInteger(replyId) || replyId <= 0) {{
        setChatSendStatus("Cannot ACK: target message id is missing.", true);
        return null;
      }}
      const textMode = String((options && options.text_mode) || "").trim().toLowerCase();
      let text = String((options && options.text) || "").trim();
      if (textMode === "pong") {{
        try {{
          const pongOptions = {{
            ...((options && typeof options === "object") ? options : {{}}),
            action_start_ms: ackActionStartMs,
          }};
          const pongText = await buildPongStyleAckReplyText(pongOptions, latestState);
          if (pongText) {{
            text = String(pongText).trim();
          }}
        }} catch (_err) {{
          // Fall back to the pre-baked ACK text if pong-style generation fails.
        }}
      }}
      if (!text) {{
        setChatSendStatus("Cannot ACK: message details are unavailable.", true);
        return null;
      }}
      let destination = normalizeNodeId((options && options.destination) || "^all");
      if (!destination) destination = "^all";
      if (destination !== "^all" && !isCanonicalNodeId(destination)) {{
        setChatSendStatus("Cannot ACK: destination is unavailable.", true);
        return null;
      }}
      const channelRaw = Number(options && options.channel_index);
      const channelIndex = Number.isInteger(channelRaw) && channelRaw >= 0 ? channelRaw : 0;
      const targetLabel = String((options && options.target_label) || "").trim()
        || (destination === "^all" ? "Everyone" : destination);
      const payload = await sendChatPayload(
        {{
          text,
          destination,
          channel_index: channelIndex,
          reply_id: replyId,
        }},
        null
      );
      if (payload && payload.ok) {{
        setChatSendStatus(`ACK sent to ${{targetLabel}} on ${{meshChannelLabelForIndex(channelIndex)}} at ${{payload.sent_at || "now"}}`);
      }}
      return payload;
    }}

    function chatAckOptionsFromButton(button) {{
      if (!(button instanceof HTMLElement)) return null;
      return {{
        reply_id: Number(button.dataset.ackReplyId || ""),
        text: button.dataset.ackText || "",
        text_mode: button.dataset.ackTextMode || "",
        destination: button.dataset.ackDestination || "^all",
        channel_index: Number(button.dataset.ackChannel || ""),
        target_label: button.dataset.ackTargetLabel || "",
        source_id: button.dataset.ackSourceId || "",
        source_label: button.dataset.ackSourceLabel || "",
        received_unix: button.dataset.ackReceivedUnix || "",
        hops: button.dataset.ackHopCount || "",
        rx_snr: button.dataset.ackRxSnr || "",
        rx_rssi: button.dataset.ackRxRssi || "",
      }};
    }}

    async function retryChatMessage(options) {{
      const text = String((options && options.text) || "").trim();
      if (!text) {{
        setChatSendStatus("Cannot retry: message text is empty.", true);
        return;
      }}

      let destination = String((options && options.destination) || "^all").trim() || "^all";
      if (destination.toLowerCase() === "all" || destination.toLowerCase() === "broadcast") {{
        destination = "^all";
      }}
      if (!(destination === "^all" || destination.startsWith("!"))) {{
        setChatSendStatus("Cannot retry: destination is invalid.", true);
        return;
      }}

      const channelRaw = Number(options && options.channel_index);
      const channelIndex = Number.isInteger(channelRaw) && channelRaw >= 0 ? channelRaw : 0;
      const replyRaw = Number(options && options.reply_id);
      const retryOfRaw = Number(options && options.retry_of);

      const body = {{
        text,
        destination,
        channel_index: channelIndex,
      }};
      if (Number.isInteger(replyRaw) && replyRaw > 0) {{
        body.reply_id = replyRaw;
      }}
      if (Number.isInteger(retryOfRaw) && retryOfRaw > 0) {{
        body.retry_of = retryOfRaw;
      }}

      const payload = await sendChatPayload(body, null);
      if (payload && payload.ok) {{
        const destLabel = destination === "^all" ? "Everyone" : destination;
        setChatSendStatus(`Retried to ${{destLabel}} at ${{payload.sent_at || "now"}}`);
      }}
    }}
