    function clampMacrosAsciiDimension(rawValue, fallbackValue = 16, minValue = 8, maxValue = 96) {{
      const numeric = Math.trunc(Number(rawValue));
      if (!Number.isFinite(numeric)) return fallbackValue;
      return Math.max(minValue, Math.min(maxValue, numeric));
    }}

    function normalizeMacrosAsciiRamp(rawRamp) {{
      const fallback = MACROS_ASCII_RAMP_FALLBACK;
      const value = String(rawRamp == null ? "" : rawRamp);
      const chars = [];
      const seen = new Set();
      for (const char of value) {{
        if (char === "\n" || char === "\r") continue;
        if (seen.has(char)) continue;
        chars.push(char);
        seen.add(char);
      }}
      const ramp = chars.join("");
      return ramp.length >= 2 ? ramp : fallback;
    }}

    function findMacrosAsciiPalettePresetByRamp(rawRamp) {{
      const normalized = normalizeMacrosAsciiRamp(rawRamp);
      for (const preset of MACROS_ASCII_PALETTE_PRESETS) {{
        if (normalizeMacrosAsciiRamp(preset.ramp) === normalized) {{
          return preset;
        }}
      }}
      return null;
    }}

    function findMacrosAsciiPalettePresetById(rawId) {{
      const id = String(rawId == null ? "" : rawId).trim();
      if (!id) return null;
      return MACROS_ASCII_PALETTE_PRESETS.find((preset) => preset.id === id) || null;
    }}

    function parseMacrosAsciiLines(rawText) {{
      const normalized = String(rawText == null ? "" : rawText).replace(/\r\n?/g, "\n");
      const rows = normalized.split("\n").slice(0, 120).map((line) => String(line || "").slice(0, 280));
      while (rows.length > 0 && rows[rows.length - 1] === "") {{
        rows.pop();
      }}
      return rows;
    }}

    function macrosAsciiSettingsFromInputs() {{
      const widthInput = document.getElementById("macros-ascii-width");
      const heightInput = document.getElementById("macros-ascii-height");
      const rampInput = document.getElementById("macros-ascii-ramp");
      const invertInput = document.getElementById("macros-ascii-invert");
      return {{
        width: clampMacrosAsciiDimension(widthInput && widthInput.value, 16, 8, 96),
        height: clampMacrosAsciiDimension(heightInput && heightInput.value, 16, 8, 96),
        ramp: normalizeMacrosAsciiRamp(rampInput && rampInput.value),
        invert: !!(invertInput && invertInput.checked),
      }};
    }}

