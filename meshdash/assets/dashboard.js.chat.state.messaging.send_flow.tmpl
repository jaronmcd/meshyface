    function classifyMessageChannel(msg) {{
      if (!msg || typeof msg !== "object") return "all";
      const toId = normalizeNodeId(msg.to || msg.destination || "");
      if (!toId || toId === "^all" || toId === "all" || toId === "broadcast") {{
        return "all";
      }}
      if (typeof msg.scope === "string" && msg.scope.trim()) {{
        return normalizeChatChannel(msg.scope);
      }}
      return "direct";
    }}

   const chatComposerMaxBytes = Math.max(
      1,
      Math.trunc(Number(typeof chatMessageMaxBytes !== "undefined" ? chatMessageMaxBytes : 200) || 200)
    );

    function chatComposerByteLength(value) {{
      const raw = String(value == null ? "" : value);
      if (typeof TextEncoder !== "undefined") {{
        try {{
          return new TextEncoder().encode(raw).length;
        }} catch (_err) {{
        }}
      }}
      try {{
        const encoded = encodeURIComponent(raw);
        let count = 0;
        for (let i = 0; i < encoded.length; i += 1) {{
          if (encoded[i] === "%" && i + 2 < encoded.length) {{
            count += 1;
            i += 2;
          }} else {{
            count += 1;
          }}
        }}
        return count;
      }} catch (_err) {{
        return raw.length;
      }}
    }}

   function parseChatFeedSearchCommand(rawText) {{
      const value = String(rawText == null ? "" : rawText);
      const trimmedStart = value.replace(/^\s+/, "");
      const match = trimmedStart.match(/^\/\/search(?:\s+([\s\S]*))?$/i);
      if (!match) return null;
      return {{
        kind: "search",
        source: "//search",
        text: "",
        query: String(match[1] == null ? "" : match[1]).trim(),
      }};
    }}

    function chatTextStartsWithLocalCommandPrefix(rawText) {{
      return String(rawText == null ? "" : rawText).trimStart().startsWith("//");
    }}

    function chatLocalCommandName(rawText) {{
      const match = String(rawText == null ? "" : rawText).trimStart().match(/^\/\/([^\s]*)/);
      return match ? String(match[1] || "").trim() : "";
    }}

    function applyChatFeedSearchFilter() {{
      const feed = document.getElementById("chat-feed");
      if (!(feed instanceof HTMLElement)) return;
      const queryRaw = String(chatFeedSearchQuery == null ? "" : chatFeedSearchQuery);
      const queryLabel = queryRaw.trim();
      const query = queryLabel.toLowerCase();
      const cachedFeedRows = Array.isArray(feed.__meshChatFeedSearchRows)
        ? feed.__meshChatFeedSearchRows
        : [];
      const needsRowRefresh = (
        cachedFeedRows.length <= 0
        || cachedFeedRows.some((row) => !(row instanceof HTMLElement) || !row.isConnected || row.parentElement == null)
      );
      const feedRows = needsRowRefresh
        ? Array.from(feed.querySelectorAll(".chat-feed-item")).filter((row) => row instanceof HTMLElement)
        : cachedFeedRows;
      if (needsRowRefresh) {{
        feed.__meshChatFeedSearchRows = feedRows;
      }}
      let visibleRows = 0;
      if (!query) {{
        for (const row of feedRows) {{
          if (!(row instanceof HTMLElement)) continue;
          row.hidden = false;
          row.classList.remove("chat-feed-search-hidden");
          visibleRows += 1;
        }}
      }} else {{
        for (const row of feedRows) {{
          if (!(row instanceof HTMLElement)) continue;
          let haystack = String(row.__meshSearchHaystack || "");
          if (!haystack) {{
            const rowName = String(row.dataset.replyName || "");
            const rowText = String(row.dataset.replyText || "");
            haystack = `${{rowName}} ${{rowText}} ${{row.textContent || ""}}`.toLowerCase();
            row.__meshSearchHaystack = haystack;
          }}
          const matches = haystack.includes(query);
          row.hidden = !matches;
          row.classList.toggle("chat-feed-search-hidden", !matches);
          if (matches) visibleRows += 1;
        }}
      }}
      let searchEmpty = feed.querySelector(".chat-feed-empty.chat-feed-search-empty");
      if (query && feedRows.length > 0 && visibleRows <= 0) {{
        if (!(searchEmpty instanceof HTMLElement)) {{
          searchEmpty = document.createElement("div");
          searchEmpty.className = "chat-feed-empty chat-feed-search-empty";
          feed.appendChild(searchEmpty);
        }}
        searchEmpty.textContent = `No messages match "${{queryLabel}}".`;
      }} else if (searchEmpty instanceof HTMLElement) {{
        searchEmpty.remove();
      }}
    }}

    function syncChatFeedSearchFilter(rawText) {{
      const parsedSearch = parseChatFeedSearchCommand(rawText);
      chatFeedSearchQuery = parsedSearch ? String(parsedSearch.query || "") : "";
      applyChatFeedSearchFilter();
      return parsedSearch;
    }}

  function appendLocalInfoChatRow(rawText, options = null) {{
      const text = String(rawText == null ? "" : rawText).trim();
      if (!text) return null;
      const opts = (options && typeof options === "object") ? options : {{}};
      const explicitChannel = Number(opts.channel_index);
      const sendCtx = meshChannelSendContext();
      const channelIndex = Number.isInteger(explicitChannel) && explicitChannel >= 0
        ? explicitChannel
        : sendCtx.sendIndex;
      const nowIso = new Date().toISOString();
      chatLocalInfoSeq += 1;
      const row = {{
        kind: "status",
        from: "local",
        to: "^all",
        text,
        rx_time: nowIso,
        captured_at: nowIso,
        channel_index: channelIndex,
        local_only: true,
        local_info_seq: chatLocalInfoSeq,
      }};
      chatLocalInfoRows.push(row);
      const maxRows = Math.max(6, Math.trunc(Number(chatLocalInfoMaxRows) || 24));
      if (chatLocalInfoRows.length > maxRows) {{
        chatLocalInfoRows.splice(0, chatLocalInfoRows.length - maxRows);
      }}
      chatLocalInfoVersion += 1;
      chatDerivedCache = null;
      if (latestState && typeof latestState === "object") {{
        renderChat(latestState);
      }}
      return row;
    }}

    async function sendChatPayload(body, successMessage, options = null) {{
      const opts = (options && typeof options === "object") ? options : {{}};
      const statusFn = (typeof opts.statusFn === "function") ? opts.statusFn : setChatSendStatus;
      const showSendingStatus = opts.showSendingStatus !== false;
      const showSuccessStatus = opts.showSuccessStatus !== false;
      const showErrorStatus = opts.showErrorStatus !== false;
      if (chatSendInFlight) return null;
      setChatSendBusy(true);
      if (showSendingStatus) {{
        statusFn("Sending...");
      }}
      try {{
        const resp = await fetch("/api/chat/send", {{
          method: "POST",
          headers: {{ "Content-Type": "application/json" }},
          body: JSON.stringify(body || {{}}),
        }});
        const payload = await resp.json().catch(() => ({{}}));
        if (!resp.ok || !payload.ok) {{
          const msg = payload && payload.error ? payload.error : `send failed (${{resp.status}})`;
          throw new Error(msg);
        }}
        if (showSuccessStatus) {{
          statusFn(successMessage || `Sent at ${{payload.sent_at || "now"}}`);
        }}
        await poll();
        return payload;
      }} catch (err) {{
        if (showErrorStatus) {{
          statusFn(`Send error: ${{err.message || err}}`, true);
        }}
        return null;
      }} finally {{
        setChatSendBusy(false);
        flushQueuedComposerSend();
      }}
    }}

    async function postStandaloneZorkCommand(text, sessionId = "") {{
      const body = {{
        text: String(text == null ? "" : text),
      }};
      const cleanSessionId = String(sessionId == null ? "" : sessionId).trim();
      if (cleanSessionId) {{
        body.session_id = cleanSessionId;
      }}
      const resp = await fetch("/api/games/zork", {{
        method: "POST",
        headers: {{ "Content-Type": "application/json" }},
        body: JSON.stringify(body),
      }});
      const payload = await resp.json().catch(() => ({{}}));
      if (!resp.ok || !payload.ok) {{
        const msg = payload && payload.error ? payload.error : `standalone zork failed (${{resp.status}})`;
        throw new Error(msg);
      }}
      return payload;
    }}

    let networkToolCommandQueue = Promise.resolve();

    async function postNetworkToolCommand(body) {{
      const requestBody = (body && typeof body === "object") ? {{ ...body }} : {{}};
      const runRequest = async () => {{
        const resp = await fetch("/api/tools/network", {{
          method: "POST",
          headers: {{ "Content-Type": "application/json" }},
          body: JSON.stringify(requestBody),
        }});
        const payload = await resp.json().catch(() => ({{}}));
        if (!resp.ok || !payload.ok) {{
          const message = payload && payload.error ? payload.error : `network tool failed (${{resp.status}})`;
          const err = new Error(message);
          try {{
            err.payload = payload;
          }} catch (_err) {{
          }}
          throw err;
        }}
        return payload;
      }};
      const queued = networkToolCommandQueue.catch(() => {{}}).then(runRequest);
      networkToolCommandQueue = queued.catch(() => {{}});
      return queued;
    }}

    function restoreChatInputFocus(input) {{
      if (!(input instanceof HTMLInputElement)) return;
      window.requestAnimationFrame(() => {{
        if (input.disabled) return;
        input.focus({{ preventScroll: true }});
        const tail = input.value.length;
        input.setSelectionRange(tail, tail);
      }});
    }}

    function flushQueuedComposerSend() {{
      if (!queuedComposerSend || chatSendInFlight) return;
      const input = document.getElementById("chat-input");
      const hasText = input instanceof HTMLInputElement && String(input.value || "").trim().length > 0;
      const preserveFocus = !!queuedComposerFocus;
      queuedComposerSend = false;
      queuedComposerFocus = false;
      if (!hasText) return;
      window.setTimeout(() => {{
        void sendChatMessage({{ preserveFocus }});
      }}, 0);
    }}

    async function sendChatMessage(options = null) {{
      const input = document.getElementById("chat-input");
      if (!(input instanceof HTMLInputElement)) return;
      const preserveFocus = !!(options && options.preserveFocus);
      const hadFocus = preserveFocus && document.activeElement === input;
      if (chatSendInFlight) {{
        const queuedText = String(input.value || "").trim();
        if (queuedText) {{
          queuedComposerSend = true;
          if (preserveFocus || document.activeElement === input) {{
            queuedComposerFocus = true;
          }}
          setChatSendStatus("Send in progress. Queued your message...");
        }}
        return;
      }}
      const rawText = String(input.value || "");
      if (!rawText.trim()) {{
        setChatSendStatus("Enter a message before sending.", true);
        if (hadFocus) {{
          restoreChatInputFocus(input);
        }}
        return;
      }}
      const searchCommand = parseChatFeedSearchCommand(rawText);
      if (searchCommand) {{
        setChatSendStatus("Chat search is active. Remove //search to send a message.");
        if (hadFocus) {{
          restoreChatInputFocus(input);
        }}
        return;
      }}
      if (chatTextStartsWithLocalCommandPrefix(rawText)) {{
        const commandName = chatLocalCommandName(rawText);
        const commandLabel = commandName ? `//${{commandName}}` : "//";
        setChatSendStatus(`Unknown local command ${{commandLabel}}. Nothing was sent.`, true);
        if (hadFocus) {{
          restoreChatInputFocus(input);
        }}
        return;
      }}
      const text = rawText;
      const textBytes = chatComposerByteLength(text);
      if (textBytes > chatComposerMaxBytes) {{
        setChatSendStatus(`Message is too long (${{textBytes}} bytes). Limit is ${{chatComposerMaxBytes}} bytes.`, true);
        if (hadFocus) {{
          restoreChatInputFocus(input);
        }}
        return;
      }}
      let destination = "^all";
      if (chatMainDirectModeEnabled && activeChatChannel === "direct") {{
        const directPeer = resolvedDirectPeerForComposer();
        if (!isCanonicalNodeId(directPeer)) {{
          setChatSendStatus("Select a user before sending a peer-to-peer message.", true);
          if (hadFocus) {{
            restoreChatInputFocus(input);
          }}
          return;
        }}
        destination = directPeer;
        if (isSelfNodeId(destination)) {{
          setChatSendStatus("Cannot send peer-to-peer message to your own radio.", true);
          if (hadFocus) {{
            restoreChatInputFocus(input);
          }}
          return;
        }}
      }}
      const replyId = Number(chatReplyTargetId);
      const sendCtx = meshChannelSendContext();
      const requestBody = {{
        text,
        destination,
        channel_index: sendCtx.sendIndex,
      }};
      if (Number.isInteger(replyId) && replyId > 0) {{
        requestBody.reply_id = replyId;
      }}
      const payload = await sendChatPayload(
        requestBody,
        null
      );
      if (payload && payload.ok) {{
        input.value = "";
        const replied = Number.isInteger(replyId) && replyId > 0;
        clearChatReplyTarget();
        if (destination === "^all") {{
          setChatSendStatus(`${{replied ? "Reply sent" : "Sent"}} to Everyone on ${{sendCtx.sendLabel}} at ${{payload.sent_at || "now"}}`);
        }} else {{
          const awaitingAck = payload.ack_requested === true && normalizeDeliveryState(payload.delivery_state) === "pending";
          const messageId = Number(payload && payload.message_id);
          if (awaitingAck && Number.isInteger(messageId) && messageId > 0) {{
            chatPendingDirectAck = {{
              messageId,
              destination,
              channelIndex: sendCtx.sendIndex,
              sentUnix: latestUnixTimestamp(
                payload && payload.sent_unix,
                payload && payload.sent_at,
                Math.floor(Date.now() / 1000)
              ),
            }};
          }} else {{
            chatPendingDirectAck = null;
          }}
          if (awaitingAck) {{
            setChatSendStatus(`${{replied ? "Reply sent direct" : "Sent direct"}} to ${{destination}} on ${{sendCtx.sendLabel}} at ${{payload.sent_at || "now"}} (awaiting ACK)`);
          }} else {{
            setChatSendStatus(`${{replied ? "Reply sent direct" : "Sent direct"}} to ${{destination}} on ${{sendCtx.sendLabel}} at ${{payload.sent_at || "now"}}`);
          }}
        }}
      }}
      if (hadFocus) {{
        restoreChatInputFocus(input);
      }}
    }}

    async function sendChatReaction(replyId, emoji) {{
      const replyNum = Number(replyId);
      const cleanEmoji = String(emoji || "").trim();
      if (!Number.isInteger(replyNum) || replyNum <= 0) {{
        setChatSendStatus("Cannot react: target message id is missing.", true);
        return;
      }}
      if (!cleanEmoji) {{
        setChatSendStatus("Choose an emoji reaction.", true);
        return;
      }}
      if (!isReactionCompatibleEmoji(cleanEmoji)) {{
        setChatSendStatus("Choose a single-codepoint emoji for reactions.", true);
        return;
      }}
      let destination = "^all";
      const sendCtx = meshChannelSendContext();
      if (chatMainDirectModeEnabled && activeChatChannel === "direct") {{
        const directPeer = resolvedDirectPeerForComposer();
        if (isCanonicalNodeId(directPeer)) {{
          destination = directPeer;
        }}
        if (isSelfNodeId(destination)) {{
          setChatSendStatus("Cannot react in peer-to-peer mode to your own radio.", true);
          return;
        }}
      }}
      const payload = await sendChatPayload(
        {{
          destination,
          channel_index: sendCtx.sendIndex,
          reply_id: replyNum,
          emoji: cleanEmoji,
        }},
        null
      );
      if (payload && payload.ok) {{
        setChatSendStatus(`Reacted ${{cleanEmoji}} on ${{sendCtx.sendLabel}} at ${{payload.sent_at || "now"}}`);
      }}
    }}

    async function sendChatAck(options = null) {{
      if (chatSendInFlight) return null;
      const ackActionStartMs = Date.now();
      const replyId = Number(options && options.reply_id);
      if (!Number.isInteger(replyId) || replyId <= 0) {{
        setChatSendStatus("Cannot ACK: target message id is missing.", true);
        return null;
      }}
      const textMode = String((options && options.text_mode) || "").trim().toLowerCase();
      let text = String((options && options.text) || "").trim();
      if (textMode === "pong") {{
        try {{
          const pongOptions = {{
            ...((options && typeof options === "object") ? options : {{}}),
            action_start_ms: ackActionStartMs,
          }};
          const pongText = await buildPongStyleAckReplyText(pongOptions, latestState);
          if (pongText) {{
            text = String(pongText).trim();
          }}
        }} catch (_err) {{
          // Fall back to the pre-baked ACK text if pong-style generation fails.
        }}
      }}
      if (!text) {{
        setChatSendStatus("Cannot ACK: message details are unavailable.", true);
        return null;
      }}
      let destination = normalizeNodeId((options && options.destination) || "^all");
      if (!destination) destination = "^all";
      if (destination !== "^all" && !isCanonicalNodeId(destination)) {{
        setChatSendStatus("Cannot ACK: destination is unavailable.", true);
        return null;
      }}
      const channelRaw = Number(options && options.channel_index);
      const channelIndex = Number.isInteger(channelRaw) && channelRaw >= 0 ? channelRaw : 0;
      const targetLabel = String((options && options.target_label) || "").trim()
        || (destination === "^all" ? "Everyone" : destination);
      const payload = await sendChatPayload(
        {{
          text,
          destination,
          channel_index: channelIndex,
          reply_id: replyId,
        }},
        null
      );
      if (payload && payload.ok) {{
        setChatSendStatus(`ACK sent to ${{targetLabel}} on ${{meshChannelLabelForIndex(channelIndex)}} at ${{payload.sent_at || "now"}}`);
      }}
      return payload;
    }}

    function chatAckOptionsFromButton(button) {{
      if (!(button instanceof HTMLElement)) return null;
