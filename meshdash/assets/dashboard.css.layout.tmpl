    .peer-dm-popout-input:focus-visible {{
      outline: 2px solid #3ea269;
      outline-offset: 1px;
    }}
    .peer-dm-popout-send-btn {{
      grid-column: 2;
      grid-row: 1;
      border: 1px solid #4b9a6d;
      background: #2f7f58;
      color: #ecfff4;
      border-radius: 999px;
      padding: 4px 10px;
      font-size: 11px;
      line-height: 1.2;
      cursor: pointer;
      white-space: nowrap;
      min-width: 56px;
