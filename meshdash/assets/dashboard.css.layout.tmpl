      color: #244936;
      border-radius: 999px;
      padding: 1px 7px;
      font-size: 9px;
      line-height: 1.2;
      font-weight: 700;
      letter-spacing: 0.02em;
      white-space: nowrap;
    }}
    .peer-dm-popout-actions {{
      display: inline-flex;
      align-items: center;
      gap: 6px;
      flex: 0 0 auto;
    }}
    .peer-dm-popout-btn {{
      border: 1px solid #bfd4c3;
      background: #ffffff;
      color: #28533c;
      border-radius: 999px;
      padding: 3px 9px;
      font-size: 10px;
      line-height: 1.2;
      cursor: pointer;
      white-space: nowrap;
    }}
    .peer-dm-popout-btn:hover {{
      background: #eaf5ed;
      border-color: #94b7a0;
    }}
    .peer-dm-popout-body {{
      flex: 0 1 auto;
      max-height: min(300px, calc(100vh - 180px));
      padding: 7px 8px;
      overflow: auto;
      background:
        linear-gradient(
          180deg,
          rgba(var(--peer-dm-channel-rgb), 0.1) 0%,
          rgba(var(--peer-dm-channel-rgb), 0.03) 46%,
          rgba(var(--peer-dm-channel-rgb), 0.01) 100%
        ),
        #fbfefb;
      display: flex;
      flex-direction: column;
      gap: 6px;
      min-height: 0;
    }}
    .peer-dm-popout-window.is-embedded .peer-dm-popout-body {{
      flex: 1 1 auto;
      max-height: none;
    }}
    .peer-dm-popout-empty {{
      border: 1px dashed rgba(var(--peer-dm-channel-rgb), 0.42);
      border-radius: 8px;
      padding: 10px 9px;
      color: #4f6a5b;
      font-size: 11px;
      line-height: 1.35;
      text-align: center;
      background: rgba(var(--peer-dm-channel-rgb), 0.06);
