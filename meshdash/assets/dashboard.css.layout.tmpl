    .peer-dm-popout-window.is-embedded .peer-dm-popout-empty {{
      min-height: 88px;
      display: flex;
      align-items: center;
      justify-content: center;
    }}
    .peer-dm-popout-msg {{
      display: inline-flex;
      flex-direction: column;
      gap: 3px;
      max-width: 85%;
      border: 1px solid rgba(var(--peer-dm-channel-rgb), 0.3);
      border-radius: 10px;
      background: rgba(var(--peer-dm-channel-rgb), 0.09);
      padding: 5px 7px;
      color: #214836;
      line-height: 1.3;
      word-break: break-word;
    }}
    .peer-dm-popout-msg.is-own {{
      margin-left: auto;
      border-color: rgba(var(--peer-dm-channel-rgb), 0.56);
      background: rgba(var(--peer-dm-channel-rgb), 0.2);
      color: #1f4231;
    }}
