    .peer-dm-popout-file-progress[hidden] {{
      display: none !important;
    }}
    .peer-dm-popout-file-progress-head {{
      display: inline-flex;
      align-items: center;
      justify-content: space-between;
      gap: 8px;
      min-width: 0;
    }}
    .peer-dm-popout-file-progress-text {{
      font-size: 10px;
      line-height: 1.2;
      color: #3f604f;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      min-width: 0;
      flex: 1 1 auto;
    }}
    .peer-dm-popout-file-progress-pct {{
      font-size: 10px;
      line-height: 1.2;
      color: #31513f;
      font-weight: 700;
      flex: 0 0 auto;
    }}
    .peer-dm-popout-file-progress-meter {{
