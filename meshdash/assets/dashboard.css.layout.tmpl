      font-size: 9px;
      color: #5c7868;
      line-height: 1.2;
      display: inline-flex;
      align-items: center;
      gap: 5px;
      white-space: nowrap;
    }}
    .peer-dm-popout-msg-text {{
      font-size: 11px;
      line-height: 1.35;
    }}
    .peer-dm-popout-composer {{
      border-top: 1px solid rgba(var(--peer-dm-channel-rgb), 0.35);
      background:
        linear-gradient(
          180deg,
          rgba(var(--peer-dm-channel-rgb), 0.15) 0%,
          rgba(var(--peer-dm-channel-rgb), 0.08) 100%
        ),
        #f2f9f4;
      padding: 7px 8px;
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      gap: 7px;
      align-items: center;
    }}
    .peer-dm-popout-input {{
      grid-column: 1;
      grid-row: 1;
      border: 1px solid rgba(var(--peer-dm-channel-rgb), 0.46);
      border-radius: 999px;
      background: #ffffff;
      color: #264634;
      padding: 5px 10px;
      font-size: 11px;
      line-height: 1.2;
      min-width: 0;
      width: 100%;
