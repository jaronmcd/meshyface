      border: 1px solid var(--surface-tint-border);
      background: linear-gradient(90deg, var(--surface-tint-bg-soft), var(--surface-tint-bg-alt));
      cursor: row-resize;
      touch-action: none;
      user-select: none;
      min-height: 6px;
    }}
    .hsplitter[data-target="top"] {{ grid-row: 3; }}
    .hsplitter[data-target="mid"] {{ grid-row: 5; }}
    .hsplitter[data-target="low"] {{ grid-row: 9; }}
    .hsplitter::before {{
      content: "";
      position: absolute;
      left: 8px;
      right: 8px;
      top: 50%;
      height: 2px;
      transform: translateY(-50%);
      background: var(--surface-tint-border-strong);
