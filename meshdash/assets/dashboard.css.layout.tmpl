    .peer-dm-popout-id-row {{
      display: inline-flex;
      align-items: center;
      gap: 6px;
      min-width: 0;
      flex-wrap: wrap;
    }}
    .peer-dm-popout-channel {{
      display: inline-flex;
      align-items: center;
      border: 1px solid rgba(var(--peer-dm-channel-rgb), 0.45);
