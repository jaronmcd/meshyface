      border: 1px solid rgba(var(--peer-dm-channel-rgb), 0.34);
      border-radius: 8px;
      background: rgba(var(--peer-dm-channel-rgb), 0.08);
      padding: 5px 7px;
      display: flex;
      flex-direction: column;
      gap: 4px;
      min-width: 0;
