{theme_css}
    * {{ box-sizing: border-box; }}
    :root {{
      --topbar-sticky-offset: 72px;
      --workspace-viewport-offset: 84px;
      --topbar-right-inset: max(12px, env(safe-area-inset-right));
      --topbar-corner-reserve: 172px;
    }}
    html, body {{
      margin: 0;
      padding: 0;
      font-family: "IBM Plex Sans", "Segoe UI", sans-serif;
      color: var(--ink);
      background:
        radial-gradient(circle at 20% -10%, #d7ead3 0, transparent 45%),
        radial-gradient(circle at 80% 0%, #d0e6d4 0, transparent 40%),
        var(--bg);
      min-height: 100%;
      min-height: 100vh;
      min-height: 100dvh;
      height: 100%;
      overflow: hidden;
    }}
    body {{
      display: flex;
      flex-direction: column;
      min-height: 100dvh;
    }}
    .topbar {{
      padding: 8px 12px;
      background: linear-gradient(100deg, #173d2d, #2d6f50);
      color: #f4fff7;
      box-shadow: var(--shadow);
      position: sticky;
      top: 0;
      z-index: 1200;
      padding-right: var(--topbar-corner-reserve, 172px);
      flex: 0 0 auto;
    }}
    .topbar-notify-corner {{
      position: absolute;
      top: 8px;
      right: var(--topbar-right-inset);
      z-index: 2;
      display: inline-flex;
      align-items: center;
      justify-content: flex-end;
      flex-direction: row-reverse;
      gap: 6px;
    }}
    .topbar-self-profile {{
      min-width: 30px;
      height: 30px;
      border-radius: 999px;
      border: 1px solid rgba(214, 238, 223, 0.55);
      background: rgba(248, 255, 251, 0.12);
      color: #f1fff6;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 0 8px;
      line-height: 1;
      white-space: nowrap;
      user-select: none;
      transition: border-color 140ms ease, background 140ms ease, color 140ms ease, box-shadow 140ms ease;
    }}
    .topbar-self-profile.status-online {{
      border-color: rgba(121, 230, 172, 0.78);
      background: rgba(53, 154, 101, 0.26);
      color: #ddffeb;
      box-shadow: 0 0 0 1px rgba(77, 190, 130, 0.32);
    }}
    .topbar-self-profile.status-warn {{
      border-color: rgba(234, 203, 129, 0.82);
      background: rgba(174, 134, 57, 0.24);
      color: #fff0cd;
      box-shadow: 0 0 0 1px rgba(213, 172, 96, 0.3);
    }}
    .topbar-self-profile.status-stale {{
      border-color: rgba(255, 162, 162, 0.88);
      background: rgba(182, 38, 38, 0.3);
      color: #fff0f0;
      box-shadow: 0 0 0 1px rgba(208, 83, 83, 0.34);
    }}
    .topbar-self-profile.status-unknown {{
      border-color: rgba(214, 238, 223, 0.5);
      background: rgba(248, 255, 251, 0.1);
      color: #f1fff6;
    }}
    .topbar-self-profile-short {{
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.35px;
      text-transform: none;
      max-width: 5ch;
      overflow: hidden;
      text-overflow: ellipsis;
    }}
    .topbar-chat-change-menu-wrap .chat-change-toggle-btn,
    .topbar-chat-settings-menu-wrap .chat-settings-toggle-btn,
    .topbar-favorite-menu-wrap .favorite-menu-toggle-btn {{
      width: 30px;
      height: 30px;
      border-color: rgba(214, 238, 223, 0.55);
      background: rgba(248, 255, 251, 0.12);
      color: #f1fff6;
    }}
    .topbar-chat-change-menu-wrap .chat-change-toggle-btn:hover,
    .topbar-chat-settings-menu-wrap .chat-settings-toggle-btn:hover,
    .topbar-favorite-menu-wrap .favorite-menu-toggle-btn:hover {{
      border-color: rgba(214, 238, 223, 0.82);
      background: rgba(248, 255, 251, 0.22);
      color: #ffffff;
    }}
    .topbar-chat-change-menu-wrap .chat-change-toggle-btn[aria-expanded="true"],
    .topbar-chat-settings-menu-wrap .chat-settings-toggle-btn[aria-expanded="true"],
    .topbar-favorite-menu-wrap .favorite-menu-toggle-btn[aria-expanded="true"] {{
      border-color: rgba(214, 238, 223, 0.82);
      background: rgba(248, 255, 251, 0.24);
      color: #ffffff;
    }}
    .topbar-chat-change-menu-wrap .chat-change-toggle-btn.has-unread {{
      border-color: #8be0af;
      color: #dbffe9;
      box-shadow: 0 0 0 1px rgba(83, 185, 124, 0.4);
    }}
    .topbar-chat-change-menu-wrap .chat-change-badge {{
      border-color: #173d2d;
    }}
    .topbar-chat-change-menu-wrap .chat-change-menu {{
      top: calc(100% + 10px);
    }}
    .topbar-chat-settings-menu-wrap .chat-settings-menu {{
      top: calc(100% + 10px);
    }}
    .topbar-favorite-menu-wrap .favorite-menu {{
      top: calc(100% + 10px);
    }}
    .topbar-favorite-menu-wrap .favorite-menu-toggle-btn {{
      width: 30px;
      height: 30px;
      padding: 0;
      border-radius: 999px;
    }}
    .topbar h1 {{
      margin: 0;
      font-size: 24px;
      line-height: 1.1;
      letter-spacing: 0.1px;
    }}
    .topbar .topbar-heading {{
      display: flex;
      align-items: center;
      flex-wrap: wrap;
      gap: 4px;
    }}
    .topbar .topbar-heading-app {{
      display: inline-flex;
      align-items: center;
    }}
    .topbar .topbar-chat-context {{
      display: inline-flex;
      align-items: center;
      max-width: min(52vw, 420px);
      padding: 3px 10px;
      border: 1px solid rgba(214, 238, 223, 0.26);
      border-radius: 999px;
      background: rgba(248, 255, 251, 0.08);
      color: rgba(241, 255, 246, 0.94);
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 0.12px;
      line-height: 1.2;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }}
    .topbar .sub {{
      margin-top: 2px;
      font-size: 11px;
      opacity: 0.95;
      display: flex;
      flex-direction: column;
      align-items: stretch;
      gap: 3px;
    }}
    .topbar .sub .sub-main {{
      display: flex;
      align-items: center;
      flex-wrap: wrap;
      gap: 6px;
      min-width: 0;
    }}
    .topbar .sub .summary-ticker-row {{
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(136px, 1fr));
      gap: 4px;
      min-width: 0;
    }}
    .topbar .summary-ticker-item {{
      border: 1px solid rgba(214, 238, 223, 0.45);
      background: rgba(248, 255, 251, 0.1);
      border-radius: 8px;
      padding: 4px 6px;
      min-width: 0;
      color: #f2fff7;
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      grid-template-rows: auto auto;
      column-gap: 6px;
      row-gap: 1px;
      align-items: end;
    }}
    .topbar .summary-ticker-item-target {{
      grid-column: span 2;
      grid-template-rows: auto auto auto;
      row-gap: 2px;
    }}
    .topbar .summary-ticker-item-target .target-radio-status {{
      grid-column: 1 / span 2;
      grid-row: 3;
      font-size: 9px;
      line-height: 1.2;
      letter-spacing: 0.16px;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      border-radius: 999px;
      border: 1px solid rgba(214, 238, 223, 0.35);
      background: rgba(248, 255, 251, 0.08);
      color: rgba(236, 255, 244, 0.9);
      padding: 1px 6px;
      justify-self: start;
      max-width: 100%;
    }}
    .topbar .summary-ticker-item-target .target-radio-status::before {{
      content: "";
      display: inline-block;
      width: 6px;
      height: 6px;
      border-radius: 999px;
      margin-right: 5px;
      vertical-align: middle;
      background: #f2ce7a;
    }}
    .topbar .summary-ticker-item-target .target-radio-status.status-online {{
      border-color: rgba(121, 230, 172, 0.7);
      color: #d5ffea;
      background: rgba(53, 154, 101, 0.22);
    }}
    .topbar .summary-ticker-item-target .target-radio-status.status-online::before {{
      background: #79e6ac;
    }}
    .topbar .summary-ticker-item-target .target-radio-status.status-warn {{
      border-color: rgba(234, 203, 129, 0.76);
      color: #fff0cc;
      background: rgba(174, 134, 57, 0.2);
    }}
    .topbar .summary-ticker-item-target .target-radio-status.status-warn::before {{
      background: #f2ce7a;
    }}
    .topbar .summary-ticker-item-target .target-radio-status.status-stale {{
      border-color: rgba(234, 203, 129, 0.76);
      color: #fff0cc;
      background: rgba(174, 134, 57, 0.2);
    }}
    .topbar .summary-ticker-item-target .target-radio-status.status-stale::before {{
      background: #f2ce7a;
    }}
    .topbar .summary-ticker-item-target .target-radio-status.status-lost {{
      border-color: rgba(255, 162, 162, 0.88);
      color: #fff0f0;
      background: rgba(182, 38, 38, 0.28);
    }}
    .topbar .summary-ticker-item-target .target-radio-status.status-lost::before {{
      background: #ff9e9e;
    }}
    .topbar .summary-ticker-item-target .target-radio-status.status-unknown {{
      border-color: rgba(234, 203, 129, 0.76);
      color: #fff0cc;
      background: rgba(174, 134, 57, 0.2);
    }}
    .topbar .summary-ticker-item-target .target-radio-status.status-unknown::before {{
      background: #f2ce7a;
    }}
    .topbar .summary-ticker-item .label {{
      grid-column: 1 / span 2;
      grid-row: 1;
      font-size: 8px;
      line-height: 1.15;
      text-transform: uppercase;
      letter-spacing: 0.2px;
      color: rgba(236, 255, 244, 0.92);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }}
    .topbar .summary-ticker-item .value {{
      grid-column: 1;
      grid-row: 2;
      margin-top: 0;
      font-size: 13px;
      font-weight: 700;
      line-height: 1;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }}
    .topbar .summary-ticker-item .time-ticker-value {{
      grid-column: 1 / span 2;
      display: flex;
      flex-direction: column;
      gap: 2px;
      line-height: 1.2;
      white-space: normal;
    }}
    .topbar .summary-ticker-item .time-ticker-row {{
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 6px;
      min-width: 0;
    }}
    .topbar .summary-ticker-item .time-ticker-key {{
      font-size: 8px;
      line-height: 1.2;
      letter-spacing: 0.22px;
      color: rgba(223, 248, 233, 0.88);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }}
    .topbar .summary-ticker-item .time-ticker-val {{
      font-size: 12px;
      line-height: 1.15;
      font-weight: 700;
      color: #f2fff7;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }}
    .topbar .summary-ticker-item .metric-ticker {{
      grid-column: 2;
      grid-row: 2;
      margin-top: 0;
      min-height: 0;
      justify-self: end;
      align-self: end;
      display: inline-flex;
      align-items: center;
      gap: 6px;
    }}
    .topbar .summary-ticker-item .metric-ticker-delta {{
      color: rgba(232, 252, 242, 0.9);
      font-size: 9px;
    }}
    .topbar .summary-ticker-item .metric-ticker-rate {{
      display: none;
      color: rgba(219, 242, 229, 0.86);
      font-size: 9px;
      line-height: 1.1;
      white-space: nowrap;
    }}
    .topbar .summary-ticker-item .metric-ticker-chart path {{
      stroke: rgba(196, 228, 208, 0.92);
      fill: none;
      stroke-width: 1.3;
      vector-effect: non-scaling-stroke;
    }}
    .topbar .summary-ticker-item .metric-ticker-chart {{
      width: 56px;
      height: 11px;
    }}
    .topbar .summary-ticker-item .metric-ticker.trend-up .metric-ticker-delta {{
      color: #b9ffd5;
    }}
    .topbar .summary-ticker-item .metric-ticker.trend-up .metric-ticker-chart path {{
      stroke: #79e6ac;
    }}
    .topbar .summary-ticker-item .metric-ticker.trend-down .metric-ticker-delta {{
      color: #ffd2d2;
    }}
    .topbar .summary-ticker-item .metric-ticker.trend-down .metric-ticker-chart path {{
      stroke: #ff9c9c;
    }}
    .topbar .summary-ticker-item .metric-ticker.trend-flat .metric-ticker-delta {{
      color: rgba(228, 249, 238, 0.9);
    }}
    .topbar .summary-ticker-item .metric-ticker.trend-flat .metric-ticker-chart path {{
      stroke: rgba(187, 220, 200, 0.94);
    }}
    .topbar .summary-ticker-item {{
      cursor: pointer;
      transition: border-color 120ms ease, background 120ms ease;
    }}
    .topbar .summary-ticker-item:hover {{
      border-color: rgba(214, 238, 223, 0.72);
      background: rgba(248, 255, 251, 0.18);
    }}
    .topbar.ticker-expanded .sub .summary-ticker-row {{
      grid-template-columns: repeat(auto-fit, minmax(208px, 1fr));
      gap: 7px;
    }}
    .topbar.ticker-expanded .summary-ticker-item {{
      border-radius: 10px;
      padding: 8px 10px;
      grid-template-columns: minmax(0, 1fr);
      grid-template-rows: auto auto auto;
      row-gap: 4px;
      align-items: start;
      background: rgba(248, 255, 251, 0.14);
    }}
    .topbar.ticker-expanded .summary-ticker-item-target {{
      grid-column: span 1;
    }}
    .topbar.ticker-expanded .summary-ticker-item-target .target-radio-status {{
      grid-column: 1;
      grid-row: 3;
      font-size: 11px;
      line-height: 1.25;
      padding: 2px 8px;
    }}
    .topbar.ticker-expanded .summary-ticker-item .label {{
      grid-column: 1;
      grid-row: 1;
      font-size: 10px;
      line-height: 1.2;
      letter-spacing: 0.5px;
      white-space: normal;
    }}
    .topbar.ticker-expanded .summary-ticker-item .value {{
      grid-column: 1;
      grid-row: 2;
      font-size: 20px;
      line-height: 1.1;
    }}
    .topbar.ticker-expanded .summary-ticker-item .time-ticker-value {{
      font-size: 13px;
      gap: 6px;
    }}
    .topbar.ticker-expanded .summary-ticker-item .time-ticker-key {{
      font-size: 10px;
      line-height: 1.2;
      letter-spacing: 0.32px;
    }}
    .topbar.ticker-expanded .summary-ticker-item .time-ticker-val {{
      font-size: 17px;
      line-height: 1.15;
    }}
    .topbar.ticker-expanded .summary-ticker-item .metric-ticker {{
      grid-column: 1;
      grid-row: 3;
      justify-self: stretch;
      display: grid;
      grid-template-columns: auto minmax(90px, 1fr);
      grid-template-rows: auto auto;
      column-gap: 8px;
      row-gap: 2px;
      align-items: center;
      width: 100%;
    }}
    .topbar.ticker-expanded .summary-ticker-item .metric-ticker-delta {{
      grid-column: 1;
      grid-row: 1;
      font-size: 12px;
      font-weight: 700;
    }}
    .topbar.ticker-expanded .summary-ticker-item .metric-ticker-rate {{
      grid-column: 1;
      grid-row: 2;
      display: inline;
      font-size: 10px;
    }}
    .topbar.ticker-expanded .summary-ticker-item .metric-ticker-chart {{
      grid-column: 2;
      grid-row: 1 / span 2;
      width: 100%;
      height: 30px;
    }}
    .topbar.ticker-expanded .summary-ticker-item .metric-ticker-chart path {{
      stroke-width: 1.6;
    }}
    .topbar .sub .sub-text {{
      margin-right: 2px;
    }}
    .theme-btn {{
      border: 1px solid rgba(214, 238, 223, 0.55);
      background: rgba(248, 255, 251, 0.12);
      color: #f2fff7;
      border-radius: 999px;
      padding: 3px 10px;
      font-size: 11px;
      line-height: 1.2;
      cursor: pointer;
      white-space: nowrap;
    }}
    .theme-btn:hover {{
      background: rgba(248, 255, 251, 0.22);
    }}
    .theme-preset-wrap {{
      display: inline-flex;
      align-items: center;
      gap: 5px;
      border: 1px solid rgba(214, 238, 223, 0.55);
      background: rgba(248, 255, 251, 0.12);
      border-radius: 999px;
      padding: 2px 8px;
      font-size: 10px;
      line-height: 1.2;
      color: #f2fff7;
      white-space: nowrap;
    }}
    .theme-preset-label {{
      opacity: 0.92;
    }}
    .theme-preset-select {{
      border: none;
      border-radius: 999px;
      background: rgba(248, 255, 251, 0.16);
      color: #f2fff7;
      font-size: 10px;
      line-height: 1.2;
      padding: 2px 8px 2px 6px;
      min-width: 94px;
      cursor: pointer;
      appearance: none;
      outline: none;
    }}
    .theme-preset-select:disabled {{
      cursor: default;
      opacity: 0.7;
    }}

    .mesh-channel-wrap {{
      position: relative;
      display: inline-flex;
      align-items: center;
      gap: 5px;
      border: 1px solid rgba(214, 238, 223, 0.55);
      background: rgba(248, 255, 251, 0.12);
      border-radius: 999px;
      padding: 2px 8px;
      font-size: 10px;
      line-height: 1.2;
      color: #f2fff7;
      white-space: nowrap;
    }}
    .channel-color-dot {{
      --channel-dot-fill: #8da3b1;
      width: 10px;
      height: 10px;
      border-radius: 50%;
      flex: 0 0 auto;
      display: inline-block;
      background: var(--channel-dot-fill);
      border: 1px solid rgba(19, 36, 26, 0.38);
      box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.22);
    }}
    .channel-color-dot.is-all {{
      background: #ffffff;
    }}
    .mesh-channel-view-dot {{
      margin-left: 1px;
      margin-right: 1px;
    }}
    .mesh-channel-menu-btn {{
      border: none;
      border-radius: 999px;
      background: rgba(248, 255, 251, 0.16);
      color: #f2fff7;
      font-size: 10px;
      line-height: 1.2;
      padding: 2px 8px 2px 6px;
      min-width: 84px;
      cursor: pointer;
      outline: none;
      white-space: nowrap;
    }}
    .mesh-channel-menu-btn:hover {{
      background: rgba(248, 255, 251, 0.24);
    }}
    .mesh-channel-menu-btn[aria-expanded="true"] {{
      background: rgba(248, 255, 251, 0.28);
    }}
    .mesh-channel-select:disabled {{
      cursor: default;
      opacity: 0.7;
    }}
    .mesh-channel-select option {{
      color: #13241a;
      background: #f8fcfa;
    }}
    .mesh-channel-select option:disabled {{
      color: #6a7f73;
    }}
    .mesh-channel-menu {{
      position: absolute;
      top: calc(100% + 6px);
      right: 0;
      min-width: 224px;
      max-width: min(320px, 86vw);
      border: 1px solid #ccddcf;
      border-radius: 10px;
      background: #f4fbf5;
      padding: 6px;
      display: flex;
      flex-direction: column;
      gap: 4px;
      box-shadow: 0 10px 28px rgba(21, 47, 33, 0.24);
      z-index: 45;
    }}
    .mesh-channel-menu[hidden] {{
      display: none !important;
    }}
    .mesh-channel-menu-item {{
      width: 100%;
      border: 1px solid #c9dccf;
      border-radius: 8px;
      background: #edf7ef;
      color: #1d4130;
      padding: 6px 7px;
      display: grid;
      grid-template-columns: auto minmax(0, 1fr);
      align-items: center;
      gap: 8px;
      text-align: left;
      font-size: 10px;
      line-height: 1.2;
      cursor: pointer;
    }}
    .mesh-channel-menu-item:hover {{
      background: #e3f2e7;
      border-color: #b6d0bf;
    }}
    .mesh-channel-menu-item.active {{
      background: #dcefe2;
      border-color: #8fb69e;
      box-shadow: inset 2px 0 0 rgba(21, 70, 46, 0.24);
    }}
    .mesh-channel-menu-item-all {{
      background: #eef4f7;
      border-color: #ccd7df;
    }}
    .mesh-channel-menu-item-all:hover {{
      background: #e3edf2;
      border-color: #b8c8d5;
    }}
    .mesh-channel-menu-item-main {{
      min-width: 0;
      display: flex;
      flex-direction: column;
      gap: 1px;
    }}
    .mesh-channel-menu-item-title,
    .mesh-channel-menu-item-meta {{
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }}
    .mesh-channel-menu-item-title {{
      font-weight: 700;
    }}
    .mesh-channel-menu-item-meta {{
      color: #5d7668;
      font-size: 9px;
    }}
    .workspace-shell {{
      --rail-width: 72px;
      --chat-panel-width: 250px;
      display: grid;
      grid-template-columns: var(--rail-width) minmax(0, 1fr);
      gap: 8px;
      padding: 8px;
      min-height: 0;
      flex: 1 1 auto;
      height: auto;
      background: var(--panel);
      align-items: stretch;
      overflow: hidden;
    }}
    .workspace-shell.chat-panel-open {{
      grid-template-columns: var(--rail-width) minmax(190px, var(--chat-panel-width)) minmax(0, 1fr);
    }}
    .workspace-main {{
      min-width: 0;
      width: 100%;
      min-height: 0;
      height: 100%;
      overflow: hidden;
    }}
    .teams-rail {{
      position: sticky;
      top: var(--topbar-sticky-offset, 72px);
      align-self: stretch;
      height: 100%;
      min-height: 0;
      border: 1px solid #c6d6c0;
      border-radius: 10px;
      background: #eef6ee;
      box-shadow: var(--shadow);
      display: flex;
      flex-direction: column;
      gap: 6px;
      padding: 8px 6px;
      overflow-y: auto;
    }}
    .teams-rail-title {{
      font-size: 9px;
      font-weight: 700;
      letter-spacing: 0.35px;
      color: #355445;
      text-transform: uppercase;
      text-align: center;
      margin-bottom: 2px;
    }}
    .rail-btn {{
      border: 1px solid #c4d8c6;
      background: #f4faf3;
      color: #234735;
