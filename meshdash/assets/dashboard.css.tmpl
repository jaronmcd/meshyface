      grid-template-columns: minmax(380px, var(--split-left-pct)) var(--splitter-size) minmax(320px, 1fr);
      grid-template-rows:
        auto
        minmax(240px, var(--split-top-px))
        var(--splitter-size)
        minmax(180px, var(--split-mid-px))
        var(--splitter-size)
        minmax(260px, 380px)
