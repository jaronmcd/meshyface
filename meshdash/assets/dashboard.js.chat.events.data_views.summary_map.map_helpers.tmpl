            ${{rows.join("")}}
          </div>
          ${{quickActions ? `
            <div class="map-node-info-actions" role="group" aria-label="Node quick actions">
              ${{quickActions}}
            </div>
          ` : ""}}
        </div>
      `;
    }}

    function bindMapNodeInfoOverlays(marker, node, options = null) {{
      if (!(marker && typeof marker.bindPopup === "function")) return;
      const opts = (options && typeof options === "object") ? options : {{}};
      const overlayNodeId = normalizeNodeId(opts.nodeId || (node && node.id) || "");
      const popupHtml = buildMapNodeInfoHtml(node, Object.assign({{}}, opts, {{ includeActions: true }}));
      marker.bindPopup(popupHtml, {{
        closeButton: true,
        autoPan: true,
        closeOnClick: false,
        className: "map-node-popup",
        maxWidth: 340,
      }});
      const popupFadeMs = 180;
      const popupEnterDelayMs = 220;
      const popupLeaveDelayMs = 180;
      let markerHovering = false;
      let popupHovering = false;
      let popupOpenTimer = null;
      let popupCloseTimer = null;
      let popupFadeTimer = null;
      const currentPopupElement = () => {{
        const popup = (typeof marker.getPopup === "function") ? marker.getPopup() : null;
        return popup && typeof popup.getElement === "function"
          ? popup.getElement()
          : null;
      }};
      const clearHoverPopupTimers = () => {{
        if (popupOpenTimer != null) {{
          window.clearTimeout(popupOpenTimer);
          popupOpenTimer = null;
        }}
        if (popupCloseTimer != null) {{
          window.clearTimeout(popupCloseTimer);
          popupCloseTimer = null;
        }}
        if (popupFadeTimer != null) {{
          window.clearTimeout(popupFadeTimer);
          popupFadeTimer = null;
        }}
      }};
      const cancelHoverPopupClose = () => {{
        clearHoverPopupTimers();
        const popupEl = currentPopupElement();
        if (popupEl instanceof HTMLElement) {{
          popupEl.classList.remove("is-closing");
        }}
      }};
      const finishHoverPopupClose = () => {{
        popupFadeTimer = null;
        if (markerHovering || popupHovering) {{
          cancelHoverPopupClose();
          return;
        }}
        if (typeof marker.closePopup === "function") {{
          marker.closePopup();
        }}
      }};
      const startHoverPopupFade = () => {{
        popupCloseTimer = null;
        if (markerHovering || popupHovering) return;
        const popupEl = currentPopupElement();
        if (popupEl instanceof HTMLElement) {{
          popupEl.classList.add("is-closing");
        }}
        popupFadeTimer = window.setTimeout(finishHoverPopupClose, popupFadeMs);
      }};
      const scheduleHoverPopupClose = () => {{
        if (markerHovering || popupHovering) return;
        clearHoverPopupTimers();
        popupCloseTimer = window.setTimeout(startHoverPopupFade, popupLeaveDelayMs);
      }};
      const finishHoverPopupOpen = () => {{
        popupOpenTimer = null;
        if (!markerHovering || hoverPopupSuppressed()) return;
        if (typeof marker.openPopup === "function") {{
          marker.openPopup();
        }}
      }};
      const scheduleHoverPopupOpen = () => {{
        if (hoverPopupSuppressed()) return;
        if (popupOpenTimer != null) {{
          window.clearTimeout(popupOpenTimer);
        }}
        popupOpenTimer = window.setTimeout(finishHoverPopupOpen, popupEnterDelayMs);
      }};
      const popupIsOpen = () => {{
        try {{
          return !!(typeof marker.isPopupOpen === "function" && marker.isPopupOpen());
        }} catch (_err) {{
          return false;
        }}
      }};
      const hoverPopupSuppressed = () => {{
        const selectedId = (typeof selectedNodeId !== "undefined")
          ? normalizeNodeId(selectedNodeId || "")
          : "";
        return !!opts.suppressHoverTooltip || popupIsOpen() || !!(overlayNodeId && selectedId === overlayNodeId);
      }};
      marker.on("popupopen", (ev) => {{
        cancelHoverPopupClose();
        const popup = ev && ev.popup;
        const popupEl = popup && typeof popup.getElement === "function"
          ? popup.getElement()
          : null;
        prepareMapNodePopupElement(popupEl, overlayNodeId, () => {{
          marker.closePopup();
        }}, {{
          onEnter: () => {{
            popupHovering = true;
            cancelHoverPopupClose();
          }},
          onLeave: () => {{
            popupHovering = false;
            scheduleHoverPopupClose();
          }},
        }});
      }});
      marker.on("mouseover", () => {{
        markerHovering = true;
        cancelHoverPopupClose();
        scheduleHoverPopupOpen();
      }});
      marker.on("mouseout", () => {{
        markerHovering = false;
        scheduleHoverPopupClose();
      }});
      marker.on("popupclose", () => {{
        markerHovering = false;
        popupHovering = false;
        clearHoverPopupTimers();
      }});
    }}

    function buildMapEmojiMarkerIcon(nodeId, isSelected, markerKind = "actual", markerConfidence = 0.45, state = latestState) {{
      if (!mapNodeUsesEmojiMarker(nodeId, markerKind, state)) return null;
      const emoji = resolveMapNodeEmoji(nodeId, state);
      if (!emoji) return null;
      const flashStrength = mapNodeActivityFlashStrength(nodeId);
      const traceProgress = mapNodeTraceProgressState(nodeId);
      const traceResultFlash = mapNodeTraceResultFlashState(nodeId);
      const traceResultStrength = traceResultFlash ? clampMapLinkValue(Number(traceResultFlash.strength), 0, 1) : 0;
      const traceResultColor = traceResultFlash && traceResultFlash.ok === true ? "#22c55e" : "#ef4444";
      const traceResultLabel = traceResultFlash && traceResultFlash.ok === true ? "succeeded" : "failed";
      const traceProgressPct = traceProgress ? Math.max(1, Math.min(99, Number(traceProgress.progressPct) || 1)) : 0;
      const traceAngleDeg = `${{(traceResultFlash ? 360 : (traceProgressPct * 3.6)).toFixed(1)}}deg`;
      const markerStyleForRing = resolveMapNodeMarkerStyle(nodeId, isSelected, markerKind, markerConfidence, state);
      const ringColor = traceResultFlash
        ? traceResultColor
        : String(markerStyleForRing && markerStyleForRing.color ? markerStyleForRing.color : "#86a9ff");
      const ringWidthRaw = Number(markerStyleForRing && markerStyleForRing.weight);
      const ringWidth = clampMapLinkValue(Number.isFinite(ringWidthRaw) ? ringWidthRaw : 2, 1, 3.4);
      const markerClasses = [
        "map-node-emoji-marker",
        isSelected ? "is-selected" : "",
        flashStrength > 0.04 ? "is-active" : "",
        traceProgress ? "is-trace-running" : "",
        traceResultFlash ? "is-trace-result" : "",
        traceResultFlash && traceResultFlash.ok === true ? "is-trace-success" : "",
        traceResultFlash && traceResultFlash.ok !== true ? "is-trace-failed" : "",
      ].filter(Boolean).join(" ");
      const traceTitleAttr = traceResultFlash
        ? ` title="${{escAttr(`Traceroute ${{traceResultLabel}}`)}}"`
        : (traceProgress
        ? ` title="${{escAttr(`Traceroute in progress (${{traceProgressPct}}%)`)}}"`
        : "");
      const iconSize = isSelected ? 30 : 24;
      const iconAnchor = Math.round(iconSize / 2);
      const popupAnchorY = isSelected ? -16 : -13;
      return L.divIcon({{
        className: "map-node-emoji-icon",
        html: `
          <div
            class="${{markerClasses}}"
            style="--map-node-flash:${{Number(flashStrength.toFixed(3))}}; --map-node-ring-color:${{escAttr(ringColor)}}; --map-node-ring-width:${{ringWidth.toFixed(1)}}px; --map-node-trace-progress:${{traceProgressPct.toFixed(0)}}; --map-node-trace-angle:${{traceAngleDeg}}; --map-node-trace-result:${{traceResultStrength.toFixed(3)}}; --map-node-trace-color:${{escAttr(traceResultFlash ? traceResultColor : "#7dd3fc")}};"
            ${{traceTitleAttr}}
          >
            <span class="map-node-emoji-glyph" aria-hidden="true">${{escAttr(emoji)}}</span>
          </div>
        `,
        iconSize: [iconSize, iconSize],
        iconAnchor: [iconAnchor, iconAnchor],
        popupAnchor: [0, popupAnchorY],
      }});
    }}

    function createMapNodeMarker(lat, lon, nodeId, isSelected, markerKind = "actual", markerConfidence = 0.45, state = latestState) {{
      if (mapNodeUsesEmojiMarker(nodeId, markerKind, state)) {{
        return L.marker([lat, lon], {{
          icon: buildMapEmojiMarkerIcon(nodeId, isSelected, markerKind, markerConfidence, state),
          keyboard: false,
          bubblingMouseEvents: false,
          riseOnHover: true,
          zIndexOffset: isSelected ? 200 : 120,
        }});
      }}
      return L.circleMarker(
        [lat, lon],
        resolveMapNodeMarkerStyle(nodeId, isSelected, markerKind, markerConfidence, state)
      );
    }}

    function refreshMapNodeMarkerPresentation(marker, nodeId, isSelected, markerKind = "actual", markerConfidence = 0.45, state = latestState) {{
      if (!(marker && typeof marker === "object")) return;
      if (isSelected) {{
        if (typeof marker.closeTooltip === "function") {{
          marker.closeTooltip();
        }}
        if (typeof marker.unbindTooltip === "function") {{
          marker.unbindTooltip();
        }}
      }}
      if (mapNodeUsesEmojiMarker(nodeId, markerKind, state)) {{
        if (typeof marker.setIcon === "function") {{
          marker.setIcon(buildMapEmojiMarkerIcon(nodeId, isSelected, markerKind, markerConfidence, state));
        }}
        if (typeof marker.setZIndexOffset === "function") {{
          marker.setZIndexOffset(isSelected ? 200 : 120);
        }}
        return;
      }}
      if (typeof marker.setStyle === "function") {{
        marker.setStyle(resolveMapNodeMarkerStyle(
          nodeId,
          isSelected,
          markerKind,
          markerConfidence,
          state
        ));
      }}
    }}

    function scheduleMapNodeActivityFlashUpdate() {{
      if (mapTraceProgressTimer != null) {{
        window.clearTimeout(mapTraceProgressTimer);
        mapTraceProgressTimer = null;
      }}
      if (mapNodeActivityFlashRaf != null) return;
      mapNodeActivityFlashRaf = window.requestAnimationFrame(() => {{
        mapNodeActivityFlashRaf = null;
        const activeFlashCount = pruneExpiredMapNodeActivityFlashes();
        const activePulseCount = pruneExpiredMapNodeTransmitPulseRings();
        const activeDirectionCount = pruneExpiredMapNodeActivityDirections();
        const activeTraceCount = pruneExpiredMapTracePaths();
        const activeTraceProgress = isNetworkMapTraceProgressActive();
        const activeTraceResultCount = pruneExpiredMapTraceResultFlashes();
        refreshMapMarkerStyles();
        if (!isNetworkMapActivityFlashVisible()) {{
          clearMapNodeTransmitPulseRings();
          clearMapNodeActivityDirections();
          clearMapTracePaths();
          if (!activeTraceProgress && activeTraceResultCount <= 0) {{
            stopMapNodeActivityFlashLoop();
            return;
          }}
        }}
        if (activeFlashCount > 0 || activePulseCount > 0 || activeDirectionCount > 0 || activeTraceCount > 0 || activeTraceResultCount > 0) {{
          scheduleMapNodeActivityFlashUpdate();
        }} else if (activeTraceProgress) {{
          mapTraceProgressTimer = window.setTimeout(scheduleMapNodeActivityFlashUpdate, 260);
        }}
      }});
    }}

    function syncNetworkMapPacketActivity(state = latestState) {{
      const safeState = (state && typeof state === "object") ? state : {{}};
      const traffic = (safeState.traffic && typeof safeState.traffic === "object")
        ? safeState.traffic
        : {{}};
      const recentPackets = Array.isArray(traffic.recent_packets) ? traffic.recent_packets : [];
      const recentChat = Array.isArray(traffic.recent_chat) ? traffic.recent_chat : [];
      const localNodeId = resolveLocalNodeId(safeState);
      const currentTokens = new Set();
      const nodesToFlash = new Set();
      const nodesToRipple = new Map();
      const directionsToAnimate = [];
      const networkMapVisible = isNetworkMapActivityFlashVisible();
      for (const packetEntry of recentPackets) {{
        if (!isMeshRadioActivityPacket(packetEntry, localNodeId)) continue;
        const token = mapPacketActivityToken(packetEntry);
        currentTokens.add(token);
        if (!networkMapVisible || lastNetworkMapPacketTokens.has(token)) {{
          continue;
        }}
        const endpoints = mapPacketActivityEndpointIds(packetEntry);
        const signalLevel = mapPacketActivitySignalLevel(packetEntry);
        const nodeIds = mapPacketActivityNodeIds(packetEntry);
        for (const nodeId of nodeIds) {{
          nodesToFlash.add(nodeId);
          const prevSignalLevel = nodesToRipple.get(nodeId);
          nodesToRipple.set(
            nodeId,
            Number.isFinite(Number(prevSignalLevel))
              ? Math.max(Number(prevSignalLevel), signalLevel)
              : signalLevel
          );
        }}
        if (
          endpoints.fromId
          && endpoints.toId
          && endpoints.fromId !== endpoints.toId
          && mapPacketActivityShouldAnimateDirection(packetEntry)
        ) {{
          directionsToAnimate.push({{ fromId: endpoints.fromId, toId: endpoints.toId, signalLevel }});
        }}
      }}
      for (const chatEntry of recentChat) {{
        if (!isMapLocalEchoActivityEntry(chatEntry, localNodeId)) continue;
        const token = mapLocalEchoActivityToken(chatEntry, localNodeId);
        currentTokens.add(token);
        if (!networkMapVisible || lastNetworkMapPacketTokens.has(token)) {{
          continue;
        }}
        const endpoints = mapLocalEchoActivityEndpointIds(chatEntry, localNodeId);
        if (!(endpoints.fromId && endpoints.toId && endpoints.fromId !== endpoints.toId)) continue;
        nodesToFlash.add(endpoints.fromId);
        nodesToFlash.add(endpoints.toId);
        nodesToRipple.set(
          endpoints.fromId,
          Math.max(Number(nodesToRipple.get(endpoints.fromId)) || 0, 0.72)
        );
        directionsToAnimate.push({{
          fromId: endpoints.fromId,
          toId: endpoints.toId,
          signalLevel: 0.72,
        }});
      }}
      lastNetworkMapPacketTokens = currentTokens;
      if (!networkMapVisible || (nodesToFlash.size <= 0 && nodesToRipple.size <= 0 && directionsToAnimate.length <= 0)) {{
        if (!networkMapVisible) {{
          lastNetworkMapPacketTokens = currentTokens;
          mapNodeActivityFlashById.clear();
          clearMapNodeTransmitPulseRings();
          clearMapNodeActivityDirections();
          clearMapTracePaths();
          stopMapNodeActivityFlashLoop();
        }}
        return;
      }}
      const nowMs = Date.now();
      for (const nodeId of nodesToFlash) {{
        mapNodeActivityFlashById.set(nodeId, {{
          startedAtMs: nowMs,
          untilMs: nowMs + 1100,
        }});
      }}
      for (const [nodeId, signalLevel] of nodesToRipple.entries()) {{
        startMapNodeTransmitRipple(nodeId, safeState, signalLevel);
      }}
      for (const direction of directionsToAnimate) {{
        startMapPacketDirectionAnimation(direction.fromId, direction.toId, safeState, direction.signalLevel);
      }}
      scheduleMapNodeActivityFlashUpdate();
    }}

    function mapLinkConfidenceLabel(confidence) {{
      const safeConfidence = clampMapLinkValue(confidence, 0, 1);
      if (safeConfidence >= 0.78) return "High";
      if (safeConfidence >= 0.56) return "Medium";
      return "Low";
    }}

    function projectMapLinkPoint(lat, lon, refLat, refLon) {{
      const metersPerDegLat = 111320;
      const metersPerDegLon = Math.max(
        1,
        Math.cos((Number(refLat || 0) * Math.PI) / 180) * metersPerDegLat
      );
      return {{
        x: (Number(lon) - Number(refLon || 0)) * metersPerDegLon,
        y: (Number(lat) - Number(refLat || 0)) * metersPerDegLat,
      }};
    }}

    function unprojectMapLinkPoint(x, y, refLat, refLon) {{
      const metersPerDegLat = 111320;
      const metersPerDegLon = Math.max(
        1,
        Math.cos((Number(refLat || 0) * Math.PI) / 180) * metersPerDegLat
      );
      return {{
        lat: Number(refLat || 0) + (Number(y) / metersPerDegLat),
        lon: Number(refLon || 0) + (Number(x) / metersPerDegLon),
      }};
    }}

    function mapLinkRecencyScore(lastSeenUnix, nowUnix = Math.floor(Date.now() / 1000)) {{
      const ts = Number(lastSeenUnix);
      if (!Number.isFinite(ts) || ts <= 0) return 0.72;
      const ageSeconds = Math.max(0, nowUnix - ts);
      if (ageSeconds <= (20 * 60)) return 1;
      if (ageSeconds >= (48 * 60 * 60)) return 0.14;
      const span = (48 * 60 * 60) - (20 * 60);
      return clampMapLinkValue(1 - ((ageSeconds - (20 * 60)) / span), 0.14, 1);
    }}

    function mapLinkEdgeHopMetric(edge) {{
      const avgHops = Number(edge && edge.avgHops);
      if (Number.isFinite(avgHops)) return avgHops;
      const lastHops = Number(edge && edge.lastHops);
      if (Number.isFinite(lastHops)) return lastHops;
      return 1;
    }}

    function mapLinkEdgeSignalScore(edge) {{
      const metrics = [];
      const avgSnr = Number(edge && edge.avgSnr);
      if (Number.isFinite(avgSnr)) {{
        metrics.push([clampMapLinkValue((avgSnr + 18) / 30, 0, 1), 0.42]);
      }}
      const avgRssi = Number(edge && edge.avgRssi);
      if (Number.isFinite(avgRssi)) {{
        metrics.push([clampMapLinkValue((avgRssi + 126) / 40, 0, 1), 0.28]);
      }}
      const hopsMetric = mapLinkEdgeHopMetric(edge);
      if (Number.isFinite(hopsMetric)) {{
        metrics.push([1 - clampMapLinkValue((Math.max(0, hopsMetric) - 1) / 5, 0, 1), 0.18]);
      }}
      const weight = Number(edge && edge.weight);
      const sessionWeight = Number(edge && edge.sessionWeight);
      const countMetric = Math.log10(Math.max(1, (Number.isFinite(weight) ? weight : 0) + (Number.isFinite(sessionWeight) ? sessionWeight : 0)) + 1);
      metrics.push([clampMapLinkValue(countMetric / 2.5, 0.08, 1), 0.12]);

      let weightedTotal = 0;
      let totalWeight = 0;
      for (const [value, weightValue] of metrics) {{
        weightedTotal += value * weightValue;
        totalWeight += weightValue;
      }}
      const baseScore = totalWeight > 0 ? (weightedTotal / totalWeight) : 0.42;
      const recency = mapLinkRecencyScore(edge && edge.lastSeenUnix);
      return clampMapLinkValue((baseScore * 0.84) + (recency * 0.16), 0.08, 0.98);
    }}

    function mapLinkDesiredDistanceMeters(edge) {{
      const quality = mapLinkEdgeSignalScore(edge);
      const hopMetric = mapLinkEdgeHopMetric(edge);
      const hopPenaltyMeters = Math.max(0, hopMetric - 1) * 2800;
      return Math.round(900 + ((1 - quality) * 17000) + hopPenaltyMeters);
    }}

    function mapLinkEdgeLocationWeight(edge) {{
      const signalScore = mapLinkEdgeSignalScore(edge);
      const hopMetric = mapLinkEdgeHopMetric(edge);
      const hopOverage = Number.isFinite(hopMetric) ? Math.max(0, hopMetric - 1) : 0;
      const hopDamping = hopOverage <= 0
        ? 1
        : clampMapLinkValue(1 / (1 + (hopOverage * 1.45)), 0.14, 1);
      const lifetimeWeight = Number(edge && edge.weight);
      const sessionWeight = Number(edge && edge.sessionWeight);
      const sampleWeight = Math.max(
        1,
        (Number.isFinite(lifetimeWeight) ? lifetimeWeight : 0)
          + (Number.isFinite(sessionWeight) ? sessionWeight : 0)
      );
      const sampleDamping = clampMapLinkValue(Math.log10(sampleWeight + 1) / 2.2, 0.55, 1);
      return clampMapLinkValue(signalScore * hopDamping * sampleDamping, 0.04, 0.98);
    }}

    function mapLinkEstimateResidualForNode(nodeId, positions, adjacency) {{
      const nodePos = positions instanceof Map ? positions.get(nodeId) : null;
      const peers = adjacency instanceof Map ? adjacency.get(nodeId) : null;
      if (!nodePos || !(peers instanceof Map) || !peers.size) {{
        return {{
          fitScore: 0,
          residualKm: null,
          residualRatio: null,
          sampleCount: 0,
        }};
      }}
      let weightedRelativeError = 0;
      let weightedMeters = 0;
      let totalWeight = 0;
      let sampleCount = 0;
      for (const [peerId, edge] of peers.entries()) {{
        const peerPos = positions.get(peerId);
        if (!peerPos) continue;
        const dx = Number(peerPos.x) - Number(nodePos.x);
        const dy = Number(peerPos.y) - Number(nodePos.y);
        const distance = Math.hypot(dx, dy);
        const desired = Math.max(1, Number(mapLinkDesiredDistanceMeters(edge)) || 1);
        if (!Number.isFinite(distance) || !Number.isFinite(desired)) continue;
        const evidenceWeight = mapLinkEdgeLocationWeight(edge);
        if (!(evidenceWeight > 0)) continue;
        const metersError = Math.abs(distance - desired);
        const relativeError = metersError / Math.max(1800, desired);
        weightedRelativeError += Math.min(2.5, relativeError) * evidenceWeight;
        weightedMeters += metersError * evidenceWeight;
        totalWeight += evidenceWeight;
        sampleCount += 1;
      }}
      if (!(totalWeight > 0)) {{
        return {{
          fitScore: 0,
          residualKm: null,
          residualRatio: null,
          sampleCount,
        }};
      }}
      const residualRatio = weightedRelativeError / totalWeight;
      const residualMeters = weightedMeters / totalWeight;
      return {{
        fitScore: clampMapLinkValue(1 - (residualRatio / 1.15), 0, 1),
        residualKm: Math.round((residualMeters / 1000) * 10) / 10,
        residualRatio: Math.round(residualRatio * 1000) / 1000,
        sampleCount,
      }};
    }}

    function mapLinkConfidenceFromFit(baseConfidence, fitScore, anchorCount) {{
      const base = clampMapLinkValue(Number(baseConfidence), 0.06, 0.92);
      const fit = clampMapLinkValue(Number(fitScore), 0, 1);
      const anchors = Math.max(0, Math.trunc(Number(anchorCount) || 0));
      const anchorDamping = anchors >= 3 ? 1 : (anchors >= 2 ? 0.82 : 0.42);
      const fitDamping = 0.28 + (fit * 0.72);
      return clampMapLinkValue(base * anchorDamping * fitDamping, 0.06, 0.88);
    }}

    function mapLinkWeightedPercentile(entries, quantile = 0.5) {{
      const q = clampMapLinkValue(Number(quantile), 0, 1);
      const prepared = [];
      let totalWeight = 0;
      for (const entry of (entries || [])) {{
        const value = Number(entry && entry.value);
        if (!Number.isFinite(value) || value < 0) continue;
        const weight = clampMapLinkValue(Number(entry && entry.weight), 0.0001, 10000);
        prepared.push({{ value, weight }});
        totalWeight += weight;
      }}
      if (!prepared.length || !(totalWeight > 0)) return 0;
      prepared.sort((a, b) => a.value - b.value);
      const target = totalWeight * q;
      let accum = 0;
      for (const entry of prepared) {{
        accum += entry.weight;
        if (accum >= target) {{
          return entry.value;
        }}
      }}
      return prepared[prepared.length - 1].value;
    }}

    function mapEstimatedPositionDistanceMeters(fromPosition, toPosition) {{
      const fromLat = Number(fromPosition && fromPosition.lat);
      const fromLon = Number(fromPosition && fromPosition.lon);
      const toLat = Number(toPosition && toPosition.lat);
      const toLon = Number(toPosition && toPosition.lon);
      if (!isValidMapCoord(fromLat, fromLon) || !isValidMapCoord(toLat, toLon)) return Number.POSITIVE_INFINITY;
      const vec = projectMapLinkPoint(toLat, toLon, fromLat, fromLon);
      return Math.hypot(Number(vec.x) || 0, Number(vec.y) || 0);
    }}

    function pruneMapEstimatedPositionSmoothingCache(activeIds, nowMs = Date.now()) {{
      const keepIds = activeIds instanceof Set ? activeIds : new Set();
      for (const [nodeId, cached] of Array.from(mapEstimatedPositionSmoothingById.entries())) {{
        if (keepIds.has(nodeId)) continue;
        const lastSeenMs = Number(cached && cached.lastSeenMs);
        if (!Number.isFinite(lastSeenMs) || (nowMs - lastSeenMs) > mapEstimatedPositionSmoothingMaxAgeMs) {{
          mapEstimatedPositionSmoothingById.delete(nodeId);
        }}
      }}
    }}

    function smoothMapEstimatedPosition(nodeId, target, options = null) {{
      const opts = (options && typeof options === "object") ? options : {{}};
      const updateCache = opts.updateCache !== false;
      const nowMs = Number.isFinite(Number(opts.nowMs)) ? Number(opts.nowMs) : Date.now();
      const normalizedId = normalizeNodeId(nodeId || "");
      const targetLat = Number(target && target.lat);
      const targetLon = Number(target && target.lon);
      if (!isSelectableNodeId(normalizedId) || !isValidMapCoord(targetLat, targetLon)) return null;
      const confidence = clampMapLinkValue(Number(target && target.confidence), 0.08, 1);
      const supportLinks = Math.max(0, Math.trunc(Number(target && target.supportLinks) || 0));
      const previous = mapEstimatedPositionSmoothingById.get(normalizedId);

      if (!updateCache && previous && typeof previous === "object") {{
        const prevLat = Number(previous.lat);
        const prevLon = Number(previous.lon);
        if (isValidMapCoord(prevLat, prevLon)) {{
          return Object.assign({{}}, target, {{
            lat: prevLat,
            lon: prevLon,
            rawLat: targetLat,
            rawLon: targetLon,
          }});
        }}
      }}

      let nextLat = targetLat;
      let nextLon = targetLon;
      let active = false;
      const previousLat = Number(previous && previous.lat);
      const previousLon = Number(previous && previous.lon);
      const previousSeenMs = Number(previous && previous.lastSeenMs);
      const previousFresh = Number.isFinite(previousSeenMs)
        && (nowMs - previousSeenMs) <= mapEstimatedPositionSmoothingMaxAgeMs;
      if (updateCache && previousFresh && isValidMapCoord(previousLat, previousLon)) {{
        const targetPosition = {{ lat: targetLat, lon: targetLon }};
        const previousPosition = {{ lat: previousLat, lon: previousLon }};
        const distanceMeters = mapEstimatedPositionDistanceMeters(previousPosition, targetPosition);
        if (Number.isFinite(distanceMeters) && distanceMeters > 90) {{
          const alpha = clampMapLinkValue(
            0.075 + (confidence * 0.09) + Math.min(0.045, supportLinks * 0.008),
            0.075,
            0.22
          );
          const maxStepMeters = 1400 + (confidence * 2200) + Math.min(1100, supportLinks * 160);
          const requestedStepMeters = Math.min(distanceMeters, distanceMeters * alpha, maxStepMeters);
          const vec = projectMapLinkPoint(targetLat, targetLon, previousLat, previousLon);
          if (
            Number.isFinite(vec.x)
            && Number.isFinite(vec.y)
            && distanceMeters > 0
            && requestedStepMeters > 0
          ) {{
            const ratio = requestedStepMeters / distanceMeters;
            const projected = unprojectMapLinkPoint(vec.x * ratio, vec.y * ratio, previousLat, previousLon);
            if (isValidMapCoord(Number(projected.lat), Number(projected.lon))) {{
              nextLat = Number(projected.lat);
              nextLon = Number(projected.lon);
            }} else {{
              nextLat = previousLat + ((targetLat - previousLat) * alpha);
              nextLon = previousLon + ((targetLon - previousLon) * alpha);
            }}
          }} else {{
            nextLat = previousLat + ((targetLat - previousLat) * alpha);
            nextLon = previousLon + ((targetLon - previousLon) * alpha);
          }}
          const remainingMeters = mapEstimatedPositionDistanceMeters(
            {{ lat: nextLat, lon: nextLon }},
            targetPosition
          );
          active = Number.isFinite(remainingMeters) && remainingMeters > 120;
        }}
      }}

      const smoothed = Object.assign({{}}, target, {{
        lat: nextLat,
        lon: nextLon,
        rawLat: targetLat,
        rawLon: targetLon,
      }});
      if (updateCache) {{
        mapEstimatedPositionSmoothingById.set(normalizedId, {{
          lat: nextLat,
          lon: nextLon,
          targetLat,
          targetLon,
          confidence,
          supportLinks,
          lastSeenMs: nowMs,
        }});
      }}
      return {{ estimate: smoothed, active }};
    }}

    function smoothMapEstimatedPositions(estimates, options = null) {{
      const opts = (options && typeof options === "object") ? options : {{}};
      const updateCache = opts.updateCache !== false;
      const nowMs = Date.now();
      const rawEstimates = estimates instanceof Map ? estimates : new Map();
      const smoothed = new Map();
      const activeIds = new Set();
      let anyActive = false;
      for (const [rawNodeId, estimate] of rawEstimates.entries()) {{
        const nodeId = normalizeNodeId(rawNodeId);
        const result = smoothMapEstimatedPosition(nodeId, estimate, {{ updateCache, nowMs }});
        const nextEstimate = result && result.estimate ? result.estimate : result;
        if (!(nextEstimate && typeof nextEstimate === "object")) continue;
        smoothed.set(nodeId, nextEstimate);
        activeIds.add(nodeId);
        if (result && result.active) {{
          anyActive = true;
        }}
      }}
      if (updateCache) {{
        pruneMapEstimatedPositionSmoothingCache(activeIds, nowMs);
        mapEstimatedPositionSmoothingActive = anyActive;
      }}
      return smoothed;
    }}

    function smoothMapLinkLineEndpoints(lines, smoothedEstimates) {{
      if (!Array.isArray(lines) || !(smoothedEstimates instanceof Map)) return [];
      return lines.map((line) => {{
        const copy = Object.assign({{}}, line);
        const fromEstimate = smoothedEstimates.get(normalizeNodeId(copy.fromId));
        const toEstimate = smoothedEstimates.get(normalizeNodeId(copy.toId));
        if (fromEstimate && isValidMapCoord(Number(fromEstimate.lat), Number(fromEstimate.lon))) {{
          copy.fromLat = Number(fromEstimate.lat);
          copy.fromLon = Number(fromEstimate.lon);
        }}
        if (toEstimate && isValidMapCoord(Number(toEstimate.lat), Number(toEstimate.lon))) {{
          copy.toLat = Number(toEstimate.lat);
          copy.toLon = Number(toEstimate.lon);
        }}
        return copy;
      }});
    }}

    function smoothMapLinkLayerOverlay(linkOverlay, options = null) {{
      const overlay = (linkOverlay && typeof linkOverlay === "object") ? linkOverlay : {{}};
      const opts = (options && typeof options === "object") ? options : {{}};
      const smoothedEstimates = smoothMapEstimatedPositions(overlay.estimates, {{
        updateCache: opts.updateCache !== false,
      }});
      return Object.assign({{}}, overlay, {{
        estimates: smoothedEstimates,
        lines: smoothMapLinkLineEndpoints(overlay.lines, smoothedEstimates),
      }});
    }}

    function buildMapLinkEstimateDensityOverlay(linkOverlay, options = null) {{
      const overlay = (linkOverlay && typeof linkOverlay === "object") ? linkOverlay : {{}};
      const lines = Array.isArray(overlay.lines) ? overlay.lines : [];
      const estimates = overlay.estimates instanceof Map ? overlay.estimates : new Map();
      const fallback = {{
        enabled: false,
        hideEstimatedMarkers: false,
        heatPoints: [],
        clouds: [],
        cloudLinks: [],
        cloudCount: 0,
        cloudLinkCount: 0,
        historyCloudLinkCount: 0,
        liveCloudLinkCount: 0,
        outlierLineKeys: new Set(),
        summaryLine: null,
        coreLineCount: 0,
        outlierLineCount: 0,
        totalLineCount: lines.length,
        corePointCount: 0,
        outlierPointCount: 0,
      }};
      if (!lines.length || !estimates.size) {{
        return fallback;
      }}

      const estimatePoints = [];
      let refLatWeight = 0;
      let refLonWeight = 0;
      let refWeightTotal = 0;
      for (const [rawNodeId, estimate] of estimates.entries()) {{
        const nodeId = normalizeNodeId(rawNodeId);
        const lat = Number(estimate && estimate.lat);
        const lon = Number(estimate && estimate.lon);
        if (!isSelectableNodeId(nodeId) || !isValidMapCoord(lat, lon)) continue;
        const confidence = clampMapLinkValue(Number(estimate && estimate.confidence), 0.08, 1);
        const supportLinks = Math.max(0, Math.trunc(Number(estimate && estimate.supportLinks) || 0));
        const sampleWeight = clampMapLinkValue(confidence * (1 + (Math.min(8, supportLinks) * 0.12)), 0.08, 2.4);
        estimatePoints.push({{
          nodeId,
          lat,
          lon,
          confidence,
          supportLinks,
          weight: sampleWeight,
          x: 0,
          y: 0,
        }});
        refLatWeight += lat * sampleWeight;
        refLonWeight += lon * sampleWeight;
        refWeightTotal += sampleWeight;
      }}
      if (estimatePoints.length <= 0 || !(refWeightTotal > 0)) {{
        return fallback;
      }}

      const refLat = refLatWeight / refWeightTotal;
      const refLon = refLonWeight / refWeightTotal;
      for (const point of estimatePoints) {{
        const projected = projectMapLinkPoint(point.lat, point.lon, refLat, refLon);
        point.x = Number(projected.x) || 0;
        point.y = Number(projected.y) || 0;
      }}

      const parent = estimatePoints.map((_entry, index) => index);
      const rank = estimatePoints.map(() => 0);
      function findRoot(idx) {{
        let i = idx;
        while (parent[i] !== i) {{
          parent[i] = parent[parent[i]];
          i = parent[i];
        }}
        return i;
      }}
      function unionRoots(a, b) {{
        const ra = findRoot(a);
        const rb = findRoot(b);
        if (ra === rb) return;
        const rankA = rank[ra];
        const rankB = rank[rb];
        if (rankA < rankB) {{
          parent[ra] = rb;
        }} else if (rankA > rankB) {{
          parent[rb] = ra;
        }} else {{
          parent[rb] = ra;
          rank[ra] += 1;
        }}
      }}

      const clusterJoinMeters = 5200;
      const clusterJoinMetersSq = clusterJoinMeters * clusterJoinMeters;
      for (let i = 0; i < estimatePoints.length; i += 1) {{
        for (let j = i + 1; j < estimatePoints.length; j += 1) {{
          const dx = estimatePoints[i].x - estimatePoints[j].x;
          const dy = estimatePoints[i].y - estimatePoints[j].y;
          const distSq = (dx * dx) + (dy * dy);
          if (distSq <= clusterJoinMetersSq) {{
            unionRoots(i, j);
          }}
        }}
      }}

      const membersByRoot = new Map();
      for (let i = 0; i < estimatePoints.length; i += 1) {{
        const root = findRoot(i);
        if (!membersByRoot.has(root)) {{
          membersByRoot.set(root, []);
        }}
        membersByRoot.get(root).push(estimatePoints[i]);
      }}
      if (!membersByRoot.size) {{
        return fallback;
      }}

      const clouds = [];
      const cloudById = new Map();
      const cloudIdByNodeId = new Map();
      for (const members of membersByRoot.values()) {{
        if (!Array.isArray(members) || members.length <= 0) continue;
        const cloudNodeIds = members
          .map((member) => normalizeNodeId(member && member.nodeId))
          .filter((nodeId) => isSelectableNodeId(nodeId));
        if (!cloudNodeIds.length) continue;
        let cloudHash = 2166136261;
        for (const memberNodeId of cloudNodeIds.slice().sort()) {{
          cloudHash = hashMixStr(cloudHash, memberNodeId);
        }}
        const cloudIdBase = `c${{(cloudHash >>> 0).toString(16)}}`;
        let cloudId = cloudIdBase;
        let duplicateIndex = 2;
        while (cloudById.has(cloudId)) {{
          cloudId = `${{cloudIdBase}}-${{duplicateIndex}}`;
          duplicateIndex += 1;
        }}
        let sumX = 0;
        let sumY = 0;
        let totalWeight = 0;
        let confidenceTotal = 0;
        for (const member of members) {{
          sumX += member.x * member.weight;
          sumY += member.y * member.weight;
          totalWeight += member.weight;
          confidenceTotal += member.confidence;
        }}
        if (!(totalWeight > 0)) continue;
        const centerX = sumX / totalWeight;
        const centerY = sumY / totalWeight;
        const centerLL = unprojectMapLinkPoint(centerX, centerY, refLat, refLon);
        if (!isValidMapCoord(centerLL.lat, centerLL.lon)) continue;

        const radiusEntries = [];
        for (const member of members) {{
          const dx = member.x - centerX;
          const dy = member.y - centerY;
          radiusEntries.push({{
            value: Math.hypot(dx, dy),
            weight: member.weight,
          }});
          cloudIdByNodeId.set(member.nodeId, cloudId);
        }}
        const cloudRadiusMeters = Math.max(380, mapLinkWeightedPercentile(radiusEntries, 0.78));
        const cloud = {{
          id: cloudId,
          lat: centerLL.lat,
          lon: centerLL.lon,
          nodeIds: cloudNodeIds,
          nodeCount: members.length,
          avgConfidence: clampMapLinkValue(confidenceTotal / Math.max(1, members.length), 0, 1),
          radiusMeters: cloudRadiusMeters,
        }};
        clouds.push(cloud);
        cloudById.set(cloudId, cloud);
      }}
      if (!clouds.length) {{
        return fallback;
      }}

      const heatPoints = [];
      for (const point of estimatePoints) {{
        const cloudId = cloudIdByNodeId.get(point.nodeId);
        const cloud = cloudId ? cloudById.get(cloudId) : null;
        if (!cloud) continue;
        const distVec = projectMapLinkPoint(point.lat, point.lon, cloud.lat, cloud.lon);
        const distMeters = Math.hypot(Number(distVec.x) || 0, Number(distVec.y) || 0);
        const radiusCap = Math.max(450, Number(cloud.radiusMeters) * 1.9);
        const falloff = 1 - clampMapLinkValue(distMeters / radiusCap, 0, 1);
        const intensity = clampMapLinkValue(
          point.weight * (0.42 + (falloff * 0.62)),
          0.06,
          1
        );
        const heatPoint = [point.lat, point.lon, intensity];
        heatPoint._meshHeatKey = `estimate-node:${{point.nodeId}}`;
        heatPoints.push(heatPoint);
      }}
      for (const cloud of clouds) {{
        const cloudIntensity = clampMapLinkValue(
          0.26 + Math.min(0.6, (cloud.nodeCount * 0.08)),
          0.22,
          0.92
        );
        const heatPoint = [cloud.lat, cloud.lon, cloudIntensity];
        heatPoint._meshHeatKey = `estimate-cloud:${{cloud.id}}`;
        heatPoints.push(heatPoint);
      }}

      const cloudLinkAgg = new Map();
      for (const line of lines) {{
        const mode = String((line && line.mode) || "history").trim().toLowerCase() === "live"
          ? "live"
          : "history";
        const fromId = normalizeNodeId(line && line.fromId);
        const toId = normalizeNodeId(line && line.toId);
        const fromCloudId = cloudIdByNodeId.get(fromId) || "";
        const toCloudId = cloudIdByNodeId.get(toId) || "";
        const fromEstimated = !!fromCloudId;
        const toEstimated = !!toCloudId;
        if (fromEstimated === toEstimated) {{
          continue;
        }}

        const cloudId = fromEstimated ? fromCloudId : toCloudId;
        const knownNodeId = fromEstimated ? toId : fromId;
        const rawKnownLat = fromEstimated ? Number(line && line.toLat) : Number(line && line.fromLat);
        const rawKnownLon = fromEstimated ? Number(line && line.toLon) : Number(line && line.fromLon);
        const knownLat = isValidMapCoord(rawKnownLat, rawKnownLon)
          ? rawKnownLat
          : Number.NaN;
        const knownLon = isValidMapCoord(rawKnownLat, rawKnownLon)
          ? rawKnownLon
          : Number.NaN;
        if (!cloudId || !isSelectableNodeId(knownNodeId)) continue;
        if (!isValidMapCoord(knownLat, knownLon)) continue;

        const qualityScore = clampMapLinkValue(Number(line && line.qualityScore), 0.08, 0.98);
        const sampleWeight = Math.max(
          0.2,
          (Number(line && line.weight) || 0) + ((Number(line && line.sessionWeight) || 0) * 0.45)
        );
        const key = `${{mode}}::${{cloudId}}::${{knownNodeId}}`;
        let agg = cloudLinkAgg.get(key);
        if (!agg) {{
          agg = {{
            mode,
            cloudId,
            knownNodeId,
            latWeighted: 0,
            lonWeighted: 0,
            geoWeight: 0,
            qualityWeighted: 0,
            qualityWeight: 0,
            sampleWeight: 0,
            sampleCount: 0,
            lastSeenUnix: 0,
            hopsWeighted: 0,
            hopsWeight: 0,
            snrWeighted: 0,
            snrWeight: 0,
            rssiWeighted: 0,
            rssiWeight: 0,
          }};
          cloudLinkAgg.set(key, agg);
        }}
        agg.latWeighted += knownLat * sampleWeight;
        agg.lonWeighted += knownLon * sampleWeight;
        agg.geoWeight += sampleWeight;
        agg.qualityWeighted += qualityScore * sampleWeight;
        agg.qualityWeight += sampleWeight;
        agg.sampleWeight += sampleWeight;
        agg.sampleCount += 1;
        agg.lastSeenUnix = Math.max(agg.lastSeenUnix, Number(line && line.lastSeenUnix) || 0);

        const avgHops = Number(line && line.avgHops);
        if (Number.isFinite(avgHops)) {{
          agg.hopsWeighted += avgHops * sampleWeight;
          agg.hopsWeight += sampleWeight;
        }}
        const avgSnr = Number(line && line.avgSnr);
        if (Number.isFinite(avgSnr)) {{
          agg.snrWeighted += avgSnr * sampleWeight;
          agg.snrWeight += sampleWeight;
        }}
        const avgRssi = Number(line && line.avgRssi);
        if (Number.isFinite(avgRssi)) {{
          agg.rssiWeighted += avgRssi * sampleWeight;
          agg.rssiWeight += sampleWeight;
        }}
      }}

      const cloudLinks = [];
      for (const agg of cloudLinkAgg.values()) {{
        const cloud = cloudById.get(agg.cloudId);
        if (!cloud || !(agg.geoWeight > 0)) continue;
        const toLat = agg.latWeighted / agg.geoWeight;
        const toLon = agg.lonWeighted / agg.geoWeight;
        if (!isValidMapCoord(toLat, toLon)) continue;
        const vec = projectMapLinkPoint(toLat, toLon, cloud.lat, cloud.lon);
        const distanceKm = Math.round((Math.hypot(Number(vec.x) || 0, Number(vec.y) || 0) / 1000) * 10) / 10;
        cloudLinks.push({{
          key: `cloud-link::${{agg.mode}}::${{agg.cloudId}}::${{agg.knownNodeId}}`,
          mode: agg.mode,
          fromId: `cloud-${{agg.cloudId}}`,
          toId: agg.knownNodeId,
          fromLat: cloud.lat,
          fromLon: cloud.lon,
          toLat,
          toLon,
          estimatedEndpoints: 1,
          qualityScore: clampMapLinkValue(
            agg.qualityWeight > 0 ? (agg.qualityWeighted / agg.qualityWeight) : 0.45,
            0.08,
            0.98
          ),
          desiredDistanceKm: distanceKm,
          lastSeenUnix: agg.lastSeenUnix,
          isReal: false,
          weight: Math.max(1, Math.round(agg.sampleWeight)),
          sessionWeight: 0,
          avgHops: agg.hopsWeight > 0 ? Math.round((agg.hopsWeighted / agg.hopsWeight) * 100) / 100 : null,
          avgSnr: agg.snrWeight > 0 ? Math.round((agg.snrWeighted / agg.snrWeight) * 100) / 100 : null,
          avgRssi: agg.rssiWeight > 0 ? Math.round((agg.rssiWeighted / agg.rssiWeight) * 100) / 100 : null,
          cloudLink: true,
          cloudId: agg.cloudId,
          cloudNodeIds: Array.isArray(cloud.nodeIds) ? cloud.nodeIds.slice() : [],
          clusterNodeCount: cloud.nodeCount,
          sampleCount: agg.sampleCount,
        }});
      }}
      cloudLinks.sort((a, b) => (
        (Number(b.sampleCount) - Number(a.sampleCount))
        || (Number(b.qualityScore) - Number(a.qualityScore))
      ));

      const historyCloudLinkCount = cloudLinks.filter((entry) => entry.mode === "history").length;
      const liveCloudLinkCount = cloudLinks.filter((entry) => entry.mode === "live").length;
      const result = {{
        enabled: heatPoints.length > 0 && clouds.length > 0,
        hideEstimatedMarkers: clouds.length > 0,
        heatPoints,
        clouds,
        cloudLinks,
        cloudCount: clouds.length,
        cloudLinkCount: cloudLinks.length,
        historyCloudLinkCount,
        liveCloudLinkCount,
        outlierLineKeys: new Set(),
        summaryLine: null,
        coreLineCount: cloudLinks.length,
        outlierLineCount: 0,
        totalLineCount: lines.length,
        corePointCount: heatPoints.length,
        outlierPointCount: 0,
      }};
      return result;
    }}

    function buildMapLinkLayerOverlay(nodes, rawEdges, options = null) {{
      const opts = (options && typeof options === "object") ? options : {{}};
      const edgeMode = (typeof normalizeMapLinkLayerMode === "function")
        ? normalizeMapLinkLayerMode(opts.mode)
        : "both";
      const minEstimateAnchors = Math.max(
        1,
        Math.trunc(Number(opts.minEstimateAnchors) || mapLinkMinEstimateAnchors)
      );
      const minEstimateConfidence = clampMapLinkValue(
        Number.isFinite(Number(opts.minEstimateConfidence))
          ? Number(opts.minEstimateConfidence)
          : mapLinkMinEstimateConfidence,
        0,
        1
      );
      const nodeMap = new Map();
      let anchorLatTotal = 0;
      let anchorLonTotal = 0;
      let anchorCount = 0;

      for (const node of (nodes || [])) {{
        const nodeId = normalizeNodeId(node && node.id);
        if (!isSelectableNodeId(nodeId) || nodeMap.has(nodeId)) continue;
        nodeMap.set(nodeId, node);
        const lat = Number(node && node.lat);
        const lon = Number(node && node.lon);
        if (!isValidMapCoord(lat, lon)) continue;
        anchorLatTotal += lat;
        anchorLonTotal += lon;
        anchorCount += 1;
      }}
      if (!nodeMap.size || anchorCount <= 0) {{
        return {{ estimates: new Map(), lines: [] }};
      }}

      const refLat = anchorLatTotal / anchorCount;
      const refLon = anchorLonTotal / anchorCount;
      const positions = new Map();
      const metaById = new Map();
      for (const [nodeId, node] of nodeMap.entries()) {{
        const lat = Number(node && node.lat);
        const lon = Number(node && node.lon);
        if (!isValidMapCoord(lat, lon)) continue;
        const point = projectMapLinkPoint(lat, lon, refLat, refLon);
        positions.set(nodeId, {{
          x: point.x,
          y: point.y,
          fixed: true,
        }});
        metaById.set(nodeId, {{
          anchorIds: new Set([nodeId]),
          supportLinks: 0,
          confidence: 1,
          seedX: point.x,
          seedY: point.y,
        }});
      }}

      const safeRawEdges = Array.isArray(rawEdges) ? rawEdges : [];
      const liveRawEdges = (typeof filterNetworkGraphRawEdgesByMode === "function")
        ? filterNetworkGraphRawEdgesByMode(safeRawEdges, "live")
        : safeRawEdges.filter((edge) => {{
            const sessionCount = Number(edge && (edge.session_count ?? edge.count ?? 0));
            return Number.isFinite(sessionCount) && sessionCount > 0;
          }});
      const seedRawEdges = edgeMode === "live" ? liveRawEdges : safeRawEdges;
      const combinedEdges = (typeof combineNetworkGraphEdges === "function")
        ? combineNetworkGraphEdges(seedRawEdges, nodeMap, {{ mode: edgeMode === "live" ? "live" : "history" }})
        : [];
      if (!combinedEdges.length) {{
        return {{ estimates: new Map(), lines: [] }};
      }}
      const adjacency = (typeof buildNetworkGraphAdjacency === "function")
        ? buildNetworkGraphAdjacency(nodeMap, combinedEdges)
        : new Map();
      const unresolvedIds = Array.from(nodeMap.keys()).filter((nodeId) => !positions.has(nodeId));
      const maxSeedPasses = Math.max(2, unresolvedIds.length + 1);

      for (let pass = 0; pass < maxSeedPasses; pass += 1) {{
        let progressed = false;
        for (const nodeId of unresolvedIds) {{
          if (positions.has(nodeId)) continue;
          const peers = adjacency.get(nodeId) || new Map();
          let totalWeight = 0;
          let sumX = 0;
          let sumY = 0;
          let supportLinks = 0;
          const anchorIds = new Set();

          for (const [peerId, edge] of peers.entries()) {{
            const peerPos = positions.get(peerId);
            const peerMeta = metaById.get(peerId) || null;
            if (!peerPos || !peerMeta) continue;
            let weight = mapLinkEdgeLocationWeight(edge);
            if (!peerPos.fixed) {{
              weight *= 0.58 * clampMapLinkValue(peerMeta.confidence, 0.12, 1);
            }}
            if (!(weight > 0)) continue;
            totalWeight += weight;
            sumX += peerPos.x * weight;
            sumY += peerPos.y * weight;
            supportLinks += 1;
            for (const anchorId of (peerMeta.anchorIds || [])) {{
              anchorIds.add(anchorId);
            }}
          }}

          if (!(totalWeight > 0) || !anchorIds.size) continue;
          const seedX = sumX / totalWeight;
          const seedY = sumY / totalWeight;
          const avgWeight = totalWeight / Math.max(1, supportLinks);
          positions.set(nodeId, {{ x: seedX, y: seedY, fixed: false }});
          metaById.set(nodeId, {{
            anchorIds,
            supportLinks,
            confidence: clampMapLinkValue(
              0.16
                + (avgWeight * 0.42)
                + Math.min(0.24, anchorIds.size * 0.08)
                + Math.min(0.12, supportLinks * 0.035),
              0.12,
              0.92
            ),
            seedX,
            seedY,
          }});
          progressed = true;
        }}
        if (!progressed) break;
      }}

      const movableIds = Array.from(positions.entries())
        .filter((entry) => entry[1] && !entry[1].fixed)
        .map((entry) => entry[0]);
      const positionedIds = Array.from(positions.keys());
      const repelRadius = 14000;
      const repelRadiusSq = repelRadius * repelRadius;

      for (let iter = 0; iter < 56 && movableIds.length > 0; iter += 1) {{
        const deltas = new Map(movableIds.map((nodeId) => [nodeId, {{ x: 0, y: 0 }}]));

        for (const edge of combinedEdges) {{
          const fromPos = positions.get(edge.a);
          const toPos = positions.get(edge.b);
          if (!fromPos || !toPos) continue;
          const dx = toPos.x - fromPos.x;
          const dy = toPos.y - fromPos.y;
          const distance = Math.hypot(dx, dy) || 1;
          const desired = mapLinkDesiredDistanceMeters(edge);
          const locationWeight = mapLinkEdgeLocationWeight(edge);
          if (!(locationWeight > 0)) continue;
          const stiffness = 0.018 + (locationWeight * 0.05);
          const delta = (distance - desired) * stiffness;
          const unitX = dx / distance;
          const unitY = dy / distance;
          if (!fromPos.fixed && deltas.has(edge.a)) {{
            const next = deltas.get(edge.a);
            next.x += unitX * delta;
            next.y += unitY * delta;
          }}
          if (!toPos.fixed && deltas.has(edge.b)) {{
            const next = deltas.get(edge.b);
            next.x -= unitX * delta;
            next.y -= unitY * delta;
          }}
        }}

        for (const nodeId of movableIds) {{
          const delta = deltas.get(nodeId);
          const nodePos = positions.get(nodeId);
          if (!delta || !nodePos) continue;
          for (const otherId of positionedIds) {{
            if (otherId === nodeId) continue;
            const otherPos = positions.get(otherId);
            if (!otherPos) continue;
            const dx = nodePos.x - otherPos.x;
            const dy = nodePos.y - otherPos.y;
            const distSq = (dx * dx) + (dy * dy);
            if (!(distSq > 1) || distSq > repelRadiusSq) continue;
            const distance = Math.sqrt(distSq);
            const push = ((repelRadius - distance) / repelRadius) * (otherPos.fixed ? 220 : 120);
            delta.x += (dx / distance) * push;
            delta.y += (dy / distance) * push;
          }}

          const meta = metaById.get(nodeId) || null;
          if (meta) {{
            delta.x += (meta.seedX - nodePos.x) * 0.06;
            delta.y += (meta.seedY - nodePos.y) * 0.06;
          }}
        }}

        const maxStep = Math.max(260, 1750 - (iter * 18));
        for (const nodeId of movableIds) {{
          const delta = deltas.get(nodeId);
          const nodePos = positions.get(nodeId);
          if (!delta || !nodePos) continue;
          nodePos.x += clampMapLinkValue(delta.x, -maxStep, maxStep);
          nodePos.y += clampMapLinkValue(delta.y, -maxStep, maxStep);
        }}
      }}

      const estimates = new Map();
      for (const nodeId of movableIds) {{
        const nodePos = positions.get(nodeId);
        const meta = metaById.get(nodeId) || null;
        if (!nodePos || !meta) continue;
        const ll = unprojectMapLinkPoint(nodePos.x, nodePos.y, refLat, refLon);
        if (!isValidMapCoord(ll.lat, ll.lon)) continue;
        const estimateAnchorCount = meta.anchorIds.size;
        if (estimateAnchorCount < minEstimateAnchors) continue;
        const residual = mapLinkEstimateResidualForNode(nodeId, positions, adjacency);
        const fitScore = clampMapLinkValue(Number(residual && residual.fitScore), 0, 1);
        const adjustedConfidence = mapLinkConfidenceFromFit(
          meta.confidence,
          fitScore,
          estimateAnchorCount
        );
        if (adjustedConfidence < minEstimateConfidence) continue;

        let qualitySum = 0;
        let qualityCount = 0;
        let positionQualitySum = 0;
        let positionQualityCount = 0;
        let snrWeight = 0;
        let snrSum = 0;
        let rssiWeight = 0;
        let rssiSum = 0;
        let hopsWeight = 0;
        let hopsSum = 0;
        const peers = adjacency.get(nodeId) || new Map();
        for (const edge of peers.values()) {{
          const quality = mapLinkEdgeSignalScore(edge);
          const locationQuality = mapLinkEdgeLocationWeight(edge);
          qualitySum += quality;
          qualityCount += 1;
          positionQualitySum += locationQuality;
          positionQualityCount += 1;
          if (Number.isFinite(Number(edge && edge.avgSnr))) {{
            snrSum += Number(edge.avgSnr) * quality;
            snrWeight += quality;
          }}
          if (Number.isFinite(Number(edge && edge.avgRssi))) {{
            rssiSum += Number(edge.avgRssi) * quality;
            rssiWeight += quality;
          }}
          if (Number.isFinite(Number(edge && edge.avgHops))) {{
            hopsSum += Number(edge.avgHops) * quality;
            hopsWeight += quality;
          }}
        }}

        estimates.set(nodeId, {{
          lat: ll.lat,
          lon: ll.lon,
          confidence: adjustedConfidence,
          rawConfidence: meta.confidence,
          anchorCount: estimateAnchorCount,
          supportLinks: meta.supportLinks,
          avgLinkQuality: qualityCount > 0 ? (qualitySum / qualityCount) : 0,
          avgPositionQuality: positionQualityCount > 0 ? (positionQualitySum / positionQualityCount) : 0,
          fitScore,
          residualKm: residual && residual.residualKm != null ? residual.residualKm : null,
          residualRatio: residual && residual.residualRatio != null ? residual.residualRatio : null,
          avgSnr: snrWeight > 0 ? Math.round((snrSum / snrWeight) * 100) / 100 : null,
          avgRssi: rssiWeight > 0 ? Math.round((rssiSum / rssiWeight) * 100) / 100 : null,
          avgHops: hopsWeight > 0 ? Math.round((hopsSum / hopsWeight) * 100) / 100 : null,
        }});
      }}

      const historyCombinedEdges = (typeof combineNetworkGraphEdges === "function")
        ? combineNetworkGraphEdges(safeRawEdges, nodeMap, {{ mode: "history" }})
        : combinedEdges;
      const liveCombinedEdges = (typeof combineNetworkGraphEdges === "function")
        ? combineNetworkGraphEdges(liveRawEdges, nodeMap, {{ mode: "live" }})
        : [];
      const lineGroups = [];
      if (edgeMode === "history" || edgeMode === "both") {{
        lineGroups.push(["history", historyCombinedEdges]);
      }}
      if (edgeMode === "live" || edgeMode === "both") {{
        lineGroups.push(["live", liveCombinedEdges]);
      }}

      const lines = [];
      for (const [lineMode, edgeList] of lineGroups) {{
        for (const edge of edgeList) {{
        const fromPos = positions.get(edge.a);
        const toPos = positions.get(edge.b);
        if (!fromPos || !toPos) continue;
        const estimatedEndpoints = (fromPos.fixed ? 0 : 1) + (toPos.fixed ? 0 : 1);
        if (estimatedEndpoints <= 0) continue;

        const fromNode = nodeMap.get(edge.a) || null;
        const toNode = nodeMap.get(edge.b) || null;
        const fromLat = fromPos.fixed ? Number(fromNode && fromNode.lat) : Number((estimates.get(edge.a) || {{}}).lat);
        const fromLon = fromPos.fixed ? Number(fromNode && fromNode.lon) : Number((estimates.get(edge.a) || {{}}).lon);
        const toLat = toPos.fixed ? Number(toNode && toNode.lat) : Number((estimates.get(edge.b) || {{}}).lat);
        const toLon = toPos.fixed ? Number(toNode && toNode.lon) : Number((estimates.get(edge.b) || {{}}).lon);
        if (!isValidMapCoord(fromLat, fromLon) || !isValidMapCoord(toLat, toLon)) continue;

        lines.push({{
          key: `${{lineMode}}::${{edge.a}}::${{edge.b}}`,
          mode: lineMode,
          fromId: edge.a,
          toId: edge.b,
          fromLat,
          fromLon,
          toLat,
          toLon,
          estimatedEndpoints,
          qualityScore: mapLinkEdgeSignalScore(edge),
          desiredDistanceKm: Math.round((mapLinkDesiredDistanceMeters(edge) / 1000) * 10) / 10,
          lastSeenUnix: Number(edge && edge.lastSeenUnix) || 0,
          isReal: !!edge.isReal,
          weight: Number(edge && edge.weight) || 0,
          sessionWeight: Number(edge && edge.sessionWeight) || 0,
          avgHops: Number.isFinite(Number(edge && edge.avgHops)) ? Number(edge.avgHops) : null,
          avgSnr: Number.isFinite(Number(edge && edge.avgSnr)) ? Number(edge.avgSnr) : null,
          avgRssi: Number.isFinite(Number(edge && edge.avgRssi)) ? Number(edge.avgRssi) : null,
        }});
      }}
      }}

      // Keep estimated positions only for nodes that participate in at least one
      // rendered estimated-link segment. If no line touches a node, don't place it.
      const estimatedNodeIdsWithLines = new Set();
      for (const line of lines) {{
        const fromId = normalizeNodeId(line && line.fromId);
        const toId = normalizeNodeId(line && line.toId);
        if (estimates.has(fromId)) {{
          estimatedNodeIdsWithLines.add(fromId);
        }}
        if (estimates.has(toId)) {{
          estimatedNodeIdsWithLines.add(toId);
        }}
      }}
      const filteredEstimates = new Map();
      for (const [nodeId, estimate] of estimates.entries()) {{
        if (!estimatedNodeIdsWithLines.has(nodeId)) continue;
        filteredEstimates.set(nodeId, estimate);
      }}

      return {{ estimates: filteredEstimates, lines }};
    }}

    function getNetworkMapFullscreenTarget() {{
      const root = document.getElementById("network-map-subviews");
      if (root instanceof HTMLElement) return root;
      return mapFrameElement instanceof HTMLElement ? mapFrameElement : null;
    }}

    function getActiveFullscreenElement() {{
      return document.fullscreenElement || document.webkitFullscreenElement || null;
    }}

    function isNetworkMapFullscreenActive(target = getNetworkMapFullscreenTarget()) {{
      const fullscreenElement = getActiveFullscreenElement();
      return !!(target instanceof HTMLElement && fullscreenElement === target);
    }}

    function networkMapFullscreenSupported(target = getNetworkMapFullscreenTarget()) {{
      if (!(target instanceof HTMLElement)) return false;
      const canRequest = (
        typeof target.requestFullscreen === "function"
        || typeof target.webkitRequestFullscreen === "function"
      );
      const documentAllowsFullscreen = (
        document.fullscreenEnabled !== false
        && document.webkitFullscreenEnabled !== false
      );
      return canRequest && documentAllowsFullscreen;
    }}

    function updateMapFullscreenControl(viewName = activeLayoutView, subviewName = activeNetworkSubview) {{
      const btn = document.getElementById("map-fullscreen-toggle-btn");
      if (!(btn instanceof HTMLButtonElement)) return;
      const target = getNetworkMapFullscreenTarget();
      const supported = networkMapFullscreenSupported(target);
      const active = isNetworkMapFullscreenActive(target);
      const normalizedView = (typeof normalizeLayoutView === "function")
        ? normalizeLayoutView(viewName)
        : String(viewName || "").trim().toLowerCase();
      const showControl = supported && (active || normalizedView === "network");
      btn.hidden = !showControl;
      btn.disabled = !supported;
      btn.classList.toggle("is-active", active);
      btn.setAttribute("aria-pressed", active ? "true" : "false");
      const label = active ? "Exit full screen network view" : "Enter full screen network view";
      btn.setAttribute("aria-label", label);
      btn.title = label;
      if (target instanceof HTMLElement) {{
        target.classList.toggle("is-fullscreen", active);
      }}
    }}

    function requestNetworkMapFullscreenResize() {{
      if (typeof requestMapResizeStabilized === "function") {{
        requestMapResizeStabilized();
      }} else if (typeof requestMapResize === "function") {{
        requestMapResize();
      }}
    }}

    async function toggleNetworkMapFullscreen() {{
      const target = getNetworkMapFullscreenTarget();
      if (!(target instanceof HTMLElement) || !networkMapFullscreenSupported(target)) return;
      try {{
        if (isNetworkMapFullscreenActive(target)) {{
          if (typeof document.exitFullscreen === "function") {{
            await document.exitFullscreen();
          }} else if (typeof document.webkitExitFullscreen === "function") {{
            await document.webkitExitFullscreen();
          }}
        }} else if (typeof target.requestFullscreen === "function") {{
          await target.requestFullscreen();
        }} else if (typeof target.webkitRequestFullscreen === "function") {{
          await target.webkitRequestFullscreen();
        }}
      }} catch (reason) {{
        console.warn("Unable to toggle network fullscreen", reason);
      }} finally {{
        updateMapFullscreenControl();
        requestNetworkMapFullscreenResize();
      }}
    }}

    function bindMapFullscreenControl() {{
      const btn = document.getElementById("map-fullscreen-toggle-btn");
      if (!(btn instanceof HTMLButtonElement)) return;
      if (btn.dataset.bound !== "1") {{
        btn.dataset.bound = "1";
        btn.addEventListener("click", (ev) => {{
          ev.preventDefault();
          void toggleNetworkMapFullscreen();
        }});
      }}
      if (document.documentElement && document.documentElement.dataset.mapFullscreenBound !== "1") {{
        document.documentElement.dataset.mapFullscreenBound = "1";
        document.addEventListener("fullscreenchange", () => {{
          updateMapFullscreenControl();
          requestNetworkMapFullscreenResize();
        }});
        document.addEventListener("webkitfullscreenchange", () => {{
          updateMapFullscreenControl();
          requestNetworkMapFullscreenResize();
        }});
      }}
      updateMapFullscreenControl();
    }}

    function bindMapResetControl() {{
      const btn = document.getElementById("map-reset-view-btn");
      if (!(btn instanceof HTMLButtonElement) || btn.dataset.bound === "1") return;
      btn.dataset.bound = "1";
      btn.addEventListener("click", () => {{
        resetMapViewToMostNodes();
      }});
    }}

    function activeMapNodeVisibilityFilterRuleCount(state = latestRawState || latestState) {{
      const safeState = (state && typeof state === "object") ? state : (latestRawState || latestState || {{}});
      const whitelistActive = (
        typeof nodeVisibilityWhitelistFilterActive === "function"
          ? nodeVisibilityWhitelistFilterActive(safeState)
          : false
      );
      const whitelistCount = (
        whitelistActive
        && typeof nodeVisibilityWhitelistIds !== "undefined"
        && nodeVisibilityWhitelistIds instanceof Set
      )
        ? nodeVisibilityWhitelistIds.size
        : 0;
      const blacklistCount = (
        typeof nodeVisibilityBlacklistIds !== "undefined"
        && nodeVisibilityBlacklistIds instanceof Set
      )
        ? nodeVisibilityBlacklistIds.size
        : 0;
      return Math.max(0, whitelistCount + blacklistCount);
    }}

    function refreshMapNodeFilterControl(state = latestRawState || latestState) {{
      const btn = document.getElementById("map-node-filter-btn");
      if (!(btn instanceof HTMLButtonElement)) return;
      const badge = document.getElementById("map-node-filter-badge");
      const activeRules = activeMapNodeVisibilityFilterRuleCount(state);
      const active = activeRules > 0;
      btn.classList.toggle("has-active-filters", active);
      btn.setAttribute("aria-pressed", active ? "true" : "false");
      btn.title = active
        ? `Node filters active (${{activeRules}} rule${{activeRules === 1 ? "" : "s"}}). Open settings to edit.`
        : "Open node visibility filters";
      if (badge instanceof HTMLElement) {{
        badge.hidden = !active;
        badge.textContent = activeRules > 99 ? "99+" : String(activeRules);
      }}
    }}

    function openMapNodeFilterSettings() {{
      applyLayoutView("settings", true);
      if (typeof setActiveSettingsTab === "function") {{
        setActiveSettingsTab("nodes", true);
      }}
      if (typeof renderNodeVisibilityListsUi === "function") {{
        renderNodeVisibilityListsUi(latestRawState || latestState || {{}});
      }}
    }}

    function bindMapNodeFilterControl() {{
      const btn = document.getElementById("map-node-filter-btn");
      if (!(btn instanceof HTMLButtonElement)) return;
      if (btn.dataset.bound !== "1") {{
        btn.dataset.bound = "1";
        btn.addEventListener("click", () => {{
          openMapNodeFilterSettings();
        }});
      }}
      refreshMapNodeFilterControl(latestRawState || latestState || {{}});
    }}

    function resolveMapPositionBadge(node, caps = null, nowUnix = Math.floor(Date.now() / 1000)) {{
      const lat = Number(node && node.lat);
      const lon = Number(node && node.lon);
      if (!isValidMapCoord(lat, lon)) {{
        return {{
          label: "No Position",
          className: "unknown",
          title: "No usable position is available for this node.",
        }};
      }}

      const heardRaw = Number(node && node.last_heard_unix);
      const heardUnix = Number.isFinite(heardRaw) && heardRaw > 0
        ? Math.trunc(heardRaw)
        : null;
      const capsPosRaw = Number(caps && caps.last_position_unix);
      const capsPosUnix = Number.isFinite(capsPosRaw) && capsPosRaw > 0
        ? Math.trunc(capsPosRaw)
        : null;

      const heardAgeSeconds = Number.isFinite(heardUnix)
        ? Math.max(0, nowUnix - heardUnix)
        : null;
      const recentlyHeard = Number.isFinite(heardAgeSeconds) && heardAgeSeconds <= chatWarnWindowSeconds;
      const positionNearLastHeard = Number.isFinite(heardUnix)
        && Number.isFinite(capsPosUnix)
        && Math.abs(heardUnix - capsPosUnix) <= 120;
      const positionRecentlyUpdated = Number.isFinite(capsPosUnix)
        && (nowUnix - capsPosUnix) <= chatWarnWindowSeconds;

      if (positionNearLastHeard || (recentlyHeard && (positionRecentlyUpdated || !Number.isFinite(capsPosUnix)))) {{
        return {{
          label: "Live GPS",
          className: "live",
          title: "Position appears to be from a recent live GPS update.",
        }};
      }}

      return {{
        label: "History/Fixed",
        className: "history",
        title: "Position appears to be fixed or from an older saved location.",
      }};
    }}
