      const decoded = (packet && packet.decoded && typeof packet.decoded === "object")
        ? packet.decoded
        : {{}};
      const snr = Number(
        summary.rx_snr
        ?? summary.rxSnr
        ?? packet.rx_snr
        ?? packet.rxSnr
        ?? decoded.rx_snr
        ?? decoded.rxSnr
      );
      const rssi = Number(
        summary.rx_rssi
        ?? summary.rxRssi
        ?? packet.rx_rssi
        ?? packet.rxRssi
        ?? decoded.rx_rssi
        ?? decoded.rxRssi
      );
      const values = [];
      if (Number.isFinite(snr)) {{
        values.push({{ value: clampMapLinkValue((snr + 15) / 27, 0, 1), weight: 0.68 }});
      }}
      if (Number.isFinite(rssi)) {{
        values.push({{ value: clampMapLinkValue((rssi + 125) / 55, 0, 1), weight: 0.32 }});
      }}
      if (!values.length) return 0.55;
      let total = 0;
      let weight = 0;
      for (const item of values) {{
