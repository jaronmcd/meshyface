      const flash = mapTraceResultFlashById.get(normalizedId);
      if (!(flash && typeof flash === "object")) return null;
      const untilMs = Number(flash.untilMs);
      if (!Number.isFinite(untilMs) || untilMs <= nowMs) {{
        mapTraceResultFlashById.delete(normalizedId);
        return null;
      }}
      const startedAtMs = Number.isFinite(Number(flash.startedAtMs))
        ? Number(flash.startedAtMs)
        : (untilMs - 1800);
      const durationMs = Math.max(1, untilMs - startedAtMs);
      const elapsedMs = Math.max(0, Number(nowMs) - startedAtMs);
      const envelope = clampMapLinkValue((untilMs - Number(nowMs)) / durationMs, 0, 1);
      const pulsePhase = (elapsedMs % 360) / 360;
      const pulse = 0.45 + (0.55 * (0.5 + (0.5 * Math.cos(pulsePhase * Math.PI * 2))));
      return {{
        ok: flash.ok === true,
        strength: clampMapLinkValue(envelope * pulse, 0, 1),
      }};
    }}

