    function mapTracePathNodeIds(startNodeId, hops, options = null) {{
      const opts = (options && typeof options === "object") ? options : {{}};
      const localAliasNodeId = normalizeNodeId(opts.localAliasNodeId || "");
      const fallbackEndNodeId = normalizeNodeId(opts.fallbackEndNodeId || "");
      const path = [];
      const appendNode = (rawNodeId) => {{
        let clean = normalizeNodeId(rawNodeId || "");
        if (
          (!clean || clean === "local" || clean === "!local")
          && isSelectableNodeId(localAliasNodeId)
        ) {{
          clean = localAliasNodeId;
        }}
        if (!isSelectableNodeId(clean)) return false;
        if (!path.length || path[path.length - 1] !== clean) {{
          path.push(clean);
        }}
        return true;
      }};
      appendNode(startNodeId);
      for (const hop of (Array.isArray(hops) ? hops : [])) {{
        const hopNodeId = (hop && typeof hop === "object") ? hop.node : hop;
        appendNode(hopNodeId);
      }}
      if (
        isSelectableNodeId(fallbackEndNodeId)
        && fallbackEndNodeId !== (path[path.length - 1] || "")
      ) {{
        appendNode(fallbackEndNodeId);
      }}
      return path;
    }}

    function mapTracePathSegmentsForNodeIds(nodeIds, state = latestState) {{
      const segments = [];
      let currentSegment = [];
      for (const rawNodeId of (Array.isArray(nodeIds) ? nodeIds : [])) {{
        const nodeId = normalizeNodeId(rawNodeId || "");
        if (!isSelectableNodeId(nodeId)) continue;
        const position = mapNodeActivityPosition(nodeId, state);
        const lat = Number(position && position.lat);
        const lon = Number(position && position.lon);
        if (!isValidMapCoord(lat, lon)) {{
          if (currentSegment.length >= 2) {{
            segments.push(currentSegment);
          }}
          currentSegment = [];
          continue;
        }}
        currentSegment.push([lat, lon]);
      }}
      if (currentSegment.length >= 2) {{
        segments.push(currentSegment);
      }}
      return segments;
    }}

    function startMapTracePathAnimation(nodeIds, state = latestState, options = null) {{
      if (!isNetworkMapActivityFlashVisible()) return false;
      if (!ensureMapTransmitPulsePane()) return false;
      const safeState = (state && typeof state === "object") ? state : latestState;
      const opts = (options && typeof options === "object") ? options : {{}};
      const segments = mapTracePathSegmentsForNodeIds(nodeIds, safeState);
      if (!segments.length) return false;
      const kind = String(opts.kind || "towards").trim().toLowerCase();
      const color = String(
        opts.color
        || (kind === "return" ? "#38bdf8" : "#f59e0b")
      );
      const layers = [];
      const weight = Math.max(1.2, Number(opts.weight) || (kind === "return" ? 3.1 : 3.6));
      const dashArray = kind === "return" ? "4 7" : "9 6";
      for (const segment of segments) {{
        const path = mapActivityNormalizePathPoints(segment);
        if (path.length < 2) continue;
        const layer = L.polyline(path, {{
          pane: mapTransmitPulsePaneName,
          color,
          opacity: 0,
          weight,
          dashArray,
          lineCap: "round",
          lineJoin: "round",
          interactive: false,
          bubblingMouseEvents: false,
        }});
        layer.addTo(map);
        layers.push(layer);
      }}
      if (!layers.length) return false;
      const nowMs = Date.now();
      mapTracePathRecords.add({{
        layers,
        kind,
        color,
        startedAtMs: nowMs,
        durationMs: Math.max(1200, Number(opts.durationMs) || 6200),
        baseOpacity: clampMapLinkValue(Number(opts.opacity) || (kind === "return" ? 0.7 : 0.78), 0.08, 0.9),
        baseWeight: weight,
      }});
      while (mapTracePathRecords.size > mapTracePathMaxRecords) {{
        const oldest = mapTracePathRecords.values().next().value;
        removeMapTracePathRecord(oldest);
      }}
      for (const rawNodeId of (Array.isArray(nodeIds) ? nodeIds : [])) {{
        const nodeId = normalizeNodeId(rawNodeId || "");
        if (!isSelectableNodeId(nodeId)) continue;
        mapNodeActivityFlashById.set(nodeId, {{
          startedAtMs: nowMs,
          untilMs: nowMs + 1800,
        }});
      }}
      scheduleMapNodeActivityFlashUpdate();
      return true;
    }}

    function startMapLiveTracerouteOverlay(rawTargetNodeId, payload, options = null) {{
      if (!isNetworkMapActivityFlashVisible()) return false;
      const opts = (options && typeof options === "object") ? options : {{}};
      const safePayload = (payload && typeof payload === "object") ? payload : {{}};
      const result = (safePayload.result && typeof safePayload.result === "object")
        ? safePayload.result
        : {{}};
      const safeState = (latestState && typeof latestState === "object") ? latestState : {{}};
      const targetId = normalizeNodeId(
        rawTargetNodeId
        || safePayload.destination
        || safePayload.dest
        || ""
      );
      const preferredSourceId = normalizeNodeId(opts.sourceId || "");
      const resolvedSourceId = normalizeNodeId(
        preferredSourceId
        || (typeof resolveNetworkRoutesSourceNodeId === "function" ? resolveNetworkRoutesSourceNodeId(safeState) : "")
        || resolveLocalNodeId(safeState)
        || ""
      );
      if (!isSelectableNodeId(resolvedSourceId) || !isSelectableNodeId(targetId) || resolvedSourceId === targetId) {{
        return false;
      }}
      const towardsPath = mapTracePathNodeIds(resolvedSourceId, result.towards, {{
        localAliasNodeId: resolvedSourceId,
        fallbackEndNodeId: targetId,
      }});
      const backStartId = towardsPath.length > 1 ? towardsPath[towardsPath.length - 1] : targetId;
      const backHops = Array.isArray(result.back) ? result.back : [];
      const backPath = backHops.length > 0
        ? mapTracePathNodeIds(backStartId, backHops, {{
            localAliasNodeId: resolvedSourceId,
            fallbackEndNodeId: resolvedSourceId,
          }})
        : [];
      let started = false;
      if (towardsPath.length >= 2) {{
        started = startMapTracePathAnimation(towardsPath, safeState, {{
          kind: "towards",
          color: "#f59e0b",
          durationMs: 6600,
          opacity: 0.82,
        }}) || started;
      }}
      if (backPath.length >= 2) {{
        started = startMapTracePathAnimation(backPath, safeState, {{
          kind: "return",
          color: "#38bdf8",
          durationMs: 5600,
          opacity: 0.68,
          weight: 2.9,
        }}) || started;
      }}
      return started;
    }}

    function mapActivityInterpolateLatLng(fromPosition, toPosition, progress) {{
      const t = clampMapLinkValue(Number(progress), 0, 1);
      const fromLat = Number(fromPosition && fromPosition.lat);
      const fromLon = Number(fromPosition && fromPosition.lon);
      const toLat = Number(toPosition && toPosition.lat);
      const toLon = Number(toPosition && toPosition.lon);
      return [
        fromLat + ((toLat - fromLat) * t),
        fromLon + ((toLon - fromLon) * t),
      ];
    }}

    function mapActivityCorridorKey(fromNodeId, toNodeId) {{
      const fromKey = String(fromNodeId || "").trim().toLowerCase();
      const toKey = String(toNodeId || "").trim().toLowerCase();
      if (!fromKey || !toKey || fromKey === toKey) return "";
      return fromKey < toKey ? `${{fromKey}}::${{toKey}}` : `${{toKey}}::${{fromKey}}`;
    }}

    function mapActivityNormalizePathPoints(path) {{
      const points = [];
      for (const point of (Array.isArray(path) ? path : [])) {{
        const lat = Array.isArray(point) ? Number(point[0]) : Number(point && point.lat);
        const lon = Array.isArray(point) ? Number(point[1]) : Number(point && (point.lng ?? point.lon));
        if (isValidMapCoord(lat, lon)) {{
          points.push([lat, lon]);
        }}
      }}
      return points;
    }}

    function mapActivityPathMetrics(path) {{
      const points = mapActivityNormalizePathPoints(path);
      const distances = [0];
      let total = 0;
      for (let index = 1; index < points.length; index += 1) {{
        const previous = points[index - 1];
        const current = points[index];
        const distance = mapEstimatedPositionDistanceMeters(
          {{ lat: previous[0], lon: previous[1] }},
          {{ lat: current[0], lon: current[1] }}
        );
        total += Number.isFinite(distance) ? Math.max(0, distance) : 0;
        distances.push(total);
      }}
      return {{ points, distances, total }};
    }}

    function mapActivityPathPointAtDistance(metrics, targetDistance) {{
      const points = Array.isArray(metrics && metrics.points) ? metrics.points : [];
      const distances = Array.isArray(metrics && metrics.distances) ? metrics.distances : [];
      if (points.length <= 0) return null;
      if (points.length === 1 || !(Number(metrics && metrics.total) > 0)) {{
        return points[0];
      }}
      const target = clampMapLinkValue(Number(targetDistance), 0, Number(metrics.total));
      for (let index = 1; index < points.length; index += 1) {{
        const startDistance = Number(distances[index - 1]) || 0;
        const endDistance = Number(distances[index]) || startDistance;
        if (target > endDistance && index < points.length - 1) continue;
        const segmentDistance = Math.max(0, endDistance - startDistance);
        const localProgress = segmentDistance > 0 ? ((target - startDistance) / segmentDistance) : 1;
        return mapActivityInterpolateLatLng(
          {{ lat: points[index - 1][0], lon: points[index - 1][1] }},
          {{ lat: points[index][0], lon: points[index][1] }},
          localProgress
        );
      }}
      return points[points.length - 1];
    }}

    function mapActivityPathSlice(path, startProgress, endProgress) {{
      const metrics = mapActivityPathMetrics(path);
      const points = metrics.points;
      if (points.length <= 0) return [];
      if (points.length === 1 || !(metrics.total > 0)) return [points[0]];
      const startDistance = clampMapLinkValue(Number(startProgress), 0, 1) * metrics.total;
      const endDistance = clampMapLinkValue(Number(endProgress), 0, 1) * metrics.total;
      const fromDistance = Math.min(startDistance, endDistance);
      const toDistance = Math.max(startDistance, endDistance);
      const slice = [];
      const appendPoint = (point) => {{
        if (!Array.isArray(point) || point.length < 2) return;
        const last = slice[slice.length - 1];
        if (
          last
          && Math.abs(Number(last[0]) - Number(point[0])) < 1e-9
          && Math.abs(Number(last[1]) - Number(point[1])) < 1e-9
        ) {{
          return;
        }}
        slice.push([Number(point[0]), Number(point[1])]);
      }};
      appendPoint(mapActivityPathPointAtDistance(metrics, fromDistance));
      for (let index = 1; index < points.length - 1; index += 1) {{
        const distance = Number(metrics.distances[index]) || 0;
        if (distance > fromDistance && distance < toDistance) {{
          appendPoint(points[index]);
        }}
      }}
      appendPoint(mapActivityPathPointAtDistance(metrics, toDistance));
      return slice.length > 0 ? slice : [points[0]];
    }}

    function cacheMapEstimatedCorridorActivityPaths(estimateLines = []) {{
      mapEstimatedCorridorActivityPathsByKey.clear();
      const addPath = (fromNodeId, toNodeId, path, line = null) => {{
        const fromId = normalizeNodeId(fromNodeId || "");
        const toId = normalizeNodeId(toNodeId || "");
        if (!isSelectableNodeId(fromId) || !isSelectableNodeId(toId) || fromId === toId) return;
        const normalizedPath = mapActivityNormalizePathPoints(path);
        if (normalizedPath.length < 2) return;
        const key = mapActivityCorridorKey(fromId, toId);
        if (!key) return;
        mapEstimatedCorridorActivityPathsByKey.set(key, {{
          fromId,
          toId,
          path: normalizedPath,
          trafficPct: clampMapLinkValue(Number(line && line.renderTrafficPct), 0.08, 1),
        }});
      }};

      for (const estimateLine of (Array.isArray(estimateLines) ? estimateLines : [])) {{
        const fromId = normalizeNodeId(estimateLine && estimateLine.fromId);
        const toId = normalizeNodeId(estimateLine && estimateLine.toId);
        const fromLat = Number(estimateLine && estimateLine.fromLat);
        const fromLon = Number(estimateLine && estimateLine.fromLon);
        const toLat = Number(estimateLine && estimateLine.toLat);
        const toLon = Number(estimateLine && estimateLine.toLon);
        if (!isValidMapCoord(fromLat, fromLon) || !isValidMapCoord(toLat, toLon)) continue;
        const basePath = [[fromLat, fromLon], [toLat, toLon]];
        addPath(fromId, toId, basePath, estimateLine);

        if (!(estimateLine && estimateLine.cloudLink)) continue;
        const knownNodeId = normalizeNodeId(estimateLine.toId || "");
        if (!isSelectableNodeId(knownNodeId)) continue;
        const cloudPoint = [fromLat, fromLon];
        const knownPoint = [toLat, toLon];
        for (const rawMemberNodeId of (Array.isArray(estimateLine.cloudNodeIds) ? estimateLine.cloudNodeIds : [])) {{
          const memberNodeId = normalizeNodeId(rawMemberNodeId || "");
          if (!isSelectableNodeId(memberNodeId) || memberNodeId === knownNodeId) continue;
          const memberPosition = mapNodeActivityPosition(memberNodeId);
          const memberPoint = (
            memberPosition
            && isValidMapCoord(Number(memberPosition.lat), Number(memberPosition.lon))
          )
            ? [Number(memberPosition.lat), Number(memberPosition.lon)]
            : cloudPoint;
          addPath(memberNodeId, knownNodeId, [memberPoint, cloudPoint, knownPoint], estimateLine);
        }}
      }}
      return mapEstimatedCorridorActivityPathsByKey.size;
    }}

    function mapPacketActivityCorridorPath(fromNodeId, toNodeId) {{
      const fromId = normalizeNodeId(fromNodeId || "");
      const toId = normalizeNodeId(toNodeId || "");
      const key = mapActivityCorridorKey(fromId, toId);
      if (!key) return null;
      const corridor = mapEstimatedCorridorActivityPathsByKey.get(key);
      if (!(corridor && Array.isArray(corridor.path) && corridor.path.length >= 2)) return null;
      const path = mapActivityNormalizePathPoints(corridor.path);
      if (path.length < 2) return null;
      if (normalizeNodeId(corridor.fromId) === fromId && normalizeNodeId(corridor.toId) === toId) {{
        return path;
      }}
      if (normalizeNodeId(corridor.fromId) === toId && normalizeNodeId(corridor.toId) === fromId) {{
        return path.slice().reverse();
      }}
      return path;
    }}

    function removeMapNodeActivityDirection(record) {{
      if (!(record && typeof record === "object")) return;
      for (const layer of [record.line, record.head]) {{
        if (layer && map && typeof map.removeLayer === "function") {{
          try {{
            map.removeLayer(layer);
          }} catch (_err) {{
          }}
        }}
      }}
      mapNodeActivityDirectionRecords.delete(record);
    }}

    function clearMapNodeActivityDirections() {{
      for (const record of Array.from(mapNodeActivityDirectionRecords)) {{
        removeMapNodeActivityDirection(record);
      }}
    }}

    function pruneExpiredMapNodeActivityDirections(nowMs = Date.now()) {{
      if (!isNetworkMapActivityFlashVisible()) {{
        clearMapNodeActivityDirections();
        return 0;
      }}
      let activeCount = 0;
      for (const record of Array.from(mapNodeActivityDirectionRecords)) {{
        const line = record && record.line;
        const head = record && record.head;
        if (!(line && typeof line.setLatLngs === "function" && head && typeof head.setLatLng === "function")) {{
          removeMapNodeActivityDirection(record);
          continue;
        }}
        const startedAtMs = Number(record.startedAtMs);
        const durationMs = Math.max(1, Number(record.durationMs) || 900);
        const ageMs = nowMs - (Number.isFinite(startedAtMs) ? startedAtMs : nowMs);
        if (ageMs >= durationMs) {{
          removeMapNodeActivityDirection(record);
          continue;
        }}
        const progress = clampMapLinkValue(ageMs / durationMs, 0, 1);
        const tailProgress = clampMapLinkValue(progress - 0.22, 0, 1);
        const animatedPath = mapActivityPathSlice(record.path, tailProgress, progress);
        const headPoint = animatedPath[animatedPath.length - 1]
          || mapActivityInterpolateLatLng(record.fromPosition, record.toPosition, progress);
        const signalLevel = clampMapLinkValue(Number(record.signalLevel), 0, 1);
        const fadeIn = clampMapLinkValue(progress / 0.18, 0, 1);
        const fadeOut = clampMapLinkValue((1 - progress) / 0.22, 0, 1);
        const opacity = clampMapLinkValue((0.28 + (signalLevel * 0.5)) * Math.min(fadeIn, fadeOut), 0, 0.86);
        const weight = 2.2 + (signalLevel * 2.2);
        line.setLatLngs(animatedPath.length >= 2 ? animatedPath : [headPoint, headPoint]);
        line.setStyle({{
          opacity,
          weight,
        }});
        head.setLatLng(headPoint);
        head.setStyle({{
          opacity: clampMapLinkValue(opacity + 0.12, 0, 0.92),
          fillOpacity: clampMapLinkValue(opacity + 0.18, 0, 0.96),
        }});
        activeCount += 1;
      }}
      return activeCount;
    }}

    function pruneExpiredMapTracePaths(nowMs = Date.now()) {{
      if (!isNetworkMapActivityFlashVisible()) {{
        clearMapTracePaths();
        return 0;
      }}
      let activeCount = 0;
      for (const record of Array.from(mapTracePathRecords)) {{
        const layers = Array.isArray(record && record.layers) ? record.layers : [];
        if (!layers.length) {{
          removeMapTracePathRecord(record);
          continue;
        }}
        const startedAtMs = Number(record.startedAtMs);
        const durationMs = Math.max(1, Number(record.durationMs) || 6200);
        const ageMs = nowMs - (Number.isFinite(startedAtMs) ? startedAtMs : nowMs);
        if (ageMs >= durationMs) {{
          removeMapTracePathRecord(record);
          continue;
        }}
        const progress = clampMapLinkValue(ageMs / durationMs, 0, 1);
        const fadeIn = clampMapLinkValue(progress / 0.14, 0, 1);
        const fadeOut = clampMapLinkValue((1 - progress) / 0.42, 0, 1);
        const opacity = clampMapLinkValue((Number(record.baseOpacity) || 0.7) * Math.min(fadeIn, fadeOut), 0, 0.9);
        const weight = Math.max(1, (Number(record.baseWeight) || 3) * (1 - (progress * 0.18)));
        for (const layer of layers) {{
          if (!(layer && typeof layer.setStyle === "function")) {{
            removeMapTracePathRecord(record);
            break;
          }}
          layer.setStyle({{
            opacity,
            weight,
          }});
        }}
        if (mapTracePathRecords.has(record)) {{
          activeCount += 1;
        }}
      }}
      return activeCount;
    }}

    function startMapPacketDirectionAnimation(fromNodeId, toNodeId, state = latestState, signalLevel = 0.55) {{
      const fromId = normalizeNodeId(fromNodeId || "");
      const toId = normalizeNodeId(toNodeId || "");
      if (!isSelectableNodeId(fromId) || !isSelectableNodeId(toId) || fromId === toId) return false;
      if (!isNetworkMapActivityFlashVisible()) return false;
      if (!ensureMapTransmitPulsePane()) return false;
      const fromPosition = mapNodeActivityPosition(fromId, state);
      const toPosition = mapNodeActivityPosition(toId, state);
      if (!fromPosition || !toPosition) return false;
      if (!isValidMapCoord(fromPosition.lat, fromPosition.lon) || !isValidMapCoord(toPosition.lat, toPosition.lon)) return false;
      const corridorPath = mapPacketActivityCorridorPath(fromId, toId);
      const animationPath = Array.isArray(corridorPath) && corridorPath.length >= 2
        ? corridorPath
        : [[fromPosition.lat, fromPosition.lon], [toPosition.lat, toPosition.lon]];
      const color = mapNodeTransmitPulseColor(fromId, state);
      const signal = clampMapLinkValue(Number(signalLevel), 0, 1);
      const fromPoint = animationPath[0];
      const line = L.polyline([fromPoint, fromPoint], {{
        pane: mapTransmitPulsePaneName,
        color,
        opacity: 0,
        weight: 2.2 + (signal * 2.2),
        lineCap: "round",
        lineJoin: "round",
        interactive: false,
        bubblingMouseEvents: false,
      }});
      const head = L.circleMarker(fromPoint, {{
        pane: mapTransmitPulsePaneName,
        radius: 3.2 + (signal * 2.4),
        color,
        fillColor: color,
        opacity: 0,
        fillOpacity: 0,
        weight: 1.2,
        interactive: false,
        bubblingMouseEvents: false,
      }});
      line.addTo(map);
      head.addTo(map);
      mapNodeActivityDirectionRecords.add({{
        line,
        head,
        fromId,
        toId,
        fromPosition,
        toPosition,
        path: animationPath,
        signalLevel: signal,
        startedAtMs: Date.now(),
        durationMs: 920,
      }});
      while (mapNodeActivityDirectionRecords.size > mapNodeActivityDirectionMaxRecords) {{
        const oldest = mapNodeActivityDirectionRecords.values().next().value;
        removeMapNodeActivityDirection(oldest);
      }}
      return true;
    }}

    function pruneExpiredMapNodeTransmitPulseRings(nowMs = Date.now()) {{
      if (!isNetworkMapActivityFlashVisible()) {{
        clearMapNodeTransmitPulseRings();
        return 0;
      }}
      let activeCount = 0;
      for (const record of Array.from(mapNodeTransmitPulseRings)) {{
        const layer = record && record.layer;
        if (!(layer && typeof layer.setStyle === "function" && typeof layer.setRadius === "function")) {{
          removeMapTransmitPulseRing(record);
          continue;
        }}
        const startedAtMs = Number(record.startedAtMs);
        const delayMs = Math.max(0, Number(record.delayMs) || 0);
        const durationMs = Math.max(1, Number(record.durationMs) || 1200);
        const ageMs = nowMs - (Number.isFinite(startedAtMs) ? startedAtMs : nowMs) - delayMs;
        if (ageMs >= durationMs) {{
          removeMapTransmitPulseRing(record);
          continue;
        }}
        activeCount += 1;
        if (ageMs < 0) {{
          layer.setStyle({{ opacity: 0, fillOpacity: 0 }});
          continue;
        }}
        const progress = clampMapLinkValue(ageMs / durationMs, 0, 1);
        const radiusStart = Number(record.startRadius) || 5;
        const radiusEnd = Number(record.endRadius) || 30;
        const easedRadius = radiusStart + ((radiusEnd - radiusStart) * (1 - Math.pow(1 - progress, 2)));
        const fade = Math.pow(1 - progress, 1.35);
        const opacity = clampMapLinkValue((Number(record.baseOpacity) || 0.62) * fade, 0, 0.72);
        const weight = Math.max(0.7, (Number(record.baseWeight) || 2) * (1 - (progress * 0.28)));
        layer.setRadius(easedRadius);
        layer.setStyle({{
          opacity,
          fillOpacity: 0,
          weight,
        }});
      }}
      return activeCount;
    }}

    function startMapNodeTransmitRipple(nodeId, state = latestState, signalLevel = 0.55) {{
      const normalizedId = normalizeNodeId(nodeId || "");
      if (!isSelectableNodeId(normalizedId) || !isNetworkMapActivityFlashVisible()) return false;
      const position = mapNodeTransmitPulsePosition(normalizedId, state);
      if (!position) return false;
      if (!ensureMapTransmitPulsePane()) return false;
      const color = mapNodeTransmitPulseColor(normalizedId, state);
      const nowMs = Date.now();
      const radiusScale = mapTransmitPulseRadiusScale(signalLevel);
      for (let idx = 0; idx < 3; idx += 1) {{
        const endRadius = (22 + (idx * 7)) * radiusScale;
        const layer = L.circleMarker(position, {{
          pane: mapTransmitPulsePaneName,
          radius: 5,
          color,
          opacity: 0,
          weight: idx === 0 ? 2.4 : 1.8,
          fill: false,
          fillOpacity: 0,
          interactive: false,
          bubblingMouseEvents: false,
        }});
        layer.addTo(map);
        mapNodeTransmitPulseRings.add({{
          layer,
          nodeId: normalizedId,
          startedAtMs: nowMs,
          delayMs: idx * 170,
          durationMs: 1250,
          startRadius: 5,
          endRadius,
          baseOpacity: idx === 0 ? 0.72 : 0.58,
          baseWeight: idx === 0 ? 2.4 : 1.8,
        }});
      }}
      while (mapNodeTransmitPulseRings.size > mapNodeTransmitPulseMaxRings) {{
        const oldest = mapNodeTransmitPulseRings.values().next().value;
        removeMapTransmitPulseRing(oldest);
      }}
      return true;
    }}

    function pruneExpiredMapNodeActivityFlashes(nowMs = Date.now()) {{
      let activeCount = 0;
      for (const [nodeId, flash] of Array.from(mapNodeActivityFlashById.entries())) {{
        const untilMs = Number(flash && flash.untilMs);
        if (!Number.isFinite(untilMs) || untilMs <= nowMs) {{
          mapNodeActivityFlashById.delete(nodeId);
          continue;
        }}
        activeCount += 1;
      }}
      return activeCount;
    }}

    function stopMapNodeActivityFlashLoop() {{
      if (mapNodeActivityFlashRaf != null) {{
        window.cancelAnimationFrame(mapNodeActivityFlashRaf);
        mapNodeActivityFlashRaf = null;
      }}
      if (mapTraceProgressTimer != null) {{
        window.clearTimeout(mapTraceProgressTimer);
        mapTraceProgressTimer = null;
      }}
    }}

    function mapNodeActivityFlashStrength(nodeId, nowMs = Date.now()) {{
      const normalizedId = normalizeNodeId(nodeId || "");
      if (!normalizedId || !isNetworkMapActivityFlashVisible()) return 0;
      const flash = mapNodeActivityFlashById.get(normalizedId);
      if (!(flash && typeof flash === "object")) return 0;
      const startedAtMs = Number(flash.startedAtMs);
      const untilMs = Number(flash.untilMs);
      if (!Number.isFinite(untilMs) || untilMs <= nowMs) {{
        mapNodeActivityFlashById.delete(normalizedId);
        return 0;
      }}
      const durationMs = Math.max(1, untilMs - (Number.isFinite(startedAtMs) ? startedAtMs : (untilMs - 1100)));
      const elapsedMs = Math.max(0, nowMs - (Number.isFinite(startedAtMs) ? startedAtMs : (untilMs - durationMs)));
      const envelope = clampMapLinkValue((untilMs - nowMs) / durationMs, 0, 1);
      const pulsePhase = (elapsedMs % 260) / 260;
      const pulse = 0.35 + (0.65 * (0.5 + (0.5 * Math.cos(pulsePhase * Math.PI * 2))));
      return clampMapLinkValue((0.3 + (pulse * 0.7)) * envelope, 0, 1);
    }}

    function applyMapNodeActivityFlashStyle(baseStyle, flashStrength, markerKind = "actual") {{
      const strength = clampMapLinkValue(flashStrength, 0, 1);
      if (!(strength > 0)) return baseStyle;
      const style = Object.assign({{}}, baseStyle);
      const radiusBase = Number(style.radius);
      const weightBase = Number(style.weight);
      const fillOpacityBase = Number(style.fillOpacity);
      style.radius = (Number.isFinite(radiusBase) ? radiusBase : 6) + ((markerKind === "estimated" ? 1.4 : 1.9) * strength);
      style.weight = (Number.isFinite(weightBase) ? weightBase : 1) + (1.2 * strength);
      style.fillOpacity = clampMapLinkValue((Number.isFinite(fillOpacityBase) ? fillOpacityBase : 0.78) + (0.22 * strength), 0.12, 1);
      style.opacity = clampMapLinkValue(0.78 + (0.22 * strength), 0.12, 1);
      style.color = strength >= 0.52 ? "#9a1f10" : "#c65819";
      style.fillColor = strength >= 0.52 ? "#fff1a3" : "#ffd06a";
      return style;
    }}

    function applyMapNodeTraceProgressStyle(baseStyle, traceProgress) {{
      if (!(traceProgress && typeof traceProgress === "object")) return baseStyle;
      const progressRatio = clampMapLinkValue(Number(traceProgress.progressRatio), 0.01, 0.99);
      const style = Object.assign({{}}, baseStyle);
      const radius = Math.max(4, Number(style.radius) || 6);
      const circumference = Math.max(8, 2 * Math.PI * radius);
      const dashLength = Math.max(1.6, circumference * progressRatio);
      const baseWeight = Number(style.weight);
      style.color = "#7dd3fc";
      style.opacity = 1;
      style.weight = Math.max(Number.isFinite(baseWeight) ? baseWeight : 1.8, 2.4 + (2.2 * progressRatio));
      style.dashArray = `${{dashLength.toFixed(1)}} ${{circumference.toFixed(1)}}`;
      style.lineCap = "round";
      return style;
    }}

    function applyMapNodeTraceResultStyle(baseStyle, resultFlash) {{
      if (!(resultFlash && typeof resultFlash === "object")) return baseStyle;
      const strength = clampMapLinkValue(Number(resultFlash.strength), 0, 1);
      if (!(strength > 0)) return baseStyle;
      const style = Object.assign({{}}, baseStyle);
      const baseWeight = Number(style.weight);
      style.color = resultFlash.ok === true ? "#22c55e" : "#ef4444";
      style.opacity = clampMapLinkValue(0.56 + (0.44 * strength), 0.2, 1);
      style.weight = Math.max(Number.isFinite(baseWeight) ? baseWeight : 1.8, 2.6 + (2.8 * strength));
      style.dashArray = null;
      style.lineCap = "round";
      return style;
    }}

    function resolveMapNodeMarkerStyle(nodeId, isSelected, markerKind = "actual", markerConfidence = 0.45, state = latestState) {{
      const kind = markerKind === "estimated" ? "estimated" : "actual";
      const safeState = (state && typeof state === "object") ? state : latestState;
      const localNodeId = normalizeNodeId(resolveLocalNodeId(safeState || {{}}) || "");
      const isLocal = !!(localNodeId && normalizeNodeId(nodeId || "") === localNodeId);
      const baseStyle = kind === "estimated"
        ? estimatedMarkerStyle(isSelected, markerConfidence, isLocal)
        : markerStyle(isSelected || isLocal);
      if (isLocal && kind !== "estimated") {{
        baseStyle.radius = Math.max(Number(baseStyle.radius) || 0, isSelected ? 8.6 : 7.2);
        baseStyle.color = isSelected ? "#3f2b8c" : "#5f40c9";
        baseStyle.fillColor = isSelected ? "#efe4ff" : "#ccb8ff";
        baseStyle.fillOpacity = isSelected ? 0.96 : 0.9;
        baseStyle.weight = Math.max(Number(baseStyle.weight) || 0, isSelected ? 2.8 : 2.1);
      }}
      const flashStrength = mapNodeActivityFlashStrength(nodeId);
      const activityStyle = applyMapNodeActivityFlashStyle(baseStyle, flashStrength, kind);
      const traceProgress = mapNodeTraceProgressState(nodeId);
      const progressStyle = applyMapNodeTraceProgressStyle(activityStyle, traceProgress);
      const resultFlash = mapNodeTraceResultFlashState(nodeId);
      return applyMapNodeTraceResultStyle(progressStyle, resultFlash);
    }}

    function resolveMapNodeEmoji(nodeId, state = latestState) {{
      const cleanNodeId = normalizeNodeId(nodeId || "");
      if (!cleanNodeId) return "";
      const safeState = (state && typeof state === "object") ? state : latestState;
      const nodes = Array.isArray(safeState && safeState.nodes) ? safeState.nodes : [];
      const node = nodes.find((entry) => normalizeNodeId(entry && entry.id) === cleanNodeId) || null;
      return (typeof nodeVisualEmojiForNode === "function")
        ? nodeVisualEmojiForNode(cleanNodeId, null, node)
        : "";
    }}

    function mapNodeUsesEmojiMarker(nodeId, markerKind = "actual", state = latestState) {{
      if ((markerKind === "estimated" ? "estimated" : "actual") !== "actual") return false;
      return !!resolveMapNodeEmoji(nodeId, state);
    }}

    function mapNodeFieldHtml(label, value, extraClass = "") {{
      const cleanValue = String(value == null ? "" : value).trim() || "n/a";
      return `
        <div class="map-node-info-row${{extraClass ? ` ${{extraClass}}` : ""}}">
          <span class="map-node-info-label">${{escAttr(label)}}</span>
          <span class="map-node-info-value">${{escAttr(cleanValue)}}</span>
        </div>
      `;
    }}

    function mapNodePopupActionButtonHtml(label, action, nodeId) {{
      const cleanLabel = String(label || "").trim();
      const cleanAction = String(action || "").trim().toLowerCase();
      const cleanNodeId = normalizeNodeId(nodeId || "");
      if (!cleanLabel || !cleanAction || !isSelectableNodeId(cleanNodeId)) return "";
      return `
        <button
          type="button"
          class="map-node-info-action-btn"
          data-map-node-action="${{escAttr(cleanAction)}}"
          data-node-id="${{escAttr(cleanNodeId)}}"
        >${{escAttr(cleanLabel)}}</button>
      `;
    }}

    function runMapNodePopupAction(action, rawNodeId) {{
      const cleanAction = String(action || "").trim().toLowerCase();
      const nodeId = normalizeNodeId(rawNodeId || "");
      if (!isSelectableNodeId(nodeId)) return false;

      if (cleanAction === "message") {{
        applyLayoutView("network", true);
        if (typeof setActiveNetworkSubview === "function") {{
          setActiveNetworkSubview("map", {{ persist: true }});
        }}
        selectNode(nodeId, true, false);
        if (typeof setChatNodeDetailsDrawerTab === "function") {{
          setChatNodeDetailsDrawerTab("messages", {{ fetchHistory: false }});
        }}
        if (typeof setChatNodeDetailsDrawerExpanded === "function") {{
          setChatNodeDetailsDrawerExpanded(true, {{
            tab: "messages",
            fetchHistory: false,
            rerender: false,
          }});
        }}
        return true;
      }}

      if (cleanAction === "trace") {{
        applyLayoutView("network", true);
        if (typeof setActiveNetworkSubview === "function") {{
          setActiveNetworkSubview("map", {{ persist: true }});
        }}
        if (typeof runChatNodeTelemetryTool === "function") {{
          void runChatNodeTelemetryTool("traceroute", nodeId);
        }}
        return true;
      }}

      if (cleanAction === "details") {{
        applyLayoutView("network", true);
        if (typeof setActiveNetworkSubview === "function") {{
          setActiveNetworkSubview("map", {{ persist: true }});
        }}
        selectNode(nodeId, true, false);
        if (typeof setChatNodeDetailsDrawerTab === "function") {{
          setChatNodeDetailsDrawerTab("details", {{ fetchHistory: true }});
        }}
        if (typeof setChatNodeDetailsDrawerExpanded === "function") {{
          setChatNodeDetailsDrawerExpanded(true, {{
            tab: "details",
            fetchHistory: true,
            rerender: false,
          }});
        }}
        return true;
      }}

      return false;
    }}

    function handleMapNodePopupActionClick(clickEv, fallbackNodeId = "", closePopupFn = null) {{
      const target = clickEv && clickEv.target;
      if (!(target instanceof Element)) return false;
      const actionBtn = target.closest("[data-map-node-action]");
      if (!(actionBtn instanceof HTMLButtonElement)) return false;
      const action = String(actionBtn.dataset.mapNodeAction || "").trim().toLowerCase();
      const nodeId = normalizeNodeId(actionBtn.dataset.nodeId || fallbackNodeId || "");
      if (!action || !nodeId) return false;
      clickEv.preventDefault();
      clickEv.stopPropagation();
      const applied = runMapNodePopupAction(action, nodeId);
      if (!applied) return false;
      if (typeof closePopupFn === "function") {{
        closePopupFn();
      }} else if (typeof map !== "undefined" && map && typeof map.closePopup === "function") {{
        map.closePopup();
      }}
      return true;
    }}

    function prepareMapNodePopupElement(popupEl, fallbackNodeId = "", closePopupFn = null, hoverHandlers = null) {{
      if (!(popupEl instanceof HTMLElement)) return false;
      popupEl.style.pointerEvents = "auto";
      popupEl.classList.remove("is-closing");
      try {{
        if (typeof L !== "undefined" && L.DomEvent) {{
          if (typeof L.DomEvent.disableClickPropagation === "function") {{
            L.DomEvent.disableClickPropagation(popupEl);
          }}
          if (typeof L.DomEvent.disableScrollPropagation === "function") {{
            L.DomEvent.disableScrollPropagation(popupEl);
          }}
        }}
      }} catch (_err) {{
      }}
      const hover = (hoverHandlers && typeof hoverHandlers === "object") ? hoverHandlers : null;
      if (hover && popupEl.dataset.hoverBound !== "1") {{
        popupEl.dataset.hoverBound = "1";
        popupEl.addEventListener("mouseenter", () => {{
          if (typeof hover.onEnter === "function") hover.onEnter();
        }});
        popupEl.addEventListener("mouseleave", () => {{
          if (typeof hover.onLeave === "function") hover.onLeave();
        }});
      }}
      const infoCard = popupEl.querySelector(".map-node-info-card");
      if (infoCard instanceof HTMLElement && infoCard.dataset.actionsBound !== "1") {{
        infoCard.dataset.actionsBound = "1";
        infoCard.style.pointerEvents = "auto";
        infoCard.addEventListener("click", (clickEv) => {{
          handleMapNodePopupActionClick(clickEv, fallbackNodeId, closePopupFn);
        }});
      }}
      return true;
    }}

    function bindMapNodePopupActionDelegates() {{
      if (typeof document === "undefined" || !document.body) return;
      if (document.body.dataset.mapNodePopupActionsBound === "1") return;
      document.body.dataset.mapNodePopupActionsBound = "1";
      document.addEventListener("click", (clickEv) => {{
        handleMapNodePopupActionClick(clickEv);
      }});
      if (
        typeof map !== "undefined"
        && map
        && typeof map.on === "function"
        && document.body.dataset.mapNodePopupPropagationBound !== "1"
      ) {{
        document.body.dataset.mapNodePopupPropagationBound = "1";
        map.on("popupopen", (ev) => {{
          const popup = ev && ev.popup;
          const popupEl = popup && typeof popup.getElement === "function"
            ? popup.getElement()
            : null;
          prepareMapNodePopupElement(popupEl);
        }});
      }}
    }}

    function buildMapNodeInfoHtml(node, options = null) {{
      const opts = (options && typeof options === "object") ? options : {{}};
      const safeNode = (node && typeof node === "object") ? node : {{}};
      const state = (opts.state && typeof opts.state === "object") ? opts.state : latestState;
      const includeActions = opts.includeActions !== false;
      const nowUnix = Number.isFinite(Number(opts.nowUnix))
        ? Math.floor(Number(opts.nowUnix))
        : Math.floor(Date.now() / 1000);
      const normalizedId = normalizeNodeId(opts.nodeId || safeNode.id || "");
      const fallbackId = String(safeNode.id || "").trim();
      const displayId = normalizedId || fallbackId || "n/a";
      const name = String(nodeLabel(safeNode) || displayId).trim() || displayId;
      const emoji = String(opts.emoji != null ? opts.emoji : resolveMapNodeEmoji(displayId, state)).trim();
      const lat = Number(safeNode.lat);
      const lon = Number(safeNode.lon);
      const hasCoords = isValidMapCoord(lat, lon);
      const positionBadge = opts.positionBadge || resolveMapPositionBadge(safeNode, opts.caps || null, nowUnix);
      const lastHeardText = typeof nodeLastHeardLabel === "function"
        ? nodeLastHeardLabel(safeNode, "n/a", nowUnix)
        : String(safeNode.last_heard || "n/a");
      const batteryPct = safeNode.battery_level ?? safeNode.battery ?? safeNode.battery_pct;
      const voltage = safeNode.voltage ?? safeNode.battery_voltage;
      const hops = safeNode.hops_away ?? safeNode.hopsAway;
      const nodeNum = safeNode.num ?? safeNode.node_num;
      const snr = safeNode.snr;
      const rssi = safeNode.rssi;
      const trailCount = Number.isFinite(Number(opts.trailPointsCount))
        ? Math.max(0, Math.trunc(Number(opts.trailPointsCount)))
        : null;
      const trailLatest = String(opts.trailLatest || "").trim();
      const isEstimated = !!opts.isEstimated;
      const confidencePct = Number.isFinite(Number(opts.confidencePct))
        ? Math.round(Number(opts.confidencePct))
        : null;
      const confidenceLabel = String(opts.confidenceLabel || "").trim();
      const qualityPct = Number.isFinite(Number(opts.qualityPct))
        ? Math.round(Number(opts.qualityPct))
        : null;
      const fitPct = Number.isFinite(Number(opts.fitPct))
        ? Math.round(Number(opts.fitPct))
        : null;
      const residualKm = Number.isFinite(Number(opts.residualKm))
        ? Math.max(0, Math.round(Number(opts.residualKm) * 10) / 10)
        : null;
      const anchorCount = Number.isFinite(Number(opts.anchorCount))
        ? Math.max(0, Math.trunc(Number(opts.anchorCount)))
        : null;
      const supportLinks = Number.isFinite(Number(opts.supportLinks))
        ? Math.max(0, Math.trunc(Number(opts.supportLinks)))
        : null;
      const avgHops = opts.avgHops;
      const avgSnr = opts.avgSnr;
      const avgRssi = opts.avgRssi;

      const headerMeta = [];
      if (emoji) headerMeta.push(`<span class="map-node-info-emoji" aria-hidden="true">${{escAttr(emoji)}}</span>`);
      headerMeta.push(`
        <div class="map-node-info-title-wrap">
          <div class="map-node-info-title">${{escAttr(name)}}</div>
          <div class="map-node-info-subtitle">${{escAttr(displayId)}}</div>
        </div>
      `);

      const rows = [];
      if (nodeNum != null && String(nodeNum).trim()) rows.push(mapNodeFieldHtml("Node Num", nodeNum));
      if (snr != null && String(snr).trim()) rows.push(mapNodeFieldHtml("SNR", snr));
      if (rssi != null && String(rssi).trim()) rows.push(mapNodeFieldHtml("RSSI", rssi));
      if (batteryPct != null && String(batteryPct).trim()) rows.push(mapNodeFieldHtml("Battery", `${{batteryPct}}%`));
      if (voltage != null && String(voltage).trim()) rows.push(mapNodeFieldHtml("Voltage", voltage));
      if (hops != null && String(hops).trim()) rows.push(mapNodeFieldHtml("Hops", hops));
      rows.push(mapNodeFieldHtml("Last Heard", lastHeardText));
      rows.push(`
        <div class="map-node-info-row is-position">
          <span class="map-node-info-label">Position</span>
          <span class="map-node-info-value">
            <span class="map-position-badge ${{escAttr(positionBadge.className || "unknown")}}" title="${{escAttr(positionBadge.title || "")}}">${{escAttr(positionBadge.label || "Unknown")}}</span>
          </span>
        </div>
      `);
      rows.push(mapNodeFieldHtml("Coords", hasCoords ? `${{lat.toFixed(5)}}, ${{lon.toFixed(5)}}` : "No GPS fix"));

      if (trailCount != null) rows.push(mapNodeFieldHtml("Trail Points", trailCount));
      if (trailLatest) rows.push(mapNodeFieldHtml("Trail Latest", trailLatest));

      if (isEstimated) {{
        rows.push(mapNodeFieldHtml("Location", "Link-inferred"));
        if (confidenceLabel || confidencePct != null) {{
          rows.push(mapNodeFieldHtml(
            "Confidence",
            confidencePct != null ? `${{confidenceLabel || "Inferred"}} (${{confidencePct}}%)` : confidenceLabel
          ));
        }}
        if (anchorCount != null) rows.push(mapNodeFieldHtml("Anchors", anchorCount));
        if (supportLinks != null) rows.push(mapNodeFieldHtml("Support Links", supportLinks));
        if (fitPct != null) rows.push(mapNodeFieldHtml("Topology Fit", `${{fitPct}}%`));
        if (residualKm != null) rows.push(mapNodeFieldHtml("Avg Fit Error", `${{residualKm}} km`));
        if (qualityPct != null) rows.push(mapNodeFieldHtml("Link Quality", `${{qualityPct}}%`));
        if (avgHops != null && String(avgHops).trim()) rows.push(mapNodeFieldHtml("Avg Link Hops", avgHops));
        if (avgSnr != null && String(avgSnr).trim()) rows.push(mapNodeFieldHtml("Avg Link SNR", avgSnr));
        if (avgRssi != null && String(avgRssi).trim()) rows.push(mapNodeFieldHtml("Avg Link RSSI", avgRssi));
      }}

      const actionNodeId = normalizeNodeId(displayId || normalizedId || fallbackId || "");
      const quickActions = includeActions && isSelectableNodeId(actionNodeId)
        ? [
            mapNodePopupActionButtonHtml("Message", "message", actionNodeId),
            mapNodePopupActionButtonHtml("Trace", "trace", actionNodeId),
            mapNodePopupActionButtonHtml("Open details", "details", actionNodeId),
          ].filter(Boolean).join("")
        : "";

      return `
        <div class="map-node-info-card${{isEstimated ? " is-estimated" : ""}}">
          <div class="map-node-info-header">
