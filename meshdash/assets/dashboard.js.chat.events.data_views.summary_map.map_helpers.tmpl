    function hashTrailSignature(nodeHistory, selection) {{
      let hash = 2166136261;
      let pointCount = 0;
      const historyNodeId = normalizeNodeId((nodeHistory && nodeHistory.node_id) || "");
      hash = hashMixStr(hash, historyNodeId);
      if (!(historyNodeId && historyNodeId === selection)) {{
        hash = hashMixInt(hash, -1);
        return {{ hash: hash >>> 0, count: 0 }};
      }}

      const rawTrail = Array.isArray(nodeHistory && nodeHistory.positions)
        ? nodeHistory.positions
        : [];
      for (const point of rawTrail) {{
        const lat = Number(point && point.lat);
        const lon = Number(point && point.lon);
        if (!isValidMapCoord(lat, lon)) continue;
        pointCount += 1;
        hash = hashMixInt(hash, Math.round(lat * 100000));
        hash = hashMixInt(hash, Math.round(lon * 100000));
        const when = Number(point && point.time_unix);
        hash = hashMixInt(hash, Number.isFinite(when) ? Math.round(when) : 0);
      }}
      hash = hashMixInt(hash, pointCount);
      return {{ hash: hash >>> 0, count: pointCount }};
    }}

    function buildMapGraphSignature(nodes, edges, options = {{}}) {{
      let hash = 2166136261;
      let nodeCount = 0;
      let nodeXor = 0;
      let nodeSum = 0;
      for (const node of (nodes || [])) {{
        if (typeof node.lat !== "number" || typeof node.lon !== "number") continue;
        let itemHash = 2166136261;
        itemHash = hashMixStr(itemHash, normalizeNodeId(node.id));
        itemHash = hashMixInt(itemHash, Math.round(node.lat * 100000));
        itemHash = hashMixInt(itemHash, Math.round(node.lon * 100000));
        nodeXor ^= itemHash;
        nodeSum = (nodeSum + itemHash) >>> 0;
        nodeCount += 1;
      }}
      hash = hashMixInt(hash, nodeCount);
      hash = hashMixInt(hash, nodeXor);
      hash = hashMixInt(hash, nodeSum);

      let edgeCount = 0;
      let edgeXor = 0;
      let edgeSum = 0;
      for (const edge of (edges || [])) {{
        const lifetimeCount = Number(edge && (edge.lifetime_count ?? edge.count ?? 0));
        const lastHops = Number(edge && edge.last_hops);
        const avgSnr = Number(edge && edge.avg_snr);
        const avgRssi = Number(edge && edge.avg_rssi);
        const snrSamples = Number(edge && edge.snr_samples);
        const rssiSamples = Number(edge && edge.rssi_samples);
        let itemHash = 2166136261;
        itemHash = hashMixStr(itemHash, normalizeNodeId(edge && edge.from));
        itemHash = hashMixStr(itemHash, normalizeNodeId(edge && edge.to));
        itemHash = hashMixInt(itemHash, Number.isFinite(lifetimeCount) ? Math.trunc(lifetimeCount) : 0);
        itemHash = hashMixStr(
          itemHash,
          (typeof edgeRxLabel === "function") ? edgeRxLabel(edge, "last", "") : (edge && edge.last_rx_time)
        );
        itemHash = hashMixInt(itemHash, Number.isFinite(lastHops) ? Math.trunc(lastHops) : -1);
        itemHash = hashMixInt(itemHash, Number.isFinite(avgSnr) ? Math.round(avgSnr * 100) : -2147483648);
        itemHash = hashMixInt(itemHash, Number.isFinite(avgRssi) ? Math.round(avgRssi * 100) : -2147483648);
        itemHash = hashMixInt(itemHash, Number.isFinite(snrSamples) ? Math.trunc(snrSamples) : 0);
        itemHash = hashMixInt(itemHash, Number.isFinite(rssiSamples) ? Math.trunc(rssiSamples) : 0);
        itemHash = hashMixInt(itemHash, edge && edge.is_real ? 1 : 0);
        edgeXor ^= itemHash;
        edgeSum = (edgeSum + itemHash) >>> 0;
        edgeCount += 1;
      }}
      hash = hashMixInt(hash, edgeCount);
      hash = hashMixInt(hash, edgeXor);
      hash = hashMixInt(hash, edgeSum);

      let edgeFadeBucketMinutes = 0;
      if (options && options.includeTemporalEdgeFade) {{
        edgeFadeBucketMinutes = Math.floor(Date.now() / 60000);
        hash = hashMixInt(hash, edgeFadeBucketMinutes);
      }}

      return `graph:${{(hash >>> 0).toString(16)}}:${{nodeCount}}:${{edgeCount}}:${{edgeFadeBucketMinutes}}`;
    }}

    function buildMapSignatures(nodes, edges, nodeHistory) {{
      const selection = activeLayoutView === "saved"
        ? resolveSavedViewNodeId(latestState)
        : (isSelectableNodeId(selectedNodeId) ? normalizeNodeId(selectedNodeId) : "");
      const savedSelectionMode = activeLayoutView === "saved" && !!selection;
      const networkSelectionMode = activeLayoutView === "network" && !!selection;

      if (savedSelectionMode) {{
        let hash = 2166136261;
        hash = hashMixStr(hash, "saved");
        hash = hashMixStr(hash, selection);
        const selectedNode = savedViewNodeFrom(nodes, latestState);
        if (
          selectedNode &&
          typeof selectedNode.lat === "number" &&
          typeof selectedNode.lon === "number"
        ) {{
          hash = hashMixInt(hash, Math.round(selectedNode.lat * 100000));
          hash = hashMixInt(hash, Math.round(selectedNode.lon * 100000));
        }} else {{
          hash = hashMixInt(hash, -2147483648);
        }}
        const trailSig = hashTrailSignature(nodeHistory, selection);
        hash = hashMixInt(hash, trailSig.hash);
        hash = hashMixInt(hash, trailSig.count);
        return {{
          signature: `saved:${{(hash >>> 0).toString(16)}}:${{trailSig.hash.toString(16)}}:${{trailSig.count}}`,
          graphSignature: "",
          selection,
          savedSelectionMode: true,
          networkSelectionMode: false,
        }};
      }}

      const graphSignature = buildMapGraphSignature(nodes, edges, {{
        includeTemporalEdgeFade: activeLayoutView === "network" && !!mapPacketLinesEnabled,
      }});
      if (networkSelectionMode) {{
        const trailSig = hashTrailSignature(nodeHistory, selection);
        return {{
          signature: `${{graphSignature}}:network:${{selection}}:${{trailSig.hash.toString(16)}}:${{trailSig.count}}`,
          graphSignature,
          selection,
          savedSelectionMode: false,
          networkSelectionMode: true,
        }};
      }}
      return {{
        signature: `${{graphSignature}}:all`,
        graphSignature,
        selection,
        savedSelectionMode: false,
        networkSelectionMode: false,
      }};
    }}


    function isValidMapCoord(lat, lon) {{
      if (!Number.isFinite(lat) || !Number.isFinite(lon)) return false;
      if (lat < -90 || lat > 90) return false;
      if (lon < -180 || lon > 180) return false;
      // Many devices report (0,0) before GPS lock. Treat that as "unknown" for overview fitting.
      if (Math.abs(lat) < 1e-9 && Math.abs(lon) < 1e-9) return false;
      return true;
    }}

    function collectTrailPoints(nodeHistory, selectionId) {{
      const selection = normalizeNodeId(selectionId || "");
      if (!selection) return [];
      const historyNodeId = normalizeNodeId((nodeHistory && nodeHistory.node_id) || "");
      if (!historyNodeId || historyNodeId !== selection) return [];
      const rawTrail = Array.isArray(nodeHistory && nodeHistory.positions)
        ? nodeHistory.positions
        : [];
      const points = [];
      for (const point of rawTrail) {{
        const lat = Number(point && point.lat);
        const lon = Number(point && point.lon);
        if (!isValidMapCoord(lat, lon)) continue;
        const timeUnix = Number(point && point.time_unix);
        points.push({{
          lat,
          lon,
          time_unix: Number.isFinite(timeUnix) ? Math.round(timeUnix) : null,
          time: point && point.time ? String(point.time) : null,
        }});
      }}
      return points;
    }}

    function collectNodeLatLngs(nodes) {{
      const pts = [];
      for (const node of (nodes || [])) {{
        const lat = Number(node && node.lat);
        const lon = Number(node && node.lon);
        if (!isValidMapCoord(lat, lon)) continue;
        pts.push([lat, lon]);
      }}
      return pts;
    }}

    function computeTrimmedBounds(points, trimFrac = 0.05) {{
      if (!Array.isArray(points) || points.length === 0) return null;
      if (points.length === 1) {{
        return L.latLngBounds(points[0], points[0]);
      }}
      const n = points.length;
      const trimCount = Math.max(0, Math.floor(n * trimFrac));
      const lats = points.map((p) => p[0]).slice().sort((a, b) => a - b);
      const lons = points.map((p) => p[1]).slice().sort((a, b) => a - b);
      const lo = Math.min(trimCount, Math.floor((n - 1) / 2));
      const hi = n - 1 - lo;
      const latMin = lats[lo];
      const latMax = lats[hi];
      const lonMin = lons[lo];
      const lonMax = lons[hi];
      const bounds = L.latLngBounds([latMin, lonMin], [latMax, lonMax]);
      return bounds && bounds.isValid() ? bounds : null;
    }}

    function fitMapToMostNodes(nodes, opts = {{}}) {{
      const points = collectNodeLatLngs(nodes);
      if (!points.length) return false;

      // If we only have one point, zoom in enough to be useful.
      if (points.length === 1) {{
        map.setView(points[0], Math.max(map.getZoom(), 12), {{ animate: false }});
        requestMapResize();
        return true;
      }}

      const trimFrac = points.length >= 14 ? 0.05 : 0;
      let bounds = computeTrimmedBounds(points, trimFrac);
      if (!bounds) {{
        bounds = L.latLngBounds(points);
      }}
      if (!bounds || !bounds.isValid()) return false;

      const pad = Number.isFinite(Number(opts.pad)) ? Number(opts.pad) : 0.18;
      const maxZoom = Number.isFinite(Number(opts.maxZoom)) ? Number(opts.maxZoom) : 13;
      map.fitBounds(bounds.pad(pad), {{ animate: false, maxZoom }});
      requestMapResize();
      return true;
    }}

    function resetMapViewToMostNodes() {{
      if (!map) return false;
      map.closePopup();
      pendingMapHistoryFocus = false;
      if (!latestState) {{
        requestMapResize();
        return false;
      }}
      const nodes = Array.isArray(latestState.nodes) ? latestState.nodes : [];
      return fitMapToMostNodes(nodes, {{ pad: 0.18, maxZoom: 13 }});
    }}

    function clampMapLinkValue(value, min, max) {{
      const parsed = Number(value);
      if (!Number.isFinite(parsed)) return min;
      if (parsed < min) return min;
      if (parsed > max) return max;
      return parsed;
    }}

    function estimatedMarkerStyle(isSelected, confidence = 0.5, isLocal = false) {{
      const safeConfidence = clampMapLinkValue(confidence, 0.12, 0.96);
      if (isLocal) {{
        return {{
          radius: (isSelected ? 8.8 : 6.2) + (safeConfidence * (isSelected ? 0.9 : 1.9)),
          color: isSelected ? "#3f2b8c" : "#5f40c9",
          fillColor: isSelected ? "#efe4ff" : "#ccb8ff",
          fillOpacity: isSelected ? 0.96 : 0.62,
          weight: isSelected ? 2.8 : 2.2,
          dashArray: "5 3",
          bubblingMouseEvents: false,
        }};
      }}
      if (isSelected) {{
        return {{
          radius: 8.4 + (safeConfidence * 0.8),
          color: "#155e75",
          fillColor: "#b6ecff",
          fillOpacity: 0.92,
          weight: 2.4,
          dashArray: "6 4",
          bubblingMouseEvents: false,
        }};
      }}
      return {{
        radius: 5.6 + (safeConfidence * 1.8),
        color: "#1d6f8a",
        fillColor: "#8fd8f5",
        fillOpacity: 0.34 + (safeConfidence * 0.34),
        weight: 1.8,
        dashArray: "5 4",
        bubblingMouseEvents: false,
      }};
    }}

    function isNetworkMapActivityFlashVisible() {{
      return (
        !!mapLiveActivityEnabled
        && activeLayoutView === "network"
        && activeNetworkSubview === "map"
        && !(typeof document !== "undefined" && document.hidden)
      );
    }}

    function mapPacketActivityToken(packetEntry) {{
      const summary = (packetEntry && packetEntry.summary && typeof packetEntry.summary === "object")
        ? packetEntry.summary
        : {{}};
      const packet = (packetEntry && packetEntry.packet && typeof packetEntry.packet === "object")
        ? packetEntry.packet
        : ((packetEntry && typeof packetEntry === "object") ? packetEntry : {{}});
      const decoded = (packet && packet.decoded && typeof packet.decoded === "object")
        ? packet.decoded
        : {{}};
      const fromId = normalizeNodeId(
        summary.from_id
        ?? summary.fromId
        ?? summary.from
        ?? packet.from_id
        ?? packet.fromId
        ?? packet.from
      );
      const toId = normalizeNodeId(
        summary.to_id
        ?? summary.toId
        ?? summary.to
        ?? packet.to_id
        ?? packet.toId
        ?? packet.to
        ?? packet.destination
      );
      const portnum = String(
        summary.portnum
        ?? decoded.portnum
        ?? packet.portnum
        ?? ""
      ).trim().toUpperCase();
      const packetId = parsePositiveMessageId(
        summary.packet_id
        ?? summary.message_id
        ?? packet.id
        ?? packet.packet_id
        ?? packet.message_id
      );
      const packetMs = latestTimestampMs(
        summary.rx_time_unix,
        summary.rx_time,
        summary.captured_at,
        summary.time,
        packetEntry && (packetEntry.captured_at || packetEntry.rx_time || packetEntry.time),
        packet.rxTime,
      );
      if (packetId) {{
        return `id:${{fromId}}|${{toId}}|${{portnum}}|${{packetId}}`;
      }}
      if (Number.isFinite(packetMs) && packetMs > 0) {{
        return `ts:${{fromId}}|${{toId}}|${{portnum}}|${{Math.trunc(packetMs)}}`;
      }}
      return `raw:${{fromId}}|${{toId}}|${{portnum}}|${{JSON.stringify(summary)}}`;
    }}

    function mapPacketActivityNodeIds(packetEntry) {{
      const summary = (packetEntry && packetEntry.summary && typeof packetEntry.summary === "object")
        ? packetEntry.summary
        : {{}};
      const packet = (packetEntry && packetEntry.packet && typeof packetEntry.packet === "object")
        ? packetEntry.packet
        : ((packetEntry && typeof packetEntry === "object") ? packetEntry : {{}});
      const nodeIds = new Set();
      const pushNodeId = (rawValue) => {{
        const normalized = normalizeNodeId(rawValue);
        if (!isSelectableNodeId(normalized)) return;
        nodeIds.add(normalized);
      }};
      pushNodeId(summary.from_id ?? summary.fromId ?? summary.from ?? packet.from_id ?? packet.fromId ?? packet.from);
      pushNodeId(summary.to_id ?? summary.toId ?? summary.to ?? packet.to_id ?? packet.toId ?? packet.to ?? packet.destination);
      return Array.from(nodeIds);
    }}

    function snapshotNetworkMapPacketActivityTokens(state = latestState) {{
      const safeState = (state && typeof state === "object") ? state : {{}};
      const traffic = (safeState.traffic && typeof safeState.traffic === "object")
        ? safeState.traffic
        : {{}};
      const recentPackets = Array.isArray(traffic.recent_packets) ? traffic.recent_packets : [];
      const localNodeId = resolveLocalNodeId(safeState);
      const tokens = new Set();
      for (const packetEntry of recentPackets) {{
        if (!isMeshRadioActivityPacket(packetEntry, localNodeId)) continue;
        tokens.add(mapPacketActivityToken(packetEntry));
      }}
      return tokens;
    }}

    function seedNetworkMapPacketActivityTokens(state = latestState) {{
      lastNetworkMapPacketTokens = snapshotNetworkMapPacketActivityTokens(state);
    }}

    function pruneExpiredMapNodeActivityFlashes(nowMs = Date.now()) {{
      let activeCount = 0;
      for (const [nodeId, flash] of Array.from(mapNodeActivityFlashById.entries())) {{
        const untilMs = Number(flash && flash.untilMs);
        if (!Number.isFinite(untilMs) || untilMs <= nowMs) {{
          mapNodeActivityFlashById.delete(nodeId);
          continue;
        }}
        activeCount += 1;
      }}
      return activeCount;
    }}

    function stopMapNodeActivityFlashLoop() {{
      if (mapNodeActivityFlashRaf != null) {{
        window.cancelAnimationFrame(mapNodeActivityFlashRaf);
        mapNodeActivityFlashRaf = null;
      }}
    }}

    function mapNodeActivityFlashStrength(nodeId, nowMs = Date.now()) {{
      const normalizedId = normalizeNodeId(nodeId || "");
      if (!normalizedId || !isNetworkMapActivityFlashVisible()) return 0;
      const flash = mapNodeActivityFlashById.get(normalizedId);
      if (!(flash && typeof flash === "object")) return 0;
      const startedAtMs = Number(flash.startedAtMs);
      const untilMs = Number(flash.untilMs);
      if (!Number.isFinite(untilMs) || untilMs <= nowMs) {{
        mapNodeActivityFlashById.delete(normalizedId);
        return 0;
      }}
      const durationMs = Math.max(1, untilMs - (Number.isFinite(startedAtMs) ? startedAtMs : (untilMs - 1100)));
      const elapsedMs = Math.max(0, nowMs - (Number.isFinite(startedAtMs) ? startedAtMs : (untilMs - durationMs)));
      const envelope = clampMapLinkValue((untilMs - nowMs) / durationMs, 0, 1);
      const pulsePhase = (elapsedMs % 260) / 260;
      const pulse = 0.35 + (0.65 * (0.5 + (0.5 * Math.cos(pulsePhase * Math.PI * 2))));
      return clampMapLinkValue((0.3 + (pulse * 0.7)) * envelope, 0, 1);
    }}

    function applyMapNodeActivityFlashStyle(baseStyle, flashStrength, markerKind = "actual") {{
      const strength = clampMapLinkValue(flashStrength, 0, 1);
      if (!(strength > 0)) return baseStyle;
      const style = Object.assign({{}}, baseStyle);
      const radiusBase = Number(style.radius);
      const weightBase = Number(style.weight);
      const fillOpacityBase = Number(style.fillOpacity);
      style.radius = (Number.isFinite(radiusBase) ? radiusBase : 6) + ((markerKind === "estimated" ? 1.4 : 1.9) * strength);
      style.weight = (Number.isFinite(weightBase) ? weightBase : 1) + (1.2 * strength);
      style.fillOpacity = clampMapLinkValue((Number.isFinite(fillOpacityBase) ? fillOpacityBase : 0.78) + (0.22 * strength), 0.12, 1);
      style.opacity = clampMapLinkValue(0.78 + (0.22 * strength), 0.12, 1);
      style.color = strength >= 0.52 ? "#9a1f10" : "#c65819";
      style.fillColor = strength >= 0.52 ? "#fff1a3" : "#ffd06a";
      return style;
    }}

    function resolveMapNodeMarkerStyle(nodeId, isSelected, markerKind = "actual", markerConfidence = 0.45, state = latestState) {{
      const kind = markerKind === "estimated" ? "estimated" : "actual";
      const safeState = (state && typeof state === "object") ? state : latestState;
      const localNodeId = normalizeNodeId(resolveLocalNodeId(safeState || {{}}) || "");
      const isLocal = !!(localNodeId && normalizeNodeId(nodeId || "") === localNodeId);
      const baseStyle = kind === "estimated"
        ? estimatedMarkerStyle(isSelected, markerConfidence, isLocal)
        : markerStyle(isSelected || isLocal);
      if (isLocal && kind !== "estimated") {{
        baseStyle.radius = Math.max(Number(baseStyle.radius) || 0, isSelected ? 8.6 : 7.2);
        baseStyle.color = isSelected ? "#3f2b8c" : "#5f40c9";
        baseStyle.fillColor = isSelected ? "#efe4ff" : "#ccb8ff";
        baseStyle.fillOpacity = isSelected ? 0.96 : 0.9;
        baseStyle.weight = Math.max(Number(baseStyle.weight) || 0, isSelected ? 2.8 : 2.1);
      }}
      const flashStrength = mapNodeActivityFlashStrength(nodeId);
      return applyMapNodeActivityFlashStyle(baseStyle, flashStrength, kind);
    }}

    function resolveMapNodeEmoji(nodeId, state = latestState) {{
      const cleanNodeId = normalizeNodeId(nodeId || "");
      if (!cleanNodeId) return "";
      const safeState = (state && typeof state === "object") ? state : latestState;
      const nodes = Array.isArray(safeState && safeState.nodes) ? safeState.nodes : [];
      const node = nodes.find((entry) => normalizeNodeId(entry && entry.id) === cleanNodeId) || null;
      return (typeof nodeVisualEmojiForNode === "function")
        ? nodeVisualEmojiForNode(cleanNodeId, null, node)
        : "";
    }}

    function mapNodeUsesEmojiMarker(nodeId, markerKind = "actual", state = latestState) {{
      if ((markerKind === "estimated" ? "estimated" : "actual") !== "actual") return false;
      return !!resolveMapNodeEmoji(nodeId, state);
    }}

    function mapNodeFieldHtml(label, value, extraClass = "") {{
      const cleanValue = String(value == null ? "" : value).trim() || "n/a";
      return `
        <div class="map-node-info-row${{extraClass ? ` ${{extraClass}}` : ""}}">
          <span class="map-node-info-label">${{escAttr(label)}}</span>
          <span class="map-node-info-value">${{escAttr(cleanValue)}}</span>
        </div>
      `;
    }}

    function buildMapNodeInfoHtml(node, options = null) {{
      const opts = (options && typeof options === "object") ? options : {{}};
      const safeNode = (node && typeof node === "object") ? node : {{}};
      const state = (opts.state && typeof opts.state === "object") ? opts.state : latestState;
      const nowUnix = Number.isFinite(Number(opts.nowUnix))
        ? Math.floor(Number(opts.nowUnix))
        : Math.floor(Date.now() / 1000);
      const normalizedId = normalizeNodeId(opts.nodeId || safeNode.id || "");
      const fallbackId = String(safeNode.id || "").trim();
      const displayId = normalizedId || fallbackId || "n/a";
      const name = String(nodeLabel(safeNode) || displayId).trim() || displayId;
      const emoji = String(opts.emoji != null ? opts.emoji : resolveMapNodeEmoji(displayId, state)).trim();
      const lat = Number(safeNode.lat);
      const lon = Number(safeNode.lon);
      const hasCoords = isValidMapCoord(lat, lon);
      const positionBadge = opts.positionBadge || resolveMapPositionBadge(safeNode, opts.caps || null, nowUnix);
      const lastHeardText = typeof nodeLastHeardLabel === "function"
        ? nodeLastHeardLabel(safeNode, "n/a", nowUnix)
        : String(safeNode.last_heard || "n/a");
      const batteryPct = safeNode.battery_level ?? safeNode.battery ?? safeNode.battery_pct;
      const voltage = safeNode.voltage ?? safeNode.battery_voltage;
      const hops = safeNode.hops_away ?? safeNode.hopsAway;
      const nodeNum = safeNode.num ?? safeNode.node_num;
      const snr = safeNode.snr;
      const rssi = safeNode.rssi;
      const trailCount = Number.isFinite(Number(opts.trailPointsCount))
        ? Math.max(0, Math.trunc(Number(opts.trailPointsCount)))
        : null;
      const trailLatest = String(opts.trailLatest || "").trim();
      const isEstimated = !!opts.isEstimated;
      const confidencePct = Number.isFinite(Number(opts.confidencePct))
        ? Math.round(Number(opts.confidencePct))
        : null;
      const confidenceLabel = String(opts.confidenceLabel || "").trim();
      const qualityPct = Number.isFinite(Number(opts.qualityPct))
        ? Math.round(Number(opts.qualityPct))
        : null;
      const anchorCount = Number.isFinite(Number(opts.anchorCount))
        ? Math.max(0, Math.trunc(Number(opts.anchorCount)))
        : null;
      const supportLinks = Number.isFinite(Number(opts.supportLinks))
        ? Math.max(0, Math.trunc(Number(opts.supportLinks)))
        : null;
      const avgHops = opts.avgHops;
      const avgSnr = opts.avgSnr;
      const avgRssi = opts.avgRssi;

      const headerMeta = [];
      if (emoji) headerMeta.push(`<span class="map-node-info-emoji" aria-hidden="true">${{escAttr(emoji)}}</span>`);
      headerMeta.push(`
        <div class="map-node-info-title-wrap">
          <div class="map-node-info-title">${{escAttr(name)}}</div>
          <div class="map-node-info-subtitle">${{escAttr(displayId)}}</div>
        </div>
      `);

      const rows = [];
      if (nodeNum != null && String(nodeNum).trim()) rows.push(mapNodeFieldHtml("Node Num", nodeNum));
      if (snr != null && String(snr).trim()) rows.push(mapNodeFieldHtml("SNR", snr));
      if (rssi != null && String(rssi).trim()) rows.push(mapNodeFieldHtml("RSSI", rssi));
      if (batteryPct != null && String(batteryPct).trim()) rows.push(mapNodeFieldHtml("Battery", `${{batteryPct}}%`));
      if (voltage != null && String(voltage).trim()) rows.push(mapNodeFieldHtml("Voltage", voltage));
      if (hops != null && String(hops).trim()) rows.push(mapNodeFieldHtml("Hops", hops));
      rows.push(mapNodeFieldHtml("Last Heard", lastHeardText));
      rows.push(`
        <div class="map-node-info-row is-position">
          <span class="map-node-info-label">Position</span>
          <span class="map-node-info-value">
            <span class="map-position-badge ${{escAttr(positionBadge.className || "unknown")}}" title="${{escAttr(positionBadge.title || "")}}">${{escAttr(positionBadge.label || "Unknown")}}</span>
          </span>
        </div>
      `);
      rows.push(mapNodeFieldHtml("Coords", hasCoords ? `${{lat.toFixed(5)}}, ${{lon.toFixed(5)}}` : "No GPS fix"));

      if (trailCount != null) rows.push(mapNodeFieldHtml("Trail Points", trailCount));
      if (trailLatest) rows.push(mapNodeFieldHtml("Trail Latest", trailLatest));

      if (isEstimated) {{
        rows.push(mapNodeFieldHtml("Estimate", "Link-layer derived"));
        if (confidenceLabel || confidencePct != null) {{
          rows.push(mapNodeFieldHtml(
            "Confidence",
            confidencePct != null ? `${{confidenceLabel || "Estimate"}} (${{confidencePct}}%)` : confidenceLabel
          ));
        }}
        if (anchorCount != null) rows.push(mapNodeFieldHtml("Anchors", anchorCount));
        if (supportLinks != null) rows.push(mapNodeFieldHtml("Support Links", supportLinks));
        if (qualityPct != null) rows.push(mapNodeFieldHtml("Link Quality", `${{qualityPct}}%`));
        if (avgHops != null && String(avgHops).trim()) rows.push(mapNodeFieldHtml("Avg Link Hops", avgHops));
        if (avgSnr != null && String(avgSnr).trim()) rows.push(mapNodeFieldHtml("Avg Link SNR", avgSnr));
        if (avgRssi != null && String(avgRssi).trim()) rows.push(mapNodeFieldHtml("Avg Link RSSI", avgRssi));
      }}

      return `
        <div class="map-node-info-card${{isEstimated ? " is-estimated" : ""}}">
          <div class="map-node-info-header">
            ${{headerMeta.join("")}}
          </div>
          <div class="map-node-info-grid">
            ${{rows.join("")}}
          </div>
        </div>
      `;
    }}

    function bindMapNodeInfoOverlays(marker, node, options = null) {{
      if (!(marker && typeof marker.bindPopup === "function")) return;
      const opts = (options && typeof options === "object") ? options : {{}};
      const contentHtml = buildMapNodeInfoHtml(node, opts);
      marker.bindPopup(contentHtml, {{
        closeButton: true,
        autoPan: true,
        className: "map-node-popup",
        maxWidth: 320,
      }});
      if (typeof marker.bindTooltip === "function") {{
        const measureTooltipSize = () => {{
          if (typeof document === "undefined" || !document.body) {{
            return {{ width: 280, height: 220 }};
          }}
          const probe = document.createElement("div");
          probe.className = "map-node-tooltip map-node-tooltip-measure";
          probe.style.position = "fixed";
          probe.style.left = "-10000px";
          probe.style.top = "-10000px";
          probe.style.visibility = "hidden";
          probe.style.pointerEvents = "none";
          probe.innerHTML = `<div class="leaflet-tooltip-content">${{contentHtml}}</div>`;
          document.body.appendChild(probe);
          const rect = probe.getBoundingClientRect();
          probe.remove();
          return {{
            width: Math.max(220, Math.ceil(rect.width) || 280),
            height: Math.max(120, Math.ceil(rect.height) || 220),
          }};
        }};
        const resolveTooltipOptions = () => {{
          const baseOptions = {{
            direction: "top",
            offset: [0, -16],
            opacity: 1,
            sticky: false,
            className: "map-node-tooltip is-top",
          }};
          if (
            typeof map === "undefined"
            || !map
            || typeof map.getSize !== "function"
            || typeof map.latLngToContainerPoint !== "function"
            || typeof marker.getLatLng !== "function"
          ) {{
            return baseOptions;
          }}
          const size = map.getSize();
          const point = map.latLngToContainerPoint(marker.getLatLng());
          const tip = measureTooltipSize();
          const padTop = 14;
          const padRight = 14;
          const padBottom = 14;
          const padLeft = 14;
          const gap = 18;
          const layouts = [
            {{
              direction: "top",
              offset: [0, -16],
              className: "map-node-tooltip is-top",
              left: point.x - (tip.width / 2),
              top: point.y - tip.height - gap,
            }},
            {{
              direction: "bottom",
              offset: [0, 16],
              className: "map-node-tooltip is-bottom",
              left: point.x - (tip.width / 2),
              top: point.y + gap,
            }},
            {{
              direction: "right",
              offset: [16, 0],
              className: "map-node-tooltip is-right",
              left: point.x + gap,
              top: point.y - (tip.height / 2),
            }},
            {{
              direction: "left",
              offset: [-16, 0],
              className: "map-node-tooltip is-left",
              left: point.x - tip.width - gap,
              top: point.y - (tip.height / 2),
            }},
          ];
          const overflowScore = (layout) => {{
            const right = layout.left + tip.width;
            const bottom = layout.top + tip.height;
            const overLeft = Math.max(0, padLeft - layout.left);
            const overTop = Math.max(0, padTop - layout.top);
            const overRight = Math.max(0, right - (size.x - padRight));
            const overBottom = Math.max(0, bottom - (size.y - padBottom));
            return overLeft + overTop + overRight + overBottom;
          }};
          let best = layouts[0];
          let bestScore = Number.POSITIVE_INFINITY;
          for (const layout of layouts) {{
            const score = overflowScore(layout);
            if (score < bestScore) {{
              best = layout;
              bestScore = score;
            }}
            if (score <= 0) {{
              best = layout;
              bestScore = score;
              break;
            }}
          }}
          return Object.assign({{}}, baseOptions, {{
            direction: best.direction,
            offset: best.offset,
            className: best.className,
          }});
        }};
        const rebindTooltip = (openNow = false) => {{
          const tooltipOptions = resolveTooltipOptions();
          if (typeof marker.closeTooltip === "function") {{
            marker.closeTooltip();
          }}
          if (typeof marker.unbindTooltip === "function") {{
            marker.unbindTooltip();
          }}
          marker.bindTooltip(contentHtml, tooltipOptions);
          if (openNow && typeof marker.openTooltip === "function") {{
            marker.openTooltip();
          }}
        }};
        rebindTooltip(false);
        marker.on("mouseover", () => {{
          rebindTooltip(true);
        }});
      }}
    }}

    function buildMapEmojiMarkerIcon(nodeId, isSelected, markerKind = "actual", markerConfidence = 0.45, state = latestState) {{
      if (!mapNodeUsesEmojiMarker(nodeId, markerKind, state)) return null;
      const emoji = resolveMapNodeEmoji(nodeId, state);
      if (!emoji) return null;
      const flashStrength = mapNodeActivityFlashStrength(nodeId);
      const markerClasses = [
        "map-node-emoji-marker",
        isSelected ? "is-selected" : "",
        flashStrength > 0.04 ? "is-active" : "",
      ].filter(Boolean).join(" ");
      const iconSize = isSelected ? 30 : 24;
      const iconAnchor = Math.round(iconSize / 2);
      const popupAnchorY = isSelected ? -16 : -13;
      return L.divIcon({{
        className: "map-node-emoji-icon",
        html: `
          <div
            class="${{markerClasses}}"
            style="--map-node-flash:${{Number(flashStrength.toFixed(3))}};"
          >
            <span class="map-node-emoji-glyph" aria-hidden="true">${{escAttr(emoji)}}</span>
          </div>
        `,
        iconSize: [iconSize, iconSize],
        iconAnchor: [iconAnchor, iconAnchor],
        popupAnchor: [0, popupAnchorY],
      }});
    }}

    function createMapNodeMarker(lat, lon, nodeId, isSelected, markerKind = "actual", markerConfidence = 0.45, state = latestState) {{
      if (mapNodeUsesEmojiMarker(nodeId, markerKind, state)) {{
        return L.marker([lat, lon], {{
          icon: buildMapEmojiMarkerIcon(nodeId, isSelected, markerKind, markerConfidence, state),
          keyboard: false,
          bubblingMouseEvents: false,
          riseOnHover: true,
          zIndexOffset: isSelected ? 200 : 120,
        }});
      }}
      return L.circleMarker(
        [lat, lon],
        resolveMapNodeMarkerStyle(nodeId, isSelected, markerKind, markerConfidence, state)
      );
    }}

    function refreshMapNodeMarkerPresentation(marker, nodeId, isSelected, markerKind = "actual", markerConfidence = 0.45, state = latestState) {{
      if (!(marker && typeof marker === "object")) return;
      if (mapNodeUsesEmojiMarker(nodeId, markerKind, state)) {{
        if (typeof marker.setIcon === "function") {{
          marker.setIcon(buildMapEmojiMarkerIcon(nodeId, isSelected, markerKind, markerConfidence, state));
        }}
        if (typeof marker.setZIndexOffset === "function") {{
          marker.setZIndexOffset(isSelected ? 200 : 120);
        }}
        return;
      }}
      if (typeof marker.setStyle === "function") {{
        marker.setStyle(resolveMapNodeMarkerStyle(
          nodeId,
          isSelected,
          markerKind,
          markerConfidence,
          state
        ));
      }}
    }}

    function scheduleMapNodeActivityFlashUpdate() {{
      if (mapNodeActivityFlashRaf != null) return;
      mapNodeActivityFlashRaf = window.requestAnimationFrame(() => {{
        mapNodeActivityFlashRaf = null;
        const activeCount = pruneExpiredMapNodeActivityFlashes();
        refreshMapMarkerStyles();
        if (!isNetworkMapActivityFlashVisible()) {{
          stopMapNodeActivityFlashLoop();
          return;
        }}
        if (activeCount > 0) {{
          scheduleMapNodeActivityFlashUpdate();
        }}
      }});
    }}

    function syncNetworkMapPacketActivity(state = latestState) {{
      const safeState = (state && typeof state === "object") ? state : {{}};
      const traffic = (safeState.traffic && typeof safeState.traffic === "object")
        ? safeState.traffic
        : {{}};
      const recentPackets = Array.isArray(traffic.recent_packets) ? traffic.recent_packets : [];
      const localNodeId = resolveLocalNodeId(safeState);
      const currentTokens = new Set();
      const nodesToFlash = new Set();
      const networkMapVisible = isNetworkMapActivityFlashVisible();
      for (const packetEntry of recentPackets) {{
        if (!isMeshRadioActivityPacket(packetEntry, localNodeId)) continue;
        const token = mapPacketActivityToken(packetEntry);
        currentTokens.add(token);
        if (!networkMapVisible || lastNetworkMapPacketTokens.has(token)) {{
          continue;
        }}
        const nodeIds = mapPacketActivityNodeIds(packetEntry);
        for (const nodeId of nodeIds) {{
          nodesToFlash.add(nodeId);
        }}
      }}
      lastNetworkMapPacketTokens = currentTokens;
      if (!networkMapVisible || nodesToFlash.size <= 0) {{
        if (!networkMapVisible) {{
          lastNetworkMapPacketTokens = currentTokens;
          mapNodeActivityFlashById.clear();
          stopMapNodeActivityFlashLoop();
        }}
        return;
      }}
      const nowMs = Date.now();
      for (const nodeId of nodesToFlash) {{
        mapNodeActivityFlashById.set(nodeId, {{
          startedAtMs: nowMs,
          untilMs: nowMs + 1100,
        }});
      }}
      scheduleMapNodeActivityFlashUpdate();
    }}

    function mapLinkConfidenceLabel(confidence) {{
      const safeConfidence = clampMapLinkValue(confidence, 0, 1);
      if (safeConfidence >= 0.78) return "High";
      if (safeConfidence >= 0.56) return "Medium";
      return "Low";
    }}

    function projectMapLinkPoint(lat, lon, refLat, refLon) {{
      const metersPerDegLat = 111320;
      const metersPerDegLon = Math.max(
        1,
        Math.cos((Number(refLat || 0) * Math.PI) / 180) * metersPerDegLat
      );
      return {{
        x: (Number(lon) - Number(refLon || 0)) * metersPerDegLon,
        y: (Number(lat) - Number(refLat || 0)) * metersPerDegLat,
      }};
    }}

    function unprojectMapLinkPoint(x, y, refLat, refLon) {{
      const metersPerDegLat = 111320;
      const metersPerDegLon = Math.max(
        1,
        Math.cos((Number(refLat || 0) * Math.PI) / 180) * metersPerDegLat
      );
      return {{
        lat: Number(refLat || 0) + (Number(y) / metersPerDegLat),
        lon: Number(refLon || 0) + (Number(x) / metersPerDegLon),
      }};
    }}

    function mapLinkRecencyScore(lastSeenUnix, nowUnix = Math.floor(Date.now() / 1000)) {{
      const ts = Number(lastSeenUnix);
      if (!Number.isFinite(ts) || ts <= 0) return 0.72;
      const ageSeconds = Math.max(0, nowUnix - ts);
      if (ageSeconds <= (20 * 60)) return 1;
      if (ageSeconds >= (48 * 60 * 60)) return 0.14;
      const span = (48 * 60 * 60) - (20 * 60);
      return clampMapLinkValue(1 - ((ageSeconds - (20 * 60)) / span), 0.14, 1);
    }}

    function mapLinkEdgeSignalScore(edge) {{
      const metrics = [];
      const avgSnr = Number(edge && edge.avgSnr);
      if (Number.isFinite(avgSnr)) {{
        metrics.push([clampMapLinkValue((avgSnr + 18) / 30, 0, 1), 0.42]);
      }}
      const avgRssi = Number(edge && edge.avgRssi);
      if (Number.isFinite(avgRssi)) {{
        metrics.push([clampMapLinkValue((avgRssi + 126) / 40, 0, 1), 0.28]);
      }}
      const avgHops = Number(edge && edge.avgHops);
      const lastHops = Number(edge && edge.lastHops);
      const hopsMetric = Number.isFinite(avgHops) ? avgHops : lastHops;
      if (Number.isFinite(hopsMetric)) {{
        metrics.push([1 - clampMapLinkValue((Math.max(0, hopsMetric) - 1) / 5, 0, 1), 0.18]);
      }}
      const weight = Number(edge && edge.weight);
      const sessionWeight = Number(edge && edge.sessionWeight);
      const countMetric = Math.log10(Math.max(1, (Number.isFinite(weight) ? weight : 0) + (Number.isFinite(sessionWeight) ? sessionWeight : 0)) + 1);
      metrics.push([clampMapLinkValue(countMetric / 2.5, 0.08, 1), 0.12]);

      let weightedTotal = 0;
      let totalWeight = 0;
      for (const [value, weightValue] of metrics) {{
        weightedTotal += value * weightValue;
        totalWeight += weightValue;
      }}
      const baseScore = totalWeight > 0 ? (weightedTotal / totalWeight) : 0.42;
      const recency = mapLinkRecencyScore(edge && edge.lastSeenUnix);
      return clampMapLinkValue((baseScore * 0.84) + (recency * 0.16), 0.08, 0.98);
    }}

    function mapLinkDesiredDistanceMeters(edge) {{
      const quality = mapLinkEdgeSignalScore(edge);
      const avgHops = Number(edge && edge.avgHops);
      const lastHops = Number(edge && edge.lastHops);
      const hopMetric = Number.isFinite(avgHops)
        ? avgHops
        : (Number.isFinite(lastHops) ? lastHops : 1);
      const hopPenaltyMeters = Math.max(0, hopMetric - 1) * 2800;
      return Math.round(900 + ((1 - quality) * 17000) + hopPenaltyMeters);
    }}

    function buildMapLinkLayerOverlay(nodes, rawEdges, options = null) {{
      const opts = (options && typeof options === "object") ? options : {{}};
      const edgeMode = (typeof normalizeMapLinkLayerMode === "function")
        ? normalizeMapLinkLayerMode(opts.mode)
        : "both";
      const nodeMap = new Map();
      let anchorLatTotal = 0;
      let anchorLonTotal = 0;
      let anchorCount = 0;

      for (const node of (nodes || [])) {{
        const nodeId = normalizeNodeId(node && node.id);
        if (!isSelectableNodeId(nodeId) || nodeMap.has(nodeId)) continue;
        nodeMap.set(nodeId, node);
        const lat = Number(node && node.lat);
        const lon = Number(node && node.lon);
        if (!isValidMapCoord(lat, lon)) continue;
        anchorLatTotal += lat;
        anchorLonTotal += lon;
        anchorCount += 1;
      }}
      if (!nodeMap.size || anchorCount <= 0) {{
        return {{ estimates: new Map(), lines: [] }};
      }}

      const refLat = anchorLatTotal / anchorCount;
      const refLon = anchorLonTotal / anchorCount;
      const positions = new Map();
      const metaById = new Map();
      for (const [nodeId, node] of nodeMap.entries()) {{
        const lat = Number(node && node.lat);
        const lon = Number(node && node.lon);
        if (!isValidMapCoord(lat, lon)) continue;
        const point = projectMapLinkPoint(lat, lon, refLat, refLon);
        positions.set(nodeId, {{
          x: point.x,
          y: point.y,
          fixed: true,
        }});
        metaById.set(nodeId, {{
          anchorIds: new Set([nodeId]),
          supportLinks: 0,
          confidence: 1,
          seedX: point.x,
          seedY: point.y,
        }});
      }}

      const safeRawEdges = Array.isArray(rawEdges) ? rawEdges : [];
      const liveRawEdges = (typeof filterNetworkGraphRawEdgesByMode === "function")
        ? filterNetworkGraphRawEdgesByMode(safeRawEdges, "live")
        : safeRawEdges.filter((edge) => {{
            const sessionCount = Number(edge && (edge.session_count ?? edge.count ?? 0));
            return Number.isFinite(sessionCount) && sessionCount > 0;
          }});
      const seedRawEdges = edgeMode === "live" ? liveRawEdges : safeRawEdges;
      const combinedEdges = (typeof combineNetworkGraphEdges === "function")
        ? combineNetworkGraphEdges(seedRawEdges, nodeMap, {{ mode: edgeMode === "live" ? "live" : "history" }})
        : [];
      if (!combinedEdges.length) {{
        return {{ estimates: new Map(), lines: [] }};
      }}
      const adjacency = (typeof buildNetworkGraphAdjacency === "function")
        ? buildNetworkGraphAdjacency(nodeMap, combinedEdges)
        : new Map();
      const unresolvedIds = Array.from(nodeMap.keys()).filter((nodeId) => !positions.has(nodeId));
      const maxSeedPasses = Math.max(2, unresolvedIds.length + 1);

      for (let pass = 0; pass < maxSeedPasses; pass += 1) {{
        let progressed = false;
        for (const nodeId of unresolvedIds) {{
          if (positions.has(nodeId)) continue;
          const peers = adjacency.get(nodeId) || new Map();
          let totalWeight = 0;
          let sumX = 0;
          let sumY = 0;
          let supportLinks = 0;
          const anchorIds = new Set();

          for (const [peerId, edge] of peers.entries()) {{
            const peerPos = positions.get(peerId);
            const peerMeta = metaById.get(peerId) || null;
            if (!peerPos || !peerMeta) continue;
            let weight = mapLinkEdgeSignalScore(edge);
            if (!peerPos.fixed) {{
              weight *= 0.58 * clampMapLinkValue(peerMeta.confidence, 0.12, 1);
            }}
            if (!(weight > 0)) continue;
            totalWeight += weight;
            sumX += peerPos.x * weight;
            sumY += peerPos.y * weight;
            supportLinks += 1;
            for (const anchorId of (peerMeta.anchorIds || [])) {{
              anchorIds.add(anchorId);
            }}
          }}

          if (!(totalWeight > 0) || !anchorIds.size) continue;
          const seedX = sumX / totalWeight;
          const seedY = sumY / totalWeight;
          const avgWeight = totalWeight / Math.max(1, supportLinks);
          positions.set(nodeId, {{ x: seedX, y: seedY, fixed: false }});
          metaById.set(nodeId, {{
            anchorIds,
            supportLinks,
            confidence: clampMapLinkValue(
              0.16
                + (avgWeight * 0.42)
                + Math.min(0.24, anchorIds.size * 0.08)
                + Math.min(0.12, supportLinks * 0.035),
              0.12,
              0.92
            ),
            seedX,
            seedY,
          }});
          progressed = true;
        }}
        if (!progressed) break;
      }}

      const movableIds = Array.from(positions.entries())
        .filter((entry) => entry[1] && !entry[1].fixed)
        .map((entry) => entry[0]);
      const positionedIds = Array.from(positions.keys());
      const repelRadius = 14000;
      const repelRadiusSq = repelRadius * repelRadius;

      for (let iter = 0; iter < 56 && movableIds.length > 0; iter += 1) {{
        const deltas = new Map(movableIds.map((nodeId) => [nodeId, {{ x: 0, y: 0 }}]));

        for (const edge of combinedEdges) {{
          const fromPos = positions.get(edge.a);
          const toPos = positions.get(edge.b);
          if (!fromPos || !toPos) continue;
          const dx = toPos.x - fromPos.x;
          const dy = toPos.y - fromPos.y;
          const distance = Math.hypot(dx, dy) || 1;
          const desired = mapLinkDesiredDistanceMeters(edge);
          const stiffness = 0.032 + (mapLinkEdgeSignalScore(edge) * 0.045);
          const delta = (distance - desired) * stiffness;
          const unitX = dx / distance;
          const unitY = dy / distance;
          if (!fromPos.fixed && deltas.has(edge.a)) {{
            const next = deltas.get(edge.a);
            next.x += unitX * delta;
            next.y += unitY * delta;
          }}
          if (!toPos.fixed && deltas.has(edge.b)) {{
            const next = deltas.get(edge.b);
            next.x -= unitX * delta;
            next.y -= unitY * delta;
          }}
        }}

        for (const nodeId of movableIds) {{
          const delta = deltas.get(nodeId);
          const nodePos = positions.get(nodeId);
          if (!delta || !nodePos) continue;
          for (const otherId of positionedIds) {{
            if (otherId === nodeId) continue;
            const otherPos = positions.get(otherId);
            if (!otherPos) continue;
            const dx = nodePos.x - otherPos.x;
            const dy = nodePos.y - otherPos.y;
            const distSq = (dx * dx) + (dy * dy);
            if (!(distSq > 1) || distSq > repelRadiusSq) continue;
            const distance = Math.sqrt(distSq);
            const push = ((repelRadius - distance) / repelRadius) * (otherPos.fixed ? 220 : 120);
            delta.x += (dx / distance) * push;
            delta.y += (dy / distance) * push;
          }}

          const meta = metaById.get(nodeId) || null;
          if (meta) {{
            delta.x += (meta.seedX - nodePos.x) * 0.06;
            delta.y += (meta.seedY - nodePos.y) * 0.06;
          }}
        }}

        const maxStep = Math.max(260, 1750 - (iter * 18));
        for (const nodeId of movableIds) {{
          const delta = deltas.get(nodeId);
          const nodePos = positions.get(nodeId);
          if (!delta || !nodePos) continue;
          nodePos.x += clampMapLinkValue(delta.x, -maxStep, maxStep);
          nodePos.y += clampMapLinkValue(delta.y, -maxStep, maxStep);
        }}
      }}

      const estimates = new Map();
      for (const nodeId of movableIds) {{
        const nodePos = positions.get(nodeId);
        const meta = metaById.get(nodeId) || null;
        if (!nodePos || !meta) continue;
        const ll = unprojectMapLinkPoint(nodePos.x, nodePos.y, refLat, refLon);
        if (!isValidMapCoord(ll.lat, ll.lon)) continue;

        let qualitySum = 0;
        let qualityCount = 0;
        let snrWeight = 0;
        let snrSum = 0;
        let rssiWeight = 0;
        let rssiSum = 0;
        let hopsWeight = 0;
        let hopsSum = 0;
        const peers = adjacency.get(nodeId) || new Map();
        for (const edge of peers.values()) {{
          const quality = mapLinkEdgeSignalScore(edge);
          qualitySum += quality;
          qualityCount += 1;
          if (Number.isFinite(Number(edge && edge.avgSnr))) {{
            snrSum += Number(edge.avgSnr) * quality;
            snrWeight += quality;
          }}
          if (Number.isFinite(Number(edge && edge.avgRssi))) {{
            rssiSum += Number(edge.avgRssi) * quality;
            rssiWeight += quality;
          }}
          if (Number.isFinite(Number(edge && edge.avgHops))) {{
            hopsSum += Number(edge.avgHops) * quality;
            hopsWeight += quality;
          }}
        }}

        estimates.set(nodeId, {{
          lat: ll.lat,
          lon: ll.lon,
          confidence: meta.confidence,
          anchorCount: meta.anchorIds.size,
          supportLinks: meta.supportLinks,
          avgLinkQuality: qualityCount > 0 ? (qualitySum / qualityCount) : 0,
          avgSnr: snrWeight > 0 ? Math.round((snrSum / snrWeight) * 100) / 100 : null,
          avgRssi: rssiWeight > 0 ? Math.round((rssiSum / rssiWeight) * 100) / 100 : null,
          avgHops: hopsWeight > 0 ? Math.round((hopsSum / hopsWeight) * 100) / 100 : null,
        }});
      }}

      const historyCombinedEdges = (typeof combineNetworkGraphEdges === "function")
        ? combineNetworkGraphEdges(safeRawEdges, nodeMap, {{ mode: "history" }})
        : combinedEdges;
      const liveCombinedEdges = (typeof combineNetworkGraphEdges === "function")
        ? combineNetworkGraphEdges(liveRawEdges, nodeMap, {{ mode: "live" }})
        : [];
      const lineGroups = [];
      if (edgeMode === "history" || edgeMode === "both") {{
        lineGroups.push(["history", historyCombinedEdges]);
      }}
      if (edgeMode === "live" || edgeMode === "both") {{
        lineGroups.push(["live", liveCombinedEdges]);
      }}

      const lines = [];
      for (const [lineMode, edgeList] of lineGroups) {{
        for (const edge of edgeList) {{
        const fromPos = positions.get(edge.a);
        const toPos = positions.get(edge.b);
        if (!fromPos || !toPos) continue;
        const estimatedEndpoints = (fromPos.fixed ? 0 : 1) + (toPos.fixed ? 0 : 1);
        if (estimatedEndpoints <= 0) continue;

        const fromNode = nodeMap.get(edge.a) || null;
        const toNode = nodeMap.get(edge.b) || null;
        const fromLat = fromPos.fixed ? Number(fromNode && fromNode.lat) : Number((estimates.get(edge.a) || {{}}).lat);
        const fromLon = fromPos.fixed ? Number(fromNode && fromNode.lon) : Number((estimates.get(edge.a) || {{}}).lon);
        const toLat = toPos.fixed ? Number(toNode && toNode.lat) : Number((estimates.get(edge.b) || {{}}).lat);
        const toLon = toPos.fixed ? Number(toNode && toNode.lon) : Number((estimates.get(edge.b) || {{}}).lon);
        if (!isValidMapCoord(fromLat, fromLon) || !isValidMapCoord(toLat, toLon)) continue;

        lines.push({{
          key: `${{lineMode}}::${{edge.a}}::${{edge.b}}`,
          mode: lineMode,
          fromId: edge.a,
          toId: edge.b,
          fromLat,
          fromLon,
          toLat,
          toLon,
          estimatedEndpoints,
          qualityScore: mapLinkEdgeSignalScore(edge),
          desiredDistanceKm: Math.round((mapLinkDesiredDistanceMeters(edge) / 1000) * 10) / 10,
          lastSeenUnix: Number(edge && edge.lastSeenUnix) || 0,
          isReal: !!edge.isReal,
          weight: Number(edge && edge.weight) || 0,
          sessionWeight: Number(edge && edge.sessionWeight) || 0,
          avgHops: Number.isFinite(Number(edge && edge.avgHops)) ? Number(edge.avgHops) : null,
          avgSnr: Number.isFinite(Number(edge && edge.avgSnr)) ? Number(edge.avgSnr) : null,
          avgRssi: Number.isFinite(Number(edge && edge.avgRssi)) ? Number(edge.avgRssi) : null,
        }});
      }}
      }}

      return {{ estimates, lines }};
    }}

    function getNetworkMapFullscreenTarget() {{
      const root = document.getElementById("network-map-subviews");
      if (root instanceof HTMLElement) return root;
      return mapFrameElement instanceof HTMLElement ? mapFrameElement : null;
    }}

    function getActiveFullscreenElement() {{
      return document.fullscreenElement || document.webkitFullscreenElement || null;
    }}

    function isNetworkMapFullscreenActive(target = getNetworkMapFullscreenTarget()) {{
      const fullscreenElement = getActiveFullscreenElement();
      return !!(target instanceof HTMLElement && fullscreenElement === target);
    }}

    function networkMapFullscreenSupported(target = getNetworkMapFullscreenTarget()) {{
      if (!(target instanceof HTMLElement)) return false;
      const canRequest = (
        typeof target.requestFullscreen === "function"
        || typeof target.webkitRequestFullscreen === "function"
      );
      const documentAllowsFullscreen = (
        document.fullscreenEnabled !== false
        && document.webkitFullscreenEnabled !== false
      );
      return canRequest && documentAllowsFullscreen;
    }}

    function updateMapFullscreenControl(viewName = activeLayoutView, subviewName = activeNetworkSubview) {{
      const btn = document.getElementById("map-fullscreen-toggle-btn");
      if (!(btn instanceof HTMLButtonElement)) return;
      const target = getNetworkMapFullscreenTarget();
      const supported = networkMapFullscreenSupported(target);
      const active = isNetworkMapFullscreenActive(target);
      const normalizedView = (typeof normalizeLayoutView === "function")
        ? normalizeLayoutView(viewName)
        : String(viewName || "").trim().toLowerCase();
      const normalizedSubview = (typeof normalizeNetworkSubview === "function")
        ? normalizeNetworkSubview(subviewName)
        : String(subviewName || "map").trim().toLowerCase();
      const showControl = supported && (active || (normalizedView === "network" && normalizedSubview === "map"));
      btn.hidden = !showControl;
      btn.disabled = !supported;
      btn.classList.toggle("is-active", active);
      btn.setAttribute("aria-pressed", active ? "true" : "false");
      const label = active ? "Exit full screen map" : "Enter full screen map";
      btn.setAttribute("aria-label", label);
      btn.title = label;
      if (target instanceof HTMLElement) {{
        target.classList.toggle("is-fullscreen", active);
      }}
    }}

    function requestNetworkMapFullscreenResize() {{
      if (typeof requestMapResizeStabilized === "function") {{
        requestMapResizeStabilized();
      }} else if (typeof requestMapResize === "function") {{
        requestMapResize();
      }}
    }}

    async function toggleNetworkMapFullscreen() {{
      const target = getNetworkMapFullscreenTarget();
      if (!(target instanceof HTMLElement) || !networkMapFullscreenSupported(target)) return;
      try {{
        if (isNetworkMapFullscreenActive(target)) {{
          if (typeof document.exitFullscreen === "function") {{
            await document.exitFullscreen();
          }} else if (typeof document.webkitExitFullscreen === "function") {{
            await document.webkitExitFullscreen();
          }}
        }} else if (typeof target.requestFullscreen === "function") {{
          await target.requestFullscreen();
        }} else if (typeof target.webkitRequestFullscreen === "function") {{
          await target.webkitRequestFullscreen();
        }}
      }} catch (reason) {{
        console.warn("Unable to toggle map fullscreen", reason);
      }} finally {{
        updateMapFullscreenControl();
        requestNetworkMapFullscreenResize();
      }}
    }}

    function bindMapFullscreenControl() {{
      const btn = document.getElementById("map-fullscreen-toggle-btn");
      if (!(btn instanceof HTMLButtonElement)) return;
      if (btn.dataset.bound !== "1") {{
        btn.dataset.bound = "1";
        btn.addEventListener("click", (ev) => {{
          ev.preventDefault();
          void toggleNetworkMapFullscreen();
        }});
      }}
      if (document.documentElement && document.documentElement.dataset.mapFullscreenBound !== "1") {{
        document.documentElement.dataset.mapFullscreenBound = "1";
        document.addEventListener("fullscreenchange", () => {{
          updateMapFullscreenControl();
          requestNetworkMapFullscreenResize();
        }});
        document.addEventListener("webkitfullscreenchange", () => {{
          updateMapFullscreenControl();
          requestNetworkMapFullscreenResize();
        }});
      }}
      updateMapFullscreenControl();
    }}

    function bindMapResetControl() {{
      const btn = document.getElementById("map-reset-view-btn");
      if (!(btn instanceof HTMLButtonElement) || btn.dataset.bound === "1") return;
      btn.dataset.bound = "1";
      btn.addEventListener("click", () => {{
        resetMapViewToMostNodes();
      }});
    }}

    function resolveMapPositionBadge(node, caps = null, nowUnix = Math.floor(Date.now() / 1000)) {{
      const lat = Number(node && node.lat);
      const lon = Number(node && node.lon);
      if (!isValidMapCoord(lat, lon)) {{
        return {{
          label: "No Position",
          className: "unknown",
          title: "No usable position is available for this node.",
        }};
      }}

      const heardRaw = Number(node && node.last_heard_unix);
      const heardUnix = Number.isFinite(heardRaw) && heardRaw > 0
        ? Math.trunc(heardRaw)
        : null;
      const capsPosRaw = Number(caps && caps.last_position_unix);
      const capsPosUnix = Number.isFinite(capsPosRaw) && capsPosRaw > 0
        ? Math.trunc(capsPosRaw)
        : null;

      const heardAgeSeconds = Number.isFinite(heardUnix)
        ? Math.max(0, nowUnix - heardUnix)
        : null;
      const recentlyHeard = Number.isFinite(heardAgeSeconds) && heardAgeSeconds <= chatWarnWindowSeconds;
      const positionNearLastHeard = Number.isFinite(heardUnix)
        && Number.isFinite(capsPosUnix)
        && Math.abs(heardUnix - capsPosUnix) <= 120;
      const positionRecentlyUpdated = Number.isFinite(capsPosUnix)
        && (nowUnix - capsPosUnix) <= chatWarnWindowSeconds;

      if (positionNearLastHeard || (recentlyHeard && (positionRecentlyUpdated || !Number.isFinite(capsPosUnix)))) {{
        return {{
          label: "Live GPS",
          className: "live",
          title: "Position appears to be from a recent live GPS update.",
        }};
      }}

      return {{
        label: "History/Fixed",
        className: "history",
        title: "Position appears to be fixed or from an older saved location.",
      }};
    }}
