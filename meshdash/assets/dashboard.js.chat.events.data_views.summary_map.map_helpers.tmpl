          currentByKey.set(point.key, point);
        }}
      }}
      const maxDriftMeters = Number.isFinite(Number(opts.maxDriftMeters))
        ? Math.max(0, Number(opts.maxDriftMeters))
        : mapEstimatedOverlayMaxDriftMeters;
      const matchedKeys = new Set();
      const transitions = [];
      for (const targetPoint of targetPoints) {{
        const matchedPoint = currentByKey.get(targetPoint.key) || null;
        const startPoint = matchedPoint || {{
          lat: targetPoint.lat,
          lon: targetPoint.lon,
          intensity: 0,
          key: targetPoint.key,
        }};
        matchedKeys.add(targetPoint.key);
        const driftMeters = matchedPoint ? mapHeatPointDistanceMeters(matchedPoint, targetPoint) : 0;
        if (matchedPoint && (!Number.isFinite(driftMeters) || driftMeters > maxDriftMeters)) {{
          transitions.push({{
            key: `${{targetPoint.key}}:out`,
            from: matchedPoint,
            to: {{
              lat: matchedPoint.lat,
              lon: matchedPoint.lon,
              intensity: 0,
              key: `${{targetPoint.key}}:out`,
            }},
          }});
          transitions.push({{
            key: `${{targetPoint.key}}:in`,
            from: {{
              lat: targetPoint.lat,
              lon: targetPoint.lon,
              intensity: 0,
              key: `${{targetPoint.key}}:in`,
            }},
            to: targetPoint,
          }});
          continue;
        }}
        transitions.push({{
          key: targetPoint.key,
          from: startPoint,
          to: targetPoint,
        }});
      }}
      for (const currentPoint of currentPoints) {{
        if (matchedKeys.has(currentPoint.key)) continue;
        if (!(Number(currentPoint.intensity) > mapHeatLayerDriftMinIntensity)) continue;
        transitions.push({{
          key: currentPoint.key,
          from: currentPoint,
          to: {{
            lat: currentPoint.lat,
            lon: currentPoint.lon,
            intensity: 0,
            key: currentPoint.key,
          }},
        }});
      }}
      if (!transitions.length) {{
        cancelMapHeatLayerDrift(layer);
        layer._meshHeatCurrentPoints = targetPoints;
        layer.setLatLngs(mapHeatPointsToLatLngArrays(targetPoints));
        if (onComplete) {{
          onComplete(layer);
        }}
        return true;
      }}

      cancelMapHeatLayerDrift(layer);
      const startedAtMs = mapAnimationNowMs();
      const state = {{
        raf: null,
        startedAtMs,
        durationMs,
        transitions,
        onComplete,
        fadeOut: !!opts.fadeOut,
      }};
      const step = (timestampMs) => {{
        const layerStillVisible = !map || typeof map.hasLayer !== "function" || map.hasLayer(layer);
        if (!layerStillVisible) {{
          cancelMapHeatLayerDrift(layer);
          return;
        }}
        const elapsedMs = Math.max(0, Number(timestampMs) - state.startedAtMs);
        const eased = mapDriftEase(elapsedMs / state.durationMs);
        const framePoints = [];
        for (const transition of state.transitions) {{
          const fromPoint = transition.from || {{}};
          const toPoint = transition.to || fromPoint;
          const intensity = Number(fromPoint.intensity) + ((Number(toPoint.intensity) - Number(fromPoint.intensity)) * eased);
          if (!(intensity > mapHeatLayerDriftMinIntensity)) continue;
          framePoints.push({{
            key: transition.key,
            lat: Number(fromPoint.lat) + ((Number(toPoint.lat) - Number(fromPoint.lat)) * eased),
            lon: Number(fromPoint.lon) + ((Number(toPoint.lon) - Number(fromPoint.lon)) * eased),
            intensity: clampMapLinkValue(intensity, 0, 1),
          }});
        }}
        layer._meshHeatCurrentPoints = framePoints;
        layer.setLatLngs(mapHeatPointsToLatLngArrays(framePoints));
        if (eased < 1) {{
          state.raf = window.requestAnimationFrame(step);
          return;
        }}
        layer._meshHeatCurrentPoints = targetPoints;
        layer.setLatLngs(mapHeatPointsToLatLngArrays(targetPoints));
        layer._meshHeatDriftAnimation = null;
        if (state.onComplete) {{
          state.onComplete(layer);
        }}
      }};
      layer._meshHeatDriftAnimation = state;
      state.raf = window.requestAnimationFrame(step);
      return true;
    }}

