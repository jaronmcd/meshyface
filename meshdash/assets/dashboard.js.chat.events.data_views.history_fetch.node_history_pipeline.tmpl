    function reportHistoryViewRenderFailure(label, err) {{
      if (typeof console !== "undefined" && console && typeof console.error === "function") {{
        console.error("Node history render failed:", label || "unknown step", err);
      }}
    }}

    function runHistoryViewRenderStep(label, renderFn) {{
      try {{
        return {{
          ok: true,
          result: typeof renderFn === "function" ? renderFn() : undefined,
          error: null,
        }};
      }} catch (err) {{
        reportHistoryViewRenderFailure(label, err);
        return {{
          ok: false,
          result: null,
          error: err,
        }};
      }}
    }}

    function resetNodeHistoryChartState(svgId, emptyId, emptyMessage, timelineId, timelineMessage) {{
      const svg = document.getElementById(String(svgId || "").trim());
      if (svg instanceof SVGElement) {{
        svg.innerHTML = "";
        svg.classList.remove("zoomed", "chart-dragging");
      }}
      const empty = document.getElementById(String(emptyId || "").trim());
      if (empty instanceof HTMLElement) {{
        empty.hidden = false;
        empty.textContent = String(emptyMessage || "").trim();
      }}
      if (timelineId) {{
        setTimelineMessage(
          timelineId,
          String(timelineMessage || "Timeline unavailable while re-rendering history.").trim()
        );
      }}
    }}

    function renderNodeNameHistoryPanel(entries, options = null) {{
      const host = document.getElementById("node-name-history-host");
      if (!(host instanceof HTMLElement)) return;
      const opts = (options && typeof options === "object") ? options : {{}};
      host.innerHTML = nodeDetailsNameHistorySectionHtml(entries, {{
        loading: opts.loading === true,
        maxRows: Number.isFinite(Number(opts.maxRows)) ? Math.max(1, Math.trunc(Number(opts.maxRows))) : 24,
        title: opts.title || "Name History",
        emptyMessage: opts.emptyMessage || "No saved name updates yet.",
        noteText: opts.noteText || "",
      }});
    }}

    function renderNodeHistoryOverviewPanel(history, options = null) {{
      const host = document.getElementById("node-history-overview-host");
      if (!(host instanceof HTMLElement)) return;
      const opts = (options && typeof options === "object") ? options : {{}};
      host.innerHTML = savedNodeHistoryOverviewSectionHtml(history, {{
        loading: opts.loading === true,
        title: opts.title || "History",
        noteText: opts.noteText || "",
        defaultWindowHours: Number.isFinite(Number(opts.defaultWindowHours))
          ? Math.max(1, Math.trunc(Number(opts.defaultWindowHours)))
          : nodeHistoryHours,
      }});
    }}

    function renderNodeHistoryUnavailable(nodeId, reason = "") {{
      setMapDataMode("node");
      syncNodeHistoryDock();
      const normalizedNodeId = normalizeNodeId(nodeId || "");
      const caption = document.getElementById("node-history-caption");
      if (caption) {{
        const suffix = String(reason || "").trim();
        caption.textContent = suffix
          ? `Unable to render history for ${{normalizedNodeId || "this node"}} right now. ${{suffix}}`
          : `Unable to render history for ${{normalizedNodeId || "this node"}} right now.`;
      }}
      resetNodeHistoryChartState(
        "signal-chart",
        "signal-empty",
        "Signal history is temporarily unavailable for this node.",
        "signal-timeline",
        "Timeline unavailable while re-rendering signal history."
      );
      resetNodeHistoryChartState(
        "node-link-quality-chart",
        "node-link-quality-empty",
        "Link-quality history is temporarily unavailable for this node.",
        "node-link-quality-timeline",
        "Timeline unavailable while re-rendering link-quality history."
      );
      resetNodeHistoryChartState(
        "node-online-chart",
        "node-online-empty",
        "Online history is temporarily unavailable for this node.",
        "node-online-timeline",
        "Timeline unavailable while re-rendering online history."
      );
      resetNodeHistoryChartState(
        "node-packets-chart",
        "node-packets-empty",
        "Packet history is temporarily unavailable for this node.",
        "node-packets-timeline",
        "Timeline unavailable while re-rendering packet history."
      );
      renderNodeNameHistoryPanel([], {{
        emptyMessage: "Name history is temporarily unavailable for this node.",
        noteText: String(reason || "").trim() || "Reselect the node to retry.",
      }});
      renderNodeHistoryOverviewPanel(null, {{
        noteText: String(reason || "").trim() || "Reselect the node to retry.",
        defaultWindowHours: nodeHistoryHours,
      }});
    }}

    function renderNodeHistory(history, nodes) {{
      setMapDataMode("node");
      const historyNodeId = normalizeNodeId(history.node_id || "");
      const node = (nodes || []).find((entry) => normalizeNodeId(entry && entry.id) === historyNodeId) || null;
      const signalSource = String(history && history.signal_source ? history.signal_source : "").trim().toLowerCase();
      const signalPoints = Array.isArray(history && history.signal_points)
        ? history.signal_points
        : (history.points || []);
      const nameHistoryEntries = Array.isArray(history && history.name_history)
        ? history.name_history
        : [];
      const caption = document.getElementById("node-history-caption");
      if (caption) {{
        const name = node ? nodeLabel(node) : (historyNodeId || "node");
        const span = history.summary || {{}};
        const trailPoints = Number.isFinite(Number(span.trail_points))
          ? Number(span.trail_points)
          : (Array.isArray(history.positions) ? history.positions.length : 0);
        const loc = (node && typeof node.lat === "number" && typeof node.lon === "number")
          ? `Current location: ${{node.lat.toFixed(5)}}, ${{node.lon.toFixed(5)}}.`
          : "No current location available from live node state.";
        const signalNote = signalSource === "local-radio"
          ? " Signal plot uses packets heard by this radio."
          : "";
        caption.textContent = `${{name}} (${{historyNodeId || "n/a"}}). ${{loc}} History window: ${{history.window_hours || nodeHistoryHours}}h, packets: ${{span.total_packets ?? 0}}, trail points: ${{trailPoints}}.${{signalNote}}`;
      }}
      const signalRendered = runHistoryViewRenderStep("signal chart", () => {{
        renderSignalChart(signalPoints);
      }});
      if (!signalRendered.ok) {{
        resetNodeHistoryChartState(
          "signal-chart",
          "signal-empty",
          "Signal history is temporarily unavailable for this node.",
          "signal-timeline",
          "Timeline unavailable while re-rendering signal history."
        );
      }}
      const linkQualityRendered = runHistoryViewRenderStep("link quality chart", () => {{
        renderNodeLinkQualityChart(signalPoints, historyNodeId);
      }});
      if (!linkQualityRendered.ok) {{
        resetNodeHistoryChartState(
          "node-link-quality-chart",
          "node-link-quality-empty",
          "Link-quality history is temporarily unavailable for this node.",
          "node-link-quality-timeline",
          "Timeline unavailable while re-rendering link-quality history."
        );
      }}
      const onlineRendered = runHistoryViewRenderStep("online chart", () => {{
        renderNodeOnlineChart(
          history.points || [],
          history.window_hours,
          Array.isArray(history.packet_timestamps) ? history.packet_timestamps : [],
          historyNodeId
        );
      }});
      if (!onlineRendered.ok) {{
        resetNodeHistoryChartState(
          "node-online-chart",
          "node-online-empty",
          "Online history is temporarily unavailable for this node.",
          "node-online-timeline",
          "Timeline unavailable while re-rendering online history."
        );
      }}
      const packetsRendered = runHistoryViewRenderStep("packets chart", () => {{
        renderNodePacketsChart(
          history.points || [],
          history.window_hours,
          historyNodeId,
          (history && typeof history.packet_series === "object") ? history.packet_series : null
        );
      }});
      if (!packetsRendered.ok) {{
        resetNodeHistoryChartState(
          "node-packets-chart",
          "node-packets-empty",
          "Packet history is temporarily unavailable for this node.",
          "node-packets-timeline",
          "Timeline unavailable while re-rendering packet history."
        );
      }}
      const namesRendered = runHistoryViewRenderStep("name history", () => {{
        renderNodeNameHistoryPanel(nameHistoryEntries);
      }});
      if (!namesRendered.ok) {{
        renderNodeNameHistoryPanel([], {{
          emptyMessage: "Name history is temporarily unavailable for this node.",
          noteText: "Reselect the node to retry.",
        }});
      }}
      const overviewRendered = runHistoryViewRenderStep("history overview", () => {{
        renderNodeHistoryOverviewPanel(history, {{
          defaultWindowHours: nodeHistoryHours,
        }});
      }});
      if (!overviewRendered.ok) {{
        renderNodeHistoryOverviewPanel(null, {{
          noteText: "Reselect the node to retry.",
          defaultWindowHours: nodeHistoryHours,
        }});
      }}
      setHistoryTab(activeHistoryTab);
      return signalRendered.ok || linkQualityRendered.ok || onlineRendered.ok || packetsRendered.ok || namesRendered.ok || overviewRendered.ok;
    }}

    async function fetchNodeHistory(nodeId, opts = null) {{
      if (!isSelectableNodeId(nodeId)) return null;
      const options = (opts && typeof opts === "object") ? opts : {{}};
      const force = options.force === true;
      const signal = options.signal || undefined;
      const cached = nodeHistoryCache.get(nodeId);
      const nowMs = Date.now();
      // Node history changes much slower than live state; avoid hammering the DB.
      const ttlMs = Math.max(refreshMs * 2, 8000);
      if (!force && cached && (nowMs - (cached.fetchedAt || 0)) < ttlMs) {{
        return cached.data;
      }}
      const url = `/api/history/node?node_id=${{encodeURIComponent(nodeId)}}&hours=${{nodeHistoryHours}}&points=${{nodeHistoryMaxPoints}}`;
      const resp = await fetch(url, {{ cache: "no-store", signal }});
      if (!resp.ok) throw new Error(`history API ${{resp.status}}`);
      const data = await resp.json();
      nodeHistoryCache.set(nodeId, {{ fetchedAt: nowMs, data }});
      return data;
    }}

    function cachedNodeHistory(nodeId) {{
      const clean = normalizeNodeId(nodeId || "");
      if (!isSelectableNodeId(clean)) return null;
      const cached = nodeHistoryCache.get(clean);
      if (!cached || !cached.data) return null;
      const dataId = normalizeNodeId(cached.data.node_id || "");
      if (dataId && dataId !== clean) return null;
      return cached.data;
    }}

    function abortNodeHistoryFetch() {{
      if (nodeHistoryFetchAbort) {{
        try {{
          nodeHistoryFetchAbort.abort();
        }} catch (_err) {{
        }}
      }}
      nodeHistoryFetchAbort = null;
      nodeHistoryFetchNodeId = "";
    }}

    function applyNodeHistoryToView(nodeHistory) {{
      const state = latestState;
      if (!state) return;
      const nodes = state.nodes || [];
      const traffic = (state.traffic || {{}});
      const edges = traffic.edges || [];
      const activeNetworkSubviewName = (typeof normalizeNetworkSubview === "function")
        ? normalizeNetworkSubview(activeNetworkSubview)
        : String(activeNetworkSubview || "map").trim().toLowerCase();
      const networkMapVisible = activeLayoutView === "network" && (
        typeof networkSubviewUsesMap === "function"
          ? networkSubviewUsesMap(activeNetworkSubviewName)
          : activeNetworkSubviewName === "map"
      );
      const drawerExpanded = (
        typeof isChatNodeDetailsDrawerExpanded === "function"
        && isChatNodeDetailsDrawerExpanded()
      );
      const drawerHistoryActive = (
        typeof isChatNodeDetailsHistoryActive === "function"
        && isChatNodeDetailsHistoryActive()
      );
      const shouldShowNodeHistoryPanel = drawerHistoryActive;
      let historyPanelRendered = false;

      if (networkMapVisible) {{
        runHistoryViewRenderStep("map render", () => {{
          renderMap(nodes, edges, nodeHistory);
        }});
      }}

      if (networkMapVisible && pendingMapHistoryFocus) {{
        runHistoryViewRenderStep("map focus", () => {{
          const historyNodeId = normalizeNodeId((nodeHistory && nodeHistory.node_id) || "");
          const selectionId = normalizeNodeId(selectedNodeId || "");
          if (historyNodeId && selectionId && historyNodeId === selectionId) {{
            focusSelectedNodeOnMap(nodeHistory);
            pendingMapHistoryFocus = false;
          }}
        }});
      }}

      // The signal plot lives in the map-data panel, rendered by renderTraffic.
      if (networkMapVisible) {{
        const trafficRender = runHistoryViewRenderStep("map data panel", () => (
          renderTraffic(traffic, nodes, nodeHistory)
        ));
        if (shouldShowNodeHistoryPanel && trafficRender.ok) {{
          historyPanelRendered = !!trafficRender.result || historyPanelRendered;
        }}
      }}

      if (drawerExpanded) {{
        runHistoryViewRenderStep("node details", () => {{
          renderNodeDetails(state, nodeHistory);
        }});
      }}

      if (drawerHistoryActive) {{
        const drawerRender = runHistoryViewRenderStep("drawer node history", () => {{
          setMapDataMode("node");
          syncNodeHistoryDock();
          return renderNodeHistory(nodeHistory, nodes);
        }});
        historyPanelRendered = !!drawerRender.result || historyPanelRendered;
      }}

      if (shouldShowNodeHistoryPanel && !historyPanelRendered) {{
        const nodeId = normalizeNodeId((nodeHistory && nodeHistory.node_id) || selectedNodeId || "");
        renderNodeHistoryUnavailable(nodeId, "Reselect the node to retry.");
      }}
    }}

    async function refreshSelectedNodeHistory(force = false) {{
      const perfToken = (typeof currentNodeSelectionPerfToken === "function")
        ? currentNodeSelectionPerfToken()
        : 0;
      const perfStartMs = perfToken > 0 && typeof nodeSelectionPerfNow === "function"
        ? nodeSelectionPerfNow()
        : 0;
      const nodeId = normalizeNodeId(selectedNodeId || "");
      const drawerExpanded = (
        typeof isChatNodeDetailsDrawerExpanded === "function"
        && isChatNodeDetailsDrawerExpanded()
      );
      const drawerHistoryActive = (
        typeof isChatNodeDetailsHistoryActive === "function"
        && isChatNodeDetailsHistoryActive()
      );
      if (!isSelectableNodeId(nodeId)) {{
        abortNodeHistoryFetch();
        if (perfToken > 0 && typeof markNodeSelectionPerf === "function") {{
          markNodeSelectionPerf(perfToken, "selection.history_refresh", perfStartMs, {{
            skipped: true,
            reason: "no-selection",
          }});
        }}
        return null;
      }}
      if (!(activeLayoutView === "network" || drawerExpanded)) {{
        // No need to load node history unless the map views that can use it are visible.
        abortNodeHistoryFetch();
        if (perfToken > 0 && typeof markNodeSelectionPerf === "function") {{
          markNodeSelectionPerf(perfToken, "selection.history_refresh", perfStartMs, {{
            skipped: true,
            reason: "view-inactive",
          }});
        }}
        return null;
      }}
      const nowMs = Date.now();
      const ttlMs = Math.max(refreshMs * 2, 8000);
      const cached = nodeHistoryCache.get(nodeId);
      const cachedData = cached && cached.data ? cached.data : null;
      const cacheFresh = !!cachedData && (nowMs - (cached.fetchedAt || 0)) < ttlMs;

      if (!force && cacheFresh) {{
        // Ensure the UI is actually showing the cached history (selection changes can
        // switch the UI into a loading state without re-rendering the chart).
        applyNodeHistoryToView(cachedData);
        if (perfToken > 0 && typeof markNodeSelectionPerf === "function") {{
          markNodeSelectionPerf(perfToken, "selection.history_refresh", perfStartMs, {{
            cacheHit: true,
          }});
          finishNodeSelectionPerf(perfToken, "history-cache-hit");
        }}
        return cachedData;
      }}

      if (!force && nodeHistoryFetchAbort && nodeHistoryFetchNodeId === nodeId) {{
        if (perfToken > 0 && typeof markNodeSelectionPerf === "function") {{
          markNodeSelectionPerf(perfToken, "selection.history_refresh", perfStartMs, {{
            skipped: true,
            reason: "already-fetching",
          }});
        }}
        return null;
      }}

      abortNodeHistoryFetch();
      nodeHistoryFetchSeq += 1;
      const seq = nodeHistoryFetchSeq;
      nodeHistoryFetchNodeId = nodeId;
      nodeHistoryFetchAbort = new AbortController();
      const signal = nodeHistoryFetchAbort.signal;

      if (!cachedData && drawerHistoryActive) {{
        renderNodeHistoryLoading(nodeId);
      }}

      try {{
        const data = await fetchNodeHistory(nodeId, {{ force: true, signal }});
        if (seq !== nodeHistoryFetchSeq) return null;
        const activeNodeId = normalizeNodeId(selectedNodeId || "");
        if (activeNodeId !== nodeId) return null;
        const drawerExpandedNow = (
          typeof isChatNodeDetailsDrawerExpanded === "function"
          && isChatNodeDetailsDrawerExpanded()
        );
        if (!(activeLayoutView === "network" || drawerExpandedNow)) return null;
        applyNodeHistoryToView(data);
        if (perfToken > 0 && typeof markNodeSelectionPerf === "function") {{
          markNodeSelectionPerf(perfToken, "selection.history_refresh", perfStartMs, {{
            cacheHit: false,
            points: Array.isArray(data && data.positions) ? data.positions.length : 0,
          }});
          finishNodeSelectionPerf(perfToken, "history-fetched");
        }}
        return data;
      }} catch (err) {{
        if (err && err.name === "AbortError") return null;
        if (seq !== nodeHistoryFetchSeq) return null;
        const msg = err instanceof Error ? err.message : String(err || "unknown error");
        const caption = document.getElementById("node-history-caption");
        if (caption && drawerHistoryActive) {{
          caption.textContent = `History error for ${{nodeId}}: ${{msg}}`;
        }}
        if (perfToken > 0 && typeof markNodeSelectionPerf === "function") {{
          markNodeSelectionPerf(perfToken, "selection.history_refresh", perfStartMs, {{
            error: msg,
          }});
          finishNodeSelectionPerf(perfToken, "history-error", {{
            error: msg,
          }});
        }}
        return null;
      }} finally {{
        if (seq === nodeHistoryFetchSeq) {{
          nodeHistoryFetchAbort = null;
          nodeHistoryFetchNodeId = "";
        }}
      }}
    }}
