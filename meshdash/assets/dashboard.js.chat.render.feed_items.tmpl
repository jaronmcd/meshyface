          const monitorNetworkTag = `<span class="chat-monitor-network-tag">[ ][MF]</span>`;
          const monitorItemClass = `chat-feed-item chat-feed-item-monitor-exact ${{selectableClass}}${{selectedFeedClass}}${{monitorViewClass}}`;
          return `<div data-node-id="${{escAttr(nodeId)}}" data-from-node-id="${{escAttr(sourceNode)}}" data-message-id="${{escAttr(messageId || "")}}" data-message-key="${{escAttr(messageKey || "")}}" data-reply-name="${{escAttr(fromMeta.label || "Unknown node")}}" data-reply-text="${{escAttr(textCompact)}}" class="${{monitorItemClass.trim()}}" title="${{escAttr(messageTooltip)}}">
            <span class="chat-entry-msg">
              ${{monitorPrefix}}
              ${{monitorNetworkTag}}
              <span class="short-name status-${{fromStatusKey}}" style="background:${{escAttr(monitorBadgeColor)}}" title="${{escAttr(fromMeta.title)}}">${{monitorShortTagHtml}}</span>
              ${{monitorReplyInline}}
              <span class="chat-entry-copy chat-monitor-text">${{textHtmlMonitor || "&nbsp;"}}</span>
            </span>
          </div>`;
        }}
        const summaryBody = isStatusMessage
          ? `${{replyInline}}${{statusBadge}}<span class="chat-feed-text chat-feed-text-inline">${{textHtml || "&nbsp;"}}</span>`
          : `${{replyInline}}${{statusBadge}}
              <span class="chat-endpoint chat-feed-author" title="${{escAttr(fromMeta.title)}}">
                <span class="node-status-dot chat-feed-status-dot status-${{fromStatusKey}}" title="${{escAttr(fromStatusDotTitle)}}" aria-hidden="true">●</span>
                <span class="chat-name status-${{fromMeta.status}}">${{escAttr(fromMeta.label)}}</span>
              </span>
              <span class="chat-feed-colon">:</span>
              <span class="chat-feed-text chat-feed-text-inline">${{textHtml || "&nbsp;"}}</span>`;
        const sideHtml = monitorMode
          ? ""
          : `<span class="chat-feed-side">
              ${{retryButton}}
              ${{deliveryChip}}
              <span class="chat-feed-time" title="${{escAttr(timeTitle || timeText)}}">${{escAttr(timeText)}}</span>
            </span>`;
        const extraRows = monitorMode ? "" : `${{reactionSummaryRow}}${{reactionRow}}`;
        return `<div data-node-id="${{escAttr(nodeId)}}" data-from-node-id="${{escAttr(sourceNode)}}" data-message-id="${{escAttr(messageId || "")}}" data-message-key="${{escAttr(messageKey || "")}}" data-reply-name="${{escAttr(fromMeta.label || "Unknown node")}}" data-reply-text="${{escAttr(textCompact)}}" class="chat-feed-item ${{selectableClass}}${{selectedFeedClass}}${{changeClass}}${{statusClass}}${{meshTintClass}}${{monitorViewClass}}"${{meshTintStyle}} title="${{escAttr(messageTooltip)}}">
          <div class="chat-feed-line">
            <div class="chat-feed-summary">
              ${{changeBadge}}
              ${{summaryBody}}
            </div>
            ${{sideHtml}}
          </div>
          ${{extraRows}}
        </div>`;
      }}).filter((item) => !!item);
