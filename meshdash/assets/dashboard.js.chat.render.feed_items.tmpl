              </span>
              <span class="chat-feed-colon">:</span>
              <span class="chat-feed-text chat-feed-text-inline${{textEmojiOnlyClass}}">${{textHtml || "&nbsp;"}}</span>`;
        const sideParts = [];
        if (timeText && timeText !== "n/a") {{
          const timeTitle = (
            rawTimeText && rawTimeText !== timeText
              ? `Time: ${{timeText}} • raw ${{rawTimeText}}`
              : `Time: ${{timeText}}`
          );
          sideParts.push(`<span class="chat-feed-time" title="${{escAttr(timeTitle)}}">${{escAttr(timeText)}}</span>`);
        }}
        if (deliveryChip) sideParts.push(deliveryChip);
        const sideHtml = (!monitorMode && sideParts.length > 0)
          ? `<span class="chat-feed-side">${{sideParts.join("")}}</span>`
          : "";
        const extraRows = monitorMode ? "" : reactionRow;
        return `<div data-node-id="${{escAttr(nodeId)}}" data-from-node-id="${{escAttr(sourceNode)}}" data-message-id="${{escAttr(messageId || "")}}" data-message-key="${{escAttr(messageKey || "")}}" data-reply-name="${{escAttr(fromMeta.label || "Unknown node")}}" data-reply-text="${{escAttr(textCompact)}}" class="chat-feed-item ${{selectableClass}}${{selfAuthoredClass}}${{selectedFeedClass}}${{changeClass}}${{statusClass}}${{alertClass}}${{tagClass}}${{nodeEmojiClass}}${{messageChannelClass}}${{monitorViewClass}}"${{nodeEmojiAttr}}${{rowStyleAttr}} title="${{escAttr(messageTooltip)}}">
          ${{messageChannelTab}}
          <div class="chat-feed-line">
            <div class="chat-feed-summary">
              ${{changeBadge}}
              ${{summaryBody}}
            </div>
            ${{sideHtml}}
          </div>
          ${{extraRows}}
        </div>`;
        }} catch (err) {{
          const failedMessageId = Number(messageIdOf(msg));
          const failedFromId = normalizeNodeId(
            (msg && (msg.from || msg.from_id || msg.fromId || msg.source || msg.source_id || msg.sourceId)) || ""
          );
          try {{
            if (typeof console !== "undefined" && console && typeof console.error === "function") {{
              console.error("Chat feed row render failed", {{
                messageId: Number.isInteger(failedMessageId) && failedMessageId > 0 ? failedMessageId : null,
                from: failedFromId || null,
                message: msg,
              }}, err);
            }}
          }} catch (_consoleErr) {{
          }}
          return "";
        }}
      }}).filter((item) => !!item);
