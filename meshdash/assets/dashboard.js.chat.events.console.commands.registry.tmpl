      registerConsoleCommand({{
        name: "nodes",
        usage: "nodes [-v|-vv|-vvv|-vvvv] [pattern] [name=<wildcard>] [id=<wildcard>] [status=<wildcard>] [port=<wildcard>] [gps=<yes|no>] [hops=<n>] [hops>n] [hops<n] [limit=<n>]",
        description: "List nodes from current state with wildcard filters.",
