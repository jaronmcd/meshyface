            }}
            if (isMatch && matchExcerpt) {{
              const matchLabel = matchScope || (isChatEntry ? "chat" : "packet");
              fallbackLineCounter += 1;
              appendConsoleLine(
                `grep|${{runId}}|${{packetKey}}|match|${{fallbackLineCounter}}`,
                `  match[${{matchLabel}}] "${{matchExcerpt.replace(/\"/g, "'")}}"`,
                packetMs,
                false,
                {{ timestampMode: "grep" }},
              );
            }}
          }}
          if (totalMatches > shownMatches) {{
            appendConsoleEventLine(
              `[grep] truncated to latest ${{shownMatches}} match(es). Use limit=<n> up to 500.`
            );
          }}
          renderConsoleBuffer(true);
          return "";
        }},
      }});
      registerConsoleCommand({{
        name: "rg",
        usage: "rg <text> [-A<n>|-B<n>|-C<n>] [limit=<n>] [scope=both|summary|packet] [source=both|packet|chat] [scan=<n>]",
