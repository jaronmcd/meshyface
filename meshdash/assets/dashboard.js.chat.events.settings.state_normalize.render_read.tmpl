    async function fetchSettingsDeviceInfoJson(url) {{
      const resp = await fetch(url, {{ cache: "no-store" }});
      if (!resp.ok) throw new Error(`${{url}} ${{resp.status}}`);
      return await resp.json();
    }}

    async function hydrateSettingsDeviceInfo(force = false) {{
      const grid = document.getElementById("settings-device-info-grid");
      if (!(grid instanceof HTMLElement)) return null;
      const nowMs = Date.now();
      if (
        !force
        && settingsDeviceInfoRawCache.fetchedAt > 0
        && (nowMs - settingsDeviceInfoRawCache.fetchedAt) < settingsDeviceInfoRawTtlMs
      ) {{
        renderSettingsDeviceInfo(latestState || {{}});
        return settingsDeviceInfoRawCache;
      }}
      if (settingsDeviceInfoHydratePromise) return settingsDeviceInfoHydratePromise;
      setText("settings-device-info-status", "Fetching live radio identity, firmware, hardware, and connection details...");
      settingsDeviceInfoHydratePromise = (async () => {{
        const results = await Promise.allSettled([
          fetchSettingsDeviceInfoJson("/api/raw/my_info"),
          fetchSettingsDeviceInfoJson("/api/raw/metadata"),
          fetchSettingsDeviceInfoJson("/api/raw/local_state"),
        ]);
        const keys = ["myInfo", "metadata", "localState"];
        const errors = {{}};
        results.forEach((result, idx) => {{
          const key = keys[idx];
          if (result.status === "fulfilled") {{
            settingsDeviceInfoRawCache[key] = result.value;
          }} else {{
            errors[key] = result.reason && result.reason.message ? result.reason.message : String(result.reason || "unknown error");
          }}
        }});
        settingsDeviceInfoRawCache.errors = errors;
        settingsDeviceInfoRawCache.fetchedAt = Date.now();
        renderSettingsDeviceInfo(latestState || {{}});
        return settingsDeviceInfoRawCache;
      }})().finally(() => {{
        settingsDeviceInfoHydratePromise = null;
      }});
      return settingsDeviceInfoHydratePromise;
    }}

    function setSettingsDatabaseInfoValue(id, value) {{
      setSettingsDeviceInfoValue(id, value);
    }}

    function clearSettingsDatabaseInfoValues() {{
      settingsDatabaseInfoValueIds.forEach((id) => setSettingsDatabaseInfoValue(id, ""));
    }}

    function formatSettingsDatabaseNumber(value) {{
      if (value == null || (typeof value === "string" && !value.trim())) return "";
      const numeric = Number(value);
      if (!Number.isFinite(numeric)) return "";
      return Math.trunc(numeric).toLocaleString();
    }}

    function formatSettingsDatabaseBytes(value) {{
      if (value == null || (typeof value === "string" && !value.trim())) return "";
      const numeric = Number(value);
      if (!Number.isFinite(numeric) || numeric < 0) return "";
      if (numeric === 0) return "0 B";
      const units = ["B", "KB", "MB", "GB", "TB"];
      let unitIdx = 0;
      let bytes = numeric;
      while (bytes >= 1024 && unitIdx < units.length - 1) {{
        bytes /= 1024;
        unitIdx += 1;
      }}
      const digits = unitIdx === 0 || bytes >= 100 ? 0 : (bytes >= 10 ? 1 : 2);
      return `${{bytes.toFixed(digits)}} ${{units[unitIdx]}}`;
    }}

    function formatSettingsDatabaseEpoch(value) {{
      const numeric = Number(value);
      if (!Number.isFinite(numeric) || numeric <= 0) return "";
      if (typeof formatLocalChatTime === "function") {{
        return formatLocalChatTime(numeric);
      }}
      try {{
        return new Date(numeric * 1000).toLocaleString();
      }} catch (_err) {{
        return "";
      }}
    }}

    function formatSettingsDatabaseDuration(seconds, maxRows) {{
      const parts = [];
      const hasSeconds = !(seconds == null || (typeof seconds === "string" && !seconds.trim()));
      const cleanSeconds = Number(seconds);
      if (hasSeconds && Number.isFinite(cleanSeconds)) {{
        if (cleanSeconds <= 0) {{
          parts.push("unlimited");
        }} else {{
          const days = Math.max(1, Math.round(cleanSeconds / 86400));
          parts.push(`${{days.toLocaleString()}}d`);
        }}
      }}
      const cleanMaxRows = Number(maxRows);
      if (Number.isFinite(cleanMaxRows) && cleanMaxRows > 0) {{
        parts.push(`max ${{Math.trunc(cleanMaxRows).toLocaleString()}} rows`);
      }}
      return parts.join(" | ");
    }}

    function settingsDatabaseInfoTableCount(stats, tableName) {{
      const counts = settingsDeviceInfoObject(settingsDeviceInfoFirst([stats], ["table_counts", "tableCounts"])) || {{}};
      return counts[tableName];
    }}

    function settingsDatabaseInfoRangeValue(stats, tableName, keyName) {{
      const ranges = settingsDeviceInfoObject(settingsDeviceInfoFirst([stats], ["ranges"])) || {{}};
      const range = settingsDeviceInfoObject(ranges[tableName]) || {{}};
      return range[keyName];
    }}

    function settingsDatabaseInfoPercent(value, maxValue) {{
      const numeric = Number(value);
      const maxNumeric = Number(maxValue);
      if (!Number.isFinite(numeric) || !Number.isFinite(maxNumeric) || maxNumeric <= 0) return "";
      const percent = Math.max(0, Math.min(999, (numeric / maxNumeric) * 100));
      return `${{percent.toFixed(percent >= 10 ? 0 : 1)}}%`;
    }}

    function settingsDatabaseInfoNumericPercent(value, maxValue) {{
      const numeric = Number(value);
      const maxNumeric = Number(maxValue);
      if (!Number.isFinite(numeric) || !Number.isFinite(maxNumeric) || maxNumeric <= 0) return null;
      return Math.max(0, Math.min(999, (numeric / maxNumeric) * 100));
    }}

    function formatSettingsDatabaseWindowDays(seconds) {{
      const numeric = Number(seconds);
      if (!Number.isFinite(numeric) || numeric < 0) return "";
      const days = numeric / 86400;
      if (days >= 10) return `${{Math.round(days).toLocaleString()}}d`;
      if (days >= 1) return `${{days.toFixed(1)}}d`;
      const hours = numeric / 3600;
      if (hours >= 1) return `${{hours.toFixed(1)}}h`;
      return `${{Math.max(0, Math.round(numeric / 60)).toLocaleString()}}m`;
    }}

    function settingsDatabaseInfoWindowSeconds(stats, tableName) {{
      const first = Number(settingsDatabaseInfoRangeValue(stats, tableName, "first_unix"));
      const last = Number(settingsDatabaseInfoRangeValue(stats, tableName, "last_unix"));
      if (!Number.isFinite(first) || first <= 0 || !Number.isFinite(last) || last <= 0 || last < first) return null;
      return last - first;
    }}

    function settingsDatabaseCapacityStatusLabel(percent) {{
      if (!Number.isFinite(percent)) return "";
      const clean = Math.max(0, Math.min(999, percent));
      return `${{clean.toFixed(clean >= 10 ? 0 : 1)}}%`;
    }}

    function clearSettingsDatabaseCapacity() {{
      const status = document.getElementById("settings-database-capacity-status");
      if (status) status.textContent = "n/a";
      for (const key of ["packets", "events"]) {{
        const fill = document.getElementById(`settings-database-capacity-${{key}}-fill`);
        const value = document.getElementById(`settings-database-capacity-${{key}}-text`);
        if (fill instanceof HTMLElement) {{
          fill.style.width = "0%";
          fill.classList.remove("warn", "danger");
        }}
        if (value instanceof HTMLElement) {{
          value.textContent = "n/a";
          value.removeAttribute("title");
        }}
      }}
    }}

    function renderSettingsDatabaseCapacityRow(key, label, stats, retentionSeconds, rowCount, maxRows) {{
      const fill = document.getElementById(`settings-database-capacity-${{key}}-fill`);
      const value = document.getElementById(`settings-database-capacity-${{key}}-text`);
      const windowSeconds = settingsDatabaseInfoWindowSeconds(stats, key === "events" ? "packet_events" : "packets");
      const windowPercent = settingsDatabaseInfoNumericPercent(windowSeconds, retentionSeconds);
      const rowPercent = settingsDatabaseInfoNumericPercent(rowCount, maxRows);
      const width = Number.isFinite(windowPercent) ? Math.max(0, Math.min(100, windowPercent)) : 0;
      const windowText = windowSeconds == null ? "" : formatSettingsDatabaseWindowDays(windowSeconds);
      const targetText = Number(retentionSeconds) > 0 ? formatSettingsDatabaseWindowDays(retentionSeconds) : "unlimited";
      const rowText = Number.isFinite(rowPercent) ? `${{settingsDatabaseCapacityStatusLabel(rowPercent)}} row cap` : "";
      const text = windowText
        ? `${{windowText}} / ${{targetText}}${{rowText ? ` | ${{rowText}}` : ""}}`
        : (rowText || "n/a");

      if (fill instanceof HTMLElement) {{
        fill.style.width = `${{width.toFixed(1)}}%`;
        fill.classList.remove("warn", "danger");
        if (Number.isFinite(rowPercent) && rowPercent >= 90) {{
          fill.classList.add("danger");
        }} else if (Number.isFinite(rowPercent) && rowPercent >= 75) {{
          fill.classList.add("warn");
        }}
      }}
      if (value instanceof HTMLElement) {{
        value.textContent = text;
        value.title = `${{label}} history window: ${{text}}`;
      }}
      return {{
        label,
        percent: Number.isFinite(windowPercent) ? windowPercent : null,
      }};
    }}

    function renderSettingsDatabaseCapacity(stats, policy) {{
      const packetResult = renderSettingsDatabaseCapacityRow(
        "packets",
        "Packets",
        stats,
        settingsDeviceInfoFirst([policy], ["retention_seconds", "retentionSeconds"]),
        settingsDatabaseInfoTableCount(stats, "packets"),
        settingsDeviceInfoFirst([policy], ["max_rows", "maxRows"])
      );
      const eventResult = renderSettingsDatabaseCapacityRow(
        "events",
        "Events",
        stats,
        settingsDeviceInfoFirst([policy], ["event_retention_seconds", "eventRetentionSeconds"]),
        settingsDatabaseInfoTableCount(stats, "packet_events"),
        settingsDeviceInfoFirst([policy], ["event_max_rows", "eventMaxRows"])
      );
      const status = document.getElementById("settings-database-capacity-status");
      if (status instanceof HTMLElement) {{
        const choices = [packetResult, eventResult].filter((entry) => Number.isFinite(entry.percent));
        if (!choices.length) {{
          status.textContent = "n/a";
        }} else {{
          choices.sort((a, b) => Number(b.percent) - Number(a.percent));
          status.textContent = `${{choices[0].label}} ${{settingsDatabaseCapacityStatusLabel(choices[0].percent)}} of configured window`;
        }}
      }}
    }}

    function settingsDatabaseInfoHealthText(stats, policy) {{
      const packets = Number(settingsDatabaseInfoTableCount(stats, "packets"));
      const packetMax = Number(settingsDeviceInfoFirst([policy], ["max_rows", "maxRows"]));
      const events = Number(settingsDatabaseInfoTableCount(stats, "packet_events"));
      const eventMax = Number(settingsDeviceInfoFirst([policy], ["event_max_rows", "eventMaxRows"]));
      const totalSize = Number(settingsDeviceInfoFirst([stats], ["total_size_bytes", "totalSizeBytes"]));
      const newestPacket = Number(settingsDatabaseInfoRangeValue(stats, "packets", "last_unix"));
      const generated = Number(settingsDeviceInfoFirst([stats], ["generated_unix", "generatedUnix"]));
      const notes = [];

      if (Number.isFinite(packets) && packets <= 0) {{
        notes.push("no packet history");
      }} else if (Number.isFinite(packetMax) && packetMax > 0 && Number.isFinite(packets)) {{
        const packetPercent = settingsDatabaseInfoPercent(packets, packetMax);
        if (packets >= packetMax * 0.98) {{
          notes.push("packet cap active");
        }} else if (packetPercent) {{
          notes.push(`${{packetPercent}} packet cap`);
        }}
      }}

      if (Number.isFinite(eventMax) && eventMax > 0 && Number.isFinite(events) && events >= eventMax * 0.98) {{
        notes.push("event cap active");
      }}

      if (Number.isFinite(totalSize) && totalSize >= 1024 * 1024 * 1024) {{
        notes.push("large DB");
      }}

      if (
        Number.isFinite(newestPacket)
        && newestPacket > 0
        && Number.isFinite(generated)
        && generated > newestPacket
        && (generated - newestPacket) > 3600
      ) {{
        notes.push("no recent packets");
      }}

      if (!notes.length) return "OK";
      return `OK | ${{notes.join(" | ")}}`;
    }}

    function settingsDatabaseInfoPages(stats) {{
      const pageCount = Number(settingsDeviceInfoFirst([stats], ["page_count", "pageCount"]));
      const pageSize = Number(settingsDeviceInfoFirst([stats], ["page_size", "pageSize"]));
      if (!Number.isFinite(pageCount) || pageCount < 0) return "";
      if (!Number.isFinite(pageSize) || pageSize <= 0) {{
        return `${{Math.trunc(pageCount).toLocaleString()}} pages`;
      }}
      return `${{Math.trunc(pageCount).toLocaleString()}} x ${{formatSettingsDatabaseBytes(pageSize)}}`;
    }}

