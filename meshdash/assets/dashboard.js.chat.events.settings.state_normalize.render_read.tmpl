      const security = settingsDeviceInfoObject(settingsDeviceInfoFirst([localConfig], ["security"])) || {{}};
      const summary = settingsDeviceInfoObject(settingsDeviceInfoFirst([safeState], ["summary"])) || {{}};

      const nodeId = settingsDeviceInfoFirst([safeState, user, nodeRow], ["local_node_id", "localNodeId", "id"]);
      setSettingsDeviceInfoValue("settings-device-info-long-name", settingsDeviceInfoFirst([user, nodeRow], ["longName", "long_name"]));
      setSettingsDeviceInfoValue("settings-device-info-short-name", settingsDeviceInfoFirst([user, nodeRow], ["shortName", "short_name"]));
      setSettingsDeviceInfoValue("settings-device-info-node-id", nodeId);
      setSettingsDeviceInfoValue("settings-device-info-node-num", settingsDeviceInfoFirst([myInfo, localState, localNodeInfo, nodeRow], [
        "my_node_num",
        "myNodeNum",
        "local_node_num",
