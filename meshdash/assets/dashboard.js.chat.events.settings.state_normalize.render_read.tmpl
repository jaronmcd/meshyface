      const safeState = state && typeof state === "object" ? state : {{}};
      const localState = settingsDeviceInfoObject(settingsDeviceInfoRawCache.localState)
        || (typeof settingsLocalStateFrom === "function" ? settingsLocalStateFrom(safeState) : null)
        || settingsDeviceInfoObject(settingsDeviceInfoFirst([safeState], ["local_state", "localState"]))
        || {{}};
      const myInfo = settingsDeviceInfoObject(settingsDeviceInfoRawCache.myInfo)
        || settingsDeviceInfoObject(settingsDeviceInfoFirst([safeState], ["my_info", "myInfo"]))
        || {{}};
      const metadata = settingsDeviceInfoObject(settingsDeviceInfoRawCache.metadata)
        || settingsDeviceInfoObject(settingsDeviceInfoFirst([safeState], ["metadata"]))
        || {{}};
      const localNodeInfo = settingsDeviceInfoObject(
        settingsDeviceInfoFirst([localState], ["local_node_info", "localNodeInfo"])
      ) || {{}};
      const user = settingsDeviceInfoObject(settingsDeviceInfoFirst([localNodeInfo], ["user"])) || {{}};
      const nodeRow = settingsDeviceInfoLocalNodeRow(safeState, localState, myInfo) || {{}};
      const deviceMetrics = settingsDeviceInfoObject(
        settingsDeviceInfoFirst([localNodeInfo], ["deviceMetrics", "device_metrics"])
      ) || {{}};
      const localConfig = settingsDeviceInfoObject(settingsDeviceInfoFirst([localState], ["local_config", "localConfig"])) || {{}};
      const lora = settingsDeviceInfoObject(settingsDeviceInfoFirst([localConfig], ["lora"]))
        || (typeof loraConfigFromState === "function" ? loraConfigFromState(safeState) : null)
        || {{}};
      const device = settingsDeviceInfoObject(settingsDeviceInfoFirst([localConfig], ["device"]))
        || (typeof deviceConfigFromState === "function" ? deviceConfigFromState(safeState) : null)
