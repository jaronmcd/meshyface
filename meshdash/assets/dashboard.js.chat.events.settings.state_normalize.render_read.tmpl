      ]));
      setSettingsDeviceInfoValue("settings-device-info-firmware", settingsDeviceInfoFirst([metadata], [
        "firmware_version",
        "firmwareVersion",
        "firmware",
      ]));
      setSettingsDeviceInfoValue("settings-device-info-pio-env", settingsDeviceInfoFirst([myInfo, metadata], ["pio_env", "pioEnv"]));
      setSettingsDeviceInfoValue("settings-device-info-state-version", settingsDeviceInfoFirst([metadata], [
        "device_state_version",
        "deviceStateVersion",
      ]));
      setSettingsDeviceInfoValue("settings-device-info-reboot-count", settingsDeviceInfoFirst([myInfo], ["reboot_count", "rebootCount"]));
      setSettingsDeviceInfoValue("settings-device-info-nodedb-count", settingsDeviceInfoFirst([myInfo], ["nodedb_count", "nodeDbCount"]));
      setSettingsDeviceInfoValue("settings-device-info-device-id", settingsDeviceInfoFirst([myInfo], ["device_id", "deviceId"]));
      setSettingsDeviceInfoValue("settings-device-info-mac", settingsDeviceInfoFirst([user], ["macaddr", "macAddr", "mac"]));
      setSettingsDeviceInfoValue("settings-device-info-role", settingsDeviceInfoFirst([device, nodeRow], ["role"]));
      setSettingsDeviceInfoValue("settings-device-info-public-key", settingsDeviceInfoFirst([user, security], [
        "publicKey",
        "public_key",
      ]));
      setSettingsDeviceInfoValue("settings-device-info-region", settingsDeviceInfoFirst([lora], ["region"]));
      setSettingsDeviceInfoValue("settings-device-info-modem-preset", settingsDeviceInfoFirst([summary, lora], [
        "modem_preset",
        "modemPreset",
      ]));
      setSettingsDeviceInfoValue("settings-device-info-wifi", settingsDeviceInfoConnectionText(safeState, metadata, "wifi"));
      setSettingsDeviceInfoValue("settings-device-info-bluetooth", settingsDeviceInfoConnectionText(safeState, metadata, "bluetooth"));
      setSettingsDeviceInfoValue("settings-device-info-serial", settingsDeviceInfoConnectionText(safeState, metadata, "serial"));

      const capabilities = [];
      if (settingsDeviceInfoFirst([metadata], ["hasWifi", "has_wifi"]) === true) capabilities.push("Wi-Fi");
      if (settingsDeviceInfoFirst([metadata], ["hasBluetooth", "has_bluetooth"]) === true) capabilities.push("Bluetooth");
      if (settingsDeviceInfoFirst([metadata], ["hasPKC", "has_pkc"]) === true) capabilities.push("PKC");
      if (settingsDeviceInfoFirst([metadata], ["canShutdown", "can_shutdown"]) === true) capabilities.push("shutdown");
      if (settingsDeviceInfoFirst([user], ["isUnmessagable", "is_unmessagable"]) === true) capabilities.push("unmessagable");
      setSettingsDeviceInfoValue("settings-device-info-capabilities", capabilities.join(", "));
      setSettingsDeviceInfoValue("settings-device-info-position-flags", settingsDeviceInfoFirst([metadata, lora, localConfig.position], [
        "position_flags",
        "positionFlags",
      ]));
