    function settingsDeviceInfoObject(value) {{
      return value && typeof value === "object" && !Array.isArray(value) ? value : null;
    }}

    function settingsDeviceInfoPathValue(root, path) {{
      if (!root || typeof root !== "object") return null;
      let current = root;
      for (const rawPart of String(path || "").split(".")) {{
        const part = String(rawPart || "").trim();
        if (!part || !current || typeof current !== "object" || !(part in current)) {{
          return null;
        }}
        current = current[part];
      }}
      return current;
    }}

    function settingsDeviceInfoFirst(roots, paths) {{
      const rootList = Array.isArray(roots) ? roots : [roots];
      const pathList = Array.isArray(paths) ? paths : [paths];
      for (const root of rootList) {{
        if (!root || typeof root !== "object") continue;
        for (const path of pathList) {{
          const value = settingsDeviceInfoPathValue(root, path);
          if (value == null) continue;
          if (typeof value === "string" && !value.trim()) continue;
          return value;
        }}
      }}
      return null;
    }}

    function settingsDeviceInfoText(value) {{
      if (value == null) return "";
      if (typeof value === "boolean") return value ? "yes" : "no";
      const text = String(value).trim();
      return text;
    }}

    function setSettingsDeviceInfoValue(id, value) {{
      const el = document.getElementById(id);
      if (!(el instanceof HTMLElement)) return;
      const text = settingsDeviceInfoText(value);
      el.textContent = text || "n/a";
      el.classList.toggle("is-empty", !text);
      if (text) {{
        el.title = text;
      }} else {{
        el.removeAttribute("title");
      }}
    }}

    function settingsDeviceInfoLocalNodeRow(state, localState, myInfo) {{
      const safeState = state && typeof state === "object" ? state : {{}};
      const nodes = Array.isArray(safeState.nodes) ? safeState.nodes : [];
      const localNodeInfo = settingsDeviceInfoObject(
        settingsDeviceInfoFirst([localState], ["local_node_info", "localNodeInfo"])
      );
      const user = settingsDeviceInfoObject(settingsDeviceInfoFirst([localNodeInfo], ["user"]));
      const directId = settingsDeviceInfoText(
        settingsDeviceInfoFirst([safeState, user], ["local_node_id", "localNodeId", "id"])
      );
      const cleanDirectId = typeof normalizeNodeId === "function" ? normalizeNodeId(directId) : directId;
      if (cleanDirectId) {{
        const byId = nodes.find((node) => {{
          const nodeId = settingsDeviceInfoText(settingsDeviceInfoFirst([node], ["id"]));
          return (typeof normalizeNodeId === "function" ? normalizeNodeId(nodeId) : nodeId) === cleanDirectId;
        }});
        if (byId && typeof byId === "object") return byId;
      }}
      const rawNum = settingsDeviceInfoFirst([localNodeInfo, localState, myInfo], [
        "num",
        "local_node_num",
        "localNodeNum",
        "my_node_num",
        "myNodeNum",
      ]);
      const nodeNum = Number(rawNum);
      if (Number.isFinite(nodeNum)) {{
        const byNum = nodes.find((node) => Number(settingsDeviceInfoFirst([node], ["num", "node_num", "nodeNum"])) === nodeNum);
        if (byNum && typeof byNum === "object") return byNum;
      }}
      return null;
    }}

    function formatSettingsDeviceInfoUptime(seconds) {{
      const numeric = Number(seconds);
      if (!Number.isFinite(numeric) || numeric < 0) return "";
      if (typeof formatUptimeHms === "function") {{
        return formatUptimeHms(numeric);
      }}
      const whole = Math.trunc(numeric);
      const days = Math.floor(whole / 86400);
      const hours = Math.floor((whole % 86400) / 3600);
      const minutes = Math.floor((whole % 3600) / 60);
      if (days > 0) return `${{days}}d ${{hours}}h ${{minutes}}m`;
      if (hours > 0) return `${{hours}}h ${{minutes}}m`;
      return `${{minutes}}m`;
    }}

    function formatSettingsDeviceInfoLastHeard(value) {{
      const numeric = Number(value);
      if (Number.isFinite(numeric) && numeric > 0) {{
        if (typeof formatLocalChatTime === "function") {{
          return formatLocalChatTime(numeric);
        }}
        return new Date(numeric * 1000).toISOString();
      }}
      return settingsDeviceInfoText(value);
    }}

    function settingsDeviceInfoConnectionText(state, metadata, kind) {{
      const summary = settingsDeviceInfoObject(settingsDeviceInfoFirst([state], ["summary"])) || {{}};
      const radio = settingsDeviceInfoObject(settingsDeviceInfoFirst([summary], ["radio_connection"])) || {{}};
      const details = settingsDeviceInfoObject(settingsDeviceInfoFirst([radio], [kind])) || {{}};
      const parts = [];
      if (kind === "wifi") {{
        const connected = settingsDeviceInfoFirst([details], ["is_connected", "connected"]);
        if (connected === true) parts.push("connected");
        if (connected === false) parts.push("disconnected");
        const ip = settingsDeviceInfoText(settingsDeviceInfoFirst([details], ["ip_address", "ipAddress", "ip"]));
        const ssid = settingsDeviceInfoText(settingsDeviceInfoFirst([details], ["ssid"]));
        const rssi = settingsDeviceInfoFirst([details], ["rssi_dbm", "rssiDbm", "rssi"]);
        if (ip) parts.push(ip);
        if (ssid) parts.push(ssid);
        if (rssi != null && settingsDeviceInfoText(rssi)) parts.push(`${{rssi}} dBm`);
        if (!parts.length) {{
          const hasWifi = settingsDeviceInfoFirst([metadata], ["hasWifi", "has_wifi"]);
          if (hasWifi === true) parts.push("available");
          if (hasWifi === false) parts.push("not available");
        }}
      }} else if (kind === "bluetooth") {{
        const pin = settingsDeviceInfoText(settingsDeviceInfoFirst([details], ["pin", "fixed_pin", "fixedPin"]));
        const hasBluetooth = settingsDeviceInfoFirst([metadata], ["hasBluetooth", "has_bluetooth"]);
        if (hasBluetooth === true) parts.push("available");
        if (hasBluetooth === false) parts.push("not available");
        if (pin) parts.push(`PIN ${{pin}}`);
      }} else if (kind === "serial") {{
        const baud = settingsDeviceInfoText(settingsDeviceInfoFirst([details], ["baud", "baud_rate", "baudRate"]));
        if (baud) parts.push(`${{baud}} baud`);
      }}
      return parts.join(" | ");
    }}

