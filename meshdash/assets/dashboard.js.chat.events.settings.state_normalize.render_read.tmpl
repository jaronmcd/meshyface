        "excluded_modules",
        "excludedModules",
      ]));

      const battery = settingsDeviceInfoFirst([deviceMetrics, nodeRow], ["batteryLevel", "battery_level"]);
      setSettingsDeviceInfoValue("settings-device-info-battery", battery == null ? "" : `${{battery}}%`);
      const voltage = settingsDeviceInfoFirst([deviceMetrics, nodeRow], ["voltage"]);
      setSettingsDeviceInfoValue("settings-device-info-voltage", voltage == null ? "" : `${{voltage}} V`);
      setSettingsDeviceInfoValue("settings-device-info-uptime", formatSettingsDeviceInfoUptime(
        settingsDeviceInfoFirst([deviceMetrics, summary], ["uptimeSeconds", "uptime_seconds"])
      ));
      setSettingsDeviceInfoValue("settings-device-info-last-heard", formatSettingsDeviceInfoLastHeard(
        settingsDeviceInfoFirst([localNodeInfo, nodeRow], ["lastHeard", "last_heard_unix", "last_heard"])
      ));

      const errors = Object.values(settingsDeviceInfoRawCache.errors || {{}}).filter(Boolean);
      const statusText = errors.length
        ? `Some radio details could not be fetched: ${{errors.join("; ")}}`
        : (settingsDeviceInfoRawCache.fetchedAt
          ? "Radio identity, firmware, hardware, and connection details from live raw endpoints."
          : "Radio identity, firmware, hardware, and connection details from the current dashboard state.");
      setText("settings-device-info-status", statusText);
