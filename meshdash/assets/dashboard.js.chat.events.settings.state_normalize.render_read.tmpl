    async function hydrateSettingsDatabaseInfo(force = false) {{
      const grid = document.getElementById("settings-database-info-grid");
      if (!(grid instanceof HTMLElement)) return null;
      const nowMs = Date.now();
      if (
        !force
        && settingsDatabaseInfoCache.payload
        && settingsDatabaseInfoCache.fetchedAt > 0
        && (nowMs - settingsDatabaseInfoCache.fetchedAt) < settingsDatabaseInfoTtlMs
      ) {{
        renderSettingsDatabaseInfo(settingsDatabaseInfoCache.payload);
        return settingsDatabaseInfoCache.payload;
      }}
      if (settingsDatabaseInfoHydratePromise) return settingsDatabaseInfoHydratePromise;
      setText("settings-database-info-status", "Fetching dashboard history database stats...");
      settingsDatabaseInfoHydratePromise = fetchSettingsDeviceInfoJson("/api/system/database")
        .then((payload) => {{
          settingsDatabaseInfoCache.payload = payload;
          settingsDatabaseInfoCache.error = "";
          settingsDatabaseInfoCache.fetchedAt = Date.now();
          renderSettingsDatabaseInfo(payload);
          return payload;
        }})
        .catch((err) => {{
          settingsDatabaseInfoCache.error = err && err.message ? err.message : String(err || "unknown error");
          settingsDatabaseInfoCache.fetchedAt = Date.now();
          setText("settings-database-info-status", `Database stats could not be fetched: ${{settingsDatabaseInfoCache.error}}`);
          renderSettingsDatabaseInfo(settingsDatabaseInfoCache.payload);
          return settingsDatabaseInfoCache.payload;
        }})
        .finally(() => {{
          settingsDatabaseInfoHydratePromise = null;
        }});
      return settingsDatabaseInfoHydratePromise;
    }}

    const settingsUpdateStatusTtlMs = 60000;

    function settingsUpdatePayloadObject(payload) {{
      return payload && typeof payload === "object" ? payload : {{}};
    }}

    function settingsUpdateStatusText(payload) {{
      const info = settingsUpdatePayloadObject(payload);
      const message = String(info.message || info.error || "").trim();
      if (message) return message;
      if (!info.available) return "Software update is unavailable.";
      const upstream = String(info.upstream || "").trim();
      const behind = Number(info.behind);
      if (Number.isFinite(behind) && behind > 0) {{
        return `Update available: ${{Math.trunc(behind)}} commit${{behind === 1 ? "" : "s"}} behind${{upstream ? ` ${{upstream}}` : ""}}.`;
      }}
      if (info.state === "up_to_date") return "Software is up to date.";
      if (info.can_update) return "Software update is ready to check GitHub.";
      return "Update status not checked.";
    }}

    function renderSettingsUpdateStatus(payload = settingsUpdateStatusCache) {{
      const info = settingsUpdatePayloadObject(payload);
      const statusEl = document.getElementById("settings-update-status");
      const checkBtn = document.getElementById("settings-update-check");
      const applyBtn = document.getElementById("settings-update-apply");
      const inFlight = !!settingsUpdateStatusFetchInFlight || !!settingsUpdateApplyInFlight;
      const canUpdate = !!info.can_update && !inFlight;
      const text = inFlight && settingsUpdateApplyInFlight
        ? "Updating from GitHub..."
        : (inFlight ? "Checking GitHub update status..." : settingsUpdateStatusText(info));
      if (statusEl instanceof HTMLElement) {{
        statusEl.textContent = text;
        const parts = [];
        const branch = String(info.branch || "").trim();
        const upstream = String(info.upstream || "").trim();
        const remoteUrl = String(info.remote_url || "").trim();
        const commit = String(info.current_commit_short || info.current_commit || "").trim();
        if (branch) parts.push(`Branch: ${{branch}}`);
        if (upstream) parts.push(`Upstream: ${{upstream}}`);
        if (commit) parts.push(`Commit: ${{commit}}`);
        if (remoteUrl) parts.push(remoteUrl);
        statusEl.title = parts.join(" | ");
      }}
      if (checkBtn instanceof HTMLButtonElement) {{
        checkBtn.disabled = inFlight;
      }}
      if (applyBtn instanceof HTMLButtonElement) {{
        applyBtn.disabled = !canUpdate;
        applyBtn.title = canUpdate
          ? "Fetch and fast-forward this Git checkout"
          : settingsUpdateStatusText(info);
      }}
    }}

    async function hydrateSettingsUpdateStatus(force = false) {{
      const statusEl = document.getElementById("settings-update-status");
      if (!(statusEl instanceof HTMLElement)) return null;
      const nowMs = Date.now();
      if (
        !force
        && settingsUpdateStatusCache
        && settingsUpdateStatusFetchedAt > 0
        && (nowMs - settingsUpdateStatusFetchedAt) < settingsUpdateStatusTtlMs
      ) {{
        renderSettingsUpdateStatus(settingsUpdateStatusCache);
        return settingsUpdateStatusCache;
      }}
      if (settingsUpdateStatusFetchInFlight) return settingsUpdateStatusFetchInFlight;
      renderSettingsUpdateStatus({{ message: "Checking GitHub update status..." }});
      settingsUpdateStatusFetchInFlight = fetchSettingsDeviceInfoJson("/api/system/update")
        .then((payload) => {{
          settingsUpdateStatusCache = payload;
          settingsUpdateStatusFetchedAt = Date.now();
          renderSettingsUpdateStatus(payload);
          return payload;
        }})
        .catch((err) => {{
          const error = err && err.message ? err.message : String(err || "unknown error");
          const payload = {{
            ok: false,
            available: false,
            can_update: false,
            state: "error",
            error,
            message: `Update status could not be checked: ${{error}}`,
          }};
          settingsUpdateStatusCache = payload;
          settingsUpdateStatusFetchedAt = Date.now();
          renderSettingsUpdateStatus(payload);
          return payload;
        }})
        .finally(() => {{
          settingsUpdateStatusFetchInFlight = null;
          renderSettingsUpdateStatus(settingsUpdateStatusCache);
        }});
      return settingsUpdateStatusFetchInFlight;
    }}

    async function runSettingsGithubUpdate() {{
      if (settingsUpdateApplyInFlight) return;
      const confirmed = window.confirm(
        "Update Meshyface from GitHub now? Local uncommitted changes or diverged commits will block the update."
      );
      if (!confirmed) return;

      settingsUpdateApplyInFlight = true;
      renderSettingsUpdateStatus({{ message: "Updating from GitHub..." }});
      try {{
        const resp = await fetch("/api/system/update", {{
          method: "POST",
          headers: {{ "Content-Type": "application/json" }},
          body: "{{}}",
          cache: "no-store",
        }});
        const text = await resp.text();
        let payload = null;
        try {{
          payload = text ? JSON.parse(text) : null;
        }} catch (_err) {{
        }}
        const info = settingsUpdatePayloadObject(payload);
        if (!resp.ok || info.ok === false) {{
          const errMsg = String(info.error || info.message || text || `HTTP ${{resp.status}}`).trim();
          settingsUpdateStatusCache = Object.assign({{}}, info, {{
            ok: false,
            can_update: false,
            message: `Update failed: ${{errMsg}}`,
          }});
          settingsUpdateStatusFetchedAt = Date.now();
          renderSettingsUpdateStatus(settingsUpdateStatusCache);
          return;
        }}
        settingsUpdateStatusCache = info;
        settingsUpdateStatusFetchedAt = Date.now();
        renderSettingsUpdateStatus(info);
        if (info.updated) {{
          appendConsoleLine(
            `system-update|${{Date.now()}}|ok`,
            `[system] update applied: ${{String(info.previous_commit || "").slice(0, 8)}} -> ${{String(info.new_commit || "").slice(0, 8)}}`
          );
        }}
      }} catch (err) {{
        const msg = err && err.message ? err.message : String(err || "unknown error");
        settingsUpdateStatusCache = {{
          ok: false,
          available: false,
          can_update: false,
          state: "error",
          error: msg,
          message: `Update failed: ${{msg}}`,
        }};
        settingsUpdateStatusFetchedAt = Date.now();
        renderSettingsUpdateStatus(settingsUpdateStatusCache);
      }} finally {{
        settingsUpdateApplyInFlight = false;
        renderSettingsUpdateStatus(settingsUpdateStatusCache);
        setTimeout(() => {{
          void hydrateSettingsUpdateStatus(true);
        }}, 1200);
      }}
    }}

