    function normalizeConsoleInteractiveSession(raw) {{
      const payload = (raw && typeof raw === "object") ? raw : {{}};
      const mode = String(payload.mode || "").trim().toLowerCase();
      if (mode === "standalone") {{
        const sessionId = String(payload.sessionId ?? payload.session_id ?? "").trim();
        if (!sessionId) return null;
        return {{
          name: "zork",
          mode: "standalone",
          sessionId,
        }};
      }}
      if (mode !== "remote") return null;
      const targetNodeId = normalizeNodeId(payload.targetNodeId ?? payload.target_node_id ?? "");
      if (!isCanonicalNodeId(targetNodeId)) return null;
      const channelIndex = normalizeMeshChannelIndex(payload.channelIndex ?? payload.channel_index ?? 0);
      const channelLabel = String(payload.channelLabel || payload.channel_label || "").trim()
        || meshChannelLabelForIndex(channelIndex);
      const seenKeysRaw = Array.isArray(payload.seenKeys) ? payload.seenKeys : [];
      const seenKeys = new Set(
        seenKeysRaw
          .map((value) => String(value == null ? "" : value).trim())
          .filter((value) => !!value)
          .slice(-4000)
      );
      return {{
        name: String(payload.name || "zork-remote").trim() || "zork-remote",
        mode: "remote",
        targetNodeId,
        targetLabel: String(payload.targetLabel || payload.target_label || "").trim(),
        channelIndex,
        channelLabel,
        seenKeys,
        autoResponseEnabled: payload.autoResponseEnabled === true || payload.auto_response_enabled === true,
        autoAwaitingReply: payload.autoAwaitingReply === true || payload.auto_awaiting_reply === true,
        autoScriptIndex: Math.max(0, Math.trunc(Number(payload.autoScriptIndex ?? payload.auto_script_index) || 0)),
        autoMode: String(payload.autoMode ?? payload.auto_mode ?? "script").trim().toLowerCase() === "free-run"
          ? "free-run"
          : "script",
        autoFreeRunIndex: Math.max(0, Math.trunc(Number(payload.autoFreeRunIndex ?? payload.auto_free_run_index) || 0)),
        autoExpectedAny: Array.isArray(payload.autoExpectedAny ?? payload.auto_expected_any)
          ? (payload.autoExpectedAny ?? payload.auto_expected_any)
            .map((value) => String(value == null ? "" : value).trim())
            .filter((value) => !!value)
            .slice(0, 24)
          : [],
        autoLastCommand: String(payload.autoLastCommand ?? payload.auto_last_command ?? "").trim(),
        autoAwaitingSinceMs: Math.max(
          0,
          Math.trunc(Number(payload.autoAwaitingSinceMs ?? payload.auto_awaiting_since_ms) || 0)
        ),
        autoAwaitingDeadlineMs: Math.max(
          0,
          Math.trunc(Number(payload.autoAwaitingDeadlineMs ?? payload.auto_awaiting_deadline_ms) || 0)
        ),
        autoSending: false,
      }};
    }}

    function persistConsoleSessionState() {{
      try {{
        const storage = window.sessionStorage;
        if (!storage) return;
        let interactiveSession = null;
        if (consoleInteractiveSession && typeof consoleInteractiveSession === "object") {{
          const mode = String(consoleInteractiveSession.mode || "").trim().toLowerCase();
          if (mode === "standalone") {{
            const sessionId = String(consoleInteractiveSession.sessionId || "").trim();
            if (sessionId) {{
              interactiveSession = {{
                name: "zork",
                mode: "standalone",
                sessionId,
              }};
            }}
          }} else if (mode === "remote") {{
            const targetNodeId = normalizeNodeId(consoleInteractiveSession.targetNodeId || "");
            if (isCanonicalNodeId(targetNodeId)) {{
              interactiveSession = {{
                name: String(consoleInteractiveSession.name || "zork-remote").trim() || "zork-remote",
                mode: "remote",
                targetNodeId,
                targetLabel: String(consoleInteractiveSession.targetLabel || "").trim(),
                channelIndex: normalizeMeshChannelIndex(consoleInteractiveSession.channelIndex),
                channelLabel: String(consoleInteractiveSession.channelLabel || "").trim(),
                seenKeys: Array.from(consoleInteractiveSession.seenKeys || []).slice(-4000),
                autoResponseEnabled: consoleInteractiveSession.autoResponseEnabled === true,
                autoAwaitingReply: consoleInteractiveSession.autoAwaitingReply === true,
                autoScriptIndex: Math.max(0, Math.trunc(Number(consoleInteractiveSession.autoScriptIndex) || 0)),
                autoMode: String(consoleInteractiveSession.autoMode || "script").trim().toLowerCase() === "free-run"
                  ? "free-run"
                  : "script",
                autoFreeRunIndex: Math.max(0, Math.trunc(Number(consoleInteractiveSession.autoFreeRunIndex) || 0)),
                autoExpectedAny: Array.isArray(consoleInteractiveSession.autoExpectedAny)
                  ? consoleInteractiveSession.autoExpectedAny
                    .map((value) => String(value == null ? "" : value).trim())
                    .filter((value) => !!value)
                    .slice(0, 24)
                  : [],
                autoLastCommand: String(consoleInteractiveSession.autoLastCommand || "").trim(),
                autoAwaitingSinceMs: Math.max(
                  0,
                  Math.trunc(Number(consoleInteractiveSession.autoAwaitingSinceMs) || 0)
                ),
                autoAwaitingDeadlineMs: Math.max(
                  0,
                  Math.trunc(Number(consoleInteractiveSession.autoAwaitingDeadlineMs) || 0)
                ),
              }};
            }}
          }}
        }}
        const payload = {{
          lines: consoleLines.slice(-consoleMaxLines),
          commandHistory: consoleCommandHistory.slice(-consoleCommandHistoryMax),
          autoscroll: !!consoleAutoscroll,
          timestamps: !!consoleShowTimestamps,
          filterText: String(consoleFilterText || "").slice(0, 120),
          interactiveSession,
          eventCounter: Math.max(0, Math.trunc(Number(consoleEventCounter) || 0)),
        }};
        storage.setItem(consoleSessionStorageKey, JSON.stringify(payload));
      }} catch (_err) {{
      }}
    }}

    function loadConsoleSessionState() {{
      try {{
        const storage = window.sessionStorage;
        if (!storage) return;
        const raw = storage.getItem(consoleSessionStorageKey);
        if (!raw) return;
        const parsed = JSON.parse(raw);
        const payload = (parsed && typeof parsed === "object") ? parsed : {{}};
        const lines = Array.isArray(payload.lines)
          ? payload.lines
            .map((value) => String(value == null ? "" : value))
            .filter((value) => !!value)
            .slice(-consoleMaxLines)
          : [];
        consoleLines.length = 0;
        consoleLines.push(...lines);
        consoleKeyQueue.length = 0;
        consoleSeen.clear();
        lines.forEach((_line, index) => {{
          const key = `restored|${{index}}`;
          consoleKeyQueue.push(key);
          consoleSeen.add(key);
        }});
        consoleCommandHistory = Array.isArray(payload.commandHistory)
          ? payload.commandHistory
            .map((value) => String(value == null ? "" : value).trim())
            .filter((value) => !!value)
            .slice(-consoleCommandHistoryMax)
          : [];
        consoleCommandHistoryCursor = -1;
        consoleCommandDraft = "";
        consoleAutoscroll = payload.autoscroll !== false;
        consoleShowTimestamps = payload.timestamps === true;
        consoleFilterText = String(payload.filterText ?? payload.filter ?? "").slice(0, 120);
        consoleInteractiveSession = normalizeConsoleInteractiveSession(payload.interactiveSession);
        consoleEventCounter = Math.max(0, Math.trunc(Number(payload.eventCounter) || 0));
      }} catch (_err) {{
      }}
    }}

    function isStandaloneConsoleSessionExpiredMessage(value) {{
      const text = String(value == null ? "" : value).trim();
      if (!text) return false;
      return /no active standalone zork session/i.test(text);
    }}

    function normalizeStandaloneZorkReplyText(value) {{
      const text = String(value == null ? "" : value).trim();
      if (!text) return "";
      return text.replace(/^zork:\s*session started\.\s*/i, "").trim();
    }}

    function wildcardPatternToRegExp(pattern) {{
      const clean = String(pattern == null ? "" : pattern).trim();
      if (!clean || clean === "*") return /^.*$/i;
      let escaped = "";
      for (const ch of clean) {{
        if ("\\^$+?.()|{{}}[]".includes(ch)) {{
          escaped += `\\${{ch}}`;
        }} else {{
          escaped += ch;
        }}
      }}
      const regexBody = escaped.replace(/\*/g, ".*").replace(/\?/g, ".");
      return new RegExp(`^${{regexBody}}$`, "i");
    }}

    function wildcardMatches(pattern, value) {{
      const cleanPattern = String(pattern == null ? "" : pattern).trim();
      if (!cleanPattern) return true;
      const target = String(value == null ? "" : value).trim();
      try {{
        return wildcardPatternToRegExp(cleanPattern).test(target);
      }} catch (_err) {{
        return false;
      }}
    }}

    function normalizeWildcardPattern(value) {{
      const clean = String(value == null ? "" : value).trim();
      if (!clean) return "";
      if (clean.includes("*") || clean.includes("?")) return clean;
      return `*${{clean}}*`;
    }}

    function parseConsoleTokens(line) {{
      const input = String(line == null ? "" : line);
      const tokens = [];
      let buf = "";
      let quote = "";
      let escaped = false;
      for (let i = 0; i < input.length; i += 1) {{
        const ch = input[i];
        if (escaped) {{
          buf += ch;
          escaped = false;
          continue;
        }}
        if (ch === "\\") {{
          escaped = true;
          continue;
        }}
        if (quote) {{
          if (ch === quote) {{
            quote = "";
          }} else {{
            buf += ch;
          }}
          continue;
        }}
        if (ch === "'" || ch === "\"") {{
          quote = ch;
          continue;
        }}
        if (/\s/.test(ch)) {{
          if (buf) {{
            tokens.push(buf);
            buf = "";
          }}
          continue;
        }}
        buf += ch;
      }}
      if (escaped) buf += "\\";
      if (quote) {{
        return {{ tokens: [], error: `Unterminated quote (${{quote}})` }};
      }}
      if (buf) tokens.push(buf);
      return {{ tokens, error: "" }};
    }}

    function parseConsoleCommandLine(line) {{
      const parsedTokens = parseConsoleTokens(line);
      if (parsedTokens.error) {{
        return {{ command: "", args: [], options: {{}}, comparisons: [], error: parsedTokens.error }};
      }}
      const tokens = parsedTokens.tokens || [];
      if (!tokens.length) {{
        return {{ command: "", args: [], options: {{}}, comparisons: [], error: "Empty command" }};
      }}
      const command = String(tokens[0] || "").trim().toLowerCase();
      if (!command) {{
        return {{ command: "", args: [], options: {{}}, comparisons: [], error: "Missing command name" }};
      }}
      const args = [];
      const options = {{}};
      const comparisons = [];
      for (let i = 1; i < tokens.length; i += 1) {{
        const token = String(tokens[i] || "");
        if (!token) continue;
        const nextTokenRaw = (i + 1) < tokens.length ? String(tokens[i + 1] || "").trim() : "";
        const valueTokenRaw = (i + 2) < tokens.length ? String(tokens[i + 2] || "").trim() : "";
        const keyLike = /^[a-zA-Z_][a-zA-Z0-9_-]*$/.test(token);
        if (keyLike && (nextTokenRaw === "=" || nextTokenRaw === "<" || nextTokenRaw === ">" || nextTokenRaw === "<=" || nextTokenRaw === ">=") && valueTokenRaw) {{
          const cmpKey = token.trim().toLowerCase();
          if (nextTokenRaw === "=") {{
            options[cmpKey] = valueTokenRaw;
          }} else {{
            comparisons.push({{ key: cmpKey, op: nextTokenRaw, value: valueTokenRaw }});
          }}
          i += 2;
          continue;
        }}
        if (token.startsWith("--")) {{
          const body = token.slice(2).trim();
          if (!body) continue;
          if (body.startsWith("no-") && body.length > 3) {{
            options[body.slice(3).toLowerCase()] = false;
            continue;
          }}
          const eqIdx = body.indexOf("=");
          if (eqIdx > 0) {{
            const key = body.slice(0, eqIdx).trim().toLowerCase();
            const value = body.slice(eqIdx + 1).trim();
            if (key) options[key] = value;
            continue;
          }}
          options[body.toLowerCase()] = true;
          continue;
        }}
        const cmpMatch = token.match(/^([a-zA-Z_][a-zA-Z0-9_-]*)(<=|>=|<|>)(.+)$/);
        if (cmpMatch) {{
          const cmpKey = String(cmpMatch[1] || "").trim().toLowerCase();
          const cmpOp = String(cmpMatch[2] || "").trim();
          const cmpValue = String(cmpMatch[3] || "").trim();
          if (cmpKey && cmpOp && cmpValue) {{
            comparisons.push({{ key: cmpKey, op: cmpOp, value: cmpValue }});
            continue;
          }}
        }}
        const eqIdx = token.indexOf("=");
        if (eqIdx > 0) {{
          const key = token.slice(0, eqIdx).trim().toLowerCase();
          const value = token.slice(eqIdx + 1).trim();
          if (key) options[key] = value;
          continue;
        }}
        args.push(token);
      }}
      return {{ command, args, options, comparisons, error: "" }};
    }}

    function pushConsoleHistoryEntry(commandLine) {{
      const clean = String(commandLine == null ? "" : commandLine).trim();
      if (!clean) return;
      if (!consoleCommandHistory.length || consoleCommandHistory[consoleCommandHistory.length - 1] !== clean) {{
        consoleCommandHistory.push(clean);
      }}
      if (consoleCommandHistory.length > consoleCommandHistoryMax) {{
        consoleCommandHistory = consoleCommandHistory.slice(-consoleCommandHistoryMax);
      }}
      consoleCommandHistoryCursor = -1;
      consoleCommandDraft = "";
      persistConsoleSessionState();
    }}

    function navigateConsoleHistory(direction, inputEl) {{
      if (!(inputEl instanceof HTMLInputElement)) return;
      if (!Array.isArray(consoleCommandHistory) || !consoleCommandHistory.length) return;
      const step = Number(direction);
      if (!Number.isFinite(step) || step === 0) return;
      if (step < 0) {{
        if (consoleCommandHistoryCursor < 0) {{
          consoleCommandDraft = inputEl.value;
          consoleCommandHistoryCursor = consoleCommandHistory.length - 1;
        }} else if (consoleCommandHistoryCursor > 0) {{
          consoleCommandHistoryCursor -= 1;
        }}
      }} else {{
        if (consoleCommandHistoryCursor < 0) return;
        if (consoleCommandHistoryCursor < consoleCommandHistory.length - 1) {{
          consoleCommandHistoryCursor += 1;
        }} else {{
          consoleCommandHistoryCursor = -1;
          inputEl.value = consoleCommandDraft;
          inputEl.setSelectionRange(inputEl.value.length, inputEl.value.length);
          renderConsoleBuffer(false);
          return;
        }}
      }}
      if (consoleCommandHistoryCursor < 0 || consoleCommandHistoryCursor >= consoleCommandHistory.length) return;
      const nextValue = String(consoleCommandHistory[consoleCommandHistoryCursor] || "");
      inputEl.value = nextValue;
      inputEl.setSelectionRange(nextValue.length, nextValue.length);
      renderConsoleBuffer(false);
    }}

    function isZorkConsoleInteractiveSession(session = consoleInteractiveSession) {{
      if (!session || typeof session !== "object") return false;
      const mode = String(session.mode || "").trim().toLowerCase();
      if (mode === "standalone") return true;
      if (mode !== "remote") return false;
      const name = String(session.name || "").trim().toLowerCase();
      return name === "zork" || name === "zork-remote";
    }}

    function normalizeConsolePromptHostLabel(value) {{
      const clean = String(value == null ? "" : value).trim().toLowerCase();
      if (!clean) return "radio";
      const compact = clean
        .replace(/[^a-z0-9._-]+/g, "-")
        .replace(/^-+|-+$/g, "")
        .slice(0, 24);
      return compact || "radio";
    }}

    function resolveConsolePromptHostLabel(state = latestState) {{
      const safeState = (state && typeof state === "object") ? state : {{}};
      const selfId = normalizeNodeId(resolveLocalNodeId(safeState) || "");
      const nodes = Array.isArray(safeState.nodes) ? safeState.nodes : [];
      const selfNode = nodes.find((node) => normalizeNodeId(node && node.id) === selfId) || null;
      const owner = localNodeUserFromState(safeState);
      const longName = String((owner && owner.long_name) || "").trim();
      const shortName = String((owner && owner.short_name) || "").trim();
      const cachedName = selfId ? String(nodeNameCache.get(selfId) || "").trim() : "";
      const namedLabel = preferredNodeName(selfNode) || longName || shortName || cachedName;
      if (namedLabel) {{
        return normalizeConsolePromptHostLabel(namedLabel.replace(/^!+/, ""));
      }}
      if (isCanonicalNodeId(selfId)) {{
        return normalizeConsolePromptHostLabel(selfRadioProfileShortLabel(selfId));
      }}
      const profileShortEl = document.getElementById("self-radio-profile-short");
      if (profileShortEl instanceof HTMLElement) {{
        const shortText = String(profileShortEl.textContent || "").trim();
        if (shortText && shortText.toLowerCase() !== "na") {{
          return normalizeConsolePromptHostLabel(shortText);
        }}
      }}
      return normalizeConsolePromptHostLabel(selfId.replace(/^!+/, "") || "radio");
    }}
