      setFormValue(displayUnitsInput, normalizeDisplayUnits(displayCfg && displayCfg.units));
      setFormValue(displayModeInput, normalizeDisplayMode(displayCfg && displayCfg.displaymode));
      setFormChecked(displayFlipInput, normalizeConfigBool(displayCfg && displayCfg.flip_screen, false));
      setFormChecked(displayHeadingBoldInput, normalizeConfigBool(displayCfg && displayCfg.heading_bold, false));
      setFormChecked(displayWakeInput, normalizeConfigBool(displayCfg && displayCfg.wake_on_tap_or_motion, false));
      setFormChecked(displayUse12hInput, normalizeConfigBool(displayCfg && displayCfg.use_12h_clock, false));
      setFormChecked(displayUseLongNameInput, normalizeConfigBool(displayCfg && displayCfg.use_long_node_name, false));
      setFormChecked(displayBubblesInput, normalizeConfigBool(displayCfg && displayCfg.enable_message_bubbles, false));

      const bluetoothCfg = bluetoothConfigFromState(state);
      setFormChecked(bluetoothEnabledInput, normalizeConfigBool(bluetoothCfg && bluetoothCfg.enabled, false));
      setFormValue(bluetoothModeInput, normalizeBluetoothPairingMode(bluetoothCfg && bluetoothCfg.mode));
      setFormValue(bluetoothFixedPinInput, normalizeConfigSeconds(bluetoothCfg && bluetoothCfg.fixed_pin, 0, 0));

      const networkCfg = networkConfigFromState(state);
      setFormChecked(networkWifiEnabledInput, normalizeConfigBool(networkCfg && networkCfg.wifi_enabled, false));
      setFormChecked(networkEthEnabledInput, normalizeConfigBool(networkCfg && networkCfg.eth_enabled, false));
      setFormChecked(networkIpv6EnabledInput, normalizeConfigBool(networkCfg && networkCfg.ipv6_enabled, false));
      setFormValue(networkWifiSsidInput, networkCfg && networkCfg.wifi_ssid != null ? networkCfg.wifi_ssid : "");
      setFormValue(networkWifiPskInput, networkCfg && networkCfg.wifi_psk != null ? networkCfg.wifi_psk : "");
      setFormValue(networkNtpInput, networkCfg && networkCfg.ntp_server != null ? networkCfg.ntp_server : "");
      setFormValue(networkAddressModeInput, normalizeNetworkAddressMode(networkCfg && networkCfg.address_mode));
      setFormValue(networkRsyslogInput, networkCfg && networkCfg.rsyslog_server != null ? networkCfg.rsyslog_server : "");

      const securityCfg = securityConfigFromState(state);
      setFormChecked(securitySerialInput, normalizeConfigBool(securityCfg && securityCfg.serial_enabled, false));
      setFormChecked(securityDebugApiInput, normalizeConfigBool(securityCfg && securityCfg.debug_log_api_enabled, false));
      setFormChecked(securityAdminChannelInput, normalizeConfigBool(securityCfg && securityCfg.admin_channel_enabled, false));

      const mqttCfg = mqttConfigFromState(state);
      const mqttMapCfg = mqttCfg && mqttCfg.map_report_settings && typeof mqttCfg.map_report_settings === "object"
        ? mqttCfg.map_report_settings
        : null;
      setFormChecked(mqttEnabledInput, normalizeConfigBool(mqttCfg && mqttCfg.enabled, false));
      setFormValue(mqttAddressInput, mqttCfg && mqttCfg.address != null ? mqttCfg.address : "");
      setFormValue(mqttRootInput, mqttCfg && mqttCfg.root != null ? mqttCfg.root : "");
      setFormValue(mqttUsernameInput, mqttCfg && mqttCfg.username != null ? mqttCfg.username : "");
      setFormValue(mqttPasswordInput, mqttCfg && mqttCfg.password != null ? mqttCfg.password : "");
      setFormChecked(mqttEncryptionInput, normalizeConfigBool(mqttCfg && mqttCfg.encryption_enabled, false));
      setFormChecked(mqttJsonInput, normalizeConfigBool(mqttCfg && mqttCfg.json_enabled, false));
      setFormChecked(mqttTlsInput, normalizeConfigBool(mqttCfg && mqttCfg.tls_enabled, false));
      setFormChecked(mqttProxyInput, normalizeConfigBool(mqttCfg && mqttCfg.proxy_to_client_enabled, false));
      setFormChecked(mqttMapReportingInput, normalizeConfigBool(mqttCfg && mqttCfg.map_reporting_enabled, false));
      setFormValue(mqttMapPublishInput, normalizeConfigSeconds(mqttMapCfg && mqttMapCfg.publish_interval_secs, 0, 0));
      setFormValue(mqttMapPrecisionInput, normalizeConfigSeconds(mqttMapCfg && mqttMapCfg.position_precision, 0, 0));
      setFormChecked(mqttMapLocationInput, normalizeConfigBool(mqttMapCfg && mqttMapCfg.should_report_location, false));

      const serialCfg = serialConfigFromState(state);
      setFormChecked(serialEnabledInput, normalizeConfigBool(serialCfg && serialCfg.enabled, false));
      setFormChecked(serialEchoInput, normalizeConfigBool(serialCfg && serialCfg.echo, false));
      setFormChecked(serialOverrideConsoleInput, normalizeConfigBool(serialCfg && serialCfg.override_console_serial_port, false));
      setFormValue(serialModeInput, normalizeSerialMode(serialCfg && serialCfg.mode));
      setFormValue(serialBaudInput, normalizeSerialBaud(serialCfg && serialCfg.baud));
      setFormValue(serialTimeoutInput, normalizeConfigSeconds(serialCfg && serialCfg.timeout, 0, 0));

      const extNotifyCfg = externalNotificationConfigFromState(state);
      setFormChecked(extNotifyEnabledInput, normalizeConfigBool(extNotifyCfg && extNotifyCfg.enabled, false));
      setFormChecked(extNotifyAlertMessageInput, normalizeConfigBool(extNotifyCfg && extNotifyCfg.alert_message, false));
      setFormChecked(extNotifyAlertBellInput, normalizeConfigBool(extNotifyCfg && extNotifyCfg.alert_bell, false));
      setFormChecked(extNotifyActiveInput, normalizeConfigBool(extNotifyCfg && extNotifyCfg.active, false));
      setFormChecked(extNotifyUsePwmInput, normalizeConfigBool(extNotifyCfg && extNotifyCfg.use_pwm, false));
      setFormValue(extNotifyOutputMsInput, normalizeConfigSeconds(extNotifyCfg && extNotifyCfg.output_ms, 0, 0));
      setFormValue(extNotifyOutputPinInput, normalizeConfigSeconds(extNotifyCfg && extNotifyCfg.output, 0, 0));
      setFormValue(extNotifyNagTimeoutInput, normalizeConfigSeconds(extNotifyCfg && extNotifyCfg.nag_timeout, 0, 0));

      const fixedFromState = fixedPositionFromState(state);
      if (fixedFromState) {{
        persistSettingsFixedPositionCache(fixedFromState);
      }}
      const fixedFromLocalNode = localNodePositionCandidate(state);
      const fixedForForm = fixedFromState || settingsFixedPositionCache || fixedFromLocalNode;
      if (!fixedFromState && !settingsFixedPositionCache && fixedFromLocalNode) {{
        persistSettingsFixedPositionCache(fixedFromLocalNode);
      }}
      if (fixedForForm) {{
        setFormValue(fixedLatInput, Number(fixedForForm.lat).toFixed(6));
        setFormValue(fixedLonInput, Number(fixedForForm.lon).toFixed(6));
        if (Number.isFinite(Number(fixedForForm.alt))) {{
          setFormValue(fixedAltInput, String(Math.trunc(Number(fixedForForm.alt))));
        }}
      }}
      const sourceFromRadio = radioPositionSourceFromState(state);
      const shouldAutoCenterFixed = (
        activeLayoutView === "settings"
        && !!fixedForForm
        && !settingsFixedMapAutoCenteredOnce
      );

      syncLoraManualFieldsDisabled();
      syncSettingsPositionSourceUi({{
        source: sourceFromRadio || (fixedForForm ? "fixed" : settingsPositionSourcePref),
        recenter: shouldAutoCenterFixed,
      }});
    }}

    function markSettingsDirty(message = "Unsaved settings changes") {{
      settingsDirty = true;
      settingsDirtyAt = Date.now();
      setSettingsStatusText(message);
    }}

    function clearSettingsDirty() {{
      settingsDirty = false;
      settingsDirtyAt = 0;
    }}

    function setSettingsStatusText(message) {{
      setText("settings-apply-status", message);
    }}

    function setChannelsStatusText(message) {{
      setText("channels-apply-status", message);
    }}

    function setSettingsAndChannelsStatusText(message) {{
      setSettingsStatusText(message);
      setChannelsStatusText(message);
    }}

    function readSelectValue(id) {{
      const el = document.getElementById(id);
      if (!(el instanceof HTMLSelectElement)) return null;
      const value = String(el.value || "").trim();
      return value.length ? value : null;
    }}

    function readCheckboxValue(id) {{
      const el = document.getElementById(id);
      if (!(el instanceof HTMLInputElement) || el.type !== "checkbox") return null;
      return !!el.checked;
    }}

    function readNumberValue(id, allowFloat = false) {{
      const el = document.getElementById(id);
      if (!(el instanceof HTMLInputElement)) return null;
      const raw = String(el.value || "").trim();
      if (!raw) return null;
      const num = Number(raw);
      if (!Number.isFinite(num)) return null;
      return allowFloat ? num : Math.trunc(num);
    }}

    function readTextValue(id) {{
      const el = document.getElementById(id);
      if (!(el instanceof HTMLInputElement) && !(el instanceof HTMLTextAreaElement)) return null;
      const raw = String(el.value || "").trim();
      return raw.length ? raw : null;
    }}

    function cacheSettingsFixedInputsIfValid() {{
      const lat = readNumberValue("settings-fixed-latitude", true);
      const lon = readNumberValue("settings-fixed-longitude", true);
      if (!isValidLatLonRange(lat, lon)) return false;
      const alt = readNumberValue("settings-fixed-altitude");
      persistSettingsFixedPositionCache({{
        lat: Number(lat),
        lon: Number(lon),
        alt,
      }});
      return true;
    }}

