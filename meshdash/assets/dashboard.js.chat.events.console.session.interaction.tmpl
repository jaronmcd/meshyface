    function syncConsoleCommandInputState(state = latestState) {{
      const input = consoleCommandInputElement();
      const runningName = consoleRunningCommand && consoleRunningCommand.name
        ? String(consoleRunningCommand.name)
        : "";
      const interactiveName = consoleInteractiveSession && consoleInteractiveSession.name
        ? String(consoleInteractiveSession.name)
        : "";
      const interactiveIsZork = isZorkConsoleInteractiveSession(consoleInteractiveSession);
      const promptLabel = runningName
        ? `${{runningName.replace(/[^a-z0-9_-]+/gi, "").slice(0, 10) || "busy"}}>`
        : interactiveIsZork
          ? ">"
          : `[${{resolveConsolePromptHostLabel(state)}}]$`;
      const placeholder = runningName
        ? (
          String(runningName).trim().toLowerCase() === "live"
            ? "ctrl+c or q to stop live"
            : `ctrl+c to stop ${{runningName}}`
        )
        : interactiveIsZork
          ? "enter zork command  /search or /help for console"
          : interactiveName
            ? `enter ${{interactiveName}} command  /search or /help for console`
          : "enter command, /search, or help";
      consolePromptLabel = promptLabel;
      if (input instanceof HTMLInputElement) {{
        input.placeholder = placeholder;
        input.setAttribute("title", placeholder);
      }}
      renderConsolePromptBuffer(false);
      persistConsoleSessionState();
    }}

    function focusConsoleCommandInput(select = false) {{
      const input = consoleCommandInputElement();
      if (!(input instanceof HTMLInputElement)) return;
      const prevWindowX = Number(window.scrollX || window.pageXOffset || 0);
      const prevWindowY = Number(window.scrollY || window.pageYOffset || 0);
      const scrollingEl = document.scrollingElement instanceof HTMLElement
        ? document.scrollingElement
        : null;
      const prevDocLeft = scrollingEl ? Number(scrollingEl.scrollLeft || 0) : prevWindowX;
      const prevDocTop = scrollingEl ? Number(scrollingEl.scrollTop || 0) : prevWindowY;
      try {{
        input.focus({{ preventScroll: true }});
      }} catch (_err) {{
        input.focus();
      }}
      if (scrollingEl) {{
        if (Number.isFinite(prevDocTop) && scrollingEl.scrollTop !== prevDocTop) {{
          scrollingEl.scrollTop = prevDocTop;
        }}
        if (Number.isFinite(prevDocLeft) && scrollingEl.scrollLeft !== prevDocLeft) {{
          scrollingEl.scrollLeft = prevDocLeft;
        }}
      }}
      const nextWindowX = Number(window.scrollX || window.pageXOffset || 0);
      const nextWindowY = Number(window.scrollY || window.pageYOffset || 0);
      if (
        Number.isFinite(prevWindowX)
        && Number.isFinite(prevWindowY)
        && (nextWindowX !== prevWindowX || nextWindowY !== prevWindowY)
      ) {{
        try {{
          window.scrollTo(prevWindowX, prevWindowY);
        }} catch (_err) {{
        }}
      }}
      if (select) {{
        input.select();
      }} else {{
        const len = input.value.length;
        input.setSelectionRange(len, len);
      }}
      consoleCursorVisible = true;
      renderConsolePromptBuffer(false);
    }}

    function insertTextIntoConsoleCommandInput(text, inputEl = null) {{
      const input = inputEl instanceof HTMLInputElement ? inputEl : consoleCommandInputElement();
      if (!(input instanceof HTMLInputElement)) return false;
      const rawText = String(text == null ? "" : text);
      if (!rawText) return false;
      const normalizedText = rawText.replace(/\r\n/g, "\n").replace(/\r/g, "\n");
      const current = String(input.value || "");
      const startRaw = Number(input.selectionStart);
      const endRaw = Number(input.selectionEnd);
      const start = Number.isFinite(startRaw)
        ? Math.max(0, Math.min(current.length, Math.trunc(startRaw)))
        : current.length;
      const end = Number.isFinite(endRaw)
        ? Math.max(start, Math.min(current.length, Math.trunc(endRaw)))
        : start;
      input.value = `${{current.slice(0, start)}}${{normalizedText}}${{current.slice(end)}}`;
      const nextCaret = start + normalizedText.length;
      try {{
      input.setSelectionRange(nextCaret, nextCaret);
      }} catch (_err) {{
      }}
      consoleCommandHistoryCursor = -1;
      consoleCommandDraft = "";
      consoleAutocompleteState = null;
      renderConsolePromptBuffer(false);
      return true;
    }}

    function handleConsolePastedText(pastedText, inputEl = null) {{
      const input = inputEl instanceof HTMLInputElement ? inputEl : consoleCommandInputElement();
      if (!(input instanceof HTMLInputElement)) return false;
      const rawText = String(pastedText == null ? "" : pastedText);
      if (!rawText) return false;
      const hasLineBreak = /\r|\n/.test(rawText);
      const batchLines = typeof normalizeConsoleBatchLines === "function"
        ? normalizeConsoleBatchLines(rawText)
        : [];
      const currentDraft = String(input.value || "").trim();
      const hasTranscriptPaste = hasLineBreak
        && typeof consoleBatchTextContainsTranscriptOutput === "function"
        && consoleBatchTextContainsTranscriptOutput(rawText);
      const canRunBatch = (
        (batchLines.length > 1 || (hasTranscriptPaste && batchLines.length >= 1))
        && !currentDraft
        && !consoleInteractiveSession
        && typeof runConsoleCommandBatch === "function"
      );
      if (canRunBatch) {{
        input.value = "";
        consoleCommandHistoryCursor = -1;
        consoleCommandDraft = "";
        resetConsoleAutocompleteState();
        renderConsolePromptBuffer(false);
        void runConsoleCommandBatch(batchLines);
        return true;
      }}
      if (hasLineBreak && (batchLines.length > 1 || hasTranscriptPaste) && !currentDraft) {{
        appendConsoleEventLine("[batch] paste ignored: pasted text does not look like a valid command batch.");
        return true;
      }}
      return insertTextIntoConsoleCommandInput(rawText, input);
    }}

    function resetConsoleAutocompleteState() {{
      consoleAutocompleteState = null;
      consoleAutocompleteMenuSelectedIndex = 0;
      consoleAutocompleteMenuSignature = "";
      hideConsoleAutocompleteMenu();
    }}

    function syncConsoleCommandDraftRender(rawValue) {{
      const value = String(rawValue == null ? "" : rawValue);
      const searchState = (typeof syncConsoleSearchFromDraft === "function")
        ? syncConsoleSearchFromDraft(value)
        : {{ active: false, changed: false }};
      if (searchState.active || searchState.changed) {{
        renderConsoleBuffer(false);
      }} else {{
        renderConsolePromptBuffer(false);
      }}
    }}

    function resolveConsoleAutocompleteContext(inputEl) {{
      if (!(inputEl instanceof HTMLInputElement)) return null;
      const draft = String(inputEl.value || "");
      const rawStart = Number(inputEl.selectionStart);
      const rawEnd = Number(inputEl.selectionEnd);
      const caret = Number.isFinite(rawStart)
        ? Math.max(0, Math.min(draft.length, Math.trunc(rawStart)))
        : draft.length;
      const selectionEnd = Number.isFinite(rawEnd)
        ? Math.max(0, Math.min(draft.length, Math.trunc(rawEnd)))
        : caret;
      if (caret !== selectionEnd) return null;

      const tokens = parseConsoleTokenRanges(draft);
      let tokenIndex = tokens.length;
      let token = {{
        text: "",
        rawStart: caret,
        rawEnd: caret,
        quote: "",
        unterminated: false,
      }};
      for (let i = 0; i < tokens.length; i += 1) {{
        const candidate = tokens[i];
        if (caret < candidate.rawStart) {{
          tokenIndex = i;
          break;
        }}
        if (caret >= candidate.rawStart && caret <= candidate.rawEnd) {{
          tokenIndex = i;
          token = candidate;
          break;
        }}
      }}

      const rawToken = draft.slice(token.rawStart, token.rawEnd);
      const commandToken = tokenIndex === 0
        ? token.text
        : String(tokens[0] && tokens[0].text ? tokens[0].text : "");
      const commandRaw = tokenIndex === 0
        ? rawToken
        : (
          tokens[0]
            ? draft.slice(tokens[0].rawStart, tokens[0].rawEnd)
            : ""
        );

      return {{
        draft,
        caret,
        tokenIndex,
        tokenText: String(token.text || ""),
        rawToken,
        rawStart: token.rawStart,
        rawEnd: token.rawEnd,
        prefixRaw: draft.slice(0, token.rawStart),
        suffixRaw: draft.slice(token.rawEnd),
        leadingSlash: commandRaw.startsWith("/"),
        commandName: String(commandToken || "").replace(/^\/+/, "").trim().toLowerCase(),
      }};
    }}

    function applyConsoleAutocompleteCandidate(inputEl, context, candidate, options = null) {{
      if (!(inputEl instanceof HTMLInputElement)) return null;
      const ctx = (context && typeof context === "object") ? context : null;
      if (!ctx) return null;
      const opts = (options && typeof options === "object") ? options : {{}};
      const normalizedCandidate = (typeof normalizeConsoleAutocompleteCandidate === "function")
        ? normalizeConsoleAutocompleteCandidate(candidate)
        : null;
      let replacement = String(
        normalizedCandidate && normalizedCandidate.insertText
          ? normalizedCandidate.insertText
          : (candidate == null ? "" : candidate)
      );
      if (!replacement) return null;
      const canAppendSpace = opts.appendSpace === true
        && !replacement.endsWith(" ")
        && !/^\s/.test(String(ctx.suffixRaw || ""));
      if (canAppendSpace) {{
        replacement += " ";
      }}
      const nextValue = `${{String(ctx.prefixRaw || "")}}${{replacement}}${{String(ctx.suffixRaw || "")}}`;
      const nextCaret = String(ctx.prefixRaw || "").length + replacement.length;
      inputEl.value = nextValue;
      try {{
        inputEl.setSelectionRange(nextCaret, nextCaret);
      }} catch (_err) {{
      }}
      syncConsoleCommandDraftRender(nextValue);
      return {{
        value: nextValue,
        caret: nextCaret,
      }};
    }}

    function handleConsoleTabAutocomplete(inputEl, state = latestState, reverse = false) {{
      if (!(inputEl instanceof HTMLInputElement)) return false;
      const activeSession = (consoleAutocompleteState && typeof consoleAutocompleteState === "object")
        ? consoleAutocompleteState
        : null;
      const currentValue = String(inputEl.value || "");
      const currentCaret = Math.max(0, Math.trunc(Number(inputEl.selectionStart) || 0));
      const currentSelectionEnd = Math.max(0, Math.trunc(Number(inputEl.selectionEnd) || 0));
      if (currentCaret !== currentSelectionEnd) {{
        resetConsoleAutocompleteState();
        return false;
      }}

      if (
        activeSession
        && Array.isArray(activeSession.candidates)
        && activeSession.candidates.length > 1
        && currentValue === String(activeSession.appliedDraft || "")
        && currentCaret === Math.max(0, Math.trunc(Number(activeSession.caret) || 0))
      ) {{
        const count = activeSession.candidates.length;
        const nextIndex = reverse
          ? (activeSession.index + count - 1) % count
          : (activeSession.index + 1) % count;
        const nextDraft = applyConsoleAutocompleteCandidate(
          inputEl,
          {{
            prefixRaw: activeSession.prefixRaw,
            suffixRaw: activeSession.suffixRaw,
          }},
          activeSession.candidates[nextIndex],
          {{ appendSpace: false }},
        );
        if (!nextDraft) {{
          resetConsoleAutocompleteState();
          return false;
        }}
        consoleAutocompleteState = {{
          ...activeSession,
          index: nextIndex,
          appliedDraft: nextDraft.value,
          caret: nextDraft.caret,
        }};
        return true;
      }}

      const context = resolveConsoleAutocompleteContext(inputEl);
      if (!context) {{
        resetConsoleAutocompleteState();
        return false;
      }}
      const candidates = resolveConsoleAutocompleteCandidates(context, state)
        .map((candidate) => (
          typeof normalizeConsoleAutocompleteCandidate === "function"
            ? normalizeConsoleAutocompleteCandidate(candidate)
            : null
        ))
        .filter((candidate) => !!(candidate && candidate.insertText));
      if (!candidates.length) {{
        resetConsoleAutocompleteState();
        return false;
      }}

      let candidateIndex = 0;
      if (candidates.length > 1) {{
        const existingIndex = candidates.findIndex((candidate) => (
          String(candidate.insertText || "") === context.rawToken
          || String(candidate.insertText || "") === context.tokenText
          || String(candidate.displayText || "") === context.rawToken
          || String(candidate.displayText || "") === context.tokenText
        ));
        if (existingIndex >= 0) {{
          candidateIndex = reverse
            ? (existingIndex + candidates.length - 1) % candidates.length
            : (existingIndex + 1) % candidates.length;
        }} else {{
          candidateIndex = reverse ? (candidates.length - 1) : 0;
        }}
      }}

      const nextDraft = applyConsoleAutocompleteCandidate(
        inputEl,
        context,
        candidates[candidateIndex],
        {{ appendSpace: candidates.length === 1 }},
      );
      if (!nextDraft) {{
        resetConsoleAutocompleteState();
        return false;
      }}

      if (candidates.length > 1) {{
        consoleAutocompleteState = {{
          candidates,
          index: candidateIndex,
          prefixRaw: context.prefixRaw,
          suffixRaw: context.suffixRaw,
          appliedDraft: nextDraft.value,
          caret: nextDraft.caret,
        }};
      }} else {{
        resetConsoleAutocompleteState();
      }}
      return true;
    }}

    function resolveConsoleAutocompleteGhostRemainder(rawToken, candidate) {{
      const token = String(rawToken == null ? "" : rawToken);
      const normalizedCandidate = (typeof normalizeConsoleAutocompleteCandidate === "function")
        ? normalizeConsoleAutocompleteCandidate(candidate)
        : null;
      if (!normalizedCandidate) return "";
      if (!token) {{
        const emptyTokenGhost = Object.prototype.hasOwnProperty.call(normalizedCandidate, "ghostText")
          ? normalizedCandidate.ghostText
          : (normalizedCandidate.displayText || normalizedCandidate.insertText || "");
        return String(emptyTokenGhost || "");
      }}
      const tokenLower = token.toLowerCase();
      const hasExplicitGhost = Object.prototype.hasOwnProperty.call(normalizedCandidate, "ghostText");
      const variants = hasExplicitGhost
        ? [String(normalizedCandidate.ghostText || "")]
        : [
            String(normalizedCandidate.displayText || ""),
            String(normalizedCandidate.insertText || ""),
          ];
      for (const variant of variants) {{
        if (!variant) continue;
        if (variant === token) return "";
        if (variant.toLowerCase().startsWith(tokenLower)) {{
          return variant.slice(token.length);
        }}
      }}
      return "";
    }}

    function resolveConsoleAutocompleteGhostSuffix(inputEl, state = latestState) {{
      if (!(inputEl instanceof HTMLInputElement)) return "";
      const draft = String(inputEl.value || "");
      if (!draft) return "";
      const caret = Math.max(0, Math.trunc(Number(inputEl.selectionStart) || 0));
      const selectionEnd = Math.max(0, Math.trunc(Number(inputEl.selectionEnd) || 0));
      if (caret !== selectionEnd || caret !== draft.length) return "";

      const context = resolveConsoleAutocompleteContext(inputEl);
      if (!context) return "";
      const rawToken = String(context.rawToken || "");

      const candidates = resolveConsoleAutocompleteCandidates(context, state)
        .map((candidate) => (
          typeof normalizeConsoleAutocompleteCandidate === "function"
            ? normalizeConsoleAutocompleteCandidate(candidate)
            : null
        ))
        .filter((candidate) => !!(candidate && candidate.insertText));
      if (!candidates.length) return "";

      return resolveConsoleAutocompleteGhostRemainder(rawToken, candidates[0]);
    }}

    function acceptConsoleAutocompleteGhost(inputEl, state = latestState) {{
      if (!(inputEl instanceof HTMLInputElement)) return false;
      const ghostSuffix = (typeof resolveConsoleAutocompleteGhostSuffix === "function")
        ? String(resolveConsoleAutocompleteGhostSuffix(inputEl, state) || "")
        : "";
      if (!ghostSuffix) return false;
      return handleConsoleTabAutocomplete(inputEl, state, false);
    }}

    function consoleAutocompleteMenuElement() {{
      const el = document.getElementById("console-autocomplete-menu");
      return el instanceof HTMLElement ? el : null;
    }}

    function hideConsoleAutocompleteMenu() {{
      const menu = consoleAutocompleteMenuElement();
      if (!(menu instanceof HTMLElement)) return;
      menu.hidden = true;
      menu.setAttribute("aria-hidden", "true");
      menu.innerHTML = "";
    }}

    function isConsoleAutocompleteMenuOpen() {{
      const menu = consoleAutocompleteMenuElement();
      return menu instanceof HTMLElement && !menu.hidden;
    }}

    function consoleAutocompleteCommandMeta(candidate) {{
      const normalizedCandidate = (typeof normalizeConsoleAutocompleteCandidate === "function")
        ? normalizeConsoleAutocompleteCandidate(candidate)
        : null;
      if (!normalizedCandidate) return "";
      const commandName = String(normalizedCandidate.insertText || normalizedCandidate.displayText || "")
        .replace(/^\/+/, "")
        .trim()
        .toLowerCase();
      if (!commandName || !(consoleCommandRegistry instanceof Map)) return "";
      const def = consoleCommandRegistry.get(commandName);
      if (!def || typeof def !== "object") return "";
      const usage = String(def.usage || commandName).trim();
      const description = String(def.description || "").trim();
      return [usage, description].filter(Boolean).join(" - ");
    }}

    function resolveConsoleAutocompleteMenuPayload(inputEl, state = latestState) {{
      const input = inputEl instanceof HTMLInputElement ? inputEl : consoleCommandInputElement();
      if (!(input instanceof HTMLInputElement)) return null;
      if (activeLayoutView !== "console" || document.activeElement !== input) return null;
      const draft = String(input.value || "");
      if (!draft) return null;
      const caret = Math.max(0, Math.trunc(Number(input.selectionStart) || 0));
      const selectionEnd = Math.max(0, Math.trunc(Number(input.selectionEnd) || 0));
      if (caret !== selectionEnd || caret !== draft.length) return null;
      const context = resolveConsoleAutocompleteContext(input);
      if (!context) return null;
      if (consoleInteractiveSession && context.tokenIndex === 0 && context.leadingSlash !== true) {{
        return null;
      }}
      const candidates = resolveConsoleAutocompleteCandidates(context, state)
        .map((candidate) => (
          typeof normalizeConsoleAutocompleteCandidate === "function"
            ? normalizeConsoleAutocompleteCandidate(candidate)
            : null
        ))
        .filter((candidate) => !!(candidate && candidate.insertText));
      if (!candidates.length) return null;
      const signature = [
        String(context.rawStart),
        String(context.rawEnd),
        String(context.rawToken || ""),
        String(context.commandName || ""),
        candidates.map((candidate) => String(candidate.insertText || "")).join("\u001f"),
      ].join("\u001e");
      return {{
        context,
        candidates,
        signature,
      }};
    }}

    function renderConsoleAutocompleteMenu(inputEl = null, state = latestState) {{
      const menu = consoleAutocompleteMenuElement();
      if (!(menu instanceof HTMLElement)) return;
      const input = inputEl instanceof HTMLInputElement ? inputEl : consoleCommandInputElement();
      const payload = resolveConsoleAutocompleteMenuPayload(input, state);
      if (!payload) {{
        hideConsoleAutocompleteMenu();
        return;
      }}
      const candidates = payload.candidates;
      if (payload.signature !== consoleAutocompleteMenuSignature) {{
        consoleAutocompleteMenuSignature = payload.signature;
        consoleAutocompleteMenuSelectedIndex = 0;
      }}
      const selectedIndex = Math.max(
        0,
        Math.min(candidates.length - 1, Math.trunc(Number(consoleAutocompleteMenuSelectedIndex) || 0))
      );
      consoleAutocompleteMenuSelectedIndex = selectedIndex;
      menu.innerHTML = "";
      menu.hidden = false;
      menu.setAttribute("aria-hidden", "false");
      menu.setAttribute("role", "listbox");
      menu.dataset.consoleAutocompleteSignature = payload.signature;
      menu.dataset.consoleAutocompleteSelectedIndex = String(selectedIndex);
      const fragment = document.createDocumentFragment();
      for (let index = 0; index < candidates.length; index += 1) {{
        const candidate = candidates[index];
        const kindRaw = String(candidate && candidate.kind || "command").trim().toLowerCase();
        const kind = kindRaw === "node" ? "node" : "command";
        const item = document.createElement("button");
        item.type = "button";
        item.className = `console-autocomplete-item console-autocomplete-item-${{kind}}${{kind === "node" ? " is-node" : ""}}${{index === selectedIndex ? " is-selected" : ""}}`;
        item.setAttribute("role", "option");
        item.setAttribute("aria-selected", index === selectedIndex ? "true" : "false");
        item.dataset.consoleAutocompleteIndex = String(index);

        if (kind === "node") {{
          const icon = document.createElement("span");
          icon.className = "console-autocomplete-node-icon";
          icon.textContent = String(candidate.nodeEmoji || "");
          item.appendChild(icon);

          const main = document.createElement("span");
          main.className = "console-autocomplete-node-main";

          const title = document.createElement("span");
          title.className = "console-autocomplete-node-title";

          const name = document.createElement("span");
          name.className = "console-autocomplete-node-name";
          name.textContent = String(candidate.nodeName || candidate.displayText || candidate.insertText || "");
          title.appendChild(name);

          const id = document.createElement("span");
          id.className = "console-autocomplete-node-id";
          id.textContent = String(candidate.nodeId || candidate.displayText || candidate.insertText || "");
          title.appendChild(id);
          main.appendChild(title);

          const meta = document.createElement("span");
          meta.className = "console-autocomplete-node-meta";
          meta.textContent = String(candidate.metaText || "");
          main.appendChild(meta);
          item.appendChild(main);
        }} else {{
          const name = document.createElement("span");
          name.className = "console-autocomplete-item-name";
          name.textContent = String(candidate.displayText || candidate.insertText || "");
          item.appendChild(name);

          const metaText = consoleAutocompleteCommandMeta(candidate);
          if (metaText) {{
            const meta = document.createElement("span");
            meta.className = "console-autocomplete-item-meta";
            meta.textContent = metaText;
            item.appendChild(meta);
          }}
        }}
        fragment.appendChild(item);
      }}
      menu.appendChild(fragment);
      const selectedEl = menu.querySelector(".console-autocomplete-item.is-selected");
      if (selectedEl instanceof HTMLElement) {{
        selectedEl.scrollIntoView({{ block: "nearest" }});
      }}
    }}

    function syncConsoleAutocompleteMenuSelection() {{
      const menu = consoleAutocompleteMenuElement();
      if (!(menu instanceof HTMLElement) || menu.hidden) return false;
      const items = Array.from(menu.querySelectorAll(".console-autocomplete-item"))
        .filter((item) => item instanceof HTMLElement);
      if (!items.length) return false;
      const selectedIndex = Math.max(
        0,
        Math.min(items.length - 1, Math.trunc(Number(consoleAutocompleteMenuSelectedIndex) || 0))
      );
      consoleAutocompleteMenuSelectedIndex = selectedIndex;
      menu.dataset.consoleAutocompleteSelectedIndex = String(selectedIndex);
      items.forEach((item, index) => {{
        item.classList.toggle("is-selected", index === selectedIndex);
        item.setAttribute("aria-selected", index === selectedIndex ? "true" : "false");
      }});
      const selectedEl = items[selectedIndex];
      if (selectedEl instanceof HTMLElement) {{
        selectedEl.scrollIntoView({{ block: "nearest" }});
      }}
      return true;
    }}

    function moveConsoleAutocompleteMenuSelection(delta) {{
      const menu = consoleAutocompleteMenuElement();
      if (!(menu instanceof HTMLElement) || menu.hidden) return false;
      const count = menu.querySelectorAll(".console-autocomplete-item").length;
      if (count < 1) return false;
      const cleanDelta = Math.trunc(Number(delta) || 0);
      if (!cleanDelta) return false;
      const current = Math.max(0, Math.min(count - 1, Math.trunc(Number(consoleAutocompleteMenuSelectedIndex) || 0)));
      consoleAutocompleteMenuSelectedIndex = (current + cleanDelta + count) % count;
      return syncConsoleAutocompleteMenuSelection();
    }}

    function applyConsoleAutocompleteMenuSelection(inputEl = null, state = latestState) {{
      const input = inputEl instanceof HTMLInputElement ? inputEl : consoleCommandInputElement();
      if (!(input instanceof HTMLInputElement)) return false;
      const payload = resolveConsoleAutocompleteMenuPayload(input, state);
      if (!payload) return false;
      const index = Math.max(
        0,
        Math.min(payload.candidates.length - 1, Math.trunc(Number(consoleAutocompleteMenuSelectedIndex) || 0))
      );
      const nextDraft = applyConsoleAutocompleteCandidate(
        input,
        payload.context,
        payload.candidates[index],
        {{ appendSpace: true }},
      );
      if (!nextDraft) return false;
      resetConsoleAutocompleteState();
      renderConsolePromptBuffer(false);
      return true;
    }}

    function handleConsolePasteEvent(ev) {{
      if (!ev || ev.defaultPrevented || activeLayoutView !== "console") return false;
      const target = ev.target;
      if (target instanceof HTMLTextAreaElement) return false;
      if (
        target instanceof HTMLInputElement
        && target.id
        && target.id !== "console-command-input"
      ) {{
        return false;
      }}
      const clipboardData = ev.clipboardData;
      const pastedText = clipboardData && typeof clipboardData.getData === "function"
        ? clipboardData.getData("text/plain")
        : "";
      if (!pastedText) return false;
      focusConsoleCommandInput(false);
      const input = consoleCommandInputElement();
      if (!(input instanceof HTMLInputElement)) return false;
      ev.preventDefault();
      ev.stopPropagation();
      return handleConsolePastedText(pastedText, input);
    }}

    function selectionIntersectsElement(selection, element) {{
      if (!(element instanceof HTMLElement)) return false;
      if (!selection || typeof selection.rangeCount !== "number" || selection.rangeCount < 1) {{
        return false;
      }}
      try {{
        const range = selection.getRangeAt(0);
        const container = range.commonAncestorContainer;
        if (container instanceof Node) {{
          return element.contains(container);
        }}
      }} catch (_err) {{
      }}
      return false;
    }}

    function selectionTextWithin(element) {{
      if (!(element instanceof HTMLElement)) return "";
      const selection = window.getSelection ? window.getSelection() : null;
      if (!selectionIntersectsElement(selection, element)) return "";
      return String(selection ? selection.toString() : "");
    }}

    function hasConsoleSelectionWithin(element) {{
      return selectionTextWithin(element).trim().length > 0;
    }}

    async function copySelectionToClipboardWithin(element) {{
      const text = selectionTextWithin(element);
      if (!text.trim()) return false;
      try {{
        if (typeof copyTextToClipboard !== "function") {{
          return false;
        }}
        return await copyTextToClipboard(text);
      }} catch (_err) {{
        return false;
      }}
    }}

    async function copyConsoleSelectionToClipboard() {{
      const pre = document.getElementById("live-console");
      return copySelectionToClipboardWithin(pre instanceof HTMLElement ? pre : null);
    }}

    async function copyChatSelectionToClipboard() {{
      const feed = document.getElementById("chat-feed");
      return copySelectionToClipboardWithin(feed instanceof HTMLElement ? feed : null);
    }}

    function startConsoleRunningCommand(name, onStop = null) {{
      const clean = String(name == null ? "" : name).trim().toLowerCase() || "command";
      consoleRunningCommand = {{
        name: clean,
        stop: typeof onStop === "function" ? onStop : null,
      }};
      syncConsoleCommandInputState();
    }}

    function stopConsoleRunningCommand(reason = "stopped", emitStatus = true) {{
      if (!consoleRunningCommand) return false;
      const active = consoleRunningCommand;
      consoleRunningCommand = null;
      syncConsoleCommandInputState();
      if (typeof active.stop === "function") {{
        try {{
          active.stop(reason, !!emitStatus);
        }} catch (_err) {{
        }}
      }}
      return true;
    }}

    function stopConsoleInteractiveSession(reason = "stopped", emitStatus = true) {{
      if (!consoleInteractiveSession) return false;
      const active = consoleInteractiveSession;
      consoleInteractiveSession = null;
      syncConsoleCommandInputState();
      if (emitStatus) {{
        const targetLabel = String(active.targetLabel || active.targetNodeId || "session");
        appendConsoleEventLine(`[${{String(active.name || "session")}}] stopped (${{String(reason || "done")}}) with ${{targetLabel}}.`);
      }}
      return true;
    }}

    async function sendConsoleInteractiveSessionLine(rawLine) {{
      const session = consoleInteractiveSession;
      if (!session) {{
        return "[console] no interactive session is active.";
      }}
      const text = String(rawLine == null ? "" : rawLine).trim();
      if (!text) return "";
      if (String(session.mode || "") !== "standalone") {{
        stopConsoleInteractiveSession("unsupported mode", false);
        return "[console] interactive session mode is no longer supported. Type \"zork\" to start a new local game.";
      }}
      const payload = await postStandaloneZorkCommand(text, session.sessionId || "");
      const nextSessionId = String(payload && payload.session_id ? payload.session_id : session.sessionId || "").trim();
      if (nextSessionId) {{
        session.sessionId = nextSessionId;
        persistConsoleSessionState();
      }}
      const replyTextRaw = String(
        payload && Object.prototype.hasOwnProperty.call(payload, "reply_text")
          ? (payload.reply_text ?? "")
          : ""
      );
      const replyText = normalizeStandaloneZorkReplyText(replyTextRaw);
      if (replyText.trim()) {{
        const receivedAtMs = Date.now();
        appendConsoleLine(
          `interactive|standalone|${{String(session.sessionId || "session")}}|${{receivedAtMs}}`,
          replyText,
          receivedAtMs,
          true
        );
      }}
      if (payload && payload.active_session === false) {{
        stopConsoleInteractiveSession("game ended", false);
      }}
      return "";
    }}
