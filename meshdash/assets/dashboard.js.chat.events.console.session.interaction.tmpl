    function syncConsoleCommandInputState(state = latestState) {{
      const input = consoleCommandInputElement();
      const runningName = consoleRunningCommand && consoleRunningCommand.name
        ? String(consoleRunningCommand.name)
        : "";
      const interactiveName = consoleInteractiveSession && consoleInteractiveSession.name
        ? String(consoleInteractiveSession.name)
        : "";
      const interactiveIsZork = isZorkConsoleInteractiveSession(consoleInteractiveSession);
      const promptLabel = runningName
        ? `${{runningName.replace(/[^a-z0-9_-]+/gi, "").slice(0, 10) || "busy"}}>`
        : interactiveIsZork
          ? ">"
          : `[${{resolveConsolePromptHostLabel(state)}}]$`;
      const placeholder = runningName
        ? `ctrl+c to stop ${{runningName}}`
        : interactiveIsZork
          ? "enter zork command  /help for console"
          : interactiveName
            ? `enter ${{interactiveName}} command  /help for console`
          : "enter command or type help";
      consolePromptLabel = promptLabel;
      if (input instanceof HTMLInputElement) {{
        input.placeholder = placeholder;
        input.setAttribute("title", placeholder);
      }}
      renderConsoleBuffer(false);
      persistConsoleSessionState();
    }}

    function focusConsoleCommandInput(select = false) {{
      const input = consoleCommandInputElement();
      if (!(input instanceof HTMLInputElement)) return;
      try {{
        input.focus({{ preventScroll: true }});
      }} catch (_err) {{
        input.focus();
      }}
      if (select) {{
        input.select();
      }} else {{
        const len = input.value.length;
        input.setSelectionRange(len, len);
      }}
      consoleCursorVisible = true;
      renderConsoleBuffer(false);
    }}

    function insertTextIntoConsoleCommandInput(text, inputEl = null) {{
      const input = inputEl instanceof HTMLInputElement ? inputEl : consoleCommandInputElement();
      if (!(input instanceof HTMLInputElement)) return false;
      const rawText = String(text == null ? "" : text);
      if (!rawText) return false;
      const normalizedText = rawText.replace(/\r\n/g, "\n").replace(/\r/g, "\n");
      const current = String(input.value || "");
      const startRaw = Number(input.selectionStart);
      const endRaw = Number(input.selectionEnd);
      const start = Number.isFinite(startRaw)
        ? Math.max(0, Math.min(current.length, Math.trunc(startRaw)))
        : current.length;
      const end = Number.isFinite(endRaw)
        ? Math.max(start, Math.min(current.length, Math.trunc(endRaw)))
        : start;
      input.value = `${{current.slice(0, start)}}${{normalizedText}}${{current.slice(end)}}`;
      const nextCaret = start + normalizedText.length;
      try {{
        input.setSelectionRange(nextCaret, nextCaret);
      }} catch (_err) {{
      }}
      consoleCommandHistoryCursor = -1;
      consoleCommandDraft = "";
      renderConsoleBuffer(false);
      return true;
    }}

    function handleConsolePasteEvent(ev) {{
      if (!ev || activeLayoutView !== "console") return false;
      const target = ev.target;
      if (target instanceof HTMLTextAreaElement) return false;
      if (
        target instanceof HTMLInputElement
        && target.id
        && target.id !== "console-command-input"
      ) {{
        return false;
      }}
      const clipboardData = ev.clipboardData;
      const pastedText = clipboardData && typeof clipboardData.getData === "function"
        ? clipboardData.getData("text/plain")
        : "";
      if (!pastedText) return false;
      focusConsoleCommandInput(false);
      const input = consoleCommandInputElement();
      if (!(input instanceof HTMLInputElement)) return false;
      ev.preventDefault();
      return insertTextIntoConsoleCommandInput(pastedText, input);
    }}

    function selectionIntersectsElement(selection, element) {{
      if (!(element instanceof HTMLElement)) return false;
      if (!selection || typeof selection.rangeCount !== "number" || selection.rangeCount < 1) {{
        return false;
      }}
      try {{
        const range = selection.getRangeAt(0);
        const container = range.commonAncestorContainer;
        if (container instanceof Node) {{
          return element.contains(container);
        }}
      }} catch (_err) {{
      }}
      return false;
    }}

    function hasConsoleSelectionWithin(element) {{
      if (!(element instanceof HTMLElement)) return false;
      const selection = window.getSelection ? window.getSelection() : null;
      if (!selectionIntersectsElement(selection, element)) return false;
      const text = String(selection ? selection.toString() : "");
      return text.length > 0;
    }}

    async function copySelectionToClipboardWithin(element) {{
      if (!(element instanceof HTMLElement)) return false;
      const selection = window.getSelection ? window.getSelection() : null;
      if (!selectionIntersectsElement(selection, element)) return false;
      const text = String(selection ? selection.toString() : "").trim();
      if (!text) return false;
      try {{
        if (!navigator.clipboard || typeof navigator.clipboard.writeText !== "function") {{
          return false;
        }}
        await navigator.clipboard.writeText(text);
        return true;
      }} catch (_err) {{
        return false;
      }}
    }}

    async function copyConsoleSelectionToClipboard() {{
      const pre = document.getElementById("live-console");
      return copySelectionToClipboardWithin(pre instanceof HTMLElement ? pre : null);
    }}

    async function copyChatSelectionToClipboard() {{
      const feed = document.getElementById("chat-feed");
      return copySelectionToClipboardWithin(feed instanceof HTMLElement ? feed : null);
    }}

    function startConsoleRunningCommand(name, onStop = null) {{
      const clean = String(name == null ? "" : name).trim().toLowerCase() || "command";
      consoleRunningCommand = {{
        name: clean,
        stop: typeof onStop === "function" ? onStop : null,
      }};
      syncConsoleCommandInputState();
    }}

    function stopConsoleRunningCommand(reason = "stopped", emitStatus = true) {{
      if (!consoleRunningCommand) return false;
      const active = consoleRunningCommand;
      consoleRunningCommand = null;
      syncConsoleCommandInputState();
      if (typeof active.stop === "function") {{
        try {{
          active.stop(reason, !!emitStatus);
        }} catch (_err) {{
        }}
      }}
      return true;
    }}

    function stopConsoleInteractiveSession(reason = "stopped", emitStatus = true) {{
      if (!consoleInteractiveSession) return false;
      const active = consoleInteractiveSession;
      consoleInteractiveSession = null;
      syncConsoleCommandInputState();
      if (emitStatus) {{
        const targetLabel = String(active.targetLabel || active.targetNodeId || "session");
        appendConsoleEventLine(`[${{String(active.name || "session")}}] stopped (${{String(reason || "done")}}) with ${{targetLabel}}.`);
      }}
      return true;
    }}

    function preferredConsoleTargetLabel(nodeId, state = latestState) {{
      const clean = normalizeNodeId(nodeId || "");
      if (!isSelectableNodeId(clean)) return "";
      const nodes = Array.isArray(state && state.nodes) ? state.nodes : [];
      const node = nodes.find((entry) => normalizeNodeId(entry && entry.id) === clean) || null;
      return preferredNodeName(node) || nodeNameCache.get(clean) || clean;
    }}

    function resolveConsoleGameTarget(ctx = null) {{
      const state = (ctx && ctx.state && typeof ctx.state === "object") ? ctx.state : latestState;
      const options = (ctx && ctx.options && typeof ctx.options === "object") ? ctx.options : {{}};
      const args = Array.isArray(ctx && ctx.args) ? ctx.args : [];
      const rawTarget = String(options.node ?? options.id ?? options.peer ?? args[0] ?? "").trim();
      let nodeId = normalizeNodeId(rawTarget || selectedNodeId || "");
      if (!isSelectableNodeId(nodeId)) {{
        return {{ ok: false, error: "Select a peer-to-peer user first or pass node=!xxxxxxxx." }};
      }}
      if (!isCanonicalNodeId(nodeId)) {{
        return {{ ok: false, error: `Invalid peer target: ${{nodeId}}` }};
      }}
      if (isSelfNodeId(nodeId, state)) {{
        return {{ ok: false, error: "Cannot start a console game session against your own radio." }};
      }}
      let channelIndex = activeMeshChannelSendIndex();
      if (Object.prototype.hasOwnProperty.call(options, "channel")) {{
        const parsedChannel = normalizeMeshChannelIndex(options.channel);
        channelIndex = parsedChannel;
      }}
      const channelLabel = meshChannelLabelForIndex(channelIndex);
      return {{
        ok: true,
        nodeId,
        targetLabel: preferredConsoleTargetLabel(nodeId, state),
        channelIndex,
        channelLabel,
      }};
    }}

    function consoleInteractiveChatKey(msg) {{
      const base = chatMessageKey(msg);
      if (base) return base;
      return "";
    }}

    function consoleInteractiveChatTimestampMs(msg) {{
      const unix = latestUnixTimestamp(
        msg && (msg.rx_time ?? msg.rxTime),
        msg && (msg.captured_at ?? msg.capturedAt),
        msg && (msg.sent_at ?? msg.sentAt)
      );
      return Number.isFinite(unix) && unix > 0 ? unix * 1000 : Date.now();
    }}

    function consoleInteractiveChatText(msg) {{
      return String(
        (msg && (msg.text ?? msg.decoded_text ?? msg.payload_text)) || ""
      ).replace(/\s+/g, " ").trim();
    }}

    function consoleRemoteAutoScriptExpectMatch(replyTextRaw, expectedAnyRaw) {{
      const replyText = String(replyTextRaw || "").trim().toLowerCase();
      const expectedAny = Array.isArray(expectedAnyRaw) ? expectedAnyRaw : [];
      if (expectedAny.length <= 0) return true;
      if (!replyText) return false;
      return expectedAny.some((needle) => {{
        const token = String(needle || "").trim().toLowerCase();
        return !!token && replyText.includes(token);
      }});
    }}

    function consoleRemoteAutoInboundReplyParts(replyTextRaw) {{
      const replyText = String(replyTextRaw || "").trim();
      if (!replyText) {{
        return {{
          text: "",
          isSegmented: false,
          part: 0,
          total: 0,
          body: "",
          finalPart: true,
        }};
      }}
      const marker = replyText.match(/^(\d+)\s*\/\s*(\d+)\s+(.*)$/);
      if (!marker) {{
        return {{
          text: replyText,
          isSegmented: false,
          part: 0,
          total: 0,
          body: replyText,
          finalPart: true,
        }};
      }}
      const partRaw = Number(marker[1]);
      const totalRaw = Number(marker[2]);
      const part = Number.isFinite(partRaw) ? Math.max(0, Math.trunc(partRaw)) : 0;
      const total = Number.isFinite(totalRaw) ? Math.max(0, Math.trunc(totalRaw)) : 0;
      if (part < 1 || total < 1) {{
        return {{
          text: replyText,
          isSegmented: false,
          part: 0,
          total: 0,
          body: replyText,
          finalPart: true,
        }};
      }}
      return {{
        text: replyText,
        isSegmented: true,
        part,
        total,
        body: String(marker[3] || "").trim(),
        finalPart: part >= total,
      }};
    }}

    function resetConsoleRemoteAutoSegmentState(activeSession) {{
      if (!activeSession || typeof activeSession !== "object") return;
      activeSession.autoSegmentTotal = 0;
      activeSession.autoSegmentNextPart = 1;
      activeSession.autoSegmentBuffer = "";
    }}

    function consumeConsoleRemoteAutoReply(activeSession, replyTextRaw) {{
      const parts = consoleRemoteAutoInboundReplyParts(replyTextRaw);
      if (!parts.text) {{
        return {{ ready: false, sawProgress: false, replyText: "" }};
      }}
      if (!parts.isSegmented) {{
        resetConsoleRemoteAutoSegmentState(activeSession);
        return {{
          ready: true,
          sawProgress: true,
          replyText: parts.body || parts.text,
        }};
      }}
      const expectedTotal = Math.max(0, Math.trunc(Number(activeSession.autoSegmentTotal) || 0));
      const expectedPart = Math.max(1, Math.trunc(Number(activeSession.autoSegmentNextPart) || 1));
      const sameSequence = expectedTotal === parts.total && expectedPart === parts.part;
      if (!sameSequence || parts.part === 1) {{
        activeSession.autoSegmentTotal = parts.total;
        activeSession.autoSegmentNextPart = 1;
        activeSession.autoSegmentBuffer = "";
      }}
      const currentPart = Math.max(1, Math.trunc(Number(activeSession.autoSegmentNextPart) || 1));
      if (parts.part === currentPart) {{
        const prior = String(activeSession.autoSegmentBuffer || "").trim();
        const next = String(parts.body || "").trim();
        activeSession.autoSegmentBuffer = prior && next ? `${{prior}} ${{next}}` : (next || prior);
        activeSession.autoSegmentNextPart = currentPart + 1;
      }} else {{
        activeSession.autoSegmentBuffer = String(parts.body || "").trim();
        activeSession.autoSegmentNextPart = parts.part + 1;
        activeSession.autoSegmentTotal = parts.total;
      }}
      if (!parts.finalPart) {{
        return {{ ready: false, sawProgress: true, replyText: "" }};
      }}
      const replyText = String(activeSession.autoSegmentBuffer || parts.body || parts.text).trim();
      resetConsoleRemoteAutoSegmentState(activeSession);
      return {{
        ready: !!replyText,
        sawProgress: true,
        replyText,
      }};
    }}

    function consoleRemoteAutoReplyLooksLikeSessionRestart(replyTextRaw) {{
      const replyText = String(replyTextRaw || "").trim().toLowerCase();
      if (!replyText) return false;
      return replyText.includes("session started") || replyText.includes("tip: type help for list of commands");
    }}

    function consoleRemoteAutoSessionMode(activeSession) {{
      return String(activeSession && activeSession.autoMode || "script").trim().toLowerCase() === "free-run"
        ? "free-run"
        : "script";
    }}

    function resyncConsoleRemoteAutoToCheckpointStart(activeSession, reasonText = "") {{
      if (!activeSession || typeof activeSession !== "object") return;
      activeSession.autoMode = "script";
      activeSession.autoScriptIndex = 0;
      activeSession.autoFreeRunIndex = 0;
      activeSession.autoAwaitingReply = false;
      activeSession.autoExpectedAny = [];
      activeSession.autoAwaitingSinceMs = 0;
      activeSession.autoAwaitingDeadlineMs = 0;
      activeSession.autoNextRetryMs = 0;
      activeSession.autoRetryCount = 0;
      resetConsoleRemoteAutoSegmentState(activeSession);
      const suffix = String(reasonText || "").trim();
      appendConsoleEventLine(
        suffix
          ? `[zork-remote][auto] session reset detected (${{suffix}}); resyncing checkpoints from start.`
          : "[zork-remote][auto] session reset detected; resyncing checkpoints from start."
      );
    }}

    function queueConsoleRemoteAutoCommand(
      activeSession,
      commandRaw,
      expectedAnyRaw,
      nowMs,
      keepRetryCount = false
    ) {{
      const command = String(commandRaw || "").trim();
      if (!command) return;
      const expectedAny = Array.isArray(expectedAnyRaw) ? expectedAnyRaw : [];
      const sentAtMs = Number.isFinite(nowMs) ? nowMs : Date.now();
      const stepTimeoutMs = Math.max(
        1000,
        Math.trunc(Number(zorkRemoteAutoResponseStepTimeoutMs) || 45000)
      );
      const retryDelayMs = Math.max(
        1000,
        Math.min(
          stepTimeoutMs - 250,
          Math.trunc(Number(zorkRemoteAutoResponseRetryDelayMs) || 8000)
        )
      );
      resetConsoleRemoteAutoSegmentState(activeSession);
      activeSession.autoLastCommand = command;
      activeSession.autoExpectedAny = expectedAny;
      activeSession.autoAwaitingReply = true;
      activeSession.autoSending = true;
      activeSession.autoAwaitingSinceMs = sentAtMs;
      activeSession.autoAwaitingDeadlineMs = sentAtMs + stepTimeoutMs;
      activeSession.autoNextRetryMs = sentAtMs + retryDelayMs;
      if (!keepRetryCount) {{
        activeSession.autoRetryCount = 0;
      }}
      const delayMs = Math.max(0, Math.trunc(Number(zorkE2EWinScriptDelayMs) || 0));
      window.setTimeout(() => {{
        void (async () => {{
          try {{
            appendConsoleEventLine(`> ${{command}}`);
            await sendConsoleInteractiveSessionLine(command);
          }} catch (err) {{
            const msg = err instanceof Error ? err.message : String(err || "unknown error");
            activeSession.autoResponseEnabled = false;
            activeSession.autoAwaitingReply = false;
            activeSession.autoExpectedAny = [];
            activeSession.autoAwaitingSinceMs = 0;
            activeSession.autoAwaitingDeadlineMs = 0;
            activeSession.autoNextRetryMs = 0;
            activeSession.autoRetryCount = 0;
            resetConsoleRemoteAutoSegmentState(activeSession);
            appendConsoleEventLine(`[zork-remote][auto] send failed: ${{msg}}`);
          }} finally {{
            activeSession.autoSending = false;
          }}
        }})();
      }}, delayMs);
    }}

    function maybeAdvanceConsoleRemoteAutoResponse(session, inboundText) {{
      const activeSession = (session && typeof session === "object") ? session : null;
      if (!activeSession) return;
      if (String(activeSession.mode || "") !== "remote") return;
      if (!activeSession.autoResponseEnabled) return;
      if (activeSession.autoSending) return;

      const nowMs = Date.now();
      if (activeSession.autoAwaitingReply) {{
        const lastCommand = String(activeSession.autoLastCommand || "").trim();
        const expectedAny = Array.isArray(activeSession.autoExpectedAny) ? activeSession.autoExpectedAny : [];
        const retryCount = Math.max(0, Math.trunc(Number(activeSession.autoRetryCount) || 0));
        const retryMax = Math.max(0, Math.trunc(Number(zorkRemoteAutoResponseRetryMax) || 3));
        const retryDeadlineMs = Math.max(0, Math.trunc(Number(activeSession.autoNextRetryMs) || 0));
        const deadlineMs = Math.max(0, Math.trunc(Number(activeSession.autoAwaitingDeadlineMs) || 0));
        if (lastCommand && retryCount < retryMax && retryDeadlineMs > 0 && nowMs > retryDeadlineMs) {{
          activeSession.autoRetryCount = retryCount + 1;
          appendConsoleEventLine(
            `[zork-remote][auto] no matching reply yet after "${{lastCommand}}"; retrying (${{activeSession.autoRetryCount}}/${{retryMax}}).`
          );
          queueConsoleRemoteAutoCommand(activeSession, lastCommand, expectedAny, nowMs, true);
          return;
        }}
        if (deadlineMs > 0 && nowMs > deadlineMs) {{
          activeSession.autoAwaitingReply = false;
          activeSession.autoExpectedAny = [];
          activeSession.autoAwaitingSinceMs = 0;
          activeSession.autoAwaitingDeadlineMs = 0;
          activeSession.autoNextRetryMs = 0;
          activeSession.autoRetryCount = 0;
          resetConsoleRemoteAutoSegmentState(activeSession);
          if (consoleRemoteAutoSessionMode(activeSession) !== "free-run") {{
            activeSession.autoMode = "free-run";
            appendConsoleEventLine(
              `[zork-remote][auto] timeout waiting for reply after "${{String(lastCommand || "zork")}}"; switching to continuous mode.`
            );
          }} else {{
            appendConsoleEventLine(
              `[zork-remote][auto] timeout waiting for reply after "${{String(lastCommand || "zork")}}"; continuing with next command.`
            );
          }}
        }}
      }}

      const inboundReply = String(inboundText || "").trim();
      if (activeSession.autoAwaitingReply) {{
        if (!inboundReply) {{
          return;
        }}
        const consumedReply = consumeConsoleRemoteAutoReply(activeSession, inboundReply);
        if (!consumedReply.sawProgress) {{
          return;
        }}
        const retryDelayMs = Math.max(1000, Math.trunc(Number(zorkRemoteAutoResponseRetryDelayMs) || 8000));
        activeSession.autoNextRetryMs = nowMs + retryDelayMs;
        if (activeSession.autoAwaitingDeadlineMs > 0) {{
          const minimumDeadlineMs = nowMs + Math.max(4000, retryDelayMs * 2);
          if (activeSession.autoAwaitingDeadlineMs < minimumDeadlineMs) {{
            activeSession.autoAwaitingDeadlineMs = minimumDeadlineMs;
          }}
        }}
        if (!consumedReply.ready) {{
          // Wait until the segmented peer reply reaches its final part.
          return;
        }}
        const replyText = String(consumedReply.replyText || "").trim();
        if (!replyText) {{
          return;
        }}
        if (
          consoleRemoteAutoSessionMode(activeSession) === "free-run"
          && consoleRemoteAutoReplyLooksLikeSessionRestart(replyText)
        ) {{
          resyncConsoleRemoteAutoToCheckpointStart(activeSession, "during continuous mode");
        }}
        const matched = consoleRemoteAutoScriptExpectMatch(replyText, activeSession.autoExpectedAny);
        if (!matched) {{
          const lastCommand = String(activeSession.autoLastCommand || "").trim();
          let continueWithNextStep = false;
          if (
            lastCommand
            && consoleRemoteAutoReplyLooksLikeSessionRestart(replyText)
          ) {{
            // A reset means prior world-state assumptions are invalid; restart scripted checkpoints.
            resyncConsoleRemoteAutoToCheckpointStart(activeSession, `while waiting for "${{lastCommand}}"`);
            continueWithNextStep = true;
          }}
          // Ignore non-matching lines and keep waiting; delayed/out-of-order mesh
          // replies are common. Retry scheduling is handled by the retry deadline.
          if (!continueWithNextStep) {{
            return;
          }}
        }}
        activeSession.autoAwaitingReply = false;
        activeSession.autoAwaitingSinceMs = 0;
        activeSession.autoAwaitingDeadlineMs = 0;
        activeSession.autoNextRetryMs = 0;
        activeSession.autoRetryCount = 0;
        resetConsoleRemoteAutoSegmentState(activeSession);
      }}

      let command = "";
      let expectedAny = [];
      const currentMode = consoleRemoteAutoSessionMode(activeSession);
      if (currentMode !== "free-run") {{
        const script = Array.isArray(zorkRemoteAutoResponseScript) ? zorkRemoteAutoResponseScript : [];
        const idx = Math.max(0, Math.trunc(Number(activeSession.autoScriptIndex) || 0));
        if (idx < script.length) {{
          const step = script[idx] && typeof script[idx] === "object" ? script[idx] : {{}};
          command = String(step.command || "").trim();
          expectedAny = Array.isArray(step.expectAny) ? step.expectAny : [];
          activeSession.autoScriptIndex = idx + 1;
        }} else {{
          activeSession.autoMode = "free-run";
          activeSession.autoFreeRunIndex = Math.max(0, Math.trunc(Number(activeSession.autoFreeRunIndex) || 0));
          appendConsoleEventLine("[zork-remote][auto] checkpoints complete. Entering continuous mode.");
        }}
      }}
      if (!command) {{
        const freeRun = Array.isArray(zorkRemoteAutoResponseFreeRunCommands)
          ? zorkRemoteAutoResponseFreeRunCommands
          : [];
        if (freeRun.length <= 0) {{
          activeSession.autoResponseEnabled = false;
          activeSession.autoAwaitingReply = false;
          activeSession.autoExpectedAny = [];
          activeSession.autoAwaitingSinceMs = 0;
          activeSession.autoAwaitingDeadlineMs = 0;
          activeSession.autoNextRetryMs = 0;
          activeSession.autoRetryCount = 0;
          resetConsoleRemoteAutoSegmentState(activeSession);
          appendConsoleEventLine("[zork-remote][auto] no continuous commands configured.");
          persistConsoleSessionState();
          return;
        }}
        const freeIdx = Math.max(0, Math.trunc(Number(activeSession.autoFreeRunIndex) || 0));
        command = String(freeRun[freeIdx % freeRun.length] || "").trim();
        expectedAny = [];
        activeSession.autoFreeRunIndex = freeIdx + 1;
      }}
      if (!command) {{
        return;
      }}
      queueConsoleRemoteAutoCommand(activeSession, command, expectedAny, nowMs, false);
    }}

    function syncConsoleInteractiveSessionMessages(state = latestState) {{
      const session = consoleInteractiveSession;
      if (!session || !state || typeof state !== "object") return;
      if (String(session.mode || "") !== "remote") return;
      if (session.autoResponseEnabled && session.autoAwaitingReply) {{
        // Tick timeout handling even when no new matching transcript line arrives.
        maybeAdvanceConsoleRemoteAutoResponse(session, "");
      }}
      const traffic = (state.traffic && typeof state.traffic === "object") ? state.traffic : {{}};
      const messages = Array.isArray(traffic.recent_chat) ? traffic.recent_chat : [];
      const localNodeId = resolveLocalNodeId(state);
      const targetNodeId = normalizeNodeId(session.targetNodeId || "");
      if (!isCanonicalNodeId(localNodeId) || !isCanonicalNodeId(targetNodeId)) return;
      for (const msg of messages) {{
        if (!msg || typeof msg !== "object") continue;
        const text = consoleInteractiveChatText(msg);
        if (!text) continue;
        const fromId = normalizeNodeId(msg.from || "");
        const toId = normalizeNodeId((msg.to || msg.destination || ""));
        const isTranscriptMessage = (
          (fromId === targetNodeId && toId === localNodeId)
          || (fromId === localNodeId && toId === targetNodeId)
        );
        if (!isTranscriptMessage) continue;
        const key = consoleInteractiveChatKey(msg);
        if (!key || session.seenKeys.has(key)) continue;
        session.seenKeys.add(key);
        const fromLabel = fromId === localNodeId
          ? "you"
          : (preferredConsoleTargetLabel(fromId, state) || fromId || "peer");
        appendConsoleLine(
          `interactive|${{String(session.name || "session")}}|${{key}}`,
          `${{fromLabel}}: ${{text}}`,
          consoleInteractiveChatTimestampMs(msg)
        );
        if (fromId === targetNodeId && toId === localNodeId) {{
          maybeAdvanceConsoleRemoteAutoResponse(session, text);
        }}
      }}
    }}

    async function sendConsoleInteractiveSessionLine(rawLine) {{
      const session = consoleInteractiveSession;
      if (!session) {{
        return "[console] no interactive session is active.";
      }}
      const text = String(rawLine == null ? "" : rawLine).trim();
      if (!text) return "";
      if (String(session.mode || "") === "standalone") {{
        const payload = await postStandaloneZorkCommand(text, session.sessionId || "");
        const nextSessionId = String(payload && payload.session_id ? payload.session_id : session.sessionId || "").trim();
        if (nextSessionId) {{
          session.sessionId = nextSessionId;
          persistConsoleSessionState();
        }}
        const replyTextRaw = String(
          payload && Object.prototype.hasOwnProperty.call(payload, "reply_text")
            ? (payload.reply_text ?? "")
            : ""
        );
        const replyText = normalizeStandaloneZorkReplyText(replyTextRaw);
        if (replyText.trim()) {{
          const receivedAtMs = Date.now();
          appendConsoleLine(
            `interactive|standalone|${{String(session.sessionId || "session")}}|${{receivedAtMs}}`,
            replyText,
            receivedAtMs,
            true
          );
        }}
        if (payload && payload.active_session === false) {{
          stopConsoleInteractiveSession("game ended", false);
        }}
        return "";
      }}
      const body = {{
        text,
        destination: session.targetNodeId,
        channel_index: session.channelIndex,
      }};
      const payload = await sendChatPayload(body, null);
      if (!(payload && payload.ok)) {{
        throw new Error("send failed");
      }}
      const messageId = messageIdOfChatPacket(payload || {{}});
      if (messageId) {{
        session.seenKeys.add(`id:${{messageId}}`);
      }}
      requestImmediatePoll(80);
      return "";
    }}
