    function resolveWeeklySummaryChartLayout(targetKey = "history") {{
      const base = historyTrendChartLayout || {{}};
      const clean = String(targetKey || "").trim().toLowerCase();
      if (clean === "node-packets" || clean === "node-link-quality") {{
        const signalBase = signalChartLayout || {{}};
        return {{
          width: Number(signalBase.width) || 900,
          height: Number(signalBase.height) || 220,
          padLeft: Number(signalBase.padLeft) || 44,
          padRight: Number(signalBase.padRight) || 44,
          padTop: Number(signalBase.padTop) || 12,
          padBottom: Number(signalBase.padBottom) || 30,
        }};
      }}
      if (clean === "network-overview") {{
        return {{
          width: Number(base.width) || 900,
          height: Number(base.height) || 220,
          padLeft: 38,
          padRight: 18,
          padTop: Number(base.padTop) || 12,
          padBottom: 18,
        }};
      }}
      return {{
        width: Number(base.width) || 900,
        height: Number(base.height) || 220,
        padLeft: Number(base.padLeft) || 46,
        padRight: Number(base.padRight) || 10,
        padTop: Number(base.padTop) || 12,
        padBottom: Number(base.padBottom) || 24,
      }};
    }}

    function resolveWeeklySummaryChartDomain(plottedSeriesEntries, targetKey = "history") {{
      const rawValues = plottedSeriesEntries.flatMap((entry) => (
        Array.isArray(entry && entry.displayedRawValues) ? entry.displayedRawValues : []
      ));
      const trendValues = plottedSeriesEntries.flatMap((entry) => (
        Array.isArray(entry && entry.displayedTrendValues) ? entry.displayedTrendValues : []
      ));
      const allValues = rawValues.concat(trendValues)
        .filter((value) => Number.isFinite(value));
      if (!allValues.length) {{
        return {{
          allValues,
          minVal: 0,
          maxVal: 1,
          clampValues: false,
        }};
      }}
      const cleanTargetKey = String(targetKey || "").trim().toLowerCase();
      const allNonNegative = allValues.every((value) => value >= 0);
      let minVal = Math.min(...allValues);
      let maxVal = Math.max(...allValues);
      let clampValues = false;
      if (cleanTargetKey === "node-packets") {{
        const preferredAllEntry = plottedSeriesEntries.find((entry) => (
          String(entry && entry.key || "").trim().toLowerCase() === "all"
        ));
        const collectEnvelopeValues = (pointKey) => {{
          const preferredPoints = Array.isArray(preferredAllEntry && preferredAllEntry[pointKey])
            ? preferredAllEntry[pointKey]
            : null;
          if (preferredPoints && preferredPoints.length) {{
            return preferredPoints
              .map((point) => Number(point && point.value))
              .filter((value) => Number.isFinite(value));
          }}
          const maximaByIdx = new Map();
          for (const entry of plottedSeriesEntries) {{
            const points = Array.isArray(entry && entry[pointKey]) ? entry[pointKey] : [];
            for (const point of points) {{
              const idx = Number(point && point.idx);
              const value = Number(point && point.value);
              if (!Number.isFinite(idx) || !Number.isFinite(value)) continue;
              const current = maximaByIdx.get(idx);
              if (!Number.isFinite(current) || value > current) {{
                maximaByIdx.set(idx, value);
              }}
            }}
          }}
          return Array.from(maximaByIdx.entries())
            .sort((left, right) => left[0] - right[0])
            .map(([, value]) => value)
            .filter((value) => Number.isFinite(value));
        }};
        const domainRawValues = collectEnvelopeValues("rawPoints");
        const domainTrendValues = collectEnvelopeValues("plottedPoints");
        const domainValues = (domainTrendValues.length ? domainTrendValues : domainRawValues)
          .filter((value) => Number.isFinite(value));
        const rawMax = domainRawValues.length ? Math.max(...domainRawValues) : Number.NEGATIVE_INFINITY;
        if (domainValues.every((value) => value >= 0)) {{
          minVal = 0;
        }} else if (domainValues.length) {{
          minVal = Math.min(...domainValues);
        }}
        if (domainValues.length) {{
          maxVal = Math.max(...domainValues);
          clampValues = Number.isFinite(rawMax) && rawMax > maxVal;
        }}
      }} else if (allNonNegative) {{
        minVal = Math.min(0, minVal);
      }}
      if ((maxVal - minVal) < 1e-6) {{
        maxVal = minVal + 1;
      }} else {{
        maxVal += ((maxVal - minVal) * 0.04);
      }}
      return {{
        allValues,
        minVal,
        maxVal,
        clampValues,
      }};
    }}

    function renderWeeklySummaryChartRows(rows, metricMeta, emptyMessage, options = {{}}) {{
      const opts = (options && typeof options === "object") ? options : {{}};
      const target = resolveWeeklySummaryRenderTarget(opts.targetKey || "history");
      const chartLayout = resolveWeeklySummaryChartLayout(target && target.key);
      const svg = document.getElementById(target.svgId);
      const empty = document.getElementById(target.emptyId);
      const chartState = target && target.chartState;
      if (!(chartState && typeof chartState === "object")) {{
        return false;
      }}
      if (!(svg instanceof SVGElement) || !(empty instanceof HTMLElement)) {{
        return false;
      }}

      const measuredWidth = Number(svg.clientWidth);
      const measuredHeight = Number(svg.clientHeight);
      const width = Number.isFinite(measuredWidth) && measuredWidth > 10
        ? Math.round(measuredWidth)
        : (Number(chartLayout.width) || 900);
      const height = Number.isFinite(measuredHeight) && measuredHeight > 10
        ? Math.round(measuredHeight)
        : (Number(chartLayout.height) || 220);
      const padLeft = Number(chartLayout.padLeft) || 46;
      const padRight = Number(chartLayout.padRight) || 10;
      const padTop = Number(chartLayout.padTop) || 12;
      const padBottom = Number(chartLayout.padBottom) || 24;
      chartState.layout = {{
        width,
        height,
        padLeft,
        padRight,
        padTop,
        padBottom,
      }};

      bindHistoryTrendChartZoom(
        chartState,
        () => rerenderWeeklySummaryChartFromCache(target.key),
        "Weekly trend chart"
      );

      const sourceRows = Array.isArray(rows) ? rows : [];
      chartState.points = sourceRows;
      const visible = getVisibleHistoryTrendRows(chartState, sourceRows);
      const plotRows = visible.rows;
      const chartLabel = `${{metricMeta.label}} trend chart`;
      setHistoryTrendChartTitle(svg, chartLabel, visible.zoomed);

      const fallbackMessage = String(emptyMessage || "No weekly summary history yet.").trim();
      const seriesDefs = [];
      if (metricMeta && Array.isArray(metricMeta.seriesOrder) && metricMeta.seriesOrder.length > 0) {{
        const labels = (metricMeta.seriesLabels && typeof metricMeta.seriesLabels === "object")
          ? metricMeta.seriesLabels
          : {{}};
        const styles = (metricMeta.seriesStyles && typeof metricMeta.seriesStyles === "object")
          ? metricMeta.seriesStyles
          : {{}};
        for (const key of metricMeta.seriesOrder) {{
          if (!key) continue;
          const style = (styles && typeof styles[key] === "object") ? styles[key] : {{}};
          seriesDefs.push({{
            key: String(key),
            label: String(labels[key] || key),
            tone: String(style.tone || ""),
            dashed: style.dashed === true,
            width: Number(style.width),
            color: String(style.color || "").trim(),
            labelColor: String(style.labelColor || "").trim(),
            readValue: (row) => row && row.series && row.series[key],
          }});
        }}
      }} else {{
        seriesDefs.push({{
          key: "primary",
          label: String(metricMeta && metricMeta.label ? metricMeta.label : "Series"),
          tone: "line",
          dashed: false,
          width: 2.3,
          readValue: (row) => row && row.value,
        }});
        seriesDefs.push({{
          key: "compare",
          label: String(metricMeta && metricMeta.compareLabel ? metricMeta.compareLabel : "Comparison"),
          tone: "compare",
          dashed: true,
          width: 2.0,
          readValue: (row) => row && row.compareValue,
        }});
      }}

      const seriesEntries = [];
      for (let s = 0; s < seriesDefs.length; s += 1) {{
        const def = seriesDefs[s];
        const values = [];
        const points = [];
        let pendingBreak = false;
        for (let i = 0; i < plotRows.length; i += 1) {{
          if (plotRows[i] && plotRows[i].breakBefore) {{
            pendingBreak = true;
          }}
          const rawValue = def.readValue(plotRows[i]);
          if (rawValue === null || rawValue === undefined) continue;
          const value = Number(rawValue);
          if (!Number.isFinite(value)) continue;
          values.push(value);
          points.push({{
            idx: i,
            value,
            breakBefore: pendingBreak,
          }});
          pendingBreak = false;
        }}
        if (!points.length) continue;
        seriesEntries.push({{
          ...def,
          index: s,
          values,
          points,
        }});
      }}

      if (!seriesEntries.length) {{
        svg.innerHTML = "";
        empty.hidden = false;
        empty.textContent = fallbackMessage;
        renderTimeline(
          chartState.timelineId,
          plotRows,
          chartLayout.padLeft,
          chartLayout.padRight,
          chartLayout.width,
          (row) => timelinePointUnix(row, "bucketUnix", ["bucketText"])
        );
        return false;
      }}
      empty.hidden = true;

      const plotW = width - padLeft - padRight;
      const plotH = height - padTop - padBottom;
      const n = plotRows.length;
      const smoothingWindow = normalizeSmoothingWindow(
        metricMeta && metricMeta.smoothingWindow,
        plotRows.length
      );
      const trendWindow = normalizeSmoothingWindow(
        smoothingWindow <= 1
          ? 1
          : Math.max(
              smoothingWindow,
              Math.round(Math.max(3, smoothingWindow) * 2.2)
            ),
        plotRows.length
      );
      const rawBucketWidthPx = 1.05;
      const trendBucketWidthPx = 4.0;
      const trendTension = String(target && target.key || "").trim().toLowerCase() === "node-packets"
        ? 0.16
        : 0.28;
      const pointScreenX = (point) => (
        padLeft + ((Math.max(0, Number(point && point.idx) || 0) / Math.max(1, n - 1)) * plotW)
      );
      const aggregatePointValuesByXPixels = (points, rawBucketWidthPx = 1.35) => {{
        const source = Array.isArray(points) ? points : [];
        if (source.length <= 3) {{
          return source.map((point) => ({{ ...point }}));
        }}
        const bucketWidthPx = Math.max(0.75, Number(rawBucketWidthPx) || 1.35);
        const compressSegment = (segmentPoints) => {{
          const segment = Array.isArray(segmentPoints)
            ? segmentPoints.filter((pt) => (
              Number.isFinite(Number(pt && pt.value))
              && Number.isFinite(pointScreenX(pt))
            ))
            : [];
          if (segment.length <= 3) {{
            return segment.map((pt) => ({{ ...pt, breakBefore: false }}));
          }}
          const first = segment[0];
          const last = segment[segment.length - 1];
          const startX = pointScreenX(first);
          const buckets = new Map();
          for (let i = 1; i < segment.length - 1; i += 1) {{
            const x = pointScreenX(segment[i]);
            const value = Number(segment[i].value);
            if (!Number.isFinite(x) || !Number.isFinite(value)) continue;
            const key = Math.floor((x - startX) / bucketWidthPx);
            const existing = buckets.get(key);
            if (existing) {{
              existing.sumValue += value;
              existing.count += 1;
            }} else {{
              buckets.set(key, {{ sumValue: value, count: 1 }});
            }}
          }}
          const mids = Array.from(buckets.entries())
            .sort((a, b) => Number(a[0]) - Number(b[0]))
            .map(([, bucket]) => ({{
              value: bucket.sumValue / bucket.count,
              breakBefore: false,
            }}));
          return [
            {{ value: Number(first.value), breakBefore: false }},
            ...mids,
            {{ value: Number(last.value), breakBefore: false }},
          ];
        }};

        const output = [];
        let segmentStart = 0;
        for (let idx = 1; idx <= source.length; idx += 1) {{
          const startsNewSegment = idx < source.length && !!source[idx].breakBefore;
          if (idx !== source.length && !startsNewSegment) continue;
          const segment = compressSegment(source.slice(segmentStart, idx));
          for (let pointIndex = 0; pointIndex < segment.length; pointIndex += 1) {{
            const point = segment[pointIndex];
            output.push({{
              ...point,
              breakBefore: pointIndex === 0 && output.length > 0,
            }});
          }}
          segmentStart = idx;
        }}
        return output;
      }};
      const plottedSeriesEntries = seriesEntries.map((entry) => {{
        const rawPoints = entry.points.map((point) => ({{ ...point }}));
        const plottedPoints = smoothSeriesPointsWithBreaks(entry.points, trendWindow);
        const displayedRawValues = aggregatePointValuesByXPixels(rawPoints, rawBucketWidthPx)
          .map((point) => Number(point && point.value))
          .filter((value) => Number.isFinite(value));
        const displayedTrendValues = aggregatePointValuesByXPixels(plottedPoints, trendBucketWidthPx)
          .map((point) => Number(point && point.value))
          .filter((value) => Number.isFinite(value));
        return {{
          ...entry,
          rawPoints,
          plottedPoints,
          displayedRawValues,
          displayedTrendValues,
        }};
      }});

      const chartDomain = resolveWeeklySummaryChartDomain(plottedSeriesEntries, target && target.key);
      let minVal = Number(chartDomain && chartDomain.minVal);
      let maxVal = Number(chartDomain && chartDomain.maxVal);
      const clampValues = !!(chartDomain && chartDomain.clampValues);
      const dayBoundaries = [];
      if (n > 1) {{
        let lastDayKey = "";
        for (let i = 0; i < plotRows.length; i += 1) {{
          const unixTs = timelinePointUnix(plotRows[i], "bucketUnix", ["bucketText"]);
          const dayKey = timelineDayKey(unixTs);
          if (!dayKey) continue;
          if (!lastDayKey) {{
            lastDayKey = dayKey;
            continue;
          }}
          if (dayKey !== lastDayKey) {{
            dayBoundaries.push({{
              idx: i,
              unixTs,
            }});
            lastDayKey = dayKey;
          }}
        }}
      }}
      const darkTheme = document.documentElement.getAttribute("data-theme") === "dark";
      const themeStyles = window.getComputedStyle
        ? window.getComputedStyle(document.documentElement)
        : null;
      const themeColor = (name, fallback) => {{
        if (!(themeStyles && typeof themeStyles.getPropertyValue === "function")) {{
          return fallback;
        }}
        const value = String(themeStyles.getPropertyValue(name) || "").trim();
        return value || fallback;
      }};
      const chartPalette = darkTheme
        ? {{
            grid: themeColor("--workspace-shell-border-muted", "#324152"),
            line: themeColor("--ui-accent", "#58c878"),
            compare: themeColor("--workspace-shell-border-strong", "#79c0ff"),
            aux1: themeColor("--ui-link", "#f3b36b"),
            aux2: themeColor("--workspace-shell-active-text", "#6fcad8"),
            aux3: themeColor("--workspace-shell-text-soft", "#d0e18a"),
            label: themeColor("--workspace-shell-active-text", "#9ce7b8"),
            compareLabel: themeColor("--workspace-shell-text", "#a4d0ff"),
            aux1Label: themeColor("--ui-link", "#f6c88e"),
            aux2Label: themeColor("--workspace-shell-active-text", "#8ddde8"),
            aux3Label: themeColor("--workspace-shell-text-soft", "#dde8a8"),
          }}
        : {{
            grid: "#dce8df",
            line: "#1f6f53",
            compare: "#265d7b",
            aux1: "#a95f27",
            aux2: "#2f6e78",
            aux3: "#6d7a2f",
            label: "#1f6f53",
            compareLabel: "#265d7b",
            aux1Label: "#a95f27",
            aux2Label: "#2f6e78",
            aux3Label: "#6d7a2f",
          }};
      const toneFallbacks = ["line", "compare", "aux1", "aux2", "aux3"];
      const toneStroke = (tone, index) => {{
        const key = tone && chartPalette[tone] ? tone : toneFallbacks[index] || "compare";
        return chartPalette[key] || chartPalette.compare;
      }};
      const toneLabel = (tone, index) => {{
        const key = tone && chartPalette[`${{tone}}Label`] ? `${{tone}}Label` : `${{toneFallbacks[index] || "compare"}}Label`;
        return chartPalette[key] || chartPalette.compareLabel;
      }};
      const buildLinearPath = (points) => (
        points.map((pt, idx) => (
          `${{idx === 0 || pt.breakBefore ? "M" : "L"}} ${{pt.x.toFixed(2)}} ${{pt.y.toFixed(2)}}`
        )).join(" ")
      );
      const enrichSeries = plottedSeriesEntries.map((entry, index) => {{
        const stroke = toneStroke(entry.tone, index);
        const labelColor = toneLabel(entry.tone, index);
        const resolvedStroke = entry.color || stroke;
        const resolvedLabelColor = entry.labelColor || labelColor;
        const widthPx = Number.isFinite(Number(entry.width))
          ? Math.max(1.2, Number(entry.width))
          : (index === 0 ? 2.3 : 2.0);
        const dashText = entry.dashed ? "5 3" : "";
        const dashAttr = dashText ? ` stroke-dasharray="${{dashText}}"` : "";
        const toScreenPoint = (point) => {{
          const rawValue = Number(point && point.value);
          const plottedValue = clampValues
            ? Math.max(minVal, Math.min(maxVal, rawValue))
            : rawValue;
          const x = padLeft + ((Math.max(0, point.idx) / Math.max(1, n - 1)) * plotW);
          const y = padTop + ((maxVal - plottedValue) / (maxVal - minVal)) * plotH;
          return {{
            x,
            y,
            breakBefore: !!point.breakBefore,
          }};
        }};
        const rawPointsXY = entry.rawPoints.map((point) => toScreenPoint(point));
        const trendPointsXY = entry.plottedPoints.map((point) => toScreenPoint(point));
        const rawPlotPoints = aggregatePointsByXPixels(rawPointsXY, rawBucketWidthPx);
        const trendPlotPoints = aggregatePointsByXPixels(trendPointsXY, trendBucketWidthPx);
        const rawPath = buildLinearPath(rawPlotPoints);
        const trendLinearPath = buildLinearPath(trendPlotPoints);
        const trendPath = buildSmoothSvgPath(trendPlotPoints, trendTension) || trendLinearPath;
        const rawWidthPx = Math.max(0.8, widthPx * 0.58);
        const rawOpacity = entry.dashed ? 0.16 : 0.2;
        return {{
          ...entry,
          stroke: resolvedStroke,
          labelColor: resolvedLabelColor,
          widthPx,
          rawWidthPx,
          rawOpacity,
          trendOpacity: 1,
          dashAttr,
          rawPath,
          trendPath,
        }};
      }});
      const axisTicks = buildLinearAxisTicks(
        minVal,
        maxVal,
        responsiveAxisTickCount(plotH, {{
          min: 5,
          max: 10,
          targetPx: 74,
        }})
      );
      const axisLabelColor = darkTheme
        ? themeColor("--workspace-shell-text", "#d7e6f2")
        : themeColor("--workspace-shell-text", "#1f6f53");
      const axisTextStyle = "font-family:'IBM Plex Sans','Segoe UI',sans-serif;font-size:10px;font-weight:600;font-variant-numeric:tabular-nums;letter-spacing:0.01em;";
      const axisLines = axisTicks.map((tick) => {{
        const y = padTop + (tick.ratio * plotH);
        return `<line x1="${{padLeft}}" y1="${{y.toFixed(2)}}" x2="${{width - padRight}}" y2="${{y.toFixed(2)}}" stroke="${{chartPalette.grid}}" stroke-width="1"></line>`;
      }}).join("");
      const axisLabels = axisTicks.map((tick) => {{
        const y = padTop + (tick.ratio * plotH);
        return `<text class="chart-axis-label" style="${{axisTextStyle}}" x="${{padLeft - 4}}" y="${{(y + 4).toFixed(2)}}" text-anchor="end" fill="${{axisLabelColor}}">${{formatMetricValue(tick.value, metricMeta.decimals)}}</text>`;
      }}).join("");
      const dayGuideLines = dayBoundaries.map((boundary) => {{
        const x = padLeft + ((Math.max(0, boundary.idx) / Math.max(1, n - 1)) * plotW);
        return `<line x1="${{x.toFixed(2)}}" y1="${{padTop}}" x2="${{x.toFixed(2)}}" y2="${{height - padBottom}}" stroke="${{chartPalette.grid}}" stroke-width="1" stroke-dasharray="2 3" stroke-opacity="${{darkTheme ? "0.45" : "0.65"}}"></line>`;
      }}).join("");
      const paths = enrichSeries.map((entry) => (
        `
          <path d="${{entry.rawPath}}" fill="none" stroke="${{entry.stroke}}" stroke-width="${{entry.rawWidthPx.toFixed(1)}}" stroke-linecap="round" stroke-linejoin="round" stroke-opacity="${{entry.rawOpacity.toFixed(2)}}"></path>
          <path d="${{entry.trendPath}}" fill="none" stroke="${{entry.stroke}}" stroke-width="${{entry.widthPx.toFixed(1)}}" stroke-linecap="round" stroke-linejoin="round" stroke-opacity="${{entry.trendOpacity.toFixed(2)}}"${{entry.dashAttr}}></path>
        `
      )).join("");
      svg.setAttribute("viewBox", `0 0 ${{width}} ${{height}}`);
      svg.innerHTML = `
        <rect x="0" y="0" width="${{width}}" height="${{height}}" fill="none"></rect>
        <line x1="${{padLeft}}" y1="${{padTop}}" x2="${{padLeft}}" y2="${{height - padBottom}}" stroke="${{chartPalette.grid}}" stroke-width="1"></line>
        ${{axisLines}}
        ${{dayGuideLines}}
        ${{paths}}
        ${{axisLabels}}
      `;
      renderTimeline(
        chartState.timelineId,
        plotRows,
        padLeft,
        padRight,
        width,
        (row) => timelinePointUnix(row, "bucketUnix", ["bucketText"])
      );
      return true;
    }}
