    let pollInFlight = false;
    let pollQueued = false;
    async function pollOnce() {{
      if (pollInFlight) {{
        pollQueued = true;
        return;
      }}
      pollInFlight = true;
      try {{
        await poll();
      }} finally {{
        pollInFlight = false;
        if (pollQueued) {{
          pollQueued = false;
          void pollOnce();
        }}
      }}
    }}

    document.addEventListener("visibilitychange", () => {{
      if (document.hidden) {{
        tabHasFocus = false;
        chatChangeCatchupArmed = true;
        clearAllChatChangeAutoDismissTimers();
        persistConsoleSessionState({{ immediate: true }});
        return;
      }}
      tabHasFocus = (typeof document.hasFocus === "function") ? !!document.hasFocus() : true;
      void pollOnce();
    }});
    window.addEventListener("blur", () => {{
      tabHasFocus = false;
      chatChangeCatchupArmed = true;
      clearAllChatChangeAutoDismissTimers();
      persistConsoleSessionState({{ immediate: true }});
    }});
    window.addEventListener("focus", () => {{
      tabHasFocus = true;
      void pollOnce();
    }});

    void pollOnce();
    const hiddenRefreshMs = Math.max(refreshMs * 6, 15000);
    let lastScheduledPollMs = 0;
    setInterval(() => {{
      const nowMs = Date.now();
      if (document.hidden && (nowMs - lastScheduledPollMs) < hiddenRefreshMs) {{
        return;
      }}
      lastScheduledPollMs = nowMs;
      void pollOnce();
    }}, refreshMs);
    setInterval(() => {{
      if (!hasActiveFileTransferSessions()) return;
      scheduleFileTransferMaintenance(latestState);
    }}, fileTransferMaintenanceHeartbeatMs);
    // Keep time labels moving even when the server returns cached/304 state.
    setInterval(() => {{
      if (!document.hidden) {{
        updateUptimeDisplay();
        updateRadioTimeDisplay();
      }}
    }}, 1000);
    setInterval(() => {{
      void loadThemeSettingsFromServer(false);
    }}, 60000);
