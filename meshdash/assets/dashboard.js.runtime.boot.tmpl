      window.__meshDashboardBootComplete = true;
      if (typeof window.__meshDashboardMarkBooted === "function") {{
        window.__meshDashboardMarkBooted();
      }}
    }}

    function runBootStep(stepName, callback) {{
      try {{
        return callback();
      }} catch (err) {{
        reportBootStepError(stepName, err);
        return undefined;
      }}
    }}

