    let pollInFlight = false;
    let pollQueued = false;
    async function pollOnce() {{
      if (pollInFlight) {{
        pollQueued = true;
        return;
      }}
      pollInFlight = true;
      try {{
        await poll();
      }} finally {{
        pollInFlight = false;
        if (pollQueued) {{
          pollQueued = false;
          void pollOnce();
        }}
      }}
    }}

    const pageActivationPollThrottleMs = Math.max(1000, Math.min(5000, Math.trunc(Number(refreshMs) || 3000)));
    let lastPageActivationPollMs = 0;
    let pageHiddenAtMs = 0;

    function requestFreshStateAfterPageActivation(reason = "page-activation", options = null) {{
      const opts = options && typeof options === "object" ? options : {{}};
      const nowMs = Date.now();
      const forceFresh = opts.force === true || !latestState;
      if (!forceFresh && lastPageActivationPollMs > 0 && (nowMs - lastPageActivationPollMs) < pageActivationPollThrottleMs) {{
        return;
      }}
      lastPageActivationPollMs = nowMs;
      if (forceFresh && typeof forceNextStatePollFresh === "function") {{
        forceNextStatePollFresh(reason);
      }} else if (forceFresh) {{
        stateEtag = "";
        stateEtagProfile = "";
        forceStateReloadOnce = true;
      }}
      void pollOnce();
    }}

    function persistDashboardSessionStateNow() {{
      if (typeof persistConsoleSessionState === "function") {{
        persistConsoleSessionState({{ immediate: true }});
      }}
      if (typeof persistMetricTickerSeriesNow === "function") {{
        persistMetricTickerSeriesNow();
      }}
    }}

    document.addEventListener("visibilitychange", () => {{
      if (document.hidden) {{
        tabHasFocus = false;
        pageHiddenAtMs = Date.now();
        chatChangeCatchupArmed = true;
        clearAllChatChangeAutoDismissTimers();
        persistDashboardSessionStateNow();
        return;
      }}
      tabHasFocus = (typeof document.hasFocus === "function") ? !!document.hasFocus() : true;
      requestFreshStateAfterPageActivation("visibility", {{
        force: pageHiddenAtMs <= 0 || (Date.now() - pageHiddenAtMs) > 10 * 60 * 1000,
      }});
    }});
    window.addEventListener("blur", () => {{
      tabHasFocus = false;
      chatChangeCatchupArmed = true;
      clearAllChatChangeAutoDismissTimers();
      persistDashboardSessionStateNow();
    }});
    window.addEventListener("focus", () => {{
      tabHasFocus = true;
      requestFreshStateAfterPageActivation("focus");
    }});
    window.addEventListener("pageshow", (event) => {{
      requestFreshStateAfterPageActivation(event && event.persisted ? "pageshow-persisted" : "pageshow", {{
        force: !!(event && event.persisted),
      }});
    }});
    window.addEventListener("pagehide", () => {{
      persistDashboardSessionStateNow();
    }});
    window.addEventListener("beforeunload", () => {{
      persistDashboardSessionStateNow();
    }});

    runBootStep("forceInitialStatePollFresh", () => {{
      if (typeof forceNextStatePollFresh === "function") {{
        forceNextStatePollFresh("initial-load");
      }}
    }});
    void pollOnce();
    const hiddenRefreshMs = Math.max(refreshMs * 6, 15000);
    let lastScheduledPollMs = 0;
    setInterval(() => {{
      const nowMs = Date.now();
      if (window.__meshDashboardGuiBenchmarkActive) {{
        lastScheduledPollMs = nowMs;
        return;
      }}
      if (document.hidden && (nowMs - lastScheduledPollMs) < hiddenRefreshMs) {{
        return;
      }}
      lastScheduledPollMs = nowMs;
      void pollOnce();
    }}, refreshMs);
    setInterval(() => {{
      if (!hasActiveFileTransferSessions()) return;
      scheduleFileTransferMaintenance(latestState);
    }}, fileTransferMaintenanceHeartbeatMs);
    // Keep time labels moving even when the server returns cached/304 state.
    setInterval(() => {{
      if (!document.hidden) {{
        updateUptimeDisplay();
        updateRadioTimeDisplay();
      }}
    }}, 1000);
    setInterval(() => {{
      void loadThemeSettingsFromServer(false);
    }}, 60000);
