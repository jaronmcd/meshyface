    function encryptedPacketUnix(entry) {{
      const summary = (entry && entry.summary && typeof entry.summary === "object")
        ? entry.summary
        : {{}};
      return latestUnixTimestamp(
        summary.captured_at,
        summary.rx_time,
        summary.time,
        entry && entry.captured_at,
        entry && entry.rx_time,
        entry && entry.time,
      );
    }}

    function historyChatEntryUnix(entry) {{
      const message = (entry && typeof entry === "object") ? entry : {{}};
      return latestUnixTimestamp(
        message.captured_at,
        message.rx_time,
        message.time,
        message.received_at,
        message.created_at,
      );
    }}

    function formatHistoryTrendTimeLabel(unixTs, includeDate = false) {{
      const ts = Number(unixTs);
      if (!Number.isFinite(ts) || ts <= 0) return "n/a";
      const date = new Date(ts * 1000);
      const hh = String(date.getHours()).padStart(2, "0");
      const mm = String(date.getMinutes()).padStart(2, "0");
      if (!includeDate) {{
        return `${{hh}}:${{mm}}`;
      }}
      const monthNames = ["Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"];
      const month = monthNames[date.getMonth()] || "";
      const day = date.getDate();
      return `${{month}} ${{day}} ${{hh}}:${{mm}}`;
    }}

    function buildCountTrendSeriesFromUnix(timestamps) {{
      const unixRows = Array.isArray(timestamps) ? timestamps : [];
      const cleanTimestamps = unixRows
        .map((value) => Math.floor(Number(value)))
        .filter((unix) => Number.isFinite(unix) && unix > 0);
      if (!cleanTimestamps.length) {{
        return {{
          points: [],
          bucketSeconds: 300,
          minUnix: null,
          maxUnix: null,
          maxCount: 0,
        }};
      }}

      let minUnix = cleanTimestamps[0];
      let maxUnix = cleanTimestamps[0];
      for (const ts of cleanTimestamps) {{
        if (ts < minUnix) minUnix = ts;
        if (ts > maxUnix) maxUnix = ts;
      }}
      const spanSeconds = Math.max(0, maxUnix - minUnix);
      let bucketSeconds = 300;
      if (spanSeconds <= 45 * 60) {{
        bucketSeconds = 60;
      }} else if (spanSeconds <= 6 * 60 * 60) {{
        bucketSeconds = 300;
      }} else if (spanSeconds <= 24 * 60 * 60) {{
        bucketSeconds = 900;
      }} else {{
        bucketSeconds = 3600;
      }}
      let bucketCount = Math.floor(spanSeconds / bucketSeconds) + 1;
      while (bucketCount > 240) {{
        bucketSeconds *= 2;
        bucketCount = Math.floor(spanSeconds / bucketSeconds) + 1;
      }}

      const bucketStart = Math.floor(minUnix / bucketSeconds) * bucketSeconds;
      const bucketEnd = Math.floor(maxUnix / bucketSeconds) * bucketSeconds;
      const countsByBucket = new Map();
      for (const ts of cleanTimestamps) {{
        const bucketUnix = Math.floor(ts / bucketSeconds) * bucketSeconds;
        countsByBucket.set(bucketUnix, (countsByBucket.get(bucketUnix) || 0) + 1);
      }}

      const points = [];
      let maxCount = 0;
      for (let bucketUnix = bucketStart; bucketUnix <= bucketEnd; bucketUnix += bucketSeconds) {{
        const count = Math.max(0, Math.trunc(Number(countsByBucket.get(bucketUnix) || 0)));
        if (count > maxCount) maxCount = count;
        points.push({{ unix: bucketUnix, count }});
      }}

      return {{
        points,
        bucketSeconds,
        minUnix,
        maxUnix,
        maxCount,
      }};
    }}

    function buildEncryptedTrendSeries(entries) {{
      const encryptedEntries = Array.isArray(entries) ? entries : [];
      const timestamps = [];
      for (const entry of encryptedEntries) {{
        const packetUnix = encryptedPacketUnix(entry);
        if (Number.isFinite(packetUnix) && packetUnix > 0) {{
          timestamps.push(packetUnix);
        }}
      }}
      return buildCountTrendSeriesFromUnix(timestamps);
    }}

    function buildHistoryChatTrendSeries(entries) {{
      const messageEntries = Array.isArray(entries) ? entries : [];
      const timestamps = [];
      for (const entry of messageEntries) {{
        const messageUnix = historyChatEntryUnix(entry);
        if (Number.isFinite(messageUnix) && messageUnix > 0) {{
          timestamps.push(messageUnix);
        }}
      }}
      return buildCountTrendSeriesFromUnix(timestamps);
    }}

    function formatHistoryTrendBucketLabel(bucketSeconds) {{
      const sec = Math.max(1, Math.trunc(Number(bucketSeconds) || 0));
      if (sec % 3600 === 0) {{
        return `${{Math.max(1, sec / 3600)}}h`;
      }}
      if (sec % 60 === 0) {{
        return `${{Math.max(1, sec / 60)}}m`;
      }}
      return `${{sec}}s`;
    }}

    function historyTrendPalette(paletteKey, darkTheme) {{
      if (paletteKey === "chat") {{
        return darkTheme
          ? {{
            grid: "rgba(170, 196, 220, 0.22)",
            line: "#4ed1a0",
            fill: "rgba(78, 209, 160, 0.24)",
            point: "#93ffe0",
            latest: "#3ad18f",
            text: "#b7cde3",
          }}
          : {{
            grid: "rgba(59, 96, 76, 0.2)",
            line: "#1f8f63",
            fill: "rgba(55, 179, 127, 0.2)",
            point: "#1d9f67",
            latest: "#136f4a",
            text: "#3a5a47",
          }};
      }}
      return darkTheme
        ? {{
          grid: "rgba(170, 196, 220, 0.22)",
          line: "#f59f47",
          fill: "rgba(245, 159, 71, 0.26)",
          point: "#ffd089",
          latest: "#ff8c42",
          text: "#b7cde3",
        }}
        : {{
          grid: "rgba(59, 96, 76, 0.2)",
          line: "#bf6a17",
          fill: "rgba(214, 138, 61, 0.2)",
          point: "#2f855a",
          latest: "#c05621",
          text: "#3a5a47",
        }};
    }}

    function renderHistoryCountTrendChart(svgId, emptyId, trend, options = null) {{
      const svg = document.getElementById(svgId);
      const empty = document.getElementById(emptyId);
      if (!(svg instanceof SVGElement) || !(empty instanceof HTMLElement)) return;

      const config = (options && typeof options === "object") ? options : {{}};
      const points = Array.isArray(trend && trend.points) ? trend.points : [];
      const maxCount = Number(trend && trend.maxCount);
      const emptyText = String(config.emptyText || "No timestamps in recent history.");
      if (!points.length || !(Number.isFinite(maxCount) && maxCount > 0)) {{
        svg.innerHTML = "";
        empty.textContent = emptyText;
        empty.hidden = false;
        return;
      }}
      empty.hidden = true;

      const darkTheme = document.documentElement.getAttribute("data-theme") === "dark";
      const palette = historyTrendPalette(String(config.palette || "encrypted"), darkTheme);

      const width = 900;
      const height = 220;
      const padLeft = 44;
      const padRight = 12;
      const padTop = 14;
      const padBottom = 28;
      const chartWidth = width - padLeft - padRight;
      const chartHeight = height - padTop - padBottom;
      const pointCount = points.length;
      const yMax = Math.max(1, Number.isFinite(maxCount) ? maxCount : 1);
      const xForIndex = (idx) => (
        pointCount <= 1
          ? (padLeft + (chartWidth / 2))
          : (padLeft + ((idx / (pointCount - 1)) * chartWidth))
      );
      const yForCount = (count) => (
        padTop + ((1 - (Math.max(0, Number(count) || 0) / yMax)) * chartHeight)
      );

      const linePoints = points.map((point, idx) => `${{xForIndex(idx).toFixed(2)}},${{yForCount(point.count).toFixed(2)}}`);
      const pathD = linePoints.length > 1
        ? `M ${{linePoints[0]}} L ${{linePoints.slice(1).join(" L ")}}`
        : "";
      const areaD = linePoints.length
        ? `M ${{linePoints[0]}} L ${{linePoints.slice(1).join(" L ")}} L ${{xForIndex(pointCount - 1).toFixed(2)}},${{(padTop + chartHeight).toFixed(2)}} L ${{xForIndex(0).toFixed(2)}},${{(padTop + chartHeight).toFixed(2)}} Z`
        : "";

      const yTickCandidates = [0, Math.round(yMax / 2), yMax];
      const yTicks = Array.from(new Set(yTickCandidates))
        .filter((value) => Number.isFinite(value) && value >= 0)
        .sort((a, b) => a - b);
      const yGrid = yTicks.map((tick) => {{
        const y = yForCount(tick);
        return `<line x1="${{padLeft}}" y1="${{y.toFixed(2)}}" x2="${{(padLeft + chartWidth).toFixed(2)}}" y2="${{y.toFixed(2)}}" stroke="${{palette.grid}}" stroke-width="1"></line>`;
      }}).join("");
      const yLabels = yTicks.map((tick) => {{
        const y = yForCount(tick);
        return `<text x="${{(padLeft - 6).toFixed(2)}}" y="${{(y + 4).toFixed(2)}}" text-anchor="end" fill="${{palette.text}}" font-size="11">${{tick}}</text>`;
      }}).join("");

      const maxTickCount = Math.min(6, Math.max(2, pointCount));
      const xTickIndexes = [];
      for (let i = 0; i < maxTickCount; i += 1) {{
        const idx = Math.round((i / Math.max(1, maxTickCount - 1)) * (pointCount - 1));
        if (!xTickIndexes.includes(idx)) {{
          xTickIndexes.push(idx);
        }}
      }}
      const includeDate = (trend.maxUnix - trend.minUnix) > (18 * 60 * 60);
      const xGrid = xTickIndexes.map((idx) => {{
        const x = xForIndex(idx);
        return `<line x1="${{x.toFixed(2)}}" y1="${{padTop}}" x2="${{x.toFixed(2)}}" y2="${{(padTop + chartHeight).toFixed(2)}}" stroke="${{palette.grid}}" stroke-width="1"></line>`;
      }}).join("");
      const xLabels = xTickIndexes.map((idx) => {{
        const x = xForIndex(idx);
        const label = formatHistoryTrendTimeLabel(points[idx].unix, includeDate);
        return `<text x="${{x.toFixed(2)}}" y="${{(height - 8).toFixed(2)}}" text-anchor="middle" fill="${{palette.text}}" font-size="10">${{escAttr(label)}}</text>`;
      }}).join("");

      const latestPoint = points[points.length - 1];
      const latestX = xForIndex(points.length - 1);
      const latestY = yForCount(latestPoint.count);
      const bucketLabel = formatHistoryTrendBucketLabel(trend.bucketSeconds);
      const yLabelPrefix = String(config.yLabelPrefix || "Items per");

      svg.setAttribute("viewBox", `0 0 ${{width}} ${{height}}`);
      svg.innerHTML = `
        <g>
          <rect x="${{padLeft}}" y="${{padTop}}" width="${{chartWidth}}" height="${{chartHeight}}" fill="none" stroke="${{palette.grid}}" stroke-width="1"></rect>
          ${{yGrid}}
          ${{xGrid}}
          ${{areaD ? `<path d="${{areaD}}" fill="${{palette.fill}}" stroke="none"></path>` : ""}}
          ${{pathD ? `<path d="${{pathD}}" fill="none" stroke="${{palette.line}}" stroke-width="2.2"></path>` : ""}}
          <circle cx="${{latestX.toFixed(2)}}" cy="${{latestY.toFixed(2)}}" r="3.8" fill="${{palette.latest}}" stroke="${{palette.point}}" stroke-width="1.2"></circle>
          ${{yLabels}}
          ${{xLabels}}
          <text x="${{(padLeft + 8).toFixed(2)}}" y="${{(padTop + 14).toFixed(2)}}" fill="${{palette.text}}" font-size="11">${{escAttr(yLabelPrefix)}} ${{bucketLabel}}</text>
        </g>
      `;
    }}

    function renderEncriptionTrendChart(entries) {{
      const trend = buildEncryptedTrendSeries(entries);
      renderHistoryCountTrendChart("encription-trend-chart", "encription-trend-empty", trend, {{
        emptyText: "No encrypted packet timestamps in recent buffer.",
        yLabelPrefix: "Packets per",
        palette: "encrypted",
      }});
    }}

    function renderHistoryChatTrendChart(entries) {{
      const trend = buildHistoryChatTrendSeries(entries);
      renderHistoryCountTrendChart("history-chat-trend-chart", "history-chat-trend-empty", trend, {{
        emptyText: "No chat timestamps in recent history.",
        yLabelPrefix: "Messages per",
        palette: "chat",
      }});
    }}

    function renderEncriptionRouteChart(routes, describeNode = null) {{
      const svg = document.getElementById("encription-route-chart");
      const empty = document.getElementById("encription-route-empty");
      if (!(svg instanceof SVGElement) || !(empty instanceof HTMLElement)) return;

      const rows = (Array.isArray(routes) ? routes : [])
        .map((item) => {{
          const count = Math.max(0, Math.trunc(Number(item && item.count)));
          const fromId = String(item && item.fromId ? item.fromId : "n/a");
          const toId = String(item && item.toId ? item.toId : "n/a");
          const fromNodeId = normalizeNodeId(fromId);
          const toNodeId = normalizeNodeId(toId);
          const fromIdentity = typeof describeNode === "function"
            ? describeNode(fromNodeId || fromId || "")
            : null;
          const toIdentity = typeof describeNode === "function"
            ? describeNode(toNodeId || toId || "")
            : null;
          const fromLabel = String(
            (fromIdentity && fromIdentity.primary)
            || fromId
            || "n/a"
          ).trim() || "n/a";
          const toLabel = String(
            (toIdentity && toIdentity.primary)
            || toId
            || "n/a"
          ).trim() || "n/a";
          return {{
            count,
            label: `${{fromLabel}} -> ${{toLabel}}`,
          }};
        }})
        .filter((item) => item.count > 0)
        .sort((a, b) => b.count - a.count)
        .slice(0, 8);

      if (!rows.length) {{
        svg.innerHTML = "";
        empty.textContent = "No encrypted routes in recent buffer.";
        empty.hidden = false;
        return;
      }}
      empty.hidden = true;

      const trimLabel = (text, maxLen = 30) => {{
        const value = String(text || "").trim();
        if (value.length <= maxLen) return value;
        return `${{value.slice(0, Math.max(0, maxLen - 3))}}...`;
      }};

      const darkTheme = document.documentElement.getAttribute("data-theme") === "dark";
      const palette = darkTheme
        ? {{
          grid: "rgba(170, 196, 220, 0.18)",
          bar: "#7cb8ff",
          barAlt: "#4c87c8",
          text: "#c3d8ed",
          count: "#d7ebff",
        }}
        : {{
          grid: "rgba(59, 96, 76, 0.16)",
          bar: "#2f73b7",
          barAlt: "#4f93d1",
          text: "#36566f",
          count: "#1f4260",
        }};

      const width = 900;
      const height = 220;
      const padLeft = 228;
      const padRight = 16;
      const padTop = 18;
      const padBottom = 18;
      const chartWidth = width - padLeft - padRight;
      const chartHeight = height - padTop - padBottom;
      const maxCount = Math.max(1, ...rows.map((row) => row.count));
      const rowHeight = chartHeight / rows.length;
      const barHeight = Math.min(20, Math.max(10, rowHeight * 0.62));

      const xTicks = [0, Math.round(maxCount / 2), maxCount]
        .filter((value, idx, arr) => arr.indexOf(value) === idx)
        .sort((a, b) => a - b);
      const xGrid = xTicks.map((tick) => {{
        const x = padLeft + ((tick / maxCount) * chartWidth);
        return `<line x1="${{x.toFixed(2)}}" y1="${{padTop}}" x2="${{x.toFixed(2)}}" y2="${{(padTop + chartHeight).toFixed(2)}}" stroke="${{palette.grid}}" stroke-width="1"></line>`;
      }}).join("");
      const xLabels = xTicks.map((tick) => {{
        const x = padLeft + ((tick / maxCount) * chartWidth);
        return `<text x="${{x.toFixed(2)}}" y="${{(height - 5).toFixed(2)}}" text-anchor="middle" fill="${{palette.text}}" font-size="10">${{tick}}</text>`;
      }}).join("");

      const bars = rows.map((row, idx) => {{
        const yCenter = padTop + (idx * rowHeight) + (rowHeight / 2);
        const y = yCenter - (barHeight / 2);
        const barWidth = Math.max(2, (row.count / maxCount) * chartWidth);
        const barColor = idx % 2 === 0 ? palette.bar : palette.barAlt;
        const label = trimLabel(row.label);
        return `
          <text x="${{(padLeft - 8).toFixed(2)}}" y="${{(yCenter + 4).toFixed(2)}}" text-anchor="end" fill="${{palette.text}}" font-size="10">${{escAttr(label)}}</text>
          <rect x="${{padLeft.toFixed(2)}}" y="${{y.toFixed(2)}}" width="${{barWidth.toFixed(2)}}" height="${{barHeight.toFixed(2)}}" rx="3" ry="3" fill="${{barColor}}"></rect>
          <text x="${{(padLeft + barWidth + 6).toFixed(2)}}" y="${{(yCenter + 4).toFixed(2)}}" text-anchor="start" fill="${{palette.count}}" font-size="10">${{row.count}}</text>
        `;
      }}).join("");

      svg.setAttribute("viewBox", `0 0 ${{width}} ${{height}}`);
      svg.innerHTML = `
        <g>
          <rect x="${{padLeft}}" y="${{padTop}}" width="${{chartWidth}}" height="${{chartHeight}}" fill="none" stroke="${{palette.grid}}" stroke-width="1"></rect>
          ${{xGrid}}
          ${{bars}}
          ${{xLabels}}
          <text x="${{(padLeft + 8).toFixed(2)}}" y="${{(padTop - 4).toFixed(2)}}" fill="${{palette.text}}" font-size="11">Top encrypted routes by packet count</text>
        </g>
      `;
    }}
