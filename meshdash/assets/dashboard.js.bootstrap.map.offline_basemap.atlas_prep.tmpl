    function ensureMapOfflineGridPane() {{
      let pane = map.getPane(mapOfflineGridPaneName);
      if (!pane) {{
        pane = map.createPane(mapOfflineGridPaneName);
      }}
      if (pane) {{
        pane.style.zIndex = "180";
        pane.style.pointerEvents = "none";
      }}
      return pane;
    }}

    function normalizeOfflineAtlasCollection(value) {{
      if (!value || typeof value !== "object" || Array.isArray(value)) {{
        return {{ type: "FeatureCollection", features: [] }};
      }}
      const features = Array.isArray(value.features) ? value.features : [];
      return {{
        type: "FeatureCollection",
        features,
      }};
    }}

    async function fetchOfflineAtlasPayload() {{
      if (mapOfflineAtlasPayload && mapOfflineAtlasPayload.ok) {{
        return mapOfflineAtlasPayload;
      }}
      if (mapOfflineAtlasFetchPromise) {{
        return mapOfflineAtlasFetchPromise;
      }}
      mapOfflineAtlasFetchPromise = (async () => {{
        try {{
          const resp = await fetch(mapOfflineAtlasEndpoint, {{ cache: "force-cache" }});
          if (!resp.ok) {{
            throw new Error(`API ${{resp.status}}`);
          }}
          const payload = await resp.json();
          if (!payload || typeof payload !== "object" || payload.ok === false) {{
            throw new Error(payload && payload.error ? String(payload.error) : "atlas payload unavailable");
          }}
          mapOfflineAtlasPayload = payload;
          return payload;
        }} catch (err) {{
          const msg = err instanceof Error ? err.message : String(err || "unknown error");
          appendConsoleLine(`offline-atlas|${{Date.now()}}|${{msg}}`, `[offline atlas] load failed: ${{msg}}`);
          return null;
        }} finally {{
          mapOfflineAtlasFetchPromise = null;
        }}
      }})();
      return mapOfflineAtlasFetchPromise;
    }}

    function sanitizeOfflineLabel(value, fallback = "") {{
      const text = String(value == null ? "" : value).replace(/\\s+/g, " ").trim();
      return text || fallback;
    }}

    function parseOfflineCityRank(value, fallback = 9) {{
      const numeric = Number(value);
      if (!Number.isFinite(numeric)) {{
        return fallback;
      }}
      return Math.max(0, Math.floor(numeric));
    }}

    function parseOfflineCityWeight(value, fallback = 0) {{
      const numeric = Number(value);
      if (!Number.isFinite(numeric)) {{
        return fallback;
      }}
      return Math.max(0, numeric);
    }}

    function offlineCityMinZoom(rank) {{
      if (rank <= 0) return 0;
      if (rank <= 1) return 2;
      if (rank <= 2) return 4;
      return 6;
    }}

    function offlineCityVisibilityBudget(zoom) {{
      if (zoom < 3) return 24;
      if (zoom < 4) return 42;
      if (zoom < 5) return 72;
      if (zoom < 6) return 120;
      if (zoom < 7) return 160;
      if (zoom < 8) return 240;
      if (zoom < 9) return 360;
      return 820;
    }}

    function offlineCitySpacingByZoom(zoom) {{
      if (zoom < 4) return 86;
      if (zoom < 5) return 76;
      if (zoom < 6) return 66;
      if (zoom < 7) return 66;
      if (zoom < 8) return 58;
      if (zoom < 9) return 40;
      return 34;
    }}

    function offlineCityRangeSpacingPx(zoom) {{
      const mapSize = map && typeof map.getSize === "function" ? map.getSize() : null;
      if (!mapSize || !Number.isFinite(mapSize.x) || !Number.isFinite(mapSize.y)) {{
        return offlineCitySpacingByZoom(zoom);
      }}
      const centerPoint = L.point(mapSize.x * 0.5, mapSize.y * 0.5);
      const samplePoint = L.point(centerPoint.x + 64, centerPoint.y);
      const centerLatLng = map.containerPointToLatLng(centerPoint);
      const sampleLatLng = map.containerPointToLatLng(samplePoint);
      const sampleDistance = map.distance(centerLatLng, sampleLatLng);
      const metersPerPixel = sampleDistance > 0 ? (sampleDistance / 64) : 0;
      if (!Number.isFinite(metersPerPixel) || metersPerPixel <= 0) {{
        return offlineCitySpacingByZoom(zoom);
      }}
      const loraRangePx = (mapOfflineLandmarkCoverageKm * 1000) / metersPerPixel;
      // We want landmarks to feel local and dense, not one-per-range-circle.
      const spacingFromRange = loraRangePx * 0.18;
      const spacingFromZoom = offlineCitySpacingByZoom(zoom);
      return clampNumber(
        Math.max(spacingFromRange, spacingFromZoom),
        mapOfflineLandmarkMinSpacingPx,
        mapOfflineLandmarkMaxSpacingPx,
        spacingFromZoom
      );
    }}

    function syncOfflineCityVisibility() {{
      if (!Array.isArray(mapOfflineCityMarkers) || mapOfflineCityMarkers.length === 0) {{
        return;
      }}
      const zoom = Number(map.getZoom());
      const safeZoom = Number.isFinite(zoom) ? zoom : 0;
      const bounds = map.getBounds();
      const paddedBounds = bounds && typeof bounds.pad === "function" ? bounds.pad(0.2) : null;
      const minSpacingPx = offlineCityRangeSpacingPx(safeZoom);
      const minSpacingSq = minSpacingPx * minSpacingPx;
      const cellSize = Math.max(16, minSpacingPx);
      const visibleBudget = offlineCityVisibilityBudget(safeZoom);
      const candidates = [];

      for (const entry of mapOfflineCityMarkers) {{
        const marker = entry && entry.marker;
        if (!marker || typeof marker.setOpacity !== "function") {{
          continue;
        }}
        const rank = parseOfflineCityRank(entry.rank, 9);
        const markerLatLng = entry.latlng
          || (typeof marker.getLatLng === "function" ? marker.getLatLng() : null);
        if (!markerLatLng || safeZoom < offlineCityMinZoom(rank)) {{
          marker.setOpacity(0);
          continue;
        }}
        if (paddedBounds && typeof paddedBounds.contains === "function" && !paddedBounds.contains(markerLatLng)) {{
          marker.setOpacity(0);
          continue;
        }}
        const point = map.latLngToContainerPoint(markerLatLng);
        const weight = parseOfflineCityWeight(entry.weight, 0);
        candidates.push({{ marker, rank, weight, point }});
      }}

      candidates.sort((a, b) => {{
        if (a.rank !== b.rank) return a.rank - b.rank;
        if (a.weight !== b.weight) return b.weight - a.weight;
        if (a.point.y !== b.point.y) return a.point.y - b.point.y;
        return a.point.x - b.point.x;
      }});

      const grid = new Map();
      const selected = [];
      const selectedLabelBoxes = [];

      function cellKey(cx, cy) {{
        return `${{cx}}:${{cy}}`;
      }}

      function isTooClose(point) {{
        const cx = Math.floor(point.x / cellSize);
        const cy = Math.floor(point.y / cellSize);
        for (let ox = -1; ox <= 1; ox += 1) {{
          for (let oy = -1; oy <= 1; oy += 1) {{
            const bucket = grid.get(cellKey(cx + ox, cy + oy));
            if (!bucket) continue;
            for (const other of bucket) {{
              const dx = point.x - other.x;
              const dy = point.y - other.y;
              if ((dx * dx) + (dy * dy) < minSpacingSq) {{
                return true;
              }}
            }}
          }}
        }}
        return false;
      }}

      function rememberPoint(point) {{
        const cx = Math.floor(point.x / cellSize);
        const cy = Math.floor(point.y / cellSize);
        const key = cellKey(cx, cy);
        const bucket = grid.get(key);
        if (bucket) {{
          bucket.push(point);
        }} else {{
          grid.set(key, [point]);
        }}
      }}

      function hasLabelOverlap(point) {{
        const xBand = Math.max(34, minSpacingPx * 1.08);
        const yBand = Math.max(14, minSpacingPx * 0.34);
        for (const box of selectedLabelBoxes) {{
          if (!box) continue;
          const dx = Math.abs(point.x - box.x);
          const dy = Math.abs(point.y - box.y);
          if (dx < xBand && dy < yBand) {{
            return true;
          }}
        }}
        return false;
      }}

      for (const candidate of candidates) {{
        if (selected.length >= visibleBudget) {{
          candidate.marker.setOpacity(0);
          continue;
        }}
        const forceInclude = candidate.rank <= 1 && safeZoom <= 4;
        if (!forceInclude && isTooClose(candidate.point)) {{
          candidate.marker.setOpacity(0);
          continue;
        }}
        if (!forceInclude && hasLabelOverlap(candidate.point)) {{
          candidate.marker.setOpacity(0);
          continue;
        }}
        candidate.marker.setOpacity(1);
        selected.push(candidate);
        rememberPoint(candidate.point);
        selectedLabelBoxes.push({{ x: candidate.point.x, y: candidate.point.y }});
      }}
    }}

