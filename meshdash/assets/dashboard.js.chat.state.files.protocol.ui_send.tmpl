    function extractFileTransferDestinationId(rawDestination) {{
      const clean = normalizeNodeId(rawDestination || "");
      if (isCanonicalNodeId(clean)) return clean;
      const text = String(rawDestination == null ? "" : rawDestination);
      const bangMatch = text.match(/![0-9a-f]{{8}}/i);
      if (bangMatch) {{
        const fromBang = normalizeNodeId(bangMatch[0]);
        if (isCanonicalNodeId(fromBang)) return fromBang;
      }}
      return "";
    }}

    function fileTransferDestinationDisplayLabel(nodeId, state = latestState) {{
      const clean = normalizeNodeId(nodeId || "");
      if (!isCanonicalNodeId(clean)) return "";
      const safeState = state && typeof state === "object" ? state : latestState;
      const nodes = Array.isArray(safeState && safeState.nodes) ? safeState.nodes : [];
      const node = nodes.find((entry) => normalizeNodeId(entry && entry.id) === clean) || null;
      const preferred = preferredNodeName(node) || nodeNameCache.get(clean) || "";
      return preferred ? `${{preferred}} (${{clean}})` : clean;
    }}

    function fileTransferHopLimitPreview(destination, state = latestState, nowUnix = Math.floor(Date.now() / 1000)) {{
      const safeState = state && typeof state === "object" ? state : latestState;
      const localState = safeState && safeState.local_state && typeof safeState.local_state === "object"
        ? safeState.local_state
        : null;
      const localConfig = localState && localState.local_config && typeof localState.local_config === "object"
        ? localState.local_config
        : null;
      const lora = localConfig && localConfig.lora && typeof localConfig.lora === "object"
        ? localConfig.lora
        : null;
      const configuredRaw = Number(lora && (lora.hop_limit ?? lora.hopLimit));
      const configured = Number.isFinite(configuredRaw) && configuredRaw >= 1
        ? Math.min(7, Math.trunc(configuredRaw))
        : 3;
      const clean = normalizeNodeId(destination || "");
      if (!isCanonicalNodeId(clean)) {{
        return {{ hopLimit: configured, detectedHops: null, source: "none", reason: "Select a destination to estimate its hop limit." }};
      }}

      const nodes = Array.isArray(safeState && safeState.nodes) ? safeState.nodes : [];
      const node = nodes.find((entry) => normalizeNodeId(entry && entry.id) === clean) || null;
      const hopsRaw = node && (node.hops_away ?? node.hopsAway);
      const detectedHops = Number(hopsRaw);
      if (hopsRaw == null || !Number.isFinite(detectedHops) || detectedHops < 0) {{
        return {{ hopLimit: configured, detectedHops: null, source: "configured", reason: "No detected route is available; the configured radio limit will be used." }};
      }}

      const lastHeardRaw = node && (node.last_heard_unix ?? node.lastHeard);
      const lastHeard = Number(lastHeardRaw);
      if (
        lastHeardRaw != null
        && Number.isFinite(lastHeard)
        && lastHeard > 0
        && Number(nowUnix) - lastHeard > 3600
      ) {{
        return {{ hopLimit: configured, detectedHops: null, source: "configured", reason: "The detected route is stale; the configured radio limit will be used." }};
      }}

      const normalizedHops = Math.max(0, Math.trunc(detectedHops));
      const requestedHopLimit = Math.max(1, normalizedHops + 1);
      return {{
        hopLimit: Math.min(configured, requestedHopLimit),
        detectedHops: normalizedHops,
        source: "detected",
        capped: requestedHopLimit > configured,
        reason: "A fresh detected route plus one safety hop will be used.",
      }};
    }}

    function renderFileTransferHopLimitPreview(state = latestState) {{
      const previewEl = document.getElementById("files-hop-limit-preview");
      if (!(previewEl instanceof HTMLElement)) return;
      const destination = resolveFileTransferDestination();
      const preview = fileTransferHopLimitPreview(destination, state);
      previewEl.dataset.source = preview.source;
      previewEl.title = preview.reason;
      if (preview.source === "none") {{
        previewEl.textContent = "Dynamic hops · select destination";
        return;
      }}
      if (preview.source === "detected") {{
        const hops = Math.max(0, Math.trunc(Number(preview.detectedHops) || 0));
        const detail = preview.capped
          ? `${{hops}} detected · configured cap`
          : `${{hops}} detected + safety`;
        previewEl.textContent = `Hop limit ${{preview.hopLimit}} · ${{detail}}`;
        return;
      }}
      previewEl.textContent = `Hop limit ${{preview.hopLimit}} · configured fallback`;
    }}

    function syncFileTransferDestinationInput(state = latestState) {{
      const input = document.getElementById("files-destination-input");
      if (!(input instanceof HTMLInputElement)) return;
      const clean = normalizeNodeId(fileTransferDestinationId || "");
      const label = fileTransferDestinationDisplayLabel(clean, state);
      if (input.value !== label) {{
        input.value = label;
      }}
      input.dataset.nodeId = clean;
      input.title = label && label !== clean ? clean : "";
      input.setAttribute("aria-label", label ? `Destination node ${{label}}` : "Destination node");
    }}

    function syncFileTransferDestinationInputFromText() {{
      const input = document.getElementById("files-destination-input");
      if (!(input instanceof HTMLInputElement)) return;
