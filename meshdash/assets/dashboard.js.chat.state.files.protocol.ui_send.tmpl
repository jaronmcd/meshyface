          clearFileTransferConsole();
          setFileTransferStatus("Transfer console cleared.");
        }});
      }}
      const clearFinishedBtn = document.getElementById("files-transfers-clear-finished-btn");
      if (clearFinishedBtn instanceof HTMLButtonElement && clearFinishedBtn.dataset.bound !== "1") {{
        clearFinishedBtn.dataset.bound = "1";
