      if (!(primary instanceof HTMLElement)) return;
      if (!(secondary instanceof HTMLElement)) return;
      const text = message ? String(message).trim() : "";
      primary.textContent = text;
      secondary.textContent = text;
      el.classList.toggle("error", !!isError);
      el.hidden = !text;
      observeChatNoticeTicker(el);
      scheduleChatNoticeTickerLayout(el);
      syncChatComposeNoticesVisibility();
    }}

