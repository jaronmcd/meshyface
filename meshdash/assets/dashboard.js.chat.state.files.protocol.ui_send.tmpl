    function fileTransferClampPercent(rawPercent) {{
      const num = Number(rawPercent);
      if (!Number.isFinite(num)) return 0;
      return Math.max(0, Math.min(100, Math.round(num)));
    }}

    function setPeerDmFileTransferUiState(peerIdRaw, state = null) {{
      const peerId = normalizeNodeId(peerIdRaw || "");
      if (!isCanonicalNodeId(peerId)) return null;
      if (!(state && typeof state === "object")) {{
        peerDmFileTransferUiByPeer.delete(peerId);
        return null;
      }}
      const normalized = {{
        peerId,
        phase: String(state.phase || "sending").trim().toLowerCase(),
        text: String(state.text || "").trim(),
        isError: !!state.isError,
        percent: fileTransferClampPercent(state.percent),
        transferId: String(state.transferId || "").trim().toLowerCase(),
        fileName: normalizeFileTransferName(state.fileName || "mesh-file.bin"),
        sentChunks: Math.max(0, Math.trunc(Number(state.sentChunks) || 0)),
        ackedChunks: Math.max(0, Math.trunc(Number(state.ackedChunks) || 0)),
        totalChunks: Math.max(0, Math.trunc(Number(state.totalChunks) || 0)),
        updatedAtMs: Date.now(),
      }};
      peerDmFileTransferUiByPeer.set(peerId, normalized);
      return normalized;
    }}

    function latestOutgoingFileTransferSessionForPeer(peerIdRaw) {{
      const peerId = normalizeNodeId(peerIdRaw || "");
      if (!isCanonicalNodeId(peerId)) return null;
      let selected = null;
      let selectedStamp = 0;
      for (const session of fileTransferOutgoingByToken.values()) {{
        if (!session || typeof session !== "object") continue;
        if (normalizeNodeId(session.destination || "") !== peerId) continue;
        const stamp = Math.max(
          0,
          Number(session.deliveredAtMs) || 0,
          Number(session.failedAtMs) || 0,
          Number(session.lastAckProgressAtMs) || 0,
          Number(session.lastRetryAtMs) || 0,
          Number(session.lastSendAtMs) || 0,
          Number(session.createdAtMs) || 0
        );
        if (!selected || stamp >= selectedStamp) {{
          selected = session;
          selectedStamp = stamp;
        }}
      }}
      return selected;
    }}

    function summarizePeerDmFileTransferState(peerIdRaw) {{
      const peerId = normalizeNodeId(peerIdRaw || "");
      if (!isCanonicalNodeId(peerId)) return null;
      const nowMs = Date.now();
      const uiStateRaw = peerDmFileTransferUiByPeer.get(peerId) || null;
      if (uiStateRaw && (nowMs - Math.max(0, Number(uiStateRaw.updatedAtMs) || 0)) > (20 * 60 * 1000)) {{
        peerDmFileTransferUiByPeer.delete(peerId);
      }}
      const uiState = peerDmFileTransferUiByPeer.get(peerId) || null;
      const session = latestOutgoingFileTransferSessionForPeer(peerId);
      let sessionState = null;
      if (session) {{
        const totalChunks = Math.max(1, Math.trunc(Number(session.totalChunks) || 1));
        const ackedChunks = Math.max(
          0,
          Math.min(totalChunks, Math.trunc(Number(session.ackedChunks) || 0))
        );
        const sentChunks = Math.max(
          ackedChunks,
          Math.min(totalChunks, Math.trunc(Number(session.sentChunks) || 0))
        );
        const activeRetries = Math.max(
          0,
          Math.trunc(Number(session.retriesSinceProgress) || Number(session.retryAttempts) || 0)
        );
        const waitingForAccept = !!session.waitingForAccept;
        const acceptProbeAttempts = Math.max(0, Math.trunc(Number(session.acceptProbeAttempts) || 0));
        let phase = "awaiting_ack";
        let text = `${{normalizeFileTransferName(session.fileName || "mesh-file.bin")}}: awaiting ACK (${{ackedChunks}}/${{totalChunks}} acked)`;
        let isError = false;
        if (session.failed) {{
          phase = "failed";
          text = `${{normalizeFileTransferName(session.fileName || "mesh-file.bin")}}: delivery failed (${{ackedChunks}}/${{totalChunks}} acked)`;
          isError = true;
        }} else if (session.delivered) {{
          phase = "delivered";
          text = `${{normalizeFileTransferName(session.fileName || "mesh-file.bin")}}: delivered (${{totalChunks}}/${{totalChunks}} acked)`;
        }} else if (waitingForAccept) {{
          phase = "awaiting_accept";
          text = `${{normalizeFileTransferName(session.fileName || "mesh-file.bin")}}: awaiting receiver accept`;
          if (acceptProbeAttempts > 0) {{
            text += ` (ping ${{acceptProbeAttempts}})`;
          }}
        }} else if (ackedChunks <= 0 && sentChunks < totalChunks) {{
          phase = "sending";
          text = `${{normalizeFileTransferName(session.fileName || "mesh-file.bin")}}: sending bursts (${{sentChunks}}/${{totalChunks}} sent)`;
        }} else if (activeRetries > 0) {{
          phase = "retrying";
          text = `${{normalizeFileTransferName(session.fileName || "mesh-file.bin")}}: retry ${{activeRetries}}/${{session.maxRetries}} (${{ackedChunks}}/${{totalChunks}} acked)`;
        }}
        const updatedAtMs = Math.max(
          0,
          Number(session.deliveredAtMs) || 0,
          Number(session.failedAtMs) || 0,
          Number(session.lastAckProgressAtMs) || 0,
          Number(session.lastRetryAtMs) || 0,
          Number(session.lastSendAtMs) || 0,
          Number(session.createdAtMs) || 0
        );
        sessionState = {{
          peerId,
          phase,
          text,
          isError,
          percent: session.delivered
            ? 100
            : (
              waitingForAccept
                ? 0
                : fileTransferClampPercent((ackedChunks / Math.max(totalChunks, 1)) * 100)
            ),
          transferId: String(session.transferId || "").trim().toLowerCase(),
          fileName: normalizeFileTransferName(session.fileName || "mesh-file.bin"),
          sentChunks,
          ackedChunks,
          totalChunks,
          updatedAtMs,
        }};
      }}
      if (uiState && sessionState) {{
        const sameTransfer = (
          !uiState.transferId
          || !sessionState.transferId
          || uiState.transferId === sessionState.transferId
        );
        if (sameTransfer && uiState.phase === "sending") {{
          return uiState;
        }}
        return sessionState.updatedAtMs >= uiState.updatedAtMs ? sessionState : uiState;
      }}
      return sessionState || uiState || null;
    }}

    function fileTransferShortTransferId(rawTransferId) {{
      const clean = String(rawTransferId || "").trim().toLowerCase();
      if (!clean) return "n/a";
      if (clean.length <= 12) return clean;
      return `${{clean.slice(0, 6)}}...${{clean.slice(-4)}}`;
    }}

    function fileTransferConsoleTimestamp(unixMs = Date.now()) {{
      const stamp = new Date(Number(unixMs) || Date.now());
      return stamp.toLocaleTimeString([], {{ hour12: false }});
    }}

    function renderFileTransferConsole() {{
      const logEl = document.getElementById("files-console-log");
      if (!(logEl instanceof HTMLElement)) return;
      const shouldStickBottom = (
        logEl.scrollHeight - (logEl.scrollTop + logEl.clientHeight)
      ) <= 20;
      const lines = fileTransferConsoleLines.slice(-fileTransferConsoleMaxEntries);
      logEl.textContent = lines.length ? lines.join("\n") : "No file transfer activity yet.";
      if (shouldStickBottom) {{
        logEl.scrollTop = logEl.scrollHeight;
      }}
    }}

    function appendFileTransferConsole(message, options = null) {{
      const text = String(message == null ? "" : message).trim();
      if (!text) return;
      const levelRaw = String(options && options.level ? options.level : "info").trim().toLowerCase();
      const level = levelRaw === "error" || levelRaw === "warn" ? levelRaw : "info";
      const tag = level === "error" ? "ERR" : level === "warn" ? "WRN" : "INF";
      fileTransferConsoleLines.push(`${{fileTransferConsoleTimestamp()}} [${{tag}}] ${{text}}`);
      if (fileTransferConsoleLines.length > fileTransferConsoleMaxEntries) {{
        fileTransferConsoleLines.splice(0, fileTransferConsoleLines.length - fileTransferConsoleMaxEntries);
      }}
      renderFileTransferConsole();
    }}

    function clearFileTransferConsole() {{
      fileTransferConsoleLines.length = 0;
      renderFileTransferConsole();
    }}

    async function copyFileTransferConsoleToClipboard() {{
      const text = fileTransferConsoleLines.length
        ? fileTransferConsoleLines.join("\n")
        : "No file transfer activity yet.";
      if (navigator.clipboard && typeof navigator.clipboard.writeText === "function") {{
        try {{
          await navigator.clipboard.writeText(text);
          return true;
        }} catch (_err) {{
        }}
      }}
      try {{
        // Browser fallback for non-secure contexts where navigator.clipboard is blocked.
        const ta = document.createElement("textarea");
        ta.value = text;
        ta.setAttribute("readonly", "readonly");
        ta.style.position = "fixed";
        ta.style.left = "-9999px";
        ta.style.top = "0";
        document.body.appendChild(ta);
        ta.focus();
        ta.select();
        ta.setSelectionRange(0, ta.value.length);
        let copied = false;
        try {{
          copied = document.execCommand("copy");
        }} catch (_err) {{
          copied = false;
        }}
        ta.remove();
        return !!copied;
      }} catch (_err) {{
        return false;
      }}
    }}

