    }}

    function fileTransferInviteSeedPeerId(state = latestState) {{
      const safeState = state && typeof state === "object" ? state : latestState;
      const selectedId = normalizeNodeId(selectedNodeId || "");
      if (!isCanonicalNodeId(selectedId)) return "";
      const localNodeId = normalizeNodeId(resolveLocalNodeId(safeState || {{}}) || "");
      if (isCanonicalNodeId(localNodeId) && selectedId === localNodeId) return "";
      return selectedId;
    }}

    function syncFileTransferDestinationFromSelectedNode(state = latestState, options = null) {{
      const selectedSeed = fileTransferInviteSeedPeerId(state);
      if (!isCanonicalNodeId(selectedSeed)) {{
        syncFileTransferDestinationInput(state);
        return "";
      }}
      if (normalizeNodeId(fileTransferDestinationId || "") !== selectedSeed) {{
        setFileTransferDestination(selectedSeed, options);
      }} else {{
        syncFileTransferDestinationInput(state);
      }}
      return selectedSeed;
    }}

    function setFileTransferDestination(rawDestination, options = null) {{
      const persist = !(options && options.persist === false);
      fileTransferDestinationId = extractFileTransferDestinationId(rawDestination || "");
      syncFileTransferDestinationInput();
      renderFileTransferHopLimitPreview(latestState);
      if (persist) {{
        persistFileTransferDestinationPreference();
      }}
    }}

    function loadFileTransferDestinationPreference() {{
      let stored = "";
      try {{
        stored = String(window.localStorage.getItem(fileTransferDestinationStorageKey) || "");
      }} catch (_err) {{
      }}
      setFileTransferDestination(stored, {{ persist: false }});
      syncFileTransferDestinationFromSelectedNode(latestState, {{ persist: true }});
    }}

    function resolveFileTransferDestination() {{
      const input = document.getElementById("files-destination-input");
      const rawInput = input instanceof HTMLInputElement ? input.value : "";
      let destination = extractFileTransferDestinationId(rawInput);
      if (!isCanonicalNodeId(destination)) {{
        destination = normalizeNodeId(fileTransferDestinationId || "");
      }}
      if (!isCanonicalNodeId(destination)) {{
        destination = fileTransferInviteSeedPeerId(latestState);
      }}
      if (!isCanonicalNodeId(destination)) return "";
      if (isSelfNodeId(destination)) return "";
      return destination;
    }}

    async function sendFileTransferFrameText(frameText, destination, channelIndex) {{
      const text = String(frameText || "").trim();
      if (!text) {{
        throw new Error("Cannot send an empty file frame.");
      }}
      const payloadBytes = utf8ByteLength(text);
      if (payloadBytes > 1024) {{
        throw new Error(`File frame too large (${payloadBytes} bytes).`);
      }}
      const body = {{
        text,
        destination,
        channel_index: channelIndex,
      }};
      const resp = await fetch("/api/files/send", {{
        method: "POST",
        headers: {{ "Content-Type": "application/json" }},
        body: JSON.stringify(body),
      }});
      const payload = await resp.json().catch(() => ({{}}));
      if (!resp.ok || !payload.ok) {{
        const msg = payload && payload.error ? payload.error : `send failed (${{resp.status}})`;
        throw new Error(msg);
      }}
      return payload;
    }}

    function buildFileTransferChunkFrames(transferId, bytes) {{
      const source = bytes instanceof Uint8Array ? bytes : new Uint8Array(bytes || []);
      const frames = [];
      let chunkIndex = 0;
      let offset = 0;
      while (offset < source.length) {{
        let end = Math.min(source.length, offset + fileTransferChunkBytes);
        let frame = "";
        while (end > offset) {{
          const chunkBytes = source.subarray(offset, end);
          const payload = encodeBytesToBase64(chunkBytes);
          frame = buildFileTransferChunkFrame(transferId, chunkIndex, payload);
          if (payload && utf8ByteLength(frame) <= fileTransferChatMaxBytes) {{
            break;
          }}
          end -= 1;
        }}
        if (end <= offset || !frame) {{
          throw new Error(`Unable to encode chunk #${{chunkIndex + 1}} within message size limit.`);
        }}
        frames.push(frame);
        offset = end;
        chunkIndex += 1;
      }}
      return frames;
    }}

    async function sendFileTransferToDestination(fileCandidate, destinationRaw, options = null) {{
      const opts = (options && typeof options === "object") ? options : {{}};
      const statusFn = (typeof opts.statusFn === "function") ? opts.statusFn : setFileTransferStatus;
      const progressFn = (typeof opts.progressFn === "function") ? opts.progressFn : null;
      const manageBusy = opts.manageBusy !== false;
      const persistDestination = opts.persistDestination !== false;
      const destination = normalizeNodeId(destinationRaw || "");
      const peerTrackId = normalizeNodeId(opts.peerId || destination || "");
      const trackPeerState = isCanonicalNodeId(peerTrackId);
      const emitProgress = (payload) => {{
        if (typeof progressFn !== "function") return;
        try {{
          progressFn(payload);
        }} catch (_err) {{
        }}
      }};
      const pushPeerState = (state) => {{
        if (!trackPeerState) return null;
        const next = setPeerDmFileTransferUiState(peerTrackId, state);
        emitProgress(next || null);
        return next;
      }};

      if (fileTransferSendInFlight) {{
        const msg = "A file transfer is already in progress.";
        statusFn(msg, true);
        pushPeerState({{
          phase: "failed",
          text: msg,
          isError: true,
          percent: 0,
        }});
        return {{ ok: false, error: msg }};
      }}
      const file = (
        fileCandidate
        && typeof fileCandidate === "object"
        && typeof fileCandidate.arrayBuffer === "function"
      ) ? fileCandidate : null;
      if (!file) {{
        const msg = "Choose a file before sending.";
        statusFn(msg, true);
        pushPeerState({{
          phase: "failed",
          text: msg,
          isError: true,
          percent: 0,
        }});
        return {{ ok: false, error: msg }};
      }}
      if (!isCanonicalNodeId(destination)) {{
        const msg = "Enter a valid destination Node ID (for example !1234abcd).";
        statusFn(msg, true);
        pushPeerState({{
          phase: "failed",
          text: msg,
          isError: true,
          percent: 0,
          fileName: file.name || "mesh-file.bin",
        }});
        return {{ ok: false, error: msg }};
      }}
      if (isSelfNodeId(destination)) {{
        const msg = "Cannot send a file to your own radio.";
        statusFn(msg, true);
        pushPeerState({{
          phase: "failed",
          text: msg,
          isError: true,
          percent: 0,
          fileName: file.name || "mesh-file.bin",
        }});
        return {{ ok: false, error: msg }};
      }}
      if (persistDestination) {{
        setFileTransferDestination(destination);
      }}

      const fileName = normalizeFileTransferName(file.name || "mesh-file.bin");
      const fileSize = Number(file.size);
      if (!Number.isFinite(fileSize) || fileSize <= 0) {{
        const msg = "Selected file is empty.";
        statusFn(msg, true);
        pushPeerState({{
          phase: "failed",
          text: `${{fileName}}: ${{msg.toLowerCase()}}`,
          isError: true,
          percent: 0,
          fileName,
        }});
        return {{ ok: false, error: msg }};
      }}
      if (fileSize > fileTransferMaxFileBytes) {{
        const msg = `File is too large (${formatFileTransferSize(fileSize)}). Limit: ${{formatFileTransferSize(fileTransferMaxFileBytes)}}.`;
        statusFn(msg, true);
        pushPeerState({{
          phase: "failed",
          text: `${{fileName}}: too large (${formatFileTransferSize(fileSize)})`,
          isError: true,
          percent: 0,
          fileName,
        }});
        return {{ ok: false, error: msg }};
      }}

      if (manageBusy) {{
        setFileTransferBusy(true);
      }}
      pushPeerState({{
        phase: "preparing",
        text: `${{fileName}}: preparing...`,
        isError: false,
        percent: 0,
        fileName,
      }});

      try {{
        let bytes = null;
        try {{
          const arrayBuffer = await file.arrayBuffer();
          bytes = new Uint8Array(arrayBuffer);
        }} catch (_err) {{
          const msg = "Could not read the selected file.";
          statusFn(msg, true);
          pushPeerState({{
            phase: "failed",
            text: `${{fileName}}: could not read file`,
            isError: true,
            percent: 0,
            fileName,
          }});
          return {{ ok: false, error: msg }};
        }}
        if (!(bytes instanceof Uint8Array) || !bytes.length) {{
          const msg = "Selected file is empty.";
          statusFn(msg, true);
          pushPeerState({{
            phase: "failed",
            text: `${{fileName}}: selected file is empty`,
            isError: true,
            percent: 0,
            fileName,
          }});
          return {{ ok: false, error: msg }};
        }}

        const transferId = buildFileTransferId();
        const payloadPlan = buildFileTransferPayloadPlan(bytes);
        const wireBytes = payloadPlan && payloadPlan.wireBytes instanceof Uint8Array
          ? payloadPlan.wireBytes
          : bytes;
        const payloadCodec = normalizeFileTransferCompressionCodec(payloadPlan && payloadPlan.codec);
        const originalSize = Math.max(0, Math.trunc(Number(payloadPlan && payloadPlan.originalSize) || bytes.length));
        const chunkFrames = buildFileTransferChunkFrames(transferId, wireBytes);
        const metaFrame = buildFileTransferMetaFrame(
          transferId,
          fileName,
          wireBytes.length,
          chunkFrames.length,
          {{
            codec: payloadCodec,
            originalFileSize: originalSize,
          }}
        );
        if (utf8ByteLength(metaFrame) > fileTransferChatMaxBytes) {{
          const msg = "File name is too long for transfer metadata. Rename the file and try again.";
          statusFn(msg, true);
          pushPeerState({{
            phase: "failed",
            text: `${{fileName}}: file name is too long`,
            isError: true,
            percent: 0,
            transferId,
            fileName,
            totalChunks: chunkFrames.length,
          }});
          return {{ ok: false, error: msg }};
        }}

        const sendCtx = meshChannelSendContext({{ appId: "files" }});
        appendFileTransferConsole(
          `Send requested: ${{fileName}} (${{formatFileTransferSize(bytes.length)}}) to ${{destination}} on ${{sendCtx.sendLabel}}.`
        );
        if (payloadPlan && payloadPlan.compressed) {{
          const savingsBytes = Math.max(0, Math.trunc(Number(payloadPlan.savingsBytes) || 0));
          const savingsPct = originalSize > 0
            ? Math.max(0, Math.round((savingsBytes / originalSize) * 100))
            : 0;
          appendFileTransferConsole(
            `Compression active (${{payloadCodec}}): ${{formatFileTransferSize(originalSize)}} -> ${{formatFileTransferSize(wireBytes.length)}} (${{savingsPct}}% smaller).`
          );
        }} else {{
          appendFileTransferConsole("Compression skipped (raw payload was best for this file).");
        }}
        statusFn(`Sending "${{fileName}}" to ${{destination}} on ${{sendCtx.sendLabel}}...`);
        pushPeerState({{
          phase: "sending",
          text: `${{fileName}}: sending metadata...`,
          isError: false,
          percent: 0,
          transferId,
          fileName,
          sentChunks: 0,
          totalChunks: chunkFrames.length,
        }});

        const metaSendResult = await sendFileTransferFrameText(metaFrame, destination, sendCtx.sendIndex);
        const confirmedChannelIndex = fileTransferExplicitChannelIndex(
          metaSendResult && metaSendResult.channel_index
        );
        const sessionChannelIndex = confirmedChannelIndex == null
          ? normalizeMeshChannelIndex(sendCtx.sendIndex)
          : confirmedChannelIndex;
        const selectedHopLimit = Number(metaSendResult && metaSendResult.hop_limit);
        const detectedHops = Number(metaSendResult && metaSendResult.detected_hops);
        const hopLimitDetail = Number.isFinite(selectedHopLimit) && selectedHopLimit > 0
          ? (
              metaSendResult && metaSendResult.hop_limit_source === "detected" && Number.isFinite(detectedHops)
                ? ` Hop limit ${{Math.trunc(selectedHopLimit)}} from ${{Math.max(0, Math.trunc(detectedHops))}} detected hop${{Math.trunc(detectedHops) === 1 ? "" : "s"}} plus safety.`
                : ` Hop limit ${{Math.trunc(selectedHopLimit)}} from the configured fallback.`
            )
          : "";
        appendFileTransferConsole(
          `Metadata sent for ${{fileTransferShortTransferId(transferId)}} (${{chunkFrames.length}} chunk${{chunkFrames.length === 1 ? "" : "s"}}).${{hopLimitDetail}}`
        );
        registerOutgoingFileTransferSession({{
          transferId,
          senderId: normalizeNodeId(resolveLocalNodeId(latestState) || ""),
          destination,
          channelIndex: sessionChannelIndex,
          fileName,
          metaFrame,
          chunkFrames,
          totalChunks: chunkFrames.length,
          sentChunks: 0,
          retryChunkCursor: 0,
          waitingForAccept: true,
          acceptProbeAttempts: 0,
          lastAcceptProbeAtMs: Date.now(),
          cwndChunks: Math.max(fileTransferCwndMinChunks, Number(fileTransferCwndInitialChunks) || 1),
          ssthreshChunks: Math.max(fileTransferCwndMinChunks, Number(fileTransferSsthreshInitialChunks) || fileTransferCwndInitialChunks),
          rtoMs: Math.max(fileTransferRtoMinMs, Number(fileTransferRtoInitialMs) || 3000),
          frameGapMs: Math.max(fileTransferInterFrameDelayMinMs, Number(fileTransferInterFrameDelayMs) || 320),
          lastWindowSendAtMs: 0,
        }});
        statusFn(`Awaiting receiver accept for "${{fileName}}" on ${{sendCtx.sendLabel}}...`);
        pushPeerState({{
          phase: "awaiting_accept",
          text: `${{fileName}}: awaiting receiver accept`,
          isError: false,
          percent: 0,
          transferId,
          fileName,
          sentChunks: 0,
          ackedChunks: 0,
          totalChunks: chunkFrames.length,
        }});
        appendFileTransferConsole(
          `Transfer ${{fileTransferShortTransferId(transferId)}} is waiting for receiver acceptance from ${{destination}} before chunk send begins.`
        );
        scheduleFileTransferMaintenance(latestState);
        requestImmediatePoll(40);
        await poll();
        return {{
          ok: true,
          transferId,
          fileName,
          sizeBytes: bytes.length,
          destination,
          totalChunks: chunkFrames.length,
          channelIndex: sessionChannelIndex,
          sendLabel: sendCtx.sendLabel,
        }};
      }} catch (err) {{
        const msg = err instanceof Error ? err.message : String(err || "unknown error");
        statusFn(`File send error: ${{msg}}`, true);
        pushPeerState({{
          phase: "failed",
          text: `${{fileName}}: send failed (${{msg}})`,
          isError: true,
          percent: 0,
          fileName,
        }});
        appendFileTransferConsole(
          `Send failed for ${{fileName}}: ${{msg}}`,
          {{ level: "error" }}
        );
        return {{ ok: false, error: msg }};
      }} finally {{
        if (manageBusy) {{
          setFileTransferBusy(false);
        }}
      }}
    }}

    async function sendSelectedFileTransfer() {{
      if (fileTransferSendInFlight) return;
      const fileInput = document.getElementById("files-input");
      if (!(fileInput instanceof HTMLInputElement)) return;
      const file = fileInput.files && fileInput.files[0] ? fileInput.files[0] : null;
      const destination = resolveFileTransferDestination();
      const result = await sendFileTransferToDestination(file, destination, {{
        statusFn: setFileTransferStatus,
        manageBusy: true,
        persistDestination: true,
      }});
      if (result && result.ok) {{
        fileInput.value = "";
      }}
    }}

    function bindFilesControls() {{
      const destinationInput = document.getElementById("files-destination-input");
      if (destinationInput instanceof HTMLInputElement && destinationInput.dataset.bound !== "1") {{
        destinationInput.dataset.bound = "1";
        destinationInput.addEventListener("input", () => {{
          syncFileTransferDestinationInputFromText();
          persistFileTransferDestinationPreference();
        }});
        destinationInput.addEventListener("change", () => {{
          syncFileTransferDestinationInput();
        }});
      }}
      const useSelectedBtn = document.getElementById("files-use-selected-btn");
      if (useSelectedBtn instanceof HTMLButtonElement && useSelectedBtn.dataset.bound !== "1") {{
        useSelectedBtn.dataset.bound = "1";
        useSelectedBtn.addEventListener("click", () => {{
          const selected = fileTransferInviteSeedPeerId(latestState);
          if (!isCanonicalNodeId(selected)) {{
            setFileTransferStatus("Select a node first, or enter a Node ID manually.", true);
            return;
          }}
          setFileTransferDestination(selected);
          setFileTransferStatus(`Destination set to ${{selected}}`);
          appendFileTransferConsole(`Destination set to ${{selected}}.`);
        }});
      }}
      const sendBtn = document.getElementById("files-send-btn");
      if (sendBtn instanceof HTMLButtonElement && sendBtn.dataset.bound !== "1") {{
        sendBtn.dataset.bound = "1";
        sendBtn.addEventListener("click", () => {{
          void sendSelectedFileTransfer();
        }});
      }}
      const fileInput = document.getElementById("files-input");
      if (fileInput instanceof HTMLInputElement && fileInput.dataset.bound !== "1") {{
        fileInput.dataset.bound = "1";
        fileInput.addEventListener("change", () => {{
          const file = fileInput.files && fileInput.files[0] ? fileInput.files[0] : null;
          if (!file) {{
            setFileTransferStatus("");
            return;
          }}
          setFileTransferStatus(`Selected: ${{normalizeFileTransferName(file.name)}} (${{formatFileTransferSize(file.size)}})`);
        }});
      }}
      bindFilesConsoleControls();
      bindFileTransferAutoAcceptToggle();
      syncFileTransferAutoAcceptToggle();
      syncFileTransferDestinationInput();
    }}
