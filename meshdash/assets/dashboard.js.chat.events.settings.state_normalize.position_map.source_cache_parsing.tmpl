    }}

    function loadSettingsFixedPositionCache() {{
      try {{
        const raw = window.localStorage.getItem(settingsFixedPositionCacheStorageKey) || "";
        if (!raw) return;
        const parsed = JSON.parse(raw);
        const candidate = fixedPositionCandidateFromObject(parsed);
        settingsFixedPositionCache = candidate ? {{
          lat: Number(candidate.lat),
          lon: Number(candidate.lon),
          alt: Number.isFinite(candidate.alt) ? Math.trunc(candidate.alt) : null,
        }} : null;
      }} catch (_err) {{
        settingsFixedPositionCache = null;
      }}
    }}

    function shouldUseUniqueNodeColorsForScope(scope = "member", tagActive = false) {{
      if (tagActive) return true;
      const cleanScope = String(scope || "member").trim().toLowerCase() === "feed"
        ? "feed"
        : "member";
      return cleanScope === "feed"
        ? !!settingsUniqueChatColorsEnabled
        : !!settingsUniqueNodeColorsEnabled;
    }}

    function shouldUseUniqueNodeColors(tagActive = false) {{
      return shouldUseUniqueNodeColorsForScope("member", tagActive);
    }}

    function normalizeSettingsBadgeEmoji(value) {{
