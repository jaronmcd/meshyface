    function normalizeSettingsPositionSource(value) {{
      const key = String(value || "").trim().toLowerCase();
      if (key === "none" || key === "gps" || key === "fixed") return key;
      return "gps";
    }}

    function loadSettingsPositionSourcePreference() {{
      try {{
        const raw = window.localStorage.getItem(settingsPositionSourceStorageKey) || "";
        if (raw) {{
          settingsPositionSourcePref = normalizeSettingsPositionSource(raw);
        }}
      }} catch (_err) {{
