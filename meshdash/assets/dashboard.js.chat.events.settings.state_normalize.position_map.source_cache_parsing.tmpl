    async function broadcastMeshyfaceProfileColor() {{
      const color = normalizeMeshyfaceProfileColor(settingsMeshyfaceProfileColor, "");
      if (!color) {{
        setMeshyfaceProfileStatusText("Choose a valid Meshyface color first.", true);
        return null;
      }}
      if (meshyfaceProfileBroadcastInFlight) return null;
      const channelIndex = normalizeMeshChannelIndex(
        meshChannelEffectiveSendIndexForApp("profiles")
      );
      const theme = typeof currentMeshyfaceProfileThemeRecipe === "function"
        ? currentMeshyfaceProfileThemeRecipe()
        : null;
      meshyfaceProfileBroadcastInFlight = true;
      syncSettingsAppearanceControls();
      setMeshyfaceProfileStatusText("Broadcasting experimental Meshyface profile color and theme...");
      try {{
        const resp = await fetch(meshyfaceProfileColorEndpoint, {{
          method: "POST",
          headers: {{ "Content-Type": "application/json" }},
          body: JSON.stringify({{
            color,
            channel_index: channelIndex,
            ...(theme ? {{ theme }} : {{}}),
          }}),
        }});
        const payload = await resp.json().catch(() => ({{}}));
        if (!resp.ok || (payload && payload.ok === false)) {{
          const message = payload && payload.error ? payload.error : `API ${{resp.status}}`;
          throw new Error(String(message));
        }}
        const sentChannel = normalizeMeshChannelIndex(
          payload && payload.channel_index != null ? payload.channel_index : channelIndex
        );
        setMeshyfaceProfileStatusText(
          `Experimental Meshyface profile broadcast on ${{meshChannelSendLabelForIndex(sentChannel)}}.`
        );
        if (typeof requestImmediatePoll === "function") {{
          requestImmediatePoll(0);
        }}
        return payload;
      }} catch (err) {{
        const message = err instanceof Error ? err.message : String(err || "unknown error");
        setMeshyfaceProfileStatusText(`Meshyface profile broadcast failed: ${{message}}`, true);
        return null;
      }} finally {{
        meshyfaceProfileBroadcastInFlight = false;
        syncSettingsAppearanceControls();
      }}
    }}

    function normalizeSettingsTimeSyncTimezone(value) {{
      const clean = String(value || "").trim();
      if (!clean) return "local";
      const lowered = clean.toLowerCase();
      if (lowered === "local" || lowered === "browser" || lowered === "system") return "local";
      if (lowered === "utc" || lowered === "z") return "UTC";
      try {{
        const resolved = new Intl.DateTimeFormat("en-US", {{ timeZone: clean }}).resolvedOptions().timeZone;
        return String(resolved || clean).trim() || "local";
      }} catch (_err) {{
        return "local";
      }}
    }}

    function defaultSettingsTimeSyncTimezone() {{
      try {{
        const tz = String(Intl.DateTimeFormat().resolvedOptions().timeZone || "").trim();
        if (!tz) return "local";
        return normalizeSettingsTimeSyncTimezone(tz);
      }} catch (_err) {{
        return "local";
      }}
    }}

    function collectSettingsTimeSyncTimezoneOptions() {{
      if (Array.isArray(settingsTimeSyncTimezoneOptionsCache) && settingsTimeSyncTimezoneOptionsCache.length) {{
        return [...settingsTimeSyncTimezoneOptionsCache];
      }}
      const seen = new Set();
      const out = [];
      const pushZone = (zoneId) => {{
        const normalized = normalizeSettingsTimeSyncTimezone(zoneId);
        if (normalized === "local" || seen.has(normalized)) return;
        seen.add(normalized);
        out.push(normalized);
      }};
      pushZone("UTC");
      pushZone(defaultSettingsTimeSyncTimezone());

      if (typeof Intl !== "undefined" && Intl && typeof Intl.supportedValuesOf === "function") {{
        try {{
          const supported = Intl.supportedValuesOf("timeZone");
          for (const zoneId of supported) {{
            pushZone(zoneId);
          }}
        }} catch (_err) {{
        }}
      }}

      for (const fallbackZone of [
        "America/New_York",
        "America/Chicago",
        "America/Denver",
        "America/Los_Angeles",
      ]) {{
        pushZone(fallbackZone);
      }}

      out.sort((a, b) => a.localeCompare(b));
      settingsTimeSyncTimezoneOptionsCache = out;
      return [...out];
    }}

    function populateSettingsTimeSyncTimezoneOptions() {{
      const select = document.getElementById("settings-time-sync-timezone");
      if (!(select instanceof HTMLSelectElement)) return;

      const previous = normalizeSettingsTimeSyncTimezone(select.value || settingsTimeSyncTimezonePref);
      const options = collectSettingsTimeSyncTimezoneOptions();
      select.innerHTML = "";

      const localOption = document.createElement("option");
      localOption.value = "local";
      localOption.textContent = "Browser Local (auto)";
      select.appendChild(localOption);

      for (const zoneId of options) {{
        if (zoneId === "local") continue;
        const option = document.createElement("option");
        option.value = zoneId;
        option.textContent = zoneId;
        select.appendChild(option);
      }}

      const selected = normalizeSettingsTimeSyncTimezone(
        settingsTimeSyncTimezonePref || previous || defaultSettingsTimeSyncTimezone()
      );
      settingsTimeSyncTimezonePref = selected;
      select.value = selected;
      if (select.value !== selected) {{
        select.value = "local";
        settingsTimeSyncTimezonePref = "local";
      }}
    }}

    function loadSettingsTimeSyncPreferences() {{
      settingsTimeSyncEnabledPref = true;
      settingsTimeSyncTimezonePref = "local";
      try {{
        settingsTimeSyncEnabledPref = parseBoolToken(
          window.localStorage.getItem(settingsTimeSyncEnabledStorageKey),
          true
        );
      }} catch (_err) {{
      }}
      try {{
        const rawTz = String(window.localStorage.getItem(settingsTimeSyncTimezoneStorageKey) || "").trim();
        settingsTimeSyncTimezonePref = normalizeSettingsTimeSyncTimezone(
          rawTz || defaultSettingsTimeSyncTimezone()
        );
      }} catch (_err) {{
        settingsTimeSyncTimezonePref = defaultSettingsTimeSyncTimezone();
      }}
    }}

    function persistSettingsTimeSyncPreferences() {{
      settingsTimeSyncTimezonePref = normalizeSettingsTimeSyncTimezone(settingsTimeSyncTimezonePref);
      try {{
        window.localStorage.setItem(settingsTimeSyncEnabledStorageKey, settingsTimeSyncEnabledPref ? "1" : "0");
        window.localStorage.setItem(settingsTimeSyncTimezoneStorageKey, settingsTimeSyncTimezonePref);
