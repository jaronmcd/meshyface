    function historyChartThemeColor(name, fallback) {{
      const themeStyles = window.getComputedStyle
        ? window.getComputedStyle(document.documentElement)
        : null;
      if (!(themeStyles && typeof themeStyles.getPropertyValue === "function")) {{
        return fallback;
      }}
      const value = String(themeStyles.getPropertyValue(name) || "").trim();
      return value || fallback;
    }}

    function historyChartSeriesPaletteColor(paletteName, fallback) {{
      const clean = String(paletteName || "").trim().toLowerCase();
      if (!clean || !Array.isArray(meshChannelColorPalette)) {{
        return fallback;
      }}
      for (const palette of meshChannelColorPalette) {{
        const name = String(palette && palette.name || "").trim().toLowerCase();
        if (name !== clean) continue;
        const fill = String(palette && palette.fill || "").trim();
        if (fill) return fill;
      }}
      return fallback;
    }}

    function historyChartPalette() {{
      const darkTheme = document.documentElement.getAttribute("data-theme") === "dark";
      const lineColor = historyChartSeriesPaletteColor("bluish green", "#009E73");
      const compareColor = historyChartSeriesPaletteColor("sky blue", "#56B4E9");
      const aux1Color = historyChartSeriesPaletteColor("orange", "#E69F00");
      const warnColor = historyChartSeriesPaletteColor("yellow", "#F0E442");
      const aux2Color = historyChartSeriesPaletteColor("reddish purple", "#CC79A7");
      const dangerColor = historyChartSeriesPaletteColor("vermillion", "#D55E00");
      const offlineColor = historyChartSeriesPaletteColor("gray", "#999999");
      return {
        grid: darkTheme
          ? historyChartThemeColor("--workspace-shell-border-muted", "#324152")
          : "#dce8df",
        line: lineColor,
        compare: compareColor,
        aux1: aux1Color,
        aux2: aux2Color,
        label: lineColor,
        compareLabel: compareColor,
        aux1Label: aux1Color,
        danger: dangerColor,
        signalWeak: dangerColor,
        signalMarginal: aux1Color,
        signalMid: warnColor,
        signalStrong: lineColor,
        connector: darkTheme
          ? historyChartThemeColor("--workspace-shell-border-muted", "#324152")
          : "#c3d2dc",
        offline: offlineColor,
        rawOpacity: darkTheme ? 0.20 : 0.24,
      };
    }}

    function signalChartFallbackQualityProfile() {{
      const defaults = (typeof signalHeatProfileDefaults === "object" && signalHeatProfileDefaults)
        ? signalHeatProfileDefaults
        : {{}};
      const numberOr = (value, fallback) => {{
        const parsed = Number(value);
        return Number.isFinite(parsed) ? parsed : fallback;
      }};
      return {{
        snrMin: numberOr(defaults.snrMin, -12),
        snrMax: numberOr(defaults.snrMax, 10),
        rssiMin: numberOr(defaults.rssiMin, -125),
        rssiMax: numberOr(defaults.rssiMax, -88),
      }};
    }}

    function resolveSignalChartQualityProfile() {{
      if (typeof resolveSignalHeatProfile === "function") {{
        const profile = resolveSignalHeatProfile();
        if (profile && typeof profile === "object") return profile;
      }}
      return signalChartFallbackQualityProfile();
    }}

    function signalChartQualityRange(metricKey, profile) {{
      const activeProfile = (profile && typeof profile === "object")
        ? profile
        : signalChartFallbackQualityProfile();
      const fallbackProfile = signalChartFallbackQualityProfile();
      const isRssi = String(metricKey || "") === "avg_rssi";
      const minKey = isRssi ? "rssiMin" : "snrMin";
      const maxKey = isRssi ? "rssiMax" : "snrMax";
      let minValue = Number(activeProfile[minKey]);
      let maxValue = Number(activeProfile[maxKey]);
      if (!Number.isFinite(minValue)) minValue = Number(fallbackProfile[minKey]);
      if (!Number.isFinite(maxValue)) maxValue = Number(fallbackProfile[maxKey]);
      if (!Number.isFinite(minValue) || !Number.isFinite(maxValue) || maxValue <= minValue) {{
        minValue = isRssi ? -125 : -12;
        maxValue = isRssi ? -88 : 10;
      }}
      return {{ min: minValue, max: maxValue }};
    }}

    function signalChartNormalizeQuality(rawValue, metricKey, profile) {{
      const range = signalChartQualityRange(metricKey, profile);
      if (typeof normalizeSignalForHeat === "function") {{
        return normalizeSignalForHeat(rawValue, range.min, range.max);
      }}
      const value = Number(rawValue);
      if (!Number.isFinite(value)) return null;
      return Math.max(0, Math.min(1, (value - range.min) / (range.max - range.min)));
    }}

    function signalChartHexToRgb(hexColor) {{
      const clean = String(hexColor || "").trim().replace(/^#/, "");
      const value = Number.parseInt(clean, 16);
      if (clean.length !== 6 || !Number.isFinite(value)) return null;
      return {{
        r: (value >> 16) & 255,
        g: (value >> 8) & 255,
        b: value & 255,
      }};
    }}

    function signalChartBlendHex(startHex, endHex, ratio) {{
      const start = signalChartHexToRgb(startHex);
      const end = signalChartHexToRgb(endHex);
      const weight = Math.max(0, Math.min(1, Number(ratio) || 0));
      if (!(start && end)) return weight < 0.5 ? startHex : endHex;
      const toHex = (value) => Math.round(Math.max(0, Math.min(255, value)))
        .toString(16)
        .padStart(2, "0");
      return `#${{toHex(start.r + ((end.r - start.r) * weight))}}${{toHex(start.g + ((end.g - start.g) * weight))}}${{toHex(start.b + ((end.b - start.b) * weight))}}`;
    }}

    function signalChartQualityColor(score, chartPalette) {{
      const palette = (chartPalette && typeof chartPalette === "object") ? chartPalette : {{}};
      const lowColor = palette.signalWeak || palette.danger || "#D55E00";
      const marginalColor = palette.signalMarginal || palette.aux1 || "#E69F00";
      const midColor = palette.signalMid || "#F0E442";
      const highColor = palette.signalStrong || palette.line || "#009E73";
      const rawQuality = Number(score);
      if (!Number.isFinite(rawQuality)) return palette.offline || "#999999";
      const quality = Math.max(0, Math.min(1, rawQuality));
      if (quality <= 0.33) {{
        return signalChartBlendHex(lowColor, marginalColor, quality / 0.33);
      }}
      if (quality <= 0.66) {{
        return signalChartBlendHex(marginalColor, midColor, (quality - 0.33) / 0.33);
      }}
      return signalChartBlendHex(midColor, highColor, (quality - 0.66) / 0.34);
    }}

    function buildSignalChartQualityGradientStops(
      points,
      metricKey,
      profile,
      chartPalette,
      padLeft,
      plotWidth
    ) {{
      const source = Array.isArray(points) ? points : [];
      const denominator = Math.max(1, Number(plotWidth) || 1);
      const originX = Number(padLeft) || 0;
      const stops = [];
      let lastOffset = 0;
      for (const point of source) {{
        const x = Number(point && point.x);
        const value = Number(point && point.value);
        if (!Number.isFinite(x) || !Number.isFinite(value)) continue;
        let offset = Math.max(0, Math.min(100, ((x - originX) / denominator) * 100));
        if (stops.length && offset < lastOffset) offset = lastOffset;
        lastOffset = offset;
        const score = signalChartNormalizeQuality(value, metricKey, profile);
        const color = signalChartQualityColor(score, chartPalette);
        stops.push({{ offset, color }});
      }}
      if (!stops.length) return "";
      const parts = [];
      if (stops[0].offset > 0) {{
        parts.push(`<stop offset="0%" stop-color="${{escAttr(stops[0].color)}}"></stop>`);
      }}
      for (const stop of stops) {{
        parts.push(`<stop offset="${{stop.offset.toFixed(2)}}%" stop-color="${{escAttr(stop.color)}}"></stop>`);
      }}
      const lastStop = stops[stops.length - 1];
      if (lastStop.offset < 100) {{
        parts.push(`<stop offset="100%" stop-color="${{escAttr(lastStop.color)}}"></stop>`);
      }}
      return parts.join("");
    }}

    function signalChartQualityGradientDef(gradientId, stops, padLeft, plotWidth) {{
      const id = String(gradientId || "").trim();
      const body = String(stops || "").trim();
      if (!id || !body) return "";
      const x1 = Number(padLeft) || 0;
      const x2 = x1 + Math.max(1, Number(plotWidth) || 1);
      return `<linearGradient id="${{escAttr(id)}}" gradientUnits="userSpaceOnUse" x1="${{x1.toFixed(2)}}" y1="0" x2="${{x2.toFixed(2)}}" y2="0">${{body}}</linearGradient>`;
    }}

    function renderSignalChart(points) {{
      const svg = document.getElementById("signal-chart");
      const empty = document.getElementById("signal-empty");
      if (!(svg instanceof SVGElement) || !(empty instanceof HTMLElement)) return;

      bindSignalChartZoom();

      const rows = Array.isArray(points) ? points : [];
      signalChartPoints = rows;
      const currentNodeId = normalizeNodeId(selectedNodeId || "");
      if (currentNodeId !== signalChartZoomNodeId) {{
        resetSignalChartZoom(currentNodeId);
      }}
      const visible = getVisibleSignalRows(rows);
      const plotRows = visible.rows;

      const chartLayout = resolveRenderedSvgChartLayout(svg, signalChartLayout);
      signalChartRenderLayout = chartLayout;
      const width = chartLayout.width;
      const height = chartLayout.height;
      const padLeft = chartLayout.padLeft;
      const padRight = chartLayout.padRight;
      const padTop = chartLayout.padTop;
      const padBottom = chartLayout.padBottom;
      const plotW = width - padLeft - padRight;
      const plotH = height - padTop - padBottom;

      svg.classList.toggle("zoomed", visible.zoomed);
      svg.setAttribute(
        "title",
        visible.zoomed
          ? "Signal chart zoomed. Wheel to zoom, drag to pan, double-click or Esc to reset."
          : "Signal chart. Wheel to zoom, drag to pan, double-click or Esc to reset."
      );

      const snrVals = plotRows.map((p) => Number(p.avg_snr)).filter((v) => Number.isFinite(v));
      const rssiVals = plotRows.map((p) => Number(p.avg_rssi)).filter((v) => Number.isFinite(v));
      if (snrVals.length === 0 && rssiVals.length === 0) {{
        svg.innerHTML = "";
        empty.hidden = false;
        empty.textContent = "No historical signal points yet for this node.";
        renderSignalTimeline(plotRows, padLeft, padRight, width);
        return;
      }}
      empty.hidden = true;

      const withSpread = (vals, fallbackMin, fallbackMax) => {{
        if (!vals.length) return [fallbackMin, fallbackMax];
        let lo = Math.min(...vals);
        let hi = Math.max(...vals);
        if (Math.abs(hi - lo) < 0.001) {{
          lo -= 1;
          hi += 1;
        }}
        return [lo, hi];
      }};

      const [snrMin, snrMax] = withSpread(snrVals, -20, 20);
      const [rssiMin, rssiMax] = withSpread(rssiVals, -130, -60);
      const xAt = (idx, total) => (
        padLeft + ((Math.max(0, idx) / Math.max(1, total - 1)) * plotW)
      );
      const yFrom = (value, minVal, maxVal) => (
        padTop + ((maxVal - value) / (maxVal - minVal)) * plotH
      );
      const chartPalette = historyChartPalette();
      const signalQualityProfile = resolveSignalChartQualityProfile();

      const buildLinearPath = (points) => {{
        const source = Array.isArray(points) ? points : [];
        if (!source.length) return "";
        return source.map((point, idx) => (
          `${{idx === 0 || point.breakBefore ? "M" : "L"}} ${{point.x.toFixed(2)}} ${{point.y.toFixed(2)}}`
        )).join(" ");
      }};

      const buildPaths = (metricKey, minVal, maxVal) => {{
        const defaultStroke = metricKey === "avg_rssi" ? chartPalette.compare : chartPalette.line;
        const n = plotRows.length;
        const sourcePoints = [];
        let previousWasFinite = false;
        for (let i = 0; i < n; i += 1) {{
          const raw = Number(plotRows[i][metricKey]);
          if (!Number.isFinite(raw)) {{
            previousWasFinite = false;
            continue;
          }}
          sourcePoints.push({{
            value: raw,
            x: xAt(i, n),
            breakBefore: !previousWasFinite && sourcePoints.length > 0,
          }});
          previousWasFinite = true;
        }}
        if (!sourcePoints.length) {{
          return {{
            rawPath: "",
            trendPath: "",
          }};
        }}
        const smoothingWindow = normalizeSmoothingWindow(
          Math.max(5, Math.min(15, Math.round(sourcePoints.length / 18))),
          sourcePoints.length
        );
        const trendPoints = (typeof smoothSeriesPointsWithBreaks === "function")
          ? smoothSeriesPointsWithBreaks(sourcePoints, smoothingWindow)
          : sourcePoints.map((point) => ({{ ...point }}));
        const toScreenPoint = (point) => ({{
          x: Number(point.x),
          y: yFrom(Number(point.value), minVal, maxVal),
          value: Number(point.value),
          breakBefore: !!point.breakBefore,
        }});
        const rawGradientStops = buildSignalChartQualityGradientStops(
          sourcePoints,
          metricKey,
          signalQualityProfile,
          chartPalette,
          padLeft,
          plotW
        );
        const trendGradientStops = buildSignalChartQualityGradientStops(
          trendPoints,
          metricKey,
          signalQualityProfile,
          chartPalette,
          padLeft,
          plotW
        );
        const safeMetricId = String(metricKey || "metric").replace(/[^a-z0-9_-]/gi, "-");
        const rawGradientId = rawGradientStops
          ? `signal-chart-${{safeMetricId}}-raw-quality-gradient`
          : "";
        const trendGradientId = trendGradientStops
          ? `signal-chart-${{safeMetricId}}-trend-quality-gradient`
          : "";
        const rawPlotPoints = (typeof aggregatePointsByXPixels === "function")
          ? aggregatePointsByXPixels(sourcePoints.map((point) => toScreenPoint(point)), 1.05)
          : sourcePoints.map((point) => toScreenPoint(point));
        const trendPlotPoints = (typeof aggregatePointsByXPixels === "function")
          ? aggregatePointsByXPixels(trendPoints.map((point) => toScreenPoint(point)), 3.2)
          : trendPoints.map((point) => toScreenPoint(point));
        const rawPath = buildLinearPath(rawPlotPoints);
        const trendLinearPath = buildLinearPath(trendPlotPoints);
        let trendPath = trendLinearPath;
        if (typeof buildSmoothSvgPath === "function") {{
          const smoothPath = buildSmoothSvgPath(trendPlotPoints, 0.2);
          if (smoothPath) trendPath = smoothPath;
        }}
        return {{
          rawPath,
          trendPath,
          rawStroke: rawGradientId ? `url(#${{rawGradientId}})` : defaultStroke,
          trendStroke: trendGradientId ? `url(#${{trendGradientId}})` : defaultStroke,
          rawGradientDef: signalChartQualityGradientDef(rawGradientId, rawGradientStops, padLeft, plotW),
          trendGradientDef: signalChartQualityGradientDef(trendGradientId, trendGradientStops, padLeft, plotW),
        }};
      }};

      const snrPaths = buildPaths("avg_snr", snrMin, snrMax);
      const rssiPaths = buildPaths("avg_rssi", rssiMin, rssiMax);
      const signalQualityGradientDefs = [
        snrPaths.rawGradientDef,
        snrPaths.trendGradientDef,
        rssiPaths.rawGradientDef,
        rssiPaths.trendGradientDef,
      ].filter(Boolean).join("");
      const rightAxisLabelX = width - 6;
      const axisTickCount = responsiveAxisTickCount(plotH, {{
        min: 3,
        max: 9,
        targetPx: 74,
      }});
      const snrAxisTicks = buildLinearAxisTicks(snrMin, snrMax, axisTickCount);
      const rssiAxisTicks = buildLinearAxisTicks(rssiMin, rssiMax, snrAxisTicks.length);
      const axisLabelY = (ratio) => {{
        const y = padTop + (Number(ratio) * plotH);
        if (ratio <= 0.001) return padTop + 10;
        if (ratio >= 0.999) return height - padBottom + 11;
        return y + 4;
      }};
      const axisLines = snrAxisTicks.map((tick) => {{
        const y = padTop + (tick.ratio * plotH);
        return `<line x1="${{padLeft}}" y1="${{y.toFixed(2)}}" x2="${{width - padRight}}" y2="${{y.toFixed(2)}}" stroke="${{chartPalette.grid}}" stroke-width="1"></line>`;
      }}).join("");
      const snrAxisLabels = snrAxisTicks.map((tick) => (
        `<text x="${{padLeft - 4}}" y="${{axisLabelY(tick.ratio).toFixed(2)}}" font-size="10" text-anchor="end" fill="${{chartPalette.label}}">${{formatMetricValue(tick.value, 1)}}</text>`
      )).join("");
      const rssiAxisLabels = rssiAxisTicks.map((tick) => (
        `<text x="${{rightAxisLabelX.toFixed(2)}}" y="${{axisLabelY(tick.ratio).toFixed(2)}}" font-size="10" text-anchor="end" fill="${{chartPalette.compareLabel}}">${{formatMetricValue(tick.value, 0)}}</text>`
      )).join("");

      svg.setAttribute("viewBox", `0 0 ${{width}} ${{height}}`);
      svg.innerHTML = `
        <rect x="0" y="0" width="${{width}}" height="${{height}}" fill="none"></rect>
        ${{signalQualityGradientDefs ? `<defs>${{signalQualityGradientDefs}}</defs>` : ""}}
        <line x1="${{padLeft}}" y1="${{padTop}}" x2="${{padLeft}}" y2="${{height - padBottom}}" stroke="${{chartPalette.grid}}" stroke-width="1"></line>
        <line x1="${{width - padRight}}" y1="${{padTop}}" x2="${{width - padRight}}" y2="${{height - padBottom}}" stroke="${{chartPalette.grid}}" stroke-width="1"></line>
        ${{axisLines}}
        ${{snrPaths.rawPath ? `<path d="${{snrPaths.rawPath}}" fill="none" stroke="${{escAttr(snrPaths.rawStroke)}}" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" stroke-opacity="${{chartPalette.rawOpacity.toFixed(2)}}"></path>` : ""}}
        ${{rssiPaths.rawPath ? `<path d="${{rssiPaths.rawPath}}" fill="none" stroke="${{escAttr(rssiPaths.rawStroke)}}" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" stroke-opacity="${{chartPalette.rawOpacity.toFixed(2)}}"></path>` : ""}}
        ${{snrPaths.trendPath ? `<path d="${{snrPaths.trendPath}}" fill="none" stroke="${{escAttr(snrPaths.trendStroke)}}" stroke-width="2.15" stroke-linecap="round" stroke-linejoin="round"></path>` : ""}}
        ${{rssiPaths.trendPath ? `<path d="${{rssiPaths.trendPath}}" fill="none" stroke="${{escAttr(rssiPaths.trendStroke)}}" stroke-width="2.15" stroke-linecap="round" stroke-linejoin="round"></path>` : ""}}
        ${{snrAxisLabels}}
        ${{rssiAxisLabels}}
      `;
      renderSignalTimeline(plotRows, padLeft, padRight, width);
    }}

    function setNodeOnlineTimelineMessage(message) {{
      setTimelineMessage("node-online-timeline", message);
    }}

    function setNodeLinkQualityTimelineMessage(message) {{
      setTimelineMessage("node-link-quality-timeline", message);
    }}

    function setNodePacketsTimelineMessage(message) {{
      setTimelineMessage("node-packets-timeline", message);
    }}

    function rerenderNodeLinkQualityChartFromCache() {{
      const chartState = historyTrendCharts.nodeLinkQuality;
      const sourcePoints = chartState && Array.isArray(chartState.sourcePoints)
        ? chartState.sourcePoints
        : [];
      const sourceNodeId = chartState ? chartState.nodeId : "";
      renderNodeLinkQualityChart(sourcePoints, sourceNodeId);
    }}

    function rerenderNodeOnlineChartFromCache() {{
      const chartState = historyTrendCharts.nodeOnline;
      const sourcePoints = chartState && Array.isArray(chartState.sourcePoints)
        ? chartState.sourcePoints
        : [];
      const sourcePackets = chartState && Array.isArray(chartState.sourcePacketTimestamps)
        ? chartState.sourcePacketTimestamps
        : [];
      const sourceWindowHours = chartState ? chartState.sourceWindowHours : null;
      const sourceNodeId = chartState ? chartState.nodeId : "";
      renderNodeOnlineChart(sourcePoints, sourceWindowHours, sourcePackets, sourceNodeId);
    }}

    function rerenderNodePacketsChartFromCache() {{
      const chartState = historyTrendCharts.nodePackets;
      const sourcePoints = chartState && Array.isArray(chartState.sourcePoints)
        ? chartState.sourcePoints
        : [];
      const sourcePacketSeries = chartState && chartState.sourcePacketSeries
        ? chartState.sourcePacketSeries
        : null;
      const sourceWindowHours = chartState ? chartState.sourceWindowHours : null;
      const sourceNodeId = chartState ? chartState.nodeId : "";
      renderNodePacketsChart(sourcePoints, sourceWindowHours, sourceNodeId, sourcePacketSeries);
    }}

    function nodeHistoryLinkQualityPathCountFromPoint(point) {{
      const hopsSamplesRaw = Number(point && point.hops_samples);
      const hopsSamples = Number.isFinite(hopsSamplesRaw) ? Math.max(0, hopsSamplesRaw) : 0;
      const packetCountRaw = Number(point && point.packet_count);
      const packetCount = Number.isFinite(packetCountRaw) ? Math.max(0, packetCountRaw) : 0;
      const evidence = Math.max(hopsSamples, packetCount * 0.5);
      if (evidence >= 18) return 4;
      if (evidence >= 9) return 3;
      if (evidence >= 4) return 2;
      if (evidence >= 1) return 1;
      return 0;
    }}

    function nodeHistoryFallbackLinkQuality(hopsValue, pathCountValue, options = null) {{
      const opts = (options && typeof options === "object") ? options : {{}};
      const hopsRaw = Number(hopsValue);
      const hops = Number.isFinite(hopsRaw) && hopsRaw >= 0
        ? Math.max(0, Math.trunc(hopsRaw))
        : null;
      const pathCountRaw = Number(pathCountValue);
      const pathCount = Number.isFinite(pathCountRaw) && pathCountRaw >= 0
        ? Math.max(0, Math.trunc(pathCountRaw))
        : 0;
      const reachable = !!opts.reachable || hops != null || pathCount > 0;
      if (!reachable) {{
        return {{
          bars: 0,
          score: 0,
        }};
      }}
      const hopsScore = hops == null
        ? 42
        : Math.max(0, Math.min(100, Math.round(100 * (1 - Math.min(1, Math.max(0, hops - 1) / 6)))));
      const pathScore = pathCount >= 4
        ? 100
        : (pathCount === 3 ? 84 : (pathCount === 2 ? 66 : (pathCount === 1 ? 38 : 0)));
      let score = Math.round((hopsScore * 0.7) + (pathScore * 0.3));
      if (hops != null && pathCount <= 0) {{
        score = Math.min(score, 46);
      }}
      if (hops != null && hops <= 2 && pathCount >= 2) {{
        score = Math.min(100, score + 8);
      }}
      const bars = score >= 86
        ? 4
        : (score >= 64 ? 3 : (score >= 42 ? 2 : (score >= 20 ? 1 : 0)));
      return {{
        bars,
        score,
      }};
    }}

    function buildNodeLinkQualityChartRows(points) {{
      const rows = Array.isArray(points) ? points : [];
      const chartRows = [];
      for (const point of rows) {{
        if (!point || typeof point !== "object") continue;
        const bucketUnix = normalizeNodePacketBucketUnix(point.bucket_unix);
        if (!Number.isFinite(bucketUnix) || bucketUnix <= 0) continue;
        const avgHopsRaw = Number(point.avg_hops);
        const avgHops = Number.isFinite(avgHopsRaw) && avgHopsRaw >= 0
          ? avgHopsRaw
          : null;
        const pathCount = nodeHistoryLinkQualityPathCountFromPoint(point);
        const reachable = avgHops != null || pathCount > 0;
        const inferred = (typeof chatNodeNavigatorInferLinkQuality === "function")
          ? chatNodeNavigatorInferLinkQuality(avgHops, pathCount, {{ reachable }})
          : nodeHistoryFallbackLinkQuality(avgHops, pathCount, {{ reachable }});
        const scoreRaw = Number(inferred && inferred.score);
        const barsRaw = Number(inferred && inferred.bars);
        if (!Number.isFinite(scoreRaw) || scoreRaw < 0) continue;
        const score = Math.max(0, Math.min(100, scoreRaw));
        const bars = Number.isFinite(barsRaw)
          ? Math.max(0, Math.min(4, barsRaw))
          : 0;
        chartRows.push({{
          value: score,
          series: {{
            quality_score: score,
            quality_bars_scaled: bars * 25,
          }},
          qualityScore: score,
          qualityBars: bars,
          avgHops,
          pathCount,
          hopsSamples: Number.isFinite(Number(point.hops_samples)) ? Math.max(0, Number(point.hops_samples)) : 0,
          packetCount: Number.isFinite(Number(point.packet_count)) ? Math.max(0, Number(point.packet_count)) : 0,
          bucketText: String(point.bucket_time || "").trim(),
          bucketUnix,
        }});
      }}
      return chartRows;
    }}

    function resolveNodeLinkQualityMetricMeta() {{
      return {{
        key: "node_link_quality",
        label: "Estimated link quality (%)",
        compareLabel: "Estimated bars (scaled)",
        seriesOrder: ["quality_score", "quality_bars_scaled"],
        seriesLabels: {{
          quality_score: "Estimated quality (%)",
          quality_bars_scaled: "Estimated bars (x25)",
        }},
        seriesStyles: {{
          quality_score: {{
            tone: "line",
            width: 2.35,
          }},
          quality_bars_scaled: {{
            tone: "compare",
            dashed: true,
            width: 1.95,
          }},
        }},
        smoothingWindow: 5,
      }};
    }}

    function renderNodeLinkQualityChart(points, nodeId = null) {{
      const chartState = historyTrendCharts.nodeLinkQuality;
      const rows = Array.isArray(points) ? points : [];
      const currentNodeId = normalizeNodeId(nodeId || selectedNodeId || "");
      if (currentNodeId !== String(chartState.nodeId || "")) {{
        resetHistoryTrendZoom(chartState);
      }}
      chartState.nodeId = currentNodeId;
      chartState.sourcePoints = rows;
      const chartRows = buildNodeLinkQualityChartRows(rows);
      const metricMeta = resolveNodeLinkQualityMetricMeta();
      renderWeeklySummaryChartRows(
        chartRows,
        metricMeta,
        "No inferred link-quality history yet for this node.",
        {{ targetKey: "node-link-quality" }}
      );
    }}

    function normalizeNodePacketBucketUnix(raw) {{
      const numeric = Number(raw);
      if (!Number.isFinite(numeric) || numeric <= 0) return null;
      if (numeric > 100000000000) {{
        return Math.floor(numeric / 1000);
      }}
      return Math.floor(numeric);
    }}

    function buildNodePacketChartRows(points, packetSeriesPayload, startUnix, endUnix) {{
      const rows = Array.isArray(points) ? points : [];
      const normalizedRows = rows
        .map((row) => {{
          const bucketUnix = normalizeNodePacketBucketUnix(row && row.bucket_unix);
          const packetCountRaw = Number(row && row.packet_count);
          const packetCount = Number.isFinite(packetCountRaw)
            ? Math.max(0, Math.trunc(packetCountRaw))
            : 0;
          return bucketUnix
            ? {{
                bucket_unix: bucketUnix,
                bucket_time: String(row && row.bucket_time || "").trim(),
                packet_count: packetCount,
              }}
            : null;
        }})
        .filter((row) => !!row)
        .filter((row) => row.bucket_unix >= startUnix && row.bucket_unix <= endUnix)
        .sort((a, b) => a.bucket_unix - b.bucket_unix);
      const zeroFilledRows = (baseRows, bucketPointMap = null) => {{
        const sourceRows = Array.isArray(baseRows) ? baseRows : [];
        if (!sourceRows.length) return [];
        const firstBucket = Number(sourceRows[0] && (sourceRows[0].bucketUnix ?? sourceRows[0].bucket_unix));
        const lastBucket = Number(sourceRows[sourceRows.length - 1] && (sourceRows[sourceRows.length - 1].bucketUnix ?? sourceRows[sourceRows.length - 1].bucket_unix));
        if (!Number.isFinite(firstBucket) || !Number.isFinite(lastBucket) || lastBucket < firstBucket) {{
          return sourceRows;
        }}
        const spanBuckets = Math.floor((lastBucket - firstBucket) / 60) + 1;
        if (!Number.isFinite(spanBuckets) || spanBuckets <= 0 || spanBuckets > 10000) {{
          return sourceRows;
        }}
        const lookup = bucketPointMap instanceof Map
          ? bucketPointMap
          : new Map(sourceRows.map((row) => [Number(row && (row.bucketUnix ?? row.bucket_unix)), row]));
        const filledRows = [];
        for (let bucketUnix = firstBucket; bucketUnix <= lastBucket; bucketUnix += 60) {{
          const existing = lookup.get(bucketUnix);
          filledRows.push(existing || {{
            bucket_unix: bucketUnix,
            bucket_time: "",
            packet_count: 0,
          }});
        }}
        return filledRows;
      }};

      const payload = (packetSeriesPayload && typeof packetSeriesPayload === "object")
        ? packetSeriesPayload
        : null;
      const packetSeriesByKey = (
        payload
        && payload.series
        && typeof payload.series === "object"
      ) ? payload.series : null;
      const packetSeriesMetric = !!(
        payload
        && payload.available === true
        && packetSeriesByKey
      );
      if (!packetSeriesMetric) {{
        return {{
          rows: zeroFilledRows(normalizedRows).map((row) => ({{
            value: row.packet_count,
            totalValue: row.packet_count,
            bucketText: row.bucket_time,
            bucketUnix: row.bucket_unix,
          }})),
          packetSeriesMetric: false,
        }};
      }}

      const selectedPacketSeriesKeys = networkOverviewPacketSeriesOrder.filter((key) => nodePacketSeriesEnabled[key]);
      const packetSeriesLookups = new Map();
      const bucketPointMap = new Map();
      for (const row of normalizedRows) {{
        bucketPointMap.set(row.bucket_unix, {{
          bucketUnix: row.bucket_unix,
          bucketText: row.bucket_time,
          totalValue: row.packet_count,
        }});
      }}

      for (const key of networkOverviewPacketSeriesOrder) {{
        const lookup = new Map();
        const seriesRows = Array.isArray(packetSeriesByKey[key]) ? packetSeriesByKey[key] : [];
        for (const row of seriesRows) {{
          if (!row || typeof row !== "object") continue;
          const bucketUnix = normalizeNodePacketBucketUnix(row.bucket_unix);
          const packetCount = Number(row.packet_count);
          if (!Number.isFinite(bucketUnix) || bucketUnix < startUnix || bucketUnix > endUnix) continue;
          if (!Number.isFinite(packetCount) || packetCount <= 0) continue;
          lookup.set(bucketUnix, packetCount);
          if (!bucketPointMap.has(bucketUnix)) {{
            bucketPointMap.set(bucketUnix, {{
              bucketUnix,
              bucketText: "",
              totalValue: null,
            }});
          }}
        }}
        packetSeriesLookups.set(key, lookup);
      }}

      const bucketSeconds = Math.max(1, Number(payload.bucket_seconds) || 60);
      const packetRateScale = 60 / bucketSeconds;
      const chartRows = [];
      const orderedRows = zeroFilledRows(
        Array.from(bucketPointMap.values())
          .slice()
          .sort((left, right) => left.bucketUnix - right.bucketUnix),
        new Map(Array.from(bucketPointMap.entries()))
      ).map((row) => ({{
        bucketUnix: Number(row.bucketUnix ?? row.bucket_unix),
        bucketText: String((row.bucketText ?? row.bucket_time) || "").trim(),
        totalValue: Number.isFinite(Number(row.totalValue))
          ? Number(row.totalValue)
          : Math.max(0, Math.trunc(Number(row.packet_count) || 0)),
      }}));
      for (const row of orderedRows) {{
        const seriesValues = {{}};
        let primaryValue = null;
        for (const key of selectedPacketSeriesKeys) {{
          const lookup = packetSeriesLookups.get(key);
          const packetCount = lookup instanceof Map ? Number(lookup.get(row.bucketUnix) || 0) : 0;
          const packetRate = Math.max(0, packetCount) * packetRateScale;
          seriesValues[key] = packetRate;
          if (primaryValue === null) {{
            primaryValue = packetRate;
          }}
        }}
        if (primaryValue === null) continue;
        chartRows.push({{
          value: primaryValue,
          series: seriesValues,
          totalValue: Number.isFinite(Number(row.totalValue)) ? Number(row.totalValue) : null,
          bucketText: String(row.bucketText || "").trim(),
          bucketUnix: row.bucketUnix,
        }});
      }}

      return {{
        rows: chartRows,
        packetSeriesMetric: true,
      }};
    }}

    function renderNodeOnlineChart(points, windowHours = null, packetTimestamps = null, nodeId = null) {{
      const svg = document.getElementById("node-online-chart");
      const empty = document.getElementById("node-online-empty");
      if (!(svg instanceof SVGElement) || !(empty instanceof HTMLElement)) return;
      const chartState = historyTrendCharts.nodeOnline;
      bindHistoryTrendChartZoom(
        chartState,
        () => rerenderNodeOnlineChartFromCache(),
        "Node online history chart"
      );

      const normalizeUnixSeconds = (raw) => {{
        const numeric = Number(raw);
        if (!Number.isFinite(numeric) || numeric <= 0) return null;
        // Accept both second and millisecond unix timestamps.
        if (numeric > 100000000000) {{
          return Math.floor(numeric / 1000);
        }}
        return Math.floor(numeric);
      }};

      const rows = Array.isArray(points) ? points : [];
      const timestampRows = Array.isArray(packetTimestamps) ? packetTimestamps : [];
      const windowHoursRaw = Number(windowHours);
      const defaultWindowHours = Number(nodeHistoryHours);
      const resolvedWindowHours = Number.isFinite(windowHoursRaw) && windowHoursRaw > 0
        ? windowHoursRaw
        : (Number.isFinite(defaultWindowHours) && defaultWindowHours > 0 ? defaultWindowHours : 72);
      const currentNodeId = normalizeNodeId(nodeId || selectedNodeId || "");
      if (currentNodeId !== String(chartState.nodeId || "")) {{
        resetHistoryTrendZoom(chartState);
      }}
      chartState.nodeId = currentNodeId;
      chartState.sourcePoints = rows;
      chartState.sourceWindowHours = resolvedWindowHours;
      chartState.sourcePacketTimestamps = timestampRows;
      const windowSeconds = Math.max(60, Math.round(resolvedWindowHours * 3600));
      const endUnix = Math.floor(Date.now() / 1000);
      const startUnix = endUnix - windowSeconds;
      const packetsByBucket = new Map();
      for (const rawTs of timestampRows) {{
        const ts = normalizeUnixSeconds(rawTs);
        if (!Number.isFinite(ts) || ts <= 0) continue;
        const bucketMinute = Math.floor(ts / 60) * 60;
        packetsByBucket.set(bucketMinute, (packetsByBucket.get(bucketMinute) || 0) + 1);
      }}
      // Merge rollup packet_count buckets as a second source. This protects against
      // partial packet timestamp availability and keeps the series resilient.
      for (const row of rows) {{
        const bucket = normalizeUnixSeconds(row && row.bucket_unix);
        if (!Number.isFinite(bucket)) continue;
        const bucketMinute = Math.floor(bucket / 60) * 60;
        const packetCount = Number(row && row.packet_count);
        const normalizedCount = Number.isFinite(packetCount) ? Math.max(0, Math.trunc(packetCount)) : 0;
        if (normalizedCount > 0) {{
          packetsByBucket.set(bucketMinute, Math.max(normalizedCount, packetsByBucket.get(bucketMinute) || 0));
        }}
      }}
      const statusOnlineWindowSeconds = Math.max(
        60,
        Math.round((Number(chatWarnWindowSeconds) || 600) / 60) * 60
      );
      const statusWarnWindowSeconds = Math.max(
        statusOnlineWindowSeconds,
        Math.round((Number(chatStaleWindowSeconds) || 1800) / 60) * 60
      );
      const officialOnlineWindowSeconds = Math.max(
        statusWarnWindowSeconds,
        Math.round((Number(meshtasticOnlineWindowSeconds) || (2 * 60 * 60)) / 60) * 60
      );
      const chartLayout = resolveRenderedSvgChartLayout(svg, signalChartLayout);
      chartState.layout = chartLayout;
      const width = chartLayout.width;
      const height = chartLayout.height;
      const padLeft = chartLayout.padLeft;
      const padRight = chartLayout.padRight;
      const padTop = chartLayout.padTop;
      const padBottom = chartLayout.padBottom;
      const plotW = width - padLeft - padRight;
      const plotH = height - padTop - padBottom;

      const eventBuckets = Array.from(packetsByBucket.entries())
        .filter(([bucket, count]) => Number.isFinite(bucket) && Number.isFinite(count) && count > 0)
        .map(([bucket]) => Math.trunc(bucket))
        .sort((a, b) => a - b);

      const timelinePoints = new Set([startUnix, endUnix]);
      for (const bucket of eventBuckets) {{
        if (bucket >= startUnix && bucket <= endUnix) {{
          timelinePoints.add(bucket);
        }}
        const statusOnlineEdge = Math.min(endUnix, Math.max(startUnix, bucket + statusOnlineWindowSeconds));
        const statusWarnEdge = Math.min(endUnix, Math.max(startUnix, bucket + statusWarnWindowSeconds));
        const officialEdge = Math.min(endUnix, Math.max(startUnix, bucket + officialOnlineWindowSeconds));
        timelinePoints.add(statusOnlineEdge);
        timelinePoints.add(statusWarnEdge);
        timelinePoints.add(officialEdge);
      }}
      const allPlotRows = Array.from(timelinePoints)
        .filter((unixTs) => Number.isFinite(unixTs))
        .sort((a, b) => a - b)
        .map((unixTs) => ({{ bucket_unix: Math.trunc(unixTs) }}));
      chartState.points = allPlotRows;
      const visible = getVisibleHistoryTrendRows(chartState, allPlotRows);
      const plotRows = visible.rows;
      setHistoryTrendChartTitle(
        svg,
        "Node online history chart (status transitions + Meshtastic official window)",
        visible.zoomed
      );

      if (allPlotRows.length === 0 || plotRows.length === 0) {{
        svg.innerHTML = "";
        empty.hidden = false;
        empty.textContent = "No historical online points yet for this node.";
        renderTimeline(
          "node-online-timeline",
          plotRows,
          padLeft,
          padRight,
          width,
          (row) => timelinePointUnix(row, "bucket_unix", ["bucket_local", "bucket_time"])
        );
        return;
      }}

      let viewStartUnix = Number(plotRows[0] && plotRows[0].bucket_unix);
      let viewEndUnix = Number(plotRows[plotRows.length - 1] && plotRows[plotRows.length - 1].bucket_unix);
      if (!Number.isFinite(viewStartUnix)) viewStartUnix = startUnix;
      if (!Number.isFinite(viewEndUnix)) viewEndUnix = endUnix;
      viewStartUnix = Math.max(startUnix, Math.trunc(viewStartUnix));
      viewEndUnix = Math.min(endUnix, Math.trunc(viewEndUnix));
      if (!(viewEndUnix > viewStartUnix)) {{
        viewStartUnix = startUnix;
        viewEndUnix = endUnix;
      }}
      const viewWindowSeconds = Math.max(60, viewEndUnix - viewStartUnix);
      const xFromUnix = (unixTs) => {{
        const ratio = Math.max(0, Math.min(1, (Number(unixTs) - viewStartUnix) / viewWindowSeconds));
        return padLeft + (ratio * plotW);
      }};
      const breakpointSet = new Set([viewStartUnix, viewEndUnix]);
      for (const row of plotRows) {{
        const rowUnix = normalizeUnixSeconds(row && row.bucket_unix);
        if (!Number.isFinite(rowUnix)) continue;
        if (rowUnix < viewStartUnix || rowUnix > viewEndUnix) continue;
        breakpointSet.add(Math.trunc(rowUnix));
      }}
      const breakpoints = Array.from(breakpointSet).sort((a, b) => a - b);
      const statusDurations = {{
        online: 0,
        warn: 0,
        stale: 0,
      }};
      const officialDurations = {{
        online: 0,
        offline: 0,
      }};
      const segments = [];
      let eventCursor = 0;
      let latestEventUnix = null;
      for (let idx = 0; idx < (breakpoints.length - 1); idx += 1) {{
        const segmentStart = Math.max(viewStartUnix, Math.trunc(Number(breakpoints[idx]) || 0));
        const segmentEnd = Math.min(viewEndUnix, Math.trunc(Number(breakpoints[idx + 1]) || 0));
        if (!(segmentEnd > segmentStart)) continue;
        const midUnix = segmentStart + Math.max(1, Math.floor((segmentEnd - segmentStart) / 2));
        while (eventCursor < eventBuckets.length && eventBuckets[eventCursor] <= midUnix) {{
          latestEventUnix = eventBuckets[eventCursor];
          eventCursor += 1;
        }}
        let statusKey = "stale";
        let officialKey = "offline";
        if (Number.isFinite(latestEventUnix) && latestEventUnix > 0) {{
          const ageSeconds = Math.max(0, midUnix - latestEventUnix);
          if (ageSeconds <= statusOnlineWindowSeconds) {{
            statusKey = "online";
          }} else if (ageSeconds <= statusWarnWindowSeconds) {{
            statusKey = "warn";
          }}
          if (ageSeconds <= officialOnlineWindowSeconds) {{
            officialKey = "online";
          }}
        }}
        const duration = Math.max(0, segmentEnd - segmentStart);
        statusDurations[statusKey] += duration;
        officialDurations[officialKey] += duration;
        segments.push({{
          start_unix: segmentStart,
          end_unix: segmentEnd,
          statusKey,
          officialKey,
        }});
      }}
      empty.hidden = true;

      const statusLaneTop = padTop + 8;
      const statusLaneBottom = padTop + (plotH * 0.60);
      const officialLaneTop = padTop + (plotH * 0.72);
      const officialLaneBottom = padTop + plotH;
      const statusLaneHeight = Math.max(24, statusLaneBottom - statusLaneTop);
      const officialLaneHeight = Math.max(18, officialLaneBottom - officialLaneTop);
      const statusYByKey = {{
        online: statusLaneTop + (statusLaneHeight * 0.14),
        warn: statusLaneTop + (statusLaneHeight * 0.50),
        stale: statusLaneTop + (statusLaneHeight * 0.86),
      }};
      const officialYByKey = {{
        online: officialLaneTop + (officialLaneHeight * 0.22),
        offline: officialLaneTop + (officialLaneHeight * 0.78),
      }};

      const percentText = (value) => {{
        const safe = Number.isFinite(value) ? Math.max(0, value) : 0;
        return safe < 9.95 ? safe.toFixed(1) : String(Math.round(safe));
      }};
      const statusOnlinePercent = viewWindowSeconds > 0 ? (statusDurations.online / viewWindowSeconds) * 100 : 0;
      const statusWarnPercent = viewWindowSeconds > 0 ? (statusDurations.warn / viewWindowSeconds) * 100 : 0;
      const statusStalePercent = viewWindowSeconds > 0 ? (statusDurations.stale / viewWindowSeconds) * 100 : 0;
      const officialOnlinePercent = viewWindowSeconds > 0 ? (officialDurations.online / viewWindowSeconds) * 100 : 0;
      const chartPalette = historyChartPalette();
      const rightSummaryX = width - 6;
      const renderSegmentLines = (rows, stateKeyName, yByState, colorByState, strokeWidth = 2.6) => {{
        const horizontals = [];
        const connectors = [];
        let previousState = "";
        for (let idx = 0; idx < rows.length; idx += 1) {{
          const row = rows[idx];
          const stateKey = String(row && row[stateKeyName] ? row[stateKeyName] : "").trim();
          const startX = xFromUnix(row && row.start_unix);
          const endX = xFromUnix(row && row.end_unix);
          const y = Number(yByState[stateKey]);
          const previousY = Number(yByState[previousState]);
          if (!Number.isFinite(startX) || !Number.isFinite(endX) || !Number.isFinite(y)) continue;
          horizontals.push(
            `<line x1="${{startX.toFixed(2)}}" y1="${{y.toFixed(2)}}" x2="${{endX.toFixed(2)}}" y2="${{y.toFixed(2)}}" stroke="${{escAttr(colorByState[stateKey] || chartPalette.connector)}}" stroke-width="${{strokeWidth.toFixed(2)}}" stroke-linecap="round"></line>`
          );
          if (idx > 0 && previousState && Number.isFinite(previousY) && previousY !== y) {{
            connectors.push(
              `<line x1="${{startX.toFixed(2)}}" y1="${{previousY.toFixed(2)}}" x2="${{startX.toFixed(2)}}" y2="${{y.toFixed(2)}}" stroke="${{escAttr(chartPalette.connector)}}" stroke-width="1.35" stroke-linecap="round" opacity="0.9"></line>`
            );
          }}
          previousState = stateKey;
        }}
        return {{
          horizontals,
          connectors,
        }};
      }};
      const statusLines = renderSegmentLines(
        segments,
        "statusKey",
        statusYByKey,
        {{
          online: chartPalette.line,
          warn: chartPalette.aux1,
          stale: chartPalette.danger,
        }},
        3.1
      );
      const officialLines = renderSegmentLines(
        segments,
        "officialKey",
        officialYByKey,
        {{
          online: chartPalette.compare,
          offline: chartPalette.offline,
        }},
        2.7
      );
      const officialRects = segments
        .filter((segment) => String(segment && segment.officialKey || "") === "online")
        .map((segment) => {{
          const startX = xFromUnix(segment && segment.start_unix);
          const endX = xFromUnix(segment && segment.end_unix);
          const rectW = Math.max(1, endX - startX);
          return `<rect x="${{startX.toFixed(2)}}" y="${{officialLaneTop.toFixed(2)}}" width="${{rectW.toFixed(2)}}" height="${{officialLaneHeight.toFixed(2)}}" fill="${{escAttr(chartPalette.compare)}}" opacity="0.12"></rect>`;
        }});

      svg.setAttribute("viewBox", `0 0 ${{width}} ${{height}}`);
      svg.innerHTML = `
        <rect x="0" y="0" width="${{width}}" height="${{height}}" fill="none"></rect>
        <line x1="${{padLeft}}" y1="${{padTop}}" x2="${{padLeft}}" y2="${{height - padBottom}}" stroke="${{chartPalette.grid}}" stroke-width="1"></line>
        <line x1="${{padLeft}}" y1="${{statusLaneTop.toFixed(2)}}" x2="${{width - padRight}}" y2="${{statusLaneTop.toFixed(2)}}" stroke="${{chartPalette.grid}}" stroke-width="1"></line>
        <line x1="${{padLeft}}" y1="${{statusYByKey.online.toFixed(2)}}" x2="${{width - padRight}}" y2="${{statusYByKey.online.toFixed(2)}}" stroke="${{chartPalette.grid}}" stroke-width="1"></line>
        <line x1="${{padLeft}}" y1="${{statusYByKey.warn.toFixed(2)}}" x2="${{width - padRight}}" y2="${{statusYByKey.warn.toFixed(2)}}" stroke="${{chartPalette.grid}}" stroke-width="1"></line>
        <line x1="${{padLeft}}" y1="${{statusYByKey.stale.toFixed(2)}}" x2="${{width - padRight}}" y2="${{statusYByKey.stale.toFixed(2)}}" stroke="${{chartPalette.grid}}" stroke-width="1"></line>
        <line x1="${{padLeft}}" y1="${{officialLaneTop.toFixed(2)}}" x2="${{width - padRight}}" y2="${{officialLaneTop.toFixed(2)}}" stroke="${{chartPalette.grid}}" stroke-width="1"></line>
        <line x1="${{padLeft}}" y1="${{officialYByKey.online.toFixed(2)}}" x2="${{width - padRight}}" y2="${{officialYByKey.online.toFixed(2)}}" stroke="${{chartPalette.grid}}" stroke-width="1"></line>
        <line x1="${{padLeft}}" y1="${{officialYByKey.offline.toFixed(2)}}" x2="${{width - padRight}}" y2="${{officialYByKey.offline.toFixed(2)}}" stroke="${{chartPalette.grid}}" stroke-width="1"></line>
        <g>${{officialRects.join("")}}</g>
        <g>${{statusLines.connectors.join("")}}${{statusLines.horizontals.join("")}}</g>
        <g>${{officialLines.connectors.join("")}}${{officialLines.horizontals.join("")}}</g>
        <text x="${{(padLeft + 4).toFixed(2)}}" y="${{(statusLaneTop - 2).toFixed(2)}}" font-size="10" text-anchor="start" fill="${{chartPalette.label}}">Status (10m online / 30m stale)</text>
        <text x="${{(padLeft - 4).toFixed(2)}}" y="${{(statusYByKey.online + 4).toFixed(2)}}" font-size="10" text-anchor="end" fill="${{chartPalette.line}}">Online</text>
        <text x="${{(padLeft - 4).toFixed(2)}}" y="${{(statusYByKey.warn + 4).toFixed(2)}}" font-size="10" text-anchor="end" fill="${{chartPalette.aux1}}">Aging</text>
        <text x="${{(padLeft - 4).toFixed(2)}}" y="${{(statusYByKey.stale + 4).toFixed(2)}}" font-size="10" text-anchor="end" fill="${{chartPalette.danger}}">Stale</text>
        <text x="${{(padLeft + 4).toFixed(2)}}" y="${{(officialLaneTop - 2).toFixed(2)}}" font-size="10" text-anchor="start" fill="${{chartPalette.label}}">Official (2h online)</text>
        <text x="${{(padLeft - 4).toFixed(2)}}" y="${{(officialYByKey.online + 4).toFixed(2)}}" font-size="10" text-anchor="end" fill="${{chartPalette.compare}}">Online</text>
        <text x="${{(padLeft - 4).toFixed(2)}}" y="${{(officialYByKey.offline + 4).toFixed(2)}}" font-size="10" text-anchor="end" fill="${{chartPalette.offline}}">Offline</text>
        <text x="${{rightSummaryX.toFixed(2)}}" y="${{(padTop + 10).toFixed(2)}}" font-size="10" text-anchor="end" fill="${{chartPalette.label}}">
          <tspan x="${{rightSummaryX.toFixed(2)}}" dy="0">Status O/A/S: ${{percentText(statusOnlinePercent)}} / ${{percentText(statusWarnPercent)}} / ${{percentText(statusStalePercent)}}%</tspan>
          <tspan x="${{rightSummaryX.toFixed(2)}}" dy="12">Official online: ${{percentText(officialOnlinePercent)}}%</tspan>
        </text>
      `;

      renderTimeline(
        "node-online-timeline",
        plotRows,
        padLeft,
        padRight,
        width,
        (row) => timelinePointUnix(row, "bucket_unix", ["bucket_local", "bucket_time"])
      );
    }}

    function renderNodePacketsChart(points, windowHours = null, nodeId = null, packetSeriesPayload = null) {{
      const chartState = historyTrendCharts.nodePackets;
      const rows = Array.isArray(points) ? points : [];
      const windowHoursRaw = Number(windowHours);
      const defaultWindowHours = Number(nodeHistoryHours);
      const resolvedWindowHours = Number.isFinite(windowHoursRaw) && windowHoursRaw > 0
        ? windowHoursRaw
        : (Number.isFinite(defaultWindowHours) && defaultWindowHours > 0 ? defaultWindowHours : 72);
      const currentNodeId = normalizeNodeId(nodeId || selectedNodeId || "");
      if (currentNodeId !== String(chartState.nodeId || "")) {{
        resetHistoryTrendZoom(chartState);
      }}
      chartState.nodeId = currentNodeId;
      chartState.sourcePoints = rows;
      chartState.sourceWindowHours = resolvedWindowHours;
      chartState.sourcePacketSeries = (packetSeriesPayload && typeof packetSeriesPayload === "object")
        ? packetSeriesPayload
        : null;
      const windowSeconds = Math.max(60, Math.round(resolvedWindowHours * 3600));
      const endUnix = Math.floor(Date.now() / 1000);
      const startUnix = endUnix - windowSeconds;
      const built = buildNodePacketChartRows(
        rows,
        packetSeriesPayload,
        startUnix,
        endUnix
      );
      const packetSeries = built.packetSeriesMetric ? nodePacketSeriesEnabled : null;
      const metricMeta = resolveWeeklySummaryMetricMeta("packets", weeklySummaryNodeSeriesEnabled, packetSeries);
      const emptyMessage = built.packetSeriesMetric
        ? "No packet activity yet in this window."
        : "No packet-rate history yet for this node.";
      renderWeeklySummaryChartRows(
        built.rows,
        metricMeta,
        emptyMessage,
        {{ targetKey: "node-packets" }}
      );
    }}

    function rerenderOnlineActivityChartFromCache() {{
      const chartState = historyTrendCharts.online;
      const points = chartState && Array.isArray(chartState.points) ? chartState.points : [];
      renderOnlineActivityChart(points);
    }}

    function rerenderWeeklySummaryChartFromCache(targetKey = "history") {{
      const target = resolveWeeklySummaryRenderTarget(targetKey);
      const chartState = target && target.chartState;
      const rows = chartState && Array.isArray(chartState.points) ? chartState.points : [];
      if (target && target.key === "node-packets") {{
        const packetSeries = rows.some((row) => row && row.series && typeof row.series === "object")
          ? nodePacketSeriesEnabled
          : null;
        const metricMeta = resolveWeeklySummaryMetricMeta("packets", weeklySummaryNodeSeriesEnabled, packetSeries);
        const emptyMessage = packetSeries
          ? "No packet activity yet in this window."
          : "No packet-rate history yet for this node.";
        renderWeeklySummaryChartRows(rows, metricMeta, emptyMessage, {{ targetKey: target.key }});
        return;
      }}
      if (target && target.key === "node-link-quality") {{
        const metricMeta = resolveNodeLinkQualityMetricMeta();
        renderWeeklySummaryChartRows(
          rows,
          metricMeta,
          "No inferred link-quality history yet for this node.",
          {{ targetKey: target.key }}
        );
        return;
      }}
      const metricKey = target && target.key === "network-overview"
        ? normalizeNetworkOverviewMetric(networkOverviewMetric)
        : normalizeWeeklySummaryMetric(weeklySummaryMetric);
      const nodeSeries = target && target.key === "network-overview"
        ? networkOverviewNodeSeriesEnabled
        : weeklySummaryNodeSeriesEnabled;
      const packetSeries = target && target.key === "network-overview"
        ? networkOverviewPacketSeriesEnabled
        : null;
      const metricMeta = resolveWeeklySummaryMetricMeta(metricKey, nodeSeries, packetSeries);
      const emptyMessage = metricKey === "packets" && packetSeries
        ? "No packet activity yet in this window."
        : (metricKey === "packets"
          ? "Need at least two saved samples to estimate packets/min."
          : "No weekly summary history yet.");
      renderWeeklySummaryChartRows(rows, metricMeta, emptyMessage, {{ targetKey: target.key }});
    }}

    function renderOnlineActivityLoading() {{
      setMapDataMode("activity");
      historyTrendCharts.online.points = [];
      historyTrendCharts.online.pointerDrag = null;
      const caption = document.getElementById("online-activity-caption");
      if (caption) {{
        caption.textContent = "Loading online-node activity history...";
      }}
      const overview = document.getElementById("online-activity-overview");
      if (overview) {{
        overview.innerHTML = "";
      }}
      const svg = document.getElementById("online-activity-chart");
      if (svg instanceof SVGElement) {{
        svg.innerHTML = "";
        svg.classList.remove("zoomed", "chart-dragging");
      }}
      const empty = document.getElementById("online-activity-empty");
      if (empty) {{
        empty.hidden = false;
        empty.textContent = "Loading historical online activity...";
      }}
      setTimelineMessage("online-activity-timeline", "Loading timeline...");
    }}

    function renderOnlineActivityError(message) {{
      setMapDataMode("activity");
      historyTrendCharts.online.points = [];
      resetHistoryTrendZoom(historyTrendCharts.online);
      const caption = document.getElementById("online-activity-caption");
      if (caption) {{
        caption.textContent = `Online activity error: ${{message || "unknown error"}}`;
      }}
      const overview = document.getElementById("online-activity-overview");
      if (overview) {{
        overview.innerHTML = "";
      }}
      const svg = document.getElementById("online-activity-chart");
      if (svg instanceof SVGElement) {{
        svg.innerHTML = "";
        svg.classList.remove("zoomed", "chart-dragging");
      }}
      const empty = document.getElementById("online-activity-empty");
      if (empty) {{
        empty.hidden = false;
        empty.textContent = "Unable to load online-activity history.";
      }}
      setTimelineMessage("online-activity-timeline", "Timeline unavailable due to online-activity error.");
    }}

    function renderOnlineActivityChart(points) {{
      const svg = document.getElementById("online-activity-chart");
      const empty = document.getElementById("online-activity-empty");
      if (!(svg instanceof SVGElement) || !(empty instanceof HTMLElement)) return;

      const chartState = historyTrendCharts.online;
      bindHistoryTrendChartZoom(
        chartState,
        () => rerenderOnlineActivityChartFromCache(),
        "Online activity chart"
      );

      const rows = Array.isArray(points) ? points : [];
      chartState.points = rows;
      const visible = getVisibleHistoryTrendRows(chartState, rows);
      const plotRows = visible.rows;
      setHistoryTrendChartTitle(svg, "Online activity chart", visible.zoomed);

      const values = plotRows.map((p) => Number(p.online_nodes)).filter((v) => Number.isFinite(v));
      if (values.length === 0) {{
        svg.innerHTML = "";
        empty.hidden = false;
        empty.textContent = "No historical online-activity points yet.";
        renderTimeline(
          chartState.timelineId,
          plotRows,
          historyTrendChartLayout.padLeft,
          historyTrendChartLayout.padRight,
          historyTrendChartLayout.width,
          (row) => timelinePointUnix(row, "bucket_unix", ["bucket_local", "bucket_time"])
        );
        return;
      }}
      empty.hidden = true;

      const width = historyTrendChartLayout.width;
      const height = historyTrendChartLayout.height;
      const padLeft = historyTrendChartLayout.padLeft;
      const padRight = historyTrendChartLayout.padRight;
      const padTop = historyTrendChartLayout.padTop;
      const padBottom = historyTrendChartLayout.padBottom;
      const plotW = width - padLeft - padRight;
      const plotH = height - padTop - padBottom;

      let minVal = Math.min(0, ...values);
      let maxVal = Math.max(...values);
      if ((maxVal - minVal) < 1) {{
        maxVal = minVal + 1;
      }}

      const xAt = (idx, total) => (
        padLeft + ((Math.max(0, idx) / Math.max(1, total - 1)) * plotW)
      );
      const yFrom = (value, minValue, maxValue) => (
        padTop + ((maxValue - value) / (maxValue - minValue)) * plotH
      );

      const n = plotRows.length;
      const pointsXY = [];
      for (let i = 0; i < n; i += 1) {{
        const raw = Number(plotRows[i].online_nodes);
        if (!Number.isFinite(raw)) continue;
        pointsXY.push({{
          x: xAt(i, n),
          y: yFrom(raw, minVal, maxVal),
        }});
      }}
      if (!pointsXY.length) {{
        svg.innerHTML = "";
        empty.hidden = false;
        empty.textContent = "No historical online-activity points yet.";
        renderTimeline(
          chartState.timelineId,
          plotRows,
          padLeft,
          padRight,
          width,
          (row) => timelinePointUnix(row, "bucket_unix", ["bucket_local", "bucket_time"])
        );
        return;
      }}

      const path = pointsXY.map((pt, idx) => (
        `${{idx === 0 ? "M" : "L"}} ${{pt.x.toFixed(2)}} ${{pt.y.toFixed(2)}}`
      )).join(" ");

      const chartPalette = historyChartPalette();

      const axisTicks = buildLinearAxisTicks(minVal, maxVal, 5);
      const axisLines = axisTicks.map((tick) => {{
        const y = padTop + (tick.ratio * plotH);
        return `<line x1="${{padLeft}}" y1="${{y.toFixed(2)}}" x2="${{width - padRight}}" y2="${{y.toFixed(2)}}" stroke="${{chartPalette.grid}}" stroke-width="1"></line>`;
      }}).join("");
      const axisLabels = axisTicks.map((tick) => {{
        const y = padTop + (tick.ratio * plotH);
        return `<text x="${{padLeft - 4}}" y="${{(y + 4).toFixed(2)}}" font-size="10" text-anchor="end" fill="${{chartPalette.label}}">${{formatMetricValue(tick.value, 0)}}</text>`;
      }}).join("");

      svg.setAttribute("viewBox", `0 0 ${{width}} ${{height}}`);
      svg.innerHTML = `
        <rect x="0" y="0" width="${{width}}" height="${{height}}" fill="none"></rect>
        <line x1="${{padLeft}}" y1="${{padTop}}" x2="${{padLeft}}" y2="${{height - padBottom}}" stroke="${{chartPalette.grid}}" stroke-width="1"></line>
        ${{axisLines}}
        <path d="${{path}}" fill="none" stroke="${{chartPalette.line}}" stroke-width="2.3"></path>
        ${{axisLabels}}
      `;
      renderTimeline(
        chartState.timelineId,
        plotRows,
        padLeft,
        padRight,
        width,
        (row) => timelinePointUnix(row, "bucket_unix", ["bucket_local", "bucket_time"])
      );
    }}

    function renderOnlineActivityOverview(activity) {{
      const summary = activity.summary || {{}};
      const target = document.getElementById("online-activity-overview");
      if (!target) return;
      const profile = Array.isArray(activity.hourly_profile) ? activity.hourly_profile : [];
      const topHours = profile
        .filter((row) => Number.isFinite(Number(row.avg_online_nodes)))
        .sort((a, b) => Number(b.avg_online_nodes) - Number(a.avg_online_nodes))
        .slice(0, 3);
      const topHoursText = topHours.length
        ? topHours.map((row) => `${{row.label}} (${{formatMetricValue(row.avg_online_nodes, 1)}})`).join(", ")
        : "n/a";
      const bestHourLabel = summary.best_hour_label || "n/a";
      const bestHourAvgText = Number.isFinite(Number(summary.best_hour_avg_online_nodes))
        ? ` (${{formatMetricValue(summary.best_hour_avg_online_nodes, 1)}} avg)`
        : "";
      const items = [
        ["Window", `${{activity.window_hours ?? nodeHistoryHours}}h (${{activity.timezone_label || "local"}})`],
        ["Samples", `${{summary.sample_hours ?? (activity.points || []).length ?? 0}}`],
        ["Distinct Nodes", `${{summary.distinct_nodes ?? 0}}`],
        ["Peak Online", `${{summary.max_online_nodes ?? 0}}`],
        ["Average Online", `${{formatMetricValue(summary.avg_online_nodes, 1)}}`],
        ["Best Hour", `${{bestHourLabel}}${{bestHourAvgText}}`],
        ["Top Hours", `${{topHoursText}}`],
        ["Range", `${{summary.window_start || "n/a"}} to ${{summary.window_end || "n/a"}}`],
      ];
      target.innerHTML = items.map(([k, v]) => (
        `<div class="overview-item"><div class="k">${{k}}</div><div class="v">${{v}}</div></div>`
      )).join("");
    }}

    function renderOnlineActivity(activity) {{
      setMapDataMode("activity");
      const summary = activity.summary || {{}};
      const bestHourLabel = summary.best_hour_label || null;
      const bestHourAvgText = Number.isFinite(Number(summary.best_hour_avg_online_nodes))
        ? `${{formatMetricValue(summary.best_hour_avg_online_nodes, 1)}} avg nodes`
        : "n/a avg nodes";
      const caption = document.getElementById("online-activity-caption");
      if (caption) {{
        if (bestHourLabel) {{
          caption.textContent = `Last ${{activity.window_hours || nodeHistoryHours}}h. Most common online time: ${{bestHourLabel}} (${{activity.timezone_label || "local"}}), ${{bestHourAvgText}}.`;
        }} else {{
          caption.textContent = `Last ${{activity.window_hours || nodeHistoryHours}}h. No saved online-activity history yet.`;
        }}
      }}
      renderOnlineActivityChart(activity.points || []);
      renderOnlineActivityOverview(activity);
    }}
