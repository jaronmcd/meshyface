    function applyServerBotSettingsFromState(_state = latestState) {{
      serverBotSettings = normalizeServerBotSettings();
      return serverBotSettings;
    }}

    function hardDisableIncomingAutomationAndFileTransferEnabled() {{
      return false;
    }}

    const zorkBotEndpoint = "/api/bots/zork";
    const zorkBotCommandHeads = new Set([
      "zork", "look", "l", "inventory", "inv", "i", "n", "s", "e", "w", "u", "d",
      "north", "south", "east", "west", "up", "down", "open", "close", "take",
      "get", "drop", "read", "examine", "x", "enter", "exit", "climb", "move",
      "push", "pull", "turn", "attack", "kill", "score", "help", "restart",
    ]);
    let zorkBotToggleInFlight = false;

    function zorkBotRuntimeFromState(state = latestState) {{
      const safeState = (state && typeof state === "object") ? state : {{}};
      const summary = (safeState.summary && typeof safeState.summary === "object")
        ? safeState.summary
        : {{}};
      const bots = (summary.bots && typeof summary.bots === "object")
        ? summary.bots
        : ((safeState.bots && typeof safeState.bots === "object") ? safeState.bots : {{}});
      const zork = (bots.zork && typeof bots.zork === "object") ? bots.zork : {{}};
      const hasRuntimePayload = Object.prototype.hasOwnProperty.call(bots, "zork");
      const hasEnabled = Object.prototype.hasOwnProperty.call(zork, "enabled");
      const enabled = hasEnabled ? !!zork.enabled : !!zorkFeatureEnabled;
      const sessions = Array.isArray(zork.sessions) ? zork.sessions : [];
      const rawSessions = Number(zork.active_session_count ?? zork.activeSessionCount ?? 0);
      const available = Object.prototype.hasOwnProperty.call(bots, "available")
        ? !!bots.available
        : (hasRuntimePayload || !!zorkFeatureEnabled);
      return {{
        available,
        enabled,
        activeSessionCount: Number.isFinite(rawSessions) ? Math.max(0, Math.floor(rawSessions)) : sessions.length,
        sessions,
        publicStartEnabled: !!(zork.public_start_enabled ?? zork.publicStartEnabled ?? enabled),
        directMessageEnabled: !!(zork.direct_message_enabled ?? zork.directMessageEnabled ?? enabled),
      }};
    }}

    function setZorkBotStatusClass(element, enabled) {{
      if (!(element instanceof HTMLElement)) return;
      element.classList.toggle("is-enabled", !!enabled);
      element.classList.toggle("is-disabled", !enabled);
      element.textContent = enabled ? "Enabled" : "Disabled";
    }}

    function setZorkBotToggleStatus(message, isError = false) {{
      const status = document.getElementById("bots-zork-toggle-status");
      if (!(status instanceof HTMLElement)) return;
      status.textContent = String(message || "");
      status.classList.toggle("is-error", !!isError);
    }}

    function zorkBotChatField(row, keys, fallback = "") {{
      if (!row || typeof row !== "object") return fallback;
      for (const key of keys) {{
        const value = row[key];
        if (value !== undefined && value !== null && String(value).trim() !== "") {{
          return value;
        }}
      }}
      return fallback;
    }}

    function zorkBotMessageId(row, keys) {{
      const raw = zorkBotChatField(row, keys, null);
      const parsed = Number(raw);
      return Number.isFinite(parsed) && parsed > 0 ? Math.floor(parsed) : null;
    }}

    function zorkBotTextHead(text) {{
      const clean = String(text || "").trim().toLowerCase();
      if (!clean) return "";
      return clean.split(/\s+/, 1)[0] || "";
    }}

    function isZorkBotCommandText(text) {{
      return zorkBotCommandHeads.has(zorkBotTextHead(text));
    }}

    function isZorkBotResponseText(text) {{
      const clean = String(text || "").trim();
      const body = clean.replace(/^\[(\d+)\/(\d+)\]\s*/i, "");
      return /^zork:/i.test(body);
    }}

    function zorkBotNodeLabel(nodeId, state = latestState) {{
      const clean = normalizeNodeId(nodeId || "");
      if (!clean) return "unknown";
      const safeState = (state && typeof state === "object") ? state : {{}};
      const nodes = Array.isArray(safeState.nodes) ? safeState.nodes : [];
      const node = nodes.find((entry) => normalizeNodeId(entry && entry.id) === clean) || null;
      const preferred = typeof preferredNodeName === "function" ? preferredNodeName(node) : "";
      return preferred || nodeNameCache.get(clean) || clean;
    }}

    function zorkBotRowTime(row, nowUnix) {{
      const rawTime = String(zorkBotChatField(row, ["rx_time", "captured_at", "time"], "") || "").trim();
      const unix = latestUnixTimestamp(row && row.rx_time, row && row.captured_at, row && row.time);
      return formatLocalChatTime(unix, rawTime || "n/a", nowUnix);
    }}

    function buildZorkBotActivity(state = latestState) {{
      const safeState = (state && typeof state === "object") ? state : {{}};
      const traffic = (safeState.traffic && typeof safeState.traffic === "object") ? safeState.traffic : {{}};
      const rows = Array.isArray(traffic.recent_chat) ? traffic.recent_chat : [];
      const localId = normalizeNodeId(resolveLocalNodeId(safeState) || safeState.local_node_id || "");
      const requests = [];
      const requestByMessageId = new Map();
      const repliesByRequestId = new Map();
      const orphanReplies = [];

      const addReply = (replyId, reply) => {{
        if (replyId === null) {{
          if (isZorkBotResponseText(reply.text)) orphanReplies.push(reply);
          return;
        }}
        if (!repliesByRequestId.has(replyId)) {{
          repliesByRequestId.set(replyId, []);
        }}
        repliesByRequestId.get(replyId).push(reply);
      }};

      rows.forEach((row, index) => {{
        if (!row || typeof row !== "object") return;
        const text = String(zorkBotChatField(row, ["text", "payload", "message"], "") || "").trim();
        if (!text) return;
        const from = normalizeNodeId(zorkBotChatField(row, ["from", "from_id", "fromId", "source", "source_id", "sourceId"], ""));
        const to = normalizeNodeId(zorkBotChatField(row, ["to", "to_id", "toId", "destination", "dest", "dest_id", "destId"], "^all"));
        const messageId = zorkBotMessageId(row, ["message_id", "messageId", "packet_id", "packetId", "id"]);
        const replyId = zorkBotMessageId(row, ["reply_id", "replyId"]);
        const fromLocal = !!localId && from === localId;
        const toLocal = !!localId && to === localId;
        const toAll = to === "^all";
        const isCommand = isZorkBotCommandText(text) && (toLocal || toAll);
        const item = {{
          row,
          index,
          text,
          from,
          to,
          messageId,
          replyId,
          timeUnix: latestUnixTimestamp(row.rx_time, row.captured_at, row.time),
        }};
        if (isCommand && (!fromLocal || toLocal)) {{
          requests.push(item);
          if (messageId !== null) requestByMessageId.set(messageId, item);
          return;
        }}
        if (fromLocal && replyId !== null) {{
          addReply(replyId, item);
          return;
        }}
        if (fromLocal && isZorkBotResponseText(text)) {{
          orphanReplies.push(item);
        }}
      }});

      const activities = requests.map((request) => {{
        const replies = request.messageId !== null
          ? (repliesByRequestId.get(request.messageId) || [])
          : [];
        const latestReplyUnix = replies.reduce((maxValue, reply) => Math.max(maxValue, Number(reply.timeUnix || 0)), 0);
        return {{
          request,
          replies,
          status: replies.length > 0 ? "responded" : "pending",
          sortUnix: Math.max(Number(request.timeUnix || 0), latestReplyUnix),
        }};
      }});

      repliesByRequestId.forEach((replies, replyId) => {{
        if (requestByMessageId.has(replyId)) return;
        if (!Array.isArray(replies) || replies.length <= 0) return;
        const latestReplyUnix = replies.reduce((maxValue, reply) => Math.max(maxValue, Number(reply.timeUnix || 0)), 0);
        activities.push({{
          request: null,
          replies,
          status: "responded",
          sortUnix: latestReplyUnix,
        }});
      }});

      orphanReplies.forEach((reply) => {{
        activities.push({{
          request: null,
          replies: [reply],
          status: "responded",
          sortUnix: Number(reply.timeUnix || 0),
        }});
      }});

      activities.sort((a, b) => {{
        const timeDiff = Number(b.sortUnix || 0) - Number(a.sortUnix || 0);
        if (timeDiff) return timeDiff;
        const aIndex = a.request ? a.request.index : ((a.replies[0] && a.replies[0].index) || 0);
        const bIndex = b.request ? b.request.index : ((b.replies[0] && b.replies[0].index) || 0);
        return bIndex - aIndex;
      }});
      const replyCount = Array.from(repliesByRequestId.values()).reduce((total, replies) => total + replies.length, 0) + orphanReplies.length;
      return {{
        activities: activities.slice(0, 24),
        requestCount: requests.length,
        replyCount,
      }};
    }}

    function botTickerAvailableForState(state = latestState) {{
      const runtime = zorkBotRuntimeFromState(state);
      return !!(runtime && runtime.available && runtime.enabled);
    }}

    function buildBotTickerSummary(state = latestState) {{
      const runtime = zorkBotRuntimeFromState(state);
      const activity = buildZorkBotActivity(state);
      const sessions = Array.isArray(runtime.sessions) ? runtime.sessions : [];
      const activeSessionCount = Math.max(
        0,
        Math.trunc(Number(runtime.activeSessionCount) || sessions.length || 0)
      );
      const requestCount = Math.max(0, Math.trunc(Number(activity.requestCount) || 0));
      const replyCount = Math.max(0, Math.trunc(Number(activity.replyCount) || 0));
      const pendingCount = (Array.isArray(activity.activities) ? activity.activities : [])
        .filter((entry) => entry && entry.status !== "responded")
        .length;
      const nowUnix = Math.floor(Date.now() / 1000);
      const latestActivity = (Array.isArray(activity.activities) ? activity.activities : [])[0] || null;
      const lastUnix = Math.max(
        Number(latestActivity && latestActivity.sortUnix) || 0,
        ...sessions.map((session) => zorkBotSessionUnix(session, "updated_unix"))
      );
      const lastAge = lastUnix > 0
        ? (typeof formatIdleAge === "function" ? formatIdleAge(lastUnix, nowUnix) : formatLocalChatTime(lastUnix, "n/a", nowUnix))
        : "none";
      const sessionLabels = sessions.slice(0, 2).map((session) => {{
        const peerId = normalizeNodeId(session && (session.peer_id || session.peerId || "")) || "";
        const peerLabel = zorkBotNodeLabel(peerId, state);
        const roomName = String((session && (session.room_name || session.roomName || session.room)) || "").trim();
        return roomName ? `${{peerLabel}} · ${{roomName}}` : peerLabel;
      }}).filter(Boolean);
      const sessionMoreCount = Math.max(0, sessions.length - sessionLabels.length);
      const sessionValue = activeSessionCount > 0
        ? `${{activeSessionCount}} active`
        : "0 active";
      const activityValue = `${{requestCount}} / ${{replyCount}}`;
      const rows = [
        {{ key: "Zork", value: "On" }},
        {{ key: "Sess", value: sessionValue }},
      ];
      if (sessionLabels.length > 0) {{
        rows.push({{
          key: "Now",
          value: `${{sessionLabels.join(", ")}}${{sessionMoreCount > 0 ? ` +${{sessionMoreCount}}` : ""}}`,
        }});
      }}
      rows.push({{ key: "Req/Rep", value: activityValue }});
      if (pendingCount > 0) {{
        rows.push({{ key: "Wait", value: String(pendingCount) }});
      }}
      rows.push({{ key: "Last", value: lastAge }});
      const rowsHtml = rows
        .map((row) => `<div class="node-ticker-row bot-ticker-row"><span class="node-ticker-key">${{escAttr(row.key)}}:</span><span class="node-ticker-val">${{escAttr(row.value)}}</span></div>`)
        .join("");
      const titleParts = [
        "Zork bot enabled",
        `${{activeSessionCount}} active session${{activeSessionCount === 1 ? "" : "s"}}`,
        `${{requestCount}} request${{requestCount === 1 ? "" : "s"}}`,
        `${{replyCount}} repl${{replyCount === 1 ? "y" : "ies"}}`,
        pendingCount > 0 ? `${{pendingCount}} pending` : "0 pending",
        `last ${{lastAge}}`,
        "Click to open Bots",
      ];
      return {{
        available: !!runtime.available,
        enabled: !!runtime.enabled,
        activeSessionCount,
        requestCount,
        replyCount,
        pendingCount,
        text: activeSessionCount > 0
          ? `${{activeSessionCount}} session${{activeSessionCount === 1 ? "" : "s"}}`
          : `${{replyCount}} repl${{replyCount === 1 ? "y" : "ies"}}`,
        rows_html: rowsHtml,
        title: titleParts.join(" | "),
      }};
    }}

    function renderBotTickerSummary(state = latestState) {{
      const tickerEl = document.getElementById("m-bots-ticker");
      const tickerItem = document.getElementById("summary-ticker-bots");
      if (!(tickerEl instanceof HTMLElement)) return;
      const summary = buildBotTickerSummary(state);
      const canShow = !!summary.available && !!summary.enabled;
      if (tickerItem instanceof HTMLElement) {{
        tickerItem.classList.toggle("has-active-bot-sessions", summary.activeSessionCount > 0);
        tickerItem.classList.toggle("has-pending-bot-activity", summary.pendingCount > 0);
      }}
      if (!canShow) {{
        updateSummaryMiniPanel("m-bots-ticker", tickerEl, {{
          mode: "text",
          text: "n/a",
          title: "Bot runtime disabled",
        }});
        return;
      }}
      updateSummaryMiniPanel("m-bots-ticker", tickerEl, {{
        mode: summary.rows_html ? "html" : "text",
        html: summary.rows_html,
        text: summary.text,
        title: summary.title,
      }});
    }}

    function renderZorkBotActivity(state, runtime) {{
      const stats = document.getElementById("bots-zork-activity-stats");
      const list = document.getElementById("bots-zork-activity-list");
      if (!(stats instanceof HTMLElement) || !(list instanceof HTMLElement)) return;
      const nowUnix = Math.floor(Date.now() / 1000);
      const activity = buildZorkBotActivity(state);
      const last = activity.activities[0] || null;
      const lastTime = last
        ? formatLocalChatTime(Number(last.sortUnix || 0), "recent", nowUnix)
        : "none";
      stats.innerHTML = [
        `<span>Requests ${{activity.requestCount}}</span>`,
        `<span>Replies ${{activity.replyCount}}</span>`,
        `<span>Sessions ${{runtime.activeSessionCount}}</span>`,
        `<span>Last ${{escAttr(lastTime)}}</span>`,
      ].join("");

      if (activity.activities.length <= 0) {{
        list.innerHTML = '<div class="bots-history-empty">No Zork activity in the current chat window yet.</div>';
        return;
      }}

      list.innerHTML = activity.activities.map((entry) => {{
        const request = entry.request;
        const replies = Array.isArray(entry.replies) ? entry.replies : [];
        const statusClass = entry.status === "responded" ? "responded" : "pending";
        const statusLabel = entry.status === "responded" ? "Responded" : "Waiting";
        const commandText = request ? request.text : "(request outside current buffer)";
        const peerId = request ? request.from : ((replies[0] && replies[0].to) || "");
        const route = request
          ? `${{zorkBotNodeLabel(request.from, state)}} -> ${{request.to === "^all" ? "public" : "bot"}}`
          : "reply only";
        const requestTime = request ? zorkBotRowTime(request.row, nowUnix) : zorkBotRowTime(replies[0] && replies[0].row, nowUnix);
        const responseText = replies
          .slice(0, 4)
          .map((reply) => reply.text)
          .join("\\n");
        const moreText = replies.length > 4 ? `\\n+${{replies.length - 4}} more part(s)` : "";
        const responseHtml = responseText
          ? `<div class="bots-history-response"><strong>bot to ${{escAttr(zorkBotNodeLabel(peerId, state))}}</strong> ${{escAttr(responseText + moreText)}}</div>`
          : '<div class="bots-history-response">No reply has been recorded yet.</div>';
        return `
          <div class="bots-history-item">
            <div class="bots-history-item-head">
              <div class="bots-history-command">${{escAttr(commandText)}}</div>
              <span class="bots-history-status-pill ${{statusClass}}">${{statusLabel}}</span>
            </div>
            <div class="bots-history-meta"><span>${{escAttr(route)}}</span><span>${{escAttr(requestTime)}}</span></div>
            ${{responseHtml}}
          </div>
        `;
      }}).join("");
    }}

    function zorkBotSessionUnix(session, key) {{
      if (!session || typeof session !== "object") return 0;
      const camelKey = key.replace(/_([a-z])/g, (_match, ch) => String(ch || "").toUpperCase());
      const value = Number(session[key] ?? session[camelKey] ?? 0);
      return Number.isFinite(value) ? Math.max(0, Math.floor(value)) : 0;
    }}

    function renderZorkBotSessions(state, runtime) {{
      const list = document.getElementById("bots-zork-session-list");
      const clearBtn = document.getElementById("bots-zork-clear-sessions-btn");
      if (!(list instanceof HTMLElement)) return;
      const sessions = Array.isArray(runtime.sessions) ? runtime.sessions : [];
      if (clearBtn instanceof HTMLButtonElement) {{
        clearBtn.disabled = zorkBotToggleInFlight || !runtime.enabled || sessions.length <= 0;
      }}
      if (sessions.length <= 0) {{
        list.innerHTML = '<div class="bots-history-empty">No active Zork sessions.</div>';
        return;
      }}
      const nowUnix = Math.floor(Date.now() / 1000);
      list.innerHTML = sessions.map((session) => {{
        const peerId = normalizeNodeId(session && (session.peer_id || session.peerId || "")) || "";
        const roomName = String((session && (session.room_name || session.roomName || session.room)) || "Unknown room");
        const moves = Number(session && session.moves);
        const moveText = Number.isFinite(moves) ? Math.max(0, Math.floor(moves)) : 0;
        const inventoryCount = Number(session && (session.inventory_count ?? session.inventoryCount));
        const inventoryText = Number.isFinite(inventoryCount) ? Math.max(0, Math.floor(inventoryCount)) : 0;
        const updatedUnix = zorkBotSessionUnix(session, "updated_unix");
        const expiresUnix = zorkBotSessionUnix(session, "expires_unix");
        const updatedText = formatLocalChatTime(updatedUnix, "n/a", nowUnix);
        const expiresText = expiresUnix > 0
          ? formatLocalChatTime(expiresUnix, "n/a", nowUnix)
          : "n/a";
        return `
          <div class="bots-session-item">
            <div class="bots-session-main">
              <div class="bots-session-peer">${{escAttr(zorkBotNodeLabel(peerId, state))}}</div>
              <div class="bots-session-meta">
                <span>${{escAttr(roomName)}}</span>
                <span>${{moveText}} moves</span>
                <span>${{inventoryText}} carried</span>
                <span>last ${{escAttr(updatedText)}}</span>
