        zorkBotToggleInFlight = false;
        renderBotsView(latestState);
      }}
    }}

    async function manageZorkBotFromUi(action, peerId = "") {{
      if (zorkBotToggleInFlight) return;
      zorkBotToggleInFlight = true;
