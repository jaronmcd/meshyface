    function zorkBotActivityResetCutoffUnix() {{
      try {{
        const raw = window.localStorage.getItem(zorkBotActivityResetStorageKey);
        const parsed = Number(raw);
        return Number.isFinite(parsed) && parsed > 0 ? Math.floor(parsed) : 0;
      }} catch (_err) {{
        return 0;
      }}
    }}

    function setZorkBotActivityResetCutoffUnix(value) {{
      const clean = Math.max(0, Math.floor(Number(value) || 0));
      try {{
        if (clean > 0) {{
          window.localStorage.setItem(zorkBotActivityResetStorageKey, String(clean));
        }} else {{
          window.localStorage.removeItem(zorkBotActivityResetStorageKey);
        }}
      }} catch (_err) {{
      }}
      return clean;
    }}

    function botRuntimeFromState(command, state = latestState) {{
      const selectedCommand = normalizeBotCatalogCommand(command);
      const safeState = (state && typeof state === "object") ? state : {{}};
      const summary = (safeState.summary && typeof safeState.summary === "object")
        ? safeState.summary
        : {{}};
      const bots = (summary.bots && typeof summary.bots === "object")
        ? summary.bots
        : ((safeState.bots && typeof safeState.bots === "object") ? safeState.bots : {{}});
      const runtimePayload = (bots[selectedCommand] && typeof bots[selectedCommand] === "object")
        ? bots[selectedCommand]
        : {{}};
      const hasRuntimePayload = Object.prototype.hasOwnProperty.call(bots, selectedCommand);
      const hasEnabled = Object.prototype.hasOwnProperty.call(runtimePayload, "enabled");
      const defaultEnabled = selectedCommand === "zork" ? !!gamesFeatureEnabled : false;
      const enabled = hasEnabled ? !!runtimePayload.enabled : defaultEnabled;
      const explicitPublicStart = runtimePayload.public_start_enabled ?? runtimePayload.publicStartEnabled;
      const explicitMessageOnly = runtimePayload.message_only ?? runtimePayload.messageOnly;
      const computedPublicStartEnabled = explicitPublicStart != null
        ? !!explicitPublicStart
        : enabled;
      const messageOnly = selectedCommand === "ping"
        ? (explicitMessageOnly != null ? !!explicitMessageOnly : !computedPublicStartEnabled)
        : false;
      const publicStartEnabled = selectedCommand === "ping"
        ? !messageOnly
        : computedPublicStartEnabled;
      const sessions = Array.isArray(runtimePayload.sessions) ? runtimePayload.sessions : [];
      const rawSessions = Number(runtimePayload.active_session_count ?? runtimePayload.activeSessionCount ?? 0);
      const available = Object.prototype.hasOwnProperty.call(bots, "available")
        ? !!bots.available
        : (hasRuntimePayload || (selectedCommand === "zork" && !!gamesFeatureEnabled));
      return {{
        available,
        enabled,
        activeSessionCount: Number.isFinite(rawSessions) ? Math.max(0, Math.floor(rawSessions)) : sessions.length,
        sessions,
        publicStartEnabled: !!publicStartEnabled,
        directMessageEnabled: !!(runtimePayload.direct_message_enabled ?? runtimePayload.directMessageEnabled ?? enabled),
        messageOnly: !!messageOnly,
      }};
    }}

    function zorkBotRuntimeFromState(state = latestState) {{
      return botRuntimeFromState("zork", state);
    }}

    function setZorkBotStatusClass(element, enabled) {{
      if (!(element instanceof HTMLElement)) return;
      element.classList.toggle("is-enabled", !!enabled);
      element.classList.toggle("is-disabled", !enabled);
      element.textContent = enabled ? "Enabled" : "Disabled";
    }}

    function setZorkBotToggleStatus(message, isError = false) {{
      const status = document.getElementById("bots-zork-toggle-status");
      if (!(status instanceof HTMLElement)) return;
      status.textContent = String(message || "");
      status.classList.toggle("is-error", !!isError);
    }}

    function zorkBotChatField(row, keys, fallback = "") {{
      if (!row || typeof row !== "object") return fallback;
      for (const key of keys) {{
        const value = row[key];
        if (value !== undefined && value !== null && String(value).trim() !== "") {{
          return value;
        }}
      }}
      return fallback;
    }}

    function zorkBotMessageId(row, keys) {{
      const raw = zorkBotChatField(row, keys, null);
      const parsed = Number(raw);
      return Number.isFinite(parsed) && parsed > 0 ? Math.floor(parsed) : null;
    }}

    function zorkBotTextHead(text) {{
      const clean = String(text || "").trim().toLowerCase();
      if (!clean) return "";
      return clean.split(/\s+/, 1)[0] || "";
    }}

    function botPublicStartHeads(command) {{
      return botPublicStartHeadsByCommand[normalizeBotCatalogCommand(command)] || botPublicStartHeadsByCommand.zork;
    }}

    function isBotPublicStartText(command, text) {{
      const clean = String(text || "").trim().toLowerCase();
      if (!clean) return false;
      if (normalizeBotCatalogCommand(command) === "ping") {{
        const head = zorkBotTextHead(clean);
        return clean === "can you see this" || clean === "can you see this?" || head === "ping" || head === "test";
      }}
      return botPublicStartHeads(command).has(clean);
    }}

    function isZorkBotCommandText(text) {{
      return zorkBotCommandHeads.has(zorkBotTextHead(text));
    }}

    function isZorkBotPublicStartText(text) {{
      return isBotPublicStartText("zork", text);
    }}

    function botCommandFromActivityRow(row) {{
      const raw = zorkBotChatField(row, ["bot_command", "botCommand", "command_name", "commandName"], "");
      const clean = String(raw || "").trim().toLowerCase();
      return Object.prototype.hasOwnProperty.call(botCatalogSpecs, clean) ? clean : "";
    }}

    function botResponseCommandFromText(text) {{
      const clean = String(text || "").trim().replace(/^\[(\d+)\/(\d+)\]\s*/i, "");
      if (/^zork:/i.test(clean)) return "zork";
      return "";
    }}

    function isZorkBotResponseText(text) {{
      return botResponseCommandFromText(text) === "zork";
    }}

    function botSessionPeerSet(runtime) {{
      const peers = new Set();
      const sessions = Array.isArray(runtime && runtime.sessions) ? runtime.sessions : [];
      for (const session of sessions) {{
        const peerId = normalizeNodeId(session && (session.peer_id || session.peerId || ""));
        if (peerId) peers.add(peerId);
      }}
      return peers;
    }}

    function zorkBotNodeLabel(nodeId, state = latestState) {{
      const clean = normalizeNodeId(nodeId || "");
      if (!clean) return "unknown";
      const safeState = (state && typeof state === "object") ? state : {{}};
      const nodes = Array.isArray(safeState.nodes) ? safeState.nodes : [];
      const node = nodes.find((entry) => normalizeNodeId(entry && entry.id) === clean) || null;
      const preferred = typeof preferredNodeName === "function" ? preferredNodeName(node) : "";
      return preferred || nodeNameCache.get(clean) || clean;
    }}

    function zorkBotRowTime(row, nowUnix) {{
      const rawTime = String(zorkBotChatField(row, ["rx_time", "captured_at", "time"], "") || "").trim();
      const unix = latestUnixTimestamp(row && row.rx_time, row && row.captured_at, row && row.time);
      return formatLocalChatTime(unix, rawTime || "n/a", nowUnix);
    }}

    function buildBotActivity(command = "zork", state = latestState, runtime = null) {{
      const selectedCommand = normalizeBotCatalogCommand(command);
      const safeState = (state && typeof state === "object") ? state : {{}};
      const traffic = (safeState.traffic && typeof safeState.traffic === "object") ? safeState.traffic : {{}};
      const rows = Array.isArray(traffic.recent_chat) ? traffic.recent_chat : [];
      const selectedRuntime = (runtime && typeof runtime === "object")
        ? runtime
        : botRuntimeFromState(selectedCommand, safeState);
      const publicStartEnabled = !!(selectedRuntime.publicStartEnabled ?? true);
      const sessionPeers = botSessionPeerSet(selectedRuntime);
      const localId = normalizeNodeId(resolveLocalNodeId(safeState) || safeState.local_node_id || "");
      const resetCutoffUnix = zorkBotActivityResetCutoffUnix();
      const items = [];
      const repliesByRequestId = new Map();
      const orphanReplies = [];

      const addReply = (replyId, reply) => {{
        if (replyId === null) {{
          orphanReplies.push(reply);
          return;
        }}
        if (!repliesByRequestId.has(replyId)) {{
          repliesByRequestId.set(replyId, []);
        }}
        repliesByRequestId.get(replyId).push(reply);
      }};

      rows.forEach((row, index) => {{
        if (!row || typeof row !== "object") return;
        const text = String(zorkBotChatField(row, ["text", "payload", "message"], "") || "").trim();
        if (!text) return;
        const from = normalizeNodeId(zorkBotChatField(row, ["from", "from_id", "fromId", "source", "source_id", "sourceId"], ""));
        const to = normalizeNodeId(zorkBotChatField(row, ["to", "to_id", "toId", "destination", "dest", "dest_id", "destId"], "^all"));
        const messageId = zorkBotMessageId(row, ["message_id", "messageId", "packet_id", "packetId", "id"]);
        const replyId = zorkBotMessageId(row, ["reply_id", "replyId"]);
        const timeUnix = latestUnixTimestamp(row.rx_time, row.captured_at, row.time);
        if (resetCutoffUnix > 0 && timeUnix > 0 && timeUnix <= resetCutoffUnix) return;
        const fromLocal = !!localId && from === localId;
        const toLocal = !!localId && to === localId;
        const toAll = to === "^all";
        items.push({{
          row,
          index,
          text,
          from,
          to,
          messageId,
          replyId,
          timeUnix,
          fromLocal,
          toLocal,
          toAll,
          botCommand: botCommandFromActivityRow(row),
        }});
      }});

      items.forEach((item) => {{
        if (!item.fromLocal) return;
        let replyCommand = item.botCommand || botResponseCommandFromText(item.text);
        if (!replyCommand && sessionPeers.has(item.to)) {{
          replyCommand = selectedCommand;
        }}
        if (replyCommand !== selectedCommand) return;
        addReply(item.replyId, item);
      }});

      const requests = [];
      const requestByMessageId = new Map();
      items.forEach((item) => {{
        if (item.fromLocal) return;
        const linkedReplies = item.messageId !== null
          ? (repliesByRequestId.get(item.messageId) || [])
          : [];
        const isPublicStart = publicStartEnabled && item.toAll && isBotPublicStartText(selectedCommand, item.text);
        const isDirectStart = item.toLocal && isBotPublicStartText(selectedCommand, item.text);
        const isDirectSessionCommand = item.toLocal && (linkedReplies.length > 0 || sessionPeers.has(item.from));
        const isCommand = isPublicStart || isDirectStart || isDirectSessionCommand;
        if (isCommand) {{
          requests.push(item);
          if (item.messageId !== null) requestByMessageId.set(item.messageId, item);
        }}
      }});

      const activities = requests.map((request) => {{
        const replies = request.messageId !== null
          ? (repliesByRequestId.get(request.messageId) || [])
          : [];
        const latestReplyUnix = replies.reduce((maxValue, reply) => Math.max(maxValue, Number(reply.timeUnix || 0)), 0);
        return {{
          request,
          replies,
          status: replies.length > 0 ? "responded" : "pending",
          sortUnix: Math.max(Number(request.timeUnix || 0), latestReplyUnix),
        }};
      }});

      repliesByRequestId.forEach((replies, replyId) => {{
        if (requestByMessageId.has(replyId)) return;
        if (!Array.isArray(replies) || replies.length <= 0) return;
        const latestReplyUnix = replies.reduce((maxValue, reply) => Math.max(maxValue, Number(reply.timeUnix || 0)), 0);
        activities.push({{
          request: null,
          replies,
          status: "responded",
          sortUnix: latestReplyUnix,
        }});
      }});

      orphanReplies.forEach((reply) => {{
        activities.push({{
          request: null,
          replies: [reply],
          status: "responded",
          sortUnix: Number(reply.timeUnix || 0),
        }});
      }});

      activities.sort((a, b) => {{
        const timeDiff = Number(b.sortUnix || 0) - Number(a.sortUnix || 0);
        if (timeDiff) return timeDiff;
        const aIndex = a.request ? a.request.index : ((a.replies[0] && a.replies[0].index) || 0);
        const bIndex = b.request ? b.request.index : ((b.replies[0] && b.replies[0].index) || 0);
        return bIndex - aIndex;
      }});
      const replyCount = Array.from(repliesByRequestId.values()).reduce((total, replies) => total + replies.length, 0) + orphanReplies.length;
      return {{
        activities: activities.slice(0, 24),
        requestCount: requests.length,
        replyCount,
        resetCutoffUnix,
      }};
    }}

    function buildZorkBotActivity(state = latestState) {{
      return buildBotActivity("zork", state, zorkBotRuntimeFromState(state));
    }}

    function botTickerAvailableForState(state = latestState) {{
      const zorkRuntime = botRuntimeFromState("zork", state);
      const pingRuntime = botRuntimeFromState("ping", state);
      return !!(
        (zorkRuntime && zorkRuntime.available && zorkRuntime.enabled)
        || (pingRuntime && pingRuntime.available && pingRuntime.enabled)
      );
    }}

    function buildBotTickerSummary(state = latestState) {{
      const commands = ["zork", "ping"];
      const runtimes = Object.fromEntries(commands.map((command) => [command, botRuntimeFromState(command, state)]));
      const activitiesByCommand = Object.fromEntries(
        commands.map((command) => [command, buildBotActivity(command, state, runtimes[command])])
      );
      const enabledCommands = commands.filter((command) => {{
        const runtime = runtimes[command];
        return !!(runtime && runtime.available && runtime.enabled);
      }});
      const sessionsByCommand = Object.fromEntries(commands.map((command) => {{
        const runtime = runtimes[command] || {{}};
        return [command, Array.isArray(runtime.sessions) ? runtime.sessions : []];
      }}));
      const activeSessionCount = commands.reduce((total, command) => {{
        const runtime = runtimes[command] || {{}};
        const sessions = sessionsByCommand[command] || [];
        const rawCount = Math.trunc(Number(runtime.activeSessionCount) || sessions.length || 0);
        return total + Math.max(0, rawCount);
      }}, 0);
      const requestCount = commands.reduce((total, command) => {{
        const activity = activitiesByCommand[command] || {{}};
        return total + Math.max(0, Math.trunc(Number(activity.requestCount) || 0));
      }}, 0);
      const replyCount = commands.reduce((total, command) => {{
        const activity = activitiesByCommand[command] || {{}};
        return total + Math.max(0, Math.trunc(Number(activity.replyCount) || 0));
      }}, 0);
      const pendingCount = commands.reduce((total, command) => {{
        const activity = activitiesByCommand[command] || {{}};
        return total + (Array.isArray(activity.activities) ? activity.activities : [])
          .filter((entry) => entry && entry.status !== "responded")
          .length;
      }}, 0);
      const nowUnix = Math.floor(Date.now() / 1000);
      const latestActivity = commands
        .flatMap((command) => Array.isArray(activitiesByCommand[command].activities) ? activitiesByCommand[command].activities : [])
        .sort((a, b) => Number(b && b.sortUnix || 0) - Number(a && a.sortUnix || 0))[0] || null;
      const sessions = commands.flatMap((command) => sessionsByCommand[command] || []);
      const lastUnix = Math.max(
        Number(latestActivity && latestActivity.sortUnix) || 0,
        ...sessions.map((session) => zorkBotSessionUnix(session, "updated_unix"))
      );
      const lastAge = lastUnix > 0
        ? (typeof formatIdleAge === "function" ? formatIdleAge(lastUnix, nowUnix) : formatLocalChatTime(lastUnix, "n/a", nowUnix))
        : "none";
      const sessionLabels = sessions.slice(0, 2).map((session) => {{
        const peerId = normalizeNodeId(session && (session.peer_id || session.peerId || "")) || "";
        const peerLabel = zorkBotNodeLabel(peerId, state);
        const roomName = String((session && (session.room_name || session.roomName || session.room)) || "").trim();
        return roomName ? `${{peerLabel}} · ${{roomName}}` : peerLabel;
      }}).filter(Boolean);
      const sessionMoreCount = Math.max(0, sessions.length - sessionLabels.length);
      const sessionValue = activeSessionCount > 0
        ? `${{activeSessionCount}} active`
        : "0 active";
      const activityValue = `${{requestCount}} / ${{replyCount}}`;
      const rows = [
        {{ key: "Games", value: enabledCommands.length > 0 ? enabledCommands.map((command) => botCatalogSpecs[command].title).join(" + ") : "Off" }},
        {{ key: "Sess", value: sessionValue }},
      ];
      if (sessionLabels.length > 0) {{
        rows.push({{
          key: "Now",
          value: `${{sessionLabels.join(", ")}}${{sessionMoreCount > 0 ? ` +${{sessionMoreCount}}` : ""}}`,
        }});
      }}
      rows.push({{ key: "Req/Rep", value: activityValue }});
      if (pendingCount > 0) {{
        rows.push({{ key: "Wait", value: String(pendingCount) }});
      }}
      rows.push({{ key: "Last", value: lastAge }});
      const rowsHtml = rows
        .map((row) => `<div class="node-ticker-row bot-ticker-row"><span class="node-ticker-key">${{escAttr(row.key)}}:</span><span class="node-ticker-val">${{escAttr(row.value)}}</span></div>`)
        .join("");
      const titleParts = [
        enabledCommands.length > 0 ? `${{enabledCommands.map((command) => botCatalogSpecs[command].title).join(" + ")}} enabled` : "Game bots disabled",
        `${{activeSessionCount}} active session${{activeSessionCount === 1 ? "" : "s"}}`,
        `${{requestCount}} request${{requestCount === 1 ? "" : "s"}}`,
        `${{replyCount}} repl${{replyCount === 1 ? "y" : "ies"}}`,
        pendingCount > 0 ? `${{pendingCount}} pending` : "0 pending",
        `last ${{lastAge}}`,
        "Click to open Bots",
      ];
      return {{
        available: commands.some((command) => !!(runtimes[command] && runtimes[command].available)),
        enabled: enabledCommands.length > 0,
        activeSessionCount,
        requestCount,
        replyCount,
        pendingCount,
        text: activeSessionCount > 0
          ? `${{activeSessionCount}} session${{activeSessionCount === 1 ? "" : "s"}}`
          : `${{replyCount}} repl${{replyCount === 1 ? "y" : "ies"}}`,
        rows_html: rowsHtml,
        title: titleParts.join(" | "),
      }};
    }}

