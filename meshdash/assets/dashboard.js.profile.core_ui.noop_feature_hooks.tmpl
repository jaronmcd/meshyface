    function normalizeServerBotSettings(_state = null) {{
      return {{
        available: false,
        enabled: false,
        log_enabled: false,
        game_enabled: false,
        game_public_start_enabled: false,
        hard_disabled_incoming_commands: [],
        ping_triggers: [],
        ping_response_template: "",
        pull_reel_symbols: [],
        pull_response_template: "",
        joke_triggers: [],
        zork_triggers: [],
        joke_lines: [],
        joke_near_guess_lines: [],
        joke_delay_punchline_enabled: false,
        active_game_sessions: 0,
        commands: [],
        disabled_commands: [],
      }};
