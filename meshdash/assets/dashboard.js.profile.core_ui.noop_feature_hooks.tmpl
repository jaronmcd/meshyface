    }}

    function syncZorkBotControls(runtime) {{
      const enableBtn = document.getElementById("bots-zork-enable-btn");
      const disableBtn = document.getElementById("bots-zork-disable-btn");
      const canToggle = !!runtime.available && !zorkBotToggleInFlight;
      if (enableBtn instanceof HTMLButtonElement) {{
        enableBtn.disabled = !canToggle || runtime.enabled;
      }}
      if (disableBtn instanceof HTMLButtonElement) {{
        disableBtn.disabled = !canToggle || !runtime.enabled;
      }}
      const note = document.getElementById("bots-zork-routing-note");
      if (note instanceof HTMLElement) {{
        note.innerHTML = runtime.enabled
          ? 'Public chat <code>zork</code> starts a private session. Gameplay commands stay in direct messages.'
          : 'Zork is not answering mesh traffic while disabled.';
      }}
      const description = document.getElementById("bots-zork-description");
      if (description instanceof HTMLElement) {{
        description.textContent = runtime.enabled
          ? "Public chat zork starts a private session. Direct messages continue gameplay."
          : "Live replies are disabled. Enable Zork here to answer public starts and direct messages.";
      }}
    }}

    async function setZorkBotEnabledFromUi(enabled) {{
      if (zorkBotToggleInFlight) return;
      zorkBotToggleInFlight = true;
      setZorkBotToggleStatus(enabled ? "Enabling..." : "Disabling...");
      renderBotsView(latestState);
      try {{
        const resp = await fetch(zorkBotEndpoint, {{
          method: "POST",
          headers: {{ "Content-Type": "application/json" }},
          body: JSON.stringify({{ enabled: !!enabled }}),
        }});
        const payload = await resp.json().catch(() => ({{}}));
        if (!resp.ok || !payload.ok) {{
          throw new Error(payload && payload.error ? payload.error : `update failed (${{resp.status}})`);
        }}
        setZorkBotToggleStatus(enabled ? "Enabled" : "Disabled");
        forceStateReloadOnce = true;
        await poll();
      }} catch (err) {{
        setZorkBotToggleStatus(`Update failed: ${{err.message || err}}`, true);
      }} finally {{
        zorkBotToggleInFlight = false;
        renderBotsView(latestState);
      }}
    }}

    async function manageZorkBotFromUi(action, peerId = "") {{
      if (zorkBotToggleInFlight) return;
      zorkBotToggleInFlight = true;
      setZorkBotToggleStatus(action === "clear_sessions" ? "Clearing sessions..." : "Ending session...");
      renderBotsView(latestState);
      try {{
        const body = {{ action }};
        if (peerId) {{
          body.peer_id = peerId;
        }}
        const resp = await fetch(zorkBotEndpoint, {{
          method: "POST",
          headers: {{ "Content-Type": "application/json" }},
          body: JSON.stringify(body),
        }});
        const payload = await resp.json().catch(() => ({{}}));
        if (!resp.ok || !payload.ok) {{
          throw new Error(payload && payload.error ? payload.error : `update failed (${{resp.status}})`);
        }}
        setZorkBotToggleStatus(action === "clear_sessions" ? "Sessions cleared" : "Session ended");
        forceStateReloadOnce = true;
        await poll();
      }} catch (err) {{
        setZorkBotToggleStatus(`Update failed: ${{err.message || err}}`, true);
      }} finally {{
        zorkBotToggleInFlight = false;
        renderBotsView(latestState);
      }}
    }}

    function bindZorkBotControls() {{
      const enableBtn = document.getElementById("bots-zork-enable-btn");
      if (enableBtn instanceof HTMLButtonElement && enableBtn.dataset.bound !== "1") {{
        enableBtn.dataset.bound = "1";
        enableBtn.addEventListener("click", () => {{
          void setZorkBotEnabledFromUi(true);
        }});
      }}
      const disableBtn = document.getElementById("bots-zork-disable-btn");
      if (disableBtn instanceof HTMLButtonElement && disableBtn.dataset.bound !== "1") {{
        disableBtn.dataset.bound = "1";
        disableBtn.addEventListener("click", () => {{
          void setZorkBotEnabledFromUi(false);
        }});
      }}
      const clearBtn = document.getElementById("bots-zork-clear-sessions-btn");
      if (clearBtn instanceof HTMLButtonElement && clearBtn.dataset.bound !== "1") {{
        clearBtn.dataset.bound = "1";
        clearBtn.addEventListener("click", () => {{
          void manageZorkBotFromUi("clear_sessions");
        }});
      }}
      const sessionList = document.getElementById("bots-zork-session-list");
      if (sessionList instanceof HTMLElement && sessionList.dataset.bound !== "1") {{
        sessionList.dataset.bound = "1";
        sessionList.addEventListener("click", (event) => {{
          const target = event.target instanceof Element
            ? event.target.closest("[data-zork-session-action]")
            : null;
          if (!(target instanceof HTMLElement)) return;
          const action = String(target.dataset.zorkSessionAction || "").trim();
          const peerId = String(target.dataset.peerId || "").trim();
          if (action === "end_session" && peerId) {{
            void manageZorkBotFromUi(action, peerId);
          }}
        }});
      }}
    }}

    function renderBotsView(state = latestState) {{
      const runtime = zorkBotRuntimeFromState(state);
