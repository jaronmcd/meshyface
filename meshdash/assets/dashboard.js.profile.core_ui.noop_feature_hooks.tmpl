    async function setZorkBotEnabledFromUi(enabled) {{
      if (zorkBotToggleInFlight) return;
      const selectedCommand = normalizeBotCatalogCommand(selectedBotCommand);
      const spec = botCatalogSpecs[selectedCommand] || botCatalogSpecs.zork;
      zorkBotToggleInFlight = true;
      setZorkBotToggleStatus(enabled ? `Enabling ${{spec.title}}...` : `Disabling ${{spec.title}}...`);
      renderBotsView(latestState);
      try {{
        const body = {{ command: selectedCommand, enabled: !!enabled }};
        if (selectedCommand === "ping") {{
          const modeInput = document.getElementById("bots-ping-message-only-checkbox");
          if (modeInput instanceof HTMLInputElement) {{
            body.message_only = !!modeInput.checked;
          }}
        }}
        const resp = await fetch(botToggleEndpoint(selectedCommand), {{
          method: "POST",
          headers: {{ "Content-Type": "application/json" }},
          body: JSON.stringify(body),
        }});
        const payload = await resp.json().catch(() => ({{}}));
        if (!resp.ok || !payload.ok) {{
          throw new Error(payload && payload.error ? payload.error : `update failed (${{resp.status}})`);
        }}
        setZorkBotToggleStatus(enabled ? `${{spec.title}} enabled` : `${{spec.title}} disabled`);
        forceStateReloadOnce = true;
        await poll();
      }} catch (err) {{
        setZorkBotToggleStatus(`Update failed: ${{err.message || err}}`, true);
      }} finally {{
        zorkBotToggleInFlight = false;
        renderBotsView(latestState);
      }}
    }}

    async function setPingMessageOnlyFromUi(messageOnly) {{
      if (zorkBotToggleInFlight) return;
      zorkBotToggleInFlight = true;
