    function parseCoreUiMeshChannelIndexCandidate(raw) {{
      if (raw == null) return null;
      if (typeof raw === "object") {{
        const nested = parseCoreUiMeshChannelIndexCandidate(
          raw.index ?? raw.channel_index ?? raw.channelIndex
        );
        if (Number.isInteger(nested) && nested >= 0) {{
          return Math.trunc(nested);
        }}
      }}
      const numeric = Number(raw);
      if (Number.isInteger(numeric) && numeric >= 0) {{
        return Math.trunc(numeric);
      }}
      const text = String(raw || "").trim();
      if (!text) return null;
      const chMatch = /(?:^|[^a-z0-9])ch(?:annel)?\s*([0-9]+)\b/i.exec(text);
      if (chMatch) {{
        const idx = Number(chMatch[1]);
        if (Number.isInteger(idx) && idx >= 0) return Math.trunc(idx);
      }}
      const leading = /^\s*([0-9]+)\b/.exec(text);
      if (leading) {{
        const idx = Number(leading[1]);
        if (Number.isInteger(idx) && idx >= 0) return Math.trunc(idx);
      }}
      const lower = text.toLowerCase();
      const sources = [];
      if (Array.isArray(meshChannelOptions)) sources.push(meshChannelOptions);
      if (Array.isArray(meshChannelSendOptions) && meshChannelSendOptions !== meshChannelOptions) {{
        sources.push(meshChannelSendOptions);
      }}
      for (const list of sources) {{
        for (const opt of list) {{
          if (!(opt && typeof opt === "object")) continue;
          const idx = Number(opt.index);
          if (!Number.isInteger(idx) || idx < 0) continue;
          const name = String(opt.name || "").trim().toLowerCase();
          if (name && name === lower) {{
            return Math.trunc(idx);
          }}
        }}
      }}
      return null;
    }}

    function explicitMessageMeshChannelIndex(msg) {{
      if (!msg || typeof msg !== "object") return null;
      const candidates = [
        msg.channel_index,
        msg.channelIndex,
        msg.channel,
        msg.mesh_channel,
        msg.meshChannel,
        msg.channel_name,
        msg.channelName,
        msg.summary && msg.summary.channel_index,
        msg.summary && msg.summary.channelIndex,
        msg.summary && msg.summary.channel,
        msg.packet && msg.packet.channel_index,
        msg.packet && msg.packet.channelIndex,
        msg.packet && msg.packet.channel,
      ];
      for (const candidate of candidates) {{
        const parsed = parseCoreUiMeshChannelIndexCandidate(candidate);
        if (Number.isInteger(parsed) && parsed >= 0) {{
          return Math.trunc(parsed);
        }}
      }}
      return null;
    }}

    function messageMeshChannelIndex(msg) {{
      const explicit = explicitMessageMeshChannelIndex(msg);
      return Number.isInteger(explicit) && explicit >= 0 ? explicit : 0;
    }}

    function messageMatchesActiveMeshChannel(msg) {{
      const activeIdx = (typeof activeMeshChannelFilterIndex === "function")
        ? activeMeshChannelFilterIndex()
        : meshChannelAllIndex;
      if (activeIdx === meshChannelAllIndex) return true;
      return messageMeshChannelIndex(msg) === activeIdx;
    }}

    function normalizeFileTransferName(rawName) {{
      const compact = String(rawName == null ? "" : rawName)
        .replace(/\r\n/g, " ")
        .replace(/\r/g, " ")
        .replace(/\n/g, " ")
        .replace(/\s+/g, " ")
        .trim();
      if (!compact) return "mesh-file.bin";
      const maxChars = 64;
      return compact.length > maxChars ? compact.slice(0, maxChars) : compact;
    }}

