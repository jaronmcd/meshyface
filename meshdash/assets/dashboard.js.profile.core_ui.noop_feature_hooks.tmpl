          return originalRenderChat(state);
        }} catch (err) {{
          renderChatCoreUiFallback(state, err);
          return;
        }}
      }};
      guardedRenderChat.__coreUiGuarded = true;
      guardedRenderChat.__coreUiOriginal = originalRenderChat;
      renderChat = guardedRenderChat;
