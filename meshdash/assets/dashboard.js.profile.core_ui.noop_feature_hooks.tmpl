      if (item instanceof HTMLElement) {{
        item.classList.toggle("is-enabled", runtime.enabled);
        item.classList.toggle("is-disabled", !runtime.enabled);
      }}
      setZorkBotStatusClass(document.getElementById("bots-zork-list-state"), runtime.enabled);
      setZorkBotStatusClass(document.getElementById("bots-zork-detail-state"), runtime.enabled);
      bindZorkBotControls();
      syncZorkBotControls(runtime);
      renderZorkBotSessions(state, runtime);
      renderZorkBotActivity(state, runtime);
    }}

