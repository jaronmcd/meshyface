    function setFileTransferDestination(rawDestination, options = null) {{
      const persist = !(options && options.persist === false);
      const clean = normalizeNodeId(rawDestination || "");
      fileTransferDestinationId = isCanonicalNodeId(clean) ? clean : "";
      const input = document.getElementById("files-destination-input");
      if (input instanceof HTMLInputElement) {{
        input.value = fileTransferDestinationId;
      }}
      if (!persist) return;
      const storageKey = (typeof fileTransferDestinationStorageKey === "string")
        ? String(fileTransferDestinationStorageKey || "")
        : "";
      if (!storageKey) return;
      try {{
        if (fileTransferDestinationId) {{
          window.localStorage.setItem(storageKey, fileTransferDestinationId);
        }} else {{
          window.localStorage.removeItem(storageKey);
        }}
      }} catch (_err) {{
      }}
    }}

