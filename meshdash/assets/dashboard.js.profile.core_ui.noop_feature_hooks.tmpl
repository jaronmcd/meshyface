    const botPublicStartHeadsByCommand = {{
      zork: new Set(["zork"]),
      ping: new Set(["ping", "test", "can you see this", "can you see this?"]),
    }};
    let zorkBotToggleInFlight = false;
    const botCatalogSpecs = {{
      zork: {{
        command: "zork",
