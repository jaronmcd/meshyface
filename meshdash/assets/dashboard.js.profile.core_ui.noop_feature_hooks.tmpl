    function renderBotActivity(command, state, runtime) {{
      const selectedCommand = normalizeBotCatalogCommand(command);
      const spec = botCatalogSpecs[selectedCommand] || botCatalogSpecs.zork;
      const stats = document.getElementById("bots-zork-activity-stats");
      const list = document.getElementById("bots-zork-activity-list");
      if (!(stats instanceof HTMLElement) || !(list instanceof HTMLElement)) return;
      const nowUnix = Math.floor(Date.now() / 1000);
      const activity = buildBotActivity(selectedCommand, state, runtime);
      const last = activity.activities[0] || null;
      const lastTime = last
        ? formatLocalChatTime(Number(last.sortUnix || 0), "recent", nowUnix)
        : "none";
      stats.innerHTML = [
        `<span>Requests ${{activity.requestCount}}</span>`,
        `<span>Replies ${{activity.replyCount}}</span>`,
        `<span>Sessions ${{runtime.activeSessionCount}}</span>`,
        `<span>Last ${{escAttr(lastTime)}}</span>`,
      ].join("");
      if (activity.resetCutoffUnix > 0) {{
        stats.innerHTML += `<span>Since reset ${{escAttr(formatLocalChatTime(activity.resetCutoffUnix, "recent", nowUnix))}}</span>`;
      }}

      if (activity.activities.length <= 0) {{
        list.innerHTML = activity.resetCutoffUnix > 0
          ? `<div class="bots-history-empty">No ${{escAttr(spec.title)}} activity since the reset.</div>`
          : `<div class="bots-history-empty">No ${{escAttr(spec.title)}} activity in the current chat window yet.</div>`;
        return;
      }}

      list.innerHTML = activity.activities.map((entry) => {{
        const request = entry.request;
        const replies = Array.isArray(entry.replies) ? entry.replies : [];
        const statusClass = entry.status === "responded" ? "responded" : "pending";
        const statusLabel = entry.status === "responded" ? "Responded" : "Waiting";
        const commandText = request ? request.text : "(request outside current buffer)";
        const peerId = request ? request.from : ((replies[0] && replies[0].to) || "");
        const route = request
          ? `${{zorkBotNodeLabel(request.from, state)}} -> ${{request.to === "^all" ? "public" : "bot"}}`
          : "reply only";
        const requestTime = request ? zorkBotRowTime(request.row, nowUnix) : zorkBotRowTime(replies[0] && replies[0].row, nowUnix);
        const responseText = replies
          .slice(0, 4)
          .map((reply) => reply.text)
          .join("\\n");
        const moreText = replies.length > 4 ? `\\n+${{replies.length - 4}} more part(s)` : "";
        const responseHtml = responseText
          ? `<div class="bots-history-response"><strong>bot to ${{escAttr(zorkBotNodeLabel(peerId, state))}}</strong> ${{escAttr(responseText + moreText)}}</div>`
          : '<div class="bots-history-response">No reply has been recorded yet.</div>';
        return `
          <div class="bots-history-item">
            <div class="bots-history-item-head">
              <div class="bots-history-command">${{escAttr(commandText)}}</div>
              <span class="bots-history-status-pill ${{statusClass}}">${{statusLabel}}</span>
            </div>
            <div class="bots-history-meta"><span>${{escAttr(route)}}</span><span>${{escAttr(requestTime)}}</span></div>
            ${{responseHtml}}
          </div>
        `;
      }}).join("");
    }}

    function renderZorkBotActivity(state, runtime) {{
      renderBotActivity("zork", state, runtime);
    }}

    function zorkBotSessionUnix(session, key) {{
      if (!session || typeof session !== "object") return 0;
      const camelKey = key.replace(/_([a-z])/g, (_match, ch) => String(ch || "").toUpperCase());
      const value = Number(session[key] ?? session[camelKey] ?? 0);
      return Number.isFinite(value) ? Math.max(0, Math.floor(value)) : 0;
    }}

    function renderZorkBotSessions(state, runtime, command = "zork") {{
      const list = document.getElementById("bots-zork-session-list");
      const clearBtn = document.getElementById("bots-zork-clear-sessions-btn");
      if (!(list instanceof HTMLElement)) return;
      const selectedCommand = normalizeBotCatalogCommand(command);
      const spec = botCatalogSpecs[selectedCommand] || botCatalogSpecs.zork;
      const sessions = Array.isArray(runtime.sessions) ? runtime.sessions : [];
      if (clearBtn instanceof HTMLButtonElement) {{
        clearBtn.hidden = selectedCommand !== "zork";
        clearBtn.disabled = selectedCommand !== "zork" || zorkBotToggleInFlight || !runtime.enabled || sessions.length <= 0;
      }}
      if (sessions.length <= 0) {{
        list.innerHTML = `<div class="bots-history-empty">No active ${{escAttr(spec.title)}} sessions.</div>`;
        return;
      }}
      const nowUnix = Math.floor(Date.now() / 1000);
      list.innerHTML = sessions.map((session) => {{
        const peerId = normalizeNodeId(session && (session.peer_id || session.peerId || "")) || "";
        const roomName = String((session && (session.room_name || session.roomName || session.room)) || "Unknown room");
        const moves = Number(session && session.moves);
        const moveText = Number.isFinite(moves) ? Math.max(0, Math.floor(moves)) : 0;
        const inventoryCount = Number(session && (session.inventory_count ?? session.inventoryCount));
        const inventoryText = Number.isFinite(inventoryCount) ? Math.max(0, Math.floor(inventoryCount)) : 0;
        const treasure = (session && typeof session.treasures === "object") ? session.treasures : null;
        const treasureTotal = Number(treasure && treasure.total);
        const treasureRecovered = Number(treasure && treasure.recovered);
        const treasureText = Number.isFinite(treasureTotal) && treasureTotal > 0
          ? `<span>${{Math.max(0, Math.floor(Number.isFinite(treasureRecovered) ? treasureRecovered : 0))}}/${{Math.max(0, Math.floor(treasureTotal))}} treasures</span>`
          : "";
        const updatedUnix = zorkBotSessionUnix(session, "updated_unix");
        const expiresUnix = zorkBotSessionUnix(session, "expires_unix");
        const updatedText = formatLocalChatTime(updatedUnix, "n/a", nowUnix);
        const expiresText = expiresUnix > 0
          ? formatLocalChatTime(expiresUnix, "n/a", nowUnix)
          : "n/a";
        const endButtonHtml = selectedCommand === "zork"
          ? `<button class="btn btn-secondary bots-sniffer-btn" type="button" data-zork-session-action="end_session" data-peer-id="${{escAttr(peerId)}}">End</button>`
          : "";
        return `
          <div class="bots-session-item">
            <div class="bots-session-main">
              <div class="bots-session-peer">${{escAttr(zorkBotNodeLabel(peerId, state))}}</div>
              <div class="bots-session-meta">
                <span>${{escAttr(roomName)}}</span>
                <span>${{moveText}} moves</span>
                <span>${{inventoryText}} carried</span>
                ${{treasureText}}
                <span>last ${{escAttr(updatedText)}}</span>
                <span>expires ${{escAttr(expiresText)}}</span>
              </div>
            </div>
            ${{endButtonHtml}}
          </div>
        `;
      }}).join("");
    }}

