    function renderChatCoreUiFallback(state = latestState, renderError = null) {{
      const safeState = state && typeof state === "object" ? state : {{}};
      const safeTraffic = (safeState.traffic && typeof safeState.traffic === "object")
        ? safeState.traffic
        : {{}};
      const nodes = Array.isArray(safeState.nodes) ? safeState.nodes : [];
      const recentChat = Array.isArray(safeTraffic.recent_chat) ? safeTraffic.recent_chat : [];
      const nowUnix = Math.floor(Date.now() / 1000);

      const feed = document.getElementById("chat-feed");
      if (feed instanceof HTMLElement) {{
        const rows = recentChat.slice(-Math.max(1, chatFeedMaxEntries || 120)).map((msg) => {{
          const fromRaw = normalizeNodeId(
            (msg && (msg.from || msg.from_id || msg.fromId || msg.source || msg.source_id || msg.sourceId)) || ""
          ) || "unknown";
          const toRaw = normalizeNodeId(
            (msg && (msg.to || msg.to_id || msg.toId || msg.destination || msg.dest || msg.dest_id || msg.destId)) || ""
          ) || "^all";
          const textRaw = String((msg && (msg.text || msg.payload || msg.message)) || "").trim();
          const rawTime = String((msg && (msg.rx_time || msg.captured_at || msg.time)) || "").trim();
          const unix = latestUnixTimestamp(msg && msg.rx_time, msg && msg.captured_at, msg && msg.time);
          const timeText = (typeof formatLocalChatTime === "function")
            ? formatLocalChatTime(unix, rawTime || "n/a", nowUnix)
            : (rawTime || "n/a");
          return `<div class="chat-feed-item chat-feed-item-monitor-exact"><span class="chat-entry-msg"><span class="chat-monitor-prefix">[${{escAttr(timeText)}}]</span><span class="chat-monitor-network-tag">[${{escAttr(fromRaw)}}→${{escAttr(toRaw)}}]</span><span class="chat-entry-copy chat-monitor-text">${{escAttr(textRaw || "(no text)")}}</span></span></div>`;
        }});
        feed.innerHTML = rows.length > 0
          ? rows.join("")
          : '<div class="chat-feed-empty">No chat messages available yet.</div>';
      }}

      const roomList = document.getElementById("chat-room-list");
      if (roomList instanceof HTMLElement) {{
        const roster = nodes
          .map((node) => {{
            const id = normalizeNodeId(node && node.id);
            if (!isSelectableNodeId(id)) return null;
            const name = preferredNodeName(node) || id;
            const lastSeenUnix = latestUnixTimestamp(
              node && node.last_heard_unix,
              node && node.last_heard_epoch
            );
            return {{
              id,
              name,
              status: freshnessStatus(lastSeenUnix, nowUnix),
              lastSeenUnix,
              lastMessageUnix: null,
            }};
          }})
          .filter((row) => !!row);
        roster.sort((a, b) => String(a.name || a.id).localeCompare(String(b.name || b.id)));
        chatRosterModel = roster;
        roomList.innerHTML = roster.length > 0
          ? roster.map((item) => (
              `<button type="button" class="chat-member-item status-${{escAttr(normalizeFreshnessKey(item.status) || "unknown")}}" data-node-id="${{escAttr(item.id)}}" title="${{escAttr(item.id)}}"><span class="chat-member-name">${{escAttr(item.name)}}</span><span class="chat-member-id">${{escAttr(item.id)}}</span></button>`
            )).join("")
          : '<div class="chat-member-empty">No nodes available.</div>';
      }}

      if (typeof renderChatChangeSummary === "function") {{
        renderChatChangeSummary(nowUnix);
      }}
      if (typeof bindChatChangeSummaryControls === "function") {{
        bindChatChangeSummaryControls();
      }}
      if (typeof tickFreshnessUI === "function") {{
        tickFreshnessUI(safeState);
      }}

      const message = renderError instanceof Error
        ? renderError.message
        : String(renderError || "").trim();
      if (message) {{
        if (typeof appendConsoleLine === "function") {{
          appendConsoleLine(`core-ui-renderChat-fallback|${{Date.now()}}|${{message}}`, `[core-ui fallback] renderChat failed: ${{message}}`);
        }}
        if (typeof console !== "undefined" && console && typeof console.error === "function") {{
          console.error("[core-ui fallback] renderChat failed:", renderError);
        }}
      }}
    }}

    function installCoreUiRenderChatGuard() {{
      if (typeof renderChat !== "function") return;
      if (renderChat && renderChat.__coreUiGuarded === true) return;
      const originalRenderChat = renderChat;
      const guardedRenderChat = function(state = latestState) {{
        try {{
          return originalRenderChat(state);
        }} catch (err) {{
          renderChatCoreUiFallback(state, err);
          return;
        }}
      }};
      guardedRenderChat.__coreUiGuarded = true;
      guardedRenderChat.__coreUiOriginal = originalRenderChat;
      renderChat = guardedRenderChat;
    }}

