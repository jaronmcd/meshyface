    }}


    function normalizeChatChannel(raw) {{
      const clean = String(raw || "").trim().toLowerCase();
      if (knownChatChannels.has(clean)) return clean;
      if (clean.startsWith("room:")) {{
        const slug = clean.slice(5).trim();
        if (roomSlugRe.test(slug)) return `room:${{slug}}`;
      }}
      return "all";
    }}

    function channelLabel(key) {{
      if (key === "direct") return "Peer-to-peer";
      if (typeof key === "string" && key.startsWith("room:")) return `#${{key.slice(5)}}`;
      return "Everyone";
    }}

    function normalizeDeliveryState(raw) {{
      const clean = String(raw || "").trim().toLowerCase();
      return knownDeliveryStates.has(clean) ? clean : "";
    }}

    function formatHopCountLabel(hops, fallback = "hops n/a") {{
      const hopCount = nonNegativeIntegerOrNull(hops);
      if (hopCount != null) {{
        return `${{hopCount}} hop${{hopCount === 1 ? "" : "s"}}`;
      }}
      return String(fallback || "").trim() || "hops n/a";
    }}

    function computeRoundTripMs(sentMsRaw, responseMsRaw) {{
      const sentMs = Number(sentMsRaw);
      const responseMs = Number(responseMsRaw);
      if (!Number.isFinite(sentMs) || sentMs <= 0) return null;
      if (!Number.isFinite(responseMs) || responseMs <= 0) return null;
      if (responseMs < sentMs) return null;
      return Math.round(responseMs - sentMs);
    }}

    function buildResponseTelemetry(sentMsRaw, responseMsRaw, hopsRaw) {{
      return {{
        rttMs: computeRoundTripMs(sentMsRaw, responseMsRaw),
        hopLabel: formatHopCountLabel(hopsRaw),
      }};
    }}

    function buildResponseTelemetryMetaHtml(sentMsRaw, responseMsRaw, hopsRaw) {{
      const telemetry = buildResponseTelemetry(sentMsRaw, responseMsRaw, hopsRaw);
      return `<div class="response-telemetry-meta"><span>RTT ${{telemetry.rttMs == null ? "n/a" : `${{telemetry.rttMs}} ms`}}</span><span>${{escAttr(telemetry.hopLabel)}}</span></div>`;
    }}

    function buildDeliveredAckDetail(msg, ackMeta = null) {{
      if (!msg || typeof msg !== "object") return "";
      const sentMs = latestTimestampMs(
        msg.sent_at,
        msg.created_at,
        msg.captured_at,
        msg.rx_time,
        msg.time,
      );
      const ackInfo = (ackMeta && typeof ackMeta === "object") ? ackMeta : null;
      const ackMs = (
        parseDashboardTimeToMs(ackInfo && (ackInfo.rx_ms ?? ackInfo.rxMs))
        || latestTimestampMs(
          msg.delivery_updated_unix,
          msg.delivery_updated_at,
          msg.updated_at,
          msg.updatedAt,
        )
      );
      const telemetry = buildResponseTelemetry(sentMs, ackMs, ackInfo && (ackInfo.hops ?? ackInfo.hopCount));
      const parts = [
        `RTT ${{telemetry.rttMs == null ? "n/a" : `${{telemetry.rttMs}} ms`}}`,
        telemetry.hopLabel,
      ];
      const rxSnrRaw = Number(ackInfo && (ackInfo.rx_snr ?? ackInfo.rxSnr));
      if (Number.isFinite(rxSnrRaw)) {{
        parts.push(`snr ${{formatMetricValue(rxSnrRaw, 1)}} dB`);
      }}
      const rxRssiRaw = Number(ackInfo && (ackInfo.rx_rssi ?? ackInfo.rxRssi));
      if (Number.isFinite(rxRssiRaw)) {{
        parts.push(`rssi ${{formatMetricValue(rxRssiRaw, 0)}} dBm`);
      }}
      return parts.join(" | ");
    }}

    function buildPacketSummaryAndRoutingAckMaps(rawPackets) {{
      const packetSummaryById = new Map();
      const deliveryAckByRequestId = new Map();
      const entries = Array.isArray(rawPackets) ? rawPackets : [];
      for (const entry of entries) {{
        const summary = (entry && entry.summary && typeof entry.summary === "object")
          ? entry.summary
          : {{}};
        const packet = (entry && entry.packet && typeof entry.packet === "object")
          ? entry.packet
          : {{}};
        const decoded = (packet.decoded && typeof packet.decoded === "object")
          ? packet.decoded
          : {{}};
        const packetId = parsePositiveMessageId(
          summary.packet_id
          ?? summary.message_id
          ?? packet.id
          ?? packet.packet_id
          ?? packet.message_id
        );
        if (packetId) {{
          for (const packetIdKey of messageIdAliasKeys(packetId)) {{
            packetSummaryById.set(packetIdKey, entry);
          }}
        }}

        const portnum = String(summary.portnum ?? decoded.portnum ?? "").trim().toUpperCase();
        if (portnum !== "ROUTING_APP") {{
          continue;
        }}
        const routing = (decoded.routing && typeof decoded.routing === "object")
          ? decoded.routing
          : {{}};
        const requestId = parsePositiveMessageId(
          routing.requestId
          ?? routing.request_id
          ?? decoded.requestId
          ?? decoded.request_id
        );
        if (!requestId) {{
          continue;
        }}
        const ackMs = latestTimestampMs(
          summary.rx_time_unix,
          summary.rx_time,
          summary.captured_at,
          entry && (entry.captured_at || entry.rx_time),
          packet.rxTime,
        ) || 0;
        const ackHops = hopCountOfChatPacket(summary) ?? hopCountOfChatPacket(packet);
        const rxSnrRaw = Number(
          summary.rx_snr
          ?? summary.rxSnr
          ?? packet.rx_snr
          ?? packet.rxSnr
        );
        const rxRssiRaw = Number(
          summary.rx_rssi
          ?? summary.rxRssi
          ?? packet.rx_rssi
          ?? packet.rxRssi
        );
        const existingAck = deliveryAckByRequestId.get(String(requestId));
        if (existingAck && Number(existingAck.rx_ms || 0) > ackMs) {{
          continue;
        }}
        deliveryAckByRequestId.set(String(requestId), {{
          request_id: requestId,
          rx_ms: ackMs > 0 ? ackMs : null,
          hops: Number.isInteger(ackHops) && ackHops >= 0 ? ackHops : null,
          rx_snr: Number.isFinite(rxSnrRaw) ? rxSnrRaw : null,
          rx_rssi: Number.isFinite(rxRssiRaw) ? Math.trunc(rxRssiRaw) : null,
        }});
      }}
      return {{ packetSummaryById, deliveryAckByRequestId }};
    }}

    function formatLatencyLabel(latencyMsRaw) {{
      const latencyMs = Number(latencyMsRaw);
      if (!Number.isFinite(latencyMs) || latencyMs < 0) return "n/a";
      const value = Math.max(0, Math.trunc(latencyMs));
      if (value < 1000) return `${{value}}ms`;
      if (value < 10000) return `${{(value / 1000).toFixed(1)}}s`;
      const totalSeconds = Math.trunc(value / 1000);
      const days = Math.trunc(totalSeconds / 86400);
      const hours = Math.trunc((totalSeconds % 86400) / 3600);
      const minutes = Math.trunc((totalSeconds % 3600) / 60);
      const seconds = Math.trunc(totalSeconds % 60);
      const parts = [];
      if (days > 0) parts.push(`${{days}}d`);
      if (hours > 0) parts.push(`${{hours}}h`);
      if (minutes > 0) parts.push(`${{minutes}}m`);
      if (seconds > 0 || parts.length === 0) parts.push(`${{seconds}}s`);
      return parts.slice(0, 3).join(" ");
    }}

    function formatDistanceMiLabel(distanceKmRaw) {{
      const distanceKm = Number(distanceKmRaw);
      if (!Number.isFinite(distanceKm) || distanceKm < 0) return "";
      const distanceMi = distanceKm * 0.621371;
      if (distanceMi < 1) return "<1mi";
      if (distanceMi < 10) return `${{distanceMi.toFixed(1)}}mi`;
      return `${{Math.round(distanceMi)}}mi`;
    }}

    function formatSignalRssiLabel(valueRaw) {{
      const value = Number(valueRaw);
      if (!Number.isFinite(value)) return "";
      return `${{Math.round(value)}}dBm`;
    }}

    function formatSignalSnrLabel(valueRaw) {{
      const value = Number(valueRaw);
      if (!Number.isFinite(value)) return "";
      return `${{value.toFixed(1)}}dB`;
    }}

    function buildLinkSignalHintText(rssiRaw, snrRaw) {{
      const parts = [];
      const rssiLabel = formatSignalRssiLabel(rssiRaw);
      if (rssiLabel) parts.push(rssiLabel);
      const snrLabel = formatSignalSnrLabel(snrRaw);
      if (snrLabel) parts.push(snrLabel);
      if (parts.length === 0) return "";
      return `link ${{parts.join(" / ")}} (last-hop)`;
    }}

    function haversineKm(latA, lonA, latB, lonB) {{
      const earthRadiusKm = 6371.0;
      const toRad = (value) => (Number(value) * Math.PI) / 180;
      const latARad = toRad(latA);
      const lonARad = toRad(lonA);
      const latBRad = toRad(latB);
      const lonBRad = toRad(lonB);
      const dLat = latBRad - latARad;
      const dLon = lonBRad - lonARad;
      const hav = (
        (Math.sin(dLat / 2) ** 2)
        + (Math.cos(latARad) * Math.cos(latBRad) * (Math.sin(dLon / 2) ** 2))
      );
      return 2 * earthRadiusKm * Math.asin(Math.sqrt(Math.max(0, hav)));
    }}

    function nodeCoordsFromStateEntry(node) {{
      if (!node || typeof node !== "object" || Array.isArray(node)) return null;
      const candidates = [
        node,
        node.position,
        node.local_position,
        node.localPosition,
      ].filter((candidate) => candidate && typeof candidate === "object" && !Array.isArray(candidate));
      for (const candidate of candidates) {{
        const lat = coordinateValueFromSpecs(candidate, [
          {{ key: "lat" }},
          {{ key: "latitude" }},
          {{ key: "latitude_i", scale: 1e-7 }},
          {{ key: "latitudeI", scale: 1e-7 }},
        ]);
        const lon = coordinateValueFromSpecs(candidate, [
          {{ key: "lon" }},
          {{ key: "lng" }},
          {{ key: "longitude" }},
          {{ key: "longitude_i", scale: 1e-7 }},
          {{ key: "longitudeI", scale: 1e-7 }},
        ]);
        if (!isValidLatLonRange(lat, lon)) continue;
        if (Math.abs(Number(lat)) < 1e-9 && Math.abs(Number(lon)) < 1e-9) continue;
        return {{ lat: Number(lat), lon: Number(lon) }};
      }}
      return null;
    }}

    function nodePositionUnix(node) {{
      if (!node || typeof node !== "object" || Array.isArray(node)) return null;
      const roots = [
        node,
        node.position,
        node.local_position,
        node.localPosition,
      ].filter((candidate) => candidate && typeof candidate === "object" && !Array.isArray(candidate));
      const raw = firstNestedValue(roots, [
        "position_unix",
        "positionUnix",
        "position_time",
        "positionTime",
        "last_position_unix",
        "lastPositionUnix",
        "timestamp",
        "time",
      ]);
      return parseDashboardTimeToUnix(raw);
    }}

    function nodePositionIsRecent(node, nowUnix = Math.floor(Date.now() / 1000)) {{
      const positionUnix = Number(nodePositionUnix(node));
      if (!Number.isFinite(positionUnix) || positionUnix <= 0) {{
        // Some payloads do not expose per-position timestamps; keep coordinates usable.
        return true;
      }}
      if (positionUnix > (nowUnix + 3600)) return false;
      return (nowUnix - positionUnix) <= requesterPositionMaxAgeSeconds;
    }}

    function offlineAtlasCityRowsFromPayload(payload) {{
      const layers = (payload && typeof payload === "object" && payload.layers && typeof payload.layers === "object")
        ? payload.layers
        : {{}};
      const cities = normalizeOfflineAtlasCollection(layers.cities);
      const features = Array.isArray(cities.features) ? cities.features : [];
      const rows = [];
      for (const feature of features) {{
        const geometry = (feature && typeof feature.geometry === "object") ? feature.geometry : null;
        const coordinates = Array.isArray(geometry && geometry.coordinates)
          ? geometry.coordinates
          : null;
        if (!coordinates || coordinates.length < 2) continue;
        const lon = Number(coordinates[0]);
        const lat = Number(coordinates[1]);
        if (!isValidLatLonRange(lat, lon)) continue;
        const props = (feature && typeof feature.properties === "object") ? feature.properties : {{}};
        const name = sanitizeOfflineLabel(props.name, "");
        if (!name) continue;
        const stateText = sanitizeOfflineLabel(
          props.state || props.region || props.admin1 || props.adm1name,
          ""
        );
        const countryText = sanitizeOfflineLabel(
          props.country || props.admin0 || props.adm0name || props.iso_a2 || props.iso_a3,
          ""
        );
        const populationRaw = Number(
          props.population ?? props.pop_max ?? props.popMax ?? props.pop
        );
        rows.push({{
          lat: Number(lat),
          lon: Number(lon),
          name,
          state: stateText,
          country: countryText,
          population: Number.isFinite(populationRaw) ? populationRaw : 0,
        }});
      }}
      return rows;
    }}

    async function loadOfflineAtlasCityRows() {{
      if (Array.isArray(offlineAtlasCityRowsCache)) {{
        return offlineAtlasCityRowsCache;
      }}
      if (offlineAtlasCityRowsPromise) {{
        return offlineAtlasCityRowsPromise;
      }}
      offlineAtlasCityRowsPromise = (async () => {{
        try {{
          const payload = await fetchOfflineAtlasPayload();
          const rows = payload ? offlineAtlasCityRowsFromPayload(payload) : [];
          offlineAtlasCityRowsCache = Array.isArray(rows) ? rows : [];
          return offlineAtlasCityRowsCache;
        }} catch (_err) {{
          offlineAtlasCityRowsCache = [];
          return offlineAtlasCityRowsCache;
        }} finally {{
          offlineAtlasCityRowsPromise = null;
        }}
      }})();
      return offlineAtlasCityRowsPromise;
    }}

    async function nearestOfflineCityHintFromCoords(latRaw, lonRaw, maxDistanceKm = offlineCityHintMaxDistanceKm) {{
      const lat = Number(latRaw);
      const lon = Number(lonRaw);
      if (!isValidLatLonRange(lat, lon)) return "";
      const rows = await loadOfflineAtlasCityRows();
      if (!Array.isArray(rows) || rows.length === 0) return "";
      const limitKm = Number(maxDistanceKm);
      const maxDistance = Number.isFinite(limitKm) && limitKm > 0 ? limitKm : offlineCityHintMaxDistanceKm;
      let best = null;
      let bestDistanceKm = null;
      for (const row of rows) {{
        if (!row || typeof row !== "object") continue;
        const cityLat = Number(row.lat);
        const cityLon = Number(row.lon);
        if (!isValidLatLonRange(cityLat, cityLon)) continue;
        const distanceKm = haversineKm(lat, lon, cityLat, cityLon);
        if (!Number.isFinite(distanceKm) || distanceKm < 0) continue;
        if (best == null || bestDistanceKm == null || distanceKm < bestDistanceKm) {{
          best = row;
          bestDistanceKm = distanceKm;
          continue;
        }}
        if (Math.abs(distanceKm - bestDistanceKm) < 0.01) {{
          const candidatePop = Number(row.population) || 0;
          const bestPop = Number(best.population) || 0;
          if (candidatePop > bestPop) {{
            best = row;
            bestDistanceKm = distanceKm;
          }}
        }}
      }}
      if (!best || !Number.isFinite(bestDistanceKm) || bestDistanceKm > maxDistance) return "";
      const cityName = sanitizeOfflineLabel(best.name, "");
      if (!cityName) return "";
      const stateName = sanitizeOfflineLabel(best.state, "");
      const countryName = sanitizeOfflineLabel(best.country, "");
      const place = stateName
        ? `${{cityName}}, ${{stateName}}`
        : (countryName ? `${{cityName}}, ${{countryName}}` : cityName);
      return place;
    }}

    function normalizeNodeCityEstimateMode(modeRaw, fallback = "both") {{
      const clean = String(modeRaw || "").trim().toLowerCase();
      if (clean === "live" || clean === "history" || clean === "both") return clean;
      const nextFallback = String(fallback || "").trim().toLowerCase();
      return (nextFallback === "live" || nextFallback === "history" || nextFallback === "both")
        ? nextFallback
        : "both";
    }}

    function resolveNodeCityLocationFromCoords(latRaw, lonRaw) {{
      const lat = Number(latRaw);
      const lon = Number(lonRaw);
      if (!isValidLatLonRange(lat, lon)) return null;
      if (Math.abs(lat) < 1e-9 && Math.abs(lon) < 1e-9) return null;
      return {{ lat: Number(lat), lon: Number(lon) }};
    }}

    function nodeBackendLocationEstimateWindow(modeRaw) {{
      const clean = String(modeRaw || "").trim().toLowerCase();
      const supported = new Set(["6h", "12h", "24h", "72h", "7d", "14d", "30d", "max"]);
      if (supported.has(clean)) return clean;
      if (clean === "live") return "24h";
      const graphMode = (typeof networkGraphEdgeMode === "string")
        ? String(networkGraphEdgeMode || "").trim().toLowerCase()
        : "";
      if (supported.has(graphMode)) return graphMode;
      return clean === "history" ? "7d" : "72h";
    }}

    function nodeBackendLocationEstimateCacheTtlMs() {{
      const pollMs = Number(refreshMs) || 0;
      return Math.max(30000, pollMs * 8);
    }}

    function nodeBackendLocationEstimateCityCacheKey(location) {{
      if (!location || typeof location !== "object") return "";
      const lat = Number(location.lat);
      const lon = Number(location.lon);
      if (!isValidLatLonRange(lat, lon)) return "";
      return `${{lat.toFixed(4)}},${{lon.toFixed(4)}}`;
    }}

    function normalizeBackendLocationEstimate(raw) {{
      if (!raw || typeof raw !== "object") return null;
      const nodeId = normalizeNodeId(raw.node_id || raw.nodeId || raw.id || "");
      if (!isSelectableNodeId(nodeId)) return null;
      const lat = Number(raw.lat ?? raw.estimated_lat ?? raw.estimatedLat);
      const lon = Number(raw.lon ?? raw.estimated_lon ?? raw.estimatedLon);
      const location = resolveNodeCityLocationFromCoords(lat, lon);
      if (!location) return null;
      const confidence = Number(raw.confidence);
      const anchorCount = Number(raw.anchor_count ?? raw.anchorCount);
      const fitScore = Number(raw.fit_score ?? raw.fitScore);
      const estimate = {{
        lat: location.lat,
        lon: location.lon,
        confidence: Number.isFinite(confidence) ? confidence : 0,
        rawConfidence: Number.isFinite(confidence) ? confidence : 0,
        anchorCount: Number.isFinite(anchorCount) ? Math.max(0, Math.trunc(anchorCount)) : 0,
        supportLinks: Number(raw.support_links ?? raw.supportLinks) || 0,
        signalSamples: Number(raw.signal_samples ?? raw.signalSamples) || 0,
        avgLinkQuality: Number(raw.avg_link_quality ?? raw.avgLinkQuality) || 0,
        avgPositionQuality: Number(raw.avg_position_quality ?? raw.avgPositionQuality) || 0,
        fitScore: Number.isFinite(fitScore) ? fitScore : 0,
        residualKm: raw.residual_km ?? raw.residualKm ?? null,
        residualRatio: raw.residual_ratio ?? raw.residualRatio ?? null,
        avgSnr: raw.avg_snr ?? raw.avgSnr ?? null,
        avgRssi: raw.avg_rssi ?? raw.avgRssi ?? null,
        avgHops: raw.avg_hops ?? raw.avgHops ?? null,
        estimateSource: String(raw.estimate_source || raw.estimateSource || raw.source || "rssi_trilateration").trim() || "rssi_trilateration",
        source: "backend",
        window: String(raw.window || "").trim(),
        city: String(raw.city || "").trim(),
        cityDistanceKm: raw.city_distance_km ?? raw.cityDistanceKm ?? null,
      }};
      return [nodeId, estimate];
    }}

    function seedBackendLocationEstimateCityCache(estimates) {{
      if (!(estimates instanceof Map) || !(nodeCityHintCache instanceof Map)) return;
      for (const estimate of estimates.values()) {{
        const city = String(estimate && estimate.city || "").trim();
        if (!city) continue;
        const key = nodeBackendLocationEstimateCityCacheKey(estimate);
        if (key) nodeCityHintCache.set(key, city);
      }}
    }}

    function backendLocationEstimateSignature(estimates) {{
      if (!(estimates instanceof Map) || !estimates.size) return "0";
      return Array.from(estimates.entries())
        .map(([nodeId, estimate]) => {{
          const lat = Number(estimate && estimate.lat);
          const lon = Number(estimate && estimate.lon);
          const confidence = Number(estimate && estimate.confidence);
          const samples = Number(estimate && estimate.signalSamples);
          return [
            normalizeNodeId(nodeId),
            Number.isFinite(lat) ? lat.toFixed(5) : "",
            Number.isFinite(lon) ? lon.toFixed(5) : "",
            Number.isFinite(confidence) ? String(Math.round(confidence * 1000)) : "",
            Number.isFinite(samples) ? String(Math.trunc(samples)) : "",
          ].join(":");
        }})
        .sort()
        .join("|");
    }}

    function updateBackendLocationEstimateSignature(windowName, estimates) {{
      if (!(nodeBackendLocationEstimateSignatureCache instanceof Map)) {{
        nodeBackendLocationEstimateSignatureCache = new Map();
      }}
      const previous = String(nodeBackendLocationEstimateSignatureCache.get(windowName) || "");
      const next = backendLocationEstimateSignature(estimates);
      nodeBackendLocationEstimateSignatureCache.set(windowName, next);
      return previous !== next;
    }}

    function invalidateNodeLinkedLocationEstimateCache() {{
      nodeLinkedLocationEstimateCacheState = null;
      nodeLinkedLocationEstimateCacheMode = "";
      nodeLinkedLocationEstimateCacheValue = new Map();
      if (typeof invalidateNetworkGraphRenderCache === "function") {{
        try {{ invalidateNetworkGraphRenderCache(); }} catch (_err) {{}}
      }}
    }}

    function refreshLocationEstimateViews() {{
      invalidateNodeLinkedLocationEstimateCache();
      if (!latestState || typeof latestState !== "object") return;
      try {{
        if (
          activeLayoutView === "network"
          && typeof renderNetworkGraphView === "function"
        ) {{
          renderNetworkGraphView(latestState);
        }} else if (
          typeof renderMap === "function"
          && activeLayoutView === "map"
        ) {{
          renderMap(latestState.nodes || [], ((latestState.traffic || {{}}).edges || []), null);
        }} else if (typeof syncNodesTableForView === "function") {{
          syncNodesTableForView(activeLayoutView, activeNetworkSubview, latestState.nodes || []);
        }}
      }} catch (_err) {{}}
    }}

    function ensureBackendLocationEstimates(modeRaw, options = null) {{
      const opts = (options && typeof options === "object") ? options : {{}};
      const windowName = nodeBackendLocationEstimateWindow(opts.backendWindow || modeRaw || "72h");
      const limit = Math.max(1, Math.min(3000, Math.trunc(Number(opts.limit) || 600)));
      const force = !!opts.force;
      if (!(nodeBackendLocationEstimateCache instanceof Map)) nodeBackendLocationEstimateCache = new Map();
      if (!(nodeBackendLocationEstimateFetchedAtMs instanceof Map)) nodeBackendLocationEstimateFetchedAtMs = new Map();
      if (!(nodeBackendLocationEstimateRequests instanceof Map)) nodeBackendLocationEstimateRequests = new Map();
      if (!force && nodeBackendLocationEstimateCache.has(windowName)) {{
        const fetchedAtMs = Number(nodeBackendLocationEstimateFetchedAtMs.get(windowName) || 0);
        if (Number.isFinite(fetchedAtMs) && fetchedAtMs > 0 && (Date.now() - fetchedAtMs) < nodeBackendLocationEstimateCacheTtlMs()) {{
          return;
        }}
      }}
      if (nodeBackendLocationEstimateRequests.has(windowName)) return;
      const params = new URLSearchParams();
      params.set("window", windowName);
      params.set("limit", String(limit));
      const request = fetch(`/api/history/location_estimates?${{params.toString()}}`, {{ cache: "no-store" }})
        .then((resp) => resp.ok ? resp.json() : Promise.reject(new Error(`HTTP ${{resp.status}}`)))
        .then((payload) => {{
          const estimates = new Map();
          const rawEstimates = payload && Array.isArray(payload.estimates) ? payload.estimates : [];
          for (const raw of rawEstimates) {{
            const normalized = normalizeBackendLocationEstimate(raw);
            if (normalized) estimates.set(normalized[0], normalized[1]);
          }}
          nodeBackendLocationEstimateCache.set(windowName, estimates);
          nodeBackendLocationEstimateFetchedAtMs.set(windowName, Date.now());
          seedBackendLocationEstimateCityCache(estimates);
          if (updateBackendLocationEstimateSignature(windowName, estimates)) {{
            refreshLocationEstimateViews();
          }}
        }})
        .catch((_err) => {{
          const estimates = new Map();
          nodeBackendLocationEstimateCache.set(windowName, estimates);
          nodeBackendLocationEstimateFetchedAtMs.set(windowName, Date.now());
          if (updateBackendLocationEstimateSignature(windowName, estimates)) {{
            refreshLocationEstimateViews();
          }}
        }})
        .finally(() => {{
          nodeBackendLocationEstimateRequests.delete(windowName);
        }});
      nodeBackendLocationEstimateRequests.set(windowName, request);
    }}

    function backendLocationEstimatesForState(_state = latestState, options = null) {{
      const opts = (options && typeof options === "object") ? options : {{}};
      const windowName = nodeBackendLocationEstimateWindow(opts.backendWindow || opts.mode || opts.estimateMode || "72h");
      ensureBackendLocationEstimates(windowName, opts);
      const cached = (nodeBackendLocationEstimateCache instanceof Map)
        ? nodeBackendLocationEstimateCache.get(windowName)
        : null;
      return cached instanceof Map ? cached : new Map();
    }}

    function nodeLinkedLocationEstimatesForState(state = latestState, options = null) {{
      const safeState = (state && typeof state === "object") ? state : {{}};
      const opts = (options && typeof options === "object") ? options : {{}};
      const mode = normalizeNodeCityEstimateMode(opts.mode, "both");
      const backendWindow = nodeBackendLocationEstimateWindow(opts.backendWindow || mode);
      const backendFetchedAtMs = (nodeBackendLocationEstimateFetchedAtMs instanceof Map)
        ? Number(nodeBackendLocationEstimateFetchedAtMs.get(backendWindow) || 0)
