    function fileTransferMissingChunkIndexes(totalChunks, receivedSet) {{
      const total = Math.max(1, Math.trunc(Number(totalChunks) || 1));
      const seen = receivedSet instanceof Set ? receivedSet : new Set();
      const missing = [];
      for (let idx = 0; idx < total; idx += 1) {{
        if (!seen.has(idx)) {{
          missing.push(idx);
        }}
      }}
      return missing;
    }}

    function findAckForOutgoingSession(session, ackByTransferKey, localNodeId) {{
      if (!session || !(ackByTransferKey instanceof Map)) return null;
      const senderId = normalizeNodeId(localNodeId || session.senderId || "");
      const expectedReceiver = normalizeNodeId(session.destination || "");
      const expectedChannel = fileTransferExplicitChannelIndex(session.channelIndex);
      const expectedTotalChunks = Math.trunc(Number(session.totalChunks));
      const ackWatermarkUnix = Math.max(0, Math.trunc(Number(session.ackWatermarkUnix) || 0));
      if (
        !isCanonicalNodeId(senderId)
        || !isCanonicalNodeId(expectedReceiver)
        || expectedReceiver === senderId
        || expectedChannel == null
        || !Number.isInteger(expectedTotalChunks)
        || expectedTotalChunks <= 0
      ) return null;
      const directKey = fileTransferKeyOf(
        senderId,
        expectedReceiver,
        session.transferId,
        expectedChannel
      );
      const ack = ackByTransferKey.get(directKey) || null;
      if (!(ack && typeof ack === "object")) return null;
      if (String(ack.transferId || "") !== String(session.transferId || "")) return null;
      if (normalizeNodeId(ack.originalSenderId || "") !== senderId) return null;
      if (normalizeNodeId(ack.originalReceiverId || "") !== expectedReceiver) return null;
      if (fileTransferExplicitChannelIndex(ack.channelIndex) !== expectedChannel) return null;
      if (Math.trunc(Number(ack.totalChunks)) !== expectedTotalChunks) return null;
      if (ackWatermarkUnix > 0) {{
        const ackUnix = Math.max(0, Math.trunc(Number(ack.latestUnix) || 0));
        if (ackUnix < ackWatermarkUnix) return null;
      }}
      return ack;
    }}
