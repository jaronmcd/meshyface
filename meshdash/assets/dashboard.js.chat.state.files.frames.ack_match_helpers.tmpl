    function fileTransferMissingChunkIndexes(totalChunks, receivedSet) {{
      const total = Math.max(1, Math.trunc(Number(totalChunks) || 1));
      const seen = receivedSet instanceof Set ? receivedSet : new Set();
      const missing = [];
      for (let idx = 0; idx < total; idx += 1) {{
        if (!seen.has(idx)) {{
          missing.push(idx);
        }}
      }}
      return missing;
    }}

    function findAckForOutgoingSession(session, ackByTransferKey, localNodeId) {{
      if (!session || !(ackByTransferKey instanceof Map)) return null;
      const senderId = normalizeNodeId(localNodeId || session.senderId || "");
      const expectedReceiver = normalizeNodeId(session.destination || "");
      const expectedChannel = fileTransferExplicitChannelIndex(session.channelIndex);
      const expectedTotalChunks = Math.trunc(Number(session.totalChunks));
      const ackWatermarkUnix = Math.max(0, Math.trunc(Number(session.ackWatermarkUnix) || 0));
      if (
        !isCanonicalNodeId(senderId)
        || !isCanonicalNodeId(expectedReceiver)
        || expectedReceiver === senderId
        || expectedChannel == null
        || !Number.isInteger(expectedTotalChunks)
        || expectedTotalChunks <= 0
      ) return null;
      const directKey = fileTransferKeyOf(
        senderId,
        expectedReceiver,
        session.transferId,
        expectedChannel
      );
      const matchesSession = (ack, requireChannel = true) => {{
        if (!(ack && typeof ack === "object")) return false;
        if (String(ack.transferId || "") !== String(session.transferId || "")) return false;
        if (normalizeNodeId(ack.originalSenderId || "") !== senderId) return false;
        if (normalizeNodeId(ack.originalReceiverId || "") !== expectedReceiver) return false;
        if (Math.trunc(Number(ack.totalChunks)) !== expectedTotalChunks) return false;
        if (requireChannel && fileTransferExplicitChannelIndex(ack.channelIndex) !== expectedChannel) return false;
        if (ackWatermarkUnix > 0) {{
          const ackUnix = Math.max(0, Math.trunc(Number(ack.latestUnix) || 0));
          if (ackUnix < ackWatermarkUnix) return false;
        }}
        return true;
      }};
      const directAck = ackByTransferKey.get(directKey) || null;
      if (matchesSession(directAck, true)) return directAck;
      // The backend is authoritative about the physical channel used. A UI
      // preference can be normalized (for example global -> Ch 0) while the
      // in-memory session still carries the pre-normalized value. Endpoints,
      // transfer ID, chunk count, and watermark make this fallback unambiguous.
      let fallbackAck = null;
      for (const candidate of ackByTransferKey.values()) {{
        if (!matchesSession(candidate, false)) continue;
        if (!fallbackAck || Number(candidate.latestUnix || 0) > Number(fallbackAck.latestUnix || 0)) {{
          fallbackAck = candidate;
        }}
      }}
      return fallbackAck;
    }}
