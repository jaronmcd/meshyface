    async function saveSelectedPingBotSettings() {{
      const commandName = String(activeBotCommandSettingsId || "").trim().toLowerCase();
      if (commandName !== "ping") return false;
      const triggersInput = document.getElementById("bots-command-ping-triggers");
      const responseTemplateInput = document.getElementById("bots-command-ping-response-template");
      const triggers = normalizeBotSettingsTextList(
        triggersInput instanceof HTMLTextAreaElement ? triggersInput.value : "",
        {{ splitCommas: true }}
      );
      const responseTemplate = String(
        responseTemplateInput instanceof HTMLInputElement ? responseTemplateInput.value : ""
      ).trim().slice(0, 240);
      const ok = await saveServerBotSettingsPatch({{
        ping_triggers: triggers,
        ping_response_template: responseTemplate,
      }});
      if (!ok) {{
        renderBotsView(latestState);
        return false;
      }}
      return true;
    }}

    async function saveSelectedZorkBotSettings() {{
      const commandName = String(activeBotCommandSettingsId || "").trim().toLowerCase();
      if (commandName !== "zork") return false;
