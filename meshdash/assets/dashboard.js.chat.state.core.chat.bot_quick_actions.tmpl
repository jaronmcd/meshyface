      return true;
    }}

    async function saveSelectedJokeBotSettings() {{
      const commandName = String(activeBotCommandSettingsId || "").trim().toLowerCase();
      if (commandName !== "joke") return false;
      const triggersInput = document.getElementById("bots-command-joke-triggers");
      const linesInput = document.getElementById("bots-command-joke-lines");
      const nearGuessLinesInput = document.getElementById("bots-command-joke-near-guess-lines");
      const delayPunchlineInput = document.getElementById("bots-command-joke-delay-punchline-enabled");
      const triggers = normalizeBotSettingsTextList(
        triggersInput instanceof HTMLTextAreaElement ? triggersInput.value : "",
        {{ splitCommas: true }}
      );
      const jokeLines = normalizeBotSettingsTextList(
        linesInput instanceof HTMLTextAreaElement ? linesInput.value : "",
        {{ splitCommas: false }}
      );
      const jokeNearGuessLines = normalizeBotSettingsTextList(
        nearGuessLinesInput instanceof HTMLTextAreaElement ? nearGuessLinesInput.value : "",
        {{ splitCommas: false }}
      );
      const ok = await saveServerBotSettingsPatch({{
        joke_triggers: triggers,
        joke_lines: jokeLines,
        joke_near_guess_lines: jokeNearGuessLines,
        joke_delay_punchline_enabled: !!(
          delayPunchlineInput instanceof HTMLInputElement
          ? delayPunchlineInput.checked
          : false
        ),
      }});
      if (!ok) {{
        renderBotsView(latestState);
        return false;
      }}
      return true;
    }}

    function bindBotCommandCatalogControls() {{
      const masterInput = document.getElementById("bots-command-master-enabled");
      if (masterInput instanceof HTMLInputElement && masterInput.dataset.bound !== "1") {{
        masterInput.dataset.bound = "1";
        masterInput.addEventListener("change", async () => {{
          const nextValue = !!masterInput.checked;
          const ok = await saveServerBotSettingsPatch({{ enabled: nextValue }});
          if (!ok) {{
            masterInput.checked = !!serverBotSettings.enabled;
          }}
          syncChatWhoisQuickActionControls();
        }});
      }}
      const hardDisableAllInput = document.getElementById("bots-command-hard-disable-all");
      if (hardDisableAllInput instanceof HTMLInputElement && hardDisableAllInput.dataset.bound !== "1") {{
        hardDisableAllInput.dataset.bound = "1";
        hardDisableAllInput.addEventListener("change", async () => {{
          const nextList = hardDisableAllInput.checked ? ["all"] : [];
          const ok = await saveServerBotSettingsPatch({{
            hard_disabled_incoming_commands: nextList,
          }});
          if (!ok) {{
            hardDisableAllInput.checked = hardDisableIncomingAutomationAndFileTransferEnabled();
          }}
          syncChatWhoisQuickActionControls();
        }});
      }}
      const list = document.getElementById("bots-command-list");
      if (list instanceof HTMLElement && list.dataset.bound !== "1") {{
        list.dataset.bound = "1";
        list.addEventListener("click", (event) => {{
          const target = event.target;
          if (!(target instanceof Element)) return;
          const item = target.closest(".bots-command-item");
          if (!(item instanceof HTMLButtonElement)) return;
          const commandName = String(item.dataset.commandName || "").trim().toLowerCase();
          if (!commandName) return;
          activeBotCommandSettingsId = commandName;
          renderManagedBotCommandList();
          syncChatWhoisQuickActionControls();
        }});
      }}
      const selectedEnabledInput = document.getElementById("bots-command-selected-enabled");
      if (selectedEnabledInput instanceof HTMLInputElement && selectedEnabledInput.dataset.bound !== "1") {{
        selectedEnabledInput.dataset.bound = "1";
        selectedEnabledInput.addEventListener("change", async () => {{
          const commandName = String(activeBotCommandSettingsId || "").trim().toLowerCase();
          if (!commandName) return;
          const ok = await saveServerBotSettingsPatch({{
            command_settings: {{
              [commandName]: !!selectedEnabledInput.checked,
            }},
          }});
          if (!ok) {{
            renderBotsView(latestState);
            return;
          }}
          syncChatWhoisQuickActionControls();
        }});
      }}
      const selectedPublicStartInput = document.getElementById("bots-command-selected-public-start-enabled");
      if (selectedPublicStartInput instanceof HTMLInputElement && selectedPublicStartInput.dataset.bound !== "1") {{
        selectedPublicStartInput.dataset.bound = "1";
        selectedPublicStartInput.addEventListener("change", async () => {{
          const ok = await saveServerBotSettingsPatch({{
            game_public_start_enabled: !!selectedPublicStartInput.checked,
          }});
          if (!ok) {{
            renderBotsView(latestState);
            return;
          }}
          syncChatWhoisQuickActionControls();
        }});
      }}
      const pingSaveBtn = document.getElementById("bots-command-ping-save-btn");
      if (pingSaveBtn instanceof HTMLButtonElement && pingSaveBtn.dataset.bound !== "1") {{
        pingSaveBtn.dataset.bound = "1";
        pingSaveBtn.addEventListener("click", async () => {{
          await saveSelectedPingBotSettings();
          syncChatWhoisQuickActionControls();
        }});
      }}
      const zorkSaveBtn = document.getElementById("bots-command-zork-save-btn");
      if (zorkSaveBtn instanceof HTMLButtonElement && zorkSaveBtn.dataset.bound !== "1") {{
        zorkSaveBtn.dataset.bound = "1";
        zorkSaveBtn.addEventListener("click", async () => {{
          await saveSelectedZorkBotSettings();
          syncChatWhoisQuickActionControls();
        }});
      }}
      const jokeSaveBtn = document.getElementById("bots-command-joke-save-btn");
      if (jokeSaveBtn instanceof HTMLButtonElement && jokeSaveBtn.dataset.bound !== "1") {{
        jokeSaveBtn.dataset.bound = "1";
        jokeSaveBtn.addEventListener("click", async () => {{
          await saveSelectedJokeBotSettings();
          syncChatWhoisQuickActionControls();
        }});
      }}
      const jokeDelayPunchlineInput = document.getElementById("bots-command-joke-delay-punchline-enabled");
      if (jokeDelayPunchlineInput instanceof HTMLInputElement && jokeDelayPunchlineInput.dataset.bound !== "1") {{
        jokeDelayPunchlineInput.dataset.bound = "1";
        jokeDelayPunchlineInput.addEventListener("change", async () => {{
          await saveSelectedJokeBotSettings();
          syncChatWhoisQuickActionControls();
        }});
      }}
    }}
