    function normalizeWhoisCommandPrefix(value) {{
      const clean = String(value || "").trim().toLowerCase();
      return knownWhoisCommandPrefixes.has(clean) ? clean : "whois";
    }}

    function nodeIdSuffixForWhois(nodeId) {{
      const clean = String(nodeId || "").replace(/[^a-z0-9]/gi, "").toLowerCase();
      if (!clean) return "";
      return clean.slice(-4);
    }}

    function buildWhoisCommandForNode(nodeId, prefixValue = chatWhoisQuickActionPrefix) {{
      const prefix = normalizeWhoisCommandPrefix(prefixValue);
      const suffix = nodeIdSuffixForWhois(nodeId);
      if (!suffix) return prefix;
      return `${{prefix}} ${{suffix}}`;
    }}

    function normalizeServerBotCommand(raw) {{
      if (!raw || typeof raw !== "object" || Array.isArray(raw)) return null;
      const name = String(raw.name || raw.command || "").trim().toLowerCase();
      if (!name) return null;
      const usage = String(raw.usage || name).trim() || name;
      const description = String(raw.description || "").trim();
      const kindRaw = String(raw.kind || "builtin").trim().toLowerCase();
      const kind = kindRaw === "custom"
        ? "custom"
        : (kindRaw === "game" ? "game" : "builtin");
      return {{
        name,
        usage,
        description,
        kind,
        enabled: parseBoolToken(raw.enabled, true),
      }};
    }}

    function normalizeBotSettingsTextList(value, {{ splitCommas = false }} = {{}}) {{
      let rawItems = [];
      if (Array.isArray(value)) {{
        rawItems = value;
      }} else {{
        let normalized = String(value || "").replace(/;/g, "\n");
        if (splitCommas) {{
          normalized = normalized.replace(/,/g, "\n");
        }}
        rawItems = normalized.split(/\r?\n/);
      }}
      const out = [];
      const seen = new Set();
      for (const rawItem of rawItems) {{
        const clean = String(rawItem || "").trim();
        if (!clean) continue;
        const key = clean.toLowerCase();
        if (seen.has(key)) continue;
        seen.add(key);
        out.push(clean);
      }}
      return out;
    }}

    function normalizeServerBotSettings(raw) {{
      if (!raw || typeof raw !== "object" || Array.isArray(raw)) {{
        return {{
          available: false,
          enabled: true,
          log_enabled: true,
          game_enabled: false,
          game_public_start_enabled: false,
          hard_disabled_incoming_commands: [],
          ping_triggers: [],
          ping_response_template: "",
          joke_triggers: [],
          zork_triggers: [],
          joke_lines: [],
          joke_near_guess_lines: [],
          joke_delay_punchline_enabled: false,
          active_game_sessions: 0,
          commands: [],
          disabled_commands: [],
        }};
      }}
      const sessionsRaw = Number(raw.active_game_sessions ?? raw.activeGameSessions ?? 0);
      const commandsRaw = Array.isArray(raw.commands) ? raw.commands : [];
      const commands = [];
      const seen = new Set();
      for (const row of commandsRaw) {{
        const normalized = normalizeServerBotCommand(row);
        if (!normalized || seen.has(normalized.name)) continue;
        commands.push(normalized);
        seen.add(normalized.name);
      }}
      const disabledRaw = Array.isArray(raw.disabled_commands ?? raw.disabledCommands)
        ? (raw.disabled_commands ?? raw.disabledCommands)
        : [];
      const disabledCommands = [];
      const disabledSeen = new Set();
      for (const value of disabledRaw) {{
        const clean = String(value || "").trim().toLowerCase();
        if (!clean || disabledSeen.has(clean)) continue;
        disabledCommands.push(clean);
        disabledSeen.add(clean);
      }}
      return {{
        available: true,
        enabled: parseBoolToken(raw.enabled, true),
        log_enabled: parseBoolToken(raw.log_enabled ?? raw.logEnabled, true),
        game_enabled: parseBoolToken(raw.game_enabled ?? raw.gameEnabled, false),
        game_public_start_enabled: parseBoolToken(
          raw.game_public_start_enabled ?? raw.gamePublicStartEnabled,
          false
        ),
        hard_disabled_incoming_commands: normalizeBotSettingsTextList(
          raw.hard_disabled_incoming_commands ?? raw.hardDisabledIncomingCommands,
          {{ splitCommas: true }}
        ),
        ping_triggers: normalizeBotSettingsTextList(
          raw.ping_triggers ?? raw.pingTriggers,
          {{ splitCommas: true }}
        ),
        ping_response_template: String(
          raw.ping_response_template ?? raw.pingResponseTemplate ?? ""
        ).trim().slice(0, 240),
        joke_triggers: normalizeBotSettingsTextList(
          raw.joke_triggers ?? raw.jokeTriggers,
          {{ splitCommas: true }}
        ),
        zork_triggers: normalizeBotSettingsTextList(
          raw.zork_triggers ?? raw.zorkTriggers,
          {{ splitCommas: true }}
        ),
        joke_lines: normalizeBotSettingsTextList(
          raw.joke_lines ?? raw.jokeLines,
          {{ splitCommas: false }}
        ),
        joke_near_guess_lines: normalizeBotSettingsTextList(
          raw.joke_near_guess_lines ?? raw.jokeNearGuessLines,
          {{ splitCommas: false }}
        ),
        joke_delay_punchline_enabled: parseBoolToken(
          raw.joke_delay_punchline_enabled ?? raw.jokeDelayPunchlineEnabled,
          false
        ),
        active_game_sessions: Number.isFinite(sessionsRaw) && sessionsRaw >= 0 ? Math.trunc(sessionsRaw) : 0,
        commands,
        disabled_commands: disabledCommands,
      }};
    }}

    function applyServerBotSettingsFromState(state = latestState) {{
      const normalized = normalizeServerBotSettings(state && state.bot_settings);
      serverBotSettings = normalized;
      return normalized.available;
    }}

    function hardDisableIncomingAutomationAndFileTransferEnabled() {{
      const hardDisabled = Array.isArray(serverBotSettings.hard_disabled_incoming_commands)
        ? serverBotSettings.hard_disabled_incoming_commands.map((item) => String(item || "").trim().toLowerCase()).filter(Boolean)
        : [];
      return hardDisabled.includes("all");
    }}

    async function saveServerBotSettingsPatch(patch = {{}}, { quiet = false } = {{}}) {{
      if (!patch || typeof patch !== "object") {{
        return false;
      }}
      botSettingsSaveInFlight = true;
      syncChatWhoisQuickActionControls();
      try {{
        const resp = await fetch(botSettingsEndpoint, {{
          method: "POST",
          headers: {{ "Content-Type": "application/json" }},
          body: JSON.stringify(patch),
        }});
        const payload = await resp.json().catch(() => ({{ ok: false, error: `API ${{resp.status}}` }}));
        if (!resp.ok || !payload || payload.ok === false) {{
          const message = payload && payload.error ? payload.error : `API ${{resp.status}}`;
          throw new Error(String(message));
        }}
        serverBotSettings = normalizeServerBotSettings(payload);
        if (!quiet) {{
          setChatSendStatus(
            "Bot settings updated.",
            false
          );
        }}
        if (latestState && typeof latestState === "object") {{
          latestState.bot_settings = {{ ...payload }};
        }}
        if (activeLayoutView === "bots") {{
          renderBotsView(latestState);
        }}
        return true;
      }} catch (err) {{
        const msg = err instanceof Error ? err.message : String(err || "unknown error");
        if (!quiet) {{
          setChatSendStatus(`Failed to update bot settings: ${{msg}}`, true);
        }}
        appendConsoleLine(`bot-settings-save|${{Date.now()}}|${{msg}}`, `[bot settings] save failed: ${{msg}}`);
      }} finally {{
        botSettingsSaveInFlight = false;
        syncChatWhoisQuickActionControls();
      }}
      return false;
    }}

