    function ensureFileTransferInboundDecisionStateLoaded() {{
      if (fileTransferInboundDecisionLoaded) return;
      fileTransferInboundDecisionLoaded = true;
      try {{
        const raw = String(window.localStorage.getItem(fileTransferInboundDecisionStorageKey) || "");
        if (!raw) return;
        const parsed = JSON.parse(raw);
        if (!Array.isArray(parsed)) return;
        const nowMs = Date.now();
        const staleDecisionMs = 75 * 60 * 1000;
        for (const item of parsed) {{
          if (!(item && typeof item === "object")) continue;
          const transferKey = String(item.transferKey || "").trim();
          if (!transferKey) continue;
          const decision = normalizeFileTransferInboundDecision(item.decision);
          if (!decision) continue;
          const updatedAtMs = Math.max(0, Math.trunc(Number(item.updatedAtMs) || 0));
          if (updatedAtMs > 0 && (nowMs - updatedAtMs) > staleDecisionMs) {{
            continue;
          }}
          fileTransferInboundDecisionByKey.set(transferKey, {{
            transferKey,
            decision,
            transferId: String(item.transferId || "").trim().toLowerCase(),
            senderId: normalizeNodeId(item.senderId || ""),
            receiverId: normalizeNodeId(item.receiverId || ""),
            fileName: normalizeFileTransferName(item.fileName || "mesh-file.bin"),
            totalChunks: Math.max(0, Math.trunc(Number(item.totalChunks) || 0)),
            decidedAtMs: Math.max(0, Math.trunc(Number(item.decidedAtMs) || updatedAtMs || nowMs)),
            updatedAtMs,
          }});
          if (fileTransferInboundDecisionByKey.size >= 1200) {{
            break;
          }}
        }}
      }} catch (_err) {{
      }}
    }}

    function persistFileTransferInboundDecisionState() {{
      try {{
