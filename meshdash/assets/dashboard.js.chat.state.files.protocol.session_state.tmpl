    function normalizeFileTransferInboundFlowState(rawState) {{
      const clean = String(rawState || "").trim().toLowerCase();
      if (clean === "paused") return "paused";
      if (clean === "canceled-by-sender") return "canceled-by-sender";
      if (clean === "canceled-by-receiver") return "canceled-by-receiver";
