      const clean = String(rawValue).trim().toLowerCase();
      if (!clean) return !!fallback;
      if (clean === "1" || clean === "true" || clean === "yes" || clean === "on") return true;
      if (clean === "0" || clean === "false" || clean === "no" || clean === "off") return false;
      return !!fallback;
