        autoRestartCount: Math.max(0, Math.trunc(Number(session.autoRestartCount) || 0)),
        maxAutoRestarts: Math.max(
          0,
          Math.trunc(Number(session.maxAutoRestarts) || fileTransferAutoRestartMaxCount)
        ),
        lastAutoRestartAtMs: Math.max(0, Math.trunc(Number(session.lastAutoRestartAtMs) || 0)),
        pausedForPeerOffline: !!session.pausedForPeerOffline,
        userPaused: !!session.userPaused,
        pausedByReceiver: !!session.pausedByReceiver,
        pausedAtMs: Math.max(0, Math.trunc(Number(session.pausedAtMs) || 0)),
        lastPauseLogAtMs: Math.max(0, Math.trunc(Number(session.lastPauseLogAtMs) || 0)),
        lastPeerFreshness: String(session.lastPeerFreshness || "").trim().toLowerCase(),
        lastPeerSeenUnix: Math.max(0, Math.trunc(Number(session.lastPeerSeenUnix) || 0)),
        receiverPausedAtMs: Math.max(0, Math.trunc(Number(session.receiverPausedAtMs) || 0)),
        lastReceiverFlowUnix: Math.max(0, Math.trunc(Number(session.lastReceiverFlowUnix) || 0)),
        delivered: false,
        failed: false,
        canceled: false,
        canceledByReceiver: false,
        deliveredAtMs: 0,
        failedAtMs: 0,
        waitingForAccept: !!session.waitingForAccept,
        acceptedAtMs: Math.max(0, Math.trunc(Number(session.acceptedAtMs) || 0)),
        acceptProbeAttempts: Math.max(0, Math.trunc(Number(session.acceptProbeAttempts) || 0)),
        lastAcceptProbeAtMs: Math.max(0, Math.trunc(Number(session.lastAcceptProbeAtMs) || 0)),
        sentChunks: Math.max(
          0,
          Math.min(totalChunks, Math.trunc(Number(session.sentChunks) || 0))
        ),
        ackedChunks: 0,
        srttMs: Math.max(0, Number(session.srttMs) || 0),
        rttvarMs: Math.max(0, Number(session.rttvarMs) || 0),
        rtoMs: Math.max(
          fileTransferRtoMinMs,
          Math.min(
            fileTransferRtoMaxMs,
            Math.trunc(Number(session.rtoMs) || fileTransferRtoInitialMs)
          )
        ),
        cwndChunks: Math.max(
          fileTransferCwndMinChunks,
          Math.min(
            fileTransferCwndMaxChunks,
            Number(session.cwndChunks) || fileTransferCwndInitialChunks
          )
        ),
        ssthreshChunks: Math.max(
          fileTransferCwndMinChunks,
