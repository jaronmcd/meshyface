            senderId: normalizeNodeId(entry.senderId || ""),
            receiverId: normalizeNodeId(entry.receiverId || ""),
            fileName: normalizeFileTransferName(entry.fileName || "mesh-file.bin"),
            totalChunks: Math.max(0, Math.trunc(Number(entry.totalChunks) || 0)),
