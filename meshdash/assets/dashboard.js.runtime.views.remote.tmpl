    function bbsRemoveDirectoryRowByKey(boardKey, options = null) {{
      const clean = String(boardKey || "").trim().toLowerCase();
      if (!clean) return null;
      const opts = (options && typeof options === "object") ? options : {{}};
      const rows = Array.isArray(bbsDiscoveredBoards) ? bbsDiscoveredBoards : [];
      const removedRow = rows.find((row) => String(row && row.key || "").trim().toLowerCase() === clean) || null;
      bbsDiscoveredBoards = rows.filter((row) => String(row && row.key || "").trim().toLowerCase() !== clean);
      if (opts.clearPosts !== false) {{
        bbsBoardPostsByKey.delete(clean);
      }}
      if (bbsActiveBoardKey === clean) {{
        const fallback = (Array.isArray(bbsDiscoveredBoards) && bbsDiscoveredBoards.length)
          ? String(bbsDiscoveredBoards[0].key || "").trim().toLowerCase()
          : "";
        bbsActiveBoardKey = fallback;
      }}
      if (removedRow && opts.persist !== false) {{
        bbsPersistState();
      }}
      return removedRow;
    }}

    function syncHostedBbsDirectoryEntry(state = latestState, options = null) {{
      if (!(bbsHostState && bbsHostState.enabled)) return;
      const opts = (options && typeof options === "object") ? options : {{}};
      const localId = bbsHostNodeId(state);
      if (!isCanonicalNodeId(localId)) return;
      const previousKey = String(opts.previousKey || "").trim().toLowerCase();
      const nextKey = bbsBoardKey(bbsHostState.board_id, localId);
      if (previousKey && nextKey && previousKey !== nextKey) {{
        bbsRemoveDirectoryRowByKey(previousKey);
      }}
      if (nextKey) {{
        bbsAllowDirectoryKey(nextKey);
      }}
      bbsHostState.host_id = localId;
      const hostKey = bbsUpsertDirectoryRow({{
        board_id: bbsHostState.board_id,
        host_id: localId,
        title: bbsHostState.title,
        motd: bbsHostState.motd,
        channel_index: bbsHostState.channel_index,
        last_seen_unix: Math.max(
          0,
          Math.trunc(Number(bbsHostState.started_unix) || Math.floor(Date.now() / 1000))
        ),
        force: true,
      }});
      if (!bbsActiveBoardKey || (previousKey && bbsActiveBoardKey === previousKey)) {{
        bbsActiveBoardKey = hostKey || nextKey || bbsActiveBoardKey;
      }}
    }}

    function applyBbsHostSettings(settings = null, options = null) {{
      const opts = (options && typeof options === "object") ? options : {{}};
      const previousKey = (bbsHostState && bbsHostState.enabled)
        ? bbsBoardKey(bbsHostState.board_id, bbsHostState.host_id || bbsHostNodeId(latestState))
        : "";
      const next = bbsExportHostSettings(settings);
      if (!(bbsHostState && typeof bbsHostState === "object")) {{
        bbsHostState = createBbsHostState();
      }}
      bbsHostState.title = next.title;
      bbsHostState.board_id = next.board_id;
      bbsHostState.motd = next.motd;
      if (bbsHostState.enabled) {{
        syncHostedBbsDirectoryEntry(latestState, {{ previousKey }});
      }}
      bbsPersistState();
      if (activeLayoutView !== "bbs") return;
      if (opts.renderView === true) {{
        renderBbsView(latestState);
        return;
      }}
      if (opts.render !== false) {{
