      }}
    }}

    function applyBbsHostRuntime(host = null, options = null) {{
      const opts = (options && typeof options === "object") ? options : {{}};
      const previousKey = bbsBoardKey(
        bbsHostState && bbsHostState.board_id,
        bbsHostState && (bbsHostState.host_id || bbsHostNodeId(latestState))
      );
      const next = createBbsHostState(host);
      if (bbsHostSettingsDirty && opts.preserveSettings !== false) {{
        const currentSettings = bbsExportHostSettings();
        next.title = currentSettings.title;
        next.board_id = currentSettings.board_id;
        next.motd = currentSettings.motd;
      }}
      bbsHostState = next;
      const payloadPosts = Array.isArray(opts.posts) ? opts.posts : [];
      const hostKey = bbsBoardKey(bbsHostState.board_id, bbsHostState.host_id);
      const latestPostUnix = payloadPosts.reduce((maxUnix, row) => {{
        const unixValue = Math.max(0, Math.trunc(Number(row && row.unix) || 0));
        return unixValue > maxUnix ? unixValue : maxUnix;
      }}, 0);
      const shouldShowRuntimeHost = !!(hostKey && bbsHostState.enabled);
      if (shouldShowRuntimeHost) {{
        bbsAllowDirectoryKey(hostKey);
        bbsUpsertDirectoryRow({{
          board_id: bbsHostState.board_id,
          host_id: bbsHostState.host_id,
          title: bbsHostState.title,
          motd: bbsHostState.motd,
          channel_index: bbsHostState.channel_index,
          last_seen_unix: Math.max(
            0,
            Math.trunc(Number(bbsHostState.started_unix) || 0),
            latestPostUnix
          ),
          force: true,
        }});
        bbsReplaceBoardPosts(hostKey, payloadPosts);
        if (!bbsActiveBoardKey || (previousKey && bbsActiveBoardKey === previousKey)) {{
          bbsActiveBoardKey = hostKey;
        }}
      }} else {{
        if (previousKey) {{
          bbsRemoveDirectoryRowByKey(previousKey, {{ persist: false }});
        }}
        if (hostKey && hostKey !== previousKey) {{
          bbsRemoveDirectoryRowByKey(hostKey, {{ persist: false }});
        }}
      }}
      bbsPersistState();
      if (activeLayoutView !== "bbs") return;
      if (opts.renderView === true) {{
        renderBbsView(latestState);
        return;
      }}
      if (opts.render !== false) {{
        renderBbsHostControls(latestState);
        renderBbsDirectory(latestState);
        renderBbsTerminal(latestState);
      }}
    }}

    async function fetchBbsHostSettings(options = null) {{
      const opts = (options && typeof options === "object") ? options : {{}};
      const silent = !!opts.silent;
      if (!bbsFeatureEnabled || bbsHostSettingsRemoteAvailable === false) return false;
      if (bbsHostSettingsFetchInFlight) return false;
      if (bbsHostSettingsLoadedOnce && opts.force !== true) return false;
      bbsHostSettingsFetchInFlight = true;
      try {{
        const resp = await fetch(bbsSettingsEndpoint, {{ cache: "no-store" }});
        const rawText = await resp.text();
        let payload = null;
        try {{
          payload = rawText ? JSON.parse(rawText) : null;
        }} catch (_err) {{
          payload = null;
        }}
        if (!resp.ok || !payload || typeof payload !== "object" || payload.ok === false) {{
          const errMsg = payload && payload.error
            ? String(payload.error)
            : (rawText || `HTTP ${{resp.status}}`);
          if (resp.status === 404 || resp.status === 503) {{
            bbsHostSettingsRemoteAvailable = false;
            bbsHostSettingsLoadedOnce = true;
          }}
          if (!silent) {{
            appendConsoleLine(`bbs-settings-load|${{Date.now()}}|error`, `[bbs] settings load failed: ${{errMsg}}`);
          }}
          return false;
        }}
        bbsHostSettingsRemoteAvailable = true;
        bbsHostSettingsLoadedOnce = true;
        const settings = (payload.settings && typeof payload.settings === "object")
          ? payload.settings
          : payload;
        if (!bbsHostSettingsDirty) {{
          applyBbsHostSettings(settings, {{ renderView: activeLayoutView === "bbs" }});
        }}
        return true;
      }} catch (err) {{
        const msg = err instanceof Error ? err.message : String(err || "unknown error");
        if (!silent) {{
          appendConsoleLine(`bbs-settings-load|${{Date.now()}}|error`, `[bbs] settings load error: ${{msg}}`);
        }}
        return false;
      }} finally {{
        bbsHostSettingsFetchInFlight = false;
      }}
    }}

    async function saveBbsHostSettings(options = null) {{
      const opts = (options && typeof options === "object") ? options : {{}};
      const silent = !!opts.silent;
      if (!bbsFeatureEnabled || bbsHostSettingsRemoteAvailable === false) return false;
      clearBbsHostSettingsSaveTimer();
      const settings = bbsExportHostSettings();
      const requestSignature = bbsHostSettingsSignature(settings);
      if (bbsHostSettingsSaveInFlight) {{
        bbsHostSettingsSaveQueued = true;
        return false;
      }}
      bbsHostSettingsSaveInFlight = true;
      try {{
        const resp = await fetch(bbsSettingsEndpoint, {{
          method: "POST",
          headers: {{ "Content-Type": "application/json" }},
          body: JSON.stringify({{ settings }}),
        }});
        const rawText = await resp.text();
        let payload = null;
        try {{
          payload = rawText ? JSON.parse(rawText) : null;
        }} catch (_err) {{
          payload = null;
        }}
        if (!resp.ok || !payload || typeof payload !== "object" || payload.ok === false) {{
          const errMsg = payload && payload.error
            ? String(payload.error)
            : (rawText || `HTTP ${{resp.status}}`);
          if (resp.status === 404 || resp.status === 503) {{
            bbsHostSettingsRemoteAvailable = false;
            bbsHostSettingsLoadedOnce = true;
          }}
          if (!silent) {{
            appendConsoleLine(`bbs-settings-save|${{Date.now()}}|error`, `[bbs] settings save failed: ${{errMsg}}`);
          }}
          return false;
        }}
        bbsHostSettingsRemoteAvailable = true;
        bbsHostSettingsLoadedOnce = true;
        const savedSettings = (payload.settings && typeof payload.settings === "object")
          ? payload.settings
          : settings;
        if (bbsHostSettingsSignature() === requestSignature) {{
          bbsHostSettingsDirty = false;
          applyBbsHostSettings(savedSettings, {{ renderView: !!opts.renderView }});
        }} else {{
          bbsHostSettingsSaveQueued = true;
        }}
        return true;
      }} catch (err) {{
        const msg = err instanceof Error ? err.message : String(err || "unknown error");
        if (!silent) {{
          appendConsoleLine(`bbs-settings-save|${{Date.now()}}|error`, `[bbs] settings save error: ${{msg}}`);
        }}
        return false;
      }} finally {{
        bbsHostSettingsSaveInFlight = false;
        if (bbsHostSettingsSaveQueued && bbsHostSettingsDirty && bbsHostSettingsRemoteAvailable !== false) {{
          bbsHostSettingsSaveQueued = false;
          queueBbsHostSettingsSave(60);
        }} else {{
          bbsHostSettingsSaveQueued = false;
        }}
      }}
    }}

