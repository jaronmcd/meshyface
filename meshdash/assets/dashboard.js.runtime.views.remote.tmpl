    async function postBbsHostCommand(action, options = null) {{
      const opts = (options && typeof options === "object") ? options : {{}};
      const cleanAction = String(action || "").trim().toLowerCase();
      if (!bbsFeatureEnabled || !cleanAction || bbsHostRuntimeRemoteAvailable === false) return null;
      const body = {{ action: cleanAction }};
      if (cleanAction === "start") {{
        body.channel_index = normalizeMeshChannelIndex(
          opts.channel_index == null ? meshChannelEffectiveSendIndexForApp("bbs") : opts.channel_index
        );
        body.settings = bbsExportHostSettings(opts.settings || bbsHostState);
      }} else if (cleanAction === "post") {{
        body.text = String(opts.text == null ? "" : opts.text);
        body.author_name = String(opts.author_name == null ? "" : opts.author_name);
        body.entry_id = String(opts.entry_id == null ? "" : opts.entry_id);
      }}
      try {{
        const resp = await fetch(bbsHostEndpoint, {{
          method: "POST",
          headers: {{ "Content-Type": "application/json" }},
          body: JSON.stringify(body),
        }});
