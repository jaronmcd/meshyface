    function remoteNodeEntriesFromState(state = latestState) {{
      const safeState = (state && typeof state === "object") ? state : {{}};
      const nodes = Array.isArray(safeState.nodes) ? safeState.nodes : [];
      const localId = normalizeNodeId(resolveLocalNodeId(safeState) || "");
      const nowUnix = Math.floor(Date.now() / 1000);
      const entries = [];
      for (const node of nodes) {{
        const nodeId = normalizeNodeId(node && node.id);
        if (!isCanonicalNodeId(nodeId)) continue;
        if (isCanonicalNodeId(localId) && nodeId === localId) continue;
        const displayName = preferredNodeName(node) || nodeNameCache.get(nodeId) || nodeId;
        const role = String((node && node.role) || "").trim();
        const hardware = String((node && node.hardware) || "").trim();
        const hopsRaw = Number(node && node.hops_away);
        const hopsAway = Number.isFinite(hopsRaw) && hopsRaw >= 0 ? Math.trunc(hopsRaw) : null;
        const lastHeardUnix = nodeLastHeardUnix(node);
        const freshness = freshnessStatus(lastHeardUnix, nowUnix);
        const searchText = nodeSearchKeywordText(nodeId, displayName, {{
          node,
          extraValues: [
            role,
            hardware,
          ],
        }});
        entries.push({{
          id: nodeId,
          node,
          displayName,
          role,
          hardware,
          hopsAway,
          lastHeardUnix,
          freshness,
          searchText,
        }});
      }}
      entries.sort((a, b) => {{
        const freshnessDelta = statusRank(a.freshness) - statusRank(b.freshness);
        if (freshnessDelta !== 0) return freshnessDelta;
        const nameDelta = String(a.displayName || "").localeCompare(String(b.displayName || ""), undefined, {{ sensitivity: "base" }});
        if (nameDelta !== 0) return nameDelta;
        return String(a.id || "").localeCompare(String(b.id || ""));
      }});
      return entries;
    }}

    function resolveRemoteTargetNodeId(entries, state = latestState) {{
      const list = Array.isArray(entries) ? entries : [];
      if (!list.length) return "";
      const explicit = normalizeNodeId(remoteTargetNodeId || "");
      if (isCanonicalNodeId(explicit) && list.some((entry) => entry.id === explicit)) {{
        return explicit;
      }}
      const selected = normalizeNodeId(selectedNodeId || "");
      if (isCanonicalNodeId(selected) && list.some((entry) => entry.id === selected)) {{
        return selected;
      }}
      const savedNodeId = normalizeNodeId(resolveSavedViewNodeId(state) || "");
      if (isCanonicalNodeId(savedNodeId) && list.some((entry) => entry.id === savedNodeId)) {{
        return savedNodeId;
      }}
      return String(list[0].id || "");
    }}

    function remoteCapabilityRows(nodeEntry, state = latestState) {{
      if (!nodeEntry || typeof nodeEntry !== "object" || !nodeEntry.node) return [];
      const node = nodeEntry.node;
      const directReady = isCanonicalNodeId(nodeEntry.id) && !isSelfNodeId(nodeEntry.id, state);
      const telemetryKnown = Number.isFinite(nodeEntry.lastHeardUnix) && nodeEntry.lastHeardUnix > 0;
      const telemetryRecent = telemetryKnown && statusRank(nodeEntry.freshness) <= statusRank("warn");
      const hopsKnown = Number.isFinite(nodeEntry.hopsAway) && nodeEntry.hopsAway >= 0;
      const gpsCapability = coerceOptionalBool(firstNestedValue([node], [
        "gps_capable",
        "position.gps_capable",
        "position_available",
        "position.available",
      ]));
      const lat = firstFiniteNestedNumber([node], ["lat", "latitude", "position.lat", "position.latitude"]);
      const lon = firstFiniteNestedNumber([node], ["lon", "longitude", "position.lon", "position.longitude"]);
      const hasPositionHint = (gpsCapability === true) || (lat != null && lon != null);
      const batteryLevel = firstFiniteNestedNumber([node], [
        "battery_level",
        "device_metrics.battery_level",
        "device_metrics.batteryLevel",
        "power.battery_level",
      ]);
      const hasBatteryHint = batteryLevel != null;
      return [
        {{
          title: "Direct messages",
          status: directReady ? "ready" : "blocked",
          detail: directReady
            ? "This node can be targeted from the message popup."
            : "This entry is not a direct-message target yet.",
        }},
        {{
          title: "Live telemetry",
          status: telemetryRecent ? "ready" : (telemetryKnown ? "partial" : "blocked"),
          detail: telemetryKnown
            ? `Last seen: ${{formatLocalChatTime(nodeEntry.lastHeardUnix, "n/a")}} (${{nodeEntry.freshness}}).`
            : "No recent telemetry timestamp is available for this node.",
        }},
        {{
          title: "Route awareness",
          status: hopsKnown ? "ready" : "partial",
          detail: hopsKnown
            ? `Reported hop distance: ${{nodeEntry.hopsAway}}.`
            : "Hop distance is not currently reported by this node.",
        }},
        {{
          title: "Telemetry metadata",
          status: (hasPositionHint || hasBatteryHint) ? "ready" : "partial",
          detail: (hasPositionHint || hasBatteryHint)
            ? `Position hint: ${{hasPositionHint ? "yes" : "no"}}, battery hint: ${{hasBatteryHint ? "yes" : "no"}}.`
            : "No position or battery hints detected in current node metadata.",
        }},
        {{
          title: "Remote config fetch",
          status: "planned",
          detail: "Config pull/apply for remote nodes is not exposed yet in this dashboard.",
        }},
      ];
    }}

    function remoteCapabilityStatusLabel(status) {{
      const key = String(status || "").trim().toLowerCase();
      if (key === "ready") return "Ready";
      if (key === "partial") return "Partial";
      if (key === "planned") return "Planned";
      if (key === "blocked") return "Blocked";
      return "Unknown";
    }}

    function setRemoteActionStatus(message, isError = false) {{
      const text = String(message == null ? "" : message).trim();
      remoteActionStatus = text || "Select a node to start exploring remote actions.";
      remoteActionStatusError = !!isError;
      const statusEl = document.getElementById("remote-action-status");
      if (statusEl instanceof HTMLElement) {{
        statusEl.textContent = remoteActionStatus;
        statusEl.classList.toggle("error", remoteActionStatusError);
      }}
    }}

    function remoteViewSelectedNodeId() {{
      const card = document.querySelector(".card.remote");
      if (!(card instanceof HTMLElement)) return "";
      const nodeId = normalizeNodeId(card.dataset.targetNodeId || "");
      return isCanonicalNodeId(nodeId) ? nodeId : "";
    }}

    function stageRemoteChatCommand(nodeId, commandText, options = null) {{
      const cleanNodeId = normalizeNodeId(nodeId || "");
      if (!isCanonicalNodeId(cleanNodeId)) {{
        setRemoteActionStatus("Pick a valid remote node first.", true);
        return;
      }}
      const command = String(commandText || "").trim();
      if (!command) {{
        setRemoteActionStatus("Nothing to stage for chat.", true);
        return;
      }}
      const directMode = !!(options && options.direct);
      selectNode(cleanNodeId, false, false);
      applyLayoutView("chat", true);
      applyChatChannel("all", true);
      if (directMode) {{
        peerDmActivePeerId = cleanNodeId;
        setPeerDmMenuOpen(false);
        if (latestState) {{
          renderChat(latestState);
        }}
        const popoutInput = document.getElementById("peer-dm-popout-input");
        if (popoutInput instanceof HTMLInputElement) {{
          popoutInput.value = command;
          window.requestAnimationFrame(() => {{
            popoutInput.focus({{ preventScroll: true }});
            const tail = popoutInput.value.length;
            popoutInput.setSelectionRange(tail, tail);
          }});
        }}
        const statusText = String((options && options.statusText) || "").trim()
          || `Staged "${{command}}" for the peer message popup. Press Enter to send.`;
        const popoutStatus = document.getElementById("peer-dm-popout-status");
        if (popoutStatus instanceof HTMLElement) {{
          popoutStatus.textContent = statusText;
          popoutStatus.classList.remove("is-error");
          popoutStatus.hidden = false;
        }}
        setRemoteActionStatus(statusText, false);
        return;
      }}
      const chatInput = document.getElementById("chat-input");
      if (chatInput instanceof HTMLInputElement) {{
        chatInput.value = command;
        window.requestAnimationFrame(() => {{
          chatInput.focus({{ preventScroll: true }});
          const tail = chatInput.value.length;
          chatInput.setSelectionRange(tail, tail);
        }});
      }}
      const statusText = String((options && options.statusText) || "").trim()
        || `Staged "${{command}}" for channel chat. Press Enter to send.`;
      setChatSendStatus(statusText);
      setRemoteActionStatus(statusText, false);
    }}

    function bindRemoteControls() {{
      const searchInput = document.getElementById("remote-node-search-input");
      if (searchInput instanceof HTMLInputElement && searchInput.dataset.bound !== "1") {{
        searchInput.dataset.bound = "1";
        searchInput.addEventListener("input", () => {{
          const changed = setGlobalNodeSearchQuery(searchInput.value, {{
            sourceInputId: "remote-node-search-input",
            skipSourceInput: true,
          }});
          if (changed && latestState) {{
            rerenderNodeSearchDependents(latestState);
          }}
        }});
        searchInput.addEventListener("keydown", (event) => {{
          if (event.key !== "Escape") return;
          const changed = setGlobalNodeSearchQuery("", {{
            sourceInputId: "remote-node-search-input",
            skipSourceInput: false,
          }});
          if (changed && latestState) {{
            rerenderNodeSearchDependents(latestState);
          }}
        }});
      }}

      const nodeList = document.getElementById("remote-node-list");
      if (nodeList instanceof HTMLElement && nodeList.dataset.bound !== "1") {{
        nodeList.dataset.bound = "1";
        nodeList.addEventListener("click", (event) => {{
          const target = event.target;
          if (!(target instanceof Element)) return;
          const button = target.closest(".remote-node-btn");
          if (!(button instanceof HTMLButtonElement)) return;
          const nodeId = normalizeNodeId(button.dataset.nodeId || "");
          if (!isCanonicalNodeId(nodeId)) return;
          remoteTargetNodeId = nodeId;
          renderRemoteView(latestState);
        }});
      }}

      const refreshBtn = document.getElementById("remote-refresh-btn");
      if (refreshBtn instanceof HTMLButtonElement && refreshBtn.dataset.bound !== "1") {{
        refreshBtn.dataset.bound = "1";
        refreshBtn.addEventListener("click", () => {{
          setRemoteActionStatus("Refreshing remote snapshot...", false);
          renderRemoteView(latestState);
          requestImmediatePoll(0);
        }});
      }}

      const openNodeBtn = document.getElementById("remote-open-node-btn");
      if (openNodeBtn instanceof HTMLButtonElement && openNodeBtn.dataset.bound !== "1") {{
        openNodeBtn.dataset.bound = "1";
        openNodeBtn.addEventListener("click", () => {{
          const nodeId = remoteViewSelectedNodeId();
          if (!isCanonicalNodeId(nodeId)) {{
            setRemoteActionStatus("Select a node before opening node details.", true);
            return;
          }}
          selectNode(nodeId, true, false);
          setRemoteActionStatus(`Opened node details for ${{nodeId}}.`, false);
          applyLayoutView("network", true);
          if (typeof setChatNodeDetailsDrawerExpanded === "function") {{
            setChatNodeDetailsDrawerExpanded(true, {{
              fetchHistory: false,
              rerender: false,
            }});
          }}
        }});
      }}

      const openDirectBtn = document.getElementById("remote-open-direct-chat-btn");
      if (openDirectBtn instanceof HTMLButtonElement && openDirectBtn.dataset.bound !== "1") {{
        openDirectBtn.dataset.bound = "1";
        openDirectBtn.addEventListener("click", () => {{
          const nodeId = remoteViewSelectedNodeId();
          if (!isCanonicalNodeId(nodeId)) {{
            setRemoteActionStatus("Select a node before opening a message popup.", true);
            return;
          }}
          selectNode(nodeId, false, false);
          applyLayoutView("chat", true);
          applyChatChannel("all", true);
          peerDmActivePeerId = nodeId;
          setPeerDmMenuOpen(false);
          if (latestState) {{
            renderChat(latestState);
          }}
          const popoutInput = document.getElementById("peer-dm-popout-input");
          if (popoutInput instanceof HTMLInputElement) {{
            window.requestAnimationFrame(() => {{
              popoutInput.focus({{ preventScroll: true }});
            }});
          }}
          const statusText = `Direct message window ready for ${{nodeId}}.`;
          const popoutStatus = document.getElementById("peer-dm-popout-status");
          if (popoutStatus instanceof HTMLElement) {{
            popoutStatus.textContent = statusText;
            popoutStatus.classList.remove("is-error");
            popoutStatus.hidden = false;
          }}
          setRemoteActionStatus(statusText, false);
        }});
      }}

      const stagePingBtn = document.getElementById("remote-stage-ping-btn");
      if (stagePingBtn instanceof HTMLButtonElement && stagePingBtn.dataset.bound !== "1") {{
        stagePingBtn.dataset.bound = "1";
        stagePingBtn.addEventListener("click", () => {{
          const nodeId = remoteViewSelectedNodeId();
          stageRemoteChatCommand(nodeId, "ping", {{
            direct: true,
            statusText: "Staged direct ping in the message popup. Press Enter to send.",
          }});
        }});
      }}

      const stageWhoisBtn = document.getElementById("remote-stage-whois-btn");
      if (stageWhoisBtn instanceof HTMLButtonElement && stageWhoisBtn.dataset.bound !== "1") {{
        stageWhoisBtn.dataset.bound = "1";
        stageWhoisBtn.addEventListener("click", () => {{
          const nodeId = remoteViewSelectedNodeId();
          if (!isCanonicalNodeId(nodeId)) {{
            setRemoteActionStatus("Select a node before staging whois.", true);
            return;
          }}
          stageRemoteChatCommand(nodeId, `whois ${{nodeId}}`, {{
            direct: false,
            statusText: `Staged whois lookup for ${{nodeId}}. Press Enter to send.`,
          }});
        }});
      }}
    }}

    function renderRemoteView(state = latestState) {{
      bindRemoteControls();
      const safeState = (state && typeof state === "object") ? state : {{}};
      const allEntries = remoteNodeEntriesFromState(safeState);
      const targetFromAll = resolveRemoteTargetNodeId(allEntries, safeState);
      remoteTargetNodeId = targetFromAll;

      const queryText = globalNodeSearchQuery();
      const query = queryText;
      const filteredEntries = query
        ? allEntries.filter((entry) => entry.searchText.includes(query))
        : allEntries;
      const listEntries = filteredEntries.slice(0, 260);
      const listOverflow = Math.max(0, filteredEntries.length - listEntries.length);

      const card = document.querySelector(".card.remote");
      if (card instanceof HTMLElement) {{
        card.dataset.targetNodeId = isCanonicalNodeId(targetFromAll) ? targetFromAll : "";
      }}

      const caption = document.getElementById("remote-node-list-caption");
      if (caption instanceof HTMLElement) {{
        if (!allEntries.length) {{
          caption.textContent = "No remote nodes discovered yet.";
        }} else if (query) {{
          const overflowText = listOverflow > 0 ? ` Showing first ${{listEntries.length}}.` : "";
          caption.textContent = `${{filteredEntries.length}} match${{filteredEntries.length === 1 ? "" : "es"}} for "${{queryText}}" out of ${{allEntries.length}} remote node${{allEntries.length === 1 ? "" : "s"}}.${{overflowText}}`;
        }} else {{
          const overflowText = listOverflow > 0 ? ` Showing first ${{listEntries.length}}.` : "";
          caption.textContent = `${{allEntries.length}} remote node${{allEntries.length === 1 ? "" : "s"}} discovered (local radio hidden).${{overflowText}}`;
        }}
      }}

      const searchInput = document.getElementById("remote-node-search-input");
      if (searchInput instanceof HTMLInputElement && document.activeElement !== searchInput) {{
        if (searchInput.value !== queryText) {{
          searchInput.value = queryText;
        }}
      }}

      const detailEntry = allEntries.find((entry) => entry.id === targetFromAll) || null;
      const nodeList = document.getElementById("remote-node-list");
      if (nodeList instanceof HTMLElement) {{
        if (!listEntries.length) {{
          nodeList.innerHTML = `<div class="remote-node-empty">${{query ? "No nodes match this search yet." : "No remote nodes are available yet."}}</div>`;
        }} else {{
          nodeList.innerHTML = listEntries.map((entry) => {{
            const isActive = detailEntry && detailEntry.id === entry.id;
            const hopsLabel = Number.isFinite(entry.hopsAway)
              ? `${{entry.hopsAway}} hop${{entry.hopsAway === 1 ? "" : "s"}}`
              : "hops n/a";
            const lastSeen = entry.lastHeardUnix ? formatLocalChatTime(entry.lastHeardUnix, "n/a") : "n/a";
            return `<button type="button" class="remote-node-btn${{isActive ? " is-active" : ""}}" data-node-id="${{escAttr(entry.id)}}" role="option" aria-selected="${{isActive ? "true" : "false"}}">
              <span class="remote-node-main">
                <span class="remote-node-name">${{escAttr(entry.displayName)}}</span>
                <span class="remote-freshness-chip status-${{escAttr(normalizeFreshnessKey(entry.freshness))}}">${{escAttr(entry.freshness)}}</span>
              </span>
              <span class="remote-node-id">${{escAttr(entry.id)}}</span>
              <span class="remote-node-meta">
                <span>${{escAttr(entry.role || "role n/a")}}</span>
                <span>${{escAttr(hopsLabel)}}</span>
                <span>${{escAttr(lastSeen)}}</span>
              </span>
            </button>`;
          }}).join("");
        }}
      }}

      const targetTitle = document.getElementById("remote-target-title");
      const targetMeta = document.getElementById("remote-target-meta");
      const capabilityList = document.getElementById("remote-capability-list");
      if (!detailEntry) {{
        if (targetTitle instanceof HTMLElement) {{
          targetTitle.textContent = "Select a node";
        }}
        if (targetMeta instanceof HTMLElement) {{
          targetMeta.textContent = "Choose a node to inspect potential remote operations.";
        }}
        if (capabilityList instanceof HTMLElement) {{
          capabilityList.innerHTML = '<div class="remote-node-empty">Capabilities will appear after selecting a remote node.</div>';
        }}
      }} else {{
        if (targetTitle instanceof HTMLElement) {{
          targetTitle.textContent = `${{detailEntry.displayName}} (${{detailEntry.id}})`;
        }}
        if (targetMeta instanceof HTMLElement) {{
          const details = [];
          if (detailEntry.role) details.push(`Role: ${{detailEntry.role}}`);
          if (detailEntry.hardware) details.push(`Hardware: ${{detailEntry.hardware}}`);
          if (Number.isFinite(detailEntry.hopsAway)) details.push(`Hops: ${{detailEntry.hopsAway}}`);
          if (detailEntry.lastHeardUnix) details.push(`Last seen: ${{formatLocalChatTime(detailEntry.lastHeardUnix, "n/a")}}`);
          if (!details.length) {{
            details.push("No additional metadata for this node yet.");
          }}
          targetMeta.innerHTML = details
            .map((item) => `<span class="remote-meta-pill">${{escAttr(item)}}</span>`)
            .join("");
        }}
        if (capabilityList instanceof HTMLElement) {{
          const rows = remoteCapabilityRows(detailEntry, safeState);
          capabilityList.innerHTML = rows.length
            ? rows.map((row) => {{
              const statusKey = String(row && row.status ? row.status : "unknown").trim().toLowerCase();
              return `<div class="remote-capability-row">
                <div class="remote-capability-title">${{escAttr(row && row.title ? row.title : "Capability")}}</div>
                <div class="remote-capability-status ${{escAttr(statusKey)}}">${{escAttr(remoteCapabilityStatusLabel(statusKey))}}</div>
                <div class="remote-capability-detail">${{escAttr(row && row.detail ? row.detail : "")}}</div>
              </div>`;
            }}).join("")
            : '<div class="remote-node-empty">No capabilities available for this node yet.</div>';
        }}
      }}

      for (const buttonId of [
        "remote-open-node-btn",
        "remote-open-direct-chat-btn",
        "remote-stage-ping-btn",
        "remote-stage-whois-btn",
      ]) {{
        const button = document.getElementById(buttonId);
        if (button instanceof HTMLButtonElement) {{
          button.disabled = !detailEntry;
        }}
      }}

      setRemoteActionStatus(remoteActionStatus, remoteActionStatusError);
    }}

    function normalizeBbsBoardId(value, fallback = "") {{
      let text = String(value || fallback || "").trim().toLowerCase();
      text = text.replace(/[^a-z0-9_-]+/g, "-");
      text = text.replace(/-+/g, "-");
      text = text.replace(/^[-_]+|[-_]+$/g, "");
      return text.slice(0, 24);
    }}

    function sanitizeBbsWireField(value, maxChars = 120) {{
      const limit = Math.max(1, Math.trunc(Number(maxChars) || 1));
      return String(value == null ? "" : value)
        .replace(/\|/g, " ")
        .replace(/\s+/g, " ")
        .trim()
        .slice(0, limit);
    }}

    function bbsBoardKey(boardId, hostId) {{
      const cleanBoardId = normalizeBbsBoardId(boardId || "");
      const cleanHostId = normalizeNodeId(hostId || "");
      if (!cleanBoardId || !isCanonicalNodeId(cleanHostId)) return "";
      return `${{cleanHostId}}|${{cleanBoardId}}`;
    }}

    function createBbsHostState(overrides = {{}}) {{
      const title = sanitizeBbsWireField(overrides.title, bbsMaxTitleChars) || "Packet Exchange";
      const boardId = normalizeBbsBoardId(overrides.board_id, title);
      const motd = sanitizeBbsWireField(overrides.motd, bbsMaxMotdChars) || "2400 baud online.";
      const channelRaw = Number(overrides.channel_index);
      const channelIndex = Number.isInteger(channelRaw) && channelRaw >= 0
        ? Math.trunc(channelRaw)
        : 0;
      const hostId = normalizeNodeId(overrides.host_id || "");
      return {{
        enabled: overrides.enabled === true,
        board_id: boardId,
        title,
        motd,
        started_unix: Math.max(0, Math.trunc(Number(overrides.started_unix) || 0)),
        channel_index: channelIndex,
        host_id: isCanonicalNodeId(hostId) ? hostId : "",
      }};
    }}

    function bbsPersistState() {{
      const host = (bbsHostState && typeof bbsHostState === "object")
        ? bbsHostState
        : createBbsHostState();
      const payload = {{
        active_board_key: String(bbsActiveBoardKey || "").trim().toLowerCase(),
        board_id: normalizeBbsBoardId(host.board_id, host.title),
        title: sanitizeBbsWireField(host.title, bbsMaxTitleChars) || "Packet Exchange",
        motd: sanitizeBbsWireField(host.motd, bbsMaxMotdChars) || "2400 baud online.",
      }};
      try {{
        window.localStorage.setItem(bbsStorageKey, JSON.stringify(payload));
      }} catch (_err) {{
      }}
    }}

    function clearBbsAnnounceTimer() {{
      if (bbsHostAnnounceTimer !== null) {{
        clearInterval(bbsHostAnnounceTimer);
        bbsHostAnnounceTimer = null;
      }}
    }}

    function loadBbsState() {{
      let stored = null;
      try {{
        const raw = window.localStorage.getItem(bbsStorageKey);
        stored = raw ? JSON.parse(raw) : null;
      }} catch (_err) {{
        stored = null;
      }}
      const source = (stored && typeof stored === "object") ? stored : {{}};
      const next = createBbsHostState(source);
      next.enabled = false;
      next.started_unix = 0;
      next.host_id = "";
      bbsHostState = next;
      const activeKeyRaw = String(source.active_board_key || "").trim().toLowerCase();
      bbsActiveBoardKey = activeKeyRaw.slice(0, 96);
      bbsDiscoveredBoards = [];
      bbsBoardPostsByKey.clear();
      bbsSeenMessageKeys = new Set();
      bbsSeenMessageOrder = [];
      bbsPostStatusText = "";
      bbsPostStatusError = false;
      bbsPostStatusChannelIndex = null;
      clearBbsAnnounceTimer();
    }}

    function setBbsPostStatus(message, isError = false, options = null) {{
      bbsPostStatusText = String(message == null ? "" : message).trim();
      bbsPostStatusError = !!isError;
      const hasChannelIndex = !!(
        options
        && typeof options === "object"
        && options.channel_index !== null
        && options.channel_index !== undefined
        && String(options.channel_index).trim() !== ""
      );
      const rawChannelIndex = hasChannelIndex ? Number(options.channel_index) : NaN;
      if (!bbsPostStatusError && Number.isInteger(rawChannelIndex) && rawChannelIndex >= 0) {{
        bbsPostStatusChannelIndex = Math.trunc(rawChannelIndex);
      }} else {{
        bbsPostStatusChannelIndex = null;
      }}
      const statusEl = document.getElementById("bbs-post-status");
      if (!(statusEl instanceof HTMLElement)) return;
      statusEl.classList.toggle("is-error", bbsPostStatusError);
      if (
        bbsPostStatusError
        || !Number.isInteger(bbsPostStatusChannelIndex)
        || bbsPostStatusChannelIndex < 0
      ) {{
        statusEl.textContent = bbsPostStatusText;
        return;
      }}
      const channelIndex = normalizeMeshChannelIndex(bbsPostStatusChannelIndex);
      const channelLabel = meshChannelLabelForIndex(channelIndex, {{ compact: true, allowAll: false }});
      const channelBadge = meshChannelBadgeHtml(
        channelIndex,
        channelLabel,
        {{
          allowAll: false,
          extraClass: "bbs-channel-badge",
          title: meshChannelLabelForIndex(channelIndex, {{ verbose: true, allowAll: false }}),
        }}
      );
      statusEl.innerHTML = `${{escAttr(bbsPostStatusText)}} • ${{channelBadge}}`;
    }}

    function bbsHostNodeId(state = latestState) {{
      const clean = normalizeNodeId(resolveLocalNodeId(state) || "");
      return isCanonicalNodeId(clean) ? clean : "";
    }}

    function bbsDisplayNodeLabel(nodeId, state = latestState) {{
      const clean = normalizeNodeId(nodeId || "");
      if (!isCanonicalNodeId(clean)) return clean || "unknown";
      return reversiNodeLabel(clean, state);
    }}

    function bbsUpsertDirectoryRow(row = {{}}) {{
      const boardId = normalizeBbsBoardId(row.board_id || row.boardId || "");
      const hostId = normalizeNodeId(row.host_id || row.hostId || "");
      const key = bbsBoardKey(boardId, hostId);
      if (!key) return "";
      const titleCandidate = sanitizeBbsWireField(row.title, bbsMaxTitleChars);
      const motdCandidate = sanitizeBbsWireField(row.motd, bbsMaxMotdChars);
      const nowUnix = Math.floor(Date.now() / 1000);
      const seenUnix = Math.max(0, Math.trunc(Number(row.last_seen_unix ?? row.lastSeenUnix) || nowUnix));
      const channelRaw = Number(row.channel_index ?? row.channelIndex);
      const channelIndex = Number.isInteger(channelRaw) && channelRaw >= 0
        ? Math.trunc(channelRaw)
        : 0;
      const nextRows = [];
      let merged = false;
      for (const current of (Array.isArray(bbsDiscoveredBoards) ? bbsDiscoveredBoards : [])) {{
        if (!current || typeof current !== "object") continue;
        const currentKey = String(current.key || "").trim().toLowerCase();
        if (currentKey !== key) {{
          nextRows.push(current);
          continue;
        }}
        nextRows.push({{
          ...current,
          key,
          board_id: boardId,
          host_id: hostId,
          title: titleCandidate || sanitizeBbsWireField(current.title, bbsMaxTitleChars) || boardId,
          motd: motdCandidate || sanitizeBbsWireField(current.motd, bbsMaxMotdChars),
          last_seen_unix: Math.max(Math.trunc(Number(current.last_seen_unix) || 0), seenUnix),
          channel_index: channelIndex,
        }});
        merged = true;
      }}
      if (!merged) {{
        nextRows.push({{
          key,
          board_id: boardId,
          host_id: hostId,
          title: titleCandidate || boardId,
          motd: motdCandidate,
          last_seen_unix: seenUnix,
          channel_index: channelIndex,
        }});
      }}
      const localId = bbsHostNodeId(latestState);
      nextRows.sort((a, b) => {{
        const aLocal = (isCanonicalNodeId(localId) && normalizeNodeId(a && a.host_id) === localId) ? 0 : 1;
        const bLocal = (isCanonicalNodeId(localId) && normalizeNodeId(b && b.host_id) === localId) ? 0 : 1;
        if (aLocal !== bLocal) return aLocal - bLocal;
        const seenDelta = (Number(b && b.last_seen_unix) || 0) - (Number(a && a.last_seen_unix) || 0);
        if (seenDelta !== 0) return seenDelta;
        return String((a && a.key) || "").localeCompare(String((b && b.key) || ""));
      }});
      bbsDiscoveredBoards = nextRows.slice(0, bbsBoardDirectoryMaxRows);
      return key;
    }}

    function bbsRemoveDirectoryRow(boardId, hostId) {{
      const key = bbsBoardKey(boardId, hostId);
      if (!key) return;
      bbsDiscoveredBoards = (Array.isArray(bbsDiscoveredBoards) ? bbsDiscoveredBoards : [])
        .filter((row) => String(row && row.key || "").trim().toLowerCase() !== key);
      if (bbsActiveBoardKey === key) {{
        const fallback = (Array.isArray(bbsDiscoveredBoards) && bbsDiscoveredBoards.length)
          ? String(bbsDiscoveredBoards[0].key || "").trim().toLowerCase()
          : "";
        bbsActiveBoardKey = fallback;
      }}
    }}

    function bbsPruneDirectoryRows(nowUnix = Math.floor(Date.now() / 1000)) {{
      const hostKey = (bbsHostState && bbsHostState.enabled)
        ? bbsBoardKey(bbsHostState.board_id, bbsHostState.host_id)
        : "";
      const rows = Array.isArray(bbsDiscoveredBoards) ? bbsDiscoveredBoards : [];
      const nextRows = rows.filter((row) => {{
        if (!row || typeof row !== "object") return false;
        const rowKey = String(row.key || "").trim().toLowerCase();
        if (!rowKey) return false;
        if (hostKey && rowKey === hostKey) return true;
        const age = nowUnix - Math.max(0, Math.trunc(Number(row.last_seen_unix) || 0));
        return age <= bbsBoardStaleSeconds;
      }});
      if (nextRows.length !== rows.length) {{
        bbsDiscoveredBoards = nextRows;
      }}
    }}

    function bbsRememberMessageKey(key) {{
      const clean = String(key || "").trim();
      if (!clean) return false;
      if (bbsSeenMessageKeys.has(clean)) return false;
      bbsSeenMessageKeys.add(clean);
      bbsSeenMessageOrder.push(clean);
      if (bbsSeenMessageOrder.length > bbsMaxSeenNetworkMessages) {{
        while (bbsSeenMessageOrder.length > Math.floor(bbsMaxSeenNetworkMessages * 0.72)) {{
          const stale = bbsSeenMessageOrder.shift();
          if (stale) bbsSeenMessageKeys.delete(stale);
        }}
      }}
      return true;
    }}

    function bbsEncodeProtocolMessage(type, ...fields) {{
      const cleanType = String(type || "").trim().toLowerCase();
      if (!cleanType) return "";
      const encoded = [bbsProtocolVersion, cleanType];
      for (const field of fields) {{
        encoded.push(sanitizeBbsWireField(field, bbsMaxPostChars));
      }}
      return encoded.join("|");
    }}

    function parseBbsProtocolMessage(text) {{
      const raw = String(text || "").trim();
      if (!raw || !raw.startsWith(`${{bbsProtocolVersion}}|`)) return null;
      const parts = raw.split("|").map((part) => String(part || "").trim());
      if (parts.length < 2) return null;
      const type = String(parts[1] || "").trim().toLowerCase();
      if (!type) return null;
      return {{ raw, type, parts }};
    }}

    function bbsProtocolMessageText(msg) {{
      if (!msg || typeof msg !== "object") return "";
      return String(msg.text ?? msg.decoded_text ?? msg.payload_text ?? "").trim();
    }}

    function bbsProtocolMessageUnix(msg) {{
      return latestUnixTimestamp(
        msg && msg.rx_time,
        msg && msg.captured_at,
        msg && msg.sent_at,
        msg && msg.created_at
      ) || Math.floor(Date.now() / 1000);
    }}

    function bbsProtocolMessageKey(msg, parsed) {{
      const messageId = messageIdOfChatPacket(msg);
      if (messageId) return `bbs:msg:${{messageId}}`;
      const fromId = normalizeNodeId(msg && msg.from || "");
      const toId = normalizeNodeId(msg && (msg.to || msg.destination) || "");
      return [
        "bbs",
        "raw",
        fromId,
        toId,
        String(msg && msg.rx_time || ""),
        String(parsed && parsed.raw || ""),
      ].join("|");
    }}

    function bbsPostsForBoard(boardKey) {{
      const cleanKey = String(boardKey || "").trim().toLowerCase();
      if (!cleanKey) return [];
      const existing = bbsBoardPostsByKey.get(cleanKey);
      if (Array.isArray(existing)) return existing;
      const rows = [];
      bbsBoardPostsByKey.set(cleanKey, rows);
      return rows;
    }}

    function bbsAppendBoardPost(boardKey, post = {{}}) {{
      const cleanKey = String(boardKey || "").trim().toLowerCase();
      if (!cleanKey) return false;
      const text = sanitizeBbsWireField(post.text, bbsMaxPostChars);
      if (!text) return false;
      const rows = bbsPostsForBoard(cleanKey);
      const entryId = sanitizeBbsWireField(post.entry_id ?? post.entryId, 60);
      if (entryId && rows.some((row) => String(row && row.entry_id || "") === entryId)) {{
        return false;
      }}
      const authorId = normalizeNodeId(post.author_id ?? post.authorId ?? "");
      const fallbackAuthor = isCanonicalNodeId(authorId) ? authorId : "anonymous";
      const authorName = sanitizeBbsWireField(post.author_name ?? post.authorName, 48) || fallbackAuthor;
      rows.push({{
        entry_id: entryId || `local-${{Date.now().toString(36)}}`,
        author_id: isCanonicalNodeId(authorId) ? authorId : "",
        author_name: authorName,
        text,
        unix: Math.max(0, Math.trunc(Number(post.unix) || Math.floor(Date.now() / 1000))),
      }});
      rows.sort((a, b) => {{
        const unixDelta = (Number(a && a.unix) || 0) - (Number(b && b.unix) || 0);
        if (unixDelta !== 0) return unixDelta;
        return String(a && a.entry_id || "").localeCompare(String(b && b.entry_id || ""));
      }});
      if (rows.length > bbsBoardMaxPosts) {{
        rows.splice(0, rows.length - bbsBoardMaxPosts);
      }}
      bbsBoardPostsByKey.set(cleanKey, rows);
      return true;
    }}

    function bbsGenerateEntryId() {{
      const now = Date.now().toString(36);
      const rand = Math.random().toString(36).slice(2, 8);
      return `${{now}}${{rand}}`.slice(0, 18);
    }}

    async function sendBbsProtocolMessage(
      type,
      fields = [],
      {{
        destination = "^all",
        channel_index = null,
        quiet = false,
      }} = {{}}
    ) {{
      if (chatSendInFlight) {{
        if (!quiet) {{
          setBbsPostStatus("Another message is already sending. Try again in a moment.", true);
        }}
        return false;
      }}
      const encoded = bbsEncodeProtocolMessage(type, ...(Array.isArray(fields) ? fields : []));
      if (!encoded) {{
        if (!quiet) {{
          setBbsPostStatus("Could not encode BBS payload.", true);
        }}
        return false;
      }}
      const channelIndex = normalizeMeshChannelIndex(
        channel_index == null ? meshChannelEffectiveSendIndexForApp("bbs") : channel_index
      );
      const payload = await sendChatPayload(
        {{
          text: encoded,
          destination: destination || "^all",
          channel_index: channelIndex,
        }},
        null,
        {{
          statusFn: setBbsPostStatus,
          showSendingStatus: false,
          showSuccessStatus: false,
          showErrorStatus: false,
        }}
      );
      if (!payload || payload.ok !== true) {{
        if (!quiet) {{
          setBbsPostStatus("BBS send failed.", true);
        }}
        return false;
      }}
      return true;
    }}

    function bbsEnsureHostDirectoryEntry(state = latestState) {{
      if (!(bbsHostState && bbsHostState.enabled)) return;
      const localId = bbsHostNodeId(state);
      if (!isCanonicalNodeId(localId)) return;
      bbsHostState.host_id = localId;
      const hostKey = bbsUpsertDirectoryRow({{
        board_id: bbsHostState.board_id,
        host_id: localId,
        title: bbsHostState.title,
        motd: bbsHostState.motd,
        channel_index: bbsHostState.channel_index,
        last_seen_unix: Math.floor(Date.now() / 1000),
      }});
      if (hostKey && !bbsActiveBoardKey) {{
        bbsActiveBoardKey = hostKey;
      }}
    }}

    function bbsActiveBoardRow() {{
      const rows = Array.isArray(bbsDiscoveredBoards) ? bbsDiscoveredBoards : [];
      const key = String(bbsActiveBoardKey || "").trim().toLowerCase();
      if (!key) return null;
      return rows.find((row) => String(row && row.key || "").trim().toLowerCase() === key) || null;
    }}

    function bbsSelectBoard(boardKey) {{
      const clean = String(boardKey || "").trim().toLowerCase();
      if (!clean) return;
      if (!Array.isArray(bbsDiscoveredBoards) || !bbsDiscoveredBoards.some((row) => String(row && row.key || "").trim().toLowerCase() === clean)) {{
        return;
      }}
      bbsActiveBoardKey = clean;
      bbsPersistState();
      if (activeLayoutView === "bbs") {{
        renderBbsView(latestState);
      }}
    }}

    function armBbsAnnounceTimer() {{
      clearBbsAnnounceTimer();
      if (!(bbsHostState && bbsHostState.enabled)) return;
      bbsHostAnnounceTimer = window.setInterval(() => {{
        void announceHostedBbs({{ quiet: true }});
      }}, bbsHostAnnounceIntervalMs);
    }}

    async function announceHostedBbs(options = null) {{
      if (!(bbsHostState && bbsHostState.enabled)) return false;
      const opts = (options && typeof options === "object") ? options : {{}};
      const boardId = normalizeBbsBoardId(bbsHostState.board_id, bbsHostState.title);
      const hostId = normalizeNodeId(bbsHostState.host_id || bbsHostNodeId(latestState));
      if (!boardId || !isCanonicalNodeId(hostId)) {{
        if (!opts.quiet) {{
          setBbsPostStatus("Local node ID is unavailable, so BBS hosting cannot announce yet.", true);
        }}
        return false;
      }}
      bbsHostState.board_id = boardId;
      bbsHostState.host_id = hostId;
      const sent = await sendBbsProtocolMessage(
        "announce",
        [boardId, hostId, bbsHostState.title, bbsHostState.motd],
        {{
          destination: "^all",
          channel_index: bbsHostState.channel_index,
          quiet: !!opts.quiet,
        }}
      );
      if (!sent) return false;
      bbsUpsertDirectoryRow({{
        board_id: boardId,
        host_id: hostId,
        title: bbsHostState.title,
        motd: bbsHostState.motd,
        channel_index: bbsHostState.channel_index,
        last_seen_unix: Math.floor(Date.now() / 1000),
      }});
      if (!bbsActiveBoardKey) {{
        bbsActiveBoardKey = bbsBoardKey(boardId, hostId);
      }}
      if (!opts.quiet) {{
        setBbsPostStatus(
          `Broadcast listing sent for "${{bbsHostState.title}}".`,
          false,
          {{ channel_index: bbsHostState.channel_index }}
        );
      }}
      return true;
    }}

    async function startBbsHosting() {{
      const localId = bbsHostNodeId(latestState);
      if (!isCanonicalNodeId(localId)) {{
        setBbsPostStatus("Local node ID is unavailable. Wait for sync and try again.", true);
        if (activeLayoutView === "bbs") renderBbsView(latestState);
        return;
      }}
      const titleInput = document.getElementById("bbs-host-title-input");
      const boardInput = document.getElementById("bbs-host-id-input");
      const motdInput = document.getElementById("bbs-host-motd-input");
      const title = sanitizeBbsWireField(
        titleInput instanceof HTMLInputElement ? titleInput.value : bbsHostState.title,
        bbsMaxTitleChars
      ) || "Packet Exchange";
      let boardId = normalizeBbsBoardId(
        boardInput instanceof HTMLInputElement ? boardInput.value : bbsHostState.board_id,
        title
      );
      if (!boardId) {{
        boardId = `bbs-${{Date.now().toString(36).slice(-6)}}`;
      }}
      const motd = sanitizeBbsWireField(
        motdInput instanceof HTMLInputElement ? motdInput.value : bbsHostState.motd,
        bbsMaxMotdChars
      ) || "2400 baud online.";
      const channelIndex = meshChannelEffectiveSendIndexForApp("bbs");
      bbsHostState = createBbsHostState({{
        enabled: true,
        board_id: boardId,
        title,
        motd,
        started_unix: Math.floor(Date.now() / 1000),
        channel_index: channelIndex,
        host_id: localId,
      }});
      const hostKey = bbsUpsertDirectoryRow({{
        board_id: boardId,
        host_id: localId,
        title,
        motd,
        channel_index: channelIndex,
        last_seen_unix: bbsHostState.started_unix,
      }});
      bbsActiveBoardKey = hostKey || bbsBoardKey(boardId, localId);
      bbsPersistState();
      armBbsAnnounceTimer();
      setBbsPostStatus(`Hosting "${{title}}".`, false, {{ channel_index: channelIndex }});
      void announceHostedBbs({{ quiet: true }});
      if (activeLayoutView === "bbs") {{
        renderBbsView(latestState);
      }}
      requestImmediatePoll(0);
    }}

    async function stopBbsHosting() {{
      if (!(bbsHostState && bbsHostState.enabled)) return;
      const boardId = normalizeBbsBoardId(bbsHostState.board_id, bbsHostState.title);
      const hostId = normalizeNodeId(bbsHostState.host_id || bbsHostNodeId(latestState));
      const channelIndex = normalizeMeshChannelIndex(bbsHostState.channel_index);
      bbsHostState.enabled = false;
      bbsHostState.started_unix = 0;
      clearBbsAnnounceTimer();
      if (boardId && isCanonicalNodeId(hostId)) {{
        bbsRemoveDirectoryRow(boardId, hostId);
      }}
      bbsPersistState();
      if (boardId && isCanonicalNodeId(hostId)) {{
        await sendBbsProtocolMessage(
          "offline",
          [boardId, hostId],
          {{
            destination: "^all",
            channel_index: channelIndex,
            quiet: true,
          }}
        );
      }}
      setBbsPostStatus("BBS host is now offline.");
      if (activeLayoutView === "bbs") {{
        renderBbsView(latestState);
      }}
      requestImmediatePoll(0);
    }}

    function renderBbsDirectory(state = latestState) {{
      const listEl = document.getElementById("bbs-board-list");
      if (!(listEl instanceof HTMLElement)) return;
      const rows = Array.isArray(bbsDiscoveredBoards) ? bbsDiscoveredBoards : [];
      if (!rows.length) {{
        listEl.innerHTML = '<div class="bbs-board-empty">No boards discovered yet. Start hosting to publish one.</div>';
        return;
      }}
      const activeKey = String(bbsActiveBoardKey || "").trim().toLowerCase();
      listEl.innerHTML = rows.map((row) => {{
        const key = String(row && row.key || "").trim().toLowerCase();
        const isActive = key && activeKey && key === activeKey;
        const title = sanitizeBbsWireField(row && row.title, bbsMaxTitleChars) || sanitizeBbsWireField(row && row.board_id, 24) || "Board";
        const boardId = sanitizeBbsWireField(row && row.board_id, 24) || "unknown";
        const hostId = normalizeNodeId(row && row.host_id || "");
        const hostLabel = bbsDisplayNodeLabel(hostId, state);
        const motd = sanitizeBbsWireField(row && row.motd, bbsMaxMotdChars);
        const seenUnix = Math.max(0, Math.trunc(Number(row && row.last_seen_unix) || 0));
        const chRaw = Number(row && row.channel_index);
        const channelIndex = Number.isInteger(chRaw) && chRaw >= 0 ? Math.trunc(chRaw) : 0;
        const channelLabel = meshChannelLabelForIndex(channelIndex, {{ compact: true, allowAll: false }});
        const channelBadge = meshChannelBadgeHtml(
          channelIndex,
          channelLabel,
          {{
            allowAll: false,
            extraClass: "bbs-channel-badge",
            title: meshChannelLabelForIndex(channelIndex, {{ verbose: true, allowAll: false }}),
          }}
        );
        const roleLabel = isSelfNodeId(hostId, state) ? "local" : "remote";
        return `<button
          type="button"
          class="bbs-board-item${{isActive ? " is-active" : ""}}"
          data-board-key="${{escAttr(key)}}"
          role="option"
          aria-selected="${{isActive ? "true" : "false"}}"
        >
          <span class="bbs-board-main">${{escAttr(title)}}</span>
          <span class="bbs-board-meta">${{escAttr(boardId)}} • host ${{escAttr(hostLabel)}} (${{escAttr(roleLabel)}}) • ${{channelBadge}} • seen ${{escAttr(formatLocalChatTime(seenUnix, "n/a"))}}</span>
          <span class="bbs-board-motd">${{escAttr(motd || "No banner set.")}}</span>
        </button>`;
      }}).join("");
    }}

    function renderBbsTerminal(state = latestState) {{
      const titleEl = document.getElementById("bbs-terminal-title");
      const metaEl = document.getElementById("bbs-terminal-meta");
      const logEl = document.getElementById("bbs-terminal-log");
      const inputEl = document.getElementById("bbs-post-input");
      const sendBtn = document.getElementById("bbs-post-send-btn");
      const activeRow = bbsActiveBoardRow();
      if (!(logEl instanceof HTMLElement)) return;
      if (!activeRow) {{
        if (titleEl instanceof HTMLElement) {{
          titleEl.textContent = "No board selected";
        }}
        if (metaEl instanceof HTMLElement) {{
          metaEl.textContent = "Host a board or pick one from the dial directory.";
        }}
        if (inputEl instanceof HTMLInputElement) {{
          inputEl.disabled = true;
          inputEl.placeholder = "Select a board before posting...";
        }}
        if (sendBtn instanceof HTMLButtonElement) {{
          sendBtn.disabled = true;
        }}
        logEl.textContent = "*** CONNECT 2400 ***\nReady.\n";
        return;
      }}
      if (titleEl instanceof HTMLElement) {{
        const hostLabel = bbsDisplayNodeLabel(activeRow.host_id, state);
        titleEl.textContent = `${{activeRow.title || activeRow.board_id || "Board"}} @ ${{hostLabel}}`;
      }}
      if (metaEl instanceof HTMLElement) {{
        const motd = sanitizeBbsWireField(activeRow.motd, bbsMaxMotdChars) || "No banner set.";
        const channelIndex = normalizeMeshChannelIndex(activeRow.channel_index);
        const channelLabel = meshChannelLabelForIndex(channelIndex, {{ compact: true, allowAll: false }});
        const channelBadge = meshChannelBadgeHtml(
          channelIndex,
          channelLabel,
          {{
            allowAll: false,
            extraClass: "bbs-channel-badge",
            title: meshChannelLabelForIndex(channelIndex, {{ verbose: true, allowAll: false }}),
          }}
        );
        metaEl.innerHTML = `${{escAttr(motd)}} | ${{channelBadge}}`;
      }}
      if (inputEl instanceof HTMLInputElement) {{
        inputEl.disabled = false;
        inputEl.placeholder = `Post to ${{activeRow.board_id}}...`;
      }}
      if (sendBtn instanceof HTMLButtonElement) {{
        sendBtn.disabled = false;
      }}
      const rows = bbsPostsForBoard(activeRow.key);
      const lines = [
        "*** CONNECT 2400 ***",
        `BOARD: ${{activeRow.title || activeRow.board_id}} (${{activeRow.board_id}})`,
        `HOST: ${{bbsDisplayNodeLabel(activeRow.host_id, state)}}`,
        `MOTD: ${{sanitizeBbsWireField(activeRow.motd, bbsMaxMotdChars) || "No banner set."}}`,
        "----------------------------------------",
      ];
      if (!rows.length) {{
        lines.push("No posts yet. Type a message to start the thread.");
      }} else {{
        for (const row of rows) {{
          if (!row || typeof row !== "object") continue;
          const stamp = formatLocalChatTime(Math.max(0, Math.trunc(Number(row.unix) || 0)), "n/a");
          const author = sanitizeBbsWireField(row.author_name, 48) || sanitizeBbsWireField(row.author_id, 24) || "anon";
          lines.push(`[${{stamp}}] <${{author}}> ${{row.text || ""}}`);
        }}
      }}
      logEl.textContent = lines.join("\n");
      if (logEl instanceof HTMLElement) {{
        logEl.scrollTop = logEl.scrollHeight;
      }}
    }}

    function renderBbsHostControls(state = latestState) {{
      bbsEnsureHostDirectoryEntry(state);
      const titleInput = document.getElementById("bbs-host-title-input");
      const boardInput = document.getElementById("bbs-host-id-input");
      const motdInput = document.getElementById("bbs-host-motd-input");
      const startBtn = document.getElementById("bbs-host-start-btn");
      const stopBtn = document.getElementById("bbs-host-stop-btn");
      const announceBtn = document.getElementById("bbs-host-announce-btn");
      const hostChannel = document.getElementById("bbs-host-channel");
      const hostStatus = document.getElementById("bbs-host-status");
      if (titleInput instanceof HTMLInputElement && document.activeElement !== titleInput) {{
        if (titleInput.value !== String(bbsHostState.title || "")) {{
          titleInput.value = String(bbsHostState.title || "");
        }}
      }}
      if (boardInput instanceof HTMLInputElement && document.activeElement !== boardInput) {{
        if (boardInput.value !== String(bbsHostState.board_id || "")) {{
          boardInput.value = String(bbsHostState.board_id || "");
        }}
      }}
      if (motdInput instanceof HTMLInputElement && document.activeElement !== motdInput) {{
        if (motdInput.value !== String(bbsHostState.motd || "")) {{
          motdInput.value = String(bbsHostState.motd || "");
        }}
      }}
      const localId = bbsHostNodeId(state);
      const hostEnabled = !!(bbsHostState && bbsHostState.enabled);
      const effectiveChannelRaw = hostEnabled
        ? normalizeMeshChannelIndex(bbsHostState.channel_index)
        : meshChannelEffectiveSendIndexForApp("bbs");
      const effectiveChannelIndex = Number.isInteger(effectiveChannelRaw) && effectiveChannelRaw >= 0
        ? Math.trunc(effectiveChannelRaw)
        : 0;
      if (startBtn instanceof HTMLButtonElement) {{
        startBtn.disabled = hostEnabled || !isCanonicalNodeId(localId);
      }}
      if (stopBtn instanceof HTMLButtonElement) {{
        stopBtn.disabled = !hostEnabled;
      }}
      if (announceBtn instanceof HTMLButtonElement) {{
        announceBtn.disabled = !hostEnabled;
      }}
      if (hostChannel instanceof HTMLElement) {{
        const channelLabel = meshChannelLabelForIndex(
          effectiveChannelIndex,
          {{ compact: true, allowAll: false }}
        );
        const channelBadge = meshChannelBadgeHtml(
          effectiveChannelIndex,
          channelLabel,
          {{
            allowAll: false,
            extraClass: "bbs-channel-badge",
            title: meshChannelLabelForIndex(effectiveChannelIndex, {{ verbose: true, allowAll: false }}),
          }}
        );
        hostChannel.innerHTML = hostEnabled
          ? `Hosting + broadcast channel: ${{channelBadge}}`
          : `Next host + broadcast channel: ${{channelBadge}}`;
      }}
      if (hostStatus instanceof HTMLElement) {{
        if (!isCanonicalNodeId(localId)) {{
          hostStatus.textContent = "Waiting for local node identity before hosting can start.";
        }} else if (!hostEnabled) {{
          hostStatus.textContent = "Offline. Fill out board details and click Host Board.";
        }} else {{
          const channelIndex = effectiveChannelIndex;
          const channelLabel = meshChannelLabelForIndex(
            channelIndex,
            {{ compact: true, allowAll: false }}
          );
          const channelBadge = meshChannelBadgeHtml(
            channelIndex,
            channelLabel,
            {{
              allowAll: false,
              extraClass: "bbs-channel-badge",
              title: meshChannelLabelForIndex(channelIndex, {{ verbose: true, allowAll: false }}),
            }}
          );
          hostStatus.innerHTML = `Online as "${{escAttr(bbsHostState.title)}}" (${{escAttr(bbsHostState.board_id)}}) on ${{channelBadge}}. Beacon every ${{Math.round(bbsHostAnnounceIntervalMs / 1000)}}s.`;
        }}
      }}
      setBbsPostStatus(bbsPostStatusText, bbsPostStatusError, {{ channel_index: bbsPostStatusChannelIndex }});
    }}

    function syncBbsNetworkState(state = latestState) {{
      const safeState = (state && typeof state === "object") ? state : null;
      if (!safeState) return;
      const localId = bbsHostNodeId(safeState);
      const traffic = safeState.traffic && typeof safeState.traffic === "object"
        ? safeState.traffic
        : {{}};
      const recentChat = Array.isArray(traffic.recent_chat) ? traffic.recent_chat : [];
      for (const msg of recentChat) {{
        if (!msg || typeof msg !== "object") continue;
        if (msg.local_echo === true || msg.localEcho === true) continue;
        const parsed = parseBbsProtocolMessage(bbsProtocolMessageText(msg));
        if (!parsed) continue;
        const dedupeKey = bbsProtocolMessageKey(msg, parsed);
        if (!bbsRememberMessageKey(dedupeKey)) continue;
        const fromId = normalizeNodeId(msg.from || "");
        const toRaw = String(msg.to ?? msg.destination ?? "").trim();
        const toToken = toRaw.toLowerCase();
        const toId = normalizeNodeId(toRaw);
        const toAll = !toRaw || toToken === "^all" || toToken === "all" || toToken === "broadcast";
        if (!toAll) {{
          if (!isCanonicalNodeId(localId)) continue;
          if (!isCanonicalNodeId(toId) || toId !== localId) continue;
        }}
        if (parsed.type === "announce") {{
          const boardId = normalizeBbsBoardId(parsed.parts[2] || "");
          const hostId = normalizeNodeId(parsed.parts[3] || fromId);
          if (!boardId || !isCanonicalNodeId(hostId)) continue;
          const title = sanitizeBbsWireField(parsed.parts[4], bbsMaxTitleChars) || boardId;
          const motd = sanitizeBbsWireField(parsed.parts[5], bbsMaxMotdChars);
          const key = bbsUpsertDirectoryRow({{
            board_id: boardId,
            host_id: hostId,
            title,
            motd,
            channel_index: messageMeshChannelIndex(msg),
            last_seen_unix: bbsProtocolMessageUnix(msg),
          }});
          if (!bbsActiveBoardKey && key) {{
            bbsActiveBoardKey = key;
          }}
          continue;
        }}
        if (parsed.type === "offline") {{
          const boardId = normalizeBbsBoardId(parsed.parts[2] || "");
          const hostId = normalizeNodeId(parsed.parts[3] || fromId);
          if (!boardId || !isCanonicalNodeId(hostId)) continue;
          bbsRemoveDirectoryRow(boardId, hostId);
          continue;
        }}
        if (parsed.type === "post") {{
          const boardId = normalizeBbsBoardId(parsed.parts[2] || "");
          const hostId = normalizeNodeId(parsed.parts[3] || fromId);
          if (!boardId || !isCanonicalNodeId(hostId)) continue;
          const key = bbsUpsertDirectoryRow({{
            board_id: boardId,
            host_id: hostId,
            title: "",
            motd: "",
            channel_index: messageMeshChannelIndex(msg),
            last_seen_unix: bbsProtocolMessageUnix(msg),
          }});
          const entryId = sanitizeBbsWireField(parsed.parts[4], 60);
          const authorId = normalizeNodeId(parsed.parts[5] || fromId);
          const authorName = sanitizeBbsWireField(parsed.parts[6], 48);
          const text = sanitizeBbsWireField(parsed.parts[7], bbsMaxPostChars);
          if (!text) continue;
          bbsAppendBoardPost(key, {{
            entry_id: entryId,
            author_id: authorId,
            author_name: authorName || bbsDisplayNodeLabel(authorId || fromId, safeState),
            text,
            unix: bbsProtocolMessageUnix(msg),
          }});
          if (!bbsActiveBoardKey && key) {{
            bbsActiveBoardKey = key;
          }}
          continue;
        }}
      }}
      const nowUnix = Math.floor(Date.now() / 1000);
      bbsPruneDirectoryRows(nowUnix);
      bbsEnsureHostDirectoryEntry(safeState);
      const activeExists = !!bbsActiveBoardRow();
      if (!activeExists) {{
        if (bbsHostState && bbsHostState.enabled) {{
          bbsActiveBoardKey = bbsBoardKey(bbsHostState.board_id, bbsHostState.host_id);
        }}
        if (!bbsActiveBoardKey && Array.isArray(bbsDiscoveredBoards) && bbsDiscoveredBoards.length) {{
          bbsActiveBoardKey = String(bbsDiscoveredBoards[0].key || "").trim().toLowerCase();
        }}
      }}
      bbsPersistState();
    }}

    async function sendBbsPost() {{
      const input = document.getElementById("bbs-post-input");
      if (!(input instanceof HTMLInputElement)) return;
      const activeRow = bbsActiveBoardRow();
      if (!activeRow) {{
        setBbsPostStatus("Select a board first.", true);
        return;
      }}
      const text = sanitizeBbsWireField(input.value, bbsMaxPostChars);
      if (!text) {{
        setBbsPostStatus("Type a message before posting.", true);
        return;
      }}
      const localId = bbsHostNodeId(latestState);
      if (!isCanonicalNodeId(localId)) {{
        setBbsPostStatus("Local node ID is unavailable. Wait for sync and try again.", true);
        return;
      }}
      const authorName = bbsDisplayNodeLabel(localId, latestState);
      const entryId = bbsGenerateEntryId();
      const channelRaw = Number(activeRow.channel_index);
      const channelIndex = Number.isInteger(channelRaw) && channelRaw >= 0
        ? channelRaw
        : meshChannelEffectiveSendIndexForApp("bbs");
      const sent = await sendBbsProtocolMessage(
        "post",
        [
          activeRow.board_id,
          activeRow.host_id,
          entryId,
          localId,
          authorName,
          text,
        ],
        {{
          destination: "^all",
          channel_index: channelIndex,
          quiet: false,
        }}
      );
      if (!sent) return;
      bbsAppendBoardPost(activeRow.key, {{
        entry_id: entryId,
        author_id: localId,
        author_name: authorName,
        text,
        unix: Math.floor(Date.now() / 1000),
      }});
      input.value = "";
      setBbsPostStatus(`Posted to ${{activeRow.title || activeRow.board_id}}.`, false, {{ channel_index: channelIndex }});
      if (activeLayoutView === "bbs") {{
        renderBbsTerminal(latestState);
      }}
    }}

    function bindBbsControls() {{
      const titleInput = document.getElementById("bbs-host-title-input");
      if (titleInput instanceof HTMLInputElement && titleInput.dataset.bound !== "1") {{
        titleInput.dataset.bound = "1";
        titleInput.addEventListener("input", () => {{
          bbsHostState.title = sanitizeBbsWireField(titleInput.value, bbsMaxTitleChars) || "Packet Exchange";
          if (!sanitizeBbsWireField(bbsHostState.board_id, 24)) {{
            bbsHostState.board_id = normalizeBbsBoardId("", bbsHostState.title);
          }}
          bbsPersistState();
          if (activeLayoutView === "bbs") {{
            renderBbsHostControls(latestState);
          }}
        }});
      }}
      const boardInput = document.getElementById("bbs-host-id-input");
      if (boardInput instanceof HTMLInputElement && boardInput.dataset.bound !== "1") {{
        boardInput.dataset.bound = "1";
        boardInput.addEventListener("input", () => {{
          bbsHostState.board_id = normalizeBbsBoardId(boardInput.value, bbsHostState.title);
          bbsPersistState();
          if (activeLayoutView === "bbs") {{
            renderBbsHostControls(latestState);
          }}
        }});
      }}
      const motdInput = document.getElementById("bbs-host-motd-input");
      if (motdInput instanceof HTMLInputElement && motdInput.dataset.bound !== "1") {{
        motdInput.dataset.bound = "1";
        motdInput.addEventListener("input", () => {{
          bbsHostState.motd = sanitizeBbsWireField(motdInput.value, bbsMaxMotdChars) || "2400 baud online.";
          bbsPersistState();
          if (activeLayoutView === "bbs") {{
            renderBbsHostControls(latestState);
          }}
        }});
      }}

      const hostBtn = document.getElementById("bbs-host-start-btn");
      if (hostBtn instanceof HTMLButtonElement && hostBtn.dataset.bound !== "1") {{
        hostBtn.dataset.bound = "1";
        hostBtn.addEventListener("click", () => {{
          void startBbsHosting();
        }});
      }}
      const stopBtn = document.getElementById("bbs-host-stop-btn");
      if (stopBtn instanceof HTMLButtonElement && stopBtn.dataset.bound !== "1") {{
        stopBtn.dataset.bound = "1";
        stopBtn.addEventListener("click", () => {{
          void stopBbsHosting();
        }});
      }}
      const announceBtn = document.getElementById("bbs-host-announce-btn");
      if (announceBtn instanceof HTMLButtonElement && announceBtn.dataset.bound !== "1") {{
        announceBtn.dataset.bound = "1";
        announceBtn.addEventListener("click", () => {{
          void announceHostedBbs({{ quiet: false }});
        }});
      }}
      const refreshBtn = document.getElementById("bbs-refresh-directory-btn");
      if (refreshBtn instanceof HTMLButtonElement && refreshBtn.dataset.bound !== "1") {{
        refreshBtn.dataset.bound = "1";
        refreshBtn.addEventListener("click", () => {{
          if (bbsHostState && bbsHostState.enabled) {{
            void announceHostedBbs({{ quiet: true }});
          }}
          requestImmediatePoll(0);
        }});
      }}
      const boardList = document.getElementById("bbs-board-list");
      if (boardList instanceof HTMLElement && boardList.dataset.bound !== "1") {{
        boardList.dataset.bound = "1";
        boardList.addEventListener("click", (ev) => {{
          const target = ev.target;
          if (!(target instanceof Element)) return;
          const row = target.closest(".bbs-board-item");
          if (!(row instanceof HTMLButtonElement)) return;
          const key = String(row.dataset.boardKey || "").trim().toLowerCase();
          if (!key) return;
          bbsSelectBoard(key);
        }});
      }}
      const postBtn = document.getElementById("bbs-post-send-btn");
      if (postBtn instanceof HTMLButtonElement && postBtn.dataset.bound !== "1") {{
        postBtn.dataset.bound = "1";
        postBtn.addEventListener("click", () => {{
          void sendBbsPost();
        }});
      }}
      const postInput = document.getElementById("bbs-post-input");
      if (postInput instanceof HTMLInputElement && postInput.dataset.bound !== "1") {{
        postInput.dataset.bound = "1";
        postInput.addEventListener("keydown", (ev) => {{
          if (ev.key !== "Enter") return;
          ev.preventDefault();
          void sendBbsPost();
        }});
      }}
    }}

    function renderBbsView(state = latestState) {{
      bindBbsControls();
      syncBbsNetworkState(state);
      renderBbsHostControls(state);
      renderBbsDirectory(state);
      renderBbsTerminal(state);
    }}
