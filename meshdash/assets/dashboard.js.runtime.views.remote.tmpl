        bbsHostRuntimeRemoteAvailable = true;
        bbsHostRuntimeLoadedOnce = true;
        const host = (payload.host && typeof payload.host === "object")
          ? payload.host
          : payload;
        const posts = Array.isArray(payload.posts) ? payload.posts : [];
        if (cleanAction === "start") {{
          bbsHostSettingsDirty = false;
        }}
        applyBbsHostRuntime(host, {{
          posts,
          preserveSettings: cleanAction !== "start" && bbsHostSettingsDirty,
          renderView: activeLayoutView === "bbs",
        }});
        return payload;
      }} catch (err) {{
        const msg = err instanceof Error ? err.message : String(err || "unknown error");
        setBbsPostStatus(msg || "BBS host request failed.", true);
        return null;
      }}
    }}

    function loadBbsState() {{
      let stored = null;
      try {{
        const raw = window.localStorage.getItem(bbsStorageKey);
        stored = raw ? JSON.parse(raw) : null;
      }} catch (_err) {{
        stored = null;
      }}
      const source = (stored && typeof stored === "object") ? stored : {{}};
      const next = createBbsHostState(source);
      next.enabled = false;
      next.started_unix = 0;
      next.host_id = "";
      bbsHostState = next;
      const activeKeyRaw = String(source.active_board_key || "").trim().toLowerCase();
      bbsActiveBoardKey = activeKeyRaw.slice(0, 96);
      bbsDiscoveredBoards = [];
      bbsBoardPostsByKey.clear();
      const storedForgottenKeys = Array.isArray(source.forgotten_board_keys)
        ? source.forgotten_board_keys
        : (Array.isArray(source.forgottenBoardKeys) ? source.forgottenBoardKeys : []);
      bbsForgottenBoardKeys = new Set(
        storedForgottenKeys
          .map((key) => normalizeBbsBoardKey(key))
          .filter(Boolean)
          .slice(-bbsBoardDirectoryMaxRows * 4)
      );
      const storedReplicaVersion = Math.trunc(Number(source.replica_version) || Number(source.replicaVersion) || 0);
      const canRestoreBoardReplica = storedReplicaVersion >= 2;
      const storedBoards = canRestoreBoardReplica && Array.isArray(source.boards) ? source.boards : [];
      for (const row of storedBoards.slice(0, bbsBoardDirectoryMaxRows)) {{
        if (!row || typeof row !== "object") continue;
        bbsUpsertDirectoryRow({{
          board_id: row.board_id || row.boardId,
          host_id: row.host_id || row.hostId,
          title: row.title,
          motd: row.motd,
          channel_index: row.channel_index ?? row.channelIndex,
          last_seen_unix: row.last_seen_unix ?? row.lastSeenUnix,
          post_count: row.post_count ?? row.postCount,
          latest_unix: row.latest_unix ?? row.latestUnix,
          latest_entry_id: row.latest_entry_id ?? row.latestEntryId,
        }});
      }}
      const storedPostsByKey = (
        source.posts_by_key && typeof source.posts_by_key === "object"
      ) ? source.posts_by_key : (
        source.postsByKey && typeof source.postsByKey === "object" ? source.postsByKey : null
      );
      if (canRestoreBoardReplica && storedPostsByKey) {{
        const knownKeys = new Set(
          (Array.isArray(bbsDiscoveredBoards) ? bbsDiscoveredBoards : [])
            .map((row) => String(row && row.key || "").trim().toLowerCase())
            .filter(Boolean)
        );
        for (const [keyRaw, posts] of Object.entries(storedPostsByKey)) {{
          const key = String(keyRaw || "").trim().toLowerCase();
          if (!key || !knownKeys.has(key) || !Array.isArray(posts)) continue;
          bbsReplaceBoardPosts(key, posts);
        }}
      }}
      bbsSeenMessageKeys = new Set();
      bbsSeenMessageOrder = [];
      bbsPostStatusText = "";
      bbsPostStatusError = false;
      bbsPostStatusChannelIndex = null;
        bbsHostSettingsLoadedOnce = false;
        bbsHostSettingsFetchInFlight = false;
        bbsHostSettingsSaveInFlight = false;
        bbsHostSettingsSaveQueued = false;
        bbsHostSettingsDirty = false;
        bbsHostSettingsRemoteAvailable = null;
        bbsHostRuntimeLoadedOnce = false;
        bbsHostRuntimeFetchInFlight = false;
        bbsHostRuntimeRemoteAvailable = null;
        clearBbsPendingProfileRequest();
        clearBbsHostSettingsSaveTimer();
        clearBbsAnnounceTimer();
        if (bbsFeatureEnabled) {{
          void fetchBbsHostSettings({{ silent: true }});
          void fetchBbsHostRuntime({{ silent: true }});
        }}
    }}

    function setBbsPostStatus(message, isError = false, options = null) {{
      bbsPostStatusText = String(message == null ? "" : message).trim();
      bbsPostStatusError = !!isError;
      const statusEl = document.getElementById("bbs-post-status");
      if (!(statusEl instanceof HTMLElement)) return;
      statusEl.classList.toggle("is-error", bbsPostStatusError);
      statusEl.textContent = bbsPostStatusText;
    }}

    function bbsHostNodeId(state = latestState) {{
      const clean = normalizeNodeId(resolveLocalNodeId(state) || "");
      return isCanonicalNodeId(clean) ? clean : "";
    }}

    function bbsDisplayNodeLabel(nodeId, state = latestState) {{
      const clean = normalizeNodeId(nodeId || "");
      if (!isCanonicalNodeId(clean)) return clean || "unknown";
      return reversiNodeLabel(clean, state);
    }}

    function bbsIsOfflineLocalBoard(hostId, state = latestState) {{
      const localId = bbsHostNodeId(state);
      const cleanHostId = normalizeNodeId(hostId || "");
      return !!(
        isCanonicalNodeId(localId)
        && cleanHostId === localId
        && !(bbsHostState && bbsHostState.enabled)
      );
    }}

    function bbsResolvePendingLoadFromContent(hostId, boardKey, state = latestState) {{
      const cleanHostId = normalizeNodeId(hostId || "");
      const cleanKey = String(boardKey || "").trim().toLowerCase();
      if (!isCanonicalNodeId(cleanHostId) || !cleanKey) return false;
      const pendingForHost = !!(
        bbsPendingProfileRequestToken
        && (!bbsPendingProfileHostId || bbsPendingProfileHostId === cleanHostId)
      );
      const staleNoReplyStatus = !!(
        bbsPostStatusError
        && String(bbsPostStatusText || "").startsWith("No BBS reply from ")
      );
      if (!pendingForHost && !staleNoReplyStatus) return false;
      if (pendingForHost) {{
        clearBbsPendingProfileRequest();
      }}
      bbsActiveBoardKey = cleanKey;
      setBbsPostStatus(
        `Loaded BBS messages from ${{bbsDisplayNodeLabel(cleanHostId, state)}}.`,
        false
      );
      return true;
    }}

    function bbsUpsertDirectoryRow(row = {{}}) {{
      const boardId = normalizeBbsBoardId(row.board_id || row.boardId || "");
      const hostId = normalizeNodeId(row.host_id || row.hostId || "");
      const key = bbsBoardKey(boardId, hostId);
      if (!key) return "";
      if (bbsIsOfflineLocalBoard(hostId) && row.force !== true) return "";
      if (bbsForgottenBoardKeys.has(key) && row.force !== true) return "";
      const titleCandidate = sanitizeBbsWireField(row.title, bbsMaxTitleChars);
      const motdCandidate = sanitizeBbsWireField(row.motd, bbsMaxMotdChars);
      const nowUnix = Math.floor(Date.now() / 1000);
      const seenUnix = Math.max(0, Math.trunc(Number(row.last_seen_unix ?? row.lastSeenUnix) || nowUnix));
      const channelRaw = Number(row.channel_index ?? row.channelIndex);
      const channelIndex = Number.isInteger(channelRaw) && channelRaw >= 0
        ? Math.trunc(channelRaw)
        : 0;
      const postCountRaw = Number(row.post_count ?? row.postCount);
      const postCount = Number.isFinite(postCountRaw) && postCountRaw >= 0
        ? Math.trunc(postCountRaw)
        : null;
      const latestUnix = Math.max(0, Math.trunc(Number(row.latest_unix ?? row.latestUnix) || 0));
      const latestEntryId = sanitizeBbsWireField(row.latest_entry_id ?? row.latestEntryId, 60);
      const nextRows = [];
      let merged = false;
      for (const current of (Array.isArray(bbsDiscoveredBoards) ? bbsDiscoveredBoards : [])) {{
        if (!current || typeof current !== "object") continue;
        const currentKey = String(current.key || "").trim().toLowerCase();
        if (currentKey !== key) {{
          nextRows.push(current);
          continue;
        }}
        nextRows.push({{
          ...current,
          key,
          board_id: boardId,
          host_id: hostId,
          title: titleCandidate || sanitizeBbsWireField(current.title, bbsMaxTitleChars) || boardId,
          motd: motdCandidate || sanitizeBbsWireField(current.motd, bbsMaxMotdChars),
          last_seen_unix: Math.max(Math.trunc(Number(current.last_seen_unix) || 0), seenUnix),
          channel_index: channelIndex,
          post_count: postCount === null
            ? Math.max(0, Math.trunc(Number(current.post_count ?? current.postCount) || 0))
            : postCount,
          latest_unix: Math.max(0, Math.trunc(Number(current.latest_unix ?? current.latestUnix) || 0), latestUnix),
          latest_entry_id: latestEntryId || sanitizeBbsWireField(current.latest_entry_id ?? current.latestEntryId, 60),
        }});
        merged = true;
      }}
      if (!merged) {{
        nextRows.push({{
          key,
          board_id: boardId,
          host_id: hostId,
          title: titleCandidate || boardId,
          motd: motdCandidate,
          last_seen_unix: seenUnix,
          channel_index: channelIndex,
          post_count: postCount === null ? 0 : postCount,
          latest_unix: latestUnix,
          latest_entry_id: latestEntryId,
        }});
      }}
      const localId = bbsHostNodeId(latestState);
      nextRows.sort((a, b) => {{
        const aLocal = (isCanonicalNodeId(localId) && normalizeNodeId(a && a.host_id) === localId) ? 0 : 1;
        const bLocal = (isCanonicalNodeId(localId) && normalizeNodeId(b && b.host_id) === localId) ? 0 : 1;
        if (aLocal !== bLocal) return aLocal - bLocal;
        const seenDelta = (Number(b && b.last_seen_unix) || 0) - (Number(a && a.last_seen_unix) || 0);
        if (seenDelta !== 0) return seenDelta;
        return String((a && a.key) || "").localeCompare(String((b && b.key) || ""));
      }});
      bbsDiscoveredBoards = nextRows.slice(0, bbsBoardDirectoryMaxRows);
      return key;
    }}

    function bbsUpdateBoardPostSummary(boardKey) {{
      const cleanKey = String(boardKey || "").trim().toLowerCase();
      if (!cleanKey || !Array.isArray(bbsDiscoveredBoards)) return;
      const rows = bbsBoardPostsByKey.get(cleanKey);
      if (!Array.isArray(rows) || !rows.length) return;
      const latest = rows[rows.length - 1] || {{}};
      const latestUnix = Math.max(0, Math.trunc(Number(latest.unix) || 0));
      const latestEntryId = sanitizeBbsWireField(latest.entry_id ?? latest.entryId, 60);
      bbsDiscoveredBoards = bbsDiscoveredBoards.map((row) => {{
        const rowKey = String(row && row.key || "").trim().toLowerCase();
        if (rowKey !== cleanKey) return row;
        return {{
          ...row,
          post_count: Math.max(rows.length, Math.trunc(Number(row.post_count ?? row.postCount) || 0)),
          latest_unix: Math.max(latestUnix, Math.trunc(Number(row.latest_unix ?? row.latestUnix) || 0)),
          latest_entry_id: latestEntryId || sanitizeBbsWireField(row.latest_entry_id ?? row.latestEntryId, 60),
        }};
      }});
    }}

    function bbsRemoveDirectoryRow(boardId, hostId, options = null) {{
      const key = bbsBoardKey(boardId, hostId);
      if (!key) return null;
      return bbsRemoveDirectoryRowByKey(key, options);
    }}

    function bbsPruneDirectoryRows(nowUnix = Math.floor(Date.now() / 1000)) {{
      const hostKey = (bbsHostState && bbsHostState.enabled)
        ? bbsBoardKey(bbsHostState.board_id, bbsHostState.host_id)
        : "";
      const rows = Array.isArray(bbsDiscoveredBoards) ? bbsDiscoveredBoards : [];
      const nextRows = rows.filter((row) => {{
        if (!row || typeof row !== "object") return false;
        const rowKey = String(row.key || "").trim().toLowerCase();
        if (!rowKey) return false;
        if (hostKey && rowKey === hostKey) return true;
        const cachedPosts = bbsBoardPostsByKey.get(rowKey);
        if (Array.isArray(cachedPosts) && cachedPosts.length > 0) return true;
        const age = nowUnix - Math.max(0, Math.trunc(Number(row.last_seen_unix) || 0));
        return age <= bbsBoardStaleSeconds;
      }});
      if (nextRows.length !== rows.length) {{
        const nextKeys = new Set(nextRows.map((row) => String(row && row.key || "").trim().toLowerCase()).filter(Boolean));
        for (const row of rows) {{
          const key = String(row && row.key || "").trim().toLowerCase();
          if (key && !nextKeys.has(key)) {{
            bbsBoardPostsByKey.delete(key);
          }}
        }}
        bbsDiscoveredBoards = nextRows;
        const activeKey = String(bbsActiveBoardKey || "").trim().toLowerCase();
        if (activeKey && !nextKeys.has(activeKey)) {{
          bbsActiveBoardKey = nextRows.length
            ? String(nextRows[0].key || "").trim().toLowerCase()
            : "";
        }}
        bbsPersistState();
      }}
    }}

    function bbsRememberMessageKey(key) {{
      const clean = String(key || "").trim();
      if (!clean) return false;
      if (bbsSeenMessageKeys.has(clean)) return false;
      bbsSeenMessageKeys.add(clean);
      bbsSeenMessageOrder.push(clean);
      if (bbsSeenMessageOrder.length > bbsMaxSeenNetworkMessages) {{
        while (bbsSeenMessageOrder.length > Math.floor(bbsMaxSeenNetworkMessages * 0.72)) {{
          const stale = bbsSeenMessageOrder.shift();
          if (stale) bbsSeenMessageKeys.delete(stale);
        }}
      }}
      return true;
    }}

    function bbsEncodeProtocolMessage(type, ...fields) {{
      const cleanType = String(type || "").trim().toLowerCase();
      if (!cleanType) return "";
      const encoded = [bbsProtocolVersion, cleanType];
      for (const field of fields) {{
        encoded.push(sanitizeBbsWireField(field, bbsMaxPostChars));
      }}
      return encoded.join("|");
    }}

    function parseBbsProtocolMessage(text) {{
      const raw = String(text || "").trim();
      if (!raw || !raw.startsWith(`${{bbsProtocolVersion}}|`)) return null;
      const parts = raw.split("|").map((part) => String(part || "").trim());
      if (parts.length < 2) return null;
      const type = String(parts[1] || "").trim().toLowerCase();
      if (!type) return null;
      return {{ raw, type, parts }};
    }}

    function bbsProtocolMessageText(msg) {{
      if (!msg || typeof msg !== "object") return "";
      return String(msg.text ?? msg.decoded_text ?? msg.payload_text ?? "").trim();
    }}

    function bbsProtocolMessageUnix(msg) {{
      return latestUnixTimestamp(
        msg && msg.rx_time,
        msg && msg.captured_at,
        msg && msg.sent_at,
        msg && msg.created_at
      ) || Math.floor(Date.now() / 1000);
    }}

    function bbsProtocolMessageKey(msg, parsed) {{
      const messageId = messageIdOfChatPacket(msg);
      if (messageId) return `bbs:msg:${{messageId}}`;
      const fromId = normalizeNodeId(msg && msg.from || "");
      const toId = normalizeNodeId(msg && (msg.to || msg.destination) || "");
      return [
        "bbs",
        "raw",
        fromId,
        toId,
        String(msg && msg.rx_time || ""),
        String(parsed && parsed.raw || ""),
      ].join("|");
    }}

    function bbsPostsForBoard(boardKey) {{
      const cleanKey = String(boardKey || "").trim().toLowerCase();
      if (!cleanKey) return [];
      const existing = bbsBoardPostsByKey.get(cleanKey);
      if (Array.isArray(existing)) return existing;
      const rows = [];
      bbsBoardPostsByKey.set(cleanKey, rows);
      return rows;
    }}

    function bbsPostUnixFromWire(value) {{
      const num = Number(value);
      if (!Number.isFinite(num) || num <= 0) return 0;
      return Math.trunc(num);
    }}

    function bbsDecodeBatchPayload(rawPayload) {{
      let text = String(rawPayload || "").trim();
      if (!text) return [];
      text = text.replace(/-/g, "+").replace(/_/g, "/");
      while (text.length % 4 !== 0) text += "=";
      let jsonText = "";
      try {{
        jsonText = atob(text);
      }} catch (_err) {{
        return [];
      }}
      try {{
        const parsed = JSON.parse(jsonText);
        return Array.isArray(parsed) ? parsed : [];
      }} catch (_err) {{
        return [];
      }}
    }}

    function bbsPostFromBatchRow(row, fallbackAuthorId = "") {{
      if (!Array.isArray(row)) return null;
      const entryId = sanitizeBbsWireField(row[0], 60);
      const authorId = normalizeNodeId(row[1] || fallbackAuthorId || "");
      const authorName = sanitizeBbsWireField(row[2], 48);
      const text = sanitizeBbsWireField(row[3], bbsMaxPostChars);
      const unix = bbsPostUnixFromWire(row[4]);
      if (!entryId || !text) return null;
      return {{
        entry_id: entryId,
        author_id: authorId,
        author_name: authorName || bbsDisplayNodeLabel(authorId || fallbackAuthorId, latestState),
        text,
        unix,
      }};
    }}

    function bbsDecodeUtf8Bytes(bytes) {{
      if (!(bytes instanceof Uint8Array)) return "";
      try {{
        if (typeof TextDecoder !== "undefined") {{
          return new TextDecoder("utf-8").decode(bytes);
        }}
      }} catch (_err) {{
      }}
      let out = "";
      for (const byte of bytes) {{
        out += String.fromCharCode(byte);
      }}
      try {{
        return decodeURIComponent(escape(out));
      }} catch (_err) {{
        return out;
      }}
    }}

    function bbsApplySnapshotPayload(payload, state = latestState) {{
      const source = (payload && typeof payload === "object") ? payload : null;
      if (!source || source.kind !== "easyface-bbs-snapshot-v1") return false;
      const boardId = normalizeBbsBoardId(source.board_id || source.boardId || "");
      const hostId = normalizeNodeId(source.host_id || source.hostId || "");
      if (!boardId || !isCanonicalNodeId(hostId)) return false;
      const posts = Array.isArray(source.posts) ? source.posts : [];
      const key = bbsUpsertDirectoryRow({{
        board_id: boardId,
        host_id: hostId,
        title: source.title,
        motd: source.motd,
        post_count: source.post_count ?? source.postCount,
        latest_unix: source.latest_unix ?? source.latestUnix,
        latest_entry_id: source.latest_entry_id ?? source.latestEntryId,
        last_seen_unix: source.latest_unix ?? source.latestUnix ?? Math.floor(Date.now() / 1000),
      }});
      if (!key) return false;
      let appended = 0;
      for (const row of posts) {{
        const post = bbsPostFromBatchRow(row, hostId);
        if (!post) continue;
        if (bbsAppendBoardPost(key, post)) appended += 1;
      }}
      if (!bbsResolvePendingLoadFromContent(hostId, key, state) && !bbsActiveBoardKey) {{
        bbsActiveBoardKey = key;
      }}
      bbsPersistState();
      if (appended > 0) {{
        setBbsPostStatus(
          `Loaded BBS snapshot from ${{bbsDisplayNodeLabel(hostId, state)}}.`,
          false
        );
      }}
      return true;
    }}

    function syncBbsSnapshotTransfers(state = latestState) {{
      if (typeof buildFileTransferRows !== "function") return false;
      let rows = [];
      try {{
        rows = buildFileTransferRows(state);
      }} catch (_err) {{
        return false;
      }}
      if (!Array.isArray(rows) || !rows.length) return false;
      let changed = false;
      for (const row of rows) {{
        if (!row || typeof row !== "object") continue;
        const key = String(row.key || row.transferId || "").trim();
        const fileName = String(row.fileName || "").trim().toLowerCase();
        if (!key || bbsSnapshotTransferKeysImported.has(key)) continue;
        if (!row.canDownload || !(row.bytes instanceof Uint8Array)) continue;
        if (!fileName.startsWith("bbs-snapshot-") || !fileName.endsWith(".json")) continue;
        const text = bbsDecodeUtf8Bytes(row.bytes);
        if (!text) continue;
        let payload = null;
        try {{
          payload = JSON.parse(text);
        }} catch (_err) {{
          continue;
        }}
        if (bbsApplySnapshotPayload(payload, state)) {{
          bbsSnapshotTransferKeysImported.add(key);
          changed = true;
        }}
      }}
      return changed;
    }}

    function bbsLatestPostCursorForBoard(boardKey) {{
      const cleanKey = String(boardKey || "").trim().toLowerCase();
      if (!cleanKey) return {{ board_id: "", since_unix: 0, tail_entry_id: "" }};
      const rows = bbsPostsForBoard(cleanKey)
        .filter((row) => row && typeof row === "object")
        .slice()
        .sort((a, b) => {{
          const unixDelta = (Number(a && a.unix) || 0) - (Number(b && b.unix) || 0);
          if (unixDelta !== 0) return unixDelta;
          return String(a && a.entry_id || "").localeCompare(String(b && b.entry_id || ""));
        }});
      const latest = rows.length ? rows[rows.length - 1] : null;
      if (!latest) return {{ board_id: "", since_unix: 0, tail_entry_id: "" }};
      return {{
        board_id: "",
        since_unix: Math.max(0, Math.trunc(Number(latest.unix) || 0)),
        tail_entry_id: sanitizeBbsWireField(latest.entry_id, 60),
      }};
    }}

    function bbsAppendBoardPost(boardKey, post = {{}}) {{
      const cleanKey = String(boardKey || "").trim().toLowerCase();
      if (!cleanKey) return false;
      const text = sanitizeBbsWireField(post.text, bbsMaxPostChars);
      if (!text) return false;
      const rows = bbsPostsForBoard(cleanKey);
      const entryId = sanitizeBbsWireField(post.entry_id ?? post.entryId, 60);
      const authorId = normalizeNodeId(post.author_id ?? post.authorId ?? "");
      const fallbackAuthor = isCanonicalNodeId(authorId) ? authorId : "anonymous";
      const authorName = sanitizeBbsWireField(post.author_name ?? post.authorName, 48) || fallbackAuthor;
      const unixValue = Math.max(0, Math.trunc(Number(post.unix) || Math.floor(Date.now() / 1000)));
      const nextPost = {{
        entry_id: entryId || `local-${{Date.now().toString(36)}}`,
        author_id: isCanonicalNodeId(authorId) ? authorId : "",
        author_name: authorName,
        text,
        unix: unixValue,
      }};
      const existingIdx = entryId
        ? rows.findIndex((row) => String(row && row.entry_id || "") === entryId)
        : -1;
      if (existingIdx >= 0) {{
        rows[existingIdx] = {{
          ...rows[existingIdx],
          ...nextPost,
          entry_id: entryId,
        }};
      }} else {{
        rows.push(nextPost);
      }}
      rows.sort((a, b) => {{
        const unixDelta = (Number(a && a.unix) || 0) - (Number(b && b.unix) || 0);
        if (unixDelta !== 0) return unixDelta;
        return String(a && a.entry_id || "").localeCompare(String(b && b.entry_id || ""));
      }});
      if (rows.length > bbsBoardMaxPosts) {{
        rows.splice(0, rows.length - bbsBoardMaxPosts);
      }}
      bbsBoardPostsByKey.set(cleanKey, rows);
      bbsUpdateBoardPostSummary(cleanKey);
      return true;
    }}

    function bbsReplaceBoardPosts(boardKey, posts = []) {{
      const cleanKey = String(boardKey || "").trim().toLowerCase();
      if (!cleanKey) return [];
      bbsBoardPostsByKey.set(cleanKey, []);
      const sourceRows = Array.isArray(posts) ? posts : [];
      for (const row of sourceRows) {{
        bbsAppendBoardPost(cleanKey, row);
      }}
      return bbsPostsForBoard(cleanKey);
    }}

    function bbsGenerateEntryId() {{
      const now = Date.now().toString(36);
      const rand = Math.random().toString(36).slice(2, 8);
      return `${{now}}${{rand}}`.slice(0, 18);
    }}

    async function sendBbsProtocolMessage(
      type,
      fields = [],
      {{
        destination = "^all",
        channel_index = null,
        quiet = false,
      }} = {{}}
    ) {{
      if (chatSendInFlight) {{
        if (!quiet) {{
          setBbsPostStatus("Another message is already sending. Try again in a moment.", true);
        }}
        return false;
      }}
      const encoded = bbsEncodeProtocolMessage(type, ...(Array.isArray(fields) ? fields : []));
      if (!encoded) {{
        if (!quiet) {{
          setBbsPostStatus("Could not encode BBS payload.", true);
        }}
        return false;
      }}
      const channelIndex = normalizeMeshChannelIndex(
        channel_index == null ? meshChannelEffectiveSendIndexForApp("bbs") : channel_index
      );
      const payload = await sendChatPayload(
        {{
          text: encoded,
          destination: destination || "^all",
          channel_index: channelIndex,
        }},
        null,
        {{
          statusFn: setBbsPostStatus,
          showSendingStatus: false,
          showSuccessStatus: false,
          showErrorStatus: false,
        }}
      );
      if (!payload || payload.ok !== true) {{
        if (!quiet) {{
          setBbsPostStatus("BBS send failed.", true);
        }}
        return false;
      }}
      return true;
    }}

    function bbsEnsureHostDirectoryEntry(state = latestState) {{
      if (!(bbsHostState && bbsHostState.enabled)) return;
      syncHostedBbsDirectoryEntry(state);
    }}

    function bbsActiveBoardRow() {{
      const rows = Array.isArray(bbsDiscoveredBoards) ? bbsDiscoveredBoards : [];
      const key = String(bbsActiveBoardKey || "").trim().toLowerCase();
      if (!key) return null;
      return rows.find((row) => String(row && row.key || "").trim().toLowerCase() === key) || null;
    }}

    function bbsDirectoryRowForHost(nodeId) {{
      const cleanNodeId = normalizeNodeId(nodeId || "");
      if (!isCanonicalNodeId(cleanNodeId)) return null;
      const rows = Array.isArray(bbsDiscoveredBoards) ? bbsDiscoveredBoards : [];
      return rows.find((row) => normalizeNodeId(row && row.host_id || "") === cleanNodeId) || null;
    }}

    function bbsRequestTargetNodeId(state = latestState) {{
      const selectedId = normalizeNodeId(selectedNodeId || "");
      if (isSelectableNodeId(selectedId)) return selectedId;
      const remoteSelectedId = normalizeNodeId(remoteTargetNodeId || "");
      if (isSelectableNodeId(remoteSelectedId)) return remoteSelectedId;
      const activeRow = bbsActiveBoardRow();
      const activeHostId = normalizeNodeId(activeRow && activeRow.host_id || "");
      if (isSelectableNodeId(activeHostId)) return activeHostId;
      const localId = bbsHostNodeId(state);
      if (bbsHostState && bbsHostState.enabled && isCanonicalNodeId(localId)) {{
        return localId;
      }}
      return "";
    }}

    function bbsSelectBoard(boardKey) {{
      const clean = String(boardKey || "").trim().toLowerCase();
      if (!clean) return;
      if (!Array.isArray(bbsDiscoveredBoards) || !bbsDiscoveredBoards.some((row) => String(row && row.key || "").trim().toLowerCase() === clean)) {{
        return;
      }}
      bbsActiveBoardKey = clean;
      bbsPersistState();
      if (activeLayoutView === "bbs") {{
        renderBbsView(latestState);
      }}
    }}

    function forgetSelectedBbsBoard() {{
      const activeRow = bbsActiveBoardRow();
      if (!activeRow) {{
        setBbsPostStatus("Select a loaded space to forget.", true);
        if (activeLayoutView === "bbs") {{
          renderBbsDirectory(latestState);
          renderBbsTerminal(latestState);
        }}
        return;
      }}
      const key = String(activeRow && activeRow.key || "").trim().toLowerCase();
      const hostedKey = (bbsHostState && bbsHostState.enabled)
        ? bbsBoardKey(bbsHostState.board_id, bbsHostState.host_id || bbsHostNodeId(latestState))
        : "";
      if (key && hostedKey && key === hostedKey) {{
        setBbsPostStatus("Use Go Offline to remove your hosted local space.", true);
        return;
      }}
      const title = sanitizeBbsWireField(activeRow && activeRow.title, bbsMaxTitleChars)
        || sanitizeBbsWireField(activeRow && activeRow.board_id, 24)
        || "space";
      bbsForgetDirectoryKey(key);
      const removed = bbsRemoveDirectoryRowByKey(key);
      if (!removed) {{
        setBbsPostStatus("Selected space was already gone.", false);
      }} else {{
        setBbsPostStatus(`Forgot loaded space "${{title}}".`, false);
      }}
      if (activeLayoutView === "bbs") {{
        renderBbsView(latestState);
      }}
    }}

    function openBbsBoard(boardKey) {{
      const clean = String(boardKey || "").trim().toLowerCase();
      if (!bbsFeatureEnabled || !clean) return false;
      if (!Array.isArray(bbsDiscoveredBoards) || !bbsDiscoveredBoards.some((row) => String(row && row.key || "").trim().toLowerCase() === clean)) {{
        return false;
      }}
      bbsSelectBoard(clean);
      applyLayoutView("bbs", true);
      if (activeLayoutView === "bbs") {{
        renderBbsView(latestState);
      }}
      return true;
    }}

    async function requestBbsSpaceForNode(nodeId, options = null) {{
      const opts = (options && typeof options === "object") ? options : {{}};
      const silent = !!opts.silent;
      const openView = opts.openView !== false;
      const preserveCurrent = !!opts.preserveCurrent;
      const cleanNodeId = normalizeNodeId(nodeId || "");
      if (!isSelectableNodeId(cleanNodeId)) {{
        if (!silent) {{
          setBbsPostStatus("Select a node before requesting a BBS space.", true);
        }}
        return false;
      }}
      if (isSelfNodeId(cleanNodeId, latestState)) {{
        if (!(bbsHostState && bbsHostState.enabled)) {{
          if (!silent) {{
            setBbsPostStatus("Your local BBS space is offline. Host it first.", true);
          }}
          return false;
        }}
        syncHostedBbsDirectoryEntry(latestState);
        bbsActiveBoardKey = bbsBoardKey(bbsHostState.board_id, bbsHostState.host_id || bbsHostNodeId(latestState));
        clearBbsPendingProfileRequest();
        bbsPersistState();
        if (openView) {{
          applyLayoutView("bbs", true);
          if (activeLayoutView === "bbs") {{
            renderBbsView(latestState);
          }}
        }}
        if (!silent) {{
          setBbsPostStatus(`Opened local BBS space "${{bbsHostState.title}}".`);
        }}
        return true;
      }}

      if (bbsAllowDirectoryKeysForHost(cleanNodeId)) {{
        bbsPersistState();
      }}
      const cachedRow = bbsDirectoryRowForHost(cleanNodeId);
      if (cachedRow && preserveCurrent !== false) {{
        bbsActiveBoardKey = String(cachedRow.key || "").trim().toLowerCase();
      }} else if (!preserveCurrent) {{
        bbsActiveBoardKey = "";
      }}
      const cursorRow = cachedRow || null;
      const cursorKey = cursorRow ? String(cursorRow.key || "").trim().toLowerCase() : "";
      const cursor = cursorKey ? bbsLatestPostCursorForBoard(cursorKey) : {{ since_unix: 0, tail_entry_id: "" }};
      const requestBoardId = cursorRow ? normalizeBbsBoardId(cursorRow.board_id || cursorRow.boardId || "") : "";
      const requestSinceUnix = Math.max(0, Math.trunc(Number(cursor.since_unix) || 0));
      const requestTailEntryId = sanitizeBbsWireField(cursor.tail_entry_id, 60);
      const requestToken = bbsGenerateRequestToken();
      const openFields = [requestToken];
      if (requestBoardId || requestSinceUnix > 0 || requestTailEntryId) {{
        openFields.push(requestBoardId, requestSinceUnix, requestTailEntryId);
      }}
      setBbsPendingProfileRequest(cleanNodeId, requestToken);
      bbsPersistState();
      if (openView) {{
        applyLayoutView("bbs", true);
        if (activeLayoutView === "bbs") {{
          renderBbsView(latestState);
        }}
      }}
      const channelIndex = meshChannelEffectiveSendIndexForApp("bbs");
      const sent = await sendBbsProtocolMessage(
        "open",
        openFields,
        {{
          destination: cleanNodeId,
          channel_index: channelIndex,
          quiet: true,
        }}
      );
      if (!sent) {{
        clearBbsPendingProfileRequest();
        if (!silent) {{
          setBbsPostStatus(`Could not request BBS space from ${{bbsDisplayNodeLabel(cleanNodeId, latestState)}}.`, true);
        }}
        if (activeLayoutView === "bbs") {{
          renderBbsView(latestState);
        }}
        return false;
      }}
      if (!silent) {{
        setBbsPostStatus(
          `Requesting BBS space from ${{bbsDisplayNodeLabel(cleanNodeId, latestState)}}...`,
          false,
          {{ channel_index: channelIndex }}
        );
      }}
      return true;
    }}

    async function respondToBbsOpenRequest(nodeId, requestToken, channelIndex, state = latestState) {{
      const cleanNodeId = normalizeNodeId(nodeId || "");
      const cleanToken = sanitizeBbsWireField(requestToken, 40);
      if (!isCanonicalNodeId(cleanNodeId) || !cleanToken) return false;
      if (!(bbsHostState && bbsHostState.enabled)) return false;
      const localId = bbsHostNodeId(state);
      if (!isCanonicalNodeId(localId)) return false;
      const settings = bbsExportHostSettings();
      bbsHostState.title = settings.title;
      bbsHostState.board_id = settings.board_id;
      bbsHostState.motd = settings.motd;
      bbsHostState.host_id = localId;
      syncHostedBbsDirectoryEntry(state);
      return sendBbsProtocolMessage(
        "profile",
        [cleanToken, settings.board_id, localId, settings.title, settings.motd],
        {{
          destination: cleanNodeId,
          channel_index: normalizeMeshChannelIndex(channelIndex),
          quiet: true,
        }}
      );
    }}

    async function openBbsBoardForHost(nodeId) {{
      const row = bbsDirectoryRowForHost(nodeId);
      if (row) {{
        const opened = openBbsBoard(String(row.key || "").trim().toLowerCase());
        if (!isSelfNodeId(nodeId, latestState)) {{
          void requestBbsSpaceForNode(nodeId, {{ silent: true, openView: false, preserveCurrent: true }});
        }}
        return opened;
      }}
      return requestBbsSpaceForNode(nodeId, {{ silent: false, openView: true, preserveCurrent: false }});
    }}

    function armBbsAnnounceTimer() {{
      clearBbsAnnounceTimer();
      if (!(bbsHostState && bbsHostState.enabled)) return;
      bbsHostAnnounceTimer = window.setInterval(() => {{
        void announceHostedBbs({{ quiet: true }});
      }}, bbsHostAnnounceIntervalMs);
    }}

    async function announceHostedBbs(options = null) {{
      if (!(bbsHostState && bbsHostState.enabled)) return false;
      const opts = (options && typeof options === "object") ? options : {{}};
      const boardId = normalizeBbsBoardId(bbsHostState.board_id, bbsHostState.title);
      const hostId = normalizeNodeId(bbsHostState.host_id || bbsHostNodeId(latestState));
      if (!boardId || !isCanonicalNodeId(hostId)) {{
        if (!opts.quiet) {{
          setBbsPostStatus("Local node ID is unavailable, so BBS hosting cannot announce yet.", true);
        }}
        return false;
      }}
      bbsHostState.board_id = boardId;
      bbsHostState.host_id = hostId;
      const sent = await sendBbsProtocolMessage(
        "announce",
        [boardId, hostId, bbsHostState.title, bbsHostState.motd],
        {{
          destination: "^all",
          channel_index: bbsHostState.channel_index,
          quiet: !!opts.quiet,
        }}
      );
      if (!sent) return false;
      bbsUpsertDirectoryRow({{
        board_id: boardId,
        host_id: hostId,
        title: bbsHostState.title,
        motd: bbsHostState.motd,
        channel_index: bbsHostState.channel_index,
        last_seen_unix: Math.floor(Date.now() / 1000),
      }});
      if (!bbsActiveBoardKey) {{
        bbsActiveBoardKey = bbsBoardKey(boardId, hostId);
      }}
      if (!opts.quiet) {{
        setBbsPostStatus(
          `Broadcast listing sent for "${{bbsHostState.title}}".`,
          false,
          {{ channel_index: bbsHostState.channel_index }}
        );
      }}
      return true;
    }}

    async function startBbsHosting() {{
      const localId = bbsHostNodeId(latestState);
      if (!isCanonicalNodeId(localId)) {{
        setBbsPostStatus("Local node ID is unavailable. Wait for sync and try again.", true);
        if (activeLayoutView === "bbs") renderBbsView(latestState);
        return;
      }}
      const titleInput = document.getElementById("bbs-host-title-input");
      const boardInput = document.getElementById("bbs-host-id-input");
      const motdInput = document.getElementById("bbs-host-motd-input");
      const title = sanitizeBbsWireField(
        titleInput instanceof HTMLInputElement ? titleInput.value : bbsHostState.title,
        bbsMaxTitleChars
      ) || "Packet Exchange";
      let boardId = normalizeBbsBoardId(
        boardInput instanceof HTMLInputElement ? boardInput.value : bbsHostState.board_id,
        title
      );
      if (!boardId) {{
        boardId = `bbs-${{Date.now().toString(36).slice(-6)}}`;
      }}
      const motd = sanitizeBbsWireField(
        motdInput instanceof HTMLInputElement ? motdInput.value : bbsHostState.motd,
        bbsMaxMotdChars
      ) || "2400 baud online.";
      const channelIndex = meshChannelEffectiveSendIndexForApp("bbs");
      const payload = await postBbsHostCommand("start", {{
        channel_index: channelIndex,
        settings: {{ title, board_id: boardId, motd }},
      }});
      if (!payload || payload.ok !== true) {{
        if (activeLayoutView === "bbs") {{
          renderBbsView(latestState);
        }}
        return;
      }}
      const hostKey = bbsBoardKey(bbsHostState.board_id, bbsHostState.host_id || localId);
      if (hostKey) {{
        bbsActiveBoardKey = hostKey;
        bbsPersistState();
      }}
      setBbsPostStatus(`Hosting "${{title}}" for direct BBS requests.`, false, {{ channel_index: channelIndex }});
      if (activeLayoutView === "bbs") {{
        renderBbsView(latestState);
      }}
      requestImmediatePoll(0);
    }}

    async function stopBbsHosting() {{
      if (!(bbsHostState && bbsHostState.enabled)) return;
      const channelIndex = normalizeMeshChannelIndex(bbsHostState.channel_index);
      const payload = await postBbsHostCommand("stop");
      if (!payload || payload.ok !== true) {{
        if (activeLayoutView === "bbs") {{
          renderBbsView(latestState);
        }}
        return;
      }}
      if (bbsHostSettingsDirty) {{
        void saveBbsHostSettings({{ silent: true }});
      }}
      setBbsPostStatus("BBS host is now offline.", false, {{ channel_index: channelIndex }});
      if (activeLayoutView === "bbs") {{
        renderBbsView(latestState);
      }}
      requestImmediatePoll(0);
    }}

    function renderBbsDirectory(state = latestState) {{
      bbsPruneDirectoryRows();
      const listEl = document.getElementById("bbs-board-list");
      const requestBtn = document.getElementById("bbs-refresh-directory-btn");
      const forgetBtn = document.getElementById("bbs-forget-directory-btn");
      const requestTargetId = bbsRequestTargetNodeId(state);
      const activeRow = bbsActiveBoardRow();
      const activeKey = String(bbsActiveBoardKey || "").trim().toLowerCase();
      const hostedKey = (bbsHostState && bbsHostState.enabled)
        ? bbsBoardKey(bbsHostState.board_id, bbsHostState.host_id || bbsHostNodeId(state))
        : "";
      if (requestBtn instanceof HTMLButtonElement) {{
        requestBtn.disabled = !isSelectableNodeId(requestTargetId);
      }}
      if (forgetBtn instanceof HTMLButtonElement) {{
        const activeIsHostedLocal = !!(activeKey && hostedKey && activeKey === hostedKey);
        forgetBtn.disabled = !activeRow || activeIsHostedLocal;
        forgetBtn.title = activeIsHostedLocal
          ? "Use Go Offline to remove your hosted local space"
          : "Forget the selected loaded space";
      }}
      if (!(listEl instanceof HTMLElement)) return;
      const rows = Array.isArray(bbsDiscoveredBoards) ? bbsDiscoveredBoards : [];
      if (!rows.length) {{
        listEl.innerHTML = '<div class="bbs-board-empty">No spaces loaded yet. Select a node and request its space.</div>';
        return;
      }}
      listEl.innerHTML = rows.map((row) => {{
        const key = String(row && row.key || "").trim().toLowerCase();
        const isActive = key && activeKey && key === activeKey;
        const title = sanitizeBbsWireField(row && row.title, bbsMaxTitleChars) || sanitizeBbsWireField(row && row.board_id, 24) || "Board";
        const boardId = sanitizeBbsWireField(row && row.board_id, 24) || "unknown";
        const hostId = normalizeNodeId(row && row.host_id || "");
        const hostLabel = bbsDisplayNodeLabel(hostId, state);
        const motd = sanitizeBbsWireField(row && row.motd, bbsMaxMotdChars);
        const seenUnix = Math.max(0, Math.trunc(Number(row && row.last_seen_unix) || 0));
        const roleLabel = isSelfNodeId(hostId, state) ? "local" : "remote";
        return `<button
          type="button"
          class="bbs-board-item${{isActive ? " is-active" : ""}}"
          data-board-key="${{escAttr(key)}}"
          role="option"
          aria-selected="${{isActive ? "true" : "false"}}"
        >
          <span class="bbs-board-main">${{escAttr(title)}}</span>
          <span class="bbs-board-meta">${{escAttr(boardId)}} • host ${{escAttr(hostLabel)}} (${{escAttr(roleLabel)}}) • loaded ${{escAttr(formatLocalChatTime(seenUnix, "n/a"))}}</span>
          <span class="bbs-board-motd">${{escAttr(motd || "No banner set.")}}</span>
        </button>`;
      }}).join("");
    }}

    function renderBbsTerminal(state = latestState) {{
      const titleEl = document.getElementById("bbs-terminal-title");
      const metaEl = document.getElementById("bbs-terminal-meta");
      const logEl = document.getElementById("bbs-terminal-log");
      const inputEl = document.getElementById("bbs-post-input");
      const sendBtn = document.getElementById("bbs-post-send-btn");
      const activeRow = bbsActiveBoardRow();
      if (!(logEl instanceof HTMLElement)) return;
      if (!activeRow) {{
        const pendingHostId = normalizeNodeId(bbsPendingProfileHostId || "");
        const pendingLabel = isCanonicalNodeId(pendingHostId)
          ? bbsDisplayNodeLabel(pendingHostId, state)
          : "";
        if (titleEl instanceof HTMLElement) {{
          titleEl.textContent = pendingLabel ? `Awaiting ${{pendingLabel}}` : "No space selected";
        }}
        if (metaEl instanceof HTMLElement) {{
          metaEl.textContent = pendingLabel
            ? `Waiting for a direct BBS reply from ${{pendingLabel}}.`
            : "Select a node and request its space.";
        }}
        if (inputEl instanceof HTMLInputElement) {{
          inputEl.disabled = true;
          inputEl.placeholder = pendingLabel ? "Waiting for profile reply..." : "Profile space will open here...";
        }}
        if (sendBtn instanceof HTMLButtonElement) {{
          sendBtn.disabled = true;
        }}
        logEl.textContent = pendingLabel
          ? `*** CONNECT 2400 ***\nDialing ${{pendingLabel}}...\nAwaiting direct profile reply.\n`
          : "*** CONNECT 2400 ***\nSelect a node and request its space.\n";
        return;
      }}
      if (titleEl instanceof HTMLElement) {{
        const hostLabel = bbsDisplayNodeLabel(activeRow.host_id, state);
        titleEl.textContent = `${{activeRow.title || activeRow.board_id || "Board"}} @ ${{hostLabel}}`;
      }}
      if (metaEl instanceof HTMLElement) {{
        const motd = sanitizeBbsWireField(activeRow.motd, bbsMaxMotdChars) || "No banner set.";
        metaEl.textContent = motd;
      }}
      if (inputEl instanceof HTMLInputElement) {{
        inputEl.disabled = false;
        inputEl.placeholder = `Post to ${{activeRow.board_id}}...`;
      }}
      if (sendBtn instanceof HTMLButtonElement) {{
        sendBtn.disabled = false;
      }}
      const rows = bbsPostsForBoard(activeRow.key);
      const lines = [
        "*** CONNECT 2400 ***",
        `BOARD: ${{activeRow.title || activeRow.board_id}} (${{activeRow.board_id}})`,
        `HOST: ${{bbsDisplayNodeLabel(activeRow.host_id, state)}}`,
        `MOTD: ${{sanitizeBbsWireField(activeRow.motd, bbsMaxMotdChars) || "No banner set."}}`,
        "----------------------------------------",
      ];
      if (!rows.length) {{
        const expectedCount = Math.max(0, Math.trunc(Number(activeRow.post_count ?? activeRow.postCount) || 0));
        if (expectedCount > 0) {{
          lines.push(`Waiting for ${{expectedCount}} post${{expectedCount === 1 ? "" : "s"}} from history sync.`);
        }} else {{
          lines.push("No posts yet. Type a message to start the thread.");
        }}
      }} else {{
        for (const row of rows) {{
          if (!row || typeof row !== "object") continue;
          const stamp = formatLocalChatTime(Math.max(0, Math.trunc(Number(row.unix) || 0)), "n/a");
          const author = sanitizeBbsWireField(row.author_name, 48) || sanitizeBbsWireField(row.author_id, 24) || "anon";
          lines.push(`[${{stamp}}] <${{author}}> ${{row.text || ""}}`);
        }}
      }}
      logEl.textContent = lines.join("\n");
      if (logEl instanceof HTMLElement) {{
        logEl.scrollTop = logEl.scrollHeight;
      }}
    }}

    function renderBbsHostControls(state = latestState) {{
      bbsEnsureHostDirectoryEntry(state);
      const titleInput = document.getElementById("bbs-host-title-input");
      const boardInput = document.getElementById("bbs-host-id-input");
      const motdInput = document.getElementById("bbs-host-motd-input");
      const startBtn = document.getElementById("bbs-host-start-btn");
      const stopBtn = document.getElementById("bbs-host-stop-btn");
      const hostStatus = document.getElementById("bbs-host-status");
      if (titleInput instanceof HTMLInputElement && document.activeElement !== titleInput) {{
        if (titleInput.value !== String(bbsHostState.title || "")) {{
          titleInput.value = String(bbsHostState.title || "");
        }}
      }}
      if (boardInput instanceof HTMLInputElement && document.activeElement !== boardInput) {{
        if (boardInput.value !== String(bbsHostState.board_id || "")) {{
          boardInput.value = String(bbsHostState.board_id || "");
        }}
      }}
      if (motdInput instanceof HTMLInputElement && document.activeElement !== motdInput) {{
        if (motdInput.value !== String(bbsHostState.motd || "")) {{
          motdInput.value = String(bbsHostState.motd || "");
        }}
      }}
      const localId = bbsHostNodeId(state);
      const hostEnabled = !!(bbsHostState && bbsHostState.enabled);
      if (startBtn instanceof HTMLButtonElement) {{
        startBtn.disabled = hostEnabled || !isCanonicalNodeId(localId);
      }}
      if (stopBtn instanceof HTMLButtonElement) {{
        stopBtn.disabled = !hostEnabled;
      }}
      if (hostStatus instanceof HTMLElement) {{
        if (!isCanonicalNodeId(localId)) {{
          hostStatus.textContent = "Waiting for local node identity before hosting can start.";
        }} else if (!hostEnabled) {{
          hostStatus.textContent = "Offline. Fill out your space and click Host Space. Nothing is advertised on the mesh.";
        }} else {{
          hostStatus.textContent = `Online as "${{bbsHostState.title}}" (${{
            bbsHostState.board_id
          }}). Replies only to direct BBS requests.`;
        }}
      }}
      setBbsPostStatus(bbsPostStatusText, bbsPostStatusError);
    }}

    function syncBbsNetworkState(state = latestState) {{
      const safeState = (state && typeof state === "object") ? state : null;
      if (!safeState) return;
      const localId = bbsHostNodeId(safeState);
      const traffic = safeState.traffic && typeof safeState.traffic === "object"
        ? safeState.traffic
        : {{}};
      const recentChat = Array.isArray(traffic.recent_chat) ? traffic.recent_chat : [];
      for (const msg of recentChat) {{
        if (!msg || typeof msg !== "object") continue;
        if (msg.local_echo === true || msg.localEcho === true) continue;
        const parsed = parseBbsProtocolMessage(bbsProtocolMessageText(msg));
        if (!parsed) continue;
        const fromId = normalizeNodeId(msg.from || "");
        const toRaw = String(msg.to ?? msg.destination ?? "").trim();
        const toToken = toRaw.toLowerCase();
        const toId = normalizeNodeId(toRaw);
        const toAll = !toRaw || toToken === "^all" || toToken === "all" || toToken === "broadcast";
        if (!toAll) {{
          if (!isCanonicalNodeId(localId)) continue;
          if (!isCanonicalNodeId(toId) || toId !== localId) continue;
        }}
        const dedupeKey = bbsProtocolMessageKey(msg, parsed);
        if (!bbsRememberMessageKey(dedupeKey)) continue;
        if (parsed.type === "open") {{
          const requestToken = sanitizeBbsWireField(parsed.parts[2], 40);
          if (!requestToken) continue;
          if (!isCanonicalNodeId(localId) || !isCanonicalNodeId(fromId) || toId !== localId) continue;
          continue;
        }}
        if (parsed.type === "profile") {{
          const requestToken = sanitizeBbsWireField(parsed.parts[2], 40);
          const boardId = normalizeBbsBoardId(parsed.parts[3] || "");
          const hostId = normalizeNodeId(parsed.parts[4] || fromId);
          if (!boardId || !isCanonicalNodeId(hostId)) continue;
          const title = sanitizeBbsWireField(parsed.parts[5], bbsMaxTitleChars) || boardId;
          const motd = sanitizeBbsWireField(parsed.parts[6], bbsMaxMotdChars);
          const postCount = Math.max(0, Math.trunc(Number(parsed.parts[7]) || 0));
          const latestUnix = bbsPostUnixFromWire(parsed.parts[8]);
          const latestEntryId = sanitizeBbsWireField(parsed.parts[9], 60);
          const key = bbsUpsertDirectoryRow({{
            board_id: boardId,
            host_id: hostId,
            title,
            motd,
            channel_index: messageMeshChannelIndex(msg),
            last_seen_unix: bbsProtocolMessageUnix(msg),
            post_count: postCount,
            latest_unix: latestUnix,
            latest_entry_id: latestEntryId,
          }});
          if (
            requestToken
            && bbsPendingProfileRequestToken
            && requestToken === bbsPendingProfileRequestToken
            && (!bbsPendingProfileHostId || bbsPendingProfileHostId === hostId)
          ) {{
            clearBbsPendingProfileRequest();
            bbsActiveBoardKey = key || bbsBoardKey(boardId, hostId);
            setBbsPostStatus(
              `Loaded BBS space from ${{bbsDisplayNodeLabel(hostId, safeState)}}.`,
              false,
              {{ channel_index: messageMeshChannelIndex(msg) }}
            );
          }} else if (!bbsActiveBoardKey && key) {{
            bbsActiveBoardKey = key;
          }}
          continue;
        }}
        if (parsed.type === "announce") {{
          const boardId = normalizeBbsBoardId(parsed.parts[2] || "");
          const hostId = normalizeNodeId(parsed.parts[3] || fromId);
          if (!boardId || !isCanonicalNodeId(hostId)) continue;
          const title = sanitizeBbsWireField(parsed.parts[4], bbsMaxTitleChars) || boardId;
          const motd = sanitizeBbsWireField(parsed.parts[5], bbsMaxMotdChars);
          const key = bbsUpsertDirectoryRow({{
            board_id: boardId,
            host_id: hostId,
            title,
            motd,
            channel_index: messageMeshChannelIndex(msg),
            last_seen_unix: bbsProtocolMessageUnix(msg),
          }});
          if (!bbsActiveBoardKey && key) {{
            bbsActiveBoardKey = key;
          }}
          continue;
        }}
        if (parsed.type === "offline") {{
          const boardId = normalizeBbsBoardId(parsed.parts[2] || "");
          const hostId = normalizeNodeId(parsed.parts[3] || fromId);
          if (!boardId || !isCanonicalNodeId(hostId)) continue;
          bbsRemoveDirectoryRow(boardId, hostId);
          continue;
        }}
        if (parsed.type === "batch") {{
          const boardId = normalizeBbsBoardId(parsed.parts[2] || "");
          const hostId = normalizeNodeId(parsed.parts[3] || fromId);
          if (!boardId || !isCanonicalNodeId(hostId)) continue;
          if (isCanonicalNodeId(localId) && hostId === localId && !(bbsHostState && bbsHostState.enabled)) {{
            continue;
          }}
          const rows = bbsDecodeBatchPayload(parsed.parts[4]);
          if (!rows.length) continue;
          const posts = rows
            .map((row) => bbsPostFromBatchRow(row, fromId))
            .filter(Boolean);
          if (!posts.length) continue;
          const packetUnix = bbsProtocolMessageUnix(msg);
          const latestPostUnix = posts.reduce((maxUnix, post) => {{
            const unixValue = Math.max(0, Math.trunc(Number(post && post.unix) || 0));
            return unixValue > maxUnix ? unixValue : maxUnix;
          }}, 0);
          const key = bbsUpsertDirectoryRow({{
            board_id: boardId,
            host_id: hostId,
            title: "",
            motd: "",
            channel_index: messageMeshChannelIndex(msg),
            last_seen_unix: latestPostUnix || packetUnix,
          }});
          for (const post of posts) {{
            bbsAppendBoardPost(key, {{
              ...post,
              unix: Math.max(0, Math.trunc(Number(post.unix) || 0)) || packetUnix,
            }});
          }}
          if (!bbsResolvePendingLoadFromContent(hostId, key, safeState) && !bbsActiveBoardKey && key) {{
            bbsActiveBoardKey = key;
          }}
          continue;
        }}
        if (parsed.type === "post") {{
          const boardId = normalizeBbsBoardId(parsed.parts[2] || "");
          const hostId = normalizeNodeId(parsed.parts[3] || fromId);
          if (!boardId || !isCanonicalNodeId(hostId)) continue;
          if (isCanonicalNodeId(localId) && hostId === localId && !(bbsHostState && bbsHostState.enabled)) {{
            continue;
          }}
          const packetUnix = bbsProtocolMessageUnix(msg);
          const key = bbsUpsertDirectoryRow({{
            board_id: boardId,
            host_id: hostId,
            title: "",
            motd: "",
            channel_index: messageMeshChannelIndex(msg),
            last_seen_unix: packetUnix,
          }});
          const entryId = sanitizeBbsWireField(parsed.parts[4], 60);
          const authorId = normalizeNodeId(parsed.parts[5] || fromId);
          const authorName = sanitizeBbsWireField(parsed.parts[6], 48);
          const text = sanitizeBbsWireField(parsed.parts[7], bbsMaxPostChars);
          if (!text) continue;
          const wireUnix = bbsPostUnixFromWire(parsed.parts[8]);
          bbsAppendBoardPost(key, {{
            entry_id: entryId,
            author_id: authorId,
            author_name: authorName || bbsDisplayNodeLabel(authorId || fromId, safeState),
            text,
            unix: wireUnix || packetUnix,
          }});
          if (!bbsResolvePendingLoadFromContent(hostId, key, safeState) && !bbsActiveBoardKey && key) {{
            bbsActiveBoardKey = key;
          }}
          continue;
        }}
      }}
      syncBbsSnapshotTransfers(safeState);
      bbsEnsureHostDirectoryEntry(safeState);
      const activeExists = !!bbsActiveBoardRow();
      if (!activeExists && !bbsPendingProfileRequestToken) {{
        if (bbsHostState && bbsHostState.enabled) {{
          bbsActiveBoardKey = bbsBoardKey(bbsHostState.board_id, bbsHostState.host_id);
        }}
        if (!bbsActiveBoardKey && Array.isArray(bbsDiscoveredBoards) && bbsDiscoveredBoards.length) {{
          bbsActiveBoardKey = String(bbsDiscoveredBoards[0].key || "").trim().toLowerCase();
        }}
      }}
      bbsPersistState();
    }}

    async function sendBbsPost() {{
      const input = document.getElementById("bbs-post-input");
      if (!(input instanceof HTMLInputElement)) return;
      const activeRow = bbsActiveBoardRow();
      if (!activeRow) {{
        setBbsPostStatus("Select a board first.", true);
        return;
      }}
      const text = sanitizeBbsWireField(input.value, bbsMaxPostChars);
      if (!text) {{
        setBbsPostStatus("Type a message before posting.", true);
        return;
      }}
      const localId = bbsHostNodeId(latestState);
      if (!isCanonicalNodeId(localId)) {{
        setBbsPostStatus("Local node ID is unavailable. Wait for sync and try again.", true);
        return;
      }}
      const authorName = bbsDisplayNodeLabel(localId, latestState);
      const entryId = bbsGenerateEntryId();
      const channelRaw = Number(activeRow.channel_index);
      const channelIndex = Number.isInteger(channelRaw) && channelRaw >= 0
        ? channelRaw
        : meshChannelEffectiveSendIndexForApp("bbs");
      if (isSelfNodeId(activeRow.host_id, latestState) && !(bbsHostState && bbsHostState.enabled)) {{
        setBbsPostStatus("Your local BBS space is offline. Host it first.", true);
        return;
      }}
      if (isSelfNodeId(activeRow.host_id, latestState) && bbsHostState && bbsHostState.enabled) {{
        const payload = await postBbsHostCommand("post", {{
          text,
          author_name: authorName,
          entry_id: entryId,
        }});
        if (!payload || payload.ok !== true) return;
        const savedPost = (payload.post && typeof payload.post === "object")
          ? payload.post
          : {{
              entry_id: entryId,
              author_id: localId,
              author_name: authorName,
              text,
              unix: Math.floor(Date.now() / 1000),
            }};
        bbsAppendBoardPost(activeRow.key, savedPost);
        input.value = "";
        bbsPersistState();
        setBbsPostStatus(`Saved post to ${{activeRow.title || activeRow.board_id}}.`, false, {{ channel_index: channelIndex }});
        if (activeLayoutView === "bbs") {{
          renderBbsTerminal(latestState);
        }}
        return;
      }}
      const sent = await sendBbsProtocolMessage(
        "post",
        [
          activeRow.board_id,
          activeRow.host_id,
          entryId,
          localId,
          authorName,
          text,
          Math.floor(Date.now() / 1000),
        ],
        {{
          destination: activeRow.host_id,
          channel_index: channelIndex,
          quiet: false,
        }}
      );
      if (!sent) return;
      bbsAppendBoardPost(activeRow.key, {{
        entry_id: entryId,
        author_id: localId,
        author_name: authorName,
        text,
        unix: Math.floor(Date.now() / 1000),
      }});
      input.value = "";
      bbsPersistState();
      setBbsPostStatus(`Posted to ${{activeRow.title || activeRow.board_id}}.`, false, {{ channel_index: channelIndex }});
      if (activeLayoutView === "bbs") {{
        renderBbsTerminal(latestState);
      }}
    }}

    function bindBbsControls() {{
      const titleInput = document.getElementById("bbs-host-title-input");
      if (titleInput instanceof HTMLInputElement && titleInput.dataset.bound !== "1") {{
        titleInput.dataset.bound = "1";
        titleInput.addEventListener("input", () => {{
          const previousKey = (bbsHostState && bbsHostState.enabled)
            ? bbsBoardKey(bbsHostState.board_id, bbsHostState.host_id || bbsHostNodeId(latestState))
            : "";
          bbsHostState.title = sanitizeBbsWireField(titleInput.value, bbsMaxTitleChars) || "Packet Exchange";
          if (!sanitizeBbsWireField(bbsHostState.board_id, 24)) {{
            bbsHostState.board_id = normalizeBbsBoardId("", bbsHostState.title);
          }}
          bbsHostSettingsDirty = true;
          if (bbsHostState && bbsHostState.enabled) {{
            syncHostedBbsDirectoryEntry(latestState, {{ previousKey }});
          }}
          bbsPersistState();
          queueBbsHostSettingsSave();
          if (activeLayoutView === "bbs") {{
            if (bbsHostState && bbsHostState.enabled) {{
              renderBbsView(latestState);
            }} else {{
              renderBbsHostControls(latestState);
            }}
          }}
        }});
      }}
      const boardInput = document.getElementById("bbs-host-id-input");
      if (boardInput instanceof HTMLInputElement && boardInput.dataset.bound !== "1") {{
        boardInput.dataset.bound = "1";
        boardInput.addEventListener("input", () => {{
          const previousKey = (bbsHostState && bbsHostState.enabled)
            ? bbsBoardKey(bbsHostState.board_id, bbsHostState.host_id || bbsHostNodeId(latestState))
            : "";
          bbsHostState.board_id = normalizeBbsBoardId(boardInput.value, bbsHostState.title);
          bbsHostSettingsDirty = true;
          if (bbsHostState && bbsHostState.enabled) {{
            syncHostedBbsDirectoryEntry(latestState, {{ previousKey }});
          }}
          bbsPersistState();
          queueBbsHostSettingsSave();
          if (activeLayoutView === "bbs") {{
            if (bbsHostState && bbsHostState.enabled) {{
              renderBbsView(latestState);
            }} else {{
              renderBbsHostControls(latestState);
            }}
          }}
        }});
      }}
      const motdInput = document.getElementById("bbs-host-motd-input");
      if (motdInput instanceof HTMLInputElement && motdInput.dataset.bound !== "1") {{
        motdInput.dataset.bound = "1";
        motdInput.addEventListener("input", () => {{
          const previousKey = (bbsHostState && bbsHostState.enabled)
            ? bbsBoardKey(bbsHostState.board_id, bbsHostState.host_id || bbsHostNodeId(latestState))
            : "";
          bbsHostState.motd = sanitizeBbsWireField(motdInput.value, bbsMaxMotdChars) || "2400 baud online.";
          bbsHostSettingsDirty = true;
          if (bbsHostState && bbsHostState.enabled) {{
            syncHostedBbsDirectoryEntry(latestState, {{ previousKey }});
          }}
          bbsPersistState();
          queueBbsHostSettingsSave();
          if (activeLayoutView === "bbs") {{
            if (bbsHostState && bbsHostState.enabled) {{
              renderBbsView(latestState);
            }} else {{
              renderBbsHostControls(latestState);
            }}
          }}
        }});
      }}

      const hostBtn = document.getElementById("bbs-host-start-btn");
      if (hostBtn instanceof HTMLButtonElement && hostBtn.dataset.bound !== "1") {{
        hostBtn.dataset.bound = "1";
        hostBtn.addEventListener("click", () => {{
          void startBbsHosting();
        }});
      }}
      const stopBtn = document.getElementById("bbs-host-stop-btn");
      if (stopBtn instanceof HTMLButtonElement && stopBtn.dataset.bound !== "1") {{
        stopBtn.dataset.bound = "1";
        stopBtn.addEventListener("click", () => {{
          void stopBbsHosting();
        }});
      }}
      const refreshBtn = document.getElementById("bbs-refresh-directory-btn");
      if (refreshBtn instanceof HTMLButtonElement && refreshBtn.dataset.bound !== "1") {{
        refreshBtn.dataset.bound = "1";
        refreshBtn.addEventListener("click", () => {{
          const requestTargetId = bbsRequestTargetNodeId(latestState);
          if (!isSelectableNodeId(requestTargetId)) {{
            setBbsPostStatus("Select a node before requesting a BBS space.", true);
            return;
          }}
          void requestBbsSpaceForNode(requestTargetId, {{
            silent: false,
            openView: true,
            preserveCurrent: false,
          }});
        }});
      }}
      const forgetBtn = document.getElementById("bbs-forget-directory-btn");
      if (forgetBtn instanceof HTMLButtonElement && forgetBtn.dataset.bound !== "1") {{
        forgetBtn.dataset.bound = "1";
        forgetBtn.addEventListener("click", () => {{
          forgetSelectedBbsBoard();
        }});
      }}
      const boardList = document.getElementById("bbs-board-list");
      if (boardList instanceof HTMLElement && boardList.dataset.bound !== "1") {{
        boardList.dataset.bound = "1";
        boardList.addEventListener("click", (ev) => {{
          const target = ev.target;
          if (!(target instanceof Element)) return;
          const row = target.closest(".bbs-board-item");
          if (!(row instanceof HTMLButtonElement)) return;
          const key = String(row.dataset.boardKey || "").trim().toLowerCase();
          if (!key) return;
          bbsSelectBoard(key);
        }});
      }}
      const postBtn = document.getElementById("bbs-post-send-btn");
      if (postBtn instanceof HTMLButtonElement && postBtn.dataset.bound !== "1") {{
        postBtn.dataset.bound = "1";
        postBtn.addEventListener("click", () => {{
          void sendBbsPost();
        }});
      }}
      const postInput = document.getElementById("bbs-post-input");
      if (postInput instanceof HTMLInputElement && postInput.dataset.bound !== "1") {{
        postInput.dataset.bound = "1";
        postInput.addEventListener("keydown", (ev) => {{
          if (ev.key !== "Enter") return;
          ev.preventDefault();
          void sendBbsPost();
        }});
      }}
    }}

    function renderBbsView(state = latestState) {{
      if (bbsFeatureEnabled && !bbsHostSettingsLoadedOnce && !bbsHostSettingsFetchInFlight) {{
        void fetchBbsHostSettings({{ silent: true }});
      }}
      if (bbsFeatureEnabled && !bbsHostRuntimeLoadedOnce && !bbsHostRuntimeFetchInFlight) {{
        void fetchBbsHostRuntime({{ silent: true }});
      }}
      bindBbsControls();
      syncBbsNetworkState(state);
      renderBbsHostControls(state);
      renderBbsDirectory(state);
      renderBbsTerminal(state);
    }}
