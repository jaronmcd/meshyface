    function remoteNodeEntriesFromState(state = latestState) {{
      const safeState = (state && typeof state === "object") ? state : {{}};
      const nodes = Array.isArray(safeState.nodes) ? safeState.nodes : [];
      const localId = normalizeNodeId(resolveLocalNodeId(safeState) || "");
      const nowUnix = Math.floor(Date.now() / 1000);
      const entries = [];
      for (const node of nodes) {{
        const nodeId = normalizeNodeId(node && node.id);
        if (!isCanonicalNodeId(nodeId)) continue;
        if (isCanonicalNodeId(localId) && nodeId === localId) continue;
        const displayName = preferredNodeName(node) || nodeNameCache.get(nodeId) || nodeId;
        const role = String((node && node.role) || "").trim();
        const hardware = String((node && node.hardware) || "").trim();
        const hopsRaw = Number(node && node.hops_away);
        const hopsAway = Number.isFinite(hopsRaw) && hopsRaw >= 0 ? Math.trunc(hopsRaw) : null;
        const lastHeardUnix = nodeLastHeardUnix(node);
        const freshness = freshnessStatus(lastHeardUnix, nowUnix);
        const searchText = nodeSearchKeywordText(nodeId, displayName, {{
          node,
          extraValues: [
            role,
            hardware,
          ],
        }});
        entries.push({{
          id: nodeId,
          node,
          displayName,
          role,
          hardware,
          hopsAway,
          lastHeardUnix,
          freshness,
          searchText,
        }});
      }}
      entries.sort((a, b) => {{
        const freshnessDelta = statusRank(a.freshness) - statusRank(b.freshness);
        if (freshnessDelta !== 0) return freshnessDelta;
        const nameDelta = String(a.displayName || "").localeCompare(String(b.displayName || ""), undefined, {{ sensitivity: "base" }});
        if (nameDelta !== 0) return nameDelta;
        return String(a.id || "").localeCompare(String(b.id || ""));
      }});
      return entries;
    }}

    function resolveRemoteTargetNodeId(entries, state = latestState) {{
      const list = Array.isArray(entries) ? entries : [];
      if (!list.length) return "";
      const explicit = normalizeNodeId(remoteTargetNodeId || "");
      if (isCanonicalNodeId(explicit) && list.some((entry) => entry.id === explicit)) {{
        return explicit;
      }}
      const selected = normalizeNodeId(selectedNodeId || "");
      if (isCanonicalNodeId(selected) && list.some((entry) => entry.id === selected)) {{
        return selected;
      }}
      const savedNodeId = normalizeNodeId(resolveSavedViewNodeId(state) || "");
      if (isCanonicalNodeId(savedNodeId) && list.some((entry) => entry.id === savedNodeId)) {{
        return savedNodeId;
      }}
      return String(list[0].id || "");
    }}

    function remoteCapabilityRows(nodeEntry, state = latestState) {{
      if (!nodeEntry || typeof nodeEntry !== "object" || !nodeEntry.node) return [];
      const node = nodeEntry.node;
      const directReady = isCanonicalNodeId(nodeEntry.id) && !isSelfNodeId(nodeEntry.id, state);
      const telemetryKnown = Number.isFinite(nodeEntry.lastHeardUnix) && nodeEntry.lastHeardUnix > 0;
      const telemetryRecent = telemetryKnown && statusRank(nodeEntry.freshness) <= statusRank("warn");
      const hopsKnown = Number.isFinite(nodeEntry.hopsAway) && nodeEntry.hopsAway >= 0;
      const gpsCapability = coerceOptionalBool(firstNestedValue([node], [
        "gps_capable",
        "position.gps_capable",
        "position_available",
        "position.available",
      ]));
      const lat = firstFiniteNestedNumber([node], ["lat", "latitude", "position.lat", "position.latitude"]);
      const lon = firstFiniteNestedNumber([node], ["lon", "longitude", "position.lon", "position.longitude"]);
      const hasPositionHint = (gpsCapability === true) || (lat != null && lon != null);
      const batteryLevel = firstFiniteNestedNumber([node], [
        "battery_level",
        "device_metrics.battery_level",
        "device_metrics.batteryLevel",
        "power.battery_level",
      ]);
      const hasBatteryHint = batteryLevel != null;
      return [
        {{
          title: "Direct messages",
          status: directReady ? "ready" : "blocked",
          detail: directReady
            ? "This node can be targeted from the message popup."
            : "This entry is not a direct-message target yet.",
        }},
        {{
          title: "Live telemetry",
          status: telemetryRecent ? "ready" : (telemetryKnown ? "partial" : "blocked"),
          detail: telemetryKnown
            ? `Last seen: ${{formatLocalChatTime(nodeEntry.lastHeardUnix, "n/a")}} (${{nodeEntry.freshness}}).`
            : "No recent telemetry timestamp is available for this node.",
        }},
        {{
          title: "Route awareness",
          status: hopsKnown ? "ready" : "partial",
          detail: hopsKnown
            ? `Reported hop distance: ${{nodeEntry.hopsAway}}.`
            : "Hop distance is not currently reported by this node.",
        }},
        {{
          title: "Telemetry metadata",
          status: (hasPositionHint || hasBatteryHint) ? "ready" : "partial",
          detail: (hasPositionHint || hasBatteryHint)
            ? `Position hint: ${{hasPositionHint ? "yes" : "no"}}, battery hint: ${{hasBatteryHint ? "yes" : "no"}}.`
            : "No position or battery hints detected in current node metadata.",
        }},
        {{
          title: "Remote config fetch",
          status: "planned",
          detail: "Config pull/apply for remote nodes is not exposed yet in this dashboard.",
        }},
      ];
    }}

    function remoteCapabilityStatusLabel(status) {{
      const key = String(status || "").trim().toLowerCase();
      if (key === "ready") return "Ready";
      if (key === "partial") return "Partial";
      if (key === "planned") return "Planned";
      if (key === "blocked") return "Blocked";
      return "Unknown";
    }}

    function setRemoteActionStatus(message, isError = false) {{
      const text = String(message == null ? "" : message).trim();
      remoteActionStatus = text || "Select a node to start exploring remote actions.";
      remoteActionStatusError = !!isError;
      const statusEl = document.getElementById("remote-action-status");
      if (statusEl instanceof HTMLElement) {{
        statusEl.textContent = remoteActionStatus;
        statusEl.classList.toggle("error", remoteActionStatusError);
      }}
    }}

    function remoteViewSelectedNodeId() {{
      const card = document.querySelector(".card.remote");
      if (!(card instanceof HTMLElement)) return "";
      const nodeId = normalizeNodeId(card.dataset.targetNodeId || "");
      return isCanonicalNodeId(nodeId) ? nodeId : "";
    }}

    function stageRemoteChatCommand(nodeId, commandText, options = null) {{
      const cleanNodeId = normalizeNodeId(nodeId || "");
      if (!isCanonicalNodeId(cleanNodeId)) {{
        setRemoteActionStatus("Pick a valid remote node first.", true);
        return;
      }}
      const command = String(commandText || "").trim();
      if (!command) {{
        setRemoteActionStatus("Nothing to stage for chat.", true);
        return;
      }}
      const directMode = !!(options && options.direct);
      selectNode(cleanNodeId, false, false);
      applyLayoutView("chat", true);
      applyChatChannel("all", true);
      if (directMode) {{
        peerDmActivePeerId = cleanNodeId;
        setPeerDmMenuOpen(false);
        if (latestState) {{
          renderChat(latestState);
        }}
        const popoutInput = document.getElementById("peer-dm-popout-input");
        if (popoutInput instanceof HTMLInputElement) {{
          popoutInput.value = command;
          window.requestAnimationFrame(() => {{
            popoutInput.focus({{ preventScroll: true }});
            const tail = popoutInput.value.length;
            popoutInput.setSelectionRange(tail, tail);
          }});
        }}
        const statusText = String((options && options.statusText) || "").trim()
          || `Staged "${{command}}" for the peer message popup. Press Enter to send.`;
        if (typeof setPeerDmPopoutStatusDisplay === "function") {{
          setPeerDmPopoutStatusDisplay(cleanNodeId, statusText, {{
            ttlMs: 15000,
            statusToken: `stage:${{command}}`,
          }});
        }} else {{
          const popoutStatus = document.getElementById("peer-dm-popout-status");
          if (popoutStatus instanceof HTMLElement) {{
            popoutStatus.textContent = statusText;
            popoutStatus.classList.remove("is-error");
            popoutStatus.hidden = false;
          }}
        }}
        setRemoteActionStatus(statusText, false);
        return;
      }}
      const chatInput = document.getElementById("chat-input");
      if (chatInput instanceof HTMLInputElement) {{
        chatInput.value = command;
        window.requestAnimationFrame(() => {{
          chatInput.focus({{ preventScroll: true }});
          const tail = chatInput.value.length;
          chatInput.setSelectionRange(tail, tail);
        }});
      }}
      const statusText = String((options && options.statusText) || "").trim()
        || `Staged "${{command}}" for channel chat. Press Enter to send.`;
      setChatSendStatus(statusText);
      setRemoteActionStatus(statusText, false);
    }}

    function bindRemoteControls() {{
      const searchInput = document.getElementById("remote-node-search-input");
      if (searchInput instanceof HTMLInputElement && searchInput.dataset.bound !== "1") {{
        searchInput.dataset.bound = "1";
        searchInput.addEventListener("input", () => {{
          const changed = setGlobalNodeSearchQuery(searchInput.value, {{
            sourceInputId: "remote-node-search-input",
            skipSourceInput: true,
          }});
          if (changed && latestState) {{
            rerenderNodeSearchDependents(latestState);
          }}
        }});
        searchInput.addEventListener("keydown", (event) => {{
          if (event.key !== "Escape") return;
          const changed = setGlobalNodeSearchQuery("", {{
            sourceInputId: "remote-node-search-input",
            skipSourceInput: false,
          }});
          if (changed && latestState) {{
            rerenderNodeSearchDependents(latestState);
          }}
        }});
      }}

      const nodeList = document.getElementById("remote-node-list");
      if (nodeList instanceof HTMLElement && nodeList.dataset.bound !== "1") {{
        nodeList.dataset.bound = "1";
        nodeList.addEventListener("click", (event) => {{
          const target = event.target;
          if (!(target instanceof Element)) return;
          const button = target.closest(".remote-node-btn");
          if (!(button instanceof HTMLButtonElement)) return;
          const nodeId = normalizeNodeId(button.dataset.nodeId || "");
          if (!isCanonicalNodeId(nodeId)) return;
          remoteTargetNodeId = nodeId;
          renderRemoteView(latestState);
        }});
      }}

      const refreshBtn = document.getElementById("remote-refresh-btn");
      if (refreshBtn instanceof HTMLButtonElement && refreshBtn.dataset.bound !== "1") {{
        refreshBtn.dataset.bound = "1";
        refreshBtn.addEventListener("click", () => {{
          setRemoteActionStatus("Refreshing remote snapshot...", false);
          renderRemoteView(latestState);
          requestImmediatePoll(0);
        }});
      }}

      const openNodeBtn = document.getElementById("remote-open-node-btn");
      if (openNodeBtn instanceof HTMLButtonElement && openNodeBtn.dataset.bound !== "1") {{
        openNodeBtn.dataset.bound = "1";
        openNodeBtn.addEventListener("click", () => {{
          const nodeId = remoteViewSelectedNodeId();
          if (!isCanonicalNodeId(nodeId)) {{
            setRemoteActionStatus("Select a node before opening node details.", true);
            return;
          }}
          selectNode(nodeId, true, false);
          setRemoteActionStatus(`Opened node details for ${{nodeId}}.`, false);
          applyLayoutView("network", true);
          if (typeof setChatNodeDetailsDrawerExpanded === "function") {{
            setChatNodeDetailsDrawerExpanded(true, {{
              fetchHistory: false,
              rerender: false,
            }});
          }}
        }});
      }}

      const openDirectBtn = document.getElementById("remote-open-direct-chat-btn");
      if (openDirectBtn instanceof HTMLButtonElement && openDirectBtn.dataset.bound !== "1") {{
        openDirectBtn.dataset.bound = "1";
        openDirectBtn.addEventListener("click", () => {{
          const nodeId = remoteViewSelectedNodeId();
          if (!isCanonicalNodeId(nodeId)) {{
            setRemoteActionStatus("Select a node before opening a message popup.", true);
            return;
          }}
          selectNode(nodeId, false, false);
          applyLayoutView("chat", true);
          applyChatChannel("all", true);
          peerDmActivePeerId = nodeId;
          setPeerDmMenuOpen(false);
          if (latestState) {{
            renderChat(latestState);
          }}
          const popoutInput = document.getElementById("peer-dm-popout-input");
          if (popoutInput instanceof HTMLInputElement) {{
            window.requestAnimationFrame(() => {{
              popoutInput.focus({{ preventScroll: true }});
            }});
          }}
          const statusText = `Direct message window ready for ${{nodeId}}.`;
          if (typeof setPeerDmPopoutStatusDisplay === "function") {{
            setPeerDmPopoutStatusDisplay(nodeId, statusText, {{
              ttlMs: 12000,
              statusToken: "ready",
            }});
          }} else {{
            const popoutStatus = document.getElementById("peer-dm-popout-status");
            if (popoutStatus instanceof HTMLElement) {{
              popoutStatus.textContent = statusText;
              popoutStatus.classList.remove("is-error");
              popoutStatus.hidden = false;
            }}
          }}
          setRemoteActionStatus(statusText, false);
        }});
      }}

      const stageWhoisBtn = document.getElementById("remote-stage-whois-btn");
      if (stageWhoisBtn instanceof HTMLButtonElement && stageWhoisBtn.dataset.bound !== "1") {{
        stageWhoisBtn.dataset.bound = "1";
        stageWhoisBtn.addEventListener("click", () => {{
          const nodeId = remoteViewSelectedNodeId();
          if (!isCanonicalNodeId(nodeId)) {{
            setRemoteActionStatus("Select a node before staging whois.", true);
            return;
          }}
          stageRemoteChatCommand(nodeId, `whois ${{nodeId}}`, {{
            direct: false,
            statusText: `Staged whois lookup for ${{nodeId}}. Press Enter to send.`,
          }});
        }});
      }}
    }}

    function renderRemoteView(state = latestState) {{
      bindRemoteControls();
      const safeState = (state && typeof state === "object") ? state : {{}};
      const allEntries = remoteNodeEntriesFromState(safeState);
      const targetFromAll = resolveRemoteTargetNodeId(allEntries, safeState);
      remoteTargetNodeId = targetFromAll;

      const queryText = globalNodeSearchQuery();
      const query = queryText;
      const filteredEntries = query
        ? allEntries.filter((entry) => entry.searchText.includes(query))
        : allEntries;
      const listEntries = filteredEntries.slice(0, 260);
      const listOverflow = Math.max(0, filteredEntries.length - listEntries.length);

      const card = document.querySelector(".card.remote");
      if (card instanceof HTMLElement) {{
        card.dataset.targetNodeId = isCanonicalNodeId(targetFromAll) ? targetFromAll : "";
      }}

      const caption = document.getElementById("remote-node-list-caption");
      if (caption instanceof HTMLElement) {{
        if (!allEntries.length) {{
          caption.textContent = "No remote nodes discovered yet.";
        }} else if (query) {{
          const overflowText = listOverflow > 0 ? ` Showing first ${{listEntries.length}}.` : "";
          caption.textContent = `${{filteredEntries.length}} match${{filteredEntries.length === 1 ? "" : "es"}} for "${{queryText}}" out of ${{allEntries.length}} remote node${{allEntries.length === 1 ? "" : "s"}}.${{overflowText}}`;
        }} else {{
          const overflowText = listOverflow > 0 ? ` Showing first ${{listEntries.length}}.` : "";
          caption.textContent = `${{allEntries.length}} remote node${{allEntries.length === 1 ? "" : "s"}} discovered (local radio hidden).${{overflowText}}`;
        }}
      }}

      const searchInput = document.getElementById("remote-node-search-input");
      if (searchInput instanceof HTMLInputElement && document.activeElement !== searchInput) {{
        if (searchInput.value !== queryText) {{
          searchInput.value = queryText;
        }}
      }}

      const detailEntry = allEntries.find((entry) => entry.id === targetFromAll) || null;
      const nodeList = document.getElementById("remote-node-list");
      if (nodeList instanceof HTMLElement) {{
        if (!listEntries.length) {{
          nodeList.innerHTML = `<div class="remote-node-empty">${{query ? "No nodes match this search yet." : "No remote nodes are available yet."}}</div>`;
        }} else {{
          nodeList.innerHTML = listEntries.map((entry) => {{
            const isActive = detailEntry && detailEntry.id === entry.id;
            const hopsLabel = Number.isFinite(entry.hopsAway)
              ? `${{entry.hopsAway}} hop${{entry.hopsAway === 1 ? "" : "s"}}`
              : "hops n/a";
            const lastSeen = entry.lastHeardUnix ? formatLocalChatTime(entry.lastHeardUnix, "n/a") : "n/a";
            return `<button type="button" class="remote-node-btn${{isActive ? " is-active" : ""}}" data-node-id="${{escAttr(entry.id)}}" role="option" aria-selected="${{isActive ? "true" : "false"}}">
              <span class="remote-node-main">
                <span class="remote-node-name">${{escAttr(entry.displayName)}}</span>
                <span class="remote-freshness-chip status-${{escAttr(normalizeFreshnessKey(entry.freshness))}}">${{escAttr(entry.freshness)}}</span>
              </span>
              <span class="remote-node-id">${{escAttr(entry.id)}}</span>
              <span class="remote-node-meta">
                <span>${{escAttr(entry.role || "role n/a")}}</span>
                <span>${{escAttr(hopsLabel)}}</span>
                <span>${{escAttr(lastSeen)}}</span>
              </span>
            </button>`;
          }}).join("");
        }}
      }}

      const targetTitle = document.getElementById("remote-target-title");
      const targetMeta = document.getElementById("remote-target-meta");
      const capabilityList = document.getElementById("remote-capability-list");
      if (!detailEntry) {{
        if (targetTitle instanceof HTMLElement) {{
          targetTitle.textContent = "Select a node";
        }}
        if (targetMeta instanceof HTMLElement) {{
          targetMeta.textContent = "Choose a node to inspect potential remote operations.";
        }}
        if (capabilityList instanceof HTMLElement) {{
          capabilityList.innerHTML = '<div class="remote-node-empty">Capabilities will appear after selecting a remote node.</div>';
        }}
      }} else {{
        if (targetTitle instanceof HTMLElement) {{
          targetTitle.textContent = `${{detailEntry.displayName}} (${{detailEntry.id}})`;
        }}
        if (targetMeta instanceof HTMLElement) {{
          const details = [];
          if (detailEntry.role) details.push(`Role: ${{detailEntry.role}}`);
          if (detailEntry.hardware) details.push(`Hardware: ${{detailEntry.hardware}}`);
          if (Number.isFinite(detailEntry.hopsAway)) details.push(`Hops: ${{detailEntry.hopsAway}}`);
          if (detailEntry.lastHeardUnix) details.push(`Last seen: ${{formatLocalChatTime(detailEntry.lastHeardUnix, "n/a")}}`);
          if (!details.length) {{
            details.push("No additional metadata for this node yet.");
          }}
          targetMeta.innerHTML = details
            .map((item) => `<span class="remote-meta-pill">${{escAttr(item)}}</span>`)
            .join("");
        }}
        if (capabilityList instanceof HTMLElement) {{
          const rows = remoteCapabilityRows(detailEntry, safeState);
          capabilityList.innerHTML = rows.length
            ? rows.map((row) => {{
              const statusKey = String(row && row.status ? row.status : "unknown").trim().toLowerCase();
              return `<div class="remote-capability-row">
                <div class="remote-capability-title">${{escAttr(row && row.title ? row.title : "Capability")}}</div>
                <div class="remote-capability-status ${{escAttr(statusKey)}}">${{escAttr(remoteCapabilityStatusLabel(statusKey))}}</div>
                <div class="remote-capability-detail">${{escAttr(row && row.detail ? row.detail : "")}}</div>
              </div>`;
            }}).join("")
            : '<div class="remote-node-empty">No capabilities available for this node yet.</div>';
        }}
      }}

      for (const buttonId of [
        "remote-open-node-btn",
        "remote-open-direct-chat-btn",
        "remote-stage-whois-btn",
      ]) {{
        const button = document.getElementById(buttonId);
        if (button instanceof HTMLButtonElement) {{
          button.disabled = !detailEntry;
        }}
      }}

      setRemoteActionStatus(remoteActionStatus, remoteActionStatusError);
    }}
