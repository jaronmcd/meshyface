    function boardGameMoveLabel(gameId, fromRow, fromCol, toRow, toCol) {{
      const fromLabel = boardGameNormalizeId(gameId) === "chess"
        ? chessCellLabel(fromRow, fromCol)
        : checkersCellLabel(fromRow, fromCol);
      const toLabel = boardGameNormalizeId(gameId) === "chess"
        ? chessCellLabel(toRow, toCol)
        : checkersCellLabel(toRow, toCol);
      return `${{fromLabel}}→${{toLabel}}`;
    }}

    async function waitForBoardGameMoveAck(checkAck, timeoutMs) {{
      const probe = typeof checkAck === "function" ? checkAck : null;
      if (!probe) return false;
      const windowMs = Math.max(500, Math.trunc(Number(timeoutMs) || 0));
      const pollMs = Math.max(80, Math.trunc(Number(gamesMoveAckPollMs) || 0) || 180);
      const deadline = Date.now() + windowMs;
      while (Date.now() < deadline) {{
        if (probe()) return true;
        await new Promise((resolve) => setTimeout(resolve, pollMs));
      }}
      return !!probe();
    }}

    async function sendBoardGameMoveWithRetry(gameId, fromRow, fromCol, toRow, toCol) {{
      if (!boardGameIsNetworkLinked(gameId)) return false;
      const refs = boardGameRefs(gameId);
      const link = refs.getLink();
      const sessionId = String(link.session_id || "").trim().toLowerCase();
      const peerId = normalizeNodeId(link.peer_id || "");
      if (!sessionId || !isCanonicalNodeId(peerId)) return false;
      const seq = Math.max(0, Math.trunc(Number(link.local_move_seq) || 0)) + 1;
      const sessionChannelRaw = Number(link.channel_index);
      const sessionChannel = Number.isInteger(sessionChannelRaw) && sessionChannelRaw >= 0
        ? sessionChannelRaw
        : meshChannelEffectiveSendIndexForApp("games");
      const moveLabel = boardGameMoveLabel(gameId, fromRow, fromCol, toRow, toCol);
      const waitPlan = Array.isArray(gamesMoveAckWaitPlanMs) && gamesMoveAckWaitPlanMs.length
        ? gamesMoveAckWaitPlanMs
        : [2500, 3500, 5000, 7000];
      const isAcked = () => {{
        if (!boardGameIsNetworkLinked(gameId)) return false;
        const current = refs.getLink();
        if (normalizeNodeId(current.peer_id) !== peerId) return false;
        if (String(current.session_id || "").trim().toLowerCase() !== sessionId) return false;
        return Math.max(0, Math.trunc(Number(current.last_remote_ack_seq) || 0)) >= seq;
      }};
      let atLeastOneSent = false;
      for (let attemptIndex = 0; attemptIndex < waitPlan.length; attemptIndex += 1) {{
        if (!boardGameIsNetworkLinked(gameId)) return false;
        const current = refs.getLink();
        if (normalizeNodeId(current.peer_id) !== peerId) return false;
        if (String(current.session_id || "").trim().toLowerCase() !== sessionId) return false;
        if (isAcked()) return true;

        const sent = await sendBoardGameProtocolMessage(
          gameId,
          "move",
          [sessionId, seq, fromRow, fromCol, toRow, toCol],
          {{ destination_id: peerId, channel_index: sessionChannel }}
        );
        if (sent) {{
          atLeastOneSent = true;
          current.local_move_seq = Math.max(
            Math.max(0, Math.trunc(Number(current.local_move_seq) || 0)),
            seq
          );
          const attemptNumber = attemptIndex + 1;
          const totalAttempts = waitPlan.length;
          const label = boardGameLabel(gameId);
          if (attemptNumber <= 1) {{
            boardGameUpdateLinkStatus(gameId, `${{label}} move ${{moveLabel}} sent. Waiting for ACK...`);
          }} else {{
            boardGameUpdateLinkStatus(gameId, `${{label}} move ${{moveLabel}} retry ${{attemptNumber}}/${{totalAttempts}}. Waiting for ACK...`);
          }}
        }}
        const acked = await waitForBoardGameMoveAck(isAcked, waitPlan[attemptIndex]);
        if (acked) {{
          boardGameUpdateLinkStatus(gameId, `Peer acknowledged ${{boardGameLabel(gameId)}} move ${{moveLabel}}.`);
          return true;
        }}
      }}
      if (atLeastOneSent) {{
        boardGameUpdateLinkStatus(gameId, `${{boardGameLabel(gameId)}} move ${{moveLabel}} sent, but ACK has not arrived yet (high latency or packet loss).`);
      }} else {{
        boardGameUpdateLinkStatus(gameId, "Move applied locally, but network send failed.");
      }}
      return false;
    }}

    async function sendCheckersMoveToPeer(fromRow, fromCol, toRow, toCol) {{
      return sendBoardGameMoveWithRetry("checkers", fromRow, fromCol, toRow, toCol);
    }}

    async function sendChessMoveToPeer(fromRow, fromCol, toRow, toCol) {{
      return sendBoardGameMoveWithRetry("chess", fromRow, fromCol, toRow, toCol);
    }}

    function syncBoardGameNetworkState(gameId, state = latestState) {{
      const refs = boardGameRefs(gameId);
      const safeState = state && typeof state === "object" ? state : null;
      if (!safeState) return;
      const localNodeId = normalizeNodeId(resolveLocalNodeId(safeState) || "");
      if (!isCanonicalNodeId(localNodeId)) return;
      const traffic = safeState.traffic && typeof safeState.traffic === "object"
        ? safeState.traffic
        : {{}};
      const recentProtocolMessages = Array.isArray(traffic.recent_packets)
        ? traffic.recent_packets
        : (Array.isArray(traffic.recent_chat) ? traffic.recent_chat : []);
      for (const msg of recentProtocolMessages) {{
        if (!msg || typeof msg !== "object") continue;
        if (msg.local_echo === true || msg.localEcho === true) continue;
        const parsed = parseBoardGameProtocolMessage(gameId, reversiProtocolMessageText(msg));
        if (!parsed) continue;
        const fromId = normalizeNodeId(msg.from || "");
        const toId = normalizeNodeId(msg.to || msg.destination || "");
        if (!isCanonicalNodeId(fromId) || fromId === localNodeId) continue;
        if (toId && toId !== localNodeId) continue;
        const dedupeKey = boardGameProtocolMessageKey(gameId, msg, parsed);
        if (refs.getSeenKeys().has(dedupeKey)) continue;

        if (parsed.type === "invite") {{
          const sessionId = String(parsed.parts[2] || "").trim().toLowerCase();
          const hostColor = boardGameParseColor(parsed.parts[4], refs.defaultLocalColor);
          const inviteChannelRaw = Number(parsed.parts[5]);
          const inviteChannel = Number.isInteger(inviteChannelRaw) && inviteChannelRaw >= 0
            ? inviteChannelRaw
            : messageMeshChannelIndex(msg);
          const controlSeq = Math.max(0, Math.trunc(Number(parsed.parts[6]) || 0));
          if (!sessionId) {{
            rememberBoardGameNetworkMessage(gameId, dedupeKey);
            continue;
          }}
          if (controlSeq > 0) {{
            void sendBoardGameProtocolMessage(
              gameId,
              "ack",
              [sessionId, "control", "invite", controlSeq],
              {{ destination_id: fromId, channel_index: inviteChannel }}
            );
          }}
          registerBoardGamePendingInvite(gameId, {{
            from_id: fromId,
            session_id: sessionId,
            received_unix: reversiProtocolMessageUnix(msg),
            host_color: hostColor,
            channel_index: inviteChannel,
          }});
          if (!boardGameIsNetworkLinked(gameId)) {{
            boardGameUpdateLinkStatus(
              gameId,
              `Invite available from ${{reversiNodeLabel(fromId, safeState)}}. Select the invite and click Accept Invite.`
            );
          }}
          rememberBoardGameNetworkMessage(gameId, dedupeKey);
          continue;
        }}

        if (parsed.type === "accept") {{
          const sessionId = String(parsed.parts[2] || "").trim().toLowerCase();
          const controlSeq = Math.max(0, Math.trunc(Number(parsed.parts[3]) || 0));
          const link = refs.getLink();
          const ackChannelRaw = Number(link.channel_index);
          const ackChannel = Number.isInteger(ackChannelRaw) && ackChannelRaw >= 0
            ? ackChannelRaw
            : messageMeshChannelIndex(msg);
          if (sessionId && controlSeq > 0) {{
            void sendBoardGameProtocolMessage(
              gameId,
              "ack",
              [sessionId, "control", "accept", controlSeq],
              {{ destination_id: fromId, channel_index: ackChannel }}
            );
          }}
          if (
            sessionId
            && link.mode === "pending_host"
            && link.role === "host"
            && link.session_id === sessionId
            && normalizeNodeId(link.peer_id) === fromId
          ) {{
            const existingChannelRaw = Number(link.channel_index);
            link.channel_index = Number.isInteger(existingChannelRaw) && existingChannelRaw >= 0
              ? existingChannelRaw
              : messageMeshChannelIndex(msg);
            link.mode = "connected";
            removeAllBoardGamePendingInvitesFromPeer(gameId, fromId);
            link.status = `Connected to ${{reversiNodeLabel(fromId, safeState)}}. You are ${{refs.playerLabel(link.local_color)}}.`;
          }}
          rememberBoardGameNetworkMessage(gameId, dedupeKey);
          continue;
        }}

        if (parsed.type === "decline") {{
          const sessionId = String(parsed.parts[2] || "").trim().toLowerCase();
          const controlSeq = Math.max(0, Math.trunc(Number(parsed.parts[3]) || 0));
          const link = refs.getLink();
          const ackChannelRaw = Number(link.channel_index);
          const ackChannel = Number.isInteger(ackChannelRaw) && ackChannelRaw >= 0
            ? ackChannelRaw
            : messageMeshChannelIndex(msg);
          if (sessionId && controlSeq > 0) {{
            void sendBoardGameProtocolMessage(
              gameId,
              "ack",
              [sessionId, "control", "decline", controlSeq],
              {{ destination_id: fromId, channel_index: ackChannel }}
            );
          }}
          if (
            sessionId
            && link.mode === "pending_host"
            && link.role === "host"
            && String(link.session_id || "").trim().toLowerCase() === sessionId
            && normalizeNodeId(link.peer_id) === fromId
          ) {{
            boardGameResetNetworkLink(
              gameId,
              `${{reversiNodeLabel(fromId, safeState)}} declined your invite.`,
              {{ keepPeer: true }}
            );
          }}
          rememberBoardGameNetworkMessage(gameId, dedupeKey);
          continue;
        }}

        if (parsed.type === "leave") {{
          const sessionId = String(parsed.parts[2] || "").trim().toLowerCase();
          const controlSeq = Math.max(0, Math.trunc(Number(parsed.parts[3]) || 0));
          const link = refs.getLink();
          const ackChannelRaw = Number(link.channel_index);
          const ackChannel = Number.isInteger(ackChannelRaw) && ackChannelRaw >= 0
            ? ackChannelRaw
            : messageMeshChannelIndex(msg);
          if (sessionId && controlSeq > 0) {{
            void sendBoardGameProtocolMessage(
              gameId,
              "ack",
              [sessionId, "control", "leave", controlSeq],
              {{ destination_id: fromId, channel_index: ackChannel }}
            );
          }}
          if (
            sessionId
            && boardGameIsNetworkLinked(gameId)
            && link.session_id === sessionId
            && normalizeNodeId(link.peer_id) === fromId
          ) {{
            boardGameResetNetworkLink(gameId, `Peer ${{reversiNodeLabel(fromId, safeState)}} ended the match.`, {{ keepPeer: true }});
          }}
          rememberBoardGameNetworkMessage(gameId, dedupeKey);
          continue;
        }}

        if (parsed.type === "chat") {{
          const sessionId = String(parsed.parts[2] || "").trim().toLowerCase();
          const sentUnix = Math.max(0, Math.trunc(Number(parsed.parts[3]) || 0));
          const chatText = String(parsed.parts[4] || "").trim();
          const link = refs.getLink();
          if (!sessionId || !chatText) {{
            rememberBoardGameNetworkMessage(gameId, dedupeKey);
            continue;
          }}
          if (!boardGameIsNetworkLinked(gameId)) continue;
          if (link.session_id !== sessionId) continue;
          if (normalizeNodeId(link.peer_id) !== fromId) continue;
          ingestGamesQuickChatMessage({{
            key: `${{boardGameNormalizeId(gameId)}}-chat:${{dedupeKey}}`,
            game_id: boardGameNormalizeId(gameId),
            session_id: sessionId,
            from_id: fromId,
            text: chatText,
            unix: Math.max(reversiProtocolMessageUnix(msg), sentUnix),
          }}, safeState);
          rememberBoardGameNetworkMessage(gameId, dedupeKey);
          continue;
        }}

        if (parsed.type === "ack") {{
          const sessionId = String(parsed.parts[2] || "").trim().toLowerCase();
          const ackKind = String(parsed.parts[3] || "").trim().toLowerCase();
          const link = refs.getLink();
          if (!sessionId) {{
            rememberBoardGameNetworkMessage(gameId, dedupeKey);
            continue;
          }}
          if (String(link.session_id || "").trim().toLowerCase() !== sessionId) {{
            rememberBoardGameNetworkMessage(gameId, dedupeKey);
            continue;
          }}
          if (normalizeNodeId(link.peer_id) !== fromId) {{
            rememberBoardGameNetworkMessage(gameId, dedupeKey);
            continue;
          }}
          if (ackKind === "move") {{
            const ackSeq = Math.max(0, Math.trunc(Number(parsed.parts[4]) || 0));
            if (ackSeq <= 0) {{
              rememberBoardGameNetworkMessage(gameId, dedupeKey);
              continue;
            }}
            link.last_remote_ack_seq = Math.max(
              Math.max(0, Math.trunc(Number(link.last_remote_ack_seq) || 0)),
              ackSeq
            );
            if (ackSeq >= Math.max(0, Math.trunc(Number(link.local_move_seq) || 0))) {{
              link.status = `${{reversiNodeLabel(fromId, safeState)}} acknowledged your move.`;
            }}
            rememberBoardGameNetworkMessage(gameId, dedupeKey);
            continue;
          }}
          if (ackKind === "control") {{
            const ackControlType = String(parsed.parts[4] || "").trim().toLowerCase();
            const ackSeq = Math.max(0, Math.trunc(Number(parsed.parts[5]) || 0));
            if (!ackControlType || ackSeq <= 0) {{
              rememberBoardGameNetworkMessage(gameId, dedupeKey);
              continue;
            }}
            link.last_remote_control_ack_seq = Math.max(
              Math.max(0, Math.trunc(Number(link.last_remote_control_ack_seq) || 0)),
              ackSeq
            );
            if (ackSeq >= Math.max(0, Math.trunc(Number(link.local_control_seq) || 0))) {{
              link.status = `${{reversiNodeLabel(fromId, safeState)}} acknowledged ${{ackControlType}}.`;
            }}
          }}
          rememberBoardGameNetworkMessage(gameId, dedupeKey);
          continue;
        }}

        if (parsed.type === "move") {{
          const sessionId = String(parsed.parts[2] || "").trim().toLowerCase();
          const seq = Math.max(0, Math.trunc(Number(parsed.parts[3]) || 0));
          const fromRow = Math.trunc(Number(parsed.parts[4]) || -1);
          const fromCol = Math.trunc(Number(parsed.parts[5]) || -1);
          const toRow = Math.trunc(Number(parsed.parts[6]) || -1);
          const toCol = Math.trunc(Number(parsed.parts[7]) || -1);
          if (!sessionId || seq <= 0) {{
            rememberBoardGameNetworkMessage(gameId, dedupeKey);
            continue;
          }}
          if (boardGameNormalizeId(gameId) === "chess") {{
            if (!chessInBounds(fromRow, fromCol) || !chessInBounds(toRow, toCol)) {{
              rememberBoardGameNetworkMessage(gameId, dedupeKey);
              continue;
            }}
          }} else if (!checkersInBounds(fromRow, fromCol) || !checkersInBounds(toRow, toCol)) {{
            rememberBoardGameNetworkMessage(gameId, dedupeKey);
            continue;
          }}
          const link = refs.getLink();
          if (!boardGameIsNetworkLinked(gameId)) continue;
          if (link.session_id !== sessionId) continue;
          if (normalizeNodeId(link.peer_id) !== fromId) continue;
          const ackChannelRaw = Number(link.channel_index);
          const ackChannel = Number.isInteger(ackChannelRaw) && ackChannelRaw >= 0
            ? ackChannelRaw
            : messageMeshChannelIndex(msg);
          if (seq <= Math.max(0, Math.trunc(Number(link.remote_move_seq) || 0))) {{
            void sendBoardGameProtocolMessage(
              gameId,
              "ack",
              [sessionId, "move", seq],
              {{ destination_id: fromId, channel_index: ackChannel }}
            );
            rememberBoardGameNetworkMessage(gameId, dedupeKey);
            continue;
          }}
          const applied = boardGameNormalizeId(gameId) === "chess"
            ? applyChessMove(fromRow, fromCol, toRow, toCol, {{ source: "remote", suppress_outbound: true }})
            : applyCheckersMove(fromRow, fromCol, toRow, toCol, {{ source: "remote", suppress_outbound: true }});
          if (!applied) continue;
          link.remote_move_seq = seq;
          link.status = `${{reversiNodeLabel(fromId, safeState)}} played ${{boardGameMoveLabel(gameId, fromRow, fromCol, toRow, toCol)}}.`;
          void sendBoardGameProtocolMessage(
            gameId,
            "ack",
            [sessionId, "move", seq],
            {{ destination_id: fromId, channel_index: ackChannel }}
          );
          rememberBoardGameNetworkMessage(gameId, dedupeKey);
          continue;
        }}
        rememberBoardGameNetworkMessage(gameId, dedupeKey);
      }}

      const nowUnix = Math.floor(Date.now() / 1000);
      const nextInvites = refs.getPendingInvites()
        .filter((row) => (nowUnix - (Number(row && row.received_unix) || 0)) <= reversiInviteStaleSeconds)
        .slice(0, reversiInviteMaxRows);
      refs.setPendingInvites(nextInvites);
      if (refs.getSelectedInviteKey() && !nextInvites.some((row) => boardGameInviteKey(row && row.from_id, row && row.session_id) === refs.getSelectedInviteKey())) {{
        refs.setSelectedInviteKey("");
      }}
    }}

    function renderBoardGameInviteSeedDisplay(gameId, state = latestState) {{
      const refs = boardGameRefs(gameId);
      const host = document.getElementById(`${{refs.id}}-peer-selected-display`);
      if (!(host instanceof HTMLElement)) return;
      const peerId = gamesInviteSeedPeerId(state);
      if (!isCanonicalNodeId(peerId)) {{
        host.textContent = "Select a node in the list to choose an invite target.";
        host.classList.add("is-empty");
        return;
      }}
      const label = gamesInviteSeedPeerLabel(state);
      host.textContent = `${{label || peerId}} (${{peerId}})`;
      host.classList.remove("is-empty");
    }}

    function renderBoardGameInviteList(gameId, state = latestState) {{
      const refs = boardGameRefs(gameId);
      const listEl = document.getElementById(`${{refs.id}}-invite-list`);
      if (!(listEl instanceof HTMLElement)) return;
      const invites = refs.getPendingInvites();
      if (invites.length < 1) {{
        listEl.innerHTML = '<div class="reversi-invite-empty">No pending invites.</div>';
        return;
      }}
      if (!refs.getSelectedInviteKey()) {{
        const first = invites[0];
        refs.setSelectedInviteKey(boardGameInviteKey(first && first.from_id, first && first.session_id));
      }}
      const rows = invites.map((invite) => {{
        const fromId = normalizeNodeId(invite && invite.from_id || "");
        const sessionId = String(invite && invite.session_id || "").trim().toLowerCase();
        const whenUnix = Math.max(0, Math.trunc(Number(invite && invite.received_unix) || 0));
        const hostColor = boardGameParseColor(invite && invite.host_color, refs.defaultLocalColor);
        const inviteKey = boardGameInviteKey(fromId, sessionId);
        const inviteChannelRaw = Number(invite && invite.channel_index);
        const inviteChannel = Number.isInteger(inviteChannelRaw) && inviteChannelRaw >= 0 ? inviteChannelRaw : 0;
        const inviteChannelLabel = meshChannelLabelForIndex(inviteChannel, {{ compact: true, allowAll: false }});
        const inviteChannelBadge = meshChannelBadgeHtml(
          inviteChannel,
          inviteChannelLabel,
          {{
            allowAll: false,
            extraClass: "reversi-invite-channel-badge",
            title: meshChannelLabelForIndex(inviteChannel, {{ verbose: true, allowAll: false }}),
          }}
        );
        const selectedClass = inviteKey === String(refs.getSelectedInviteKey() || "").trim().toLowerCase()
          ? " is-selected"
          : "";
        const yourColorLabel = refs.playerLabel(refs.opponent(hostColor));
        return `<button
          type="button"
          class="reversi-invite-item${{selectedClass}}"
          title="${{escAttr(fromId)}}"
          data-from-id="${{escAttr(fromId)}}"
          data-session-id="${{escAttr(sessionId)}}"
        >
          <div class="reversi-invite-main">${{escAttr(reversiNodeLabel(fromId, state))}}</div>
          <div class="reversi-invite-meta">${{escAttr(fromId)}} • ${{escAttr(formatLocalChatTime(whenUnix, "now"))}} • ${{inviteChannelBadge}} • host ${{escAttr(refs.playerLabel(hostColor))}} • you ${{escAttr(yourColorLabel)}}</div>
        </button>`;
      }});
      listEl.innerHTML = rows.join("");
    }}

    function renderBoardGameLinkUi(gameId, state = latestState) {{
      const refs = boardGameRefs(gameId);
      renderBoardGameInviteSeedDisplay(gameId, state);
      renderBoardGameInviteList(gameId, state);
      const hostColorSelect = document.getElementById(`${{refs.id}}-host-color-select`);
      if (hostColorSelect instanceof HTMLSelectElement) {{
        hostColorSelect.value = boardGameParseColor(refs.getHostColorPreference(), refs.defaultLocalColor);
      }}
      const statusEl = document.getElementById(`${{refs.id}}-link-status`);
      if (statusEl instanceof HTMLElement) {{
        const linkMode = String(refs.getLink() && refs.getLink().mode || "local").trim().toLowerCase();
        const modeLabel = linkMode === "connected"
          ? "Connected"
          : (linkMode === "pending_host" ? "Pending Invite" : "Local");
        const modeClass = linkMode === "connected"
          ? "is-connected"
          : (linkMode === "pending_host" ? "is-pending" : "is-local");
        const statusText = String(refs.getLink() && refs.getLink().status || "Local hotseat mode.");
        statusEl.innerHTML = `<span class="games-link-mode-badge ${{modeClass}}">${{escAttr(modeLabel)}}</span><span class="games-link-status-text">${{escAttr(statusText)}}</span>`;
      }}
      const hostBtn = document.getElementById(`${{refs.id}}-host-btn`);
      const acceptBtn = document.getElementById(`${{refs.id}}-accept-btn`);
      const declineBtn = document.getElementById(`${{refs.id}}-decline-btn`);
      const disconnectBtn = document.getElementById(`${{refs.id}}-disconnect-btn`);
      const inviteSeedReady = isCanonicalNodeId(gamesInviteSeedPeerId(state));
      const pendingInvite = boardGamePendingInviteChoice(gameId);
      const link = refs.getLink();
      if (hostBtn instanceof HTMLButtonElement) {{
        hostBtn.disabled = !inviteSeedReady || link.mode === "connected" || link.mode === "pending_host";
      }}
      if (acceptBtn instanceof HTMLButtonElement) {{
        acceptBtn.disabled = !(pendingInvite && isCanonicalNodeId(pendingInvite.from_id));
      }}
      if (declineBtn instanceof HTMLButtonElement) {{
        declineBtn.disabled = !(pendingInvite && isCanonicalNodeId(pendingInvite.from_id));
      }}
      if (disconnectBtn instanceof HTMLButtonElement) {{
        disconnectBtn.disabled = !(link.mode === "connected" || link.mode === "pending_host");
      }}
      if (hostColorSelect instanceof HTMLSelectElement) {{
        hostColorSelect.disabled = link.mode === "connected" || link.mode === "pending_host";
      }}
    }}
