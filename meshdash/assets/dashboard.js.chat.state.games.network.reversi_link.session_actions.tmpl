    async function waitForReversiControlAck(checkAck, timeoutMs) {{
      const probe = typeof checkAck === "function" ? checkAck : null;
      if (!probe) return false;
      const windowMs = Math.max(500, Math.trunc(Number(timeoutMs) || 0));
      const pollMs = Math.max(80, Math.trunc(Number(gamesMoveAckPollMs) || 0) || 180);
      const deadline = Date.now() + windowMs;
      while (Date.now() < deadline) {{
        if (probe()) return true;
        await new Promise((resolve) => setTimeout(resolve, pollMs));
      }}
      return !!probe();
    }}

    async function sendReversiControlWithRetry(
      controlType,
      fields = [],
      {{
        destination_id = "",
        session_id = "",
        channel_index = null,
        status_label = "Control message",
      }} = {{}}
    ) {{
      const cleanType = String(controlType || "").trim().toLowerCase();
      const peerId = normalizeNodeId(destination_id || reversiLink.peer_id || "");
      const sessionId = String(
        session_id || reversiLink.session_id || (Array.isArray(fields) ? fields[0] : "")
      ).trim().toLowerCase();
      if (!cleanType || !isCanonicalNodeId(peerId) || !sessionId) {{
        return {{ sent: false, acked: false, seq: 0 }};
      }}
      const currentChannelRaw = Number(reversiLink.channel_index);
      const defaultChannel = Number.isInteger(currentChannelRaw) && currentChannelRaw >= 0
        ? currentChannelRaw
        : meshChannelEffectiveSendIndexForApp("games");
      const sendChannel = normalizeMeshChannelIndex(channel_index == null ? defaultChannel : channel_index);
      const seq = Math.max(0, Math.trunc(Number(reversiLink.local_control_seq) || 0)) + 1;
      const waitPlan = Array.isArray(gamesMoveAckWaitPlanMs) && gamesMoveAckWaitPlanMs.length
        ? gamesMoveAckWaitPlanMs
        : [2500, 3500, 5000, 7000];
      const label = String(status_label || "Control message").trim() || "Control message";
      const isAcked = () => {{
        const currentPeer = normalizeNodeId(reversiLink.peer_id || "");
        const currentSession = String(reversiLink.session_id || "").trim().toLowerCase();
        if (currentPeer !== peerId) return false;
        if (currentSession !== sessionId) return false;
        return Math.max(0, Math.trunc(Number(reversiLink.last_remote_control_ack_seq) || 0)) >= seq;
      }};
      let atLeastOneSent = false;
      for (let attemptIndex = 0; attemptIndex < waitPlan.length; attemptIndex += 1) {{
        if (isAcked()) return {{ sent: true, acked: true, seq }};
        const sent = await sendReversiProtocolMessage(
          cleanType,
          [...(Array.isArray(fields) ? fields : []), seq],
          {{ destination_id: peerId, channel_index: sendChannel }}
        );
        if (sent) {{
          atLeastOneSent = true;
          reversiLink.local_control_seq = Math.max(
            Math.max(0, Math.trunc(Number(reversiLink.local_control_seq) || 0)),
            seq
          );
          const attemptNumber = attemptIndex + 1;
          const totalAttempts = waitPlan.length;
          if (attemptNumber <= 1) {{
            updateReversiLinkStatus(`${{label}} sent. Waiting for ACK...`);
          }} else {{
            updateReversiLinkStatus(`${{label}} retry ${{attemptNumber}}/${{totalAttempts}}. Waiting for ACK...`);
          }}
        }}
        const acked = await waitForReversiControlAck(isAcked, waitPlan[attemptIndex]);
        if (acked) {{
          updateReversiLinkStatus(`${{label}} acknowledged by peer.`);
          return {{ sent: true, acked: true, seq }};
        }}
      }}
      if (atLeastOneSent) {{
        updateReversiLinkStatus(`${{label}} sent, but ACK has not arrived yet (high latency or packet loss).`);
        return {{ sent: true, acked: false, seq }};
      }}
      updateReversiLinkStatus(`${{label}} failed to send.`);
      return {{ sent: false, acked: false, seq: 0 }};
    }}

    async function hostReversiMatch() {{
      const peerId = gamesInviteSeedPeerId(latestState);
      if (!isCanonicalNodeId(peerId)) {{
        updateReversiLinkStatus("Select a node in the main list before hosting.");
        if (activeLayoutView === "games") renderGamesView(latestState);
        return;
      }}
      reversiPeerId = peerId;
      const hostColor = Number(reversiHostColorPreference) === reversiPiece.white
        ? reversiPiece.white
        : reversiPiece.black;
      const guestColor = reversiOpponent(hostColor);
      const sessionChannel = meshChannelEffectiveSendIndexForApp("games");
      const sessionId = generateReversiSessionId();
      reversiState = createNewReversiState();
      refreshReversiDerivedState({{ autoPass: true }});
      persistReversiState();
      reversiLink = createReversiLinkState({{
        mode: "pending_host",
        role: "host",
        session_id: sessionId,
        peer_id: peerId,
        channel_index: sessionChannel,
        local_color: hostColor,
        remote_color: guestColor,
        local_move_seq: 0,
        remote_move_seq: 0,
        local_control_seq: 0,
        last_remote_control_ack_seq: 0,
        status: `Invite sent to ${{reversiNodeLabel(peerId)}}. You are ${{reversiPlayerLabel(hostColor)}}; waiting for accept...`,
      }});
      removeAllReversiPendingInvitesFromPeer(peerId);
      const sendResult = await sendReversiControlWithRetry(
        "invite",
        [sessionId, normalizeNodeId(resolveLocalNodeId(latestState) || ""), reversiColorToken(hostColor), sessionChannel],
        {{
          destination_id: peerId,
          session_id: sessionId,
          channel_index: sessionChannel,
          status_label: "Invite",
        }}
      );
      if (!sendResult.sent) {{
        reversiLink.mode = "local";
        reversiLink.role = "";
        reversiLink.session_id = "";
      }} else if (sendResult.acked) {{
        updateReversiLinkStatus(
          `Invite delivered to ${{reversiNodeLabel(peerId)}}. You are ${{reversiPlayerLabel(hostColor)}}; waiting for accept...`
        );
      }}
      if (activeLayoutView === "games") renderGamesView(latestState);
    }}

    async function acceptReversiInvite() {{
      const invite = reversiPendingInviteChoice();
      if (!invite) {{
        updateReversiLinkStatus("No pending invite to accept.");
        if (activeLayoutView === "games") renderGamesView(latestState);
        return;
      }}
      const peerId = normalizeNodeId(invite.from_id || "");
      const sessionId = String(invite.session_id || "").trim().toLowerCase();
      const hostColor = Number(invite.host_color) === reversiPiece.white ? reversiPiece.white : reversiPiece.black;
      const guestColor = reversiOpponent(hostColor);
      const inviteChannelRaw = Number(invite.channel_index);
      const inviteChannel = Number.isInteger(inviteChannelRaw) && inviteChannelRaw >= 0
        ? inviteChannelRaw
        : meshChannelEffectiveSendIndexForApp("games");
      if (!isCanonicalNodeId(peerId) || !sessionId) {{
        updateReversiLinkStatus("Invite details are invalid.");
        if (activeLayoutView === "games") renderGamesView(latestState);
        return;
      }}
      if (
        reversiLink.mode === "pending_host"
        && isCanonicalNodeId(reversiLink.peer_id)
        && String(reversiLink.session_id || "").trim()
        && (
          normalizeNodeId(reversiLink.peer_id) !== peerId
          || String(reversiLink.session_id || "").trim().toLowerCase() !== sessionId
        )
      ) {{
        await sendReversiControlWithRetry(
          "leave",
          [reversiLink.session_id],
          {{
            destination_id: reversiLink.peer_id,
            session_id: String(reversiLink.session_id || "").trim().toLowerCase(),
            channel_index: Number.isInteger(Number(reversiLink.channel_index)) ? Number(reversiLink.channel_index) : meshChannelEffectiveSendIndexForApp("games"),
            status_label: "Leave",
          }}
        );
      }}
      reversiPeerId = peerId;
      reversiState = createNewReversiState();
      refreshReversiDerivedState({{ autoPass: true }});
      persistReversiState();
      reversiLink = createReversiLinkState({{
        mode: "connected",
        role: "guest",
        session_id: sessionId,
        peer_id: peerId,
        channel_index: inviteChannel,
        local_color: guestColor,
        remote_color: hostColor,
        local_move_seq: 0,
        remote_move_seq: 0,
        local_control_seq: 0,
        last_remote_control_ack_seq: 0,
        status: `Connected to ${{reversiNodeLabel(peerId)}}. You are ${{reversiPlayerLabel(guestColor)}}.`,
      }});
      removeReversiPendingInvite(peerId, sessionId);
      removeAllReversiPendingInvitesFromPeer(peerId);
      await sendReversiControlWithRetry(
        "accept",
        [sessionId],
        {{
          destination_id: peerId,
          session_id: sessionId,
          channel_index: inviteChannel,
          status_label: "Accept",
        }}
      );
      if (activeLayoutView === "games") renderGamesView(latestState);
    }}

    async function declineReversiInvite() {{
      const invite = reversiPendingInviteChoice();
      if (!invite) {{
        updateReversiLinkStatus("No pending invite to decline.");
        if (activeLayoutView === "games") renderGamesView(latestState);
        return;
      }}
      const peerId = normalizeNodeId(invite.from_id || "");
      const sessionId = String(invite.session_id || "").trim().toLowerCase();
      const inviteChannelRaw = Number(invite.channel_index);
      const inviteChannel = Number.isInteger(inviteChannelRaw) && inviteChannelRaw >= 0
        ? inviteChannelRaw
        : meshChannelEffectiveSendIndexForApp("games");
      removeReversiPendingInvite(peerId, sessionId);
      const sent = await sendReversiControlWithRetry(
        "decline",
        [sessionId],
        {{
          destination_id: peerId,
          session_id: sessionId,
          channel_index: inviteChannel,
          status_label: "Decline",
        }}
      );
      if (sent.sent) {{
        updateReversiLinkStatus(`Declined invite from ${{reversiNodeLabel(peerId)}}.`);
      }} else {{
        updateReversiLinkStatus(`Declined locally; failed to notify ${{reversiNodeLabel(peerId)}}.`);
      }}
      if (activeLayoutView === "games") renderGamesView(latestState);
    }}

    async function disconnectReversiMatch() {{
      const linked = reversiIsNetworkLinked() || reversiLink.mode === "pending_host";
      if (linked && isCanonicalNodeId(reversiLink.peer_id) && String(reversiLink.session_id || "").trim()) {{
        await sendReversiControlWithRetry(
          "leave",
          [reversiLink.session_id],
          {{
            destination_id: reversiLink.peer_id,
            session_id: String(reversiLink.session_id || "").trim().toLowerCase(),
            channel_index: Number.isInteger(Number(reversiLink.channel_index)) ? Number(reversiLink.channel_index) : meshChannelEffectiveSendIndexForApp("games"),
            status_label: "Leave",
          }}
        );
      }}
      resetReversiNetworkLink("Disconnected. Local hotseat mode.", {{ keepPeer: true }});
      if (activeLayoutView === "games") renderGamesView(latestState);
    }}
